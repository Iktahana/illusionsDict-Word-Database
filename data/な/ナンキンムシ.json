        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして造作もなく、彼の、南京虫だらけの巣へ投り込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫や蚤蚊に攻められながら、野羊の乳を飲み、アラビア人のコックの料理を食って、一八七二年の十二月十二日から翌年三月中旬にわたる単調な船住いをつづけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処は南京豆と南京米とそして南京虫の本場です。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "下から南京虫がごそ／＼と這い出してくる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫は、恐らく、硫黄や、黄燐くさい、栄養不良な工人の病的な肌の代りに、どうしたのか急に、汗と脂肪ぎった溌剌たる皮膚があるのを感じて、いぶかしげな顔をしただろう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……実際居留民の保護だけなら、何故、こんな不便な、きたないマッチ工場の南京虫がうようよしている寄宿舎に入れて置くかね？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つは家に南京虫が湧いた時です。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫なんだ」　だから、あんな奴は殺してもいいと、ラスコリニコフみたいに呟いている自分に、しかし鶴雄はどきんとしたのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れぬ風土の寒風はひとしおさすらいの身に沁み渡り、うたた脾肉の歎に耐えないのであったが、これも身から出た錆と思えば、落魄の身の誰を怨まん者もなく、南京虫と虱に悩まされ、濁酒と唐辛子を舐めずりながら、温突から温突へと放浪した。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は直ちに、水夫｜二人にかつがれて、最も震動と、轟音のはなはだしい船首の、彼の南京虫だらけの巣へ連れ込まれた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫がその南京虫の待ちくたびれている巣へもぐり込んだのは、午前一時前十五分であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッハッハハハハハ、蚤と南京虫のだろう！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは蚤と南京虫の資本家！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫は物の隙間にその生を保つ。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事を忍べば忍ぶ程、兄夫婦やその子は私を馬鹿扱いにし、嘲けり笑い、私が卸した許りの手拭いで泥の手をふいたり、私の茶碗へつぶした南京虫を一杯入れたり、六神丸を無断で売って、その金を使って了ったり、私が買った炭を平気で盗み、その度に私へ悪口をつくのです。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーヴの上に虱や南京虫が落ちると、プツン、プツンと、音をたてて、人が焼ける時のような生ッ臭い臭いがした。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処から出てくるか、夜通し虱と蚤と南京虫に責められる。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "）――身体が蟹の汁で汚れる、それがそのまま何日も続く、それで虱か南京虫が湧かない「筈」がなかった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかには、蝎、南京虫、虱など、いずれも夜となく、昼となく、我々を悩ませました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝎に螫されると命を失うと云うので、虱や南京虫に無神経の苦力らも、蝎と聞くと顔の色を変えました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝎　南京虫は日本にもたくさん輸入されているから、改めて紹介するまでもないが、満洲の夏において最も我々をおびやかしたものは蝎であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫を恐れない満洲の民も、蝎と聞けば恐れて逃げる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝎も南京虫とおなじく、人家の壁の崩れや、柱の割れ目などに潜んでいる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも南京虫とは違って、その毒は生命に関する。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その代り、お前んとこで、ただの一匹でも南京虫が俺を刺したが最後、擲りつけて呉れるぞ、誓つて擲りつけて呉れるぞ、このおいぼれ魔法使女め！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと旅屋を見つけて、泊り込むと、直ぐと南京虫がちくちく螫しに来るので、迚も寝つかれない。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川氏はその一刹那、若い男の懐中で百円札が幾枚か南京虫のやうに身を縮かめてゐるやうに思つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾ながら愛相がつきまして……」　店員は南京虫のやうにそこらの手さげ鞄かシヤツの縫ひ目に潜り込んでしまひたいやうな表情をした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
