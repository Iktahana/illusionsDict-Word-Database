        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もし人情話も落語の一種であるというならば、円朝の話し口は少しく勝手違いの感があるべきであるが、自然に聴衆を惹き付けて、常に一時間内外の長丁場をツナギ続けたのは、確かにその話術の妙に因るのであった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "次期をうけ持つ大隅・光造それに清八の協力が、安徳帝入水の長丁場を見事な成績で演じたことであつた。",
              "citation": {
                "source": "文楽の光明",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから叔父と対座した長丁場の二六時中、怪獣が泣き喚いた賑やかな時間でさへ、この黒々とした想念の雲は、私の脳漿にからみついて離れない。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古河を今朝たって野木、間々田、小山、それから二里の長丁場でこの小金井。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "長丁場で、駕籠かきがすこしくたびれてくると、主水正、「ホイ、投げ銭だ……」　と駕籠の中から、パラパラッと銭を投げる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三味線堀は佐竹右京太夫様のお上屋敷、あれからいたしまして、吾妻橋の袂といいますから、かなりの長丁場。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "へっ、いいかげん長丁場だなア」「ねえ、旦那。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "長丁場で気の毒だけれども南鐐でいいかえ」「二｜朱か。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れては乘り、屈託しては歩き、十二里の長丁場を樂々と征服して、藤澤へあと五六町といふところまで來たのは、第一日の申刻過ぎ――。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お局お六",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れては乗り、屈託しては歩き、十二里の長丁場を楽々と征服して、藤沢へあと五六町というところまで来たのは、第一日の申刻（四時）過ぎ――。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お局お六",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所は筋違御門（今の萬世橋）の籾御藏跡あたりから、片側町の柳原を、和泉橋から新し橋を經て、淺草御門前の郡代屋敷あたりまで、かなりの長丁場ですが、昔は恐ろしく淋しいところ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げるんやないぞ」　長丁場になると踏んで将昭は権利書を持ったまま、大きな音を立てて階段を降りていった。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れもしない、青山から本所の両国停車場までの長丁場を、ぼくと母とは人力車にゆられて行った。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろ長丁場を、素通しのトラックで飛ばして来たんだからねえ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも厚和から上海までの長丁場だ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二十四日（水曜）　九時起き、ＰＣＬ迄、又これから此の長丁場を毎日自動車で通ふかと思ふとうんざりだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも長丁場だから時間はある。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
        }
