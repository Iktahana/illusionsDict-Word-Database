        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "物腰がやわらかで、無口で、そうして、ひどい泣き虫の女であった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先王も、わしも、幼い時から泣き虫でした。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくには、太宰治が泣き虫に見えてならぬ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この泣き虫は、しかし、岩のようだ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつかり挑戦すると美智子は奥の手の泣き虫を発揮するし、美智子の母はさうするとやつぱり其方に加勢して「何だね、小ちやな者を相手にしてムキになるなんて！",
              "citation": {
                "source": "美智子と日曜日の朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふ泣き虫な子だらう、僕は苦々しく思つた。",
              "citation": {
                "source": "晩秋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はほんとに泣き虫だよ、だから兄さんにからかはれるんだよ。",
              "citation": {
                "source": "晩秋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "千之介の泣き虫はこの頃の癖で厶ります。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は弱虫で泣き虫で、意気地なしなのよ、私のやうに弱虫になつたら生きては行けなくなりますよ。",
              "citation": {
                "source": "背負ひ切れぬ重荷",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁の感情がどう細かに動いているかも知らず、老人は泣き虫であるからしかたがないと思うからである。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き虫で学校でも友達をうまく作れないジョブズは、野球やフットボールなどの団体スポーツになじめなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "組合役所の二階はその頃から文法学校で（今日でも小学校に使われている）、そこへわれわれの憐むべきウィリは七つの年から泣き虫の勉強ぎらいの生徒として六年間通い、古代英語の書体を稽古したり（彼は生涯イタリア書体は書かなかった）、ラテン語の初歩を暗誦したりした。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居や映画などで、いつも私のことを泣き虫だと笑っていた彼だ。",
              "citation": {
                "source": "死ね！",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き虫だと彼から笑われた私は、不覚にもまた涙をこぼした。",
              "citation": {
                "source": "死ね！",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不良少年の中でも、特別、弱虫、泣き虫小僧であったのである。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱虫の泣き虫小僧の不良少年の手である。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、心配した近所の人たちが相談して、必ず、泣き虫がなほる「荒熊病院」へ入院させました。",
              "citation": {
                "source": "泣き虫の小ぐまさん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、すつかり、泣き虫が、なほつたさうです。",
              "citation": {
                "source": "泣き虫の小ぐまさん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又泣き虫の多次郎は？",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがままで、きかん坊で、そのくせ泣き虫だった私を、素直な強い子にするために、母はさぞかし心を砕いていたのだろうと、これまたこのごろしきりに思われる。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　さて、ひとりっ子というものは、わがままっ子のきかんぼうが育つものですが、林太郎はどっちかといえば、いくじなしの泣き虫子にそだちました。",
              "citation": {
                "source": "あたまでっかち",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうじゃないかね、お爺さん」と彼はイーヌィチをふりむいて笑いだした、「私という人間は、自分が百姓婆さんでボロ雑巾で、泣き虫のめそめそ野郎だもんで、めそめそしたことは我慢がならんのです。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはただ気取りや見え坊のためにあんなポオズを択んでゐたが、つまらぬ泣き虫野郎であつた。",
              "citation": {
                "source": "井伏鱒二は悪人なるの説",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊ちゃんは未だ七つか八つで、泣き虫だ。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お粂か、お玉か」「お玉だよ」「あの可愛らしいのが、お轉婆で、泣き虫で、あまり利口ではないけれど」　それはまた、八五郎に取つて一つの魅力だつたことでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼女",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かというと直ぐ痙攣る、神経質な、泣き虫な彼は、揺籃の時から、自分をとり繞んだ、むせるような熱愛の中で、まるで温室の植物のような発育を続けた。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずう体に似合わない泣き虫。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "引捉えて来た造船所連の告げるところによると、この泣き虫は今早朝、ある漁師の家の附近にうろついているところを、大勢してとっつかまえて、必死に抵抗するのを、ようやくのことで縄にかけて来たのだとのこと。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この、泣き虫め」　と、台所の縁へ、菅笠を抛り出した。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
