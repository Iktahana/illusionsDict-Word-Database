        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これほどにも情深く、心根のやさしい人があるかと思い、ヘルンに対して、何かいじらしく涙ぐましいものさえも感じたというのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに考えることは人生への或る涙ぐましい思慕の情と、或るやるせない寂寥とである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは漂泊の芭蕉の心に、或る純情な、涙ぐましい、幽玄な「あわれ」を感じさせた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶井君と三好君との交際は、側で見てさへ羨ましいほど親密で、しかも涙ぐましいほどに純情だつた。",
              "citation": {
                "source": "本質的な文學者",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "異性もなく金もなく、いつも飢ゑて都會に放浪してゐた頃の彼を思ふと、私はいつも涙ぐましい思ひがする。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何がなし、その純情の美しさが心をひき、涙ぐましい「いぢらしさ」が感じられ、そこに或る何かの意味深いもの、世の常の思想に表現できない神祕の意味を感じさせる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間の心の歩みは尊く涙ぐましい。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲社の特種に鼻を明かされて乙社がこれに匹敵するだけの価値のある特種を捜すのに「涙ぐましい」努力を払うというのは当然である。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟を正して、夢中になって、涙ぐましい程ゾクゾクと共鳴して観ておりながら、何故そんな気持になるのか説明出来ない芸術である」　というのが衆口の一致する処らしい。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇ましいとも、美しいとも、尊いとも、勿体ないとも、涙ぐましいとも、何ともかんともたとえようのない人間美の現われでなければならぬ。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には平常向い合って話していると、あの風采がソックリそのまま、実にタヨリない、涙ぐましい位のお坊ちゃんに見えて来る。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども冒頭からもう涙ぐましい気持にされていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみならず勃凸がどれほどおんつぁんを便りにし、その身の上をも懸念してゐるかゞ感ぜられると、私は妙に涙ぐましい気分にさへなつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此のありさまを、高い二階から先生が、あら玉の春着きつれて醉ひつれて　涙ぐましいまで、可懷い。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗いカンテラの灯の前に立って、その縁日玩具をうろうろと猟っていた少年時代を思い出すと、涙ぐましいほどに懐しく思われます。",
              "citation": {
                "source": "我楽多玩具",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑平老から涙ぐましいほど温かい手紙がくる、さつそくビール代や新聞代の借銭を払ふ、荷が軽くなつて吻とする。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は天満宮参詣をやめて旧友Ｍ君を訪ねる、涙ぐましいほど歓待してくれた、奥さんもお嬢さんも、おばあさんまで出てきて、私の与多話を聞いて下さつた、十時近く、帰宿して熟睡。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒と米とを持つてくることを忘れない彼は涙ぐましい友情を持ちつゞけてゐる、彼に幸福あれ、おとなしく飲んで、いつしよに寝る、一枚の蒲団も千枚かさねたほどあたゝかだつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い遠い實在への涙ぐましいあこがれである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　このおほいなる愛と無心のたのしき日影たのしき浪のあなたにつれられて行く心もちは涙ぐましい。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙ぐましい夕暮　これらの夕暮は涙ぐましく、私の書齋に訪れてくる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送る人、見送られる人の感情にまで、さばかり涙ぐましい「忘却の悦び」を感じさせるところの、あの古風なるスコツトランドの旋律は！",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛には全く論理がなく、その情操は純一に感傷的で、女性的に、柔和であって涙ぐましい。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して抒情詩は、主に恋愛や別離を歌い、その情操は哀傷的、情緒的で、優美にやさしく涙ぐましい。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にリリカル（抒情詩的）という言葉は、常に哀傷的で涙ぐましい情緒を指してくる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いの面目これに過ぎたるは無く、そのお優しくこまかい、おいたはりには、他人の私どもでさへ、涙ぐましい思ひが致しました程でございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢語の所謂戦袍で、斎藤実盛の涙ぐましい談を遺したのも其の鎧直垂に就いてである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一同涙ぐましい程失望した。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クーパーは、かすんでよく見えない両眼をみはって、いまどんなことが、じぶんの周囲に起こっているかを見定めようと、なみだぐましい努力をしている。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "クイーン・メリー号が遭難してからこっちのかれのなみだぐましい奮闘ぶりには、仇敵といえども拍手をおくらずにはいられないだろう。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
