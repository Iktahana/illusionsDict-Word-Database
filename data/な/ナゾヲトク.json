[
  {
    "uuid": "3d3db02f-b123-5118-a694-c375dbbc3dfd",
    "entry": "謎を解く",
    "reading": {
      "primary": "なぞをとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
