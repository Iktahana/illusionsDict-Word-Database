    "definitions": [
      {
        "index": 1,
        "gloss": "to break down crying",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ワッと泣き伏す雪枝の姿。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "典六「御助勢申すとも」　雪枝「有難う存じます」と其の場に嬉し泣きに泣き伏す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "感極まってワッと泣き伏す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "君江も、Ｔ「長七さん」　と嬉しそうに抱き付いて泣き伏す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は寄って母親の胸に泣き伏す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく私のすがたを見つめているうちに、私には面皰もあり、足もあり、幽霊でないということが判って、父は憤怒の鬼と化し、母は泣き伏す。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き伏すところなどでも肩の運動一つでその表情の特徴が立派に表現される。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ野田山の墳墓を掃いて、母上と呼びながら土に縋りて泣き伏すをば、此上無き娯楽として、お通は日課の如く参詣せり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おみのは呆れた體にて弟の顏をぢつと眺めてゐたりしが、やがてわつと地に泣き伏す。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀も気丈な女ながら、ここに到ってこらえかね、人前もはばからず、泣き伏す。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さして行く笠置の山、と仰せられては、藤原季房ならずとも、泣き伏すにきまっている。",
              "citation": {
                "source": "一燈",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（泣き伏す）――ばかな女、いや狐だな。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「省さん、わたしは嬉しい」　ようよう一こと言ったが、おとよはまた泣き伏すのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウヌ生ふざけて……親不孝ものめが、この上にも親の面に泥を塗るつもりか、ウヌよくも……」　おとよは泣き伏す。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬頭粗服、風采あがらざる一老書生なりしに、それを蜀山人とは、如何にして知り給ふぞと問へば、凡そ天下ひろしといへども、今の世、蜀山人ならで、かゝる句を咏み得るものあらむやと言はれ、吉原第一も今日限りと、齒をくひしばり、わつとばかり泣き伏す。",
              "citation": {
                "source": "牛經",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おいよはテーブルの上に泣き伏す。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "静まりきった夜の空気の中に、時々鼻をかみながらすすり上げすすり上げ泣き伏す痛ましい声だけが聞こえた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は、今にも夫人が、ノートの上に瓦破と泣き伏すことを予期していた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（思はずわーつと泣き伏す）…………。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（取り乱して泣き伏す。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お冬は思わず和吉にしがみつこうとして又躊躇し、やがてわっと泣き伏す。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（父の膝に泣き伏す。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は、今にも夫人が、ノートの上に瓦破と泣き伏すことを予期してゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜も娘の死を思うて、易々とは寝付かれないと見えまして、ウトウトしたかと思うと、『おとしおとし』と、叫んで、狂気のように跳ね起きて布団の上に端座して、何やらブツブツと申すかと思うと、又さめざめと泣き伏すのでありました。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "板谷だったら、膝に泣き伏すことも出来る。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　泣き伏す事は、一層彼の人の胸をあおりたてるようだったけれど、私は自分がみじめに思えて仕方がなかった、別れた男との幾月かを送った此部屋の中に、色々な幻が泳いでいて私をたまらなくした。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "板谷だつたら、膝に泣き伏すことも出来る。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂気のような養策、泣き伏す看護婦、警察の人々、親類縁者、近所の人々、診察に来る患者などがゴッタ返した。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が大船の窓の火ややに消えゆき、唯だ一つ残れる最後の薄き光に、われ外より硝子ごしにさし覗けば、われならぬ面やつれせしわが影既に内にありて、あはれ君が棺の前にさめざめと泣き伏すなり。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（泣き伏す）紳二　　死んでくれつて云ふのか？",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
