        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と何はさておき、お祖母さんがいつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私は、何はさておき、娘の籍をこしらえておかねばならんと考えたのです。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておき今の日本人は今の日本語を巧みに用いて弁舌の上達せんことを勉むべきなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど考えてみるとあまりハキハキした言葉でも仕事でもないが、癖になっていると病気のようなもので、何はさておき、ちょっと巡回して来ないと気がすまないのだ。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておき、あの子も人並の身なりはせにゃならんし、とまあいった次第でな。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドヤドヤとくりこんで来た月輪組の連中は、ただちに階上の二間をぶっ通して借りきって旅の汗を洗いにただちに風呂場へ駆けおりる者、何はさておき酒だ酒だとわめくもの、わるふざけて女中を追いまわす者――到着と同時にもう家がこわれるように大にぎわい。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておき、こうして衆人の前で、はずかしめられた良人という滑稽な役割を演じたり、あまつさえ、いろんな潤色まで施して自分がこうむった凌辱を事こまかに描き出して見せるのが、彼にとっては愉快なばかりか、気休めにさえなったものらしい。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておきハーマンの普段着だ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておき、ローラ・コルテス嬢は真珠の窃盗で告発された。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと戸惑ってはいるが、何はさておき親分に忠実だ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておき、厄介なことになった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "国へ帰ったら、何はさておきボルトン・ガーデンへ招待しますわ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "大統領のお力添えを」「何はさておき、命は惜しいからな」「とにかく何も失いません。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "全ての材料がそろい、ヤマは面白そうだし、何はさておき記者｜冥利に尽きる。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておき、既発売「アントロジイ・ソノール」のレコードを手に入れるのは、今日ではなかなかむずかしいことであるが、幸いにして所有している人は、もう一度｜筐底から取り出して、古人の心意気を味わってみるがよい。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておき、お抱え弁護士に渡しなさい」「そうだ、そうだな。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておき、食堂の謎を解明しました。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はさておき、大衆は不安を一掃できるかどうか知りたいでしょうし、もし調子が悪ければ、あなたもすぐ出走取り消し出来るでしょう。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼んでいらっしゃる」　何はさておきと、駈けだして行った。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを草木に譬うれば、緑の柳、紅の花と現れる世の変化も思想なる根より起こるものであるから、なにはさておき根の培養は怠れない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにはさておきモータが新式だ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
