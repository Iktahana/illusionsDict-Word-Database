[
  {
    "uuid": "b856771b-1101-5bd0-a108-5402aed4749e",
    "entry": "内戦",
    "reading": {
      "primary": "ないせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
