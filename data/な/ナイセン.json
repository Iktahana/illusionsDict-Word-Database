      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "civil war",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "内戦の折は、最初ジャクスン将軍の部下、のちにフッド将軍に従い大佐まで昇進しましたが、リー軍の降伏とともに農園に戻り、三・四年は続けました。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにはあるいは国内戦争がもちあがるかもわからぬ。",
              "citation": {
                "source": "一つの世界",
                "author": "――私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いボルシェビキで、国内戦のときは、一方の指揮者となって戦ったプロレタリア作家タラソフ・ロディオーノフが、本気な顔をしているのは当然だ。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小説は作者オストロフスキーがロシアの国内戦当時自身経験し又見聞した歴史を描いたものであり、多分正宗白鳥氏であったかは、この作品の題材と筆致とを批評して、期待した程の感動を受けなかったと言っておられたと思う。",
              "citation": {
                "source": "ヒューマニズムへの道",
                "author": "――文芸時評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一七年から二〇年までの、国内戦の後、ソヴェトはレーニンのいわゆる「勝利のための退却」をして国内産業へ個人資本の流用を許した。",
              "citation": {
                "source": "文壇はどうなる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　国内戦当時から、ソヴェトには、新しいプロレタリア作家が、どんどん現われた。",
              "citation": {
                "source": "文壇はどうなる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トゥルビーン家の数日」という国内戦時代の中ブルジョア層を主題にした脚本などは一九二七・八年モスクワ芸術座で上演され、ひどく評判だった。",
              "citation": {
                "source": "新たなプロレタリア文学",
                "author": "――アレゴリーと諷刺――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一九一七年から国内戦にかけての時代に存在したソヴェト作家の数・質と、一九四〇年代、この第二次大戦に際して世界的に活躍したソヴェト作家たちの数と質とに見られる必然的な飛躍である。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七年から国内戦時代に出現した新しいソヴェト作家たちの才能は、やはりもとの社会からひきついでの、偶然性と自然発生によるものであった。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "デニキン、コルチャック、ウランゲルらによる国内戦と飢饉と大移動と、それにたいするボルシェヴィキの奮闘などは、ロシアの全人民に無限の経験とエピソードとをもたらした。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内戦時代のたたかいの結果、失明し全身不随となった若いオストロフスキーが、同志と家族にたすけられつつ、その生涯の終りに「鋼鉄はいかに鍛えられたか」という長篇小説をのこした。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術座小舞台で「我等の青春」という国内戦時代のコムソモール（青年共産同盟員）たちの感情、若さから誤謬は犯しながら雄々しく実践でそれを清算する働きぶりなどを歴史的に見た劇を上演している。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（革命の国内戦やヨーロッパ戦争で負傷した人々だ。",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、五年ずつ先へ先へと、生産拡張の予想計画というのをたててソヴェト同盟は、着々、欧州大戦と国内戦とで低下した生産能力を高めつつあった。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内戦を経て、勇ましい階級的闘士をウンと出した婦人の基本的文化も一般的に云えば低かった。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内戦、饑饉、チブスの中から、不屈な革命的大衆の力でソヴェト同盟の新文化がモリモリせりあがって来たのだ。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バーベリが、短い強い文体で独特な手法を示しながら国内戦の豊富な大衆的経験を主題とする短篇を発表しはじめた。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時ソヴェト同盟の民衆は、謂わば「俺等のあの時分の日記」でも読みかえして見るように、国内戦時代にかかれたそれらの作品を愛読した。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも大して面白い小説も出ないじゃないか」「どれもこれも国内戦だな。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現や描写の不完全な作品をよんでもそのすき間を補ってゆくような国内戦時代の自分達の経験、或る場合には感傷を持ち合せていない。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学の主題としての、国内戦は、記録文学の時代をすぎて既に革命の歴史的観点から、丸彫りにして再現さるべき時になっている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファジェーエフの「壊滅」、ショーロホフの「静かなドン」などはよい作品だが、国内戦は局部的に扱われているのである。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内戦の時代にくらべれば、革命後十年を経た建設期の日常の事件は、今は地味なものとなった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内戦当時、コムソモールと政治部員はやっぱり絵で飾った三等列車や貨車にのって、あらゆる地方をまわった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生産の場所での日常の闘争へ参加し、国内戦時代とは性質のちがう建設期のソヴェト・プロレタリアートの英雄的行動を観察し、記録し、活々とした芸術品にまとめようとする。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内戦時代は赤衛軍の指揮官をやって、現在国際革命文学局の書記をしている作家タラソフ・ロディオーノフが、彼の指導するモスクワの大金属工場「鎌と鎚」の文学研究会で、丸い赤鼻を一層赤くして、こう批判したようなものが出来る。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一七―二一年の困難な国内戦の期間、農民がうけもった革命的役割は「赤のパルチザン」の功績にハッキリと現れている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内戦はまだ鎮まらない。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで「パルチザン」は国内戦当時におけるソヴェト農民大衆の革命的役割の見本であるが、農民作家は、では「赤いパルチザン」の業績を、芸術活動で、どう記録しているだろうか。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内戦のときにトポーロフはパルチザンを組織し、コルチャック軍と闘った。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
