      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seducer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう友達の中にも硬派と軟派と二種類あって、その硬派の首領株からはだいぶいじめられた。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カタイ大ッピラな燐寸工場以外、硬派と軟派を兼ねているからだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの硬派、軟派は、新聞社内の二つの区別じゃ勿論なかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、阿片、モルヒネ、コカイン、ヘロイン、コデイン等を扱う商売が軟派だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い、広い、渾沌たる支那内地に居住する外国人の多くは、この硬派か軟派かを本当の仕事としていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "硬派は軟派よりはもっと仕事が困難だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟派が曝露して罰金や牢屋ですむところを、硬派は命をかけなければならなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "邦人達は、たいてい、この軟派を仕事としている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、支配人が、しょっちゅう、大々的に、硬派と軟派と兼ねて禁制品を扱いながら、一度もあげられたためしがないのを知っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　硬派でも軟派でも、細々と、小心に、ちょっとずつ扱っている人間は、発覚すると、自分自身の血税で、そのつぐないをつけさせられている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「郷票をかっぱらうんなら、まだ分るが、鐚一文もない軟派の娘をかっぱらってどうするんだい。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ高等学校では、硬派と軟派と対立していて、軟派の生徒が、時々、硬派の生徒に殴られたものですが、私が、このような大軟派の恰好で街を歩いても、ついに一度も殴られた事がない。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大軟派といっても、それは形ばかりで、女性には臆病でした。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来明治の文壇と称したものは、江戸末期に於ける軟派文学の継続であり、純然たる国粋的｜戯作風のものであったが、これが延長なる今日の文壇も、本質に於て昔と少しも変っていない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そうでなくても、元来年の割にませていて、彼等上級生達の思い上った行為に対しても時として憫笑を洩らしかねない彼のことだし、それにその頃から荷風の小説を耽読する位で、硬派の彼等から見て、些か軟派に過ぎてもいたので、これは上級生達から睨まれるのも当然であったろう。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええか、おい、ちょっと男前や思て、ひとのスメ（娘）に手エ出しやがって、それで済む思てけつかんのか、おれを誰や思てけつかんのや、道頓堀の勝いうたら、お前みたいな、へなちょこの軟派とちょっと違うネやぞ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と問掛けて、後談を聞くべく、病室の寝床の上で、愁然としてまず早や頭を垂れたのは、都下京橋区尾張町東洋新聞、三の面軟派の主筆、遠山金之助である。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "性欲的に観察して見ると、その頃の生徒仲間には軟派と硬派とがあった。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟派は例の可笑しな画を看る連中である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟派は数に於いては優勢であった。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外は中国一円から東北まで、悉く軟派である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖硬派たるが書生の本色で、軟派たるは多少｜影護い処があるように見えていた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺足袋小倉袴は硬派の服装であるのに、軟派もその真似をしている。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "只軟派は同じ服装をしていても、袖をまくることが少い。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断紺足袋で外出しても、軟派は好く町湯に行ったものだ。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟派は二階を当にして行く。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の想像では、埴生は生れながらの軟派であるので免れるのだと思っていたのである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらかと云えば軟派で、女色の事は何でも心得ているらしい。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗組員は艦長の勝麟太郎（海舟）ら九十六｜人、ほかに日本の近海を測量にきて、なんぱしたアメリカの海軍士官ブルック大尉ら十｜人がのりました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
