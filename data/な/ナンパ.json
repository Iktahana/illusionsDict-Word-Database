[
  {
    "uuid": "fb1fa62a-6422-53d0-bb61-1bfbf81fbcb5",
    "entry": "軟派",
    "reading": {
      "primary": "なんぱ",
      "alternatives": [
        "ナンパ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
