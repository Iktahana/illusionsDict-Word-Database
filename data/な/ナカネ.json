        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "』『まあ、なかなかね。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでお寺のちいさなかねがなるようじゃ。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが魚を一つ買うのにもこの頃はこういう微妙なかねあいのところを通っているということに、もう少し深く考えられてかかることだろうと思う。",
              "citation": {
                "source": "龍田丸の中毒事件",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなかねがあるのか？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "床につくと、いつもは十分もたたぬうちに眠つてしまう私も、この夜はなかなかねつかれなかつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さん、まだなかなかね」と泣きそうな鼻声を出した。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウーンあんなこんなかねて期せざる御縁辺はお互いにネ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も警察は恐っかなかねえけんどな。",
              "citation": {
                "source": "前夜",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方からぶっつからないうちにとめる、そのわずかなかねあいです。",
              "citation": {
                "source": "ばかな汽車",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それが、学生さんにはなかなかねえ……まあ、よくお考えなすっては如何ですか。",
              "citation": {
                "source": "浅間噴火口",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "県や市の衛生課、医師会、警察、みんなかねての計画どおり手際よく救護陣を敷いた。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "定臣　　へえ、そんなかねえ。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）まだなかなかね……。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中を使ふのはなかなかね。",
              "citation": {
                "source": "写真（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の上でなきしきっていたせみの声もいつしかしずまり、かなかなのこえだけ、小さなかねをたたくように聞えて、あたりは夕もやにつつまれてきました。",
              "citation": {
                "source": "あたまでっかち",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人に向つては日本式でやれ、これがプリンシプルなんです」「それぢや、安里さんも、なかなかね」　こんなことを、ぽつりぽつりと、両方で云ひ合つて、またしばらく黙り込んだ。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにが楽しいのかと思うほど、よく笑うよ」　京野等志は、床にはいつても、なかなかねつかれなかつた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいからだの工合はどんなかね。",
              "citation": {
                "source": "幸福への意志",
                "author": "DER WILLE ZUM GLUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だけど、ホントに僕の顔はこんなかね？",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝晩のこと、マアこの位がいいところでしょう、九時台はなかなかね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客さんは将校じゃなかね。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、つまらねえ」「つまらなかねえだ、ちょうゐ斎先生は剣術の神さまみてえに偉えだよ、あんまり偉えだで、世間がうるさくってなんねえ、人が放っておかねえだで、あんまりうるさくってなんねえから、この山ん中へ逃げて来さしっただよ」　弥市はむきになって云った。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえーおっどろいた、そんなに古いとは知らなかった、へえー、そんなかね、だけどそんなに古い学問をおれたちがならって、まだなにか役に立つことがあるのかい」　茅野先生そのときは、いつもよりずっと濃い代赭色になった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔と違う」「昔の地主さんもサン／″＼のようですけれど、新しく地主になった僕達のところだって、税が高いから一向駄目ですよ」「それは察している」「肥料と税金で半分は持って行かれてしまいます」「そんなかね？",
              "citation": {
                "source": "田園情調あり",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょうど一月でございますのよ」「ははあ、そんなかね、もう。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのばんは、うちにかえって、ベッドにはいってからも、それが気になって、なかなかねむれませんでした。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとすれば、それは自分の体のなかね。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリエイティヴな、しかも無形にちかいながらも一種のコミュニティのための仕事と、単純なかねもうけとが、どこでどのように接しあうのかという面白い問題をはらみながらすべてはまだ未解決だ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に「その後の工合はどんなかね？",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春泥って、写真を見ると仲々好男子だが、実物もあんなかね」　私は段々好奇心を起して、こんなことを聞いて見た。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
