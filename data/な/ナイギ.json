    },
    "definitions": [
      {
        "index": 1,
        "gloss": "your wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スタンドにゐるお内儀さんは、時々怪訝さうな眼付をその方にやつてゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所のお内儀さんなどが通りがかりに児をあやすと、嬉しそうな色が父親の柔和な顔に漲る。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝長屋　井戸端でお内儀さん二三人の立ち話し。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端のお内儀が囁き合った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「綺麗なひとは倖せね」　と言ったのを小耳にはさんだ三次が、　お内儀に「どうしたんです」と訊く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お内儀が、Ｔ「何でも立派な剣道の先生とかが是非お嫁にと仰しゃって」　聞いて三次情け無かった。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも長屋のお内儀二三人、ワイワイ話している。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お内儀連、キャッキャッ笑う。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鯵かしらん」　すると、畳敷の方の柱の根に横坐りにして見ていた内儀さん――ともよの母親――が、は　は　は　は　と太り肉を揺って「みんなおとッつあんに一ぱい喰った」と笑った。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑貨店の内儀に緒を見せて貰いながら、母は、「藤よ、そんなに店の物をいらいまわるな。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と内儀は愛相を云った。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、他の内儀達に皮肉られた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸文字屋の内儀は邪推深い、剛慾な女だ。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭や小僧から買うよりも、内儀から買う方が高い、これは、村中に知れ渡っていることである。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内儀が火鉢の傍に坐りこんでじろ／＼番頭や小僧の方を見ている。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今云い出すと却って内儀に邪推されやしないだろうか？",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の傍に坐りこんでいる内儀の眼がじろりと光る。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　不意に、内儀の癇高い声がひびく。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「身共買った覚えはないぞ」　伊吉がいいえ、Ｔ「村上様のお内儀様で御座います」　「なんじゃ家内が？",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「お内儀さんが借りて来たんです」　提灯の大写。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "２７＝表　舟宿のお内儀に送られて来た太郎左衛門が浪之助に、Ｔ「では明日の晩」　「頼んだぞ」　と言い残して去る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送って浪之助、お内儀に、Ｔ「船頭どもは大丈夫だろうな」　お内儀が意味あり気に笑った。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六が此の間の奴は、Ｔ「あの侍ですよ旦那」　右門お内儀を呼びとめて、　十手を示して、Ｔ「明日の晩どうかしたんですか」　お内儀「いいえ」Ｔ「其処のお寺で結構なお説教が御座います」　と言ってお内儀は家の中へ――　伝六、右門に、Ｔ「あのお寺ですよ旦那」　と言う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "追って来た伊吉続いて入ろうとして、お内儀にとめられた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「お類さんがッ」　「来ている筈だ」　「そんな御方は来て居りません」　「いま見たんだ」Ｔ「早く帰らぬと御主人様が心配なさる」　とお内儀を押しのけて入る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本服を着なれないぎごちなさで、白襟をきつく合わせているその娘は、大股に、すこし右肩をよけい振るような膝ののびた歩きつきで人通りの間を尾張町へ出た。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、引くことの出来ないぎりぎりの間に兄弟は立っていた。",
              "citation": {
                "source": "野に臥す者",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」　彼らは彼ら自身すら知らない間に、相ついで近づいた、そして近づいたということは、それが合図なように重い二人の肉体が揉みあう機会を、もう、外すことができないぎりぎりのところに追いつめていた。",
              "citation": {
                "source": "野に臥す者",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでずいぶんお客様の感情を損ねた場合もあるが、その代り、もうこれより勉強の出来ないぎりぎりの決着の値をつける。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の彼はまだ、こんな風に描写できるだろう――背が高く、痩せていて、ブロンドで、勉強家の目を持ち、いくぶん猫背で、身だしなみにはどこかだらしなく、魅力的というよりは罪のないぎこちなさが目立った。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
