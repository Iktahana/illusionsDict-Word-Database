[
  {
    "uuid": "fc55c393-9968-5a33-b107-813c2b2270fd",
    "entry": "鳴きたてる",
    "reading": {
      "primary": "なきたてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to chirp loudly (insects, birds, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秋もはじめのころの、学校の前の松の木山のうれに、たくさんのからすがむれて、そのやかましく鳴きたてる声が、勉強のじゃまになる、ある晴れた日の午後であった。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへにわとりは声をそろえて、コッケコー、コッケコーと鳴きたてるので、そのさわぎといったら、まったく耳もつぶれるほどでした。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴きたてるこほろぎ、その声が身にしみわたる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは、いつもいやな声で、カアカア鳴きたてるくせに、今日はどうして黙ってるのかしら。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "木蔦のからんだ壁に群がってる雀が、騒がしく鳴きたてる。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "木つつきは始終島を見まわって人の影さえみれば咎めでもするように鳴きたてる。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか遠くのほうから、はげしく鳴きたてる犬の声が聞こえてきます。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、どうでせう、そのたんびに、おほきい方の犬がウワ※といふのと一しよに、ピエロは、ひどくかみつかれたやうに、キヤン／＼なきたてるのです。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、カエルたちはがんこで、ひっきりなしに、「アク、アク、アク」と、なきたてるばかりです。",
              "citation": {
                "source": "うまい商売",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伸子はよろこんで、「ほら、いるでしょう」ときょうもなきたてる鵞鳥の群を見せた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
