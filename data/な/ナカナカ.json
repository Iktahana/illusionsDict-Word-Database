    },
    "definitions": [
      {
        "index": 1,
        "gloss": "very",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしそれではあまり体面に関するので、夫人が是非フロックコートを新調するようにすすめたが、頑として中々きかない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの悪い病です』といって、中々許してくれないので、書斎はますます乱雑になるばかりであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は素人考えで何でも楽器は指の先で弾くものだから女に適したものとばかり思うていたが中々そんな浅いものではない。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の一室狭けれども今宵はゆるやかに寝るべしと思えば船中の窮屈さ蒸暑さにくらべて中々に心安かり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹名を書いた札のついてゐるのは有難いが中々一度見た位では覚えられさうもない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の本館から下方の山腹にはもう人家が少く、色々の樹林に蔽はれた山腹の斜面が午後の日に照らされて中々美しい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處の湯元から湧き出す湯の量は中々豐富らしい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の秋になつて病氣の工合が大分よくなつたし、醫者も許し又すゝめてくれたので、何處かへ試しに行つて見ようと思ふと、生憎なもので時候外れの霖雨がしばらくつゞいて、中々適當な日は來なかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯空で考へるだけでは題目は中々出て來ないが、何か一つつゝき始めると其の途中に無數の目當てが出來過ぎて困る位である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが中々｜永かったのでこっち側に居る私たちは実際あきてしまいました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "折ふしの風邪に取みだしたる姿はづかしく、中々の御目通りに絶かね參らする事のつらければ、免し給へ、又こそとて、何もうはべは美はしくして使ひを歸しぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って清水のお貸元の身内になるんだ」　「石松、お前ん処の父っつあんあれで中々昔はやくざ仲間で鳴らした男だってね」　「何んだって、父っつあんがやくざ？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "儂はこう言う話が至って好きでね」　「爺っつあん、中々話せるね。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次中々承知しない。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜かんとするが中々抜けぬ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこれ早く致せと叱りとばし、さて、Ｔ「では早速お帰り下さりますよう」　なりひらが中々動かない。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまが団九郎に、Ｔ「妾なんぞが　御一緒に　お供して」　と言って、Ｔ「御迷惑で　御座いましょうね」　団九郎が中々もって迷惑どころか、却って喜んで居りまする。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな工合だか、お前には中々分るまい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題の解決は中々付かない。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾の考えではあなた中々見こみがあるわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言ふ中、浮木がグイと沈んだから合すと、餌釣としては、中々大いのが上つた。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六、　「ヘヘン、中々言えませんよ」　右門が、　「誰だ、言えよ」　伝六、　「へ……」Ｔ「当てて御覧なさいよ旦那」Ｔ「誰だか言って御覧なさいよ」　右門が、Ｔ「当てて見ろ伝六」　「アッ、嫌ンなっちゃうな」　と伝六。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども尽くる時には尽き易き金銀にて、光りを磨きし餝屋とて日本の長者の名ありしものも、今は百貫目に足らぬ身代となり、是にては中々今までの格式を追ひ難しと急に分別極めて家財を親類に預け、有り金を持つて代々の住所を立退き、大阪の福島に坊主行義の世帯して北に見渡す野山の気色に自ら足れりとしける。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな工合で互に励み合うので、ナマケル奴は勝手にナマケて居るのでいつまでも上達せぬ代り、勉強するものはズンズン上達して、公平に評すれば畸形的に発達すると云っても宜いが、兎に角に発達して行く速度は中々に早いものであったのです。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまあただ文章の上だけの話でありますが、其から「浮雲」其物が有した性質が当時に作用した事も中々少くはなかったように覚えています。",
              "citation": {
                "source": "言語体の文章と浮雲",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「中々容易ぢゃなかったんでせう。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが中々永かったのでこっち側に居る私たちは実際あきてしまひました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "度々のことで面倒だから、今度から止めにして、先へ勝手に寝ることにしろと何度も言うが、妻は婦道に背くと言い、なかなか承知しないので困っている云々（大意）と。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も、なかなかの、田舎者ですが、私のさとは、彼の生れ在所より、更に十里も山奥でありますから、何をかくそう、私は、もっとひどい田舎者なのであります。",
              "citation": {
                "source": "田舎者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理性や知性の純粋性など、とうに見失っているらしく、ただくらげのように自分の皮膚感触だけを信じて生きている人間たちにとっては、なかなか有り難い認識論である。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
