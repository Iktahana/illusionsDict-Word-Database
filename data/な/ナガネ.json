    "definitions": [
      {
        "index": 1,
        "gloss": "sleeping a long time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
