    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stranger",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名護屋山三郎の様なのは、かぶき者・無頼漢で、芸能のあつた――其為、幸若舞の詞も、お国に伝へたらしい――傭兵風の流れ者でもあつたのだ。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "居酒屋にはホセのほかにも一人の土方がだるまを相手にしてゐたが、彼等はこの土地の鈍重な自然人とは種属がちがつて、流れ者の度胸と機に応ずる才智があつた。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはば流れ者の生活であつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばかッ、そういうまねは、流れ者か、碌でなしのすることで、れっきとした先祖代々からの百姓のすることだねえど。",
              "citation": {
                "source": "荒蕪地",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一流れ者の小忰であるＡは、ここ数年の間、大泥棒、大親分として、ひそかに村人の、伝統的な英雄崇拝感といったようなものを満足せしめていたのである。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそくもとの一流れ者の小忰に還元されてしまい、横目でにらんでふふんとやられてしまった。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "居酒屋にはホセのほかにも一人の土方がだるまを相手にしていたが、彼等はこの土地の鈍重な自然人とは種属がちがって、流れ者の度胸と機に応ずる才智があった。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は承知の上で、卑しい流れ者と結婚した。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ来たのは我家の始祖がトリガーセンの流れ者だったからですよ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに流れ者ってことですよ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにも生活の根を持たない、流れ者のような浮草のような、つかみどころを見せない、しかし不思議な存在感のある、妙に気持ちのなかに残る女性、というような役柄だ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらくして別れたが、流れ者にはよくあることだ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
