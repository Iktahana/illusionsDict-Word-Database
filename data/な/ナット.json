        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本年末は島田、光井の方へ毛布二枚つづきお送りしたのみならず、自身のために『ロンドン・タイムス』の文芸付録とアメリカの『ＴＨＥ　ＮＡＴＩＯＮ』誌を一年予約しました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "共和党からの候補者には、パリでＮＡＴＯの最高指令官をやっていたアイゼンハワー元帥が、えらばれた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばワシントンのホワイトハウスやパリ郊外のＮＡＴＯ司令部だ。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "納豆屋の「ナットナットー、ナット、七色唐辛子」という声もこの界隈では近ごろさっぱり聞かれなくなった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は怜悧で、ココナットの実を日向に乾かして割る術をも心得ている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャクモンが『一八二八｜至三二年｜印度紀行』一にジャグルナット行の巡礼葉竹の両端に二つ行李附けて担い行李ごとに赤布片を付ける、林中の虎を威すのだとあるが、そんな事で利く事か知らん。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロジェクトによる成果をまとめてＣＤ―ＲＯＭを作り、売上げの一部を資金援助にまわしてきたウォルナット・クリーク社の販売成績が落ちてきたといった問題が、一度に噴き出しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナットというのは、その外周が六角形で、内周は円になっているが、ここに外周が十六角形のナットがあると仮定しよう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このナットの外径は二〇ミリ、内径は五ミリほどとする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その五円玉と中心を一致させて、ナットを上にのせる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このナットの上にまた五円玉を重ねる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五円玉の、ナットの外にはみだした部分がヴェランダ、内径のほうにはみだした部分が、中央階段の周囲をめぐっている廊下になる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいから、入れってば」　さっきの十六角形のナットを、もういちど思いだしてほしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸ッ子の住家であるかないかは、ナットーの買いぶりや、喰いぶりを見るが一番よくわかるということを予てから聴いていたが、彼等売り子の話を聞くと、成る程とうなずかせられる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この箱代が五銭するのかね」と聴いたら、「新婚の御夫婦や何かは、大きな声でナットー屋アなんかとおっしゃりにくいと見えましてね、こちらがお気に召すらしいのですよ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと口に栗と云っても、ここらの国々に多い栗の木は、普通にホース・チェストナットと呼ばれて、その実を食うことは出来ないと云います。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速に支度をして、ベーカーストリートの停車場から運ばれてゆくと、ガーデンの門前にゆき着いて、先ずわたしの眼をひいたのは、かのホース・チェストナットの並木でした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、近所の理髪店へ行って、きのうはキウ・ガーデンからハンプトン・コートを廻って来たという話をすると、亭主はあの立派なチェストナットを見て来たかと云いました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口に栗と云っても、ここらの国々に多い栗の木は、普通にホース・チェストナットと呼ばれてその実を食うことは出来ないと云います。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速に支度をして、ベーカーストリートの停車場から運ばれてゆくと、ガーデンの門前にゆき着いて、先ずわたしの眼をひいたのは、彼のホース・チェストナットの並木でした。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大河内氏の著書は、鶏小舎を改造せる作業場の中で、ズボンをつけ、作業帽をかぶりナット製作をしている村の娘たち、あるいは村の散髪屋を改造せる作業場で、シボレー自動車用ピストンリングの加工をしている縞のはんてんに腰巻姿の少女から中年の女の姿、その他の写真で飾られている。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者達が起きる時分で、一太が大きな声で、「ナットナットー」と呼んで歩くと、「ちょいと、納豆やさん」とよび止められた。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度のインターナショナルの言葉で『ココナットの実』と申しますオモチャを二つ持っております。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその『ココナットの実』を、きょう中に二つとも、ある人の手に渡すので御座います。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方は、お姫様がよく御存じの方で御座いますが……そうしますると、その『ココナットの実』が、その方と、それから矢張り、お姫様がよく御存じのモウ一人の方の運命を支配致しまして、お二方ともお姫様のところへは二度とお出でになる事が出来ないような、恐ろしい運命に陥られる事になるので御座います。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "タッタ今ハッキリと思い出したわ」「その約束をキット守って下さるなら、このオモチャを……おいしい『ココナットの実』を貴女に一つ分けて上げます。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの畸狂変態の世界を作り出した種々な手法には、さしずめ、書庫にあるグイド・ボナットー（十三世紀伊太利のファウストと云われた魔術師）の『点火術要論』やヴァザリの『｜祭礼師と謝肉祭装置』などの影響が窺われるね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
