        "examples": {
          "standard": [
            {
              "text": "トラックの荷台から、大量の木材が地面に投げ下ろされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "漁師たちは、獲れた魚を船から埠頭に投げ下ろした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "建設現場では、クレーンで資材を投げ下ろす作業が行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "博士邸がいま飛行機から投げ下ろす爆弾によって爆撃されようとしているのだった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "険に寄って姿を隠し、大石大木を投げ下ろす様子が秩序立っていて隙がない。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試練の嵐　空魔艦のなげおろす爆弾は、いよいよ氷上にぶつかった。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
