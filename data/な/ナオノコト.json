    "definitions": [
      {
        "index": 1,
        "gloss": "all the more",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女給ときたら尚のことだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこの和尚のことだと、少しも不思議ではなかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は苦勞性であつて、いろんなことをほじくり返して氣にするものだから、尚のこと眠れなかつたのであらう。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藥で赤い私の額のためによけい氣もひけて、尚のことこんな反撥をしたのであつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、これでも自身の知覚のデリケエトを、なんだか高尚のことに思って、それを頭のよさと思いちがいして、こっそり自身をいたわっていたところ、なかったか。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれから、この話を、その焼和尚のことから始めようと思う。",
              "citation": {
                "source": "再度生老人",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉の『笈の小文』を讀むものは、あの中に鑑眞和尚のことに關した記事を見つけるであらう。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会人にとっては尚のことだ。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとったと思えば尚のこと、せめて一年に一度ぐらいは、自分で描きたいものを描いてみたい気がしてなりません。",
              "citation": {
                "source": "帝展の美人画",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "」田中が大村と一緒でないことが尚のことうれしいに違いなかった。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い夢におびやかされたと後で分ったけれど、このことがあってから清子は尚のこと姑の側を離れないようにした。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧侶くさみの少しもない闊達な老人で、ここから十里あまりへだてた温海という温泉場では、この和尚のことを、ああ、あの名僧かと人はいう。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、どうしてもシックリしない情熱を統制しなければならない勝気なお花さんも苦しかつたに違ひないが、太郎さんは尚のこと苦しかつたに相違ない。",
              "citation": {
                "source": "訣れも愉し",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガンマ和尚のことばはおだやかであるが、ここはまさしく怪星ガンの中だ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の奴等は丈が低いから、少しのび上ると帽子ごしによく見える、何でも時代行列なんで、ディオゲネスが桶に入って来るかと、思うと、女学生の撥っかえりが、クレオパトラに化けて大勢の黒ン坊を従えて来る、独逸面のまずいクレオパトラは人を馬鹿にしているが、その奴隷になる学生は尚のこと気が知れない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "客も大当り、店は尚のこと大当り、神様の加護がある場所だ」　しかし店は繁昌しなかった。",
              "citation": {
                "source": "餅のタタリ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "手型を盗んだ人があると知って、尚のこと疑いを深めております」「安彦兄さんの身長を記憶しておられませんか」「記憶しません」「お嬢さんは銃声をききましたか」「いいえ」「実は、安彦さんは、復員してきたばかりではないのですよ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は尚のこと打撃時代であり、彼のスマートな守備ぶりがいかほどプロ的であっても、あの貧打でベストメンバーにはいる筈はありえないのである。",
              "citation": {
                "source": "戦後新人論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い先祖代々の位牌、青山家の古い墓地、それらのものを預けてある馬籠の寺のことから、そこに黙って働いている松雲和尚のことがしきりに半蔵には問題の人になって来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世を捨てて僧に成ってさえ決して心了せないものを布衣でいたなら尚のこと心は満足しないだろう。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こッちがわが子とは思わないのに、わが子と称する怪物は尚のこと万が一にした方が清々としてよろしいようなものだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことがあつたので、尚のことＨさんの眼は敏感にはたらいたわけなのでした。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや人に媚びたり、あるひはわれとわが心に媚びるときに女人の唇辺によく浮ぶ、あの無心または有心の嬌羞では尚のことなかつた。",
              "citation": {
                "source": "鸚鵡",
                "author": "『白鳳』第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら、尚のこと。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから此方、品子の奴がいぢめてエへんやろか、あんぢよう懐いてるやろか思うたら、もうその事が心配でなあ、毎晩夢に見るぐらゐだすねんけど、福子の前やつたら、そんなことちよつとも云はれしまへんよつてに、尚のことこゝが辛うて／＼、………」と、庄造は胸を叩いてみせながらべそを掻いた。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから此方、品子の奴がいじめてエへんやろか、あんじょう懐いてるやろか思うたら、もうその事が心配でなあ、毎晩夢に見るぐらいだすねんけど、福子の前やったら、そんなことちょっとも云われしまへんよってに、尚のことここが辛うて辛うて、………」と、庄造は胸を叩いてみせながらべそを掻いた。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつとでも暗いことのある仕事はすまいとなると尚のことさうですし、主人は勿論暗いことが大嫌ひで、私だつてその主義ですから、とてもやり切れませんわ。",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンデン　えゝ、それはさうでせうけれど――さういふ病人にこそ、尚のこと醫者の必要があるのぢやないのでせうか。",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟木　だから尚のこと――いや、仮りにそうだとしてもだな。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も、ごぞんじ無いのだ、と私は苦しさを胸一つにおさめて、けれども、その事実を知ってしまってからは、なおのこと妹が可哀そうで、いろいろ奇怪な空想も浮んで、私自身、胸がうずくような、甘酸っぱい、それは、いやな切ない思いで、あのような苦しみは、年ごろの女のひとでなければ、わからない、生地獄でございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
