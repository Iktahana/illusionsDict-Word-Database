    "definitions": [
      {
        "index": 1,
        "gloss": "address (on an envelope)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕の手紙を書く名宛も、生活の祕密を語る友も、天地にただ君一人しか居なかつた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "園が手紙を取りだした時、星野とだけ書いてある封筒の裏が上になっていたので、名宛人が誰であるかはもとより判りようはずがないのに、園の顔にはふとある混乱が浮んだようにも思え、少しもそんなことがないようにも清逸には思えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其より御國許へ飛脚を飛して、御用の儀これあり、諸役人ども月番の者一名宛殘止まり、其他は恩田杢同道にて急々出府仕るべし、と命じ給ひければ、こはそも如何なる大事の出來つらむと、取るものも取り敢へず、夜に日についで出府したり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻木大佐は痛く打悦び、『君に其决心があるなら屹度出來ます、鐵車の製造所は、我が秘密造船所内の何處かに設け、充分の材料は私の方から供給し、また君の助手としては、毎日午前午後に交代に、四｜名宛の水兵を遣はす事に致しませう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "すず子はその名宛が誰れであらうともみんな自ら開封した。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は家へ帰ると、早速、幸子の名宛で別荘へ遅れる旨の電報を打った。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして名宛の左側の、親展とか侍曹とか至急とか書くべきところに、閑事という二字が記されてあった。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなある日、一代の名宛で速達の葉書が来た。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人物の性格通り、名宛もきっちり、筆跡もぐらつかずくっくりしていて、あたかも書斎で書かれたかのようだった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にビーズ入りのバッグを開いてみると、新しいハンカチが二枚と、六円二十何銭入りの蟇口と、すこしばかりの化粧道具を入れた底の方から、柳川ヨシエという名宛の質札が二枚出た。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにマンネリングのお父さんからの丁寧な手紙がつけてありましたが、それは私の名宛であったので、読んでから焼いてしまいました。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "差出し人はＭ丸乗組みの印度船員某、名宛人は院長及び副院長となって、その内容はほぼ次の通りの英文であった。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒゲの家には両親や兄弟が居り、その方からも私の名宛で（私たちの間だけで呼ばれていた名で）レポが入ってきた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして各々の大臣の秘書役として、大臣文学者の門を叩いてゐる文学青年のうちで最も意久地のなさゝうな一人を夫々一名宛挙げて、秘書役になぞらへて痛棒を喰はせた皮肉な見立なのであつた。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一枚の葉書に二人の名宛を書いた。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其赤塗の表には名宛も何も書かないで、真鍮の環に通した観世撚の封じ目に黒い墨を着けてあつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民学校の校舎が重傷者の収容所に充てられ、部落から毎日二名宛看護に出ることになつてゐた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい」「ここへ置きますよ」　配達夫の立ち去った後で、お光はようやく店に出て、框際の端書を拾って茶の間へ帰ったが、見ると自分の名宛で、差出人はかのお仙ちゃんなるその娘の母親。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "表書きは確かにわたしの名宛てになっているが、筆跡には記憶がない。",
              "citation": {
                "source": "謎の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤塗の表には名宛も何も書かないで、真鍮の環に通した観世撚の封じ目に黒い墨を着けてあった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二十五｜番地ぢやなくつて」と細君は答へたが、宗助が名宛を書き終る頃になつて、「手紙ぢや駄目よ、行つて能く話をして來なくつちや」と付け加へた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには皆坂井の名宛が書いてあつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は箔の剥げた古い額を一二｜枚讀んで歩いたが、不圖一窓庵から先へ探し出して、もし其所に手紙の名宛の坊さんがゐなかつたら、もつと奧へ行つて尋ねる方が便利だらうと思ひ付いた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小野清三様」と子昂流にかいた名宛を見た時、小野さんは、急に両肱に力を入れて、机に持たした体を跳ねるように後へ引いた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "状袋へ名宛を書くときに、森本の名前を思い出そうとしたが、どうしても胸に浮ばないので、やむを得ず大連電気公園内娯楽掛り森本様とした。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて名宛を認め終ると、「ただ通り一遍の文言だけ並べておいたらそれで好いでしょう」と云いながら、手焙の前に翳した手紙を敬太郎に読んで聞かせた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは私の失念だ」　田口は再び手紙を受け取って、名宛の人の住所と番地を書き入れてくれた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら賃銀は貰ったって、こんなあてのない仕事は厭だ、今年はもうだめなんだ、来年神官でも呼んで、よくお祭をしてから、コンクリーで底からやり直せと、まあ私たちは大丈夫のやうなことを云ひながら働いたもんです。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは矢島の陋劣なあてこすりだったのだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女の病的な内気さも追々溶け何か生命の緒を優しく引きほぐされて行くようなあてもない明るさが、かの女の生活にいつか射し添っているのであった。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
