    "definitions": [
      {
        "index": 1,
        "gloss": "southerly (wind)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
