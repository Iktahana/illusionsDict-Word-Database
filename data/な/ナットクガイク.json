    "definitions": [
      {
        "index": 1,
        "gloss": "to accept (e.g. an explanation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
