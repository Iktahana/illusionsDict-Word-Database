  {
    "uuid": "3092701a-b5d6-55d7-af89-08a10f8710b0",
    "entry": "綯う",
    "reading": {
      "primary": "なう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to twine (fibers to make rope)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "釣瓶縄をすげかへる、私自身が綯うた棕梠縄である、これで当分楽だ、それにしても水は尊い、井戸や清水に注連を張る人々の心を知れ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の老人が庭前の蓆の上で縄を綯うていた。",
              "citation": {
                "source": "怪人の眼",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茶を一ぱい飲ましてくれ」　老人は縄を綯う手を止めて顔をあげたが不審そうに云った。",
              "citation": {
                "source": "怪人の眼",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪心を以て見るが故に、藁を綯うて造りたる縄も蛇体と見えるのぢや。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御存じでございませんか、今の男は、夫役に来て縄を綯うておりました者でございますが」「そうか気が注かざったが、彼の鼻のひしゃげた老人か」　老人かと云うなり権兵衛は体を崩して倒れてしまった。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒を見て縄を綯うのじゃない。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも莞爾々々して、亡くなる前日まで縄を綯うたりせっせと働いて居ました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒をつかまえて縄を綯うような、ブマなことをしでかした自分を、米友は歯痒く思って地団駄を踏みました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉門次は炉辺で火を焚きながら縄を綯うている、どうも登山の支度をしてはいないらしい、何だか訝しく思うて聞いて見ると、穂高の案内なら昨夜の中に伝えて下さればよかった、と快く承知し、支度もそこそこ、飯をかっこみ、四十分ばかりで出発した。",
              "citation": {
                "source": "穂高岳槍ヶ岳縦走記",
                "author": "鵜殿正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "反つてそれから来る温さに感謝して、秋の、冬の長い夜な夜なを、繩を綯うたり、草鞋を編んだりして、夜を更かさねばならなかつた。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ盗人を捉えて繩を綯うような話です。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒を捕えて縄を綯うようだが、なかなか油断してはいかぬ。",
              "citation": {
                "source": "吾人の文明運動",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、白雲が知識の足らないために、芸術を理解することの妨げを痛感して、泥棒を捉まえて縄を綯うよりも、モット緩慢な仕事を、この画面の前で始めたのは、事のそれほど、画面そのものが白雲の研究心を誘う力あるものと見なければならない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日々工場に出て麻を綯う（鼻緒のしんをつくる）仕事に従っていた。",
              "citation": {
                "source": "その人",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "口があいていて、私は仲間に「綯うとき、ここに麻がひっかかって痛いんだよ。",
              "citation": {
                "source": "その人",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と、心にさけんだ時はすでに、ガリガリガリッと、刀身と細い鎖とは、縄を綯うように、縒られていたのである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に唾し、藁を素ごき、掌と掌を合わせて綯う力にも、何か傍目にも分る熱気がこもっていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "祕佛萩原朔太郎つゆしものうれひはきえず、わづかなるつちをふむとて、あなうらをやぶらせたまふ。",
              "citation": {
                "source": "祕佛",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか有田の乞食婆の喰っていたあの唐辛子のかかった真赤なうどんと、ポツオリの旗亭のトマトのかかった赤いスパゲッティとの類似のためであろうとも思われない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、この頃でもやはりときどきは「鷹を貰い損なう」ことがあるような気がするのである。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と偉さうに咳ばらひを一つして、「よい眺めぢやなう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹脂の香に　朝は悩まし　　うしなひし　さまざまのゆめ、森竝は　風に鳴るかなひろごりて　たひらかの空、　　土手づたひ　きえてゆくかなうつくしき　さまざまの夢。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等のものゝ大部分はみんなうちの庭や建物の一部を寫生したものである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上品なうへに粋だつた。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらいつか蝎はじぶんのからだがまっ赤なうつくしい火になって燃えてよるのやみを照らしてゐるのを見たって。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてほ〔ん〕たうにそのまっ赤なうつくしいさそりの火は音なくあかるくあかるく燃えたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "直次、其方は死なうと思ふや。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は社に向ってゆく、空は未だ全く暗くなってはしまわぬ、右手の農家の前では筒袖をきて手拭を冠った男が藁しべなどを掃いている、左手の何か大きい四角の石で女らしいのが頻りに藁を打って居る、夜なべに縄をなうか、草履でもつくるのであろう。",
              "citation": {
                "source": "八幡の森",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その訳は、人間の頭で考え得られる大概の事は昔のギリシア人が考えてしまっている、それだからギリシアの戦術を研究すれば何かしらきっと今度の戦争に役に立つような、参考になるようなうまい考えの掘出しものが見付かるだろう、というのであった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、そうすることによって結局は奉公の第一義にかなうことが出来るという自分勝手な考えもありはしたが、とにかく興味の向くことなら何でも構わず貪るように意地汚くかじり散らした。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
