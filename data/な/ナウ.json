    "definitions": [
      {
        "index": 1,
        "gloss": "to do ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "祕佛萩原朔太郎つゆしものうれひはきえず、わづかなるつちをふむとて、あなうらをやぶらせたまふ。",
              "citation": {
                "source": "祕佛",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか有田の乞食婆の喰っていたあの唐辛子のかかった真赤なうどんと、ポツオリの旗亭のトマトのかかった赤いスパゲッティとの類似のためであろうとも思われない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、この頃でもやはりときどきは「鷹を貰い損なう」ことがあるような気がするのである。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と偉さうに咳ばらひを一つして、「よい眺めぢやなう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹脂の香に　朝は悩まし　　うしなひし　さまざまのゆめ、森竝は　風に鳴るかなひろごりて　たひらかの空、　　土手づたひ　きえてゆくかなうつくしき　さまざまの夢。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等のものゝ大部分はみんなうちの庭や建物の一部を寫生したものである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上品なうへに粋だつた。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらいつか蝎はじぶんのからだがまっ赤なうつくしい火になって燃えてよるのやみを照らしてゐるのを見たって。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてほ〔ん〕たうにそのまっ赤なうつくしいさそりの火は音なくあかるくあかるく燃えたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "直次、其方は死なうと思ふや。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は社に向ってゆく、空は未だ全く暗くなってはしまわぬ、右手の農家の前では筒袖をきて手拭を冠った男が藁しべなどを掃いている、左手の何か大きい四角の石で女らしいのが頻りに藁を打って居る、夜なべに縄をなうか、草履でもつくるのであろう。",
              "citation": {
                "source": "八幡の森",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その訳は、人間の頭で考え得られる大概の事は昔のギリシア人が考えてしまっている、それだからギリシアの戦術を研究すれば何かしらきっと今度の戦争に役に立つような、参考になるようなうまい考えの掘出しものが見付かるだろう、というのであった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、そうすることによって結局は奉公の第一義にかなうことが出来るという自分勝手な考えもありはしたが、とにかく興味の向くことなら何でも構わず貪るように意地汚くかじり散らした。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありあけながい疾患のいたみから、その顔はくもの巣だらけとなり、腰からしたは影のやうに消えてしまひ、腰からうへには藪が生え、手が腐れ身体いちめんがじつにめちやくちやなり、ああ、けふも月が出で、有明の月が空に出で、そのぼんぼりのやうなうすらあかりで、畸形の白犬が吠えてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながい疾患のいたみから、その顔はくもの巣だらけとなり、腰から下は影のやうに消えてしまひ、腰から上には藪が生え、手が腐れ身体いちめんがじつにめちやくちやなり、ああ、けふも月が出で、有明の月が空に出で、そのぼんぼりのやうなうすらあかりで、畸形の白犬が吠えてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして丁寧に死なうとしたらそれの出來る金持どもすら、そんなことには無精になり、無關心になつてしまつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "白く透き通る切片は、咀嚼のために、上品なうま味に衝きくずされ、程よい滋味の圧感に混って、子供の細い咽喉へ通って行った。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の瀟洒なフランス流の友人河村は日本の女によって恋の重荷をになう。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋々々の壁の伝説のニデイアの像のかけられた下を快楽のために奴隷にされたフィリッピン人の拳闘家が、床下を犬のように這いながらときどき兇暴なうなり声を出した。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふふふふ、弱いなうお前等は……」　定めてあの張作霖がそんな風に相好を崩してのけぞり返つただらうと思ふと、その昔馬賊の荒武者だつたといふ人のよさも想像されて、無殘な爆彈に血染められたと言ふその最後が傷ましくも感じられはしないだらうか？",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、家のようなうず高い薪の堆積にぐいと力を入れた。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその翌日からは、散歩ごとに六蔵を伴なうことにして、機に応じていくらかずつ知能の働きを加えることにいたしました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『忘れ得ぬ人は必ずしも忘れてかなうまじき人にあらず、見たまえ僕のこの原稿の劈頭第一に書いてあるのはこの句である。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れてかなうまじき人といわなければならない、そこでここに恩愛の契りもなければ義理もない、ほんの赤の他人であって、本来をいうと忘れてしまったところで人情をも義理をも欠かないで、しかもついに忘れてしまうことのできない人がある。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "上がり口の四畳半が玄関なり茶の間なり長火鉢これに伴なう一式が並べてある。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本書紀第十六巻に記録された、太子が鮪という男に与えた歌にも「ない」が現われており、またその二十九巻には天武天皇のみ代における土佐国大地震とそれに伴なう土地陥没の記録がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人は自然を勝手に手製の鋳型にはめて幾何学的な庭を造って喜んでいるのが多いのに、日本人はなるべく山水の自然をそこなうことなしに住居のそばに誘致し自分はその自然の中にいだかれ、その自然と同化した気持ちになることを楽しみとするのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけにこうした仕事にはいつでも危険が伴なうのであろう。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「今日本にあらゆる種類の全く無用な団体を作ろうとする熱、一種の狂熱がある……文学芸術の研究は決してかかる協会に伴なうものではない。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南国の炎天に蒸された樹林は「小さなうごめく生命」の無尽蔵であった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
