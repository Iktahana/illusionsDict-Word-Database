    "definitions": [
      {
        "index": 1,
        "gloss": "southern foot (of a mountain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その熔岩は、シャスタの南麓から迸ったのであるが、ちょっと富士山から、桂川に沿うて猿橋まで達しているところの「猿橋熔岩」に似ている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然路が右へ曲ると途方もない広い新道が村山｜瀦水池のある丘陵の南麓へ向けて一直線に走っている。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛の墓は、蓮池城の東南麓の畑の中にある。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雲去るかと思へば、雲は南麓に來たる。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "南麓霽るゝかと思へば、雲また北麓に涌き、近く我に及ばむとして及ばず。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "追手は山の南麓にありしなるべし。",
              "citation": {
                "source": "白河の七日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ヶ嶽の南麓に当る広大な原である。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日はその南麓を巡つて来た八ヶ嶽の今日は北の裾野を横切つてゐるわけである。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "東役所址は今の諏訪公園の南麓県立女子師範学校の辺に当る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）やんれ　岡崎の娘さんわしとゆかぬか鎌もつてあの山　蔭へ草刈に草を枕にやつとさのさ草がしをれるやつとさのさ茨がとめたらどうなさるおや、岡崎の娘さんそのときや茨とやつとさのさ大函小函（大函小函は、北海道大雪山の南麓。",
              "citation": {
                "source": "野口雨情民謡叢書　第一篇",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "千山の南麓に近づいて南山溝と云ふ小川があり、川に臨んで上石橋子と云ふ村がある。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　二時四十分、また車中の人となり、キフホイザーを下り、南麓のフランケンハウゼン（鹽湯のある小さい町）を過ぎると、それから先は平野で、進路を北へ取り、一五キロでアルテルンの村を通り、更に一八キロでザンガーハウゼンの町へ辿りついた。",
              "citation": {
                "source": "キフホイザー",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の武尊山の谷間から流れ出る発知川と川場川を合わせる薄根川、谷川岳の南麓に源を発して法師温泉を過ぎ、高橋お伝の生まれた村の桃野で利根川に合する赤谷川に産するものは東京近県の絶品といわれている。",
              "citation": {
                "source": "冬の鰍",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙義山の南麓から出る西牧川と南牧川を合わせる鏑川の水は美しい。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日は富士川より引き返し新釣場として近頃紹介され申候富士南麓浮島沼に近き沼川に、やはり寒鮠を試み申候。",
              "citation": {
                "source": "寒鮠の記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛名南麓の箕輪町でも、疎開学童を受け入れることになったので、校舎の修築、炊事場の新設、井戸を新しく掘るなど、いろいろ準備に忙しい。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は数時間の後には八ヶ岳の南麓を通過し、彼の妻のいる療養所の赤い屋根を車窓から見ようとおもえば見ることも出来るのだ。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地点を見れば、まさしく胆吹山の南麓であって、その周囲を見れば荒野原、その一部分の雑木が斫り倒され、榛莽荊棘が刈り去られてある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚お天理ヶ岳（天治ヶ岳）から東岳に連る尾根や、其南麓を流れる七滝沢なども、行場として修験者などは登降したらしい形跡が見られる。",
              "citation": {
                "source": "奥秩父",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく南麓から、霧がぽかぽかやって来た。",
              "citation": {
                "source": "穂高岳槍ヶ岳縦走記",
                "author": "鵜殿正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は実に天保元年八月四日を以て、萩城の東郊松下村護国山の南麓に生る。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "東方ノ別峰ヲ鉄岳ト云、其東ハ三繋平ト云、甲信武三州ノ分界ニシテ、荒川其南麓ヨリ発源ス。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『甲斐国志』の所謂三繋平と称するものは、正に此処を指したものであることは、「荒川其南麓ヨリ発源ス」とある文が之を証明していよう。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚お金峰山の条に東方ノ別峰ヲ鉄岳ト云、其東ハ三繋平ト云、甲信武三州ノ分界ニシテ、荒川其南麓ヨリ発源ス、山梨郡帯那山、奥仙丈、秩父郡界ノ雁坂等ニ綿亘セリ。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小高岳南方大日向ヨリ出テ、田代沢、逆川、蝉ヶ沢、手小屋沢、先倉沢ヲ合セ、湯小屋村ヲ貫キ、奈良股川ヲ合セテ中手山ノ南麓ヲ西流シ、利根川ニ入ル。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この水源地は聖岳の南麓二千三百米の高所にあって白檜の密林に囲まれ、石灰岩やラディオラリヤ板岩の露出した河床を、生れた許りの清い水が潺湲たる音を立てて流れています。",
              "citation": {
                "source": "日本アルプスの五仙境",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻曲山の直ぐ右に続く二峰は、霧積温泉の北に聳ゆるもので、南麓に懸る二、三の小瀑布が温泉附近に景致を添えている。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沼は中央火口丘である地蔵岳の北麓に、小沼は其東南麓で長七郎山の北に在る。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は忘れたが、ある春の日の午前十一時前後、下総北相馬郡布川という町の、高台の東南麓にあった兄の家の庭で、当時十四歳であった自分は、一人で土いじりをしていた。",
              "citation": {
                "source": "幻覚の実験",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそのころに今川氏に内訌が起こり、外からの干渉をも受けそうになっていたのを、この浪人が政治的手腕によってたくみに解決し、その功によって愛鷹山南麓の高国寺城を預かることになった。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
