[
  {
    "uuid": "d4feb73f-f6ea-5c00-a264-a38d92a18a44",
    "entry": "内乱",
    "reading": {
      "primary": "ないらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
