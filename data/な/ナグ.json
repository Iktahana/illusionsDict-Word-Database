  {
    "uuid": "640708f8-0e07-540f-a63a-5446a576318f",
    "entry": "和ぐ",
    "reading": {
      "primary": "なぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ガ行",
