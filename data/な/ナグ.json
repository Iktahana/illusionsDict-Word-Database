      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become calm (of one's mind, feelings, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眞晝の燒けつくやうな暑さが和ぐ頃だつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の思いますには、彼等の心の和ぐように折角恩を被せて、ねえ貴嬢。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と肺肝を絞る熱涙滴然、もって人類の石心を和ぐべく鉄腸を溶解すべし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に懲治を受けたる者は饑饉においても救われ、戦に出でても死せず、他の獣にも襲わるる事なく、天地万有と相和ぐに至り、衣食住において欠くる所なく、子孫相つづいてこの世に栄え、長寿の幸福を享受するに至ると、これエリパズの語る所である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、貴方様のお名前を有仰つてお尋ね……」「ああ、何でも可いから早く断つて」「さやうでございますか、それではお断り申しませうかね」（五）の二　婆は鴫沢の前にその趣を述べて、投棄てられし名刺を返さんとすれば、手を後様に束ねたるままに受取らで、強ひて面を和ぐるも苦しげに見えぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その罪から自分が容易に追はれたとて先生の感情だつてあれ以上に和ぐものではあるまい。",
              "citation": {
                "source": "悦べる木の葉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄と妹　　兄冬の日背をあたたむる南の窓のたたずまひ、胸｜和ぐる心地すに、暫しきたまへ妹よ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ妹の幸子の病状や、親戚のことの変りなど、矢代に訊かれるまま話すだけだったが、こうして母と話している間だけ、あたりに光りの満ち和ぐ思いのするのが、円光に染って休んでいるようで愉しく、屈託のない暫くだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ寄る男をつれなく過ぐす自由も女に許されたる楽しき特権にして、相手の男の相場に負けて破産する日も、女は猶恋の小唄を口吟みて男ごころを和ぐ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お早う』と云ふ一言で以つて双方の間がズツト和ぐ。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お早う」という一言で以って双方の間がズット和ぐ。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "人かく神の命に背きてその恩寵を失へるがゆゑに能く善を行ひて以て聖旨を和ぐるをえず、キリスト來臨したまふに及びその從順の徳によりて神人はじめて融和すと四〇―四二【髮】枝。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方切支丹教師の方は追放令に服したふりをして有馬領に隠れ、法服をぬいで布教に従事、秀吉の癇癪の和ぐ時を待つことゝしたが、折からアゴスチノ小西行長が肥後、天草の領主となつたので、彼等に保護を加へることができた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "之も神経衰弱療法の一つで、何でもいゝ、何かしら目的をもつて行動してをればいくらか意識の分裂が和ぐのだから、僕は実にはやキチョウメンに、風速何百米の嵐でも出掛けて行つた。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "之も神経衰弱療法の一つで、何でもいい、何かしら目的をもって行動しておればいくらか意識の分裂が和ぐのだから、僕は実にはやキチョウメンに、風速何百米の嵐でも出掛けて行った。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳なく出来たものとすればこの上ないけれども、たとい無理算段して拵えられたものであっても、そうでないと河野から一言云って貰えば、それで吉岡の心も解けて和ぐだろう。",
              "citation": {
                "source": "好意",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」勝代は疼痛が和ぐのにつれてこんなことを云つて涙を浮べた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんは家で皆なに介抱されて死んだのじゃけれど、勝は他所の土地で一人で死ぬのじゃ」勝代は疼痛が和ぐのにつれて、こんなことを言って涙を浮べた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてまたかの美しき看護婦ドルス嬢にいたしましても、ここに権力の残酷なる命令を実行いたしましたあかつきには、いかにしてあの巧妙なる弁舌をもって、病人に勧めてよくその苦痛を和ぐる下剤を服用させることができましょうや。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして神が我らを愛し給うたように、我らもキリストにありて隣人の弱きを負い、隣人の罪をゆるし、隣人と和ぐことができる。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝ら心の中に塩を保ち、かつ互いに和ぐべし。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、此地方は近年は、降雪の量も前のやうに多くはなくなり、陽気もあたゝかになつたと人は言つてゐるが、人が住むやうになつて開墾も新にされてくると、宇宙の創造者全能之大天主ヤーヴエの御恵で天地の気象も、和ぐものであらうか。",
              "citation": {
                "source": "トラピスト天使園の童貞",
                "author": "三木露風",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫子にして邦家を得ば、所謂之を立つれば斯に立ち、之を道（みちび）けば斯に行（したが）い、之を綏（やす）んずれば斯に来り、之を動かせば斯に和ぐ。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなたイ，リオンめざしつゝイーリス送るクロニオーン、『ウーリュンポスを後にして、イーリス、汝速かに聖イ，リオンに赴きて王プリアモスに宣んし曰へ、　145彼は愛兒の贖にアカイア水師おとづれて、アキルリュウスを和ぐる賠償彼に致すべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長に叱られると真赤になって憤慨するけれど、社長の恩顧を思い出すと直ぐに和ぐ。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその直ぐの瞬間に、「あれは命をつなぐものだ」といふ考へが彼の頭を占領した。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では多人数の会へ出ても、不意に人の頭をなぐったり、毒づいたりしようとするところの、衝動的な強迫観念に悩まされることが稀れになった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『なぐれ』『たため』『しめろ』雜然たる叫聲の中、殺氣は既に滿ち渡つて、氣早の若者は行成横合から飛び出して、思ひ切り芳の天窓を擲つた、續いて何處よりともなく、拳の雨は彼の頭上に降り注いだのである。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃の浅間山、飛騨の硫黄岳、遠くの火山から、吹きなぐれた灰でもあろうか……空は曇り切って、どんよりと、眠むそうな顔をしている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士はもう森林や砂礫をかなぐり捨てて熔岩の滑らかな岩盤をむきだしにしている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
