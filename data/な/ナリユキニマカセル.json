        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "成り行きに任せるということに、長谷川は甘えた。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　志村は舌打ちして、もう成り行きに任せることにきめた。",
              "citation": {
                "source": "無法者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「成り行きに任せると仰言いますの。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事無抵抗主義で、万事成り行きに任せるというのか。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が向けば自首して出てもいいし自首が間に合わずに逮捕されたとならば、それでも差し支えないし、また場合によって死にたくなったら自殺してもかまわぬし……万事その場の成り行きに任せるつもりなのであった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は成り行きに任せるのほかはなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今はただ万事をその成り行きに任せるばかりだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "成り行きに任せるしかない、その間に昼飯を食べに行こう。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそいで帆をおろし、舵をひきあげて、なりゆきにまかせるより外はありませんでした。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事をなりゆきにまかせるのが、最も賢明なのだ。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
