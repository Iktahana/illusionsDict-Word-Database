[
  {
    "uuid": "2802e6f3-6299-5772-bc49-d5e2a5c07dec",
    "entry": "内旨",
    "reading": {
      "primary": "ないし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
