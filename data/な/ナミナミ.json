[
  {
    "uuid": "5b37ecc2-db43-5e19-8046-d524113044fa",
    "entry": "並々",
    "reading": {
      "primary": "なみなみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
