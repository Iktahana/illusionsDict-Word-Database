[
  {
    "uuid": "5af69070-e040-5c04-80f3-0cb8368b97ab",
    "entry": "菜飯",
    "reading": {
      "primary": "なめし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
