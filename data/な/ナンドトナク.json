[
  {
    "uuid": "03c28e40-748a-5195-9329-c30bcf590b2a",
    "entry": "何度となく",
    "reading": {
      "primary": "なんどとなく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
