          "literary": [
            {
              "text": "たぶん、そこには、ステンレスの流し台があると思います』とある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピュータの組み立て作業台として、台所のステンレス流し台ほど絶好最適の場所はない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとなりが電気タワシのついた流し台で、厨芥や汚物は、電気の装置が自動的に外へ持ちだしてしまうので、中気で手にふるえのきているひとでも、めったにしくじるということはない。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの硝子戸はあいているが、いつものコックの姿は見えず、二人の女給が高声に話しながら、流し台によりかかってタバコを吸っていた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアの左側は、食器を洗う流し台だ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "キチンに入った里里葉は、流し台をうしろにして立った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "流し台とは反対の壁に、奥行と幅のぴったりと適合した作業テーブルがあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く、早く」　こちらの二人は何事かとびっくりして、いそいでその部屋の中へ入って行きますと、そこはこの船の料理場らしく、壁に色々な形の鍋がかけてあって、流し台のようなものもあり、大きな戸棚の中には、茶碗や皿やコップなどが、こなごなに割れてかたまっています。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
