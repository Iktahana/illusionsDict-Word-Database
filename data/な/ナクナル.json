[
  {
    "uuid": "2147fd82-bd31-5ea6-8c0c-234968d1fa8c",
    "entry": "亡くなる",
    "reading": {
      "primary": "なくなる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
