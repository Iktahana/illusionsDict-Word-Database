    "definitions": [
      {
        "index": 1,
        "gloss": "second player (out of three)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "谷が狭くなって、崖側を行くと、緩いながらも雪の傾斜で辷るから、ミヤマナナカマドの枝を捉えながら上る、前にも増した雪の断裂で、草鞋に踏み蹂った雪片は、山桜の葩弁のように、白く光ってあたりに飛び散る。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐の山にも「ナカギリ」という地名がある。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美貌は、新種族プラナカン（Pranakans）に酷似す。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」『スズサン、リヨウジカンケイサツニコウリユウセラル、ドナタカスグゴライセイヲコウ――ハナカワヤ』「おや、すゞがあげられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カクテアシタハヒルトナリ、　　水音イヨヨシゲクシテ、　鳥トキドキニ群レタレド、　　　ヒトノケハヒハナカリケリ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じように、トナカイの群れを養う土人の家族が映写されても、それがカラフトのおおよそどのへんに住むなんという種族の土人だかまるきりわからないから、せっかくの印象を頭の中のどの戸棚にしまってよいか全く戸まどいをさせられる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクタチ兄ダイハ、ナカヨク、タッシャニ、コノシマニ、クラシテイマス。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの秘密を具体的に探り出すのはナカナカ容易な仕事でないことが最初からわかり切っていた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人同士もナカナカの乗気で、この三月の末には祝言という処まで進んでおったという話……」「ホンニなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナカナカの理屈じゃ」「それに引換えまして私共の一生は、まことに貧乏神様々で御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手線電車が田町に停まったら、降りた人が入口を開け放しにして行って寒くてしようがないので、入口を閉めようとしたがナカナカ閉まらない。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が相手だったことがわかるかも知れないが、その夜がナカナカ明けない。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ……」　と重役の一人が味方の仮装マネージャーを浴びせ倒しに掛かっていたが、ナカナカ腰が砕けない模様である。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの映画でもっともおもしろいのは、雪の林中でのトナカイと犬との格闘の場面である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トナカイが死地に陥って敢然たる攻勢を取り近寄る犬どもを踏みつぶそうとする光景は獣類とはいえ悲壮である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからの後の場面で荒涼たる大雪原を渡ってくるトナカイの大群の実写は、あれは実に驚くべき傑作である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも映画俳優としては人間は犬やトナカイの脚下にひざまずいて教えをこう必要がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾さんの父は、川越の藩士で、明治七八年頃からづツと逓信省の腰辨は腰辨でも、其の頃の官吏だからナカ／＼幅も利けば、生活も樂にしてゐたらしい。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ここにいるのが、あたしの古い友だちのベーだよ」こう言うと、一ぴきのトナカイを、角をつかまえて、ひっぱり出してきました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのトナカイの首には、ピカピカ光る銅の首輪がはめてあって、それでつながれていたのでした。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、こいつ、とってもこわがるから」こう言うと、小さな娘は、かべのさけ目から長いナイフを取り出して、それでトナカイの首すじをなでました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいそうに、トナカイは足をバタバタやりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにつながれている、トナカイさんにきいてごらん」「そうですよ、あそこは雪と氷ばかりで、じつにめぐまれた、すばらしい所ですよ！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、トナカイは言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
