  {
    "uuid": "78f084f8-a85b-5285-8e3f-7ab078242afd",
    "entry": "仲",
    "reading": {
      "primary": "なか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "relation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山賊仲間に聖者のゐたためしは先づないが、修道院の中には天使から悪魔までがずらりとゐる。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都は嘗つて小生自身二年間ゐて、詩人にとつては有難い土地だと思つてゐるので、京都あたりからもつと面白いものが出てもよかりさうなものだと、かねがね思つてゐたが、仲々出なかつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も心で尊敬するわけではないが、非常にジャーナリスチックな交遊をしたりするから、何か仲間の足溜りの役をなす。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその他の場合では、罪のない笑談を言ったりして、妻や子供の家族を笑わせ、女中までも仲間に入れて、一家｜団欒の空気を作った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の仲の好い成人が、子供の片言のようなことをしゃべり合って、何時間もの長い間、笑ったり戯れたりしている風景こそ、おそらく真にフェアリイランド的であったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『内のパパとママとは、だれにも解らない不思議な言葉でだれにも解らない神秘のことを話している』と、学校へ行ってる男の子が、自慢らしく仲間の子供に語ったほど、それは奇妙な別世界の会話であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分について言へば、自分は彼の多數の友人――實に彼は多數の友人と交つてゐた――の一人であり、しかも交情日尚淺く、相知ることの最もすくない仲であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たち詩人の仲間は、すべてが單純な情熱家であり、客觀的な觀照眼を殆んどもたない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日ましに彼と仲良くなった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間はかならず二十代の美青年たるべきこと。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "資金として馬場が二百円、私が百円、そのうえほかの仲間たちから二百円ほど出させる予定である。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間、――馬場が彼の親類筋にあたる佐竹六郎という東京美術学校の生徒をまず私に紹介して呉れる段取りとなった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はつまらん奴を仲間にいれたなあ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間にいれてやることにした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば、たいへんな仲間ばかり集って来たものさ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな仲間もまた一興じゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたと仲間になるなんて！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩だけ、ふたりで仲よく遊ぼう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、同じクラスの者は大学を出てからも、仲の良いくせにつまらないところで張合って喧嘩をしたがる傾向がある。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後を祖母が耕二の顔に向つて「フンフンフン」といふ咬みつきたいやうな、肉親仲間以外では決してされることのない笑ひを一つかけた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて彼等の間では彼等が世間に向つて抱くその野望からの当然の産物として出て来なければならなかつたのは、仲間同志に於ては、その仲間の誰でもを褒めたとも譏つたとも理由の分らない噂――まあまあ噂――さうつまり噂なんだ、それを作り出さんことに閑暇がない。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等仲間の党派に変動を来すのも、半分は此の月給日のことだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、連れ出した男を此の世に於ける唯一の寄すがり者のやうに思へる心に浮々した足取で、そのフェルトをペタペタ夜道に打つつけながら、解雇された仲間で一番給料も多かつた男の下宿の方に歩んだ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奥さんなるものの姪と彼とが恋仲であることを奥さんに知られてゐる彼だからなのである。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉における木曾義仲の崇拝や、戦国時代への特殊な歴史的懐古趣味を、一方蕪村の平安朝懐古趣味と比較する時、両者の異なる詩人的気質が、おのずから分明して来るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我れを厭ふ」というので、平常隣家と仲の良くないことが解り、日常生活の背景がくっきりと浮き出している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上僕の風変りな性格が、小学生時代から仲間の子供とちがって居たので、学校では一人だけ除け物にされ、いつも周囲から冷たい敵意で憎まれて居た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の生徒や教師に対して、一人一人にみな復讐をしてやりたいほど、僕は皆から憎まれ、苛められ、仲間はずれにされ通して来た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人は、仲間と一緒の方を楽しむらしい。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書の綱が性慾のコマを廻す原始人の礼儀は外界物に目も呉れないで目前のものだけを見ることでしただがだが現代文明が筆を生みました筆は外界物です現代人は目前のものに対するにその筆を用ひました発明して出来たものが不可なかつたのですだが好いとも言へますから――僕は筆を折りませうか？",
              "citation": {
                "source": "迷つてゐます",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
