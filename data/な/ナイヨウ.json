[
  {
    "uuid": "79197e85-cdde-5e70-9b26-71554aafc497",
    "entry": "内容",
    "reading": {
      "primary": "ないよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
