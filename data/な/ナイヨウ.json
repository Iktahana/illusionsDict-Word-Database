    "definitions": [
      {
        "index": 1,
        "gloss": "contents",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "内容価値と技巧価値は対立してはゐませんよ。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "内容は技巧以前のものです。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "技巧を考慮する男は吃度価値ある内容を持つてゐます。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情といふ語の内容も色々であらうが、「独り居て怡しむ」底の感情、対人的に発露するに非ざる、そこはかとなき欣怡の情である。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "云へばいふ程、相手は心理的観察の対象を、益々得るといふわけだし、云ふ方は、益々話の内容自体の中に突き進むといつたわけだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "議論の内容如何に拘わず、議論することそのことが癪だといふ、女ならでは夜の明けぬ、悲しむべきことではあるまいか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　　　　　×　　　　　　　　×　或る一つの内容を盛るに最も適はしい唯一形式は、探し得られる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、内容といふものは絶えず流動してゐる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくは一千年前の昔の子供も、活動寫眞とは別の娯樂で、同じ内容のものを見て居たのだ。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして尚一千年後の未來の子供も、何かの珍しい別の仕掛で、同じ内容の忍術芝居や漫畫映畫を見て居るだらう。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みにその「定評」の内容をあげて見よう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば、詩人蕪村の魂が咏嘆し、憧憬し、永久に思慕したイデアの内容、即ち彼のポエジイの実体は何だろうか。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「上風に」のに、「音なき麦を」のをが、てにをはとしての重要な働きをして、句の内容する象景を画いてることは言うまでもない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の如き小詩形が、一般にこうした複雑な内容を表現し得るのは、日本語の特色たるてにをはと、言語の豊富な聯想性とによるのであって、世界に類なき特異な国語の長所である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の詩としては閻王の口や牡丹を吐んとす　が最も有名であるけれども、単なる比喩以上に詩としての内容がなく、前掲の句の方が遥かに幽玄でまさっている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこうした幻想風の俳句は、芭蕉始め他の人々も所々に作っているけれども、その幻想の内容が類型的で、旧日本の伝統詩境を脱していない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の詩では、韻律上の美を目的として、特殊な固有名詞を盛んに使うが、日本の歌や俳句のように、内容（情想）のイメージにかけて、表象上の効果に用いるものは、一般に見て尠いようである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きのふの空の有りどころ」という言葉の深い情感に、すべての詩的内容が含まれていることに注意せよ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば上例の諸句にしても、「この道や行く人なしに秋の暮」などの句にしても、言葉それ自身に節奏の抑揚があり、その言葉の節付けする抑揚が、おのずからまた内容の沁々とした心の咏嘆（寂びしおり）を表出している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句に於ける切字の「や」は、非常に豊富な内容をもつ複雑な言語であつて、外国語に於ける！",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻訳の可能性がある俳句は、連想の内容が極めてすくなく、詩趣が稀薄である代りに、理智的の説明を内容に有する俳句だけである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代女の「蜻蛉つり今日は何所まで行つたやら」「身に沁みる風や障子に指の跡」「朝顔につるべ取られて貰ひ水」等の句は、言葉のイメーヂやヴィジョンから来る詩趣でなくして、人情的な内容からくる興味を主としたものであるから、この種の句ならば、翻訳を通じて外人に理解させることが出来るのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所にそれを再録したのは、詩のスタイルを同一にし、且つ内容に於ても、本書の詩篇と一脈の通ずる精神があるからである。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内容はすっかり忘れてしまったが、それを読んだときに身に沁みた平和で美しいフランスの田舎の雰囲気だけが今でもそっくり心に残っているようである。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなども具体的内容は覚えていないが、この記事で窺われた当時の根岸子規庵の気分と云ったようなものだけははっきり思い出すことが出来る。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ内容の手紙を、投函しての歸りみち、友人の山岸外史とひよつこり逢つた。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎はさつそく泥をこねて、所謂岩乘な、いい舟の製作にとりかかり、狸は、すまねえ、すまねえ、と言ひながらあちこち飛び廻つて專ら自分のお辨當の内容調合に腐心し、夕風が微かに吹き起つて湖面一ぱいに小さい波が立つて來た頃、粘土の小さい舟が、つやつやと鋼鐵色に輝いて進水した。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうな内容のお手紙を受取り、私はへんな、夢見心地に似たものを感じた。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内容は子供等に解る訳もなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど『美しいシャボン玉』を壊さないように、注意に注意して気をつけましたと、未亡人となった夫人が後で言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
