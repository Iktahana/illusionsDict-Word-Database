  {
    "uuid": "cb9023f1-a6e0-5ad1-8c46-a2a307d6cba6",
    "entry": "内申",
    "reading": {
      "primary": "ないしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unofficial report",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "客が足を洗ッてしまッて、まだふききらぬうち、主人は、『七番へご案内申しな！",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『六番さんのお浴湯がすんだら七番のお客さんをご案内申しな！",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の所へご案内申しあげましょう。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（さあ、それではご案内申しましょう、どれ、ちょうど私も米を磨ぎに参ります。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺までいらっしゃいます前には、あの、まあ、伊勢へおいで遊ばすお方に、山田が玄関なら、それをお通り遊ばして、どうぞこちらへと、お待受けの別嬪が、お袖を取るばかりにして、御案内申します、お客座敷と申しますような、お褥を敷いて、花を活けました、古市があるではござりませぬか。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一所においでなさい、御案内申しませうから。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて、洲崎だの、仲町だの、諸入費の懸かる場所へは、強ひて御案内申さないから、讀者は安心をなすつてよい。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……右は、といふうちに、――豫め御案内申しましたつけ、仲の町正面の波除へ突き當つたと思召せ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「――三密の月を澄ます所に、案内申さんとは、誰そ。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "路をいそぐと一旦はお斷りなされましたを、無理にねがうて御案内申しました。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちもまゐつて御案内申せ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御婦人を、旦那――帳場で、このお座敷へ御案内申したのでございます。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに御案内申します。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御案内申し上げます。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親方もね、実は、お景物にお目に掛ける、ちょうど可いからッて、わざと昨夜も、貴方を隣桟敷へ御案内申したんです。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（さあ、其では御案内申しませう、どれ、丁度私も米を磨ぎに参ります。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまここまで出てまいりましたのは、大空の神のお子さまがまもなくおくだりになると承りましたので、及ばずながら私がお道｜筋をご案内申しあげたいと存じまして、お迎えにまいりましたのでございます」とお答え申しました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お風呂へ御案内申しませう」　その声に彼は婢を見返りて、「ああ、姐さん、この花を那裏へ持つて行つておくれでないか」「はあ、その花で御座いますか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ當る所あり、御案内申さむといふに、導かれて、再び白雲山に上る。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にや、案内申さむか』と云へば、『腹減りたり。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『明日金精峠を越ゆ』と云へば、『御案内申さむ』といふ。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしが御案内申しまする。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それからわたくしが肩にかけ又ある時には路ゆく百姓の馬の背を借りて、ようようこれまで御案内申しました。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "物知りの夜光命も、これには驚くかと思ひの外、『報知新聞の受賣か』と素破拔かれて、裸男大いに器量を下げたるが、『好し／＼、さらば、世間に知れざる櫻の名所案内申さむ。",
              "citation": {
                "source": "小利根川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "参られたならばねんごろに御案内申せとの御伝言でござりますゆえ、手前これより御案内申しまするでござります。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼じゃが、こちらからご案内申せ」　待ちきっていたとみえて、あわただしい声といっしょに、その三庵がうろうろしながら取り乱した顔をみせると、おろした駕籠を内玄関のほうへ回させて、そのまま人の目にかかるのを恐れるようにあたふたと招じあげました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のないしんとした蘆洲のなかへ薫の姿は見えなくなって行った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女は今までにないしんみりした気分になつて来るのを感じた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の声もきこえないしんとした夜ふけに、ほそぼそとした白鳥の歌を傍受していると、日本がかあいそうになってきて涙がでた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、池のそばの、何ひとつ物音のきこえないしんとした林の中に並んで坐っていた。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            }
          ]
        }
