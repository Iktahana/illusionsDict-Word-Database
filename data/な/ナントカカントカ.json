        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｔ「何とかかんとか　言ってて先生　早い事……」　「早い事いっちまったんかな」と言い乍ら半次は去る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもたうとう、十二月中には、雪の中で何とかかんとか、もとのやうな形になったんです。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もうかれこれ十三年何とかかんとか言いながら連れ添うている。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "天分に於ては決して彼等｜二三子には、劣らないが今では富岡先生すら何とかかんとか言っても矢張り自分よりか大津や高山を非常に優った者のように思ってお梅｜嬢に熨斗を附けようとする！",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ひの老人、県会議員選挙の依頼状を貰つたのがうれしいと見えて、出かけて来て、何とかかんとか自慢らしい話。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、差入弁当となると、何とかかんとか難くせをつけたい。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこんな下らないぐちをさへ云ふ女なのに、何とかかんとか他人様に云はれると云ふのは何といふ皮肉でせうね。",
              "citation": {
                "source": "書簡　山田邦子宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居に関係している事は初耳ですが、田舎ダネの下らない探偵小説を何とかかんとかといってアトカラアトカラ本屋へ持込むので有名ですよ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかかんとか、ウラーッ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーニン何とかかんとか※　大きな声で叫んで拳固を上から下へ振りまわす。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵なんか少し風の変ったのを書くとすぐ何とかかんとか変な目をして見るものの顔を見るとおだやかな感じなどはどうしても持てない様な気持になって来る。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むづかしい詰め將棋を何とかかんとかして詰ましちやつたやうな小説だなあ」と小林秀雄がそれを讀んで私に言つてくれたが、恐らく小林の考へたよりもつと、その比喩はあの小説をうまく説明してゐたのだ。",
              "citation": {
                "source": "小説のことなど",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことがあれば、烏啼はふだん何とかかんとかいって紳士ぶっているが、彼奴の弟は人間にあるまじききたないことをやっているじゃないかと、世間から後指を指されるのが、今から予想するだに烏啼にはたまらない厭なことだった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルラーケンで落ち合う筈の近藤｜茂吉君は、倫敦からやって来るんで、急がしくって急がしくってとか、何とかかんとか体裁のいい事ばかり並べたてて、旅行は一と月限り、九月一日は夕方までに是非倫敦に帰るんだなんて、几帳面なことをしゃべっていた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『三十四歳です』『では、えらいお婆さんという訳でもないじゃありませんか』『いや、田舎では二十三、四歳を過ぎてもお嫁に行けないと、何とかかんとか噂を立てられるのでしてね。",
              "citation": {
                "source": "縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでは無い、必定また人のことを何とかかんとか――あゝ、あゝ、素性が素性なら、誰が彼様な男なぞの身の上を羨まう。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どんなに評判が悪い』と聞くと、『津田の川口が埋つて居るのに、浚渫船が修繕にやつてあるとか、何とかかんとか云つて、日に日に汽船が徳島へ這入るのが延びて、去年の八月から今に小松島へ着いて居るでせう、新聞が攻撃するのせんのつてそら話になりませんね。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア我輩には関係はねえ――と一頁を瞥見して、二頁を返したが、倫敦電報とか、紐育電報とか、何とかかんとか云ふ電報で埋つて居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも彼がその次に有楽座へ行った時、案内者を捕まえて、何とかかんとかした上に、だいぶ込み入った手数をかけたんだそうだ」「どこにいたんですその女は」と自分は是非確めたくなった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも主人に云わせると教師ほどつらいものはないそうで彼は友達が来る度に何とかかんとか不平を鳴らしている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分が胃病で苦しんでいる際だから、何とかかんとか弁解をして自己の面目を保とうと思った者と見えて、「君の説は面白いが、あのカーライルは胃弱だったぜ」とあたかもカーライルが胃弱だから自分の胃弱も名誉であると云ったような、見当違いの挨拶をした。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は単に引合いに出しただけなのだから、「道友」達に何とかかんとか云われることは迷惑である。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何とかかんとかいって荊州を呉へかえさない算段をめぐらしているにきまっておるさ！",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく何とかかんとか断じているのはおそろしい。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとかかんとか鋸楽師を苛めて寝かさなかった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴けば、杉田先生はお年寄役だけに、三十六計の奥の手も余り穏かならじとあって、単身踏み留まり、なんとかかんとか胡魔化して、荷物をことごとく巻上げて来たとの事だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落の奴等は、なんとかかんとか言うげっとも、やはり、高木の旦那は腹が大きいなあ。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪魔になったから狩りに連れ出して谷底へ突き落として、過って落ちたんだとか自殺したんだとか、なんとかかんとかいうことにしてごまかしてしまったんじゃねえか？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーリー・バードと、なんとかバードと、なんとかかんとかって衛星で、同時に世界中をむすべるようになったんだとさ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その和寇とは一寸ちがふが、北朗襲庵の通知が実は一ヶ月以前から已にその予告があり、殊に最近、北朗自身その例の名筆をふるつて姫路より来信して曰く、姫路の展覧会大成功裡に終りそれから跡片付やらなんとかかんとかして二十六日には正に庵に行くべしと、愈和寇襲来と思つて、毎日／＼待つたの待たんの。",
              "citation": {
                "source": "北朗来庵",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
