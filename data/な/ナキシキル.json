[
  {
    "uuid": "c73eaae4-c9b3-5c6a-8159-c5358b75211b",
    "entry": "鳴き頻る",
    "reading": {
      "primary": "なきしきる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to chirp or buzz constantly (usu. insects or birds)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "続いて、がたがたと些と荒く出ると、拍子に掛かって、きりきりきり、きりりりり、と鳴き頻る。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌翌朝、私は鳴き頻る鶯の声を聞きながら、目を覚ました。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの山に灯が見えて、暮れせまる谿河に、なきしきる河鹿の聲。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ころ／＼ころげてまあるい虫・つながれて吠えるばかりの仔犬の暑さ・朝からはだかで蝉よとんぼよ・夕立つや蝉のなきしきる　夕立つや逃げまどふ蝶が草のなか　七月十八日朝ぐもり、蝉しぐれ、身心なごやかなり。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れし木犀の香やうやく衰へ、裏の栗林に百舌鳥なきしきる。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "追加三句　　（帰郷　やつぱりうまい水があつたよ、の句と共に句賛の三句とする）・露のしたゝるしたしさにひたる・別れて遠い秋となつた　朝から百舌鳥のなきしきる枝は枯れてゐるけさはほどよい起床だつた、すべてがおだやかに運ばれた、何かうれしい事でもないかな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
