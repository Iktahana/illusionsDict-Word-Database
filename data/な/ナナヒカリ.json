    "definitions": [
      {
        "index": 1,
        "gloss": "benefiting from the influence of a master or parent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
