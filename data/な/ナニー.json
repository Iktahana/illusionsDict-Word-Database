        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つづいて「後藤又兵衛」や「敵国降伏」や「ヱルナニー」が出た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「詭弁は哀しきオナニーである。",
              "citation": {
                "source": "精神のへど",
                "author": "――手帳より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは鶴の巣籠、何かほかに」「ほかには何も知らぬ」「ナニー」「ほかに虚鈴というのがあるが、これは、おのおの方にはわかるまい」「何を！",
              "citation": {
                "source": "大菩薩峠",
                "author": "東海道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "六二年はピーター・ポール・アンド・メアリーのはじめてのＬＰが出た年だし、ＡＢＣテレビに『フーテナニー』という新番組ができた年でもある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーター・ポール・アンド・メアリーがテレビの『フーテナニー』でうたう『この国はあなたの国』は、バリー・サドラーの『悲しき戦場』やデイヴ・ダドレイの『ヴェトナム・ブルース』とおなじく、反戦どころか戦意を逆に高揚させるタカ派の音楽であった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレビの『フーテナニー』などには絶対にあらわれることのない場所で、フォークソングは、すさまじく巧みにうたわれたのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六一年五月、ミネソタ大学のフーテナニーに参加。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "転ばない日は、女に、オナニーのためのダッチ・ボーイがわりに使われてしまう。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
