  {
    "uuid": "d927e6d6-364e-5b6d-995e-5f8bfc387a46",
    "entry": "内方",
    "reading": {
      "primary": "ないほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "inside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「内方でおっしゃいます。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お婆さん、私は直帰るんですが、」「あい、」「どうぞねえ、」と何やら心細そうで気に懸ると、老人の目も敏く、「内方にゃ御病気なり、夜分、また、どうしてじゃ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どうだかね、私、内方へ参ったは些との間だし、雨に駈出しても来さっしゃらねえもんだで、まだ帰らっしゃらねえでごぜえましょう。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さて、更めて内方へ、ものも、案内を頼みましょう。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの覚えたのは、内方袖方、御手に蝶や花、どうやどうんど、どうやどうんど、一丁、二丁、三丁、四丁ッてもう陽気なことばかりで、訳が解らないけれど、貢さんのはまた格別だねえ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駒は内方の召使やおまへんか。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そいでまアお氣の毒だすが内方へお頼みしに來ましたんや。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "内方からは左になる窓の向うには庭のアカシヤが枝を伸して居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社頭の松の下に雪を避け、藁を焚いて暖を取りながら、吉田氏の内方に斡旋を乞うて百太夫社の開扉を待つたが、生憎責任者の組長が不在で遂に不可能となり、宿望の百太夫像は見られずに終つた。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちくたしは従来卯の花をくたすから卯の花くたしだというてゐるけれども、庄内地方の方言ではくたすを雨にぬれるといふ事に用ゐてるさうで（庄内方言考）、卯の花くだしといふのはつまり卯の花雨といふ意味であらう。",
              "citation": {
                "source": "用言の発展",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は腰を掛けながら、毎朝例刻に先を爭つて席を奪ひ合ひながら、丸の内方面へ向ふ自分の運命を顧みた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丸の内方面らしい」　弾かれたように群衆はどっと雪崩をうって、爆弾の落ちたとは反対の方に走りだした。",
              "citation": {
                "source": "空襲下の日本",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッと丸の内方面が明るくなったと思うと、毒々しい火焔がメラメラと立ちのぼり始めた。",
              "citation": {
                "source": "空襲下の日本",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、まことに粗末な品でござりますれど、能登守様のお内方へ差上げ下さいまするよう、主人からの言いつけでござりまする」　使に来た女中が捧げているのは、蒔絵の重に酒を添えて来ているものらしくあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "東に伊賀伊勢方面へ、西に河内方面へ、と東西にのびる道が三輪の町で丁字形に岐れて奈良方向へ北上している。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてその内方より見たる状を示す。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は其処から出てゆく時に、先ず扉を内方へ引く。",
              "citation": {
                "source": "蠱惑",
                "author": "――冬夜、瞑目して坐せるある青年の独白――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）斎院御方半物三人、装束自内方被進。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　庄内地方のオクナイ様　佐々木君の報告の中に、黒川友恭著「荘内方言考」を引いて、山形県荘内地方では、他の地方ではオシラ神というものを、オコナイ様というとの事が見えていた。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには庄内方面よりもいっそう雪の深かりそうな羽後の仙北地方がよかろう。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱傷を受けた部分だけが皮下組織から剥離し、一センチくらいの幅に細長く裂け、その中途、または端で切断されることもあり、縮み上がり、少しく内方に巻き込み、ぶらぶらとぼろ布か塵払いみたいに垂れ下がっている。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユズリハの枝を取りそれを上方より望み見ればその葉が車輪状に四方に拡がり出で、したがってその赤き葉柄も四方に射出して見え、外方は緑葉、内方は赤葉柄で特に美しく眺められ棄てたものではないと感ずる。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殻片が開いたその際は、その種子があたかも舟に乗ったように並んでいるのだが、その殻片がだんだん乾くと、その両縁が内方に向こうて収縮、すなわち押し狭められ、ついにその種子を圧迫して急に押し出し、それを遠くへ飛ばすのである。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその嚢の中に汁を含んだ膨大せる毛と種子とがあって、その毛はその嚢の外方の壁面から生じており、その種子は内方の底から生じている。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟味所の内方、オースチン師の室は、燦然たる洋風に飾られていたが、窓には厚く蔽いが掛けられ扉には堅く錠が下ろされ、さも厳重に固められていた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目金之助　　　　　高浜清様　　　　　　○明治四十年七月十七日（松山一番町池内方高浜宛）（封書）　啓　松山へ御帰りの事は新聞で見ました。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、垣に沿って沖の方へそれた魚たちは、いつの間にか、大きい網の内方に向って短い垣網が二つ建っている。",
              "citation": {
                "source": "大謀網",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は腰を掛けながら、毎朝例刻に先を争って席を奪い合いながら、丸の内方面へ向う自分の運命を顧みた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいったいには年じゅうの時候のうちでは春はあまり自分の性に合わないほうである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はむしろ意味のわからないほうがいいような気がしていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
