    },
    "definitions": [
      {
        "index": 1,
        "gloss": "long",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "長の年月、海を見るたびに、おぼろに感じてゐたことが、急に明るみに出た感じ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気の軽重で、処分の軽重を決めたといふ校長の頭の程は、凡そ奇ッ怪なものでありますが、或ひは此の校長が、その地では人望のある、謂はば人格者かも知れないのです。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長がもし人望のよい人である場合は、文部省によつて、アツサリ放校が取消されたにしても、何らか校長の顔を立てるためには生徒の方に臨時の損が振りかけられたに相違ありません。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリスタン・コルビエールは、千八百四十五年、七月十九日、午前八時、モルレーに於て汽船会社の社長の息子として生れ、千八百七十五年、三月一日午後十時同所で死んでゐるから三十年に足らぬ生涯であつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生の詩の特長の一つは、一般に「易しくて解りよい」といふ評判のあることである。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その人とは、口をきいたこともなかつたが、それでも、校長の官舍と、私の下宿とは、つい近くだつたので、登校の途中、ちらと微笑をかはすことがあつて、この人は、その、校長追放の騷ぎの中で、氣の毒であつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のちかくに、校長の息子がゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ひとの名前を忘れ易く、この校長のお名前も、はつきり憶えてゐない。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この校長のときに、私たちは卒業したのである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長の去つた後で、途中から来た者と初めからゐた者とは話合つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夫婦喧嘩は珍しくない、妻君は酷いヒステリーに罹つてゐる、娘だつて午後五時以後は何んな理由があらうと外出させて貰へないさうだと、校長の家の近所にゐる生徒が聞いて来てゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り叱らぬ先生の前で、生徒達は聞こえよがしに校長の悪口を言合つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈が高く顔の小さい、額がノツシリしてフロックコートのよく似合ふ、前校長の容姿が何時か彼の心を離れないものとなつてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうだ、校長の身で全校の修身を抱へてゐるやうな者は一寸此の市中にでもあるまいからな……」　訓辞も近頃ではホンの特別な場合以外にはしなくなつてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師達も最早七分は校長の宅を訪問してゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は校長が自分を快く思つてゐないことも知らないではなかつたが、校長に話掛けられゝばニタニタ笑ひながら、大きい声で校長の頭の上を声が通過するやうな物の云ひ方をした。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は校長の権威のために、道場の方には我不関でゐようと考へてゐたのに、遂に昼食時間道場の方に足を運んだ。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは折々フットボールが飛んで来て窓硝子が割れるので、校長の考案したことであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "枡と枡との境の板よりもウンと受け板が手前に出してさへあれば零しはしまいといふ校長の意見通りにその受け板は取附けられた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その噂に依ると、二三日前から――さう、だから彼等の噂に一日と続くものはあんまりない筈である――竹山を辞職させようといふ社長の考へだといふ噂があつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日社長の宅へ行つたといふのはつまり御機嫌伺ひ方々その真否の偵察に出掛けたのであつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "来たには来たが彼は話材を考案する余裕を持つことなしに来たことを彼は社長の庭園のお世事を言つてしまつた時に気付いた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "………「あゝさう、俳優達の悪口だ」、――彼は今社長の前へ来てから始めてホツトした。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長が一寸した会社のことでの気附を述べ出すと、彼は皮表紙の手帖と買つたばかりの鋭鉛筆とを出して、一寸書きつけては社長の顔をみて、「はァ、はァ、」と云つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うムうム、――いやそれは私は気付いてゐないぢやない、今日も社長の所で一口二口洩して置きはしたが、いつたいどんなことをするんだい？",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "総長の演説があったが何を云っているか自分にはちっとも分らないので少々心細くなった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カール総長の握手の力の強いのにびっくりした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学証書と云ったような幅一尺五寸｜長二尺ほどの紙に大きな活字で皇帝や総長の名を黒々と印刷したものを貰ったが文句はラテン語で何の事か分らない、見ていると気の遠くなるようなものであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日附の所に D. Berolini d. 19. mens. とあって下に総長の署名がある。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
