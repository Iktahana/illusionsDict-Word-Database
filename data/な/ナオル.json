[
  {
    "uuid": "9c034ba2-dd09-5129-a253-bc2878a94ea2",
    "entry": "治る",
    "reading": {
      "primary": "なおる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
