  {
    "uuid": "aeb144c6-c7e2-565e-90e8-79f4973a8952",
    "entry": "直る",
    "reading": {
      "primary": "なおる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to get mended",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（ペンを擱いて向き直る）女　恰度よかつたわね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの怪我や片輪は、直るものなら病院で直してくれる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "横山先生のところへ連れて行くと、先生は一目見ただけで、これはじきに直る、毎日上白米を何合ずつ焚いて喰わせろと云った。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唾を飮み込めば直るといふことを知らないと見える。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（画家の方へ向き直る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷は直る、然し、精巧な銃を毀したならば、それは直らない。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所へ入ってしゃがんでいると直ると云われてそれを実行したことはたしかであるが、それがどれだけ利いたかは覚えていない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と前垂を横に刎ねて、肱を突張り、ぴたりと膝に手を支いて向直る。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、何んにつけても、早く、とまた屹と居直ると、女房の返事に、苦い顔して、横睨みをした平吉が、「だが、何だぜ、これえ、何それ、何、あの貸したきりになってるはずだぜ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっとしていれば直るものはひとりで直るようにできているものらしい。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "動き回れば傷も骨折もなかなか直るときはないであろう。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝れば直るが無理すると肺炎になる。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはわずかに十度か二十度ぐらい回転するだけで、すっかり元の方向まで向き直るようなことはない。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の壺の振りよう一つで蔵元屋の身代が立直るか、直らぬかの境い目と、両親に言い聞かせられたお熊さんの、一心から身を斬らるるような思いをしながら毎夜毎夜のカラクリ丁半……早よう死にたい死にたいと花の盛りのお熊さんが、神仏を祈って御座ったいじらしさ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし時を逆行させる場合にはいろいろな向きに倒れた鉛筆がみんな垂直に起き直るから事がらは簡単になる。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が向き直ると、ヤコフ・イリイッチは一寸苦がい顔をして、汗ばんだだぶだぶな印度藍のズボンを摘まんで、膝頭を撥きながら、突然こう云い出した。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その※腫は、と医者は席を立たうと思つたかして、私の方に向き直ると云ふのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「首の座に直る」ということは悲観の極を一度味わったことのある人ということでありましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老女改めて阿難の方に向き直る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と一口がぶりと遣って、悵然として仰反るばかりに星を仰ぎ、頭髪を、ふらりと掉って、ぶらぶらと地へ吐き、立直ると胸を張って、これも白衣の上衣兜から、綺麗な手巾を出して、口のまわりを拭いて、ト恍惚とする。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と柳の眉の、面正しく、見迎えてちょっと立直る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階へ返って、小座敷へ坐直る、と下階で電話を掛けます。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」四　婦は分別に伏せた胸を、すつと伸ばす状に立直る。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と裳をすらりと駒下駄を踏代へて向直ると、半ば向うむきに、すつとした襟足で、毛筋の通つた水髮の鬢の艶。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言いさま整然として坐り直る、怒気満面に溢れて男性の意気｜熾に、また仰ぎ見ることが出来なかったのであろう、お雪は袖で顔を蔽うて俯伏になった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は小洋燈に灯を移して、摺附木を火鉢の中へ棄てた手で鬢の後毛を掻上げざま、向直ると、はや上框、そのまま忙しく出迎えた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二で直るいいか」大将｜両腕を上げ整枝法のピラミッド形をつくる。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の落度になっても可いの、そのかわりね、心がおありだったら、どうぞ旦那の病気が直るように、お鶴さん、お前も念じて下さいな。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、別人とは納得しながら、うっかり口に出そうな挨拶を、唇で噛留めて、心着くと、いつの間にか、足もやや近づいて、帽子に手を掛けていた極の悪さに、背を向けて立直ると、雲低く、下谷、神田の屋根一面、雨も霞も漲って濁った裡に、神田明神の森が見える。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスピリンをどっさり呑めば、けろっとなおるのだが。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
