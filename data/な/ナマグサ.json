[
  {
    "uuid": "3d23edd6-024f-5aa4-8ec4-e3110a7ddbfe",
    "entry": "生臭",
    "reading": {
      "primary": "なまぐさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
