    "definitions": [
      {
        "index": 1,
        "gloss": "something that smells of fish or blood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "實生活の生臭い風にお顏を撫でられるのが、とてもとても、いやなんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親はまず最初の試みに注意深く色と生臭の無い魚肉を選んだらしい。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孵化場から今帰りがけのところとみえて、彼が近づくと生臭い香いがあたりに香った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と氣遣顏の私さへ、其生臭い肉を口中充滿に頬張つて居つたのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "人參も、干瓢も、もさ／＼して咽喉へつかへて酸いところへ、上置の鰺の、ぷんと生臭くしがらむ工合は、何とも言へない。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生臭いにおいがプンとして、はき気を催しそうだった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖くないことを示すという自尊心が、ぼくをして生臭い石油をまるで毒薬をのむ様な悲壮な表情で飲ませてしまったのだ。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯の煮物を作るにも、しそと土しょうがをいれ、酢と醤油以外に水を使わず、些も生臭味の出ない様に煮るこつを心得ているといった風で、やもめ暮しに重宝であった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の家の門は、自分にとって、あの神曲の地獄の門以上に薄気味わるく、その門の奥には、おそろしい竜みたいな生臭い奇獣がうごめいている気配を、誇張でなしに、実感せられていたのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この「女の決闘」という、ほんの十頁ばかりの小品をここまで読み、その、生きてびくびく動いているほどの生臭い、抜きさしならぬ描写に接し、大いに驚くと共に、なんだか我慢できぬ不愉快さを覚えた。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、この私の「女の決闘」をお読みになって、原作の、女房、女学生、亭主の三人の思いが、原作に在るよりも、もっと身近かに生臭く共感せられたら、成功であります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実生活の生臭い風にお顔を撫でられるのが、とてもとても、いやなんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして貴女はここに來たのやさしい　青ざめた　草のやうにふしぎな影よ貴女は貝でもない　雉でもない　猫でもないさうしてさびしげなる亡靈よ貴女のさまよふからだの影からまづしい漁村の裏通りで　魚のくさつた臭ひがするその腸は日にとけてどろどろと生臭くかなしく　せつなく　ほんとにたへがたい哀傷のにほひである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その腸は日にとけてどろどろと生臭くかなしく　せつなく　ほんとにたへがたい哀傷のにほひである。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしは、そんな生臭坊主ぢやありません。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしはあなたを生臭坊主だと思つてをります。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、あなたは生臭坊主です。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなぢや、わたしはいつまでも、生臭坊主の糞坊主です。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "生臭坊主でも偉くなれないことはないぜ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間にやいくらでも生臭坊主で、和尚になつてるのがあるからな。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを塩胡椒し、家鴨の肉の截片を入れてちょっと煮込んで食べるのだが、鼈四郎は味見をしてみるのに血生臭いことはなかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生臭いおさかななんかは。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭旅宿の留学生臭い生活を離れて格安ホテルに暫らく自由を味ってみたり、エッフェル塔の影が屋根に落ちる静かなアパルトマンに、女中を一人使った手堅い世帯持ちの真似をしてみたり、新吉は巴里を横からも縦からも噛みはじめた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉七は、すしは生臭くて好きでなかった。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚をいじったあとの、あのたまらない生臭さが、自分のからだ一ぱいにしみついているようで、洗っても、洗っても、落ちないようで、こうして一日一日、自分も雌の体臭を発散させるようになって行くのかと思えば、また、思い当ることもあるので、いっそこのまま、少女のままで死にたくなる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍にたくさんの獣の骨や頭の類がころがっていて、其処から生臭い鬼魅悪い臭がして来ます。",
              "citation": {
                "source": "人蔘の精",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、生臭い生の肉を口に入れる気はいたしません。",
              "citation": {
                "source": "人蔘の精",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はおよそ生きてるもの、動いてるものに何か浅薄で生臭いものを感ずる性質でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、冐險なんて下手な言葉を使ふから何か血なまぐさくて不衞生な無頼漢みたいな感じがして來るけれども、信じる力とでも言ひ直したらどうでせう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまぐさい春のにほひがする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
