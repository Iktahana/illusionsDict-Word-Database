          "literary": [
            {
              "text": "ナイトクラブだよ、ひっひっひい、なんて手かもしれない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナイトクラブなんていうから」「ナイトクラブって、どういうクラブ？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで国語辞典見るよ」「ナイトクラブって、英語じゃねえのかよ」　慶一は、高志が笑いやむタイミングをはかっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　ナイトクラブに於て。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りには、「恋鳩」「処女林」と、一等船客級をねらうナイトクラブがある。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "歓楽地、リオへ遊ぶ一等船客級相手のナイトクラブ――。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "※これは白い　白いは肌　と、舞台の歌声とともに緞帳があがるが、だんだん、その白いというのが肢だけでなくなるというのが、「恋鳩」のナイトクラブたるところだ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくこんな、ナイトクラブあたりにはけっして見られぬような女性が、どうして途方もない大勝負をカムポスに挑むのだろう。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、半分｜自棄でリオへ来て、話に聴いたナイトクラブとはどんなところだろうと、なんだか覗くような気持で『恋鳩』へゆきました」　「では、どうして、カムポスと一勝負という気になりましたね。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "※｜これは白い　｜白いは肌　と、舞台の歌声とともに緞帳があがるが、だんだん、その白いというのが肢だけでなくなるというのが、「恋鳩」のナイトクラブたるところだ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、半分｜自棄でリオへ来て、話に聴いたナイトクラブとはどんなところだろうと、なんだか覗くような気持で『恋鳩』へゆきました」「では、どうして、カムポスと一勝負という気になりましたね。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのレディース・ナイトクラブはブルジョア有閑婦人によって作られているものだそうだ。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのレディース・ナイトクラブの貴婦人の希望も其処にあるのだそうだ。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話を僕にしてくれたのは支那の青年で李さんという人だったが、その李さんは尚詳しくレディース・ナイトクラブの部屋の構造を話してくれたので夫れを書くことにしよう。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテル、ダンスホール、映画館、レストラン、できればナイトクラブ式な社交場、といふ風なものを網羅して……」　田沢が夢中で喋つてゐる間、素子は、さつきから怪しくなつて来た空模様を、ぢつと窓に顔を寄せて眺めてゐた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君がもうちつとくだけると、早速、ナイトクラブの経営なんてものを委してみたいんだが、少々その、方面では融通の利かんお嬢さんでな、これが……」　さう云ひながら、彼は、首を縮める真似をした。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台は、同時に、高級なナイトクラブのホール正面の、階段のあるステージ。",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の洋楽趣味は、酒席や、ナイトクラブや、キャバレーから広まったものではない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ・Ｄ・Ｔノ踊リ子ダト云ッテタケレド、日劇ニイタノハホンノ半年グライデ、ソノ後何ヲシテイタノカ、浅草辺ニイタコトモアルラシイシ、ドコカノナイトクラブニモイタラシイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はテキサスに生まれて子供のときは教会の聖歌隊でうたい、まだ十代のときすでにナイトクラブでかせぎ、メディシン・ショー（田舎で人々に薬を売る、一種の興行。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォーク歌手のマーティ・ベイリンがナイトクラブをはじめようとし、そこで演奏するロック・グループをさがしにかかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイボール凡そ六杯位飲み、旗一兵がすゝめるので、中川三郎経営のナイトクラブ、コーパといふのへ寄る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
