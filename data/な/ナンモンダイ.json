    "definitions": [
      {
        "index": 1,
        "gloss": "difficult problem or question",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
