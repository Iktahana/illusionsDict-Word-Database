    "definitions": [
      {
        "index": 1,
        "gloss": "Solanaceae (nightshade family of plants)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
