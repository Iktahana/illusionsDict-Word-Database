        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「人間どもは、何だって、暑い暑いとぬかしながら、暑い処にコビリついているんだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが、御連中だよ」（だが、何だって此小僧奴は子供らしくねえんだろう。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに又何だって跟けられてるんだい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だって突破しろなんて云うんだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、第三金時丸なり、又は淫乱婆としては、それは必要欠くべからざる事では、あっただろうが、何だってそれに雇われねばならないんだろう。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　何だって、コレラ病患者は、こんなことが知りたかったんだろう。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は自分を見るや泣き声を絞って、何だってもう浮いていたんですものどうしてえいやらわからないけれど、隣の人が藁火であたためなければっていうもんですから、これで生き返るでしょうか……。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だってあなたが居なくなってからはまるで泣きの涙で日を暮らして居るんだもの、政夫さんに手紙をやりたいけれど、それがよく自分には出来ないから口惜しいと云ってネ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だってあんな非度いことを民子に言ったっけかしら。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "名乗っただろうが誰も聞いちゃ居なかった」　その時お静坊が、　「兄さん、本当は妾聞いたんだけれど怖いから誰にも言わなかったのよ」　「何だって？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石さんが二階に来て居るんだよッ」　「なッ何だって、石松が来てる？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はやくざになるのはよせ」　「何だって？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「何だって斯んな物盗んだりなんぞするんだ」　と叱り付けられてお絹が甘える様に言った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺らは、ただ金を取るために、危いことだって、気にむかないことだって、何だってやっている。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だって一旦汚した身体ですから、そりゃおっしゃらないでも、私の方で気が怯けます。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、その何だって、物をこそ言わねえけれど、目もあれば、口もある、それで生白い色をして、蒼いものもあるがね、煮られて皿の中に横になった姿てえものは、魚々と一口にゃあいうけれど、考えて見りゃあ生身をぐつぐつ煮着けたのだ、尾頭のあるものの死骸だと思うと、気味が悪くッて食べられねえッて、左様いうんだ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の為だって、何だって、一旦他の人に身をお任せだもの、道理だよ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前、お前、それで気を落したんだけれど、命をかけて願ったものを、お前、それまでに思うものを、柳ちゃん、何だってお見捨てなさるものかね、解ったかい、あれ、あれをお聞きよ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だって月謝を出さなければ物事はおぼえられない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷風の猿真似だって何だってかまやしませんよ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐吉さんだって、それを知って居るに違いないのに、何だってあんな嘘の自慢をしたのでしょう。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だってまた、そんなものを買って来るんだい。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だってあたし赤に黒のぶちなんていやだわ。",
              "citation": {
                "source": "まなづるとダァリヤ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だって私の居ないのに渡した、え何だって渡した。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だってよいジャあないか。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やるなら一緒にやってもいい」「あなたは一体、何しにここへ来たのだろう」「さあ、――風に吹かれて」「言って置くけれども、御託宣と、警句と、冗談と、それから、そのにやにや笑いだけはよしにしましょう」「それじゃ、君に聞くが、君はなんだって僕を呼んだのだ」「おめえはいつでも呼べば必ず来るのかね？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだって浮いていたのを見つけたんだもの、よもや池とは思わないから、いちばんあとで池を見たら浮いていたんですもの、という。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだってあんな真似をしたのだい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の近づくのを少しも知らないと見えて、「なんだってお前は鳥のまねなんぞした、え、なんだって石垣から飛んだの？",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺ら、なんぼなんだって、こんなにひどいとは思わなかったよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
