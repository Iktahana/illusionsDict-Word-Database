[
  {
    "uuid": "cb9f8559-6348-55bb-bd43-447c8e4643cb",
    "entry": "仲居",
    "reading": {
      "primary": "なかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
