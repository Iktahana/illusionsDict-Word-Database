    "definitions": [
      {
        "index": 1,
        "gloss": "how ...!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「何て幸福な今の耕二だらう！",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て鬼だ」「船長ってえ鬼だったよ」「大笑いさすなよ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何てったって、化けるのは俺の方が本職だよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て、やけに吹きやがるんだ！",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "みち子はもう一度同じことを云って見たが、同じような返事だったので、本当に腹を立て「何て不精たらしい返事なんだろう、もう二度と来てやらないから」と云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生この石何て云うのす。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ云う岩のすき間のごと何て云うのだたべな。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て噂話の好きな人達なんだらう……」と、私はふとそんな事を心の中で考へながら、武井さんの顏をちらりと見た。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ何て云ひますか、その魅力とでも云ふものがあるんですね。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て、縁儀の悪いこっちゃ、一と晩に二人も怪我をしやがって！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不軍紀な、何て不軍紀な！",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何てお前ら、邪推深いんだね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵タイて、何て馬鹿な奴だろうね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、何ていったかしら、アシクリゲ、……」「膝栗毛だろう。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やかましいねえ、お前の足ったら、何て無器用なんだらう。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生この石何て云ふのす。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ云ふ岩のすき間のごと何て云ふのだたべな。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何てふしあわせな子どもだろう。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は舌打ちして　――何て野暮な花だろう、イギリスそのものだ」　といっていた。",
              "citation": {
                "source": "マロニエの花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銑さん、まあ、何てこッてしょう、どうした婆さんでしょうねえ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と遠灯の目ばたきをしながら、揃えた膝をむくむくと揺って、「何て、寒いでしょう。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お年寄を、こんなこと、何て乱暴なんだろう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　と敷居に、其の袖も帶も靡くと、ひら／＼と團扇が動いて、やゝ花やかな、そして清しい聲して、「御挨拶もしませんで……何うしたら可いでせう……何て失禮なんでせうね、貴方、御免なさいまし。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみの旦那はなかなか恐い人だねえ、何て云うんだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何て云う、汝の兄※は。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、この先生は何て云うんですか。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう自分で名前を書いて爪印して来たんですが、一体それは何ていふ書付なんでせう。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何ていふ書付か、それはお前さんに聞きたいんだ、こちらで。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "所でラヴェルなんてバッハが見たら苦労性なデコラトゥールだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し根が風癲（フーチヤン）だから、何かほかのことが頭を占めてる時は、金なんて忘れてるといつた塩梅だな」。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
