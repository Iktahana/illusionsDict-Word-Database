    "definitions": [
      {
        "index": 1,
        "gloss": "to line up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家敷の二方に並ぶ病室からは、患者や附添人等の呑気な饒舌が、時には高く、その余はゴトゴトと聞えて来た。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある杉垣の内を覗けば立ち並ぶ墓碑｜苔黒き中にまだ生々しき土饅頭一つ、その前にぬかずきて合掌せるは二十前後の女三人と稚き女の子一人、いずれも身なり賤しからぬに白粉気なき耳の根色白し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道右へ廻りて両側に料理屋茶店など立ち並ぶ間を行く。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍に並ぶ柱燈｜人造麝香の広告なりと聞きてはますます嬉しからず。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼なれば白面の魎魅も影をかくして軒を並ぶる小亭｜閑として人の気あるは稀なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏見人形に思い出す事多く、祭り日の幟立並ぶ景色に松蕈添えて画きし不折の筆など胸に浮びぬ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上の霧のうすれの明るみに松の生え並ぶ白州の浜が覗かれた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の銅羅が暁を破ると見送人達は鉄梯子を下りて対岸に並ぶと、二度目の銅羅と一斉にわめき出す。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "プノンペンの街、タマリンドの街路樹、メコン河の流れ、シソワット王の城内、彼方には椰子の林があり、赫熱とした熱帯の強烈な太陽の直射と、熱風を避けた王城内でノラの母はシソワット王と廷臣の居並ぶ玉座のまえで、オーケストラと数十人の唄い手の歌声のなかで華麗な彼女はカンボジヤの踊りを舞うのだった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この少年は數學は勿論、其他の學力も全校生徒中、第二｜流以下であるが、畫の天才に至つては全く並ぶものがないので、僅に壘を摩さうかとも言はれる者は自分一｜人、其他は悉く志村の天才を崇め奉つて居るばかりであつた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この少年は数学は勿論、その他の学力も全校生徒中、第二流以下であるが、画の天才に至っては全く並ぶものがないので、僅に塁を摩そうかとも言われる者は自分一人、その他は、悉く志村の天才を崇め奉っているばかりであった。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は畑、左は堤の上を一列に老松並ぶ真直の道をなかば来たりし時、行先をゆくものあり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづけて五回音がして空中へ五つの煙の団塊が団子のように並ぶだけと云わばそれまでのものである。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、二月もたって近辺にぽつぽつバラックが建ち並ぶようになった頃に、思い出して行ってみたが、その店はまだ焼跡のままであった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと今度は女の子連中が――それは三人だったが、改札口へ並ぶように男の児の前へ立った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "驛路の馬の鈴の音、しやんと來る道筋ながら、時世といひ、大晦日、道中寂りとして、兩側に廂を並ぶる商賈の家、薪を揃へて根占にしたる、門松を早や建て連ねて、歳の神を送るといふ、お祭の太鼓どん／＼／＼。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣屋はこの辺に棟を並ぶる木屋の大家で、軒、廂、屋根の上まで、犇と木材を積揃えた、真中を分けて、空高い長方形の透間から凡そ三十畳も敷けようという店の片端が見える、その木材の蔭になって、日の光もあからさまには射さず、薄暗い、冷々とした店前に、帳場格子を控えて、年配の番頭が唯一人｜帳合をしている。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　鏡の中の俳優Ｉ氏　某百貨店の理髪部へはいって、立ち並ぶ鏡の前の回転椅子に収まった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の、ひとのよい無學ではあるが利巧な、若く美しい妻は、居並ぶ近親たちの手前、嫉妬でなく頬をあからめ、それから匙を握つたまま聲しのばせて泣いたといふ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の、ひとのよい無学ではあるが利巧な、若く美しい妻は、居並ぶ近親たちの手前、嫉妬でなく頬をあからめ、それから匙を握ったまま声しのばせて泣いたという。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだランプをつけないので薄暗い土間に居並ぶ人影もおぼろである。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸数五百に足らぬ一筋町の東の外れに石橋あり、それを渡れば商家でもなく百姓家でもない藁葺き屋根の左右｜両側に建ち並ぶこと一丁ばかり、そこに八幡宮ありて、その鳥居の前からが片側町、三角餅の茶店はこの外れにあるなり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "開場式のお歴々の群集も畢竟一種の囚徒で、工場主の晩餐会の卓上に列なる紳士淑女も、刑務所の食卓に並ぶルンペンらも同じくギャングであり囚人の群れであるように思われてくる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子よ、太郎よ、今、巴里のカフェー・ド・ユ・ラ・ペイユの張り出し椅子の並ぶあたりに春の夕陽が斜にさしかかってはいないだろうか。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣屋は此邊に棟を並ぶる木屋の大家で、軒、廂、屋根の上まで、犇と木材を積揃へた、眞中を分けて、空高い長方形の透間から凡そ三十｜疊も敷けようといふ店の片端が見える、其の木材の蔭になつて、日の光もあからさまには射さず、薄暗い、冷々とした店前に、帳場格子を控へて、年配の番頭が唯一人帳合をしてゐる。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹長以下これに従い一列に並ぶ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "……塚の前で、さしむかって、私と並ぶと、きみが、そのまま、白くなって消えそうで危っかしい。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は屋台が廻って、この玄関前へも練込んで来て、芸妓連は地に並ぶ、雛妓たちに、町の小女が交って、一様の花笠で、湯の花踊と云うのを演った。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同士討　　虐殺　　二重の壁　　赤城様――得三様　　旭一　急病　雲の峰は崩れて遠山の麓に靄薄く、見ゆる限りの野も山も海も夕陽の茜に染みて、遠近の森の梢に並ぶ夥多寺院の甍は眩く輝きぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
