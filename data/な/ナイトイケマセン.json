        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから今夜は大切な二人のお客さまがありますからどなたも静かにしないといけません。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ吐き出してしまわないといけませんよ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは最大急行で通らないといけません。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、よく調べないといけません。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大目に見ないといけません。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）御金は粗末にせずにしんぼうして使わないといけません。",
              "citation": {
                "source": "悶悶日記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先生に十分仕込んでいただかなければ、まるでお役に立ちませんよ」「なァに、役者になるには年が行き過ぎているくらいなのですから、いよいよ決心してやるなら、自分でも考えが出るでしょう」「きイちゃん、しッかりしないといけませんよ」と、お袋はそれでも娘には折れている。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二軒のあいだにはちょうど野原があるんですが、向こうへ行こうと思うと大きな道に沿ってから脇道に入らないといけません。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としてはそれだけを専門にしたいのですが、もちろん、まずちゃんと稼いでおかないといけませんし、いや、この話は横に置いておいて、シャーロック・ホームズさん、貴重なお時間であることは重々承知です。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者は、赤ん坊を見て、『よほど大切になさらないといけませんな、そして暖かく。",
              "citation": {
                "source": "かなしみの日より",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前、お台所の稽古も、少しはしておかないといけませんよ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く帰らないといけませんわ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお召物も、もうお着換へにならないといけませんね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃぜひ一度出かけてみなくってはいけませんな……けれど、林さんのような色男はよほど注意しないといけませんぜ、袖ぐらいちぎられてしまいますからな」と訓導の杉田が笑いながら言った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わ、私がしゃべらないといけませんか」「あたりまえだ」　長谷部大尉は一喝した。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事の時ならばなんでもないことが、大仰に仔細ありげに考えられますから、よっぽど注意しないといけません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "狐と僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、芯が疲れきっているのねえ」「用心しないといけませんよ。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御用心遊ばさないといけません。",
              "citation": {
                "source": "葛の葉狐",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が変ると、皆の気持ちがゆるむものですけれど、貴方たちは級長さんと副級長さんですから、先生を助けてしっかりして下さらないといけませんよ。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがたは、ここへいらっしゃったら、世界第一の文化都市へ来たとお思いにならないといけません。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのように高等教育を受けて世の中へ出たての人はとかく雷獣｜輩が食物にしたがるものですから、その辺はよく御注意なさらないといけません。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ斯う云ふことになつて居るので、警察へ屆けてあるんだと一應警察の手を經ないといけませんから……」斯う云つて時計は渡さずに歸したが、屆けてあるともないとも云はずに、職人は歸つて去つた。",
              "citation": {
                "source": "不良兒",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう二三日は、おとこの中でぢつとしてゐないといけません。",
              "citation": {
                "source": "あひるさん　と　にはとりさん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩の鹹い梅干なら四、五｜度もよく湯煮漏さないといけません。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この淡雪を拵える時白身の釈きようが足りないといけません。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
