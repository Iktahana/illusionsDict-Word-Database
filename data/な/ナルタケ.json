    "definitions": [
      {
        "index": 1,
        "gloss": "as (much) as possible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
