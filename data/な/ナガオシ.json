        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "所がその内にどう云ふ拍子か、彼のついた金羽根が、長押しの溝に落ちこんでしまつた。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその上へ乗りながら、長押しの金羽根を取り出さうとした。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は長押しに手をかけた儘、ぶらりと宙へぶら下つた。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "東北その他へ出る汽車には、みんながおしおしにつめかけて、機関車のぐるりや、箱車の屋根の上へまでぎっしりと乗上って、いのちがけでゆられていくありさまでした。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「川井君がのう、僕の背中を突くんで」　またあるときは、「僕が一ばんにおしっこがしとうなったら、島田君も山本君もみんながおしっこがしとなって先生が笑うたんで」などと克子はそっくり健になって、まるで自分が幼稚園の教室で、それを経験してきたようにお母さんに話す。",
              "citation": {
                "source": "赤いステッキ",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
