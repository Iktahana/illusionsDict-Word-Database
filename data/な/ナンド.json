    "definitions": [
      {
        "index": 1,
        "gloss": "how many times",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何度云つても同じだが、フォルムに就いての理念のないといふことが、当今文学人をして彷徨不安ならしめてゐる第一の事だと思ふのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "度々のことで面倒だから、今度から止めにして、先へ勝手に寝ることにしろと何度も言うが、妻は婦道に背くと言い、なかなか承知しないので困っている云々（大意）と。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は、何度も云ふやうだが詩人がその先人のお手本――茲では必竟本場のお手本といふことになるが――を、よく呑み込まなければならない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一句が頭の中に蔓延つてゐて、何度考へ直しても同し結果しか得られなかつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝が来るたびに、隣りのタカヂアスターゼの下から三番目の子供が、「イチオー………コイマー」と何度も／＼呼ぶのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ好い」といふ風な強い印象はないが、何度行つてもその度毎に親しみのあるやうな、比較的飽きない温泉である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "編暦をつかさどる人々は、たとえば東京における三月の平均温度が摂氏何度であるかを知らなくても職務上少しもさしつかえはない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの話は、柳家小さんの落語のごとく、クライスラーのクロイツェルソナタのごとく実に何度となく同じ聴衆の前に繰返されて、そうしてその度ごとに新しくその聴衆を喜ばしたものである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでも、あなたの氣の向いたやうに、とはじめから何度も言つてるぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近在の人らしい両親に連れられた十歳位の水兵服の女の子が車に酔うて何度ももどしたりして苦しさうであるが、苦しいとも云はずに大人しく我慢してゐるのが可愛想であつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の地震学上から判断される限り、同じ事は未来においても何度となく繰返されるであろうということである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対しては出来るだけの応急救済法を講じなければならないことは勿論であるが、同時にまた将来いつかは必ず何度となく再起するにきまっているこの凶変に備えるような根本的研究とそれに対する施設を、この機会に着手することが更に一層必要であろうと思われる。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間に子供の時から何度となく母上に聞かされていた土佐の安政地震の話がありあり想い出され、丁度船に乗ったように、ゆたりゆたり揺れるという形容が適切である事を感じた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近在の人らしい両親に連れられた十歳くらいの水兵服の女の子が車に酔うて何度ももどしたりして苦しそうであるが、苦しいともいわずに大人しく我慢しているのが可哀相であった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘が何度も青春を迎えるといった言葉が思い出される。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猪が仔猪をつれて来て相撲って遊ぶところです」　赤土は何度か猪の蹄に蹴鋤かれたらしく、綿のように柔かに、ほかほか暖そうであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰幅のよい長身に両手をだらりと垂らし、投出して行くような足取りで、一つところを何度も廻り返す。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら何度やっても同じことなのだ」　仕事であれ、男女の間柄であれ、混り気のない没頭した一途な姿を見たいと思う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の父は潔癖家で、毎朝、自分の使う莨盆の灰吹を私に掃除させるのに、灰吹の筒の口に素地の目が新しく肌を現すまで砥石の裏に何度も水を流しては擦らせた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何度通っても新らしい風物と新らしい感慨にいつも自分を浸すのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "掘り出したものは何度も何度も洗ったり泥を吐かせたりしなければならぬ。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を見ながらふと気の付いたことは、若いときから上野の花を何度見たかしれない訳であるが、本当に桜の花を見て楽しむ意味での花見をすることが出来るようになったのはほんの近年のことらしい、ということである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて私の住居を尋ねて来る人は、たとえ真昼間でも、交番やら店屋などを聞き聞き何度もまごついて後にやっと尋ねあてるくらいなものである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何度となく警告しに来た青年団員がおしまいに少し腹を立てたらその時だけ消した。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年の学校生活に暇乞をしてから以来、何かの機会に『老子』というものも一遍は覗いてみたいと思い立ったことは何度もあった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次にさあ早くお帰りと言われて何度も振り返って笑ったり手を振ったりし乍ら長屋の奥へ消えて行く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝三次がＴ「何度も言うがお絹さん。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）川端　君江が悲しそうに何度か※躇した後、遂に飛び込まんとする。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "六助とお絹は何度も去って行く二人に礼を述べる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大府岡崎｜御油なんど昔しのばるゝ事多し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
