        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そう言いながらわたくしが、いざ学園へ出かける気配いでも見せると、何かかにか理由をつけて引止めます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し話を途切らすと、君は、ぴくりとして眼を覚ますのだから、弱った」　それで葛岡は一夜まんじりともせず、何かかにか咽喉から声を出していたと言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから行くたびに何かかにか愚痴が出るようになり、程なく遂々お京さんはアンリーから逃げ出した。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃除がすんで一服する間もなく、そこにはもう何かかにか走り使ひが待つてゐる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆には、どこの家でも前の日から仕事を休んで、何かかにか忙しげであつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なく氣休めの言葉を何かかにか云ふと、その言葉を後生大事と覺え込んでゐて、醫者にかかつてゐる間、一日一日暦をめくつて、その約束の日に近づくのを、千秋の思ひで待ちかねてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "來やうが遲いとか、取り方が汚ないとか、始終何かかにか叱言があつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな何かかにか短く挨拶の言葉を云つて二階へ通つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の内心をみつめることをしないものだけがそこでは何かかにかやつて居れるといふことだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "じょうだんだと思ってきいてお呉れでない」とさんざん物悲しい事をならべたあげくとうとう行くことに返事されたのでにわかに一所に行く供人をえらんだり何かかにか用意するのに一週間許りは夢のように立っていよいよその日になった。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人を已めてから、実業界に這入って、何かかにかしているうちに、自然と金が貯って、この十四五年来は大分の財産家になった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "働いても働いてもゆたかな暮しが出来ないので、幾分かすてばち気味に、少し金が入るとすぐ何かかにかにつかって仕舞うので、よけい切りつめた暮しをしなければならないらしい。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭腦をも絶對に休めてゐようと思つてゐるのだが、しかし、生きてゐる限りは何かかにか、心に浮んで仕方がない。",
              "citation": {
                "source": "輕井澤より",
                "author": "〔小川未明君へ。〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かみさん連も、ここに住んでいると留守番がなくてすむから、何かかにか外へでてみんなで稼いでいますからね。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私のあずかつた憲法の中にございますが、ただの義務教育がどこにあるかというと、若し法律の素人が考えますと、どこの学校に入つたところで何かかにか相当の費用をとられている。",
              "citation": {
                "source": "涙をもつて正義をささえる",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人見さんと王仁さんはビールをとりにいらっしゃるし、一馬兄さままで何かかにかで時々いらっしゃるわね。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉六という男は他のことは分別のある癖に自分がしたことのないせいか、病気のことにかけては乱暴な男でして、母がそう言うと、「ちと食わにゃ、力もつくまい」　なにかかにか取寄せたり、土産を持って来たりして母に食べさします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」なにかかにか出そうだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかかにか出そうだ、何舞とかに舞と、地蔵舞を見さえな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ人間というやつは、興奮の振動体のようなもので、いつも二十四時間、なにかかにかの興奮に神経を焦がしている。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にはそんなことは構わぬと称する人も数多あるが、なにかかにか言われると、まったく無頓着に聞き流す人はほとんどない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかかにか、用をしたり、考えたり、然し結局、何にもしないと同じことだ。",
              "citation": {
                "source": "春盲",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうちは、三人でなにかかにか話題にすることもあつたが、そのうちに、安里はすぐにいつもの調子で自分勝手なおしやべりをはじめ、福子はだんだん黙り込んでしまつた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋にこもっていることが少なくなり、外へ出てなにかかにかする、薬園へでかけていって、鋸や鉋を借りだし、柵の毀れを直したり賄所の羽目板を打付けたりする。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際には腰は曲ってはいないのだが、腰の曲っているようなたどたどしい動作で、酒の燗をしたり、鍋の下を煽いだり、煮込みを皿へつけたり、箸や盃を洗ったり、絶えずなにかかにかしているが、それはできるだけ客と話すことを避けているようにみえる。",
              "citation": {
                "source": "嘘アつかねえ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うるさいもめごとや諍そいのない、静かな世の中がこないものかしら、相当な智恵者がそろっていて、いつもなにかかにかやりあっているのだもの、ねえ甲之助さん、あなた大きくなったら、もっと静かな住みいい世の中にして下さいね」　信乃は思いきって、知也が死罪になる、ということをうちあけようとした。",
              "citation": {
                "source": "めおと蝶",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――田口氏は三日にいちどぐらいずつ来て、なにかかにかして、では仲井さんお頼みしますと云って、片手に手鞄と洋杖、片手に黒いベルベットの帽子を持って、おっとりと一歩一歩おひとがらに帰っていった。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気さえよければおるいさんは一日じゅう、いや、殆んどというべきだろうが、いつも水道端にいて、なにかかにか洗い、器物類は家の横に並べて乾した。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
