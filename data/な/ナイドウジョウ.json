    "definitions": [
      {
        "index": 1,
        "gloss": "inner practice hall (for Buddhism; on the imperial palace grounds)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
