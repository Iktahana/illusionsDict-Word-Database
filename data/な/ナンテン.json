[
  {
    "uuid": "f45cbfbc-a40b-5caa-afc2-f80d0e627e1d",
    "entry": "何点",
    "reading": {
      "primary": "なんてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
