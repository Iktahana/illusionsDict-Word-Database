[
  {
    "uuid": "9ac19a00-eb0d-5e60-9ccb-e56c44bc5fb8",
    "entry": "なだれ込む",
    "reading": {
      "primary": "なだれこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
