          "literary": [
            {
              "text": "この方は何用でいらっしゃいました。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何用あつて行くやと問ひければ、そこにて児を殺したる事あれば、こよひは我も共に死なむと思ひてなり。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、我が家の前の道を、ラウペパ王が面を覆み、騎乗して、何用のためか、あわただしく走り過ぎた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何用で来なすった？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、お前らは一体何用でここへ来た？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　此夏の末頃から、何用あるとも無く、三日とあげずに、眞間のあたり駒を乘り廻し、雨風の日にさへ其立派な風彩で練歩く一人の若殿があつた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉虫　その与五郎どのが何用あってここへはまいられた。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕は何用でも大抵葉書で濟ますのだが、若し一｜枚で足りなければ二｜枚續きにする。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいよい、何用じゃ」「実は今朝ほど、御門内にいぶかしい笹折りが一包み投げ入れてでござりましたゆえ、早速一見いたしましたところ、品物は大きな生鯛でござりましたが、何やら殿様宛の手紙のような一事が結びつけてござりますゆえ、この通り持参してござります」「……？",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く手をふさいで何用があるのじゃ！",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "源空寺の和尚に何用があるんですかい」「どじだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「案内も請わずにぬうとはいって、何用じゃ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな品物、何用あって冥途まで持参するつもりじゃった」「あッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だれに断わって、このうちへへえってきたんだ」「死んだ音蔵にさ」「ご番所の野郎か」「しかり」「何用があるんだ」「御用筋の通った御用があって来たのよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おおこれは牧野氏、深夜のご来駕何用かな！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はいはい何用でござんすかえ？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さア何用で参れらたな？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「承ればお歴々、木地師風情の拙宅へ、何用あっておいでなされたかな」「されば」といったのは長崎左源太、一膝ズルよう進み出たが、「万事掛け合いは率直がよろしい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白紙へ筋を引いたのが碁盤、碁石といっても同じく紙製、眼のないほどの囲碁好きで、どこへ何用で行こうとも、この二品だけは携えて行く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "な、何用ではいってきたのか」「いや、その御挨拶は恐れ入りました。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何用で来なすったのかね？",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一寸すまないが××寺へ行って、権さんてのをつれてきとくれな」「そんな男に何用があるんだ」「まあ、まかしておくれ、わるいようにはしないから……仕様がない、おろくと一緒にするのさ」「一緒にするたって、荷物つきだぞ」「…………」　権は、飛び出た眼を不安そうに突き出して直ぐ来た。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼は、『ふん、何用ですって？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから自分は二十六日には朝何時に家を出て、何処其処に行って何用を弁じて、何時何十分頃に宅に帰っとると云う事が詳しく書いてある手紙を裁判所に出して下さい。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人の同心が、人々の逃げてしまった武者窓へ近づいて、顔を出すと、一人の門人が立上ってきて「何用か」　と、怒鳴った。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "八郎太は立ったままで「何用か？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重子はまた八重子で、「お姉さま、なによう」とすでに甘えかゝろうとする調子で返事する声が聞えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにようあんた、なにをリクエストしたんだよう」黄色い服の女がいった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なによう、のん気なこといって、御旅行かい、だなんてよう」肩をむき出しにした黄いろいワンピースの女は、ほがらかで、そしてひどく醜かった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一色村をお出になるとき、あんなにようお話し申しておいたでしょう。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
