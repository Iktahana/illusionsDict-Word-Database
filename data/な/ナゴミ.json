    "definitions": [
      {
        "index": 1,
        "gloss": "feeling of calmness and relaxation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この世なるえにしふかくして母よ子と和みくらさんみじかきこの世を。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の眼には真佐子のやや、ぬきえもんに着た襟の框になっている部分に愛蘭麻のレースの下重ねが清楚に覗かれ、それからテラコッタ型の完全な円筒形の頸のぼんの窪へ移る間に、むっくりと搗き立ての餅のような和みを帯びた一堆の肉の美しい小山が見えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏霞棚引きかけ、眼を細めてでもいるような和み方の東山三十六峯。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "和み合う睫の間にか、充ち足りた胸の中にか白雲の一浮きが軽く渡って行く。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚きはそのまま、心の和みが取り戻せた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川幅の大半を埋めている小石の大河原にも若草の叢の色が和みかけている。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女はまるで相手に関はぬ態度で、しかし、身体つきをちよつとかしげた顔に生れつき自然に持つ媚態とでもいつた和みを示し、ふくよかに答へた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへの気持ちの和みにもなるよ」　老婢は「へえ」と空返事をしてゐた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "圓山川の面は今、こゝに、其の、のんどりと和み軟いだ唇を寄せて、蘆摺れに汀が低い。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "和みなし、この世界ただ響きて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "和みにぎみたま、そは童。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "和み霊、また和せ、ただに安らと、荒み霊、まつろはぬいざことむけむ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく観よ、和み霊に吾が幼子、亀の子の揺る影を、鰭、さざなみ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "和み靈、また和せ、ただに安らと、荒み靈、まつろはぬいざことむけむ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく觀よ、和み靈に吾が幼子、龜の子の搖る影を、鰭、さざなみ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうがうしその薄光、寂び寂びしプラチナのすぢ、濃き淡き峰の畳みに、引きちがふ山の小襞に、また雨と和み注げり、柔かき金色の霧。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日は空がよく晴れ、横浜の沖は、春の海らしく和み渡った。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かも瓜　（やや和みたる調子にて）お前のいふことは、わしにとつて確かに新らしい世界の発見だ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした場合庸三はいつも無口で、葉子が客の朗らかな談敵になるのであったが、差向いの時よりも、その方がかえって庸三の神経に、いくらかの余裕と和みが与えられるのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく晴れた麗しい日和で、空気のなかには何か細かいものが無数に和みあっているようだった。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく晴れた麗しい日和で、空気のなかには何か細かいものが無数に和みあつてゐるやうだつた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもです、自然の和みのなかに溶け入る黄金の針のやうに微動し戦慄する感受性を開花させないならば、人工香料の平面的な、固定的な、直線的な表情でも、十分に酔ふことが出来るかもしれない。",
              "citation": {
                "source": "「香水の表情」に就いて",
                "author": "――漫談的無駄話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いなる救ひ主には逢はねども一人寂しく泣けばなぐさむ　宗教家の云ふやうな救世主とか、大慈大悲の仏菩薩とかには出逢はないでも、自分は唯だ一人で寂しく泣くことをすると心が和み、慰めが得られる。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで俺は何も彼も――山吹との恋のことや、その恋が今日破れたことまでお話ししたのでございます」「そうそうあの時のあなたというものはまるで狂人のようでしたね」　妙な人は打ち案じながら、「けれど暫時俺を相手に無駄話をしておられるうちに次第に心が和みましたな。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっと見ていると心が和み、つい恍惚となってしまう。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心は静かに和み海のように胸が開けて来た。",
              "citation": {
                "source": "開運の鼓",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和み充ち足りた心には、四辺のおどろしい風物も、これからの危険も苦にならなかった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泡や小さなごみからはまつすぐな影の棒が、斜めに水の中に並んで立ちました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "泡や小さなごみからはまっすぐな影の棒が、斜めに水の中に並んで立ちました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの深空にあるもしづかに解けてなごみ燐光は樹上にかすかなり。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
