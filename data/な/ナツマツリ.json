    "definitions": [
      {
        "index": 1,
        "gloss": "summer festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上田の町を歩いている頃は高原の太陽が町のアスファルトに照り付けて、その余炎で町中はまるで蒸されるように暑く、いかにも夏祭りに相応しい天気であった。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして村の連中が夏祭りの相談をしながら、一杯飲んでいる処へやって来て、口々に忠実めかして報告した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の夏祭りナア……ええか……今度の夏祭り時にナア……ええか……」　禿頭はニヤニヤ笑いながら桃の刺青の耳に口を寄せた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東北の夏祭りの山車と思はば大過なからん歟。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪は「よいしよ／＼」東京のは「わつしよ／＼」夏の日盛りの炎天の下で赤や黄や草色で彩つた團扇や手拭を持つて殺倒する、東京の夏祭りは、どこまでも野趣と蠻力とを持つてゐる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋祭りにはまだ間があり、夏祭りは過ぎてしまいました。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天神祭と言えば、夏祭りの多い尾道でも有名な祭りであるが、その夜に私は天神山の裏でばったりすみ子に逢った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした追憶の一番濃いのは住吉神社の夏祭りの夜の神楽の折のことだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾道は夏祭りの多い港であるが、住吉明神の祭礼は「お旅」と言って、街はずれの「御所」という海べの草っぱのあき地に神輿が移って、一夜を仮泊されるのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜からこの黄風島の夏祭りが始まるのだった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちの監守にとっても、それはやはり尊い夏祭りの夜だったのである。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭り　江戸ッ児の気勢は祭りに於て最も遺憾なく発揮される。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭りと両国の花火は夏の年中行事と市民にはなっていたのだろう、あんぽんたんも昼寝からむりに覚されて、行水の盥のなかへ入れられ、お船へのせて花火を見せるからと、だましだましいやがるのに着物をきせられた。",
              "citation": {
                "source": "牢屋の原",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の夏祭りは、六月の初めから、諸所で引き続いて行はれ、月末の住吉祭りで終る。",
              "citation": {
                "source": "涼み芝居と怪談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の夏祭りは鯵を焼き物に据ゑたからである。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方々々によつて、盆踊りに立てる髯籠系統の柱・竿は、夏祭りのものと混同せられてゐる。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　夏祭り平安朝に著しくなつたのは、神は楽舞を喜ぶものと考へる信仰である。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、夏祭りは、可なり後世に、祭りの体裁を備へて来たので、祓へ又は禊ぎと其に伴うた神楽から、音楽本位の祭礼の時代に、祭りとして認められる事になつたのであつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭りは、六月大祓へと同じ意義のものであつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文献で見れば、春祭りが一等古く、夏祭りが最新しい。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季の祭りの中でも、町方で最盛んな夏祭りは、実は一等遅れて起つたものであつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋祭りを主とする田舎の村々でも、夏祭りを疎かにする処はなかつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、夏祭りのまつりと言はれる様になつたのは、夏神楽の発達から来てゐる。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつりと神遊び・神楽との関係から、夏祓へは夏祭りと称せられる様になつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "形こそ替れ、事実から見れば、夏祭りの疫病と蝗害とを祓へ去らうとしてゐる事は一つであり、又一つの祭礼が、主神を換へて行はれた形にもなつてゐる。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮花祭は、三月末の行事だが、此は夏祭りの部類に入るものである。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "御輿のお渡りが行はれたのは、夏祭りの中心であつて、水辺の、禊ぎに適した地に臨まれるのである。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして其上に、夏祭りと同根の、夏祓への分化した様式が、七夕節供や水神供となり、又祭りの余興としか考へられなくなつた相撲があり、すつかり見えの変つて了うたのが、盂蘭盆であり、何ともつかぬ年中行事となつたのが、盆礼の「おめでたごと」であつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、近代最盛んな夏祭りは、実は、すべての祭りの前提として行はれた祓への、変形に過ぎなかつたのである。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
