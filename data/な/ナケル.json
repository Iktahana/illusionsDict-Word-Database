    "definitions": [
      {
        "index": 1,
        "gloss": "to shed tears",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "火に充ちし手のナポリの聖女、心菫に泣ける薔薇、聖ギヂルが花、汝は見しや天の砂漠に汝が十字架？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚の婦人たちが自由自在に泣けるのが不思議な気がした。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田　　泣ける奴は時々涙をこぼすようにしろ、いいか……じゃあけるぞ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと眼に入つたのは、今、此船の責任を双肩に擔へる船長が、卑劣にも此時、舷燈の光朦朧たるほとりより、天に叫び、地に泣ける、幾百の乘組人をば此處に見捨てゝ、第三の端艇に乘移らんとする處。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の時恥辱と恐怖とに弱きものの聲をも得立てず、傷み、悲み、泣ける容、粧はざるに愁眉、泣粧。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした、おまえさんが出かけてしまったら、思いきり泣けるんだからね」　町の人たちは、すぐに、だれかがまた、お姫さまに結婚を申しこんだことを知りました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらでも、いくらでも泣けるのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お寺の和尚さんに怒鳴りつけられたときも、蔵の中へ閉ぢこめられるときも泣かなかつた栄蔵は、今どういふわけで泣けるのか解らなかつたが、頬を伝ふ涙をとめることが出来なかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお祖父さんが、本箱のふたをしめてくれながらいふと、一層泣けるのであつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのくらい単純な内容で泣ける人が今の世にもあるかと思ったらありがたかった。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやすみなさいまし」と自分の寝床へこれからがいざ自分のために本当に泣けるのだと行く時分は、夜明けの烏が鳴き、東の空は白みかかっている。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣かない世代、泣けない私たちはもしかしたら、泣く時代、泣ける彼等より不幸なのかも知れない。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もなき国の白楊、列長う両側に顫へわななき、色青き蝋の火のほの暗みおびゆるごとく、広きより狭み暮れゆく其果の遠き切目に、仄かなる噴水の香ぞひとり密かに泣ける。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、急に泣けるくらい、悲しくなって来たのをこらえて、「ごめんなさいまし……」と、云った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣くことなら、あす、きみのでていったあとで、存分に泣けるからな。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の心は能く解つた」　今ははや言ふも益無ければ、重ねて口を開かざらんかと打按じつつも、彼は乱るる胸を寛うせんが為に、強ひて目を放ちて海の方を眺めたりしが、なほ得堪へずやありけん、又言はんとして顧れば、宮は傍に在らずして、六七間｜後なる波打際に面を掩ひて泣けるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその日のその夜に会ふ毎に、果して月の曇るか、あらぬかを試しに、曾てその人の余所に泣ける徴もあらざりければ、さすがに恨は忘られしかと、それには心安きにつけて、諸共に今は我をも思はでや、さては何処に如何にしてなど、更に打歎かるるなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの色を売るの一匹婦も、知らず誰か爾に教へて、死に抵るまで尚この頼り難き義に頼り、守り難き節を守りて、終に奪はれざる者あるに泣けるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその夜に限っては、葉子はだれの前でも素直な心で泣けるような気がした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間まではだれの胸にでも抱きついてしみじみ泣けると思っていた葉子は、その音を聞きつけるとはっというまもなく、張りつめたいつものような心になってしまって、大急ぎで涙を押しぬぐいながら、踵を返して自分の部屋に戻ろうとした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこで泣けるか、と思つた。",
              "citation": {
                "source": "蚊",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、自分は「泣ける場処」を発見したやうに思つた。",
              "citation": {
                "source": "蚊",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣けると思つたら泣けなかつた。",
              "citation": {
                "source": "蚊",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが部屋に、わが部屋に弊私的里の從姉きて蒼白く泣けるあり。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、今でも覚えている、俺はワッと声をあげて泣けるものなら、子供よりもモッと大声を上げて、恥知らずに泣いてしまいたかった。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで返つて楽々と泣ける気がするのであつた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ただこれだけで、感謝の意味で涙がこぼれるといふのか、または自分の身に關して泣けるといふのか、お粂には一寸わけがわからなかつた。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "癩がそれ自身何らの罪でもないにかかわらず、現実には、かくのごとく憎悪されずにいられないという宿命のおそろしさに目をふさいで、快く泣ける映画が作られたということはいろんな意味で私を懐疑的にしないではおかない。",
              "citation": {
                "source": "映画と癩の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉を継いで、「でも、俺は未だ泣ける――さう思つたら嬉しかつた……余計に涙が出て来た……今日は頬辺が紅くなるほど泣いちやつた。",
              "citation": {
                "source": "出発",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸張りて立てよ、　　林の雪のうへ、青き杉葉の落ちちりて、　　空にはあまた烏なけるを。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
