    "definitions": [
      {
        "index": 1,
        "gloss": "grove in summer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "魚臭き村に出けり夏木立　旅中の実咏である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青葉の茂った夏木立の街道を通って来ると、魚くさい臭いのする、小さな村に出たというのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白蝋の御両頬には、あの夏木立の影も映らむばかりでございました。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりむくと、刀をさしたさむらいが、夏木立の青い日影を浴びて立っていた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑いよ／＼濃かにして、夏木立深き處、山幽に里靜に、然も今を盛の女、白百合の花、其の膚の蜜を洗へば、清水に髮の丈長く、眞珠の流雫して、小鮎の簪、宵月の影を走る。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あやなき闇に凄然じや、閻羅と見ゆる夏木立」。",
              "citation": {
                "source": "「桂川」（吊歌）を評して情死に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、新聞で読んで感嘆したのはマダ一部少数者だけであったが、越えて数月この「武蔵野」を巻軸として短篇数種を合冊した『夏木立』が金港堂から出版されて美妙斎の文名が一時に忽ち高くなった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　初対面の印象　私が初めて美妙と音信したのは『夏木立』発行後間もなくであった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその中の「武蔵野」を感嘆した一人であったから、マダ学生の貧しいポッケットの中から『夏木立』をも購読し、『我楽多文庫』をも『都之花』をも愛読していた。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、美妙の『夏木立』は明治二十一年八月の出版で、『浮雲』第一編よりは一年遅れてる。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も『夏木立』中の「武蔵野」は初め『読売新聞』に載ったのであるが、やはり『浮雲』の方が先んじていた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨晴れやパンの樹のある夏木立三月十日　今日の午後二時にコロンボに着く筈。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季の題目を以てこれを例せんに夏山　夏野　夏木立　青嵐　五月雨　雲の峰　秋風　野分　霧　稲妻　天の河　星月夜　刈田　凩　冬枯　冬木立　枯野　雪　時雨　鯨　等はその壮大なる者なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、四季の題目につきて動きやすき者を挙ぐれば春風ト秋風　暮春ト晩秋　五月雨ト時雨　桜ト紅葉　夕立ト時雨　夏野ト枯野　夏木立ト冬木立　等数ふるに堪へざるべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "『先づたのむ椎の木もあり夏木立』　あの幻住庵の跡は石山から、一里ばかりも奧にあると聞いた。",
              "citation": {
                "source": "芭蕉",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車がなつかしい王子あたりの、煤煙に黝んだ夏木立ちの下蔭へ来たころまでも、水の音がまだ耳に着いていたり、山の形が目に消えなかったりした。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外で、夏木立が爽やかに初夏の空気を薫らせた。",
              "citation": {
                "source": "沈丁花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに茂れる夏木立は八幡の御社なり。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏木立の一語も、用ゐ得て妙也。",
              "citation": {
                "source": "鎌倉大仏論",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは、どうしても、夏木立ならざるべからず。",
              "citation": {
                "source": "鎌倉大仏論",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば　鎌倉やみ仏なれど釈迦牟尼は美男におはす夏木立かな　の如き歌では如何にも耳ざはりである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "成るほどこの歌の如きにしても　柔肌の熱き血汐に触れも見でさびしからずや道を説く君　のやうに　鎌倉や御仏なれどシヤカムニは美男におはす夏木立哉　のやうに一読直ちに瞭然とは行かない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、美妙の『夏木立』は明治二十一年八月の出版で、『浮雲』第一編よりは一年遅れてゐる。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も『夏木立』中の『武蔵野』は初め読売新聞に載つたのであるが、矢張『浮雲』の方が先んじてゐた。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹木と水との公園、日光が草の上におどる輝き、夏木立を愛する者はいくら歩いても飽きぬ公園だ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝の上の夏木立の色がまたすばらしく、そのあたりにつぎつぎと虹が生れる。",
              "citation": {
                "source": "滝しぶき",
                "author": "吉野秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ頼む椎の木もあり夏木立　　　　芭蕉　これはその『幻住庵記』の終りにくっつけてある俳句で、食物にこまれば椎の実を拾って食えばいい。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず何よりも頼りとする椎の樹もある、その辺一面の夏木立の中に、というのである。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "棟梁の材ばかりなり夏木立五月二十三日　大雪崩会歓迎句会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧みる七十年の夏木立草刈の顔は脚絆に埋もれて七月十日　句謡会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
