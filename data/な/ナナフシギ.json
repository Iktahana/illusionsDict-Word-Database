          "literary": [
            {
              "text": "土地に七不思議が有ればそれはその第一に数えて可い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "又か、とむかしの名僧のやうに、お叱りさへなかつたら、こゝで、番町の七不思議とか稱へて、其の一つに數へたいくらゐである。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――盲目なんだから、深川七不思議の中だらうぜ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若紳士が言ったのは、例の、おいてけ堀、片葉の蘆、足洗い屋敷、埋蔵の溝、小豆婆、送り提燈とともに、土地の七不思議に数えられた、幻の音曲である。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤスベエねえちゃんの、一高七不思議の一つ、「開かずの扉」には、もう、みんな、きゃあ、きゃあ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とムキになるのは大きに野暮、號外を見てぴしや／＼と額を叩き、「不思議だ不思議だ」といつたとて勝つたが不思議であてにはならぬといふにはあらず、こゝの道理を噛分けてさ、この七不思議を讀み給へや。",
              "citation": {
                "source": "神樂坂七不思議",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こののっぺら坊の話は、本所の七不思議の置いてけ堀と一つのものである。",
              "citation": {
                "source": "怪譚小説の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所ならば七不思議の一ツに数えよう、月夜の題目船、一人船頭。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが年々一日も違わないので、ここでは七不思議の一つと云われています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ私は美術界の七不思議の一つに、一人の人物を加へたいのである、それは奥村土牛氏である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "土牛はその気質の上からいつても運命的な作家であつたといふ意味からも画壇の七不思議の一つであつたことは確かである、印象批評が彼を「名人芸だ」とか「神品」だとか言つて、何事も語らなかつたから、一層不思議さはふかまつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶数ふれば十二勝、十六名所、七不思議、誰か一々｜探り得べき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ青臭い山の中で御座います」「青臭いどころか、お前、天狗巌だ、七不思議だと云ふ者が有る、可恐い山の中に違無いぢやないか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男、二人に向ひ、『鹽原には七不思議あり。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く逆杉、曰く一夜竹、曰く冬蓼、曰く冬桃、曰く夫婦鳥、曰く片葉ノ蘆、曰く精進川、これ鹽原の所謂七不思議なり』と説明す。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男更に語を改め、『この行にも七不思議が出來さう也。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを新七不思議の第一と爲さむ』と云へば、二人笑つて頷く。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを新七不思議の第三となさむ』と云へば、二人頷く。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち鹽原七不思議の一なり』と、裸男説明すれば、『これは別に何も不思議には非ず。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等の新七不思議の方が、ずつと不思議なり』と十口坊いふ。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おい／＼十口坊、新七不思議とは云ふものの、まだやつと三つだけに非ずや』と云ふ折しも、十口坊は手に持ちたる蝙蝠傘をぱツと開きて、さしかざす。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を新七不思議の第四となさむ。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を新七不思議の第五となさむ。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を新七不思議の第六と爲さむ。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議にはあらねど、假りに之を新七不思議の第七となさむ。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い雨の音が、傘をたたいて、本所七不思議の狸でも化けて出そうな夕暮れであった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事はむろんこのアパートの七不思議の一つに数えられているのでしたが、或る時、お隣りのミセスがチョットしたものを借りに来た序に、さり気なくこのことを尋ねてみますと、フラウはみるみる首のつけねまで真赤になりながら、うつ向き勝ちにこう答えられるのでした。",
              "citation": {
                "source": "奥様探偵術",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "置いてけ堀といえば、本所七不思議のなかでも、一番有名になっていますが、さてそれが何処だということは確かに判っていないようです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、本所の七不思議というのからして、ほんとうには判っていないのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この七不思議を仕組んだものには「七不思議｜葛飾譚」という草双紙がありましたが、それには何々をかぞえてあったか忘れてしまいました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
