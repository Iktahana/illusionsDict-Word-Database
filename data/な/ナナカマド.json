    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese rowan (Sorbus commixta)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
