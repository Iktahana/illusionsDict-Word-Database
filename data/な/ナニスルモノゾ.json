          "literary": [
            {
              "text": "片手なぞ、今は何するものぞ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川織田何するものぞと思わせたに違いない。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉にして見れば一小城何するものぞの腹である。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "術をもって対すれば、俳優何するものぞ。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸御免の眉間傷｜対手に治右ごとき何するものぞよ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十三万石何するものぞ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦塩であろうと吉林であろうと、何するものぞ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "些細な、富貴、幸福、何するものぞという……」　「そうだ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "些細な、富貴、幸福、何するものぞという……」「そうだ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "区々たる地位、片々たる財産、学理の前には何するものぞ。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "区々たる繩墨、彼に於て何するものぞ。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し此の如き微弱なる答辯は畢竟何するものぞ。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはきのう聖林寺の観音の写実的な確かさに感服したが、しかしこの像の前にあるときには、聖林寺の観音何するものぞという気がする。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし仏教の価値にして永世滅せず、機に応じてますます顕揚せらるべきものなりとせば、区々たる曲庇遂に何するものぞ。",
              "citation": {
                "source": "仏教史家に一言す",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい自分は――酔っぱらいの暴れ者は、あの昨日のだぼら吹きは、ああした処女と比べていったい何するものぞ？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "何するものぞっ」覚明は身を沈め、宙を切って行く薙刀の柄をのぞんで手をのばした。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲の献策で、多年、質子としていた信長の子を、安土へ送り返しはしても、心のうちではなお、（信長ずれが、何するものぞ）　という軽視は充分に残していたし、浜松の徳川家康に対してはなおさらのこと、（やがて、見よ）　と、いう反撃ばかりを、常に、長篠以後は殊に、誇示していた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "二万の敵軍何ものぞ、一猿面公、何するものぞ、という気概だった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十万の大軍、何するものぞ。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「呉人の青二才ども、何するものぞ」　蘇飛を大将として、陳就、※龍を先鋒として、江上に迎撃すべく、兵船をおし出し、準備おさおさ怠りない。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝ら、湖南の草民ずれが、何するものぞ。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「楠木の小細工など、公綱に何するものぞ。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "区々たる規律が、戦敗崩壊後に、なにするものぞ。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "果は「悠々たる哉天壌、寥々たる哉古今、五尺の小躯を以てこの大をはからんとす、ホレーショの哲学そもなにするものぞ」なんて、その書置きを暗記して、朗読して喜ぶ。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私が自由人であり、あなた方が入国を許可してくださるならば、衰えた体に鞭打ち、健康上の危険性も、命すらなにするものぞとあなた方の国に参上し、あなた方が目下中国および世界に対して、従ってあなた方自身に対してもなしている過ちを思い留まるようにと懇願することでしょう。",
