        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼も家の出入には、苗床が囲ってあったりする大家の前庭を近道した。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　凡そ同人雜誌は、新しい藝術の苗床であり花床でなければならない。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると細かく密生した苗床を草履か何かですりつぶしたりする。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の一部にある金蓮花はほとんど苅り取られ、園の苗床に冠せてある葭簀や、フレームの天井は明るみ切って、既に夏になり切っている。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど全体が滝から成っていると言ってもいい、谿流から水を引いて、苗床を拵らえるために、山間農民の忙しい最中であった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、晩飯をすますが早いか、祖父は鋤を持つて、晩播南瓜の苗床を新規に拵らへようといつて外へ出た。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草はもうだいぶ前に、苗床から本畑に移されてゐた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは苗床の底に敷きつめる落葉のかき集め、本畑に入れる數百貫もの堆肥の準備といふやうな仕事に始まる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "春、苗が六七葉を生じたところで苗床から本畑へ移植してからは、無事に根附くまで、どのやうな心勞であらうか。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕作段別がはつきりきまらなくては、苗床を作るにも、堆肥を作るにも差支へがあるのだが、さういつまでも延び延びにしておくわけにはいかなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗床は一間に四間のものが丁度一段分である。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この苗床の底に入れる落葉を掻き集めるために駿介は毎日｜竹籠を背負ひ、熊手を持つて山へ行つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗床には一尺五寸の厚さに敷きつめるので、十數囘にわたつてこの荷を運ばなければならないのだつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗床がすむと今度は本畑に用ひる堆肥だつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "堆肥の準備が終つたのちに、なほ殘つてゐる仕事は、苗床の掩ひに使ふ麥藁の薦を編むことである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから苗床の周圍に立てる柱や枠を作らねばならぬ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草の苗床準備がそれである。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗代地の冬起し、煙草の苗床の準備並に播種の時が相前後した。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗代地の耕起が濟むと、直に、煙草の苗床の準備であつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗床は本畑一段歩の分が一間に四間の廣さとして、今年の耕作段別は二段歩だから、二つ作らなければならなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介はかねて山から伐り出しておいた材木をもつて、苗床の周圍に立てる柱と、この柱を横に貫く貫木とを作つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱と貫木とをもつて、苗床の床框が成るわけだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上にさらに、早くからそのために織つておいた薦をかぶせて、かうして苗床の處置は一應終つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ぢゆう上にかぶせておいた苗床の薦をすつかり取り拂つてやる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時になると彼一人また煙草の方へ行つて、苗床に水をかける。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗床のかうした管理は、種子が發芽し、成長して、本畑に移植するやうになるまで續くことである。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草は發芽してからは、水は一日に一度やればよかつたが、駿介は水をやる時以外にも、暇があれば來て、苗床を見護らずにはゐられなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑に來た駿介は、苗床の上に急いで小麥藁をかぶせて行つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜木林の開墾から、落葉の掻き集めから、堆肥の準備から、苗床をしつらへるまでの一切を思ひ出した。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……畑仕事、苗床をこしらへる、唐辛を播いておく。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
