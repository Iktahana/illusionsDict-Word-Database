[
  {
    "uuid": "5ee9f788-d9bf-5818-b43a-8f5cbe60f621",
    "entry": "馴れ馴れしい",
    "reading": {
      "primary": "なれなれしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
