    },
    "definitions": [
      {
        "index": 1,
        "gloss": "person inside a cartoon body suit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "医者も患者も面白がつて、病院中の人気者だつた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの世の中の人たちは、そんなに容易に敬服などするものでない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっとしていつしか書中の人となりける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひはまた、道徳の善惡よりも、感覺の好き嫌ひに依つて世の中の人たちはその日常生活に於いて互ひに罵り、または罰し、または賞し、または服してゐるものだといふ事を暗示してゐる笑話であらうか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「世の中の人は皆、嘘つきだから、話を交すのがいやになつたのさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の水が子守歌のように、高くなり、低くなって、私たちの足音を消して、後から追い冠せて来るときには、一行はまた、森の中の人となっていた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四は、山の不幸は、住人の不幸になって、シャスタ山と、切っても切れぬ歴史中の人を、埋没しようとしている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、画中の人物が蒲団を引っかぶる。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、今日世上に、家庭問題を論究しつつある人々の内にも、必しも不円満な家庭中の人｜許りは居るまい、人の模範となるべき家庭を保って居る人も、多いであろうけれども、実行の伴わない論者も、決して少くはあるまいと思う。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "円満な家庭中の人が、却って不円満な家庭の人から講釈いわるるような、奇態の事実がありはせまいか。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中の人山中の趣になれて、却て其の趣味を解せざるが如く、家庭趣味に浴しつつある人も、其の趣味を談ぜざれば、折角身幸福の中にありながら、其の幸福を、十分に自覚しないで過ぎ去る訳である。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一体にシンとしてまた如何にもハッキリとした景色、吾等二人は真に画中の人である。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで家中の人が皆集って、それをどうしようかと相談しましたが、可哀相なような気持もするけれど、見ずに置くのも気にかかる、とにかく開いて見るがよいと、あれの父が言い出しまして、皆の居る中であけました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを調べた上で、もし出来るならば、世界中の人間がことごとく盲あるいは聾であったとしたらこれらの人間の建設した科学は吾々の科学とどうちがうか、という問題を考えてみたいと思っている。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリンピック競技では馬や羚羊や魚の妙技に肉薄しようという世界中の人間の努力の成果が展開されているのであろう。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつまり国務大臣や宮中の人が科学に縁のない人ばかりだからであろう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に彼は、國定教科書の中にも採用さるべき立志傳中の人物である。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のかいた海岸や砂丘や静かな北国の街々なぞの景情が友を遠い旅中の人として私の故郷を訪づれた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中の人の心は緊張と弛緩の波の上に泛っている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒楼の下の岸には画舫もある、舫中の人などは胡麻半粒ほどであるが、やはり様子が分明に見える。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「読者の中の人間」を拡張し進化させるようなものならばそれを文学と名づけるになんの支障があろうとは思われないのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの退屈は下手な芝居映画の退屈などとは全く類を異にした退屈であって、それは画中の人生と自然そのものの退屈から来る圧迫感である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど先生が「吾輩は猫である」を書いていた時だから、さっそくそれを利用されて作中の人物のいたずら書きと結びつけたのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇中の人物に自己を投射しあるいは主人公を自分に投入することによって、その劇中人物が実際の場合に経験するであろうところの緊張とそれに次いで来るように設計された弛緩とを如実に体験すると同等の効果を満喫して涙を流しはなをすする、と同時に泣くことの快感に浸るのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中の人というものは、お互い、こわばった挨拶をして、用心して、そうしてお互いに疲れて、一生を送るものなのでしょうか。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかでも、「奪い合い」という長編戯曲に就いては私は、いまでも、その中の人物の表情までも、はっきり思い出すことができるのであります。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まん中の人はせいも高く、大きな眼でじっとこっちを見てゐます。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まん中の人はせいも高く、大きな眼でじっとこっちを見ています。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国中の人間はこのお布告を見ると大騒ぎをして、お祝いの支度を始めました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "変だなと思っておうちへ帰ってみると、家中の人は皆、太郎さんの顔を見て一時に笑い出しました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
