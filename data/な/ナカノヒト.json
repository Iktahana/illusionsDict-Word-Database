[
  {
    "uuid": "8150248c-9da1-5782-a5e5-da3e087f7422",
    "entry": "中の人",
    "reading": {
      "primary": "なかのひと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "名詞"
      ],
      "ctype": null,
