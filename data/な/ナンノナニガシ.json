    "definitions": [
      {
        "index": 1,
        "gloss": "certain person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして宿所がきまるや、さっそく築地何町何番地、何の某方という桂の住所を訪ねた。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通何の某家と書くところを、わざとそうしたのは宣伝のためだと、見て人も気付いた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代、諸大名の御前で細工事ご覧に入れた際、一度でも何の某があやまちをしてご不興を蒙ったなどということは聞いたことが無い。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "袋には朝日軒と書かれてあり、普通何の某家と書くところを、わざとそうしたのは無論宣伝のためであったろう。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし文学士何の某というような名ばかりを振り廻すのが、社の働でもあるまいと思うから言うのだ」「いや。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、極く内々の話だが、今でこそ私は腰弁当と人の数にも算まえられぬ果敢ない身の上だが、昔は是れでも何の某といや、或るサークルでは一寸名の知れた文士だった。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "京橋の誰それ、烏森の何の某、という風に、参詣した連中の残した御札がその御堂の周囲にべたべたと貼りつけてある。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、先ず大きな字で、『一千八百何十何年』と書き、次いで小さい字で、『地主、何の某』と書いてから、必要な事項を残らず認ためた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　一切不捨　何の某は帽子ばかり上等なのをかぶつてゐる。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその帽子を除いたにしても、何の某の服装なるものは、寸分も立派になる次第ではない。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の某の小説はセンテイメンタルだとか、何の某の戯曲はインテレクチユアルだとか、それらはいづれも帽子の場合と、選ぶ所のない言葉である。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "見世物はそれ位にして、今から考えると馬鹿々々しいようなのは、郵便ということが初めて出来た時は、官憲の仕事ではあり、官吏の権威の重々しかった時の事ですから、配達夫が一葉の端書を持って「何の某とはその方どもの事か――」といったような体裁でしたよ。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると我我の目の前に何の某と云ふ人物を立たせ、その何の某の英雄たることを認めさせる為には、凡人たらざる半面を指摘すると同時に凡人たる半面をも指摘してなければならぬ。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どの藩の者ということを聞かれはしなかったか』と古参が聞くと、『なるほど代物はいただきませぬが御名札をいただきたいといったから、松平隠岐守家来何の某と書いて置いて来た。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が思ふに、日本人は、道徳的に利己主義者だといふわけでもなくて、たゞ、「赤の他人」といふ言葉の含む、何の某ならざる人物に対する無意識の疎隔感情が、いかなる場合にも自分を周囲から孤立させてしまふのである。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち親爺もＫさんの魂胆が分かり、Ｋさんの前身が、何の某の身内の何の某といふ人物だつたといふやうなことも分かつて、大いに慌てはじめた。",
              "citation": {
                "source": "囲碁修業",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "右方に副主任の青木がゐるところからして、このとき昌造は主任であるわけだが、前方の「役人」たちは三人共若い丁髷で、何の某と名乘る大官でもなささうだから、主任ではあつても技術面の昌造らの位置といふものは今日の常識からは、はるかにひくいものだつたのであらう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "圓蔵の顔がしばらく、暗く、うすらかなしく、その中から、「八笑人」の、あの仇討のひとくさりの「ヤーめずらしや何の某……」。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の某と言ふ楊弓の名人でもなければ――」「一應尤もだが、平次、まぐれ當りと言ふ事がある」「へエ」　平次も弱りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのペルシャの絨毯を見られよ、何の某が作ったかを問うことなくしてその美を感じる。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の某と言う楊弓の名人でもなければ――」「一応尤もだが、平次、まぐれ当りという事がある」「ヘエ」　平次も弱りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大村兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬も何の某という立派な血統のある犬でも訓練が悪いと駄犬に劣るものだそうだ。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、女子供連れで遊びに釣るのはいいが、都釣連の何の某という名まえの通った人が競技会をやるのはどうかと思う。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今日の近代戰は、一體相手の顏をみたこともなければ、何の某かわからない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議にもそこには何の某という者がないのです。",
              "citation": {
                "source": "民藝とは何か",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "源平時代の戰において、花やかな武者と武者が双方の陣頭に立つて、一方が「われこそは清和天皇の後裔何の某の末孫何の某」とやれば、片方は「われこそは桓武天皇の後裔何代目の誰だ」などとやつてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにがし区なにがし町――といつても、つい先年まではさしづめ武蔵野などと言つてゐたあたりの、なにがし精神病院内、なんのなにがしと書いてある。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう言へば手紙の最後の署名にも、又封筒の裏面にも、日付の下になんのなにがしとあり、やつぱりはんこが捺してある。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、霊魂の不滅を主張せんとするものは、またこれに対して説をなしていう、「たれがしは死後幽霊となりてその形を現したり、なんのなにがしは死後再生したることあり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きている時こそ、なんのなにがしと名前が有ったり金が有ったり慾が有ったりしますけれどごらんなさいまし！",
              "citation": {
                "source": "詩劇　水仙と木魚",
                "author": "――一少女の歌える――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
