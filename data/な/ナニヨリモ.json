    "definitions": [
      {
        "index": 1,
        "gloss": "more than anything",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "感覚、つまり自然を何よりも大事に守つて居るからである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに私のやうな貴族的な性情をもつて生れた人間にとつて何よりも寂しいことは、あのなつかしい「愛」の欠陥である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて稀にみる子供らしい純一無垢な性情と、そして何よりも人間としての純潔さを、私共は互に愛し悦びあつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも私は、彼の「聰明さ」が氣に入らなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも彼は、詩の表現效果について意見を述べた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも不可解なのは、一面極めて冷靜なる理智の人でありながら、一面狂氣じみた情熱に内燃してゐる人のやうであつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも彼の矛盾は、一面に於て「典型的な小説家」でありながら、一面に於て「典型的な詩人」であることだつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも芥川君は、私を本質的によく理解してくれた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお手紙の文面が、やさしく正直なのも大きな悦びでありましたが、それよりも何よりも、私にはあのお手紙の長さが有難かったのです。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂に拠れば、男女川はその身長に就いての質問を何よりも恐れるそうである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」山田君は、何よりも先に、その箇所に目をそそいで言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間修業」だの、「自然に親しむ」なぞといふことが云はれるが、それはもとより大切乍ら、それと詩とは只関係が密接なだけで、先づ何よりも先人の作品は読まれなければならぬ。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも彼はもと善良な人で、その善良は今も依然存するが、彼の善良は働きを失つてゐる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりもその證據は、子供たちの悦ぶ映畫が、常に忍術使ひの出るチヤンバラ劇と、奇々怪々の夢に充ちた漫畫映畫と、ポンチ的諧謔のチヤツプリンとに限られてゐる。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも我々は、國語問題の急務として、今日「耳の健康」を囘復せねばならないのである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも彼の心は、そうした「家郷」が欲しかったのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　おそろしい冬に於て、何よりも人々は火を愛した。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも気温の高くなるのが、ありがたいのである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの事を考えると、何よりも年老いた父に気の毒だ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄棚もあり、枝折戸もあり、何よりも値が安く、六圓五十錢なので、それが嬉しかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天空に浮遊するかの如き、嶮にして美なる林道を「天の浮橋」と呼ぶそうであるが、何よりも喬木林の陰森さにおどろかされる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白つぽい砂礫を洗ふ浅緑色も一種特別なものであるが、何よりも河の中洲に生えた化粧柳の特異な相貌はこれだけでも一度は来て見る甲斐があると思はれた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からその時に備えるのが、何よりも肝要である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この水準を高めるには何よりも先ず、普通教育で、もっと立入った地震津浪の知識を授ける必要がある。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何よりも先ず事実の方から確かめてかかる事が肝心であるから、万一読者の中でそういう現象を目撃した方があったらその観察についての示教を願いたいと思う次第である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白っぽい砂礫を洗う水の浅緑色も一種特別なものであるが、何よりも河の中洲に生えた化粧柳の特異な相貌はこれだけでも一度は来て見る甲斐があると思われた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛唐国の花だとさげすみながら、人は何と争って五月の花壇の真中に何よりも大切にこの宝石の様な花たちを、栽培するようになった事よ。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何よりもその器械の簡単さに驚いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについて先ず何よりも先に思い当るのは現代の教育のプログラムである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分等が商売がら何よりも眼につくのは物理学の中等教科書の内容である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
