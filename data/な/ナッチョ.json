        "examples": {
          "standard": [
            {
              "text": "バーで注文したビールには、付け合わせにナッチョが付いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、ナッチョにチーズソースをたっぷりつけて美味しそうに食べていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この店のナッチョは自家製トルティーヤチップスを使っていて、香ばしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（いきなり、投げやりな調子で歌い出す「チンタオ節」）海尻よいとこと誰が言うた、うしろはハゲ山、前は川、尾のないキツネが出るそうな、僕も二三度だまされたあ、ナッチョラン！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は貧乏身よりはチリヂリ、あっちもこっちもナッチョランかっ、尾の無いキツネにもなりますがな！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他を見て「お前さんはバカだ」と言ったり、「これこれの作品はナッチョラン！",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
