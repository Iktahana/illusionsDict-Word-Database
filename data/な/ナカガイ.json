        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "始末に困るんだよ」　こんな鷹揚なものの云い方をしながら父親は獲物を鰻｜仲買に渡した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数百の受話器が仲買人たちの耳に瞬間に数千の符牒を発した。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それにまた、思ひ掛ない巡り合せで、人にはどんな好運が向いて※ないとも限らないからね……」　ヽヽヽヽヽヽヽ　それから半年ほどたつた時、ちの一万二千三百七十五｜号の△△債劵は仲買人を※て、ある田｜舍の大｜地主の手に渡つてゐた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘアネットの髪、田舎の辮髪者の髪、三銭か四銭で切らして、仲買人、公司へ持って来て売る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "公司、仲買人の持ってきた髪を、また六割か、五割に値切る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――仲買人、掛値を云うて持ってくる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲買人、巡警と来て、切れ、切らなければ、税金をとるという。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんな税金、仲買人と、巡警が勝手にこしらえた税金、そんな税金ない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利人の公司、仲買人と巡警に金掴ましている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、安二郎は廃球以外に新品の電球も扱っていて、電球工場から仕入れたのを地方の会社や劇場に納入する一種の仲買いの様なことをしていたが、時々｜刺青のたあやんと称する男が、五百個千個と電球を売りつけに来るのを安い値で買いとっていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の父は京都にいる時分から鼓の修繕や仲買い見たようなことをやっていた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "各地の銀行や仲買店を次から次に汗だくだくで呼び出しつつ、資力の続く限り製糖株を買いにまわった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢき近くの、縮の仲買商人の子の新太郎ちやんである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして縮の仲買商人になつた今でも、塩沢とか十日町とか小千谷といふやうな、越後でも山の方の町や村から縮を買入れて来ると、この呉服問屋で買つて貰つてゐたのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼッテルベルグ老人はもと株式仲買人で、今は財産の利息で暮してゐる氣樂な體だつたが、その收入が幾分減つたので、寒くて不自由でも少し暮しを詰めようといふ譯で、今年の冬はストックホルムからわざわざ寒氣の嚴しい島の別莊へ移り込んだ。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、グスタフソンは深々と座席に埋めた大きな體を重たさうに動かしながら、「どうも聞き覺えのある名前だと思つて今まで頭をひねつてゐたんだが、そいつは金貸し兼仲買人のやがて七十になる爺さんだよ。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では隨分大きい仲買所でも仕拂を多少づつ遲れさす、即ちそれ丈人の金を融通しておくのである。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広っ場の中は一めんの死体で、ちょうど沖から帰って来た漁師が思い思いに海岸へ魚の盛りをこしらえて、仲買人の来るのを待っている時のように、人の盛りをこしらえてあった。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後藤は後に名を庄吉と改めて米の仲買を業としていた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って三五屋という名前は大阪では一廉の大商人で通っていたが、長崎では詰まらぬ商人宿に燻ぶっている狐鼠狐鼠仲買に過ぎなかった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又二人の友人で又木某という他県人の青物仲買人があった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンバルト街の大きな株式仲買店で、モーソン・ウィリアム商会と云う所に欠員を。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私はすぐさま夜中に乗り込んで、今朝お目にかかって、そのままバーミングハムへ私と一しょに来ていただこうと思ってやって来たわけなのでございます」　株式仲買店事務員は彼の不思議な経験を話し終ってから、ちょっとだまった。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名なる仲買店モウソン・ウィリアム会社には、常に百万｜磅以上に相当する株券、債券、あるいは保証金などのあるため、番人を常備しありたる上、支配人は用心深く、彼が負わされているそれらの重用物件のために、最新式の金庫を数個用意し、その上ビルディング内には、昼夜の別なく見張人を残しありたるなり。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『で、ただいまはモウソンの仲買人で。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が前にいたような、ぴかぴかの机にずらりと並んだ仲買人、というような大事務所を考えていただけに、正直言って、目をまっすぐ見開いてしまいました。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "株式仲買人の驚くべき経験が語られたあと、つとシャーロック・ホームズが私に目配せをする。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と仲買人が声を張り上げて、「あそこ、ぼくらの前を行くのがやつです。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仲買人の先導で五階まで昇ると、目の前に半開きの扉があって、そこを依頼人が叩く。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はその仲買人を誰だかわからないかのように見つめていて、私は案内人の顔に表れた驚愕から、これはけしてその雇い主の平生の表情ではないと知った。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
