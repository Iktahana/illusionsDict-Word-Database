[
  {
    "uuid": "1898a3b3-c9e1-56be-bea7-c299a7a99f2d",
    "entry": "何とやら",
    "reading": {
      "primary": "なんとやら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
