[
  {
    "uuid": "a5735a28-6f14-5de4-961e-d47c62737c72",
    "entry": "投げ打つ",
    "reading": {
      "primary": "なげうつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Godan verb with 'tsu' ending",
        "動詞-他動詞"
