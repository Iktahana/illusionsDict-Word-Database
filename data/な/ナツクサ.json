    "definitions": [
      {
        "index": 1,
        "gloss": "summer grass",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人夫よ　はやく夏草を刈りつくせ狼火をあげよ　烟を空にたなびかせよ空想の陣幕を野邊にはつてまぼろしの宴樂をほしいままにせよ。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草が生ひ茂つて、出たばかりの朝日は露にキラキラ光つてゐた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮒鮓や彦根の城に雲かかる　夏草の茂る野道の向うに、遠く彦根の城をながめ、鮒鮓のヴィジョンを浮べたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は天主閣の建っていた所が平地になって、いつしか姫小松まばらにおいたち、夏草すきまなく茂り、見るからに昔をしのばす哀れなさまとなっています。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草の茂った中洲の彼方で、浅瀬は輝きながらサラサラ鳴っていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う側は、袖垣、枝折戸、夏草の茂きが中に早咲の秋の花。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "屹と心を取直し、丈に伸びたる夏草を露けき袖にて押分け押分けなお奥深く踏入りて忍び込むべき処もやと、彼方此方を経歴るに、驚くばかり広大なる建物の内に、住む人少なければ、燈の影も外へ洩れず。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥は寂然とした夏草塚の傍に、小さく見えて待っていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草や兵者どもの夢の跡――わたしも芭蕉翁を気取って、しばらく黯然たらざるを得なかった。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草にまじつて、こゝそこに咲きみだれてゐる鬼百合はまつたく炎天の花といひたい矜持をかゞやかしてゐる。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふの酔がまだ残つてゐるつく／＼ぼうし・ま昼ふかうして鳴子鳴る・ゆふべの夏草をふみわける音がちかづく・日ざかりあるくはつるんだ虫で　八月十六日朝風は秋風だ。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の薄暗い中に、紅や黄の夏草の花がポツ／＼見える。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少、ねむそうな顔をしているが、それでもどこかに、ひとかどの風騒の士の構えを示して、夏草を踏みわけ河原へ向った。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには夏草が繁つて居り、油蝉が木立に鳴いて居た。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "題のない歌南洋の日にやけた裸か女のやうに夏草の茂つてゐる波止場の向うへ　ふしぎな赤錆びた汽船がはひつてきたふはふはとした雲が白くたちのぼつて船員のすふ煙草のけむりがさびしがつてる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は校庭に夏草茂り、｜四つ葉のいちめんに生えたれども、今は野球の練習はげしく、庭みな白く固みて炎天に輝やけり。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まどろすの歌――風船乘りの夢夏草のしげる叢からふはりふはりと天上さして昇りゆく風船よ籠には舊暦の暦をのせはるか地球の子午線を越えて吹かれ行かうよ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "題のない歌南洋の日にやけた裸か女のやうに夏草の茂つてゐる波止場の向うへ　ふしぎな赤錆びた汽船がはひつてきた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも夏草に見る情熱の奔騰する激しさはなく、近寄つて見なければその存在さへもはつきりしないほどに慎ましく控え目である。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが最初の夜から歳子を一番驚かしたのは、一面｜茫々と生えてゐる夏草だつた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、きょ年の夏、兵太郎君と川あそびにいって、川からあがったばかりの、ぴかぴか光るおたがいのはだかんぼうを、おいしげった夏草の上でぶつけあい、くるいあって、たがいに際限もなくわらいころげたことだった。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中、処々夏草の茂りに蔽われたのに、雲の影が映って暗い。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　姫の紫の褄下に、山懐の夏草は、淵のごとく暗く沈み、野茨乱れて白きのみ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庫裡の縁先には夏草が高くしげつてゐて、鷄頭の花が四つ五つ咲いてゐた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は女から十歩ばかり離れて歩きながら、ステツキを振つてみちみちの夏草を薙ぎ倒してゐた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幅一尺か、五寸くらいの心細い野道を、夏草の露を避けながら、ゆらゆら自転車に乗っていった。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚下に延びはびこった夏草の中をがさがさと這う音もした。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、惜むべし杉の酒林の落ちて転んだのが見える、傍がすぐ空地の、草の上へ、赤い子供の四人が出て、きちんと並ぶと、緋の法衣の脊高が、枯れた杉の木の揺ぐごとく、すくすくと通るに従って、一列に直って、裏の山へ、夏草の径を縫って行く――この時だ。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすみのたなびくはるの野べにほほえむすみれのゆかしきかななつくさしげれるおかのうえにさけるなでしこのやさしきかな人の世のためしいかにもあれ神とともにある身ぞやすけき　和田弁太郎はその歌声に耳を傾け、それら一団の顔を眺める。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
