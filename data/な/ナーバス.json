          "literary": [
            {
              "text": "「人の神経をナーバスにして、人の心を萎縮させて、その生活を憂鬱にさせる。",
              "citation": {
                "source": "沙漠の美姫",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わきにやけ出されの女、ナーバスになって居て、こわがり此処に居て大丈夫でしょうか、としきりにきく。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十二日（土曜）　山内さんケイコ、今日自分少しナーバスなのを、話して居る間に感じた。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
