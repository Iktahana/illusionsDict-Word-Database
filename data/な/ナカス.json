[
  {
    "uuid": "44027781-f961-5460-ae00-3cfe7d8bfd7d",
    "entry": "泣かす",
    "reading": {
      "primary": "なかす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to make someone cry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「阿波十郎兵衛など見せて我子泣かすも益なからん」源叔父は真顔にていう。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等を泣かすのは何時でも私であつた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の再現して見せたその調子は自分を泣かすだけの力を持っていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんな本箱みたいな生物学者を泣かすなんて、どうも偉い細君だな。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸になほ物見る子らはうづくまり、はや倦ましげに人形をそが手に泣かす。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は遂に父親から、三十にして親を泣かす、俥挽き土を掘り石を担げと罵られた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊子のかげ、扇のかげ、動く兎の紫のかげ、花瓶のかげ、皿に転がる林檎のかげはセザンヌ翁をも泣かすらむ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "影はなによりまた寂し、踊子のかげ、扇のかげ、動く兎の紫のかげ、花瓶のかげ、皿に転がる林檎のかげはセザンヌ翁をも泣かすらむ。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音の卑しく、其響の険なるは、幾多世上の趣味家を泣かすに足る者あるべし。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「流れ流れてェ、落ち行く先はァ、北はシベリヤ、南はジャバよ……」というその曲が、もう五十近い他吉の耳にも、そこはかとなく物悲しく、賑かな場所で泣かすまいと、わざとそんな場所をえらんで連れて来て、手紙を見せる、その前から、もう他吉は涙が出て来た。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中マリウチアといふ娘は、この戲にて我を泣かすること屡なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お春を捕へろ、帰つた奴は泣かすぞ。",
              "citation": {
                "source": "蚊",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぎし日のあどけなかりし哀愁はこまやかに匂シヤボンの消ゆるごと目のふちの青き年増や泣かすらん。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も冷たい指さきの青い疵さへ、その身さへ、遊びつかれて見て泣かす、君が狂氣のしをらしや。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒を笑はすといふ事は、女を泣かすといふ事と同じやうに、立派な教育である。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は貴方の事許りを考へて優しい女らしい事を並べたてゝ、只貴方を泣かすのではないんですの。",
              "citation": {
                "source": "獄中の女より男に",
                "author": "原田皐月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「清二――年寄りを泣かすでねえぞ。",
              "citation": {
                "source": "前夜",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、所領の統治者としても手腕凡ならず、百姓を泣かすな、ふとらせるな、といふのが彼の統治方針。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字も読めない文字の中から、綺麗な異人を泣かすほどの悲しさが、妖しいまでの艶めかしさでむらだち流れてくるのであつた。",
              "citation": {
                "source": "母を殺した少年",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "男を泣かすのは男の友情だということを、わしはこんどはじめて、つくづくと知ったよ」　左膳のことばかり言われるのがお露には、少女らしい胸に、不服なのか、「はい。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井常次は休憩時間十分間に十一人の子供を泣かすことは稀で無かつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供を泣かす、床板を焚く、そして『耶蘇の奴畜生めが八釜敷うて寝られんわい』と礼拝の讃美歌に反対する。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方が小さくて、何かじぶくって泣くとお母さんが、もうやめいなと云うと、虫が泣かすんじゃああーんと泣いたという話、こういう伝説を御存知ですか？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母様が御秘蔵で、おおええええ顕治が泣くんじゃない虫が泣かすんだ、のうと仰云るのを覚えていて云ったのですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔小さかった時「虫が泣かすんじゃあ」と泣いた人は、成長して、虫は余り敏感に作用しなくなったかどうかと云うことを話して、大笑いしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪戯な快活な金髪の娘で、彼女を泣かすのを面白がり、泣かしたあとではやたらに接吻してくれた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、七兵衛がいうには、自分の盗人ぶりの質の良いというのは、盗んで人を泣かすような金は盗まず、盗んだ金を自分の道楽三昧には使わず……ことに自分は盗みをするそのことに趣味を感じているのだから、盗んだあとの金銀財宝そのものには、あまり執着を感じていない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯屋の白ツ子と、パン屋の兄弟とが聯合して岩公を泣かす時僕はいつも助けてやるのだつた。",
              "citation": {
                "source": "夏の月",
                "author": "川端茅舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の鉄瓶の単調なかすかな音を立てているのだけが、何だか心強いような感じを起させる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼頃近くになっても霜柱の消えないような玄関の前に立って呼鈴を鳴らしてもなかなかすぐには反応がなくて立往生をしていると、凜冽たる朔風は門内の凍てた鋪石の面を吹いて安物の外套を穿つのである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
