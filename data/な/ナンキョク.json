    "definitions": [
      {
        "index": 1,
        "gloss": "South Pole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕と室生の對立したこの世界は、互に兩立できない世界であり、地球の南極と北極である。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに反対の極端の例をあげてみると、あの厖大な南極大陸の上にすむ「陸棲動物」の中で最大なるものは何か、という人困らせの疑問に対する正しい解答は「それは羽のない一種の蚊である」というのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先日まで、南極が一ばん暑くて、北極が一ばん寒いと覚えていたのだそうで、その告白を聞いた時には、私は主人の人格を疑いさえしたのである。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二番書記、アンモニアツク兄弟の中で、南極へ行つたのは誰だ。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パン、ポラリス、南極探険の帰途、ヤツプ島沖にて死亡、遺骸は水葬せらる。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "これわれと永久に別れて無究に相見ず、われは北極の氷と化し君は南極の石となりて、感ぜず思わず、限りなく相見ずと思いたもうともなお忍びたもうことを得るや。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又三郎さん北極だの南極だのおべだな。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大循環志願者出発線、これより北極に至る八千九百ベェスター南極に至る八千七百ベェスターと書いてあるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南極はここから八千七百ベェスターだねえ、ずいぶん遠いねえ』なんて云っている、僕たちもふり向いて、ああそうですね、もうお別れです、僕たちはこれから北極へ行くんです、ほんの一寸の間でしたね、ご一緒したのも、じゃさよならって云うんだよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南極か北極へ向いて上の方をどんどん行くときは雲なんか赤かぁないんだよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けば今晩当町に南極探検後援会の活動写真が劇場においてあるとの事。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "影写の合間には地方の有力者が立って、南極探検の説明やら挨拶やらをするが、淳朴なる田舎の婦子供を動かすには余りに学術的に亘り、その効果は認められないようであった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君よ、もし諸君が菓子｜饅頭を買うの余裕あるならば、この国家的大事業なる南極探検に応分の寄付なし給い。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一は近頃ヨーロッパのある学者仲間で、地球の果に何か秘密でも見出さんとするごとく、幾度の失敗にも懲りず、しきりに南極探検船を出しておる事。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　頃はポルトガル第一の科学者モンテス博士の南極探検船が、ある夜秘密にセントウベス湾を出発した、二カ月ほど以前の事である。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上はコルテス博士がポルトガルの海岸にて拾上げし、不思議なる瓶中より出でし不思議なる書面なり、記者はもはや多く記さず、賢明なる読者諸君は、なにゆえに近頃ヨーロッパの学者社会より、幾度の失敗にも懲りず、しばしば不思議なる南極探検船の派遣せらるるか、その秘密をば知りたもうべし。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見る間に南極の空が浮びあがって、星の世界一周が始まったのだ。",
              "citation": {
                "source": "星の劇場",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という著るしい対照だろう、およそ一切の表現中で、これほど対照の著るしく、芸術の南極と北極とを、典型的に規範するものはない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあらゆる著るしいコントラストで、芸術の南極と北極とを対照した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩は音楽と共に、この点で美術の対蹠する南極に立たねばならぬ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの象徴主義に徹したことから、不思議にも日本人は、詩的精神の最も遠い北極のレアリズムから、逆に西洋詩の到達する南極に逼ってきた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら芸術の南極と北極とは、その極端のゆえにかえって相通ずるからだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に詩と小説とは、文学における南極と北極、即ち主観主義と客観主義との両極を、判然として対照している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラシズムとロマンチシズムとは、実に芸術における北極と南極で、世界の終る両端である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に吾人の不可思議に堪えないことは、クラシズムの如き芸術の北極圏に属するものが、反対に芸術の南極極地であり、主観の情熱を本位とする詩の如き文学と、何故に結婚すべく必然されるかと言うことである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩が感情の文学であり、主観の南極に於ける芸術でありながら、クラシズムの如き北極的寒烈の形式を選定し、この矛盾した内容と形式とが結婚するのは、いかにしても不可思議なことに思われる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには北極と南極とがある。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと思ふ、かかる夕日に白銀の絹衣ゆるがせ、いまあてに花｜摘みながらかく愁ひ、かくや聴くらむ、紅の南極星下われを思ふ人のひとりも。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "南極へ着いたものは自分がペンギン鳥と踊つてゐる心になり、シヤムに行けば象の鼻をねじり倒した画は自分の活動と思ひ、クルツプやモスコウ、イルクツク、ニユーヨークなどは、ほんとに腕に力が入つた。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、体操の先生がこの鈴懸の木の下で南極探検の話をなすつた。",
              "citation": {
                "source": "秘密",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
