    "definitions": [
      {
        "index": 1,
        "gloss": "reluctant (to part)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "引上げてゲッチンゲンへ移るときはさすがに名残惜しい気がするのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は、不潔で臭い病室や、時々夜半にひゞいて来るどっかの銃声や、叫喚が面白く名残惜しいものに思われてきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は名残惜しいような気になって、思乱れながら眺めました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "高輪も終に近いかと思えば名残惜しいとして、最近に節子から貰った手紙の中に書添えてあった歌だ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は良人と相談をして夫人への土産だけを出し、その弟子に托して名残惜しい製作室を出て引き返さうとした。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか心細く名残惜しいような顔をしていたが、際限もないから私はそこを辞して出た。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "名残惜しいけれど仕方がありませんので、村人達はせめてもの心やりに、丘のふもとへ行ってみました。",
              "citation": {
                "source": "キンショキショキ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "名残惜しいけれど仕方がない。",
              "citation": {
                "source": "正覚坊",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "名残惜しいけれども帰してやるという意志があり、そこに強い感動がこもるのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに自分はそれをさえさほどに名残惜しいとも思わない。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は銀之助も名残惜しいやうな気に成つて、着た儘の襯衣とズボン下とを寝衣がはりに、宿直の蒲団の中へ笑ひ乍ら潜り込んだ。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈何に丑松は名残惜しいやうな気に成つて、蒼ざめた先輩の頬へ自分の頬を押宛てゝ、『先生、先生。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "名残惜しいやうな気に成つて、冷く心地の好い朝の空気を呼吸し乍ら、やゝしばらく眺め入つて居たが、不図胸に浮んだは蓮太郎の『懴悔録』、開巻第一章、『我は穢多なり』と書起してあつたのを今更のやうに新しく感じて、丁度この町の人々に告白するやうに、其文句を窓のところで繰返した。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶三はお千代の行方が知れなくなったかと思うと急に名残惜しいような気がし出した。",
              "citation": {
                "source": "夏すがた",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは舗道から一歩踏み出そうとして、何やら急にわけもわからず名残惜しい気がして、又ぶらぶら歩き出すと、間もなく酒屋の前の曲角にポストの立っている六丁目の停留場である。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし自分が関係を断つような事があっても女の方では別に名残惜しいとも何とも思わないように見える事である。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ見納めになっても名残惜しい気がしないように、そして永く記憶から消失せないように、能く見覚えて置きたいような心持になり、ベンチから立上って金網を張った垣際へ進寄ろうとした。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思つてみると、なんだか、このまゝ別れるのが……辛いつていふと変だけど、まあ、名残惜しいやうな気がしたのね。",
              "citation": {
                "source": "モノロオグ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "出懸けに一風呂浴びて、午前七時名残惜しい野営地を後にした。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義王は出たけれ共、それでもあんまり名残惜しい、せめてもと又かえって住みなれた障子にこう書きつけた。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は名残惜しい焚火と別れて散り散りに退散する。",
              "citation": {
                "source": "茸をたずねる",
                "author": "飯田蛇笏",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、伝馬牢へ移されちゃ、もう、おめえのような親切者に、死出の世話をして貰うこたあ出来めえと思うと、何だか、名残惜しい」「なあに、あっちの牢番号も分ってるし、手をかける者も、知れてるから、よく蔵六にも、頼んでおいてやろうよ」「蔵六とは」「伝馬の牢番では、一番古顔な男さ」「お係は？",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、おめえはもうそれでいいのか」「ちょうど、深川の水に六年住んで、今夜が見納めかと思うと、何だか、名残惜しいけれど……」「見納めだなんて、縁起でもない事を云わぬがいい。",
              "citation": {
                "source": "春の雁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ……」「名残惜しいなあ」「羨ましいなあ。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで一緒に暮らしてきた偉大な医師たちに別れを告げるのは名残惜しい。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "名残惜しいけれども、このまま打分にするという句意である。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "停留場はこの見当らしい」　と応じて、新太郎君は歩き出したが、矢張り名残惜しい。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月八日（木曜）　今日、島耕二「新興へ定ったので名残惜しいが二の替りから休むよ」と言ふ、丁度東からはクビ話が出かゝってゐる折柄、うまく話が運んだらしくてよかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車へ乗る事も久しぶりだけれども、何となく東京へなごりおしい気持ちなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
