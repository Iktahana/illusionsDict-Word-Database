[
  {
    "uuid": "05913b25-9bfc-5632-b46a-bd0bda604e3e",
    "entry": "難儀",
    "reading": {
      "primary": "なんぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
