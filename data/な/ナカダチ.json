    },
    "definitions": [
      {
        "index": 1,
        "gloss": "break between the light meal and the actual serving of tea (during a formal tea ceremony)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俺だって一晩中立ち通したかねえからな」「冗談云うない。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "申し合せたように、舟中立ち上って籃の内を覗くと、七八寸もあろうと云う魚が、縦横に狭い水の中を馳け廻っていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "姦夫姦婦が日中立ち去るのは人に笑われて、お前たちのツラの皮でも気がひけよう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年アメリカにしばらく住んでいた頃、Ｓ教授が、欧州訪問の途中立ち寄った時に、この話を持ち出した。",
              "citation": {
                "source": "無知",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは夜中立ち聞きしてしまったよ」　すると、親義がいった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄弟仲はよかつたと見えるね」「蔭になり日向になり、私のことを案じてくれ、お夏を中立ちにして、三度の食事にまで氣を配つてくれました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女御用聞き",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして宴飮了し果て口腹おのおの滿てる時、ゲレーナ騎將ネストール、衆中立ちて宣んし曰ふ、421　I 449 とほぼ同じ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚神速のアキリュウス眺めて彼を憐みつ、アカイア人の群の中立ちて飛揚の言句曰ふ、　535532　ユーメーロス。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが異教の日本で、ここでは動物を親切に取扱い、鶏、犬、猫、鳩等がいたら、それを避けて行くなり、又はまたいで行くなりしなくてはならず、米国では最も小心翼々としている鴉でさえも、ここでは優しく取扱われるので、大群をなして東京へ来るのだという、争う余地のない事実へ、私の心はしょっ中立ち戻るのである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "「開聞ヶ｜岳も此処から見える筈ですが……」　と小林さんは中立ちになって、「あれですよ。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元二の順に杯も※つて來た時、自分國許の事に懲りて仔細あつて、世を忍ぶ若ものが庄屋の屋敷に奉公して、其の妻と不義をする、なかだちは、婦が寵愛の猫で、此の首環へ戀歌を結んで褄を引くと云ふ運び。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この定着感（教科書がそうであるように、しばしば必要以上に強化された）があるからこそ、私たちは印刷された本をなかだちに、自分の頭の中で、時間と空間をへだてた著者たちとこころゆくまで対話をかわすことができたのである。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼輔はおろか、関白殿、信西入道、あらゆる人びとのなかだちでも、この恋は所詮ならぬと思え」「なりませぬか」「ならぬ、ならぬ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗默の敵意はこの偶然のつまらない事柄をなかだちに、今は公然のあらはなものになつて了つたのである。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "組合が勢ひを得て以來小作人同志の間で讓渡される、あるひは地主から代償として得る耕作權の價格が急激に上昇し、土地そのものの價格が下つてくると、土地賣買のなかだちを口入師に早がはりした農民があちこちの人の溜りに姿をあらはした。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家賃三十四円の借家人と家主以上の関係が、母親なみが頼まれる縫物をなかだちとして生じた。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月老氷人のなかだちで。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰かの悪戯だ」と疑ってみても、このムク犬が、こんな悪戯のなかだちにたつようなムク犬でないことによって、打消されてしまうのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りつづける五月の雨は友だちの足をとどめさせたばかりでなく、親しみを増させるなかだちともなった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれが一層王室と将軍家とを結びつけるなかだちとなり、政令二途に出るような危機を防ぎ止め、動揺する諸藩の人心をしずめることに役立つなら、上洛に要する莫大な費用も惜しむところではないと言って、関東方がこの旅に多くの望みをかけて行ったというに不思議はない。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日申し上げ候儀、御取り用いに相成り、日本国安全のなかだちとも相成り候わば、この上なき幸いの儀に御座候。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱い空気に蒸される林檎の可憐らしい花、その周囲を飛ぶ蜜蜂の楽しい羽音、すべて、見るもの聞くものは回想のなかだちであったのである。",
              "citation": {
                "source": "朝飯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋する女を友情ゆえに、思いきるばかりか、こうして自分がなかだちとなって、その二人をまとめてやろうとする丹下左膳の心中、そのつらさはどんなでしょう！",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　もし運がよければ、君は、いつもみんなが芸術をなかだちとして見ることになれている、あの有名な女性たちのだれかに、親しく出会うことができる。",
              "citation": {
                "source": "神の剣",
                "author": "GLADIUS DEI",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五歳のとき、保延四年、和泉前司道経になかだちを頼み、藤原｜基俊の弟子となった。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は望まなかったのですが拙者が彼の誠意を認めて婚約を結んだので、いまさら彼から破約を申出るはずはないと思いますが」「なかだち役を買ったわしにも、こんなことが起ろうとは信じられなかった。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄蕃は伝四郎と伊緒とのなかだちをした人である、ふたりの顔を見たとき伊緒はすぐに用向がなんであるかを察した、けれど眉も動かさなかった。",
              "citation": {
                "source": "日本婦道記",
                "author": "春三たび",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ我々が交わりを結ぶなかだちとなったものだからである＊＊＊＊。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀のおむらという老妓の家から看板を借りて出ると、すぐ、お喜代は、斧四郎の眼にとまって、柳橋の浜中屋がなかだちで、囲われたのだった。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神をなかだちにして誓えば、大坂城の濠さえうずめた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
