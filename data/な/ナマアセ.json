[
  {
    "uuid": "702e2c39-9664-5e5d-9c85-f0bbadb71b08",
    "entry": "生汗",
    "reading": {
      "primary": "なまあせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
