    "definitions": [
      {
        "index": 1,
        "gloss": "sweat caused by fear, stress, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "タマラナイ興奮と、恐怖のために全身ビッショリと生汗を流しながら、身動き一つ出来ずにいた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまた急に青白くなって、房々した頭髪の下に隠れている白い額にニジンダ生汗を、平手でジックリと拭い上げた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一知の額には生汗がジットリと浮出していた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも失神しそうにゴックリと唾を飲み込んで、額からポタポタと生汗を滴らしながら大きく大きく眼を瞠った。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇場あり……そんなものを見まわしながら生汗を掻いて行くうちに、やがて蛍色の情熱的な光りに満ち満ちた一つのホールに出た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の気のない顔に生汗を滴らせ、白い唇をわななかせつつ互いの顔を睨み合って、肩で呼吸をするばかりであった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽様が黄色く見えて、生汗が背中を流れて、ツクツク魚売人の商売が情無うなります。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか註釈を入れんか」　と嘲弄したが、林技師が額の生汗を拭いて坐り直した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいにはその寝息の一つ一つが、極度に残忍な拷問か何ぞのように思われて来て、身体中にビッショリと生汗がニジミ出て来るのです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトは私が引受けますけに……」　今にも気絶しそうに生汗を滴らしながら唖女の瞳を一心に凝視していた澄夫は、この時やっと気を取直したらしく、伝六郎の顔を見て真赤になった。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身にゾーッと生汗を掻きながら今一度、静かに左右を振返ってみたが、その彼の怯えた視線は、タッタ今通って来た台所の角の、新しい黒い雨樋の処へピタリと吸い寄せられた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆青白く唇を噛んで、眼が血走って、まるで地獄の責苦から逃れた人のように生汗を流していた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬私の全身には湯気の立つ生汗が流れた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜市××町二ノ八、横浜メーター計量株式会社、としるしてある名刺を見詰めて私は、額に生汗をにじませ口をもぐ／＼させてしどろもどろの受け答をしたが、何んとかして早く此場が逃げたくなつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、全身にビッショリと生汗を掻いているのに気が付いたが、そのうちに又、フト気が付いて、見るともなく丸｜卓子の向う側を見るとハッとした。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、生汗に冷え切った全身がゾクゾクとして来た。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして棒のように強直した全身に、生汗をビッショリと流したまま仰向け様にスト――ンと、倒れそうになったので、吾知らず観念の眼を閉じた……と思ったが……又、ハッと機械のように足を踏み直した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又もニジミ出して来る額の生汗をハンカチで拭いた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "額から生汗がポタポタと滴り落ちて、唇がわなわなとふるえ出して、又もフラフラとなりかけたように思った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ブ――――ン……　……という音につれて私の眼の前に、正木博士の骸骨みたような顔が、生汗をポタポタと滴らしながら鼻眼鏡をかけて出て来た……と思うと、目礼をするように眼を伏せて、力なくニッと笑いつつ消え失せた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "船首にグングンのしかかって来る断崖絶壁の姿を間一髪の瀬戸際まで見せ付けられた連中の額には皆｜生汗が滲んだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "声も立て得ないまま瞳を大きく見開いているその猫のタマラナイ姿を一生懸命の思いで、生汗をかきかき正視しているうちに、私は、私の神経がみるみる恐ろしい方向に冱えかえって行くのに気がついていた。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はゾーッとして思わず額の生汗を撫であげた。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと右手を動かして、ポケットからハンカチを取り出して、顔一面に流るる生汗を拭うことが出来た。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みすすむにつれて、私の手はぶるぶる顫え、額や脇の下には気味の悪い生汗が浮んで来た。",
              "citation": {
                "source": "※の囁き",
                "author": "――肺病の唄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とろんとした乳白の雲が低く淀んでゐて、空氣がじとじとして、生汗をかいてゐるやうな日である。",
              "citation": {
                "source": "七月七日",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして生活は、大地を離れた繁忙な事務の中に閉じ籠められ、一つ所に動きがとれぬほど固定され、毎日同じことを繰返す機械のようになされて、額ににじみ出る汗は、筋肉を働かせることから来る力強い爽快な汗ではなくて、日光と空気とが不足して窒息してゆく、じりじりとした生汗である。",
              "citation": {
                "source": "悪夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ来たな、これで今日半日は潰せると思っていると、先生汗を拭いて肩を入れて例のごとく座敷までずかずか上って来て「奥さん、苦沙弥君はどうしました」と呼ばわりながら帽子を畳の上へ抛り出す。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬子の声は低くてよく聞えなかったが、譲治は何となく息苦しくなり、生汗がじとじと渉んできました。",
              "citation": {
                "source": "深夜の客",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらの額からも、生汗がダラダラと流れ落ちているが、もう二十分近くも、刀を合わせたきり、喘ぎ喘ぎ、同じ言葉を投げあっているだけだ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
