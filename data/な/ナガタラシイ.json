[
  {
    "uuid": "bd9bf26a-6448-5086-8a15-0d7500b3f0a6",
    "entry": "長たらしい",
    "reading": {
      "primary": "ながたらしい",
      "alternatives": [
        "ながったらしい"
      ],
      "is_heteronym": true
    },
    "grammar": {
