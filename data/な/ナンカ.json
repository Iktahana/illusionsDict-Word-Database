  {
    "uuid": "96e7ebfa-ad4b-57e6-bf52-bcb6ef54506d",
    "entry": "軟化",
    "reading": {
      "primary": "なんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
