    "definitions": [
      {
        "index": 1,
        "gloss": "the south",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "次女の婿は、これは小坂の養子らしいが、早くから出征していまは南方に活躍中とか聞いていたが、君は知らなかったのかい？",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "華麗と歓楽とを夢みるように、この雪白く、氷堅き北方の閉鎖から解かれて、南方の奢侈を、立ち姿や、寝像にまで現して、昼となく、夜となく、おそらく、千年も万年も、不断の進みをつづけているのだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労の足を引き擦って、石壁の上に登りついたとき、眼は先ず晶々｜粲々として、碧空に輝きわたる大雪田、海抜三千百八十九｜米突の高頂から放射して、細胞のような小粒の雪が、半ば結晶し、半ば融けて、大気を含んだ、透明の泡が、岩の影に紫色を翳しているのに、眩ゆくなるばかりに駭いた、南方八月の雪！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の少しばかり調べてみた結果では、昨年の颱風の場合には、同時に満洲の方から現われた二つの副低気圧と南方から進んで来た主要颱風との相互作用がこの颱風の勢力増大に参与したように見えるのであるが、不幸にして満洲方面の観測点が僅少であるためにそれらの関係を明らかにすることが出来ないのは遺憾である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外住宅者は干し物を東南方の側には出して乾せない日である。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために中層へは南方から暖かい空気が舌を出したような形になっている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二七年の寒冷なビクトリア港の静かな波間にオランダの汽船が碇泊すると、南方政府の逮捕命令をうけて上海を逃れた陳独秀が船着場に衰えた姿をあらわした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "広東香港間の電信が切断されてその後の消息は不明なのですが、恐らく明日は外国人は南方に於ける商業上の前途を楽観して、交易所では支那へ夥しい投資が行われるでしょう。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "××府の女、六朝の血を衝けた彼女達の北方軍閥に対する憎悪は、南方の組織に関わらずその力によって北方軍閥の倒壊をまって自己を擁力しようとする陰謀、シイ・ファン・ユウも目的をそこにもっていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民政府に於て左党の政策の欠如が右党に幸して、彼等は尨大な小ブルジョワを党に獲得し、南方の多くのブルジョワも三民主義の名に隠れて党に参加した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の夏始めに、涼み台が持ち出されて間もなく、長男が宵のうちに南方の空に輝く大きな赤味がかった星を見付けてあれは何かと聞いた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方外国や支那から、おもしろい器物を取寄せたり、また古渡の物、在来の物をも珍重したりして、おもしろい、味のあるものを大に尊んだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "北米の南方ではわがタイフーンの代わりにその親類のハリケーンを享有しているからますます心強いわけである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてかくしのキャラメルを取り出して三つ四つ一度に頬張りながら南方のすそ野から遠い前面の山々へかけての眺望をむさぼることにした。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはことしのお正月にＫ君と二人で、共に紋服を着て、井伏さんのお留守宅（作家井伏鱒二氏は、軍報道班員としてその前年の晩秋、南方に派遣せられたり）へ御年始にあがって、ちょうどＩ君も国民服を着て御年始に来ていましたが、その時、Ｉ君が私たち二人を庭先に立たせて撮影した物です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』沙魚の領海とは隨分奇妙な名稱だが、實際印度洋中マルダイブ群島から數千里南方に當つて、斯る塲所のあるといふ事は、甞て或地理書で讀んだ事があるが、今、吾等の目撃したのは確かにそれだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎角する間に今迄は、其邊を縱横に暴廻つて居つた沙魚は、其氣味惡き頭を南方に向けて、恰も矢を射るやうに駛り出した。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私も蹴鞠のやうに跳起きて見ると、此時天全く明けて、朝霧霽れたる海の面、吾が端艇を去る事三海里ばかりの、南方に當つて、椰子、橄欖の葉は青※と茂つて、磯打つ波は玉と散る邊、一個の島が横つて居つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十二回　海軍の家南方の無人島――快活な武村兵曹――おぼろな想像――前は絶海の波、後は椰子の林――何處ともなく立去つた　櫻木海軍大佐は暫時して口を開いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』といひつゝ、染々と吾等兩人の姿を打瞻め『此處は印度洋もズツト南方に偏した無人島で、一番に近いマダカツスル群島へも一千哩以上、亞細亞大陸や、歐羅巴洲までは、幾千幾百哩あるか分らぬ程で、到底尋常では人の來るべき島ではありませんが。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一八）焼酎の御馳走　一行は多少ヤケ気味に、それよりはブラリブラリと牛の歩み宜しく、またもや一里あまり進んで、南方村という寒村に来掛かれば、路傍の開放されたる一軒家では、褌一本の村の爺さん達四、五人｜集って、頻りに白馬か何か飲んでいる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに南方の文帝、元嘉の年中、京洛の婦女子、皆悉く愁眉、泣粧、墮馬髻、折要歩、齲齒笑をなし、貴賤、尊卑、互に其の及ばざるを恥とせり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方に行った頃、武田麟太郎が鰐に食われて死んだという噂がひろがった。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪の話」以後、武田さんは南方へ行き、沈黙した。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方派遣日本語教授要員の募集の記事が、ふと眼に止ったのである。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
