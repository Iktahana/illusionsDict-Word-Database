          "literary": [
            {
              "text": "儂が今、此処へこう角を打ちました」　「そうか、成る程……いい手だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水一家にはいい児分が多いからね」　「成る程ね。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人もはっと気がつき、　「成る程そうだった。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄五郎が、Ｔ「成る程ね、神信心もまんざら悪かァ無え筈よ」　と言われて三次真赤になった。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程、と三次受取って見る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「典六は親分が憎くて　仲蔵に味方するんじゃ　ないんでしょう」　五郎蔵、成る程と頷く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふみが、Ｔ「ひょッと兄さん変な気を起して」Ｔ「川へはまるか首をつるか」　成る程と伝六。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門伝六にそれを示して、Ｔ「この羽織は生島屋の仕立だ」　と言って、Ｔ「あそこで縫った品ァこの通り」Ｔ「袂の裏に白糸を三筋縫い込んである」　成る程と伝六感心した。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちいち貯金なんて、めんどうくさい」　成る程と思い、私は黙ってうなずきました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは成る程、君も僕もぜんぜん生産にあずかっていない人間だ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○科にお勤めになっていらっしゃる……成る程。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しっかりしてくれなくちゃ困る」　てえ御立腹なんで……成る程、よく読んでみますと鴨の長明の方丈記の英訳なんで。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一週間ばかり経って、奥様が流産をなすった……妊娠三箇月で……成る程。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程、考えてみると手や足で動作の真似をしたり、眼や口の表情で感情をあらわしたり、背景で場面を見せたりするのは、技巧としては末の末ですからね」「能」という名前の由来、もしくは「能」の神髄に関する説明で、これ位穿った要領を得た話はない。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "指一本｜指されんと来とる」「成る程なあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程……われわれ非人風情には寄っても付けぬ初耳の話じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "都合のよい御返事を申上げて貰うたなら一杯奢るが……」「成る程なあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処の女中でも、自分の付添うておる者には贔負が勝ちますもので……」「成る程のう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御酒なんぞも、お余りをタンマリと頂戴しましたもので……」「成る程……」「ところがそのアトで勝手口の塵埃箱を覗いてみますと、お野菜の切端のような物ばっかりしか御座いません。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程のう」　さすがの松倉十内も非人の明察振りに舌を巻いたらしい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "タッタ今わかった」「どうしてかいな」「どうしてと言うて知れた事……この四、五日が間、福岡博多の何処の家にも下がっとるこの渋団扇の由来を知らんと言うからには、遠方行きにきまっとる」「成る程なあ」「ところで今日の用向きは何かいな。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑前領で手をかけては面倒になるし、又、油断もしおるまいと思うたけに、思い切って豊後と筑前境いの夜明の峠道で待ち受けたわい」「成る程なあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程これなら一杯がものある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬さんがそう言うと、成る程一々尤もだが、それはあまり感心しないぜ」「何故、何故」　と犬は眼を瞠って申しました。",
              "citation": {
                "source": "犬のいたずら",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程と思わせずには置かない茶人の拷問道具ばかりらしい。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞いた他の連中は皆理屈に負けて「成る程、毒にさえなればこわい事はない」と思う者さえありました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "茸共は、成る程毒茸はえらいものだと思いました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程」とか「結構ですな」とか何とか言い言い腮を撫でている態度である。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの不幸が大きくなればなるほど、そうして僕の愛情が深くなればなるほど、僕はあなたに近づきにくくなるのです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化の伝統が古くなるほど、人の心に余裕が生れ、生活がのんびりとして暮しよくなる。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
