        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「木村さんも信者なんですか？",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近衛公が議会で、日本主義というのは、なんですか？",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで結構なんです」　言い終えたところは山猫の檻のまえであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな中では私は、無鉄砲少女が好きなんです。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんですよツ」と、お祖母さんは気短かに、返答した。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それが神経屋なんですよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんな芸術ゲの字も分つてゐない奴等なんですよ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも福岡市でも竹原といへば知らない人もないつて言つて好い位な家なんですから、余りお粗末にやれば……」　それは奥さんに従いて来た奥さんの声だつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その歌が窓から近づいて来るやうなんです。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、ほんたうに、さうなんです。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀んでしまつてから、「黄金風景つて、どんな小説なんですか？",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが龍宮なんです、この場所が。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけぢや、不足なんですか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの連中は我々の善良なる友人であるが、考へが偏狹で感情はうそ寒く、自分の鼻からさきの事はまるで見えない……何の事はない、ただもう馬鹿なんです。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな太郎の為に…………太郎の美くしいお嫁さんに着物を買ふため麻のハンカチ古い革手袋、昔はやつたお高祖づきんの布つ片へ、そつと貯めて置かうとするお金なんです。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっかさんが病気なんですから今晩でないと困るんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鷺の方はなぜ手数なんですか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「民さん、なんです、そんなにひとりで笑って」「政夫さんはりんどうの様な人だ」「どうして」「さアどうしてということはないけど、政夫さんは何がなし竜胆の様な風だからさ」　民子は言い終って顔をかくして笑った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は「サケ」と「シャケ」が間違ったら飛んでもない間違いを起しますが、アイヌ人は「サケ」も「シャケ」も音としては同じことなんです。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃいませ」　「御免なすって……石松つあんのお宅はこちらで御座いますか」　「あの……兄さん今一寸留守なんですけど」　「へえ儂は駿河の清水港の次郎長の身内、大瀬半五郎と申します」　「お父っつあん、お父っつあん」　とお静、奥へ呼ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は」　「お半さん、今日は俺、石松の事でお前に謝りに来たンだ」　「なんですの、改まって？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分、なんですか」　「おい七五郎、石松が来てるんだろう」　「石松なんて来てませんよ」　「何ッ」　「何ッ」Ｓ＝屋根裏　石松、階下の物音に窓の方へ匍い出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾も、歌劇団を抜け出すつもりなんです。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スマ子女史はワイシャツの縫目からミス・フランセのコバルトの細巻をとりだして火をつけると、蒸気のこもった部屋に水沫のように緑色の煙を吐き出して、――だが、人に聞くと君はちかごろ恋のテクニックに夢中なんですって？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "會社員の奧さんで肋膜がお惡い上に盲膓炎なんですつて。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと顏立は好い方なんですけれどね……」「惡いんぢやないんですか？",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちよつとちよつと、あれが檀那樣なんですよ……」　教へられてその窓の方を振り向くと、何時の間にか紺の脊廣を着た若い紳士がその女と並んで、胸から上を窓臺に凭せ掛けながら立つてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、私はこの仕事に從ふやうになつてからもうかれこれ十五六年になりますが、そんな風でゐながら、心の底ではやつぱりこの仕事が好きなんですね。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾ら思つてみても、そんな事、あたし達には駄目なんですもの……」　奧さんはかすれたやうな声で答へながら、青木さんの顏を見上げた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
