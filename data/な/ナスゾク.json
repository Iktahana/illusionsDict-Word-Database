        "examples": {
          "standard": [
            {
              "text": "ナス属には、食用のナスやジャガイモの他に、観賞用の植物も含まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "トマトはナス属の一種で、世界中で広く栽培されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の生態系調査では、ナス属の希少な野生種が発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、稀に印度大麻にストリヒナス属（矢毒クラーレの原植物）が寄生すると、その果実を土人が珍重して呪術に用ゆるけれども、恐らくそれではないか――という報告を一つもたらせたのみである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この草は元来北米の産でナス科ナス属に属し Solanum carolinense L. の学名を有する。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
