    "definitions": [
      {
        "index": 1,
        "gloss": "habit of idleness (laziness)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんなことがなくても、そろそろ怠け癖がついているのです。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰省中に勉強するつもりで、いろいろの書物をさげて来たのだが、いざとなるとやはりいつもの怠け癖が出る。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄八　四五日商売を休んだので、みんな怠け癖が附いてしまやあがった。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし怠け癖のついた木山は、こつ／＼初めから出直すといふ心構へには容易になれなかつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間大仕事にかゝつてゐたので、それを濟ませた安心から、三田は怠け癖がついてしまつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと安川は牛乳配達であらうと自由労働者であらうと商売に軽重をつける気持はもたない男で、生来の怠け癖と非力からさういふ働きを愛さなかつたまでであるが、いよいよ仕方のない時はさういふ仕事をしていいと考へてゐた。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オッカネ」　と、それからはいくらか怠け癖も治ったということである。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は彼に向い、亭主をそそのかして怠け癖をつけたのはおまえさんだと言って、まっこうから食ってかかった。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更派出婦になるのも、もう怠け癖がついてますから。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠け癖をつけちゃいかん。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ怠け癖がついちまって、さっぱり仕事もせずに、もうろく親爺みたいに、ぼそぼそ言ってるだけだからなあ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠け癖がついたんだわ、しようのないわたし！",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は典型的な小ロシア人で、そろそろ怠け癖がつきだしたから、この際性根を叩き直す必要がある。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は典型的な小ロシヤ人で、そろそろ怠け癖がつきだしたから、この際ひとつ根性骨を叩き直す必要がある。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは先生が煙つたいとかギゴチないとか云ふよりも、たゞもう無意味な怠け癖の結果であつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘つきで薄情で怠け癖のある記者は、少しばかりの才能はあったにしても、決して有力な存在にはなれないのですが、「東京ポスト」のような出来星の新聞では、この適当に要領の良い「渡り者」を、弁舌と風采で高く買う気になったのも無理のないことだったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四次元の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "出た方が良いよ」「そりゃ判ってるけれど――どうも怠け癖がついてしまって」「小説か何か書いているのかい」　私は暗然と顔を上げた。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島で物不足、心配事、怠け癖を見て、髪の毛が白くなった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはいまこの怠け癖から抜け出しつつあるが、なかなか具合がよい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の優柔不断だの、怠け癖だの、色好みだのを俎上にのぼせ、それらをさんざんにこきおろしながら、かえってそこに自分の「我」をはっきりとつかみ、一個人としての、私人としての人間をつかんだ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでゐて何も手に附かない、人知れず廻るなまけぐせの毒酒にああ、わたしは中てられた。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、なまけぐせをだしおって、やり損じなどした時には、それこそ、この卜斎より石見守さまがその細首をつけてはおくまいぞ」　すこしあとの文句がすごいな――と蛾次郎は思ったが、卜斎はそういいのこすと、かれをおきのこしてそこをかけだし、石見守の行列へついていった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
