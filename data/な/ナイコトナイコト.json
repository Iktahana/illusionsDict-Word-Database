        "examples": {
          "standard": [
            {
              "text": "彼はいつも無い事無い事を言って、人を騙そうとするから気をつけなきゃ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの週刊誌は、スキャンダルをでっち上げるために無い事無い事を書くことで有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そんな無い事無い事を言うんじゃないよ！」と、彼女は友人に腹を立てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "おひなさまのときの染わけかまぼこのようね、近代日本の日本人が、近代日本の日本人であり得ないということはない、それを一遍「それはないことないこと」にしてから、妙に分裂させてしかつめらしく云い出す、何を「ないことないこと」にしているかということについては自分さえも自分に向って沈黙していて。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
