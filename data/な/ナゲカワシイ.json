    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lamentable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
