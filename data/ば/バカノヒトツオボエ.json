    "definitions": [
      {
        "index": 1,
        "gloss": "one who knows little often repeats it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
