    "definitions": [
      {
        "index": 1,
        "gloss": "ume grove",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "相州小田原の町に電車鐵道待合の、茶店の亭主が言に因れば、土地の鹽辛、蒲鉾、外郎、及び萬年町の竹屋の藤、金格子の東海棲、料理店の天利、城の石垣、及び外廓の梅林は、凡そ日本一也。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぎて裏門を出でぬ、貴嬢はここの梅林を憶えたもうや、今や貴嬢には苦しき紀念なるべし、二郎には悲しき木陰となり、われには恐ろしき場処となれり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこン処は梅林で、上の山が桜の名所で、その下に桃谷というのがあって、谷間の小流には、菖蒲、燕子花が一杯咲く。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　それから私、あの、梅林のある処に参りました。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝梅林に金色夜叉の梅を見る、富山唯繼一輩の人物あるのみ。",
              "citation": {
                "source": "熱海の春",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年の早春、葉子は、一寸した病後の気持で、熱海の梅林が見度くなり、良人と、新橋駅から汽車に乗った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕刻、熱海梅林の鶴の金網前に葉子は停って居た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこン処は梅林で上の山が桜の名所で、其下に桃谷といふのがあつて、谷間の小流には、菖浦、燕子花が一杯咲く。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ツて天上に遊んで居るんだから籠の中に居ないのかも知れないよ）それから私、あの、梅林のある処に参りました。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　去る昭和三年十二月卅一日夜、予、日高郡妹尾に在て、大雨中に十八町ばかり山中を歩む内、深谷に臨んだ道側の雜木が、忽ち悉く滿開せる梅林と化け、一天微雲だになく月さえ渡つた。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩み出すと復た月夜の梅林が現じた。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてお前の頼も聴かうから、まあ能く種々考へて置くが可いの」「はい」第七章　熱海は東京に比して温きこと十余度なれば、今日｜漸く一月の半を過ぎぬるに、梅林の花は二千本の梢に咲乱れて、日に映へる光は玲瓏として人の面を照し、路を埋むる幾斗の清香は凝りて掬ぶに堪へたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大きな梅林が有つて、一本々々種の違ふのを集めて二百本もあるが、皆老木ばかり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで熱海の梅林も凄い。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右にゆけば、梅林あり、櫻も多く、喬松立ちつらなりて、三方の眺望ひらけたり。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "脈々たる幽香に護られて、醉夢いづくにか迷ひけむ、窓に近き鶯聲の綿蠻たるに驚けば、日は已に梅林の梢に昇りぬ。",
              "citation": {
                "source": "杉田の一夜",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田原城址の小峯山、水戸の第一第二の二公園にも、梅林あり。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "本牧の三溪園にも梅林あり。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "江東にては、向島の花屋敷、四木の吉野園に梅林あり。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "龜戸天神の梅林も無くなれり。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内にては、湯島天神、芝公園、深川公園などにも梅林あるが、關東にては、青梅在の吉野村の梅を見ずんば、梅を説くの資格なかるべし。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "越生在の津久根にも、越ヶ谷にも、多摩川畔の久地にも、梅林あり。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂梅林的ならずして、野趣愛すべし。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『持主は誰れ』『川邊氏』、『何本かある』『凡そ六百本』、『幾何の收入かある』『四五百圓』、『梅林は此處だけなるか』『一昨年までは、山の彼方の上作延にも梅林ありたるが、今は梅を切りて、栗を植ゑたり』。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅林を辭して、西に數十間行けば、一帶の小山樹木を帶ぶ。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "日向和田へとて、梅林を辭すれば、麥畑となる。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "上市を行き盡して、萠えそめたる麥生かなたに一帶白くたなびけるは、花か雲かと云ひたきをなど考ふる間もなく、車は早くも梅林の中に入りぬ。",
              "citation": {
                "source": "水戸觀梅",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "祠後の梅林無くなり、その代りに藤棚出來て、龜戸天神は益※藤の名所也。",
              "citation": {
                "source": "吾嬬の森",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京第一の梅林なりき、水戸義公、臥龍梅と命名したりき。",
              "citation": {
                "source": "吾嬬の森",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
