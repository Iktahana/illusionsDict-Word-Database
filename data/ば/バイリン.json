  {
    "uuid": "cfe68f49-35e0-500a-85e7-cd23f4c0b65a",
    "entry": "梅林",
    "reading": {
      "primary": "ばいりん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
