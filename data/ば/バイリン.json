        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "梅霖の雨しとどと降るに、汗流れ、こんこんと、苦しき喉に咳するよ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安達君から、梅霖欝々、憂愁如水などはがきに書いて来た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
