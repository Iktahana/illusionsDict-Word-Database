          "literary": [
            {
              "text": "さうでなく、きつと、何かわるいことをしたばつに、お母さまが何にもありませんとおつしやつたのにちがひない。",
              "citation": {
                "source": "乞食の子",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでないと、大将は王女をとりかえさないで空手でかえって来たばつに、きっとくびをきられるにきまっていました。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鬼が島へ鬼せいばつに行こうと思います。",
              "citation": {
                "source": "桃太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鬼が島へ、鬼せいばつに行くのだ。",
              "citation": {
                "source": "桃太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鬼が島へ鬼せいばつに行くのだ。",
              "citation": {
                "source": "桃太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二升につき十九匁出さなければならないのを出さなかったり何かするとすぐばつになる。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶたれるのはがまんできるが、ぶたれたあとは、きまつて、ばつに、なんにもたべさしてくれません。",
              "citation": {
                "source": "てがみ",
                "author": "アントン・チエーホフ　Anton Chehov",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやく死べし、と苦しき声にて申候へば、前へも申すとふり、われ頼みもせぬに、家の名高き名剣を盗み出し、親のばつにて石臼を切り、名剣何ともならず候に付、言訳なく、そのめいけんにて自害せしに、我に恨み申が、こんりんならく死る事ならず。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｒすい星から、地球せいばつにやってきたのだ。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
