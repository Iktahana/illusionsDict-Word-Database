        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此地形が主墳の周圍に陪塚を造るをゆるさぬ。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "お穴樣の探檢",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの御陵のごときは、二重に堀をめぐらし、その周圍には陪塚といつて臣下の人だちの墓がたくさん竝んでをります。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
