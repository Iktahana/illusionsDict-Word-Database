    },
    "definitions": [
      {
        "index": 1,
        "gloss": "crowbar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おもしろいことには、アラビア語の川は「ナフル」、ヘブライのが「ナハル」「ナーバール」等。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからナタル、ザンジバールをも見舞った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでノアルで細筆のフランス文字、ブルバールデトセトラ。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月十三日『東京朝日新聞』）　　　　　　　　　三十八　　　　　　世界で最大のダイアモンド　近頃トランスバール政府ではその所有に属する世界最大の金剛石を英国皇帝に献ずる事に決した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三町出るとブールバール・デジタリアンの大通りです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　エチオピア事件でほとんど毎日毎夕の新聞に伊国首相や、エ国皇帝、それから国際聯盟の英仏代表イーデン、ラバールの肖像が出る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七六九年インドの北西部飢饉し牛多く死し虎常時の食を得ず、ブハワバール市を侵しおよそ四百人を殲し、住民逃げ散じて市ために数年間空虚となったとクルックの『西北印度諸州篇』に見え、次に開化の増進に随い虎が追々減少する事体を述べ居る。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林も、その山をついさっきまで、鑿で穴を穿ったり、バール（テコ）で起こしたり、鶴嘴で起こしたりしていた、坑夫たちも、まるで造りつけられたように、いろいろな恰好で、じっと見詰め、もの思いに耽っているように見えた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリル、ペンチ、曲げ柄ドリル、バール、クランプ、錐などで、様々な大きさ、用途のものが揃っていた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベートーベンがパリーへ来て、私の宿の傍のブリューバールへ馬車で降り、いきなり店頭にかかっていた淫らな画を見て腹を立て、早速次の日、ウインへ帰って行ったという。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭渕橋、河原のブールバール。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑丈な二十四歳のゴーリキイの胸に溢れるロマンチシズム、より高く、より強く、自由に美しく生きようとする憧憬を誇り高きジプシイの若者ロイコ・ゾバールの物語にもり込んだ。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイもロイコ・ゾバールの物語では労働階級の存在にも問題にもふれていない。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどそれは正夫さんには意識的でなくてシャインバールなものと存じます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に有限なものを通して無限なものを捕捉し得る者は、私の唯一つの思想感情もしくは行爲を知ることによつてさへ、私がまことの神の信者であるか、それともバールの僧侶であるかを洞察し得るであらう。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　矢代はブリュウバールの方に日本があると思うらしく、傾いたその道路の方を見ながら暫く黙っていてから、また云った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に有限なものを通して無限なものを捕捉し得る者は、私の唯一つの思想感情もしくは行為を知ることによってさえ、私がまことの神の信者であるか、それともバールの僧侶であるかを洞察し得るであろう。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストルキオが歌劇「ラ・ボエーム」のミミ、私が歌劇「お蝶夫人」の蝶々さんを持って歩いたのですが、ポルトガルの首都リスボンのテアトル・ムニシバールで歌劇を上演した時のことです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "下で一寸話し、ずっとブルバール〔並木道〕を歩いてプーシュキン広場に出た。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルバールではかりやを見つけ 10к ずつではかった。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリバールではぬれた青草、池の中にあるレンガのかげが赤く、水たまりに空の色が映って美しかった。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ブルバールがすっかり秋だ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一四年のヘルマン・バールの言葉を顧みよう。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おびゆる人々　一九一四年、ドイツでは、ヘルマンバールは、次のように叫んでいる。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間は水を持つて來て、彼の顏に水を浴せ、彼に飮ませた、かくてドクトル・バールトは助かつた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに先年英国とトランスバールと戦うたときに世界中でトランスバールをほめ立てたと想像しても、決してそのためにかの国が英国に勝ちえたろうとは思われぬ。",
              "citation": {
                "source": "人類の生存競争",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮に先年南アフリカに紛騒のあった際に、万国連合高等裁判所がトランスバールは英国に属するが正当であると宣告したと想像してみるに、ボア人がつつしんでこれを承認するであろうか、人口は少なく、資力も不充分で、必ず負けることが明らかに知れていても一戦争せずには決してすまされぬに違いない。",
              "citation": {
                "source": "戦争と平和",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時も僕は頭の中で「バールセロナの、乙女子よ、来ませずや我が胸に！",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アチン人種、馬来人種、ザンギバール人種、マホメダ人種、さまざまの人種が集まって出来た土人軍の五十人が先頭に立って、進む後から、白人の一団が進んで行く、その後を小荷駄の一隊が五十人の土人軍に守られて粛々として歩をすすめる。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
