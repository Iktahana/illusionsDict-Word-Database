    "definitions": [
      {
        "index": 1,
        "gloss": "bachelor (degree holder)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
