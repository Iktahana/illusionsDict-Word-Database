    "definitions": [
      {
        "index": 1,
        "gloss": "admission fee (at the theatre, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "場銭を集めて一樽買ったら言分あるまい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで山のように積んであった寺銭も場銭も盆｜茣蓙も、賽目までも虚空に消え失せて、あとには夥しい砂ほこりが分厚く積っているばかり。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなパロレーの後で忌々しい七で鴨なぞ狙わなかったら、おれは場銭を残らず掻っさらっちまったんだぜ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "場銭が二銭上ったと云ってこぼしていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、今日は妹を連れて映画を見たのよ、自腹だから、スッテンテンになってしまったわ、かせがなくちゃ場銭も払えない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "場銭が十五銭ね、それから、店のものはこわさないようになさい、三倍位には取られてしまうのよ、それから、この部屋で、お上さんも旦那も、女給もコックも一緒に寝るんだから、その荷物は棚へでもあげておおきなさい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私今日は妹を連れて活動見たのよ、自腹だから、スッテンテンよ、かせがなくちゃ場銭も払えない。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "特別にして貰ってるけれど、いくらなんだって、場銭を出す時なんか、おかみさんの前に、顔が挙げられやしない。",
              "citation": {
                "source": "傷痕の背景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、帆柱のかげからムックリとはね起きた六尺ゆたかの壮漢、「こいつら、ふざけやがって……」　盆ゴザも、場銭も、火鉢も、煙草も、手あたり次第に取って海へ投げ込む大荒れの勇者が現われました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎」と峰吉はいよいよ怒り、「さては野郎賭場を荒らし、賭場銭さらいに来やがったな！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾兒が場銭をさらいに来たわ！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藤作のやり方が悪かったにしても、場銭をさらいに来やがったと、こう云われては腹に据えかねる……そうでなくてさえ怨みの重なる、高萩一家の奴原だ、この際一気に片づけてしまえ！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜造　へえ、人も二、三人斬りました、が、それよりも、こともあろうに賭場を荒しましてね、場銭あらかた、その上に寺箱まで、といってもご存じはねえでしょうが、とにかくゴッソリ引っかついで逃げ出したんで、あんまりやり方が憎いんで、皆でとっつかめいて、眠らそうてんで。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男がスーッと立って「今夜の所、場銭、寺銭、この盆は俺が貰った！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座がデングリかえる騒ぎになって、さて気がついて見ると場銭、寺箱、見えなくなっている。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、出せ、寺と場銭をスッカリ出せっ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜造　へえ、人も二、三人斬りました、が、それよりも、こともあろうに賭場を荒しましてね、場銭あらかた、その上に寺箱まで、と言っても御存じはねえでしょうで、とにかくゴッソリ引っかついで逃げ出したんで、あんまりやり方が憎いんで、皆でとっつかめえて、眠らそうてんで。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男がスーツと立って「今夜のところ、場銭、寺銭、この盆は俺が貰った！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座がデングリ返る騒ぎになって、さて気が付いて見ると場銭、寺箱、見えなくなっている。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦直後、雨後の筍に似て立ち並び始めたバラック飲食店の場銭と、強請とで酒と小遣に不自由しなかった習慣は一朝にして脱することが出来ず、飲食店の閉鎖、恐喝行為の強力な取締りと、組の解体は彼等を陸に上がった河童にした。",
              "citation": {
                "source": "刺青",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口が象潟署の給仕をしてゝ、ドサの手伝ひで場銭を貰ふ話、東が北海道の親分に囲まれて腕を切ってみせる話が面白かった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、天保銭か、台場銭の端ただろうが、飲むに都合がある」　庄次郎が、そのまま、渡すと、「あっ」　開けて見た四、五人の眼が、息をのんで、「……だいぶある」　呻いた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よくも、お上の声を騙って、賭場銭を攫やがったな。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、その時の賭場銭をそろえて、土肥半蔵が、手をついて謝れ」「左様なことはできん」「できねえと。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画や、それからたとえばせんだっての「人生の設計」なども、この大きな問題を考究するときの資料になるべきものであろう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子はそれを袱紗に包んで、「どれ、若い恋人に会ひに行かうかね」　なかばせん子の気を牽きながらかういつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼媼は又かゝる遊を喜ぶべき人とも見えぬに、男寢衣を身に着けて供せしを思へば、壹ら姫を悦ばせんがために心を竭せるものなるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女の身のかゝる事に従事せんはいとあしき事なるを、さりとも家の為なればせんなし。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等は調の古きところが大に耳にかなふやうに覺ゆれどそれも人々の感情なればせん方も無き事なり。",
              "citation": {
                "source": "萬葉集を讀む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あら、この親爺め、はア、酔っ払って……駄目だよ、折詰へ手つけては……あしたの朝、餓鬼奴らに見せて喜ばせんだから……こんな旨いものめったに見られねえんだから……一口ずつでもいいから食わなけりゃ、餓鬼奴らも可哀そうだわ。",
              "citation": {
                "source": "おびとき",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
