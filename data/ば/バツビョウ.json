        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "抜錨後二時間にして、船は魚津に着きぬ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶喜は、六日夜大阪に退き、同夜近臣数人と天保山沖で軍艦開陽艦に乗ろうとしたが、暗夜のため見つからず、先ず米国砲艦イロユイスに身を寄せ、翌七日開陽艦に移乗し、八日の夜抜錨して江戸に向った。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなあわただしい抜錨の間ぎわになった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜錨の時刻は一秒一秒に逼っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「葉子さん、あなたは私を見殺しにするんですか……見殺しにするん……」一〇　始めての旅客も物慣れた旅客も、抜錨したばかりの船の甲板に立っては、落ち付いた心でいる事ができないようだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一　絵島丸が横浜を抜錨してからもう三日たった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三時間後には愴惶として抜錨し北極海へ取って返した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の少将ペリの率た艦隊は前年壬子十月十三日（一八五二年十一月二十四日）に抜錨し、前月十九日（一八五三年五月二十六日）に琉球那覇港に著し、此月二十六日（七月二日）に那覇港を発して浦賀に向つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "船はその晩サンフランシスコを抜錨した。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日の火曜日と――木曜日の真夜中に、コロナ号がバルセロナを抜錨する。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくして再び神戸を抜錨した諾威船ヴィクトル・カレニナ号が大洋へ乗出すと間もなく、帆布に包まれて火棒を圧石に付けた大きな物が舷側から逆巻く怒涛の中へ投込まれた。",
              "citation": {
                "source": "上海された男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐世保抜錨までは先便すでに申し上げ置きたる通りに有之候。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ手紙ヲ見タラ、オ前ノ船ハスグニ抜錨シテ、港外へ出ロ。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一等運転士、すぐに抜錨を命じてください。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ、そんなことを」「さあ、すぐ抜錨しないと危険です。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "七人で、抜錨ができるか。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "）五、ホンコン上陸、旧知に会う　十一月二十五日天明、呉淞抜錨。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日（日曜）碇泊、八日正午抜錨。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八日（日曜）、午後二時マルセイユ港抜錨。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午十二時、ホンコンを抜錨す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　午後六時半、同港を抜錨す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時に至り埠頭にて滝波氏と相わかれ、パシフィック会社汽船オリサ号（五千三百五十九トン）に移り、六時抜錨して南進に就く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後七時抜錨して湾を出ず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "当夜十一時抜錨し、海峡狭所に向かいて西進す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後五時抜錨して、夜九時タルカワノ港に入る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後五時抜錨してイキケに向かう。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルバリョは凶報を受けると共に即座に抜錨して陸からの攻撃に備えた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "デル・カノは即座に抜錨して逃げた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
