[
  {
    "uuid": "656b1e91-51ad-51bc-a4bb-ad9e01686898",
    "entry": "万来",
    "reading": {
      "primary": "ばんらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
