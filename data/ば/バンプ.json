    "definitions": [
      {
        "index": 1,
        "gloss": "vamp (woman who uses her sex appeal to exploit men)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」何というバンプ〔vamp ＝ 妖婦、男たらし、浮気女〕だろう！",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あのバンプをのこして、おめおめと死ぬことができるだろうか。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の態度が一変し、バンプ型の女になったのには、大した意味はなかったのであった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
