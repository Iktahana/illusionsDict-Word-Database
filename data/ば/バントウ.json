[
  {
    "uuid": "2098ead2-fb92-52cc-acd7-3e051732cccc",
    "entry": "番頭",
    "reading": {
      "primary": "ばんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(head) clerk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やっと車の音が玄関へ飛び込んで来ると思うと番頭や女中の出迎える物音がしてそうして急に世の中が賑やかに明るくなった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　富士浅間神社　浅間神社の後からならでは、出すまじき馬を、番頭が気を利かして、宿まで馬士にひかせて来てくれたが、私はやはり、参詣を済ませてから乗りたいため、馬を社後まで戻させ、手軽なリュックサックを提げて町を歩きだした。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんたちがどんなに田舎者見てえな恰好をしてたって、番頭に化けたって、腰弁に化けて居たって、第一、おめえさんなんぞ、上はアルパカだが、ズボンがいけねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからな、お前さんは、番頭さんにゃ見えねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時、番頭さんだって、どうして、皆度のある眼鏡で、ロイド縁だよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして内から年取つた番頭らしいのが出て來たが、別に這入れとも云はず突立つたまゝで不思議さうに吾々二人を見下ろしてゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、多分番頭と思はれる五十恰好のその人は、恰度例へば何處かの役所の極めて親切な門衞のやうな態度で「前からの御申込でなければとてもとても……」と云つて、突然に乘込んで來ることの迂闊さを吾々に教へて呉れるのであつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内する人は土地の有志三四名と宿屋の番頭であった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六｜藏といふ通ひ番頭の筆にて此樣の迎ひ状いやとは言ひがたし。",
              "citation": {
                "source": "ゆく雲",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "六蔵といふ通ひ番頭の筆にてこの様の迎ひ状いやとは言ひがたし。",
              "citation": {
                "source": "ゆく雲",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨークで安ホテルを捜しあてたときに帳場に居たのっぽの番頭がやはりチューインガムを噛んでいた。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて一人の番頭とすれちがう。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の番頭から掏り取った紙入れを取り出し、中味を抜き取り、空の紙入れをポンと投げる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼んだのは先刻三次とすれ違って紙入れを引っこ抜かれた例の番頭である。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭と鉄五郎は見知りらしく立ち話し。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭は鉄五郎に紙入れを掏られた事を逐一話している。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄五郎は傍の番頭と三次を見比べて心に頷くと三次に、Ｔ「やったな三次？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝内部　徳兵衛、番頭手代に当り散らして居る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　襖の処で乳母や番頭がオロオロ顔である。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝源兵衛宅表　番頭の長吉や手代が提灯持って娘を探しに八方へ走る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うから番頭の長七や手代がやって来た。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階から下りて来た女中の報告で、　番頭や女中が、Ｔ「宮本武蔵？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは小店員の話であるが、同じやうに中番頭のものが六月號の文章倶樂部に出てゐたが、その方がずつとよかつた。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "近江商人の店などでは、新潟あたりから小僧をやとひ番頭にしてやるといふ條件でながい間の奉公を勸めさせ、やがてそれが相當の年配になると、酒や女で店をしくじるやうに仕向けて、結局店から追つ放つてしまふといふことが、常套的に行はれてゐるさうである。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章倶樂部のものはさうした資本家惡の犧牲になる一人の中番頭のなんともならない境遇が實に丹念にかけてゐた。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "マツノスケは彼女を見ると番頭を遠ざけてから云った。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを米屋の番頭から聞きこんだあるはしっこい女は、じゃ、うちにある外米を売ってあげよう、うんと安くしてあげてもかまわないから、と云いだした。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとは市ヶ谷の質屋の番頭さんをしていた千ちゃんという人が、時々ここへ遊びに来やあしねえかね」「はあ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "をぢさんの屋敷へも出入りをするので、貸本屋の番頭はをぢさんを能く知つてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は番頭に逢つて、正月以來かの小幡の屋敷へどんな本を貸入れたかと訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
