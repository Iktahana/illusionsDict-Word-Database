[
  {
    "uuid": "2de8d65a-b907-5690-88b7-6f5e35e85890",
    "entry": "蛮行",
    "reading": {
      "primary": "ばんこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
