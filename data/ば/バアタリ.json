        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これで結果が悪ければ、場当たり主義だの朝令暮改だの、日本語には悪口の豊富なボキャブラリーが用意されている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言といい演技といい、俗受け専門、場当たり専門、実にお話にもならないもので、わたしは苦々しいのを通り越して腹立たしくなった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも一種の場当たりであると言う者もあった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "へんな場当たりの人気があるんだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛川と云えば佐夜の中山はと見廻せど僅かに九歳の冬｜此処を過ぎしなればあたりの景色さらに見覚えなく、島田｜藤枝など云う名のみ耳に残れるくらいなれば覚束なし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をあくればあたり静まり返りて、たそがれの色また一際襲い来れり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をあくればあたり静まり返りて、たそがれの色また一際襲ひ来れり。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は柾生のことなど忘れ、早足になって、坂のなかばあたりで三人に追いついた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉は彼らにしてみればあたりまへのことを言つたにすぎないのであらうが、その時古賀にはおそろしくつめたいひびきをもつてきかれたのである。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "川岸の葦のわか葉に梅ちればあたりの草も香に匂ふかな夜は香のまさるおもへば人恋ふる心に似たる梅の初花梅かをる窓のひさしに月させばやすらはでこそ起き明しつれ大隅国の加治木にありて。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして褒める人のうちにもこれを僕と同じような考えをもって、まあまあ思っただけのことをやったと、平易にいわばあたり前に考える人は少なかろう。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は組み合はせた兩腕を枕にして、半ばあたりの風景に、半ば自分の裡のさまざまな思ひに、しばらくは放心したやうな状態になつてゐた。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三七―三九我これを聞きてそのいづれの路よりなるを知らざればあたりをみまはし、わが冷えわたる身をかの頼もしき背に近寄せぬ　四〇―四二ソルデルロまた。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ればあたりに誰もいない。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから強えぞ、――獅子だってのっぽのジョンのそばあたりにもよれやしねえんだぜ！",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半ばあたりへ来ると、直造は一々前まで行くのを止めて、ふりかへつては「山下さん、お次へどうぞ」と云ふ風に名を呼びはじめた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふとそのときすぐそばあたりで何かがばしゃんと池に落ちる音、水をかいて近くで見きわめようとする。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "身重になった看護婦が、一つ病院の中でそういう体で大して無理のない部署へまわり、出産休暇まで勤務をつづけるのは、思ってみればあたりまえのことだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みればあたりの水は濁り、ひっそりとして彼女のすがたは消え失せたのであったが、水面に浮んだ分の体がちらと光ったままで、かれの視覚にもつれついて中中離れなかった。",
              "citation": {
                "source": "幻影の都市",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソルボンヌのそばあたりには古い建物が非常に多くて、その便所が、水洗には改良されているが、コンクリートの踏石（レンガ位の大さ）が左右にあって、あとは流し口のついた凹みだけというのを見たことがありました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "予定なんかをはみ出すのは云わばあたり前みたいなことであろうと思って居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ればあたりのせまい河原にも、小谷にも、累々と雪が残っている。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なにかと風評のあった二人の結婚はかなり人々をおどろかしたが、そうきまってしまえばあたりまえな話で、案じていたほどうるさい口も聞かずに済み、その年も暮れて天正二年を迎えた。",
              "citation": {
                "source": "石ころ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　僕は麻素子さんにさういふことを言ひだされても、格別驚きはしなかつたので、田端の驛の裏出口、芥川の家、さうしてまた近くと聞いてゐる麻素子さんの家、それぞれの丁度なかばあたりで、「あなたは、」と麻素子さんに聞いてゐた。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の口がうるさくなったのは当然であろう、おもんでさえ「旦那か」などと云ったくらいで、なにも知らぬ者からみればあたりまえの関係でないと思うのが自然である。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車体の周囲には丈の高い草が生えていて、ドアのなかばあたりまで、草が車体をかくしていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "湾の沖に向かって、岬のなかばあたりまで、遠浅が長く続いている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアに鍵をかけ、タイトぎみのスカートの裾を、太腿のなかばあたりまでたくし上げた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかばあたりまでは屋根があり、板壁と一体になって木製のベンチがあった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイトぎみなスカートが、太腿のなかばあたりまで、たくし上げられている。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
