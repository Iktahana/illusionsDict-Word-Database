    "definitions": [
      {
        "index": 1,
        "gloss": "being a match for thousands",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
