        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "余語医官命信恬陪侍。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は学士や大臣に命じて宴席に陪侍さした。",
              "citation": {
                "source": "蓮花公主",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "役にさえ立たなければいじめられはしないのだ。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "想えばいじらしい相手だ。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子はこの頃ようやく感じ出したことだが、村川をいじめればいじめるほど、不思議な快感が、心の中にしみ出して来た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあんばいじゃ、助宗の野郎も、早駕籠を飛ばせていったにちげえねえですぜ」「決まってらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあんばいじゃ、一筋なわで行きそうもねえやつのようだから、気をつけねえとやられるぞ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあんばいじゃ、おれが出る幕じゃねえらしいな」「ところが、おめがね違い、足もとから火が出たんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悲鳴が出るあんばいじゃ、ふところが北風だろうから、じゃこいつをおめえに半分くれてやろうよ」「な、なんです？",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっと手間がかかりそうだと思ったが、このあんばいじゃぞうさなくかたがつきそうだよ」「ありがてえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "取って下さらなければいじめるわよ。",
              "citation": {
                "source": "母",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあんばいじゃ、夜明けまでにかたづくでしょう」「いや、私はもっとはやいような気がする。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴロゴロ　ガラガラ　なにがなるおれのはらんなかで　なにがなる子ヤギどもかと思ったがこんなあんばいじゃ石ころだ　それから、オオカミは泉のところまできました。",
              "citation": {
                "source": "オオカミと七ひきの子ヤギ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "医科の学生は聞えよがしに、「弱いものさえ見ればいじめたがる奴があるものさ。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者、牧師、小学校の先生、……思えばいじらしき限りです。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「情愛々々って言っても、お前のは猫可愛がりだから何にもならない」「男親の前へ出ると思うことが碌々言えない子ですから、女親が相談に乗ってやらなければいじけるばかりですわ」「何あに、狡いんだ。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "医薬の用いようのない・いじればいじるほど悪化し昂進するばかりの・病気を、せんさくするなんて愚かなことだ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙しばいじゃないよ。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」龍巻は、苦痛もわすれ、「して、厦門船は、いつ纜を巻きそうだ」「いつどころじゃねえ、もう出船のしたくをしているようすなんで、風のあんばいじゃ夕方にも、港をズリだすかも知れませんぜ」「じゃ、こうしちゃいられねえ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "投扇興　ふと――　刀の柄糸の縺れを見つけて、それを気にしてつくろいだすと、いじればいじるほど解けて来て、果ては、しまつが悪くなったので、糸切歯をあててプツンとかみましたが、その糸屑も唇にくわえたまま、なぜか、相良金吾の目にいつまでも、消えない怒りが燃えていました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "独りごとに……「そうだ、さっきの娘も、どうせあのあんばいじゃ四、五日は起きられまい。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
