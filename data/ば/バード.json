    "definitions": [
      {
        "index": 1,
        "gloss": "bird",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "バードが極飛行から無事に屯営に帰って来たのを皆が狂喜して迎え、機上から人々の肩の上にかつぎ上げて連れてくる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時バードの愛犬が主人に飛びつこう飛びつこうとするのだが人々にさえぎられて近寄れず不平でむやみに駆け回っているがだれも問題にしてくれない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからバードが宿舎にはいってくるとたれかが熱いコーヒー（？",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小介川文學士が伴ふて來た一人の男を除いては皆な此倶樂部の會員で、其の一人はオックスホード大學の出身、其一人はハーバード大學の出身など、皆なそれ／″＼の肩書を持て居る年少氣鋭、前途有望といふ連中ばかり。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さうです、僕はオックスフオードにもハーバードにも帝國大學にも早稻田にも三田にも高等商業學校にも居たことは無いのです。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言つたのはハーバード出身の紳士。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は小兒の時を回想して當時の學校を懷しく思ふだけの意味で言つたのです』とハーバードは罪のない微笑を浮べて言譯した。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何卒その大島小學校のことを話して貰ひたいものです』とハーバードは前言のお謝罪にオックスホードに贊成した。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『是非お話を願ひたいものです』とハーバードは乘氣になつた。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『權藏は今如何して居ますか』と問たのはハーバードである。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "デリシアスかい、ハッバードか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェムズバードって名付けてね。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンバード街のでっかい株屋のモウソン＆ウィリアム。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕立屋、ウィリアム・バードの証言。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時王の使｜喚いて彼を海へ追い込み、牝馬を伴れ帰って介抱すれば、海馬生まると（一八一四年版ラングレー仏訳『シンドバード航海記』一二頁）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてセイロンのシンガリース人は林中で猴が死んでも屍を見せぬといい、その諺に「白い鳥と稲鳥（パッジー・バード、鷺の一種）と直な椰樹と死んだ猴、それを見た人は死なぬはず」という。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔバードだって、キャディだって、金さえ払えば、いくらでも買える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーリー・バードと、なんとかバードと、なんとかかんとかって衛星で、同時に世界中をむすべるようになったんだとさ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラが「ラナ・バード」とつけ加える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリック・バードンが叫び、アラン・プライスのオルガンが突っこんでくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーリー・バードのたまもの。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンシルバニア地方を代表したフイラデルフイア大学はタフトを、ニユーハンプシヤイア地方からのハーバード大学はマツキンレイを、そしてメリーランド地方としてはワシントン大学がルーズベルトを支持した。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｗ」大学が「Ｐ」を一蹴して、ハーバードを一八九八年、九年と続けて撃破した折などは、勝盃を贈らうとするマツキンレイ大統領の腕が悲しみに震えてゐた、あれが次の総選挙に際しての敗戦の陰影をつくつた――といふやうな噂が飛んだ位ゐであつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は前年の冬にはハーバードを破り、フイラデルヒアに迫つて惜しくも破れた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持の逍遥するフォッシュ通りから、シャンゼリゼー、バードブロウニュあたりには、身なりをかまわぬ人々が、何をして良いのか分らなそうに、うろうろして遊んでいる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、ある大学の神学部長をつとめてゐたロオレンスとハーバード大学の総長エリオツト博士が、つれ立つてあるきながら、この問題について談話をとりかはしてゐたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちようどそのころブルー・バード映画の全盛時代がきた。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホバード夫人は、「それが世界に通商をひろめて来た精神」である不屈不撓な事業熱をもっている船長イーベン・ホーレイの多難な生涯と揚子江上の荒々しい回漕事業の盛衰とをこの小説の縦糸にしているのである。",
              "citation": {
                "source": "「揚子江」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七四年からはカルルスバードの温泉療法が試みられた。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
