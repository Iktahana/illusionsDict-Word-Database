    "definitions": [
      {
        "index": 1,
        "gloss": "(cutting) with a single stroke",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
