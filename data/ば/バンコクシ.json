        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "パーレー万国史、クヮッケンボス文典などという書名を連ねた紙片に過ぎなかったが、それが恐ろしく幼い野心を燃え立たせた。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナショナルの二位しか読めないのが急に上の級へ入って、頭からスウヰントンの万国史などを読んだので、初めの中は少しも分らなかったが、其時は好な漢籍さえ一冊残らず売って了い夢中になって勉強したから、終にはだんだん分る様になって、其年（明治十七年）の夏は運よく大学予備門へ入ることが出来た。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつたい何時も誤魔化読をする時には、小説を先づ斯う開いて、其上へ、詰り英語の塾だから、ナシヨナル読本、スイントンの万国史などを載せる。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼時余は、母に、論語を学び、二宮尊徳の修身を聴講し、ナシヨナル・りいどる巻の一に依つて英語を手ほどかれ、和訳すゐんとん万国史を講義された。",
              "citation": {
                "source": "余話（秘められた箱）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すゐんとん万国史は、余が稍長じた頃だつたが、たゞその書物の装釘が、灰色に太き金文字を印したる表紙を憶えてゐるのみである。",
              "citation": {
                "source": "余話（秘められた箱）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――朝になると、その書物は何時の間にか姿を消して、書箱の観音開きには堅く錠が下され、母の机上には、不景気なナシヨナル・りいどると、灰色のすゐんとん万国史等が悄然と積み重ねてあるばかりで、徒らに余の退屈をそゝつたからである。",
              "citation": {
                "source": "余話（秘められた箱）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類の発展には一貫の意味目的があって、国家は各その一部の使命を充す為に興亡盛衰する者であるらしい（万国史はヘーゲルのいわゆる世界的精神の発展である）。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼時余は、母に、『論語』を学び、二宮尊徳の修身を聴講し、『ナショナル・りいどる』巻の一に依つて英語を手ほどかれ、『和訳すゐんとん万国史』を講義された。",
              "citation": {
                "source": "余話",
                "author": "秘められた箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "『すゐんとん万国史』は、余が稍※長じた頃だつたが、ただその書物の装幀が、灰色に太き金文字を印したる表紙を憶えてゐるのみである。",
              "citation": {
                "source": "余話",
                "author": "秘められた箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "――朝になると、その書物はいつの間にか姿を消して、書箱の観音開きには堅く錠が下ろされ、母の机上には、不景気な『ナショナル・りいどる』と、灰色の『すゐんとん万国史』等が悄然と積み重ねてあるばかりで、徒らに余の退屈をそそつたからである。",
              "citation": {
                "source": "余話",
                "author": "秘められた箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの散歩は――ときには別荘の庭、ときにはネスクーチヌィ公園、またあるときは関門の外まで足を伸ばすといった風で、いつも何か本を一冊――たとえばカイダノーフの万国史通など――を持って出るのだったが、それをめくってみることはめったになく、とてもたくさん空で覚えていた詩を、高らかに朗読する方が多かった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨吉が初めて就いた語学の教師は海軍省へ出る小官吏とかで、三十銭の月謝でパアレエの万国史まで教えてくれた話も引出された。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下の一室は昔しオルター・ロリーが幽囚の際｜万国史の草を記した所だと云い伝えられている。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤は、生意気でなくて、しっかりした娘として毛糸編物の内職で弟の世話をしてやりながら弟に教えてもらって英語の万国史などをも読み、和歌も上手な松島秀子という娘と結婚する。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもそのはず共立学校では余はやうやう高橋（是清）先生にパーレーの『万国史』を教へられて居た位であつた。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百は漢訳和訳の洋説を読んで慊ぬので、とうとう保にスペルリングを教えてもらい、ほどなくウィルソンの読本に移り、一年ばかり立つうちに、パアレエの『万国史』、カッケンボスの『米国史』、ホオセット夫人の『経済論』等をぽつぽつ読むようになった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "スヰントンの万国史は中学などで使っているが、あれさえ始から終までスッカリ分る中学の教師はないと思う。",
              "citation": {
                "source": "今世風の教育",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｕ君は先刻Ｈ君が会つて差入れの事を云つたら、万国史と辞書がはいつたのならそれでもう申分なしだと云つてゐたさうですよ。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "葦「第四リーダーと万国史を読んでおります。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の本は二十年も三十年も前の本だ、先生がおれに貸してくれた本はスミスの代数とスウイントンの万国史と資治通鑑それだけだ、あんな本は東京の古本屋にだってありやしない。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も稲垣氏でさえ慶応義塾でピネオの文典とか、カッケンポスの万国史とかミッチェルの地理書とかいう位のものを読んだくらいのもので、発音は凡ていわゆる変則読みであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ、万国史、自分、「ゲエテとの対話」。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙはロシア語の万国史をよんで居る。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ、万国史、イジプトのところをよみよみ教えてくれる。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "パアレーの『万国史』。",
              "citation": {
                "source": "十六、七のころ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い英語の経済学や万国史はさして珍しくもない。",
              "citation": {
                "source": "虫干",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "万国史で見た西洋の天子の冠のような形をした小さい島が入江から真近い処にあるのに今初めて気がついた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ待て、これを貸してやろう、スマラグドフの万国史だ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年ばかり前、わしが娘に地理と万国史を教えにはかかったものの、わし自身がかなり怪しいところへもってきて、人並みの参考書もなかったもんですからな。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
