          "literary": [
            {
              "text": "第三幕　第一場札荅蘭城、城門の景。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面切ったのは、色の白い、ちょっとぼうぼう眉のお公卿さんと見えるような大姐御、どてらを引っかけて、立膝で、手札と場札とを見比べている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子供がたとえばふだんいたずらをするからといって、今もいたずらをしたとでも思っているのか。",
              "citation": {
                "source": "卑怯者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤貧の境地にはずつと距離のあるびんばふだけを私は知つてゐる。",
              "citation": {
                "source": "赤とピンクの世界",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このピンク色の世界に住むこともずゐぶん苦しいけれど、びんばふだからいざ死なうといふ気にはなれない。",
              "citation": {
                "source": "赤とピンクの世界",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は購買組合ですが、そういうところから物を買っていないところは、例えばふだんとっている三河屋というような店へその切符をやるのです、三河屋がその切符をまとめて、市へかえすのらしい様です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
