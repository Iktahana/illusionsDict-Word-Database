    "definitions": [
      {
        "index": 1,
        "gloss": "attendant's booth (in a bathhouse changing room)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
