        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "健康のバロメーターになる。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそのタタキ加減がその日の低気圧のバロメーターになるので、これは老幼を問わず同様の感想であったらしい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔いのバロメーターみたいなものだね」「恋は？",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象はその人の眼の高さのバロメーターである。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮人は磁石なしに方角を知り、バロメーターなしに悪天候を前知する。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に登第者の多寡は、其地方の文運を卜すべき一つのバロメーターともいへる。",
              "citation": {
                "source": "歴史上より觀たる南支那の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はいま五十五、六歳、まだ老人という歳でもないが、頭とひげは雪のように白くそれと共に左の眉に二寸ばかり長い毛が一本つきでている、おこるときにはこの長い毛が上に動き、わらうときには下にたれる、町の人はこの毛をもって先生の機嫌のバロメーターにしている。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして餞別の金高はその碼頭の匪徒の格式を計るバロメーターとなるのであるから各匪は挙って出来るだけ沢山進物をする。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つは、いかに多くの俳優が揃っていても、それがただ名優であるというだけでは、その国の文化のバロメーターにならない。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その国の文化が高いということの一つのバロメーターになるのは、俳優の中に学識のあるものが沢山いるということです。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代人として最も高い教養をもった人達が、俳優の中に沢山いるということが、その国の文化が高いということのバロメーターです。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄養の的確なバロメーターである。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、食物に対する注意、バロメーターの使い方、隧道内の空気の検査法、宿営の場合の注意など、すべてにわたって、手落ちなく話して聞かせた。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれにとって、納入される新聞雑誌、諸出版、単行本は、中央気象台にかかって来る気象電話のように、一つ一つが、日本の現状のバロメーターの目盛として記録整理されてゆくのである。",
              "citation": {
                "source": "国立国会図書館について",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッキング・ケースは、アメリカではいまや自動車と同様、経済のバロメーターといわれるほどの普及ぶりである。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "関心の質的特色は教養のバロメーターとなるだろう。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ教養の実質そのものが何であるかはまだ判らぬとしても、このバロメーターは実際的な利用価値を有っているだろうと思う。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが教養を量るバロメーター自身を離れて、教養の実質を実際的な問題とすることは出来ないかも知れぬ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "教養のバロメーターは、その人が如何なる関心を持つかにあるだろう。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に文化的技能の獲得如何は、文化の唯一のバロメーターとさえ考えられている。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題はそのドイツ文化的哲学「文化」なるものによって計られるべき文化哲学的な文化水準が、果して本当に文化を正当に量り得る文化のバロメーターかどうか、ということに帰する。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "安部磯雄事件は日本のラジオ放送に対する社会的統制力のバロメーターとして極めて鋭敏な感度を有っていたわけだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は密かにその日数で、その玩具がどの程度にお気に入ったかを占うバロメーターにしていた。",
              "citation": {
                "source": "解説　趣味を通じての先生",
                "author": "額田六福",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは人気のバロメーターだと思ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中食の際バロメーターは氣温十一度半、氣壓六百五十四粍を示してゐたが、どうも朝から天候險惡になりさうであつた。",
              "citation": {
                "source": "黒岩山を探る",
                "author": "沼井鐵太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處はバロメーターによると千八百五十米を示してゐたが、實際はも少し高所にあつたらしい。",
              "citation": {
                "source": "黒岩山を探る",
                "author": "沼井鐵太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして午後十時就床の時は氣温は七度半、氣壓は六百十九粍、バロメーターの標高千七百十米を示してゐた。",
              "citation": {
                "source": "黒岩山を探る",
                "author": "沼井鐵太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
