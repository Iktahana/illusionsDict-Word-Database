[
  {
    "uuid": "58470487-34d8-5542-8a51-f4a67eefa317",
    "entry": "罰",
    "reading": {
      "primary": "ばつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-接尾辞"
      ],
