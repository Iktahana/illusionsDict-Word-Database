  {
    "uuid": "f3e66122-ecb1-5f61-a6e6-493f9f7055c8",
    "entry": "跋",
    "reading": {
      "primary": "ばつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "epilogue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実施の時代にはえて低級の事が跋扈する。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はここまで書いて此の物語が以前に送つた跋文にくらべて、どこか物足りなさを感じた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がふとしたことから跋文を紛失したと青い顔をして来たときに思つた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは兄が私の跋文を紛失させた罪もあるが。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この創作集の末尾に、田中君が跋文を書き添へてゐるやうですが、それに據れば、「俺の過去は醜惡で複雜、まともに語れるものではない。",
              "citation": {
                "source": "田中君に就いて",
                "author": "――田中英光著『オリムポスの果實』序",
                "note": "青空文庫"
              }
            },
            {
              "text": "堯はそう言われたとき自分の裡に起こった何故か跋の悪いような感情を想い出しながら考えた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "闊歩横行、登攀、跋渉、そんな事はお茶の子で。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初期のは市人の中の気慨のある者か或は武士の仕官の途に断念した者などが、武士の跋扈に反抗して之を膺懲し或は之に対抗する考へから起つたのであるらしいが、夫から以後、即ち天明前後から天保あたりへ懸けての侠客といふものは多くは博徒のやうな類である。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も関東ばかりが侠客が跋扈したと云ふでは無い、京大阪にも侠客はある。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "年輩四十｜幾干、骨格の逞しい、頭髪の長生た、四角な顔、鋭い眼、大なる鼻、一見一癖あるべき人物で、其風俗は官吏に非ず職人にあらず、百姓にあらず、商人にあらず、実に北海道にして始めて見るべき種類の者らしい、則ち何れの未開地にも必ず先づ最も跋扈する山師らしい。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "跋　宗教で最後のものは体験であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「口説かれるのも下拙だし、気は利かないし、跋は合わず、機会は知らず、言う事は拙し、意気地は無し、」「堪忍したまえ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金力の跋扈、ことに下等獣類に等しき工夫共の手により質朴なる田舎に撤かるる悪銭は、実に慨嘆に堪えぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "跳梁跋扈厭き足らぬ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もう、やけになつて、鳴きしきる蟲の音を合方に、夜行の百鬼が跳梁跋扈の光景で。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠がそんなに跋扈しては、夜寒の破襖を何うしよう。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも、こども服のノーテイ少女、モダン仕立ノーテイ少年の、跋扈跳梁は夥多しい。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども渠は絶えず身を悶えて、跋ね覆えさんとしたりしなり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩むにつれて、足下の叢より池に跋ね込む蛙は、礫を打つがごとく水を鳴らせり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつては自分の相手方であった団菊左の諸名優も相次いで凋落し、後輩の若い俳優らが時を得顔に跋扈しているのを見ると、彼はその仲間入りをするのを快く思わなかったかも知れない。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は、私が人名辞典やら、「葛原勾当日記」の諸家の序やら跋やら、または編者の筆になるところの年譜、逸話集、写真説明の文など、諸処方々から少しずつ無断盗用して、あやうく、纏めた故葛原勾当の極めて大ざっぱな略伝である。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "附録の論文「自由詩のリズムに就て」は、この書物の跋と見るべきである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この詩集は、詩集である以外に、私の過去の生活記念でもある故に、特に書物の序と跋とを、二人の知友に頼んだのである。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上を跋文の形として、日頃の喜びと、懷しさを、更に更に高く捧げたく思ふ私である事は、世の多くの讀者とまたすこしも變らないのである。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけでも既に不思議な恩寵なのに、さらにまた、その本の跋に、この支那文学の俊才が、かねてから私の下手な小説を好んで読まれていたらしい意外の事実が記されてあって、私は狼狽し赤面し、かつはこの奇縁に感奮し、少年の如く大いに勢いづいてこの仕事をはじめたというわけである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の書の体たるや、水滸伝平妖伝等に同じと雖も、立言の旨は、綱常を扶植し、忠烈を顕揚するに在りというを以て、南安の郡守｜陳香泉の序、江西の廉使劉在園の評、江西の学使｜楊念亭の論、広州の太守｜葉南田の跋を得て世に行わる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨海の林佑、葉見泰等、潜渓の詩に跋して、又｜各宋太史の期望に酬いんことを孝孺に求む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も財力乏しく、地位亦低きの旅行者が、馬にも乘れず、車にも乘れず、只管雙脚の力を頼むより他に山河跋渉の道なきと同樣である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかく、それらの音楽によつて多くの人々が、好い気持にされてゐるのだから文句はないのだが、然しもと／＼気分の暈縁なぞといふオボコイものを聴いて喜んでゐる連中が取引のこととなると俄然骨ばつてくるし、而も楽々骨ばれるやうに前以て備へてゐるので、「音楽と世態」なぞと今並べてみたくなるのである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたの友達つたら悪いのばつかり……」　祖母は不満さうに言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
