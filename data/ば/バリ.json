[
  {
    "uuid": "69aab3b8-7564-5d4e-aff2-f69e4e96153e",
    "entry": "罵詈",
    "reading": {
      "primary": "ばり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
