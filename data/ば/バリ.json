    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(verbal) abuse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悪口を云われる方では辛抱して罵詈の嵐を受け流しているのを、後に立っている年寄の男が指で盆の窪を突っついてお辞儀をさせる、取巻いて見物している群集は面白がってげらげら笑い囃し立てる、その観客の一人一人のクローズアップの中からも吾々はいくらも故旧の誰彼の似顔を拾い出すことが出来るのである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わめき、罵詈、溺れるような死にものぐるいの手と脚のもがき、屋台の顛覆。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども自分の方から凡俗に降って膝を交えることは、とても出来｜悪い性分なので、自分の自由をはたにひけらかし、また他を罵詈呵責してはたのものに何等かのショックを与えることの上に人間との交渉を保って行こうと馬翁の無意識が努めるらしい。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屑屋はまた貴婦人を捕えて罵詈讒謗、「あ、あ良い匂だ咽返るようだ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の輪の拡がり、嵐の狂うごとく、聞くも堪えない讒謗罵詈は雷のごとく哄と沸く。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の宗教を奉ぜんとするに會へば、之を嘲笑するは科學を悦ぶものの免れざるところであり、他人の科學を尊信するを見れば、之を罵詈するは宗教を悦ぶものの免れざるところである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其二は、自らの主義、人間は Passion の動物なれば、少くとも自家の私見、善く言ひて主義なるものに拘泥することなき能はず、故に若し一の私見と他の私見と撞着したる時に、近頃流行の罵詈評論に陥ることなきにしもあらず。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "公開書になっているのも、罵詈がしてあれば、棄て置いても好い。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また先方にも過誤がある場合には、それを捉えて罵詈の返報をすることも出来る。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが下りて行くと、妻はそとへも聴えるような甲高な声で、なお罵詈罵倒を絶たなかった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛律は蘇武が鉄火の罵詈に遭い、すっかり恥をかいて手を引いた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "椰子の葉を叩くスコールの如く、麺麭の樹に鳴く蝉時雨の如く、環礁の外に荒れ狂う怒濤の如く、ありとあらゆる罵詈雑言が夫の上に降り注いだ。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒鳴り疲れた妻が一寸息を切って椰子水に咽喉を潤おす段になって、やっと、今迄盛んに空中に撒き散らされた罵詈が綿の木の棘の様にチクチクと彼の皮膚を刺すのを感じた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分が平生不思議に思うことは、昔でも今でも俳人の世界ではいろいろの党派のようなものができて、そうして各流派流派の「主張」とか「精神」とかいうものを固執して他流を排斥しあるいは罵詈するようなこともかなり多い。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち付け打ち付け罵詈讒謗を極めて見たが鳥居は動かなかった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの粗忽を、大に陳謝したが、しかしこの珍本たるや、この所有主には、はなはだ貴重なものであったと見えて、その老人は憤然として、自分に罵詈の言葉を投げかけて、踵を返して立ち去った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう大体の見当はついたが、――またこの電信でどうしようと云うことも、まあ想像は出来るが、しかしこうして待っている間に、君の知ってるだけのことを話してもらってもいいね」　その年取った法衣姿の無頼漢は、無茶苦茶な悪口罵詈を浴びせかけて来た。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "表扉は叩いても開けられることはなく、返事といえばただ向こうから止めどなくやってくる罵詈雑言。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばへ来たとき、御者はわけがわからないという風に空の馬車を引っかき回して、何とも巧みに罵詈雑言を操ってまくし立てていたよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の輪の拡がり、嵐の狂ふ如く、聞くも堪へない讒謗罵詈は雷の如く哄と沸く。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子掲示板上で実におぞましい罵詈雑言のぶつけ合いなど見るにつけ、心に引っ掛かるのはその点だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビルダデのこのヨブ攻撃は、殊に第四節の如きは、罵詈の語としては簡潔｜雄勁にして、正に独創的の警句というべきである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人が宗教を信奉するのに出会い、これを嘲笑するのは科学を悦ぶ者の免れないところであり、他人の科学を尊信するのを見れば、これを罵詈するのは宗教を悦ぶ者の免れないところである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "□　罵詈はいけないといふ。",
              "citation": {
                "source": "批評",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし罵詈悪口まで行かなければ、本当のことが言へないやうな場合がよくある。",
              "citation": {
                "source": "批評",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "罵詈は批評の尖つたものではないか。",
              "citation": {
                "source": "批評",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその老学者に深い尊敬を払っているが故に、そして氏の生得の高貴な性格を知っているが故に、その言葉の空しい罵詈でないのを感じて私自身の卑陋を悲しまねばならなかった。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎しみの場合に於ても、例えば私が私を陥れたものを憎んで、これに罵詈を加えたとすれば、憎まれた人も、その醜い私の罵詈も共に還って来て私の衷に巣喰うのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校の文芸部か何かで我鬼大将になれた、といふやうなことが彼等の運の始まりで、適度にでしやばりで、適度に野暮ッたいといふ彼等のえてして持つてゐる性質が、偏狭で、自信のない文壇といふ小主観国にどうかしたはずみには顔を出すといふ運びとなるのである。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は汗を拭い、ちょっと威容を正して門をくぐり、猛犬はいないかと四方八方に気をくばりながら玄関の呼鈴を押した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
