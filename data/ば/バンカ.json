[
  {
    "uuid": "2623bea6-8afe-5908-a053-ec3a019a3d33",
    "entry": "挽歌",
    "reading": {
      "primary": "ばんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
