    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tomato (Solanum lycopersicum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "畑には灰いろの花椰菜が光って百本ばかりそれから蕃茄の緑や黄金の葉がくしゃくしゃにからみ合ってゐた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕃茄か、アーリアナか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "次は、肉を刻み油でいため、蕃茄羹をかけたものだ。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんかいてみたいのは野外の風景であるが今の病体ではそれは断念するほかはなかった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のようなものにはこの劇中でいちばんかわいそうなは干物になった心臓の持ち主すなわちにんじんのおかあさんであり、いちばん幸福なのは動物にまでも同情されるにんじんである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしから秋はいちばんからだもこころもひきしまって、勉強のできる時だといってあるのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水先案内もあるだろう、医者もあろう、船の行く処は誰が知ってる、私だ、目が見えないでも勝手な処へ指揮をしてやる、おい、星一ツない暗がりでも燈明台なんぞあてにするには及ばんから。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、なんといっても、いちばんかわいらしいのは、開いたお城の門のところに立っている、小さな娘さんでした。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにをおいても、いちばんかわいがってやるぞ。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、死んだ子供というものは、だれにとっても、いちばんかわいいものです。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、いちばんかたいはがねで、いなずまをきたえさせました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "同ばんかた、わが言ひしことを、そくざにおいて、打ちけされけることあり。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さむいと、おもひてをれば、ばんかたより、また、ゆきがふりいだして、げに、さむいことになつたよ。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一ばんかの女の感情の根をこの都に下ろさしたのは、むす子とマロニエの花を眺めたときだった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがな、お前は家附の娘だから、出て行くことが出来ぬと謂えば、ナニ出て行くには及ばんから、床ずれがして寝返りも出来ない、この吾を、芳之助と二人で負って行って、姨捨山へ捨てるんだ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何、それにゃ及ばんから、御贔屓分に盛を可く、ね。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、思金神という、いちばんかしこい神さまが、いいことをお考えつきになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で、天皇は、矢河枝媛のお生み申した若郎子皇子を、いちばんかわいくおぼしめしていらっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、わたしをいちばんかわいがってくださった方なのです。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
