          "literary": [
            {
              "text": "おれが何を盗んだ」「しらばっくれるな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでは末造がしらばっくれると、ついそうかと思ってしまったが、今度は余り強烈な直覚をして、その出来事を目前に見たように感じているので、末造の詞を、なる程そうでもあろうかとは、どうしても思われなかった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の暮に一度たずねて来て、なにか手文庫の錠前がこわれているから直してくれというので、宿屋に見に行きましたが、あいにく留守で、こっちも忙がしいのでそれぎり行きませんが、その甚右衛門がどうか致しましたか」「白らばっくれるな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、白ばっくれるな。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、白ばっくれるな。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ直ぐに白状しろ」「へえ、なんでございます」「ええ、白らばっくれるな、てめえの襟っ首にぶらさがっているのはなんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "その生徒は捨吉の顔を覗き込むようにして、「白ばっくれるない」　という声を浴せかけて通った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さアどうですか」と白ばっくれるのに、「どういう意味か、知ってるか」とニヤニヤ皆と目くばせしてから、尋ねます。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも知らないと白ばっくれるか」「おどろいたでたらめをいう人だ」「とにかくお気の毒さまだ。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ご上人様のことよ、しらばっくれるない」「…………」「アッハッハッ、まあいいや。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白ばっくれるのもいい加減にしろよ。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあうまいわね、ほんとに白ばっくれることだけはお上手だわ。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "白ばっくれるのと鈍感なのとは結局お隣り同志だわ。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「白ばっくれるなら云ってきかしてやる。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しらばっくれると、ひっくりかえして験めるぜ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜お通夜に来た新助を木戸のところで殺したろう」「えッ」「白ばっくれるな松五郎。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、どうしたというんで――」「白ばっくれるな、新吉、手前の仕た事を見せてやるから」　現場にはまだ同心も町役人も居りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい何がどうしたんだ、え、井崎さん」「白ばっくれるない、――井崎さん手紙を見せてやりましょう」　これは勘次の声です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "濡れた千両箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佐々さん、白ばっくれるなんて罪なことだけはしないで下さいね」「わたし、ほんとに今夜はじめてなのに――。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君は白ばっくれるな、君は俺の最も大切な秘密を知っている。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "非国民だ」　私は心当りがないから、どの句だろうと首を伸ばすと、「しらばっくれるのも、いい加減にしろ」　と、男が指で示したのは「なんとかの気もしらずに女房またはらみ」という一句である。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しらばっくれるな、とおさいはかなきり声をあげた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――しらばっくれるな、われらはみんな知っているんだ、きさまは埴谷城代を隠退させるために来た、にも拘わらず、きさまは城代におべっかを使い、ごまをすり、逆に城代を居据らせてしまったではないか」「私が城代におべっかを使った？",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんだと、白ばっくれるな。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よう、もうやめにすべえよ」となをこが云った、「たのむからほかの話しにすべえ、本当に殿さまに笑われるし、恥ずかしいだからよ」「なをこもいいかげん白ばっくれるだな」ときよきが云った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しらばっくれるな。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「未だ白ばっくれるのかい？",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
