[
  {
    "uuid": "f41254f2-7ad2-5d19-8071-7c568e74aec4",
    "entry": "爆笑",
    "reading": {
      "primary": "ばくしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "roar of laughter (from multiple people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "数分間ごとに爆笑と拍手の嵐が起こる。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっぱら談話をリードしているその中の一人が何か二言三言言ったと思うと他の二人が声をそろえて爆笑する、それに誘われて話し手自身も愉快そうに大きく笑っている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また二言三言何か言ったと思うと再び同じような爆笑が起こってそれが三声つづく。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうかなり規則正しい爆笑の週期的発作が十秒ないし二十秒ぐらいの間隔をおいて実に根気よく繰り返されていた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を話しているか何がおかしいかわからない傍観者の自分には、この問題的な爆笑が全く機械的な現象のように思われて来た。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう瞬間が最もたわいのない軽口とそれに対する爆笑を誘発するに適当なものではないか。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちうなぎどんぶりが三人の前に運ばれて食事が始まると同時に今までの間欠的爆笑がぴたりと止まってしまった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こう側の三人の爆笑とそれに続く沈静との週期的交代の観察に気を取られて、しばらく前方の老人の事を忘れていたが、突然、実に突然にその老人が卓上の呼び鈴をやけくそにたたきつけるけたたましい音に驚かされてそのほうに注意をよびもどされた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗けたのか」　と頬を膨らましてスゴスゴ引き退るトタンに大爆笑と大拍手が敵味方から一時に湧き返るという、空前絶後の不可思議な盛況裡に、無事に予定の退却となった。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やったな、やったな」という声や、またも、「イチロ、イチロ」という叫び声が爆笑と混って聴えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私たちは、爆笑した。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨の新婚旅行……」　芸妓連中が一斉に爆笑した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚旅行……誰が……」　と云ったので今一度、爆笑が起った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一隅の別室からにぎやかな爆笑が間歇的に聞こえて来る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠行かっしゃい」　崩れるような爆笑を打ちのせて、主水之介の乗物はゆさゆさと常盤橋御門へさしかかりました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーレムの電柱に、二度もおカマ掘られちゃ、たまりませんねえ」　ワラが下品に笑い、慶一以外の全員が爆笑した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――では、これから照明を落としますが、ここは場末の映画館でもないし、みなさんも、もうティーネイジャーではないのですから、妙な行為は慎んでください」　爆笑と、相手がいねえぞ、というヤジ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……僕は……僕はまだ、何も言いませんが君に……初めてお眼にかかったんですが……」　またドッと起る爆笑……。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "またも湧き起る爆笑と、続いて起るゲラゲラ笑いとを、華やかに渦巻くジャズの旋律と一緒にフロックの背中に受け流しながら、愴惶として階段を駈け降りた。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ舌打やら、噴飯の爆笑が起り、「とうふや！",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "布袋さまみたいな貴様が泣くと、褌のないのよりも、もっとみっともないぞ」　どっと一座は爆笑した。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふふふふ」「何だって――」　とケリーが頤をおさえながら、その方へつめよると、一座はまたどっと爆笑した。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆笑の花園みたいである。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをキッカケに、井戸端からドッと爆笑がまきおこって、その場の暗い気持をふきとばしてしまった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして彼は陰欝に爆笑した。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "と僕を――（爆笑）はっはっはっは、なるようになるさ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽかんとしてる女の顔へ、一同の爆笑が集中する。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひげの女らは、思いきり淫猥な言葉で応酬しながら、男たちの爆笑をうしろにお尻で調子を取っていく。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という神楽なのか釣ばりを咽喉にひっ懸けて苦しんでるモドキを大国主命か誰か出て来て除ってやる滑稽な仕草と対話のある神楽が演じられる頃になると、見物の間には爆笑と歓呼とが伝わり、だんだんと狂言小屋や、角力場のような光景に化して行った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
