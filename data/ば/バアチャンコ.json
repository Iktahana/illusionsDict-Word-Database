    "definitions": [
      {
        "index": 1,
        "gloss": "child who loves their grandmother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は完全にばあちゃん子で、週末はいつも祖母の家に行きたがる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖母が旅行でいない間、そのばあちゃん子はとても寂しそうにしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は祖母との絆が深く、典型的なばあちゃん子だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そのばあさまは、私があなたのことや島田のこと話し、やっぱりあなたがおばあちゃん子だったこと話すので、お目にかからないのにそんな噂も知っているのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
