    "definitions": [
      {
        "index": 1,
        "gloss": "off the board (go, shogi, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "５　碁将棋では、盤外作戦ということを云う。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤外の言動で相手をじらせて、平静な思考力を失わせようという作戦のことだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ人の盤外作戦にひっかかり易い方である。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまそれに悪意ありと邪推した人が勝手に架空の盤外作戦にひっかかるだけの話である。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚上手を行って升田を怒らせたりジラせたりするような悪どいことをやれば、升田はたぶん誰よりも人の盤外作戦にひっかかってしまうだろうと私は思う。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が案外人の盤外作戦にひっかからないのは、腕に差があるからであろう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、腕に差のない大山や塚田は盤外作戦をやらないタチの棋士だから、破綻を見せずにすんでいるのだろうと私は思っている。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
