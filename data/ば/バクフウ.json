        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その時すでに窓はすぽんと破られ、猛烈な爆風が私の体をふわりと宙にふきとばした。",
              "citation": {
                "source": "長崎の鐘",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "上へあがれば、あの爆風で吹きとばされる。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために原子爆弾の巨大なる爆風に吹き飛ばされた結果、あのようなことになったのであろうというのである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼がくらむ閃光、強烈な熱線と放射線、狂猛な爆風……。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれをあいつに一撃されようものなら、この研究所の塔は爆風のためにすっ飛んでしまうだろう。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう何人、機械人間があらわれても平気ですよ」　機械人間の破片は、こちらへもものすごい勢いで飛んで来たのだから、もし博士や少年たちが、機械人間の中へはいっていなければ、その爆風や断片で、大けがをしたにちがいない。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてです」「いまの爆風と破片で、こちらの操縦装置がこわれてしまったんだよ。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだか、まだか、マートン技師」　デニー博士の声が、爆風のように響く。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "千切れた海草が、ふらふらと舞い上っていくのが、爆風で跳ねあげられた人間のように見える。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、爆風と言ふのが、相当にひどいものなのです。",
              "citation": {
                "source": "鵠が音",
                "author": "島の消息",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハヽヽヽヽヽといふ、突然部屋に爆風のやうな哄笑が起つた。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の底からこみあげてくる、いや、全身がひとつの爆風に化したといふ哄笑である。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰向けにねて、部屋一杯にこもる爆風をたてながら、左右に身をうねらせてゐるのであつた。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠はやわらかいから、爆発してもその爆風は土壌の圧縮によって相当のクッションになるらしい。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし本当はそうではなく、立っていて、首だけ爆風にやられたのであろう。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは放射物質による害そのものであり、原子爆弾は単に爆風と火傷のみならず、放射物質による害も加えるものであることが証明された。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの超電撃的地球儀的｜広汎大作戦が、真実に日本軍の手によって行われたその恐るべき大現実に、爆風的圧倒を憶えない者は一人もなかった。",
              "citation": {
                "source": "不沈軍艦の見本",
                "author": "――金博士シリーズ・10――",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲弾は、この研究所の前方に落ち、それから、彼等の頭上をとび越えて、後の山上に落ちて、ものすごい音響と閃光とそして吹き倒すような爆風とを齎した。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑道を通って外へ鉱石をはこび出すためのケーブル吊下げ式の運搬器も、その鉄塔も、爆風のため吹きとんでしまい、今は切れ切れになった鋼索が、赤い土のあいだから、枯草のように顔を出しているだけであった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆風が艇の方へこないように、不要の機械を置いて防いだ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その爆風で、艇はうしろへ押しもどされた。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大矢警部も窓をメンミツに調べていたが、「君は爆風のことを考えているのだね」「えゝ、まア、そうです。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでハムレットはどうなったのですか」「防空壕のそばへ爆弾が落ちると、爆風と地動で土盛が崩壊し、ハムレットが中からとびだしてしまいました。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、だあーんと爆風が到達し、職員室は震駭し、皆はばらばらと硝子片を引きかむった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ととどろいて、着物があおられ、木の葉が吹き飛ばされたが、爆風もここまで来るとよほど弱くなっていて、牛があばれだすほどではなかった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時すでに窓はすぽんと破られ、猛烈な爆風が私の体をふわりと宙に吹き飛ばした。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
