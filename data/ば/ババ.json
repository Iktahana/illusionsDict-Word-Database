[
  {
    "uuid": "11c9cc38-e9eb-5131-94b2-12e0d7fd025d",
    "entry": "糞",
    "reading": {
      "primary": "ばば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
