  {
    "uuid": "412d83b4-35bd-5313-aa83-c2b492dde78e",
    "entry": "ババ",
    "reading": {
      "primary": "ババ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rum baba",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アババババ、アババババ、",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "オババサンニ可愛イ言葉。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも手紙の終りに『オババサマニヨロシク』とか『オババサマニ可愛イ言葉』とか書いている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "オババサマとは彼の妻の母であって、名義上、小泉家の養子たる彼にとっては、姑の義母に当る老婦人である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が蛇を追ったといって叱られ、植木屋が筍を抜いたといって怒られ、はては『おババさま』の姑でさえが、枯れた朝顔をぬいたというので『おババさま好き人です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は畠の横の草原に寝て青い大空を仰いで「チチババチバチバ」という可愛らしい雲雀の声をいつまでもいつまでも見詰めていた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　シツカリト　カナヅチヲ　ニギリシメテ、コウババカリノ　マチヘ　マツスグ　アルイテ　ユキマシタ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんの名をカシムと言い、弟の名をアリ・ババと言いました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからアリ・ババは貧乏な娘をおかみさんにもらいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金持のおじょうさんをもらったカシムは、毎日ぶらぶら遊んでくらしていましたが、そのはんたいに、アリ・ババは毎日せっせと働かなくてはなりませんでした。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、アリ・ババが、いつものように森へ行って木を切っていますと、はるか向うの方に、まっ黒い砂けむりが、もうもうと立っているのが見えました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "」アリ・ババはふるえながら、三びきのろばをかくして、自分はそばの木にのぼりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリ・ババののぼった木の下まで来ると、どろぼうたちは、みんな馬からとびおりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリ・ババは木からおりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリ・ババは中へ入って行きました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけのものをあつめるには、まあ何年かかったことだろうと、アリ・ババは思いました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリ・ババは家へ帰って来ました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは金貨の袋を見て、大へん悲しそうな、またこわいような顔をして、アリ・ババに泣きつきました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとアリ・ババは落ちつきはらって、「安心おしよ。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、アリ・ババが袋からつかみ出す金貨を、「一｜枚、二枚」とかぞえはじめました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちアリ・ババが、ふと気がついたように顔を上げて、「そんなかぞえ方をするのはばかだね。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、どうしてアリ・ババの家でますがいるのか、ふしぎに思ったものですから、ますの底に少しばかりラード（ぶたの油）をぬって、かしてくれました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリ・ババのおかみさんは、ますをかりて、大いそぎで帰って来ました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
