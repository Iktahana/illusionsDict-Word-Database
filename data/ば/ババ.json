      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "行く途々に牛の糞の乾いたやつがあるたびに、それを拾つて口に入れようとするのには閉口したと、よく祖母は話してゐた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "合い憎のことには、私の場合、犬馬の労もなにも、興ざめの言葉で恐縮であるが、人糞の労、汗水流して、やっと書き上げた二百なにがしの頁であった。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりそのころの私は、さきにも鳥渡言って置いたように金魚の糞のような無意志の生活をしていたのであって、金魚が泳げば私もふらふらついて行くというような、そんなはかない状態で馬場とのつき合いをもつづけていたにちがいないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹の陰謀なんて糞くらえだ！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや随分乱暴な鼠の糞じゃ。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉の大木の下に床几を積み上げたるに落葉やゝ積りて鳥の糞の白き下には小笹生い茂りて土すべりがちなるなど雑鬧の中に幽趣なるはこの公園の特徴なるべし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原の草を縛り合わせて通りかかった人を躓かせたり、田圃道に小さな陥穽を作って人を蹈込ませたり、夏の闇の夜に路上の牛糞の上に蛍を載せておいたり、道端に芋の葉をかぶせた燈火を置いて臆病者を怖がらせたりと云ったような芸術にも長じていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが馬糞などと一緒に散らばっているのを平気で拾って喰うのであった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ御自身の高級な宿命に、糞尿を浴びせられたやうな氣がするらしい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとをただせば、さかなの糞だからね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、お前のたれた糞尿は、お前が持つて歸つたらいいだらう、といふ意味なのだらうか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお辨當箱には鼬の糞でまぶした蚯蚓のマカロニなんか入つてゐるのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つて追ひ、お爺さんは無言で立つて懷紙でその縁側の糞をていねいに拭き取る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるものはただ垢と、凡俗と、アジア風の生活ばかりです……僕はあまり糞眞面目な顏が、おそろしくもあれば嫌ひでもあります。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は糞眞面目な話を恐れます。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に依ると、あの花の馨は、糞ッ臭いから、いやだと言うようだが、幸いに私の嗅覚は、それほど過敏でない故か、ちっとも苦にならないどころか、臭いからして、私はこの花が好きだ、梅の匂いのように上品でないかも知れないが、土臭いのが堪まらなくいい。",
              "citation": {
                "source": "菜の花",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出て見ると月は高い、槍ヶ岳は大海から頭をのそりと出す烏帽子岩のようで、雪の白条は岩の上へ鴎が糞を落したようだ、自分は恍惚として、今山の巓に立っているのか、波の寄る渚を歩いているのかと、惑った、夜の自然は一切を平等にして、山とか海とかに仮現する異性を失わせる。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはかれらが腐肉や糞堆をその定住の楽土としているからであろう。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かな愚かな表情を、院長さんとその園芸家とどっちが頭がうごくだらうといった風の――えい糞考へても胸が悪くなる。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家畜の糞を丸めてボールを作り転がし歩く黄金虫がある。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが困った事にはそういう罪人をつかまえる為政者の方でもちゃんとそれを承知しているから、あらかじめ犬の糞を用意しておいて、すぐにそれを食わせ、そうしてすっかり毒を吐き出させてしまう。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではせっかくの毒も何の役にも立たなくて、結局犬の糞を食わされるだけが余計な事になる訳である。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらずこのような事が繰り返されていたとすれば、犬の糞の効力の及ばない場合が相当に多かったかもしれない。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次観念してシャアシャアと、Ｔ「今日も亦旦那の糞詰り見てえな面にぶつかりやしたね」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「それじゃ糞の役にも立つめえ」　さー左衛門驚いた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハヤミのオオケストラ、彼の人糞。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――醜婦奴、ガウンが百度ひらいたって、糞。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "將棋では何｜糞つと力み返つて遠慮なしに負かしたり負かされたりする事既に五六年にもならうか？",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い、歯糞のついた歯が、凋れた唇の間からのぞき、口臭が、喇叭状に拡がって、こっちの鼻にまで這入ってきた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、今にも凋んだ唇を曲げて、黄色い歯糞のついた歯を露出して泣きだしそうだった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
