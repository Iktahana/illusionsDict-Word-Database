    "definitions": [
      {
        "index": 1,
        "gloss": "explosion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――若し、今、こいつに火をつけたら、ダイナマイト見たいに、爆発するに決ってる。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その火山灰は西の二｜列か三列の石英粗面岩の火山が、やっとしずまった処ではありましたが、やっぱり時々｜噴火をやったり爆発をしたりしていましたので、そこから降って来たのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海へ下る九十九折のピンヘッド曲路では車体の傾く度に乗合の村嬢の一団からけたたましい嬌声が爆発した。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲の大戦が爆発して以来は却って世間一般特に実業者の側で痛切にこの必要を感ずるようになったと見え、公私各種の理化学的研究所が続々設立されるようになった。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば短時間の強い光源としてのアンダーソンの針金の電気爆発を使う代りに水銀のフィラメントの爆発を使ったり、また電扇の研究と聯関して気流の模様を写真するために懐炉灰の火の子を飛ばせるといったようなことも試みた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇〇年軍務局で爆発物調査委員会が設置されたとき、レーリーが委員長に選ばれた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わば遠からず爆発しようとする火山の活動のエネルギーがわずかに小噴気口の噴煙や微弱な局部地震となって現われていたようなものであった。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその器械の構造は勿論一切を極秘密にしているから分らぬが、とにかく磁力を利用したもので、これを載せた船の向かう処一定の距離にある沈設水雷をことごとく爆発して無効にするそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "直径六フィート、高さ六十フィートの鋼鉄製の大砲を作り、その中でアセチリンその他の瓦斯を爆発させ空気に劇動を起させる趣向だという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にナタリーの悲鳴が爆発して彼女の頬に紅色の液体がながれていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、嫉妬と憤怒が胸に爆発した。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じことは火山の爆発についても言われるであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると霧島つつじが二、三日の間に爆発的に咲き揃う。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙が綺麗な渦の環になってフワフワと上がって行く、すると高い所で弾が爆発して、それからがいわゆる花火の現象になるのである。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じくらいの時間間隔を置いて連続的に五回の爆発をやるのがいちばん多いようであった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この匂いを嗅ぐと、少年時代に遊び歩いた郷里の北山の夏の日の記憶が、一度に爆発的に甦って来るのを感じる。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とうとうこらえていたものが、爆発してしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を唸って、前方で爆発する。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女や、子供や、老人の叫喚が、逃げ場を失った家畜の鳴声に混って、家が倒れ、板が火に焦げる刺戟的な音響や、何かの爆発する轟音などの間から聞えてくる。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時、奥の方で、ハッパが連続的に爆発する物凄い音響が轟いた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッパが爆発したあと、彼等は、煙が大方出てしまうまで一時間ほど、ほかで待たなければならない。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸善の棚へ黄金色に輝く恐ろしい爆弾を仕掛けて来た奇怪な悪漢が私で、もう十分後にはあの丸善が美術の棚を中心として大爆発をするのだったらどんなにおもしろいだろう。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "記紀にはないが、天手力男命が、引き明けた岩戸を取って投げたのが、虚空はるかにけし飛んでそれが現在の戸隠山になったという話も、やはり火山爆発という現象を夢にも知らない人の国には到底成立しにくい説話である。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年時代に上記のごときおとぎ文学や小説戯曲に読みふけっているかたわらで、昆虫の標本を集めたり植物※葉を作ったり、ビールびんで水素を発生させ「歌う炎」を作ろうとして誤って爆発させたり、幻燈器械や電池を作りそこなったりしていたのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の留学生ばかりを弟子にして生活していたのが、大戦の爆発と共に留学生は皆引き上げるし、同時に日本人に対する市民の反感が高まった時に、なんらかのいやな経験をしたのではあるまいか、その後の生計をどうして立てて行ったろうか。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の数隊は極北の島々にそれぞれの観測所を設けて地磁気や気象の観測をしたり、あるいは火薬の爆発によって人工地震波を作りそれを地震計で観測した結果から氷盤の厚さを測定したり、あるいはまた近ごろ学界の問題になっている宇宙線に連関して空気の電離状態を研究したりすることになっている。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日に二条の鉄路の中央のひどいぬかるみの流れを蹴たててペンキ塗りの箱車を引いて行く二頭のやせ馬のあわれな姿や、それが時々爆発的に糞をする様子などを思い出すことはできる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある遠い国の炭鉱では鉱山主が爆発防止の設備を怠って充分にしていない。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで検閲はパスするが時々爆発が起こるというのである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三年まえ、罪なきものを殴り、蹴ちらかして、馬の如く巷を走り狂い、いまもなお、ときたま、余燼ばくはつして、とりかえしのつかぬことをしてしまうのである。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
