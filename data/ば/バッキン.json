        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仕上らないと罰金だ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "球がそれて土手の斜面に落ちると罰金だそうである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は営業上の事で警察へ呼ばれたが、出頭しなかったので五ポンドの罰金を取られた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、いつかスイスで某将軍の銅像を真赤に塗りつぶして捕えられ罰金を課せられた英国の学生の話を想い出した。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "饂飩屋も、お湯屋も、煙草屋も、商売の一寸した手落ちにケチをつけられて罰金沙汰にせられるのが怖い。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "没収されても罰金をとられても、又別の方法で持って来る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟派が曝露して罰金や牢屋ですむところを、硬派は命をかけなければならなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、それが、すったもんだの揚句、罰金をとられることになった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーイが断罪となっても、主人は、自国人同志が、同胞愛で、罰金か、拘留か、説諭くらいですんじまう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "罰金を取るちゅうだぞ。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠の岸で見つけた雲雀の卵を取って、罰金と仕末書を取られた者がある。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　米吉は、警察で、百円の罰金を云い渡された。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「百円の罰金がいるんなら、勝手に取ってくらッせえ！",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米吉は、勿論、罰金の百円はなかった。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂糖を入れたら罰金だらう。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかにこれは罰金です。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドモ又の命が買いもどせるくらいの罰金を出させなけりゃ、俺たちの腹の虫は納まらないや。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田　　俺たちは力を協せて、九頭竜という悪ブローカーおよび堂脇という似而非美術保護者の金嚢から能うかぎりの罰金を支払わせることを誓う。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「罰金取らへらんすぢゃ。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "税務署に見っけらへれば、罰金取らへる。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂糖を入れると酒になるので、罰金です。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こそこそ半分かうじのまゝの酒を三升つくって罰金を百円とられるよりは大びらでいゝ酒を七斗呑めよ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ罰金だけ納めて下さってそれでいゝやうな訳です。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とても罰金が出来さうにもありませんし、それに……。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "罰金のこと蕪木のこと、それは労役に服すると云ふ方法で略解決がつくと思はれたから、最初に片付けてしまつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とても罰金が出來さうにもありませんし、それに……。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "罰金のこと、蕪木のこと、それは勞役に服すると云ふ方法で略解決がつくと思はれたから、最初に片附けてしまつた。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "罰金やと安二郎は苦り切ってお君の答弁振りをのゝしったが、豹一はふと、故買の嫌疑ならお君よりむしろ安二郎に掛かるのが当然であったと疑い、調べてみると古物商の届けはお君の名儀になっていたのだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一万円の罰金刑に処せられた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
