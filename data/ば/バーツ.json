    "definitions": [
      {
        "index": 1,
        "gloss": "baht (currency of Thailand)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
