        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうでもいいけど、北尾の茶番のお相手なんかやっちまったクラッシャー・バンバン・ビガロよ！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラッシャー・バンバン・ビガロの死を悼み、合掌。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば箱の大きさから、電源の取付け位置、ねじの位置まで標準化されたために、板金屋がＰＣの箱をバンバン作って、世界中に売りまくっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際絵に書いたようなマッチ・ポンプだよな」とあきれながらでかけていくと、「世界ではバンバン売れていくＷｉｎｄｏｗｓが日本市場では今一売れないのはなぜだろう」と森高マニアの編集長が振ってきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちぇッ」「…………」「じれってえな」「…………」「何がわからねえんだろうね」「…………」「まちげえならまちげえ、犯人なら犯人と、ふにおちねえことがあるなら、バンバンと締めあげてみりゃらちがあくじゃござんせんか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンバン手が叩かれた。",
              "citation": {
                "source": "反逆",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの暫くそうやっておくと、おさやはすぐ丸い棒をふりあげて、しぶきが顔にはねかかるのをかまわず力一杯バンバン、バンバンたたき、もう一つかえしてこっちを叩きつけ、もうそれですんだことにして、お縫にゆすがせる。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさやは上気した顔でせっかちにバンバンやりながら、「大きいもんはこれが一番ええ。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸な男が若い二人に同情して、よくばりの商人（恋人ペーチャの親爺）をバンバンいきなりトタンのなまこ板をふりまわしておどしつけ、とり上げた金を、おば・女地主にやったのを、又おばをおどしつけ（それのピストルのつかいかたが又極めて無邪気で、ノンセンスだ）金をとりあげて二人を一緒にしてやる。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の教師　　バンバンザアイ。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女一同　　バンバンザアイ。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに因果と、夕陽で味方がギラギラとまぶしい最中に、その夕陽を背負った敵の方から、バンバン大砲を打ち込むんだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほしがりません勝つまでは、一億一心バンバンザイとね！",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の家で畳干してバンバン叩いています、いかにもゴミの立つ音です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう畳バンバンは駄目で（人足の都合で）明日になりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日の明方には、もうバカンバンバンには辟易しているので恐縮していたら、そうでない方だったので勇気百倍、まして北風で向きがよかった上、北方上手に投弾されなかったので大助りいたしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のキャプション付きの図（fig55990_746.png、横224×縦200）入る］図‐746　外国人は、何故日本人が、彼等が鳥に向ってバンバン発砲して廻ることに反対するのか、不思議に思う。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かい粉雪が防水帽をバンバン打ちつける音は、小さな弾丸を連続発射するかのよう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは何かな」二　突然バンバンという音がして、まるで千｜丁のライフルを舞踏会場で発砲したかのよう。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            }
          ]
        }
