          "literary": [
            {
              "text": "月夜にバラライカひくんだな。",
              "citation": {
                "source": "よい家",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手なバラライカや胡弓の音を聞くたんびに耳を押えてウンウン云っていたのですが……そうして一日も早く両親の処へ帰りたい……上等のグランドピアノを思い切って弾いてみたいと、そればかり考え続けていたのですが……。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時代に空想したやうに一輛の馬車に、バイブル一卷、バラライカ一挺、愛人と共に荒野を漂ふジプシーの旅に任しゆく氣輕さは、いまはあまりに寂しい空想である。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りすがりの窓から内部の板壁に貼ってある専門地図、レーニンの肖像、数冊の本、バラライカなどが見えた。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで主として吹奏楽、それでなければギターやバラライカを主にしたもの、それで一週間に何度と仕事のあとそこへ行って研究する。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓、笛、トロンボーン、ギター、バラライカ、などが片づけてある。",
              "citation": {
                "source": "ソヴェト同盟の音楽サークルの話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂ロシア気質というものは、イリフ、ペトロフ両人の極めてダイナミックな社会精神と感情の活動を一貫してどこにも古風なバラライカの響となってつたわってはいない。",
              "citation": {
                "source": "音楽の民族性と諷刺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モルダヴィヤ南瓜というやつは、瓢箪とも呼ばれて、ロシアではこれでバラライカを拵らえる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "二弦の手軽なバラライカで、その音も床しい爪弾を聴きに集まる、胸や首筋の白い娘たちに※せをしたり、口笛を吹いたりする、あの二十歳前後のおしゃれで剽軽な若者たちの装飾でもあり、慰めでもある。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラライカ　露西亜の農民間に愛用される楽器の一種で、共鳴胴の表面が三角形をなす、マンドリンに類似した三絃琴。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまた、ひどくお似合いでないお人もありましてね、型どおりの恰好におぐしを作って、前髪をつまんで立てたり鬢の毛を揃えたりすると、お顔のぜんたいがまるでお百姓のバラライカの絃が切れたみたいな様子になることもありました。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの漫画には、例の黒いつば広帽をかぶってルバーシカを着たゴーリキイがバラライカを弾きながら歌っている記念像の台座のぐるりを、三人のロシアの浮浪人が輪おどりしていて、その台座の石には「マクシム・ゴーリキイに。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤坊もそれより大きい子供たちもここではロシアのバラライカを逆に立てたような顔付をしていた。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ふいにあたりがむやみに騒々しくなって、赤や青のシャツの上へ百姓｜外套をひっかけ、ぐでんぐでんに酔いつぶれた大きな百姓が、酒場の中からわめいたり、うたったり、バラライカを鳴らしたりしながら、どやどやと出てきた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラライカやギタルラを伴奏しながらスラヴの唄をうたう口から、安来節や鴨緑江節を寄席芸人に劣らぬ節廻しで聞かせるほど、それほど悪達者であろうとは！",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
