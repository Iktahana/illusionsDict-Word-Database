    "definitions": [
      {
        "index": 1,
        "gloss": "absurd",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とかく識つたかぶりは、このやうな馬鹿らしい結果に終る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不調和な、馬鹿らしいものになり勝でございますわ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、たとへば「思はぬ大利あり」とか「物事に蹉跌あり、西方凶」などといふ、考へれば馬鹿らしい暗示が卓子を圍む氣持を變に動かすこと我ながらをかしいくらゐだ。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丈夫でいるのこそ、クソ馬鹿らしい！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又徴兵に取られて馬鹿らしいが、仕様がない位いにしか思っていない人々もあるだろう。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿らしい、見当ちがいだ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、十三年も勤続している彼の身の上にもやがてこういうことがやって来るのではないかと、一寸馬鹿らしい気がした。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗に、三角だの四角だのいう馬鹿らしい形容の恋の状態をも考慮にいれて、そのように記したのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢田先生は、土曜日毎にお見えになり、私の勉強室でひそひそ、なんとも馬鹿らしい事ばかりおっしゃるので、私は、いやでなりませんでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はら／＼して居る中に、その場合々々に応じて、一番危険な、一番破壊的な、一番馬鹿らしい仕打ちを夢中でして退けて、後になつてから本当に臍を噛みたいやうなたまらない後悔に襲はれるのだ。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまだ何か云ふ積りであつたが総てが馬鹿らしいので、そのまゝ口をつぐんでしまつた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さんは、悲しいとき、口惜しいとき、欲しいとき、馬鹿らしいことをしたとき、澄み切った大空や、漫々たる海上を眺めたことがありませんか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と例の頓狂聲『貴方に料理方だなんて、其樣な馬鹿らしい事が出來ますか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その志よみすべし、（しかし馬鹿らしい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿らしいやおまへんか、野瀬の身代は大将一人で作ったんやおまへん、御寮さんの働きで半分は作られたんです、女房が一人で寝て亭主が外で泊って来るなんて、一体夫婦といえますかと言われて一々思い当る気がした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな馬鹿らしいこと……」「イイエ……おかあさん……あれはおとうさまのお顔よ。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いかけた時に、おじさんは、「馬鹿らしい。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿らしい事であったが、しかし、あれも今ではなつかしい思い出になった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ学校から疲れて帰り、さあ、けさ冷しておいたミルクでも飲みましょう、と汗ばんだ上衣を脱いで卓のうえに置いた、そのとき、あの無智な馬鹿らしい手紙が、その卓のうえに白くひっそり載っているのを見つけたのだ。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつの馬鹿らしい機械仕掛で、夢中になぐられ、なぐられて居る。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そしてそれは馬鹿らしいことであると思つたのであります。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間性の、あらゆる洗練を経た後のあわれさ、素朴さ、切実さ――それが馬鹿らしい程小児性じみて而も無性格に表現されている巴里。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく懐しいような、馬鹿らしいような、煩わしいような恥らわしい自己嫌悪にさえかかって、そのまま手紙を二三日放って置いた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にも何となく甘苦い哀愁が抽き出されて、ふとそれがいつか知らぬ間に海の上を渡っている若い店員にふらふらと寄って行きそうなのに気がつくと、「なにを馬鹿らしい。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉は斯ういう馬鹿らしいほど無邪気な夫人に今更あきれて、やっぱり憎み切れない女だと思った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり、ひろがると、馬鹿らしいと笑っても居られなくなるからね。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり馬鹿らしい話なので、つい、ふざけ過ぎてしまいました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に五十円出せと言うのですけれども、ばからしい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不思議な宿の大きい葛籠でも脊負つて來て下さつたら、それを證據に、私だつて本當にしないものでもないが、そんな稻の穗などを持つて來て、そのお人形さんの簪だなんて、よくもまあそのやうな、ばからしい出鱈目が言へたもんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばからしいが、行つて來ませう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
