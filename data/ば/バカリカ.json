        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本人ばなれする程鼻は高くなったが、眼が釣り上って、容色を増した感が少しも起らなかった許りか、鏡にうつしてみて、まるで自分でもとっつき難い顔になった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はヘーゲルの様な純粋の哲学者を軍人政治家と結び付ける許りか、其思想が彼等軍人政治家の実行に深い関係を有してゐるのだといふ事を説明しやうと試みた。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんとりむしと言はれずに首席になることは困難であつたが、私はそのやうな嘲りを受けなかつた許りか、級友を手ならす術まで心得てゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんとりむしと言はれずに首席となることは困難であつたが、私はそのやうな嘲りを受けなかつた許りか、級友を手ならす術まで心得てゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃、倹約家の葛岡も、きょうは何とも言わない許りか、自分の使い残した僅かの所持金まで全部私に手渡したのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者上りの彼女は純白のドレスの胸にピンクの薔薇をつけて、頭には真紅のターバン、真黒のレースの手袋をはめている許りか、四角い玉の色眼鏡を掛けているではないか。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも桂月氏はその桜の花を決して明るく描かなかつた許りか、陰気にさへも描いてゐたことは、東洋の詩と夢の国としての『日本』の現実的な是正として成功作だといはなければなるまい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の抒情詩人としての小倉氏は、姓名もかはつた許りか画題上の相貌を変へて立ち窺はれたといふことは、相当に驚異的な変り方であらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して明朗でない許りか、圧迫感をもつてゐるのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画の雪舟の水墨のもつリアリテはセザンヌのもつリアリテと比べて何の遜色がないといへる許りか、優つてゐても劣つてはゐないのであるし、現実主義者としての写楽の高さは、単なる観念的な現実主義者ではなく、芸術に於いて言はれてゐるところの『表現力』を併つたところの写実性であるところに写楽の偉さがあるだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖れて居ない許りか、好んで敗けず劣らず無駄口を叩く。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「郷里へ歸つてゐたのかね、」と僕が訊ねても君は僕の顏を見ない許りか返事もしなかつた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学は直接に思想を取扱ふものだけに、財産として自分のうちの土蔵にしまつておく事が出来ない許りか、どうかするとそれを弄んでゐる者の手を傷けるからである。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまきは、狂気のようになって津田を罵倒した許りか、娘の上に、神も怒らすほどの証を立てた。",
              "citation": {
                "source": "光のない朝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し貴方が其※お心持から又この暗い世界へ私と同じ様に身を沈めてお了ひになつたらそしたら貴方が死ぬ許りか私も死ぬのですもの。",
              "citation": {
                "source": "獄中の女より男に",
                "author": "原田皐月",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋も深く湖畔の風が冷い、山には雲が走る、ただに山許りかは、人の心も雲で一杯だ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれでは面白くないので、恋に結び付け、自分達の恋は世間の批難を買つた許りか、天変まで起つて一所に居てはいけないと諭してゐる、そこでやむを得ず泣く泣く海を渡つて祖国を離れ私から遠ざかつたのであると斯う説明したわけであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、変則な強直をしている点に、第一説明が付きますし、何より犯人が、その無意識状態を利用した許りか、日頃不思議な法術の種になっている｜悪魔の爪（中世紀の所謂魔女に現われた宗教性ヒステリー現象）を、却って逆用した事がお判りになりましょう。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、堂の内外には何等異常がない許りか、試みに頭上の節穴から光線を落してみても、髪毛の漆が光るに過ぎない。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而うして、其れは決して不可能で無い許りか、自分は欧洲へ来て見て、初めて日本の女の美が世界に出して優勝の位地を占め得ることの有望な事を知つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分達は幾つかの美術館を訪うて、ラフワエル、チチアン、ベラスケツ、ムリリヨオ、リユウバンス、※ン・ダイク等外国の傑作の多く集められて居るのに益を受けた許りか、レンバツハ、シユインド、フオオエバツハ、ベツクリン等｜独逸近代の大家の名品に初めて接する事の出来たのを嬉しいと思つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "而うして、其れは決して不可能で無い許りか、自分は歐洲へ來て見て、初めて日本の女の美が世界に出して優勝の位地を占め得ることの有望な事を知った。",
              "citation": {
                "source": "巴里の旅窓より",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "許りか、格子先にはさや／＼と風に戦ぐ孟宗竹が五、六本、その根方には毒だみが青白く花咲いてさへゐやう。",
              "citation": {
                "source": "吉原百人斬",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時携帯していた地図は、例の輯製二十万分の一の図で、登山には全く役に立たないことが多い許りか、時には大に迷惑することがあったにも拘らず、他に良地図がないから止むなく用いていたのである。",
              "citation": {
                "source": "北岳と朝日岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷から吹き上げる風は冷く且強いにも拘らず、絶頂は不思議に風が当らない許りか、風呂場へ這入った時のように生温くさえ感じた。",
              "citation": {
                "source": "秩父宮殿下に侍して槍ヶ岳へ",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪許りかと思つたら其の蓆の切も一緒に縛られてあつたのである。",
              "citation": {
                "source": "落葉降る下にて",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天墨絨の服」も秋田雨雀氏など率先して着てゐられたらうそのころの青春的な芸術家の象徴で、エプロンの女給たちにはいか許りか憧憬の的であつたらう。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま斧鉞を加へられたと思ふ個所も、決して原作の詩情を失はないばかりか、却つて原作よりも善くなつて居る。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "死なないばかりか、少し太った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の実業家らしいのですが、財産やら地位やらを一言も広告しないばかりか、名誉の家だって事さえ素振りにあらわさず、つつましく涼しく笑って暮しているのですからね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
