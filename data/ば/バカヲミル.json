[
  {
    "uuid": "93d35860-15c3-5378-ae7d-674b1f73d04a",
    "entry": "馬鹿を見る",
    "reading": {
      "primary": "ばかをみる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
