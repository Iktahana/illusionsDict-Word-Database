    "definitions": [
      {
        "index": 1,
        "gloss": "outskirts (of a town)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奈良という侘しい古都に、薄暗い古道具屋の並んだ場末を考えるだけで寂しいのに、秋の薄暮の灯ともし頃、宵の燈火の黄色い光をイメージすると、一層情趣が侘しくなり、心の古い故郷に思慕する、或る種の切ないノスタルジアを感じさせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風や酒肆に詩うたふ漁者樵者　街道筋の居酒屋などに見る、場末風景の侘しげな秋思である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲店　醉月坂を登らんとして渇きに耐へず蹌踉として醉月の扉を開けば狼藉たる店の中より破れしレコードは鳴り響き場末の煤ぼけたる電氣の影に貧しき酒瓶の列を立てたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲店　醉月　　醉月の如き珈琲店は、行くところの侘しき場末に實在すべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しながら「亡び行く生物」の中に、この菜の花が、次第に加わるのではなかろうか、それとも都落ちの仲間に入って、次第に我等の付近から、影を隠してしまうのではあるまいか、場末の旅籠屋などで、食膳の漬け菜の中から、菜の花の蕾が交って出ることがあるが、偶然だけに、どんなにか私を悦ばすことだろう。",
              "citation": {
                "source": "菜の花",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ふに「場末の新開町」といふ言葉は今の東京市の殆んど全部に當嵌まる言葉である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場末の町へまでも荒して歩くためには一体何千キロの毒薬、何万キロの爆弾が入るであろうか、そういう目の子勘定だけからでも自分にはその話は信ぜられなかった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日では場末の荒物屋芋屋でもこれを使っている。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやり唄は場末の家の建壊しの跡などへ手風琴鳴しを一人連れて風の吹き曝しに向って唄い出す。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の売出しごろには舞台の背景に巴里の場末の魔窟を使い相手役はジゴロ（パリの遊び女の情人）に扮した俳優を使い彼女自身も赤い肩巻に格子縞の Basque という私窩子型通りの服装をして彼女の唄の内容を芝居がかりで補ったものだが、このごろは小唄専門のルウロップ館あたりへ出る場合にはその必要は無い。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い場末の横町がそこに哀しくなすり出される。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいぼれとただ呼ばれる老人は鋸を曲げながら弾いていろいろなメロディを出す一つの芸を渡世として場末のキャフェを廻っていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者の実例は場末の玩具屋の店頭で見られる安絵本のポンチなどがそれである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者がこの器械の事を近着の科学雑誌で読んだ後、場末の町を散歩していたら、とある米屋の店先で小僧がズックの袋に豆かなにか入れたのを一生懸命汗を垂らして振っていた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧水氏はいつも好んで、場末の汚ない繩のれんで酒を飮んだ。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで或る街の深夜に、ぐでぐでに醉つて死場所を探してゐる不幸な紳士が、場末の薄暗い地下室で、チャップリンの扮してゐる乞食ルンペンと邂逅する。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまた夜になると、紳士は大酒を飮んでヘベレケになり、場末の暗い街々を徘徊して、再度また昨夜の乞食ルンペンに邂逅する。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが都会の新文化の発展に追除けられ追除けられして竪川筋に移り、小名木川筋に移り、場末の横堀に移った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達の小屋はセエヌ左岸のアルマの橋を渡ったところに、日本画の万灯に飾られて、富士山や田園の書割にかこまれて、賑かにメリンスの友禅の魅力を場末の巴里人に挨拶していたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "開幕前妾がひどく打萎れているのを見て、一座の日本女優の松子がそれと察して、ジョージ・佐野が、今日は珍らしくはしゃいで好きな場末の流行歌などを歌ってふざけていたなどと、妾に告げて呉れました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ二｜臺の三｜等車、次に二｜等車が一｜臺、此三｜臺が一｜列になつてゴロ／＼と停車場を出て、暫時くは小田原の場末の家立の間を上には人が押し下には車が走り、走る時は喇叭を吹いて進んだ。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら新宿をそばに控えているからといって、今どきの場末の稽古師匠が毎日｜店屋物を取ったり、刺身を食ったり、そんなに贅沢ができる筈がねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、俺の町の、場末の煤煙だらけの家に残っているおッ母アも、手袋を縫って、やっと、おまんまを食っているんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アムステルダアム　測候所を尋ねて場末の堀河に沿って歩いて行った。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "門番のおばさんでも、気の変な老紳士でも、メーゾン・レオンの亭主でも、悪漢とその手下でも、また町のオーケストラでも、やっぱり縦から見ても横から見てもパリの場末のそれらのタイプである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一編の最後に光の消えたスクリーンの暗やみの中から響く、甘い美しい音楽は、なんとなく「新内の流し」とでもいったような、パリの場末の宵やみを思わせるものである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに「場末の新開町」という言葉は今の東京市のほとんど全部に当てはまる言葉である。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば場末の洋食屋で食わされるキャベツ巻きのようにプンとするものを感じる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……まだ胎内に居ります内に、唯今の場末へ引込みましてな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……橋詰から打向ふ眞直な前途は、土塀の續いた場末の屋敷町で、門の軒もまばらだけれども、其でも兩側は家續き……　で、町は便なく、すうと月夜に空へ浮く。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
