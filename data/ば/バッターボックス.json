          "literary": [
            {
              "text": "テレビのプロ野球中継を見ているとき、バッターボックスに立った選手に心の中で「クソ」と不快の舌打ちをくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、ファーストバッターとなって、バッターボックスに立っているような、極めて勇しい自分の姿を頭に描いてみたりする。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球場のバッターボックスからフェンスまでの半分くらいです。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
