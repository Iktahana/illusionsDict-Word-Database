    "definitions": [
      {
        "index": 1,
        "gloss": "(verbal) abuse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
