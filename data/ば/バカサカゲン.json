[
  {
    "uuid": "d4676194-44c8-5abe-8c3b-3d89e73d9e49",
    "entry": "馬鹿さ加減",
    "reading": {
      "primary": "ばかさかげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
