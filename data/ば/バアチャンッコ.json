        "examples": {
          "standard": [
            {
              "text": "その女の子は、いつだって「ばあちゃん、ばあちゃん」と、祖母の後を追いかけるばあちゃんっ子だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "両親がいても、彼女はばあちゃんっ子で、祖母にかまってもらいたがる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「僕、ばあちゃんっ子だから、おばあちゃんの話を聞くのが好きなんだ」と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
