[
  {
    "uuid": "9a9ca859-b273-50aa-9c71-fda7cf307acf",
    "entry": "驀進",
    "reading": {
      "primary": "ばくしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
