  {
    "uuid": "b6a45923-4d37-52a3-bfcb-6242b7f86d72",
    "entry": "爆心",
    "reading": {
      "primary": "ばくしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
