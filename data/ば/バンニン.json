      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "guard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "競犬場番人、黒奴のアランがノラの男妾だという評判が街にひろがった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」先生、この時、チョイと目を転じて、メートルグラスの番人を見た、これはおかわりの合図。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "番人小屋もなかった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつ、ぬしとの番人にもならねえんだぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、樫の棒を持った番人が銅羅声をあげて、掛小屋の中から走り出て来る。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、番人が現場へやって来る頃には、僕等はちゃんと、五六本の松茸を手籠にむしり取って、小笹が生いしげった、暗い繁みや、太い黒松のかげに、息をひそめてかくれていた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」番人は樫の棒で、青苔のついた石を叩いた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　番人は、トシエの親爺に日給十八銭で、松茸の時期だけ傭われていた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "番人が、番人小屋の方へ行ってしまうと、僕等は、どこからか、一人ずつヒョッコリと現われて来た。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また番人の子供やばあさんもほんとうに絵のようで愉快でした。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーテの家には制服を着けた立派な番人が数人いましたが、シラーのほうには猫背の女がただ一人番していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の廊下の扉のわきに「宝蔵見物のかたはここで番人をお待ちくだされたし」という張り札がしてある。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりこの庭の番人になるんだ」「だけど、お友達なんかなくって淋しかないの」「うん、あるよ、時々外から来るよ。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが一番人生で、値打ちがあると信じたことに向っては、万事を放擲して目的に取り組む。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "追出しの番人が何やらものを鳴らして歩く。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子ども等はその番人の派手で古風な制服に魅着してついて歩く。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈そうな上院の正門の番人に眺められながらかすかな傾斜に地取して名料理店フォワイヨが角にある。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分は一人娘である以上、いずれは平凡な婿を取って、一生この餓鬼窟の女番人にならなければなるまい。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土手へ出ちゃ、何時までもこうしていますのに、唯いては、谷戸口の番人のようでおかしゅうござんすから、いつかッからはじめたんですわ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくりして振りかえって見ましたらあの番人のおじいさんが心配そうに白い眉を寄せて私の肩に手を置いて立っているのです。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その番人のおじいさんが云いました。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　番人のおじいさんはガラスの前に進みました。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　番人のおじいさんは私の涙を拭いて呉れてそれから両手をせなかで組んでことりことり向うへ見まわって行きました。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもみんなが入口で何か番人に渡すらしいのだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "番人は『ええ、いらっしゃい。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "番人幾たびも見巡りしが、何事も無くて夜は明けぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、宝物庫には番人がいて、経蔵には、年紀の少い出家が、火の気もなしに一人｜経机に対っていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ、薬師堂に詣でて、それから宝物庫を一巡すると、ここの番人のお小僧が鍵を手にして、一条、道を隔てた丘の上に導く。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピクルスは　いま　かりばの　ばんにんを　しています。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
