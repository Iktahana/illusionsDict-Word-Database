[
  {
    "uuid": "f00d4dab-2280-54ad-9d76-bd292655d222",
    "entry": "番人",
    "reading": {
      "primary": "ばんにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
