        "gloss": "airing of clothes, hanging scrolls, etc. (to prevent damage from insects and mould)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "土用の明けた翌日からいつも武田家では曝涼をした。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中曲輪三分の一が曝涼の場所にあてられた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日に渡った曝涼も十八日にめでたく終え家中一同館の中で信玄から酒肴を賜わった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
