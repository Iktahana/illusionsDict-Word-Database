    },
    "definitions": [
      {
        "index": 1,
        "gloss": "staff",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここに細川方の幕僚で丹波を領している細川｜下野守教春も、その数に洩れず、急いで国元へ引返して行きました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラフアルガルの海戰で重傷を負つたネルソンが、軍醫や部下の幕僚たちに圍まれながら、死にのぞんで言つた言葉は有名である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラフアルガルの海戦で重傷を負つたネルソンが、軍医や部下の幕僚たちに囲まれながら、死にのぞんで言つた言葉は有名である。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎兵を主力とする匈奴に向かって、一隊の騎馬兵をも連れずに歩兵ばかり（馬に跨がる者は、陵とその幕僚数人にすぎなかった、）で奥地深く侵入することからして、無謀の極みというほかはない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞いて、校尉韓延年以下漢軍の幕僚たちの頭に、あるいは助かるかもしれぬぞという希望のようなものが微かに湧いた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが一兵卒の言った言葉ゆえ、それほど信頼できるとは思わなかったが、それでも幕僚一同｜些かホッとしたことは争えなかった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友仁はその馬前へ往って策を献じたところが、それが月沙の意に称うて、脱公の幕僚に推薦してくれた。",
              "citation": {
                "source": "富貴発跡司志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薨ずるや、幕僚相議して、喪を祕せむとせしが、酒井忠勝の言によりて、漸く之を公けにせしを以て、その事情を推するを得べし。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報は来ているが、海軍省が伏せてるから号外を出せないんだ、」とさも大本営か海軍省の幕僚でもあるような得意な顔をして、「昨夜はマンジリともしなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ淡島屋の身代は先代が作ったので、椿岳は天下の伊藤八兵衛の幕僚であっても、身代を作るよりは減らす方が上手で、養家の身代を少しも伸ばさなかったから、こういう破目となると自然淡島屋を遠ざかるのが当然であって、維新後は互に往来していても家族的関係は段々と薄らいで来た。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『読売新聞』を牙城とした紅葉は堀紫山を幕僚と頼んで三面及び文芸欄は思うままに主宰した。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗艦の上では幕僚会議が開かれた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦長以下幕僚たちはいずれも見えない空を仰ぎ、暗の空にとびだしていった勇士の前途に幸多かれと祈った。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行島は設計以上の出来ばえじゃ」　飛行島建設団首脳部は、いつの間にやら、大航空母艦飛行島司令官および幕僚となっていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は「鋼鉄の宮殿」に幕僚をよびあつめ、警戒を厳重にして、会議に余念がなかった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二人の巨漢は、今なお鋼鉄の宮殿の中において、リット提督やその幕僚と向きあっている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "東部防衛司令官香取中将は作戦室の正面に厳然と席をしめ、鹿島参謀長以下、幕僚を大｜卓子のまわりにグルリと集め、秘策をねっていた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "元帥の諧謔10・29（夕）　元帥ジヨツフルが、仏蘭西の軍事委員として幕僚を引連れて米国へ渡つた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "モルトケ元帥は幕僚長で将帥ではない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大本営案については、全国務大臣が幕僚として参加するという形の軍事内政の両面に渡る案さえ一頃有力であった。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "主将は変な、イラン風とツラン風俗の混った装をしているそうだが、アフラシャブの幕僚だったらしい男が二人以上ついているという話だ。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後宮総参謀長その他の幕僚も御一緒であったが、畑大将は私が杭州で風邪をひき、二日ばかり微熱のために静養したのを土地の新聞か何かで御存じであったのであろう、「杭州でお悪かったそうだが、いかがです」という風にたずねられた。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名なる顏之推の子の顏愍楚は、朱粲の軍に囚はれてその幕僚となつたが、後に軍中食に乏しくなると、彼の一家を擧げて朱粲に嗜酒之人。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの時彼等の間へ、軍司令官のＮ将軍が、何人かの幕僚を従えながら、厳然と歩いて来たからだった。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時突然次の部屋から、軍司令官を先頭に、軍司令部の幕僚や、旅団長などがはいって来た。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝典を、とどこおりなく終えたアカグマ最高行政官の大総督スターベア公爵は、幕僚委員と、招待しておいた各国使臣とに取り囲まれて、子供のように、はしゃいでいた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、幕僚会議の準備ができましたから、どうぞ」「おお、そうか」　戦争長官ラヂウム元帥は、自分の机のうえに足をあげて、動物漫画の本を読んでいたが、ここで、残念そうに、ぱたりと頁を閉じた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、女史からの無電をきいていた者は、長官をはじめとし、遠方で聞いていた幕僚の悉くが、その怪電気にあたって即死してしまったのだ」「女史からの電波に、殺人電気を載せるなんて、アカグマ国の奴等は、人か鬼かですねえ」「人か鬼かといっても、今更仕方がない。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、今重態のリウサン参謀が、もし一命を助かれば、何もかも分るだろう」　只一人の生残者リウサン参謀の快癒を待つまでもなく、怪電気は、太青洋の空を越えて、一瞬間に、ラヂウム元帥と、十数名の優秀なる幕僚たちを、殺害してしまったのである。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
