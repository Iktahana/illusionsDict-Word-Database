[
  {
    "uuid": "f13f6d67-cd32-5cf1-a49a-64169f2d1a28",
    "entry": "バンド",
    "reading": {
      "primary": "バンド",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
