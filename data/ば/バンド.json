    },
    "definitions": [
      {
        "index": 1,
        "gloss": "band (group of musicians)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アイスクリーム　帝劇にバンドマン歌劇が來た時、二階も棧敷も、着飾つた西洋人で一杯だつた。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮舟のようにネオンサインにブルウスの曲目があらわれると、ジャズ・バンドが演奏を始めた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャズ・バンドが開演された。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャズ・バンド、マルセル・シュオブに似たセロ弾き、グロテスクな洋服師思い出すボンベイの過去、いまではロシアで苦心｜惨憺アンナ・ニコロを祝福して、私は最期迄知ってしまう。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときによってジャズ・バンドがビビの音楽をやっているとき、死海の水に映って正気を失った士官に貴女が抱かれて、独逸仕込の接吻の洪水のなかで、彼奴がロメオとジュリエットの名台詞を彼がネロのようにそりかえって早口で喋舌るときは全く貴女を薄倖の踊子だとさえ思ったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の踊場のジャズ・バンドが気狂のように太鼓をたたいた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主頭のロシア人のジャズ・バンドが演奏を始めたのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草はレッド・バンドを喫い、酒はラム酒、とくにネグリッタラムにてつくるバカーデ・カクテールを愛飲する。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもバンドのとれたよごれた鼠色のフェルト帽を目深に冠っていて、誰も彼の頭の頂上に髪があるかないかを確かめたものはないという話であった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "着のみ着のまゝの彼等の服装は、もう着破って、バンド一条さえ残っていなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉桂の根を束ねて赤い紙のバンドで巻いたものがあった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その左に小さな演壇、右手にオーケストラバンド、指揮者と楽手二名だけ見える。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから教会の方で、賑やかなバンドが始まりました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スナイダーは、自分のバンド（尤もその半数は、みんなビジテリアンだったのです、）を、そっくりつれてやはり一昨日、ここへ着いたのだそうです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーチになった祭壇のすぐ下には、スナイダーを楽長とするオーケストラバンドが、半円陣を採り、その左には唱歌隊の席がありました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが祭壇の下オーケストラバンドの右側に、「異教徒席」「異派席」という二つの陶製の標札が出て、どちらにも二十人ばかりの礼装をした人たちが座って居りました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラストのバンドが始まったのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、バンドが一曲を奏した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがすむと、純白の背広の胸に、赤いバラの造花をつけた望月三郎がほのかに薄化粧をしてバンドの前に現れた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンドをしていないので、胸のふくらみはたるんだ柔さだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヤヅバンドの楽隊なども、文壇でいちばん先にかつぎ出したのは僕だらう。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――したがって日本人に最も接近させられる――であるけれども、彼等の極端なるジャズバンドの音楽でさえ、日本俗謡の八木節や安来節の類に比し、尚｜遙かに貴族感的で、どこかに＊シルクハットや燕尾服を着たところの、儀礼正しき紳士道を聯想させる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面の石段を登ると、細いバンドのように閂のついた木扉が両方に開いて、前房は薄暗い。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するともう、森医院の徳一君が、ズボンのバンドをゆるめはじめた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれが真珠、いずれが豚、つくづく主客てんとうして、今は、やけくそ、お嫁入り当時の髪飾り、かの白痴にちかき情人の写真しのばせ在りしロケットさえも、バンドの金具のはて迄。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とＮ君は突き放すやうな口調で言つて、ズボンのバンドをしめ上げ、「僕たちだつて、なほしたんぢやないか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※高等女学校のスチユデント、　腰にはバンドの輝きて、　右手に持つはテキストブツク、　左手にシルクアンブレラア、　髪にはバツタアフライ、ホワイトリボン……」　自分は亦此処にも日本らしいからぬメロデイを聞いておやおやと思つたのある。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその空地の真中に、自分の締めていたバンドを外ずすと、縦一すじに置きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
