[
  {
    "uuid": "1d9fc17a-53fc-5a59-b994-728e9f13567d",
    "entry": "莫大",
    "reading": {
      "primary": "ばくだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
