        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "泰松寺の老師が、五六人の伴僧を随へて、しづ／＼棺前に進み寄つた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、東妙和尚が伴僧を連れて来て、地蔵様の前で地蔵経を読んでくれました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐうしろに右頬を斬られ大きなガーゼをあてて、ばんそうこうで十字にとめた田口巡査がついていく。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ゆびの　あちこちに　ばんそうこうを　はっていると　ともだちが　ふたりして　ばんごはんに　やってきました。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
