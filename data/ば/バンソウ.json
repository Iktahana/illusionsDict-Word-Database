    "definitions": [
      {
        "index": 1,
        "gloss": "priests assisting at a Buddhist service",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
