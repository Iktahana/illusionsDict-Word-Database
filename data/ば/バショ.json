    "definitions": [
      {
        "index": 1,
        "gloss": "place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがて最初に目に入つた玉屋に這入ると、部屋は明るくガランとしてゐて、温室のやうだつた、客の腰掛場になつてゐる、畳二枚を縦に並べた場所の、その中程に置かれた火鉢には其処の主人が如何にも睡げによつかゝつてをり、お主婦さんも割烹着を着たまゝ火鉢で手をぬくめてゐた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり一口にいえば、今の日本の若い娘たちが、最も退屈を感じて『詰まンないの』というような場所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが最後の死場所である。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と緒方氏とは、ほんの二三度話合っただけの間柄ではあるが、よい小説家を、懸命に努力した人間を、よほどの不幸の場所に置いたまま、そのまま死なせてしまったという事実に就いて、かなりの苦痛を感じている。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所は、小坂氏のお宅の近くの或る支那料理屋。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りにその要求の満足される場所が生活の方に転移するとしても、転移したら転移したとしての詩心の表現物、即ち詩は要求されるのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にまた老年が迫って来ては、心の孤独のやり場所もないであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに場所も平地であるから、雲霧とか山霧とかいふ温泉特有の情趣がなく、すべて感じが乾燥して居る。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "順つてそれが周囲に対して特異な気分を反映するほど、さうした場所の印象と魅惑を深くする。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに好い加減古びてゐるのと場所柄とで、何となく物寂びた雅致を帯びて、静かな廃屋といつたやうな情趣がある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山谷堀に上がれば雨はら／＼と降り来るも場所柄なれば面白き心地もせらる。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しい事には歳が歳であったから見もし聞きもした場所も事実も、二昔も程遠き今日からふりかえって考えてみると夢のような取り止めも付かぬ切々が、かすかな記憶の糸につながれて、廻り燈籠のように出て来るばかりで。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰省してこの濠のあったはずの場所を歩いてみても一向に想い出せないような昔の幻影が、かえって遠く離れた現在のここでの追憶の中にありありと浮んで来るのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ、繪本の畫伯もつい、（蓬莱も龍宮も、同じ樣な場所なんだから）浦島さんの案内役も、この石龜に違ひないと思ひ込むのも無理のない事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、おいでになるわけのない場所に出現したのが、不思議さ、ただの海龜ではあるまい、と言つて澄ます事にしよう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだけの煙だと、さうさね、日本の國を二十ほど寄せ集めたくらゐの廣大な場所が燃えてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが龍宮なんです、この場所が。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうよ、同じ山でも、場所に依つて名前が違ふのよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "國技館太宰治　生れてはじめて本場所といふものを、見せてもらつたわけであります。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒込の富士から神田明神、深川八幡の境内、鉄砲洲の稲荷、目黒｜行人坂などが、その主なる場所であった、がそれも、今ではお伽噺になってしまった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来、井戸なるものは、水を溜めるべきであつて、埃を溜めたりする場所柄では無い。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "此セメントを使った月日と、それから委しい所書と、どんな場所へ使ったかと、それにあなたのお名前も、御迷惑でなかったら、是非々々お知らせ下さいね。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると本当に読んでもらいたいと思うことはやはり何遍か同じことを繰返して色々の場所へ適当に織込むのが著者の立場からはむしろ当然かもしれない。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんは多くの同種類の云い伝えと同様に、時と場所との限られた範囲内での経験的資料とある形而上的の思想との結合から生れたものに過ぎないだろう。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて郊外へでも行けばさういふ點でいくらか工合のいゝ場所があるだらうと思つたが、併し一方で又餘り長く電車に乘り、又重いものをさげて長途を歩るくのは今の病氣に障るといふ掛念があつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所が場所だけに見物が段々背後に集まつて來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを主題にしたスケッチを一枚描かうと思つて適當な場所を搜して居ると、ちやんとした本物の畫學生らしいのが二人、同じ「青い家」を取入れて八號位の畫布を描いて居るのに出合つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の中で離れ／＼になつて何の連絡もなかつた色々の場所が丁度數珠の珠を絲に連ねるやうに、電車線路に貫かれてつながり合つて來るのが一寸面白かつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また子を生むといつでもその子を取り上げられるので色々隠し場所を変えた末に、とうとう主人の書斎の書棚の奥に隠した猫もある。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこではまっくろな泥が、あたたかに春の湯気を吐き、そのあちこちには青じろい水ばしょう、牛の舌の花が、ぼんやりならんで咲いていました。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
