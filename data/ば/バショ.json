[
  {
    "uuid": "5586026e-0afe-56de-b08d-550e6de53f0f",
    "entry": "場所",
    "reading": {
      "primary": "ばしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
