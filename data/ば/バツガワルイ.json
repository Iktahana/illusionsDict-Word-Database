        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左うとでも云はなかつたら、バツが悪いからなんだよ。",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもバツが悪いぞ、泣くより他に手はないかな。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分達がミヽヅクを持ち逃げして、皆なに迷惑をかけてバツが悪いもので、酔つた振りでもしたんでせう。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈を消して、朝のひかりでおもむろに一服（実は一杯やりたいのだけれど、酒が悪い、バツが悪い、等々！",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしましょうね、今さらあのカフエーに逆もどりも出来ないし、少し廻って来ましょうか、飯田さんも私に会うのはバツが悪いでしょうから……」「ええ、ではそうしてね。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖かくなつて、初めて外套を着ずに出た日は、裸で飛び出したほどバツが悪い。",
              "citation": {
                "source": "衣食住雑感",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかるでせう、バツが悪いのを誤魔化さうと思つて、わざと素気ないことを云ふのね。",
              "citation": {
                "source": "驟雨（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "内の女連はバツが悪いから留守を使って追い返した。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを買ふことにきめたのは、本屋があまり褒めるので断わるのもバツが悪いからであつた。",
              "citation": {
                "source": "明治詩壇の回顧",
                "author": "三木露風",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雲も、ちょっとバツが悪い思いをしている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで年久しくビールは一切敬遠してゐたが、近来、父母には似ないで両祖父に似た鬼子の豚児（ではなかつた賢息）が酒豪とあつて、時々ビールを厨房に命じたついでにひとりではバツが悪いのかおやぢにも一杯を献じようといふのでつき合つてゐるうち、近ごろでは、これも亦、悪くないと思ひはじめた。",
              "citation": {
                "source": "飲料のはなし",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは懐中電燈であったが、ポッケットに入れた方は確かにライカかコンタックスに違いなく、こんな時にそんなものを持っているのをバツが悪いと感じたのであろう。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角来たもんだから、―――」ナオミも浜田も熊谷も、一としきり黙り込んでしまったので、私はどうもそう云わなければ、バツが悪いような気がしました。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると余は少々ばつがわるい。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家――叔父の家――に行って長居すれば祖父母の感情にさわる、といって円光寺に行っても母と円光寺との関係上ばつがわるい。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の客は玄一郎ひとりで、三度めとはいうものの相当ばつがわるい。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
