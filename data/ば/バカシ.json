    "definitions": [
      {
        "index": 1,
        "gloss": "approximately",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある時ヘルンから万葉集の歌を質問され、答えることができなかったので、泣いてその無学を詫び、良人に不実の罪の許しを乞うた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの悪い病です』といって、中々許してくれないので、書斎はますます乱雑になるばかりであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして尚、一切の我がままと偏屈を許してくれた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十米レエスならば、まず今世紀、かれの記録を破るものはあるまい、とファン囁き、選手自身もひそかにそれを許していた、かの俊敏はやぶさの如き太宰治とやらいう若い作家の、これが再生の姿であろうか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、若々しい言ひ方が許して貰へるなら、私はその当時、宇宙を知つてゐたのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さんのお許しが出ましたか？",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その候補者の方が、本校の出身であるからには、生徒の激励にもなることゝ思ふので……」と云つて許してしまつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで竹山は、色んな泣事を並べて来る青年や娘は、殊に娘の方は不精無精ながらに、来る奴来る奴みんな入社を許した。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気で休学して郷里で遊んでいたときのことであるが、病気も大体快くなってそろそろ退屈しはじめ、医者も適度の運動を許してくれるようになった頃のことであった。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この心をお許し下さい。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのやうに何も言はず、ただ微笑して無限に許してゐるやうな素振りを見せながらも、皮裏にひそかに峻酷の陽秋を藏してゐて、浦島のわがままを一つも許さず、嚴罰を課する意味であの貝殼を與へたのか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしたら、お前は、おれをきつと許してくれるだらうな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから山の全裸体像として、線や、光や、影や、円味やを研究するのに、富士ぐらい秘密を許してくれる山はあるまい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、「速度のはやい」なども実感を強めるための俗語として「速度の大なるすなわち運動の速い」の略語として通用を許してもそれがために物理学は何の損害をも受ける心配はないかと思われる。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の秋になつて病氣の工合が大分よくなつたし、醫者も許し又すゝめてくれたので、何處かへ試しに行つて見ようと思ふと、生憎なもので時候外れの霖雨がしばらくつゞいて、中々適當な日は來なかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拡ごりの隙より、今や見る土量の幅は天幅を閉ぎて蒼穹は僅かに土量の両｜鰭に於てのみ覗くを許している土の巨台に逢着した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの罪を許しわたくしの呪をお解きください。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日の力をかりてわたしはおまへに許しを乞ひに來た。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（誰が許して誰が許されるのであらう。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんだら許してやる。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」な建築は円窓と半月窓とを許し、また床柱の曲線と下地窓の竹に纏う藤蔓の彎曲とを咎めない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "緊張のあとに来る弛緩は許してもらってもいいであろう。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ取締規則がこれを許しても、また二、三の変り者が実例を示して鼓吹したにしてもあまり流行はしそうもない、してもあの緊張した空気の中で好い声が楽に出ようとは思われない。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十六年二月校訂の時しるす）本書は昭和十二年五月内務省主催第二回神職講習会における講義を速記したものであって、昨年三月｜神祇院で印刷に附して関係者に頒布せられたが、今回｜書肆の請により同院の許しを得て新たに刊行したものである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "青く感じたものは赤く塗り、丸く見えたらいびつに描くというような概念的機械的方法によって製作しているのではないかという疑いが起るのは、やはり許してもらう外ない。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての人の罪を許し、すべての人が互に愛して抱き合はうといふ觀念は、單に觀念としては空虚のものに思はれるが、人もし或る日の室生に接すれば、それが生きた思想として迫つてくるのを感ずるだらう。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「先生といふ必要がない」といふ聲を聽くのは、僕等の正に感動してゐる野口氏への愛慕を、實に根柢から拒絶するものであり、この場合の事情からしても、詩人にあるまじき純一性の缺乏で、もし鈍感からならば賤しむべく、故意に惡意からするならば許しがたき奴だと思つた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし場合が場合であり、會衆の氣分が感傷的に緊張してゐた際なので、私は直覺的に野口氏への許しがたき侮辱を感じた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　あたしが此の間片附けて帰つてから、まだ三日ばかしにきやならないんだけれど、まあまた散らかつたわね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ移つて来たばかしの家なので、玄関には電球がなかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
