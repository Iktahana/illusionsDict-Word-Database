    "definitions": [
      {
        "index": 1,
        "gloss": "watchman (implies low rank or burakumin status)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
