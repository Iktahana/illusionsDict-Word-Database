    "definitions": [
      {
        "index": 1,
        "gloss": "fortunetelling (as an occupation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
