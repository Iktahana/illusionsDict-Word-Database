        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "バタートーストにスープに、ハムエッグスに、コーヒーに葡萄酒、どれもふつうの量の三倍から四倍もあった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "バタートーストが　やきあがるまでの　やっかいばらいの　つもりだったのですが。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　たぶん――赤のクイーン　バタートーストに決まってるじゃないの！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも　しばらくしたら　おちゃも　バタートーストも　ごじゆうに　どうぞ　ってことに　なって。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、このびんには毒の印はなかったので、アリスが味見してみると、とってもおいしくて（なんと風味はサクランボのタルトにカスタード、パイナップルからローストチキンとキャラメル、あつあつのバタートーストまでがいっしょになったみたいで）あっというまに飲みきっちゃった。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、このびんには〈毒〉の印はなかったので、アリスが思い切って味見してみると、とってもおいしくて（なんと風味はサクランボのタルトにカスタード、パイナップルからローストチキンとキャラメル、あつあつのバタートーストまでがいっしょになったみたいで）あっというまに飲みきっちゃった。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
