    "definitions": [
      {
        "index": 1,
        "gloss": "rainy season",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戸外は――地面は半ば乾いてあつたかい、空を風は、目標ありげにとぶ、梅雨期の或る一日だ。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体椎という樹は梅雨期に葉が赤くなるものなのでしょうか。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しなんと云っても堪らないのは梅雨期です。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨期のせいか、その時はしとしとと皮に潤湿を帯びていたのに、年数も経ったり、今は皺目がえみ割れて乾燥いで、さながら乾物にして保存されたと思うまで、色合、恰好、そのままの大革鞄を、下にも置かず、やっぱり色の褪せた鼠の半外套の袖に引着けた、その一人の旅客を認めたのである。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしこの回向堂を志して、ここまで来ると、あんなに日当りで、車は母衣さえおろすほどだったのが、梅雨期のならい、石段の下の、太鼓橋が掛った、乾いた池の、葉ばかりの菖蒲がざっと鳴ると、上の森へ、雲がかかったと見るや、こらえずさっと降出したのに、ざっと一濡れ。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨期が来ると一雨ごとに緑の毛氈が濃密になるのが、不注意なものの目にもきわ立って見える。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「男らしくもない、そんな事を言って梅雨期はどうします、まさか蓑笠を着て坐ってやしまい。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　其頃は時候も梅雨期の終に属して居たので世間が鬱陶しかつた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨期には、滅茶苦茶に照って、体中の水気を焙り出してしまうほど暑く、土用に入ってから、ジトジト降ったり、涼し過ぎたり、麹室の中みたいに暗くて蒸し暑く息苦しかったりした。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風な、乾燥した梅雨期に、緑屋の上の飲料水の沢に、掘鑿が突き当った。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の頭は梅雨期を過ぎて初夏の陽が輝いたかのように爽々しくなった。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、梅雨期に入つたのである。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　梅雨期が近づき出すと、ここの花園の心配はこの院内のことばかりではなくなって来た。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く梅雨期の幻想のまま、事實私は北海道の人人の醇朴さにキリストの精神を見て來たのかもしれぬと、このごろになつてよく思ふ。",
              "citation": {
                "source": "梅雨",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また年が一つ明けて春となり、やがてじめじめとした梅雨期になつた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明けはなした小さな窓からはすぐ向ひの丘の上まで重々しく垂れさがつてゐる梅雨期の雨雲がのぞかれ、いくどにも吹きこんでくる風は霧のやうなしめりを含むでゐた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "また年が一つ明けて春となり、やがてじめじめとした梅雨期になった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ梅雨期のことで、眼にいるものは皆涼しく、そして憂鬱であつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬戸から日和山へかけては、この雨のすくない乾いた梅雨期でなしに、他の季節を選んで、もつとゆつくり歩いて見たらばと思はれるやうなところだ。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて梅雨期にでも入ったのか、この海岸の空気も毎日｜陰鬱であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　初日の景気が少し続いたかと思うと、早くも六月に這入り、梅雨期となって毎日の雨天で人出がなくなりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大仏の末路のあわれなはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれほど灰色雲に包まれてゐる天地でも、梅雨期に於ける山の影は決して寂しいものではない。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか梅雨期の蒸々した鬱陶しい日が來た。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほととぎす妄りに鳴かず一章を読み終へて後一章を次ぐ　咢堂先生を嘗て莫哀山荘に御尋ねした時軽井沢では梅雨期にはほととぎすが喧しい位啼くといふ御話であつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "上下四千載の歴史は、梅雨期の天氣の如く、陰鬱の影多くして光霽の趣に乏しい。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨期の前でよく雨が降った。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
