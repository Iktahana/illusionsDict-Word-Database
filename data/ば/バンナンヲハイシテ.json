[
  {
    "uuid": "9e26f4cd-6924-5155-80c3-b41acb91e0ab",
    "entry": "万難を排して",
    "reading": {
      "primary": "ばんなんをはいして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
