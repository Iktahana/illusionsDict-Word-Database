        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スークル・カ・バッチャ、この豚の子奴！",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代の人が驚異したのに無理はないが、今日はバッチェット方法、ポイグナード方法、その他の方法を知れば、随分大きな魔方陣でも列べ得ること容易である。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "書いたものをお兄さんに渡してもらい、結果を後で教えてもらうという人間バッチ処理で臨みました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューター屋の言葉で、これをバッチ処理という。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア人ジォヴァンニ・バッチスタ・バシレの『イル・ペンタメロネ』の四巻一譚に、ミネカニエロ翁雄鶏を飼う。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが椿岳の市価が出ると忽ちバッチラがいで持ってってしまって、梵雲庵には書捨ての反古すら残らなかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あたしのぶんなんて、あるのかしら」「もう、バッチリ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと撮れたのかよ」「バッチリ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの歌、もうバッチリ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と同時にバッチャリと潰れた音がしたと思うと間もなく、生あたたかい、酸っぱいような小便のにおいがムラムラと顔に迫って来ましたので、三太郎君は、ヨロヨロとあとしざりしながら顔をそむけました。",
              "citation": {
                "source": "卵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガルスワージーの“saint's progress”バッチンスの“this freedom”その他、深く読むべきものが多いと思います。",
              "citation": {
                "source": "嫁入前の現代女性に是非読んで貰いたい書籍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜き合わせる間もなかったが、バッチリ柄頭で受け止めた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰まっていた物が取れたようだ」　死骸の側へ寄って行き、死骸の袖で刀を拭い、バッチリ鞘へ納めてしまった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仕事はどの程度急ぐのか、どれくらい作業時間を必要とするかをカードに書き添えてコンピューターにどんどん仕事を渡し、高価な機械にはむだなく働き続けてもらおうとするバッチ処理と呼ばれるこうした使い方によって、組織全体から見た処理能力の利用効率は高まった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、一度ギャストンバッチの女優学校へでも這入って、正規の発音を習わなきゃ、信用出来ないわ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてラケットと靴を持った両手をホンの一寸たたいたと思ったら、バッチリと生あたたかい手錠をかけてしまった。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『しばらくだったなァ、勤めたのかい』『うん』　友野は、少しばかり反身になって、胸のバッチを示した。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バッチリ噛み切る歯音がした。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一行に加はつて船出した一人に、ジョ※ンニ・バッチスタ・シドチとよぶ筋骨逞しい僧侶があつた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分転換が何より必要だから、キャッチボールをしたり、フリーバッチングをしたりしたが、やがて、その気力も失った。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は屋久島へ行ったことはないけれども、千七百年代の初頭、例の新井白石が政治をやっていたころ、イタリヤのパレルモの人、ジョヴァンニ・バッチスタ・シドチという宣教師が死を覚悟で密航してきたことがある。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「船にも乗ったろうし、汽車にも乗ったろうし、新聞売りの手にも渡ったろうし、バッチンの穴の中へも入ったろうし、紙芝居のおじさんの手にも、そのほか考えたら、まだいろいろあるだろう。",
              "citation": {
                "source": "一銭銅貨",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏の夕｜其処へ行って当時中学生であった余らがバッチングを遣っていると、其処へぞろぞろと東京がえりの四、六人の書生が遣って来た。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我らは本場仕込みのバッチングを拝見することを無上の光栄として早速それを手渡しすると我らからそれを受取ったその脹脛の露出した人は、それを他の一人の人の前に持って行った。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのバッチングはなかなかたしかでその人も終には単衣の肌を脱いでシャツ一枚になり、鋭いボールを飛ばすようになった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "取引き仲間にトバッチリをかけると、あとでたたられる。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長五　詰らねえトバッチリを喰うもんだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このトバッチリを喰って、皇帝の父君、すなわち第十一世維新王は十七歳の時に廃位されて南印度洋の孤島レユニオン島へ流謫され、今もって街頭でヴァイオリンの流し弾きをして、ようやく露命をつないでいるという惨状なんです。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "りっぱな釣り会のバッチをつけた人が、ドロだらけの釣り服で平気で腰をかけているのも困りものだ。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
