      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "barrel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "タキクンハ　「ヒゲサン」ト　ヨバレルノガ　イヤデ　タマリマセン。",
              "citation": {
                "source": "センセイノ　コ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主がかえって来たので東京に来たが男から手紙が来てバレル、女身持ち。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点を可能な限り改善するために、松本たちはフォントのパターンを一文字分ずつ高速に移動させる機能を持った、バレルシフターと呼ばれるＡＳＩＣを起こした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を敬うに、地にぬかずくような気違いであるから、まかり間違うと、腕ずくでアバレルほかにウサバラシができない。",
              "citation": {
                "source": "天皇陛下にさゝぐる言葉",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "規律などは滅茶々々、酔つたあげく兵舎の窓をとびだして妓楼へ行く奴、町へくりだし情婦の家へくづれこむのは良い方で、女を押へつけて無理無体に思ひをとげる奴、上官は見て見ぬフリ、士気があがつてゐるからアバレル、血気がなくては敵の軍艦に突ッこめない、まるでもう当り前の顔でかう言つてゐる。",
              "citation": {
                "source": "決闘",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜はスイバレだからキンチャンカマルよ」　雨のことが水で「スイ」、降ることを「バレル」、「キンチャン」は金を持ってくるので客のこと、「カマル」は加えるで客が多くくる。",
              "citation": {
                "source": "符牒の語源",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "血統書ニ依ルトコノ犬ノ父ハロンドン生レデレスリート云ウ名ダッタノデ、ソノ仔モ同ジ名デ呼バレルコトニナッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "直チニ×××号室ニ運バレル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ある唯一の證拠としては、そっと紙に包んで懐に入れている鼻があるが、それを持ち出したら彼の大事な秘密がバレルのは云う迄もない。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の若者たちは狂躁なジャズのリズムにのってカストリの濛気をフットウさせカンシャク玉がアバレルようなアンバイ式に一向に芸術的ならぬ現実的エロを味い、甚だもって高遠ならざる恋をさゝやく。",
              "citation": {
                "source": "現代とは？",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
