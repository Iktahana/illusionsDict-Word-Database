        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西洋人は東洋暖地へ来てやっとバンガローのベランダ造りを思いついたようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所は椰子林の中を切り拓いて建てた、草葺きのバンガロー風のもので、柱は脚立のように高く、床へは階段で上った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空地の真中から、草葺きのバンガローが切り拓かれた四方へ大ランプの灯の光を投げている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンガロー風で、正面と横とに広い階段がついている。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀟洒たるバンガロー風の家だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日、両将は木留の本営に居たのであったが、急を聞いて部下三四百を率い、馳せ来って、吉次越の絶頂の凹んだ処に木と草とで忽ち速成のバンガローを造って、悠々と尻を落ちつけて、指揮したと云う。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論この建物もバンガロー以上であつた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンガロー風で、正面と横とに広い階段がついてゐる。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の屋敷はご料林の麓、酒井男爵の別墅から半町｜距った林の中にあった、それは瀟洒たるバンガロー式の小窓の多い建物で外見は寧ろ貧しかったが内部の装飾の燦然さは眼を驚かすばかりであると町の人達は云っていた。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンガローの横手まで歩いて行くと広い後庭の中央に可成り大きな温室が夕陽に硝子屋根を反射させて秋霧の中に横倒わっていた。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事が評議、研究されているうちに、間もなく正午過ぎになると、又々異様なものが、このバンガローの中から次から次に発見されて、係官たちを面喰らわせた。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してお庭の隅の常春藤に蔽われたバンガロー風の小舎には燈火がアカアカと灯って、しきりに人影が動いている。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に避暑外人の借りているバンガローがそのほとりにあって、金髪の女や幼女が、青や黄や赤や、スマートな服装をして池辺に戯れたり、ボートを漕いだりしているのも、外国らしい感じを抱かせる。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時敬太郎は、果しのない広野を埋め尽す勢で何百万本という護謨の樹が茂っている真中に、一階建のバンガローを拵えて、その中に栽培監督者としての自分が朝夕起臥する様を想像してやまなかった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はバンガローの床をわざと裸にして、その上に大きな虎の皮を敷くつもりであった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでヘルマン先生は、かねて飲み仲間の親友マドロスに隣地へ小意気なバンガローをたてゝやり、二人でひねもす、よもすがら、飲んでゐたさうで、ヘルマン先生なりふり構はず、ボロ服に、貧乏時代からのマドロスパイプをくはへたまゝ、酒の外には余念がなかつたさうである。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み仲間のゐたバンガローに当時は日本人の老画家が住んでゐて、廃屋廃園に、私達を案内してくれ、ヘルマン氏の思ひ出をきかせてくれたのであつた。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでヘルマン先生は、かねて飲み仲間の親友マドロスに隣地へ小意気なバンガローをたててやり、二人でひねもす、よもすがら、飲んでいたそうで、ヘルマン先生なりふり構わず、ボロ服に、貧乏時代からのマドロスパイプをくわえたまま、酒の外には余念がなかったそうである。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み仲間のいたバンガローに当時は日本人の老画家が住んでいて、廃屋廃園に、私達を案内してくれ、ヘルマン氏の思い出をきかせてくれたのであった。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "風光明媚なる適地に、バンガロー風の病院をたて、ベッドにねむれば星が見える。",
              "citation": {
                "source": "深夜は睡るに限ること",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、このバンガローに、睡眠旅行ホテルというような名前をつける。",
              "citation": {
                "source": "深夜は睡るに限ること",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "血のつながった、たった一人の甥を、根岸台のあんなバンガローに追いあげて、いっさい構いつけないなんて……せめて、あたしが蔭にまわって庇うぐらいのことをしなくっちゃ、世間のもの笑いになります。",
              "citation": {
                "source": "喪服",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫　　（読み続ける）「四万坪の地区には、整然たる道路、衛生的な下水水道電熱供給装置テニスコート等の設備があり多くの小綺麗なバンガローや荘重なライト式建築、さては、優雅な別荘風の日本建築などが、富士の眺めや樹木に富む高台一帯の晴れやかな環境に包まれて……」（新聞を投げ出し）おい、散歩でもして見るか。",
              "citation": {
                "source": "紙風船（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンガロー風のポーチに立つて、二三べん大きな声で呼んでみても暫くは誰も出て来ない。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかに小会堂風のだの、バンガロー風のだのが、林間のそこここに立つてゐたが、どれを見ても内も外も一様にひどく荒廃してゐた。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで白人達は自分で潜水する必要がなくなり、ブルームの町の白人区域に美しい庭のついたバンガローを建て、赤いポインセティヤの葉がしなだれかかるヴェランダのハンモックで冷たい飲物を飲みながら貝の値段や真珠の市価を論じて暮すようになった。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にはフトしたことから、その行方が判ったので、新聞記者の特種スクープの野心と、半面にはその心境を慰めたい気持とから、僕は軽井沢のバンガローの貸別荘に潜んでいたのを探し出した。",
              "citation": {
                "source": "吉川さんの声と眼",
                "author": "平野零児",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、ここで結構ですわ……キャンプ村のバンガローを借りて、今夜はそこで泊ります」「バンガローの鍵を持っている管理人は、今日は吉田へ行っているはずだ。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
