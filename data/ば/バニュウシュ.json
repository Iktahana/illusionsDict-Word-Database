          "literary": [
            {
              "text": "馬肉、羊肉、木苺、菱の実｜等を喰い、馬乳や馬乳酒を嗜む。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い毛皮の陰に北風を避け、獣糞や枯木を燃した石の炉の傍で馬乳酒を啜りながら、彼等は冬を越す。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬肉、羊肉、木苺、菱の實等を喰ひ、馬乳や馬乳酒を嗜む。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い毛皮の陰に北風を避け、獸糞や枯木を燃した石の爐の傍で馬乳酒を啜りながら、彼等は冬を越す。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」チホン「私の誕生日でございました故、十人ほど友達を招きまして馬乳酒を飲み合って居りました」法官「イサクの殺された時刻は――たしか午前の二時であったが、お前は何をして居たか？",
              "citation": {
                "source": "死の復讐",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "調査も予定通り進み、馬乳酒の少し酸っぱいような不思議な味も初めて経験し、無事に帰りのトラックに乗った。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
