    "definitions": [
      {
        "index": 1,
        "gloss": "blowing up and sinking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
