          "standard": [],
          "literary": [
            {
              "text": "左様でございます」「こいつと一緒に番屋まで来てくれ」　二人を引っ張って、半七は近所の自身番へ行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪く片付けていやあがると引っぱたくぞ」「今と違って、むかしの番屋の調べはみんなこんな調子でしたよ」と、半七老人は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「町奉行は格別、番屋で調べるときには、岡っ引や手先ばかりでなく、八丁堀のお役人衆もみんなこの息で頭からぽんぽん退治つけるんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七も承知したが、ここではどうにもならないから、ともかくも番屋まで来いと云って、お俊を引っ立てて出ようとするところへ、さっきから入口に立っていた女がはいって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐずぐずしていると、番屋へ引き摺って行って引っぱたくぞ」と、半七はその腕を一つ小突いて嚇し付けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "番屋の柱へ縛りつけて、絞めあげるから……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうして、その小僧はどうした」「番屋へ預けて置きました」と、半七は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの方にも眼があるから、白い黒いはちゃんと睨んでいるのだ」　　　　　六　大番屋へ送られて三人は更に役人の吟味を受けた後に、新次郎は重罪であるからすぐに伝馬町の牢屋へ送られた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さんが今、番屋に止められたと云って、なあちゃんが泣き込んで来たんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたんでしょうねえ」「ねえさんが番屋へあげられた」と、半七も団扇の手をやすめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が番屋で申し立てたところによると、曲者は背の低い小児のような怪物で、顔もからだも一面に黒かったのを見ると、おそらく裸体であったらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "お滝はそのままに番屋に止められてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "お浪は仔細ないと認められて一と先ず釈されたが、お照は申し口に少し胡乱の廉があるというので、これも番屋に止められた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを正直に白状しないために、お照は番屋に止められたのであろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ち兼ねたように出て来たお浪を蔭へ呼んで、半七はその後なんにも変ったことはないかと訊くと、別に変ったこともないが、もう少し前に古着屋の息子が来て、お照が番屋へ止められた話を聞いて、真っ蒼になって帰ったとお浪は話した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中のお滝はどうしたと訊くと、けさから番屋へ止められたままで、まだ下げられないとの事であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方そこらの番屋へ引き挙げたのであろうと、半七はその足で近所の自身番へ行ってみると、そこには幸次郎の姿も見えなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、てめえにうしろ暗いことがねえならば、なぜ番屋を逃げ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "その許可を得て、彼は直ぐに深川の北六間堀へ出向いて、柘榴伊勢屋の主人由兵衛を番屋へ呼び出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、なんでもいいから番屋まで来てくれ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは決して番屋へ連れて行かれるような覚えはありませんよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金はみんな甚右衛門から出ているんだろう」　ここまで問いつめられても、豊吉はまだ強情に口をあかないので、彼をひと先ず番屋につないで置いて、半七は更にその女房をよび出して、彼の家へふだん近しく出入りするものを調べた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人が番屋で申し立てたのじゃあ、駿河屋で何か建て増しをするので、その相談ながら両国辺でいっしょに飲んで、駿河屋の主人を照降町まで送って帰る途中だということです」　半七は忌々しそうに舌打ちをした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "その清五郎はまだ番屋にいるのか」「清五郎の疵はたいした事でもねえので、そこで手当てをした上で、まだ番屋に残っています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "本部屋にいた吉助は勿論、名代部屋にいたお駒の客ふたりは高輪の番屋へ連れてゆかれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定は番屋へ引っ立てられると、もう尋常に覚悟を決めてしまったらしく、何もかも素直に白状した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐにその女を番屋へ連れて来てくれ」　　　　　二　尾張屋のおかんは町内の自身番へよび出されて、半七の吟味をうけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれと一緒に番屋へ来い」　お千代は真っ蒼になって泣き出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "「番屋へ連れて行くのも可哀そうだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門天の与ふるところ既に武芸に在り、等輩を思惟するに誰か将門に比ばんや。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
