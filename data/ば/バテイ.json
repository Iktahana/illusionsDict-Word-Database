[
  {
    "uuid": "d507fec1-3d6a-5f90-9a02-af1823f394ac",
    "entry": "馬丁",
    "reading": {
      "primary": "ばてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
