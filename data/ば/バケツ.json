        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "裏口からじゆんが馬穴に水を入れて、下げて入つて來た。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側には、七輪や、馬穴や、ゆきひらや、鮑の植木鉢や、座敷は六｜畳で、押入れもなければ床の間もない。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は急にせわしそうに、台所に立って行くと、馬穴をさげて井戸端へ水を汲みに出た。",
              "citation": {
                "source": "魚の序文",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなにゴタゴタしないで、風呂敷へでも包んでしまえよ」「ええでもこうやって、馬穴をさげて行こうかと思っているのよ」　私達が初めて所帯を持った二階借りの家から、その引越し先の屋敷跡へは、道程から云うと、五丁ばかりもあったであろう。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なか子は、打水をするやうな様子をして、家主の神さんや、問屋の番頭が来はせぬかと、冷々しながら屑屋が帰へつて行くまでは、馬穴をさげて溝板の上をざぶざぶ濡らして歩いてゐた。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処へも行けやしないし馬穴持つて逃げたら、お父さんつてばね、あの時になつて、私を橋の上から突きおとしたンですからね」　継母はばらばらと涙をこぼして、忍び泣きをしてゐる。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "より江はつまらなそうに、店先へ出て、店に並べてある笊や鍋や、馬穴なぞを、ひいふうみいよおと数えてみました。",
              "citation": {
                "source": "蛙",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧ッ、馬穴をやるから足を洗って　その鉄梯子から上って来な」　ガレージの隅がほのあかるくなった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから鉄梯子がさがっていて、小さい馬穴が紐にぶらさがって降りて来た。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は馬穴にいっぱい生鰯を入れてもらうとその辺の雑草を引き抜いてかぶせた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　帰えり道、娘は重そうに馬穴を私の前に出してこう云った。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "より江はつまらなさうに、店先へ出て、店に並べてある笊や鍋や、馬穴などを、ひいふうみいよおと数へてみました。",
              "citation": {
                "source": "蛙",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何日も汚れた鍋や茶碗を馬穴へつけっぱなしで、その汚れた水へ色々な羽虫が飛んで来ても、伊代は歯も指も黄いろくして煙草を吸ってばかりいた。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊代は出窓の上の、馬穴の上に飛び交う蠅を見ていた。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れたものの匂いを一寸かいでみては、アルヘンティーナようにおどけた身振りで、馬穴のまわりを、ぶうんと唸りながら身軽に飛びまわっている蠅ども、米粒が固く張りついている茶碗の上で合掌してみせたりしている小蝿達を伊代は飽きずに眺めていた。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁ぎわや太い柱の陰に桶や馬穴が汚物をいっぱい溜め、そこらに糞便をながし、骨を刺す異臭のなか「助けて　おとうちゃん　たすけて「みず　水だわ！",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "細民街のぼろアパアト、黄塵白日、子らの喧噪、バケツの水もたちまちぬるむ炎熱、そのアパアトに、気の毒なヘロインが、堪えがたい焦躁に、身も世もあらず、もだえ、のたうちまわっているのである。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "審判員がこぼれただけの水を補給しようとして、バケツを持つて追つかけて、打ちあけるのだが全部は入らないといふ風だつた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は、そこで、おふくろが、どつかから貰ひ水してあるバケツに飛びつく。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もどしたものを母親が小さな玩具のバケツへ始末してゐた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのバケツの色彩が妙に眼について今でも想出される。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バケツ一つだけで弥生町門外の井戸まで汲みに行ってはぶっかけているのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もどしたものを母親が小さな玩具のバケツへ始末していた、そのバケツの色彩が妙に眼について今でも想い出される。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はさっそく新しい水をバケツに二はいくみ入れてやった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて外より戸を開け、先にモデル娘、続いてウェエベルの上さん、箒、バケツ、雑巾を持ち、登場。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、彼女は二階の縁側の拭き掃除が終って、汚れ水の入ったバケツを提げて立ったまゝ屋根ごしに近所の大きな屋敷で樹を植え換えているのを見入っているところだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨董屋は、今朝、戦線へ出動した山東兵が、雨傘を持ったり、石油罐の一方をくり抜いて太い針金を通したバケツをさげていた、と笑っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い土のような人間が、その下にころがっている頭蓋から脳味噌をバケツに掻き取っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時しも老いし小使は、　　豚にゑさかふバケツして、農学校の窓下を、　　足なづみつゝ過ぎしなれ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は助手が変てこな、ねじのついたズックの管と、何かのバケツを持って来た。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
