        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "砲弾にて破損せる古き穀倉の内部、辛くも全滅を免かれしバナナン軍団、マルトン原の臨時｜幕営。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に出て一応各部署を点検し終わると、ふたたび幕営に入り、雷のごとき鼾声を立てて熟睡した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、李陵は小袖短衣の便衣を着け、誰もついて来るなと禁じて独り幕営の外に出た。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕営の中に残った将士は、李陵の服装からして、彼が単身敵陣を窺ってあわよくば単于と刺違える所存に違いないことを察した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋天一碧の下、ずるころになってようやく彼は幕営に戻る。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自宅ならば格別、それが幕営のうちであるので、彼もその始末に窮していると、女がどこからか現われた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣地と定った場所では、兵等が罵り合い右往左往して、幕営の準備をしていた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、眠りはなかなか来ず、漠然とした不安が、夜の幕営の裡で彼の心にのしかかった。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "混雑の頂上にあるイランの陣の間を、スーラーブの膝の下にされた今日の老戦士が、一人で、いそいで、自分の幕営に戻ろうとしていた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七色の縞が鮮かに見え、ルスタムの処から眺めると、数多いイランの幕営が、優しく小さく群てその晴やかな光の冠に抱き込まれているように思えた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の顔のまわりには、十人あまりの顔が、皆まん中に置いた燈火の光をうけて、赤く幕営の夜の中にうき上っている。",
              "citation": {
                "source": "英雄の器",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕営の外はしんとしている。",
              "citation": {
                "source": "英雄の器",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ幕営をつくるがいい。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は我々の宗教的修業で、メソディスト幕営集合以外、これに比すべきものは何も思い出せなかった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年私は、三枝、辻本の両君と、後立山から立山山脈の初縦走を企て、七月中旬、大出の猟師兵三郎を案内に、ほか四人の荷持ちと、籠川入りの扇沢を遡ったが、谷間の幕営に三日も降り込められた。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外に幕営中の軍隊も闇に紛れて逃亡してしまった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前のインカの幕営地に派遣された三十騎の一隊は、インカの后妃たち、附人たちなど多数の男女を率いて帰って来た。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで――」　近習の一名に麾ねかれて、宗矩は、何事かと急いで、家康の幕営へ駈けて行った。",
              "citation": {
                "source": "剣の四君子",
                "author": "柳生石舟斎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士はまた、幕営の奥へもどって行った。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いざ、こなたへござれ」　と自身、自分の幕営のうちへ、手を取らぬばかり宥りながら導いて行った。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの、どの幕囲のなかに、信玄その人が床几をすえているのか、旗じるしや馬簾だけを的に捜したのでは分らないほど、同じような幕営がいくつもあった。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵はいたずらに前衛戦で勝とうとせず、ひたぶるに、信玄の幕営のみを目がけているものと思われたからである。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十隊のお味方勢が、彼方、千曲川の下流からも、上流からも」　八幡の森の梢に、物見に登っていた者たちは、こう大声で下に知らせ、下にいた部将はすぐ、信玄の幕営へ向って、同じ声をもって告げていた。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、見たので、信長の旗下は、信長の幕営を出て、みな川岸へ、槍を揃えていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その信長の幕営の裏から――幔幕をかなぐり上げて、今し、そっと這いこんで行こうとする男がある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康の三河勢も、榊原康政、大久保｜忠世、本多平八郎、石川｜数正など、「織田衆におくるるな」　と、忽ち対岸を突破して、越前勢の朝倉｜景健の幕営へ突き進んで行ったが、ようやく味方と遠ざかって、後ろも敵、前も敵、甚だしい苦戦に陥った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ために、信長その人について、深い理解をもち得ない敵国の民衆は、織田軍と聞けば、涙も仮借もないものと一途に怖れおののいて、その幕営をめぐって市が立つどころか、求めても、人は逃げてしまうし、捜しても、物資は地下に蔵されてしまう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまちのうちに、十八ヵ国の諸国をたぶらかし、われ密詔を受けたりと偽称して、幕営二百余里にわたる大軍を編制しました」「そいつは捨ておけん」「もとよりのことです」「で――まだ詳報はこないか」「昨夜、夜半から今暁にかけて、ひんぴんたるその早馬です。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮑将軍の弟の鮑忠が、抜けがけをして、かなりの味方を損じたという不利な報告があったし、今また、先鋒の孫堅が、木ッ端｜微塵な大敗をこうむったという知らせに、幕営の諸将も、全軍の兵気も、「いかがすべき？",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹操はすぐ幕営に引かせて彼に会った。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
