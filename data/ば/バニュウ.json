        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馬肉、羊肉、木苺、菱の実｜等を喰い、馬乳や馬乳酒を嗜む。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い毛皮の陰に北風を避け、獣糞や枯木を燃した石の炉の傍で馬乳酒を啜りながら、彼等は冬を越す。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬肉、羊肉、木苺、菱の實等を喰ひ、馬乳や馬乳酒を嗜む。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い毛皮の陰に北風を避け、獸糞や枯木を燃した石の爐の傍で馬乳酒を啜りながら、彼等は冬を越す。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒙古人古来馬肉を食い、殊にその腐肉を嗜み、また馬乳で酒を作った事は支那人のほかにルブルキスやマルコ・ポロやプルシャワルスキ等の紀行に詳し。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年（大正五年）十二月の『風俗』に、林若樹君が「不思議な薬品」てふ一文を出し、本邦現存最古の医書｜丹波康頼の『医心方』から引き陳ねた奇薬の名の内に、馬乳、白馬茎、狐と狗の陰茎あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い下髪を赤い布で飾った小柄な女は馬乳で有名なクルムィク人の婦人代表だ。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬乳を其儘飮むのではなくして、馬の乳からして製した所のクーミー（Koumis）といふ酒を飮みます。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」チホン「私の誕生日でございました故、十人ほど友達を招きまして馬乳酒を飲み合って居りました」法官「イサクの殺された時刻は――たしか午前の二時であったが、お前は何をして居たか？",
              "citation": {
                "source": "死の復讐",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で私は襤褸を纏い顔にローレルの粉を塗り、頭に馬皮の帽子を冠り、馬乳を入れたニッケル筒を藤蔓で左の脇下へ垂らし、桜の柄の付いた拳銃を上衣のかくしへ窃ばせました。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして馬乳を一杯に入れたニッケルの筒を藤蔓で脇の下に下げて居りました。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬乳で産湯を使った身だ（彼等の諺）」　こんな具合で訳も無く彼等の仲間に這入りました。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこちの天幕からは馬乳から採ったカス酒に酔った男達の元気のよい唄声が聞えて来る……平和で自由で元気に充ちた隊商気分が、不毛の原野に今や溢れているのであった。",
              "citation": {
                "source": "喇嘛の行衛",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その実の円い者を草竜珠といい、長い者を馬乳葡萄といい、白い者を水晶葡萄といい、黒い者を紫葡萄という」とこれである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "調査も予定通り進み、馬乳酒の少し酸っぱいような不思議な味も初めて経験し、無事に帰りのトラックに乗った。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノガイの草地では、馬乳が療養上有名です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
