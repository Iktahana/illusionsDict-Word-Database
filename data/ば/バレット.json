[
  {
    "uuid": "7b961915-e190-5d97-a8c3-00e91083724e",
    "entry": "バレット",
    "reading": {
      "primary": "バレット",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "balletto (16th-17th century genre of light vocal composition)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妾達が最初におあいしたのは、カバレット・トアズンドルの舞踊会でした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・トアズンドルの舞台では、ターバンを巻いた印度人が、細腰のヒンズー女を抱いて、宗教的な怪奇な踊りを舞っていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット銀座の情婦、無智な妖婦から電話がかかってくる。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレットのキャラバン、酒場から酒場へ近道の建札、夜の美粧院に吊された青蛙の料理写真にしたらんたん、足の化粧法、日本人を日本人らしく見せない整型学、醜いものをグロテスクにするための進歩主義、あわただしい木馬競走に見惚れる観衆の喝采。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は花田君子柳の下に棄てて、カバレット銀座、未来の情婦、万国の血をみて狂うメイ・フレデリック、私を見るや彼女の情熱死物狂い（その頃喫茶店インタナショナルの芸術家は珈琲とフランス菓子に驚歎して昆虫類が今後人間に代ってエゴイズムと排他主義、実行する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・ポンペアの低い嬉びに、世界各国の鶏の歌奏でるユダの主人、私はシャンパン、緑色の天井、進撃勇ましい、桃色の月、見上げて、十人のコウカサスの女に接吻する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのカバレット・トア・ズン・ドルの淡い憶いがネムの花に夢のように、あらわれるのだが、彼女は何もかも知らぬふりをして、私の用事を待つ、それが英国種の牝犬のように無関心な顔をして、その実細心なデコルテを内にかくしてかしこまっている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "で僕はむくむく起きあがると贅六らしくだらしなく身繕いして、そっと自分の服装を見たんだが、カバレット・トア・ズン・ドルの歴史がべたべたそのまま張られているのに気がついたのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はマルセーユのカバレット・トア・ズン・ドルの東洋の女を一人忘れものしたのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は即座にカバレット・トア・ズン・ドルにお別れを告げると、ローヌ河でパンツを洗濯してすっかり清浄な心と魂を持つ女になったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・バビロンの白煉瓦の高層な建物から流れるワルツの曲が街角に直立した赤い帽子の印度巡査をモスモロスの道化役者風にしたててバビロンの入口の廻転ドアの前に金モールのいかめしい英国人の門衛が莞爾とした笑いをたたえている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の界わいを、極度に断截された近代娘たちが、短いスカートと男のような乳房と新しい恋愛教科書によった独立の精神をもった彼女たちが、キャバレットとバーと夜の百貨店へくりだした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アアル・ユウ・ミスタア・ヘンリイ・バレット・アアント・ユウ？",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでヘンリイ・バレットは現在どこに行っているかね？",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「では漢口へ電報を打ってヘンリイ・バレットの脚を取り寄せよう。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「美華禁酒会長ヘンリイ・バレット氏は京漢鉄道の汽車中に頓死したり。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十三号というのを見ることにして階子をのぼりつつバレット〔召使〕、――あの人はあなたの御知り合いですか。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリザベス・バレット・ブラウニングの「※葡萄牙詩抄」（Sonette nach dem Portugiesischen）を譯す。",
              "citation": {
                "source": "リルケ年譜",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラウニング夫人（人）Mrs. Browning. 名はエリザベス・バレット、一八〇六―一八六一。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "大部分はバレット＝ハミルトンとヒントンの「イギリスのほ乳類の歴史」、ドナルドソンの「ラットについて」に興味深く総括されている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
