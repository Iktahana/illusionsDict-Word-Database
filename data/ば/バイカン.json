[
  {
    "uuid": "24b8ace8-129c-5b4c-9430-353d827b2c3e",
    "entry": "陪観",
    "reading": {
      "primary": "ばいかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
