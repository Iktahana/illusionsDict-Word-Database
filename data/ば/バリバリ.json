    "definitions": [
      {
        "index": 1,
        "gloss": "vigorously (ripping, tearing, scratching, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ブンゼン燈のバリバリと音を立てて吹き付ける焔の輻射をワイシャツの胸に受けながらフラスコの口から滴下する綺麗な宝石のような油滴を眺めているのは少しも暑いものではなかった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一郎は自分の足があんまり痛くてバリバリ白く燃えてるやうなのをこらへて云ひました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと急にバリバリバリッと烈しい音がして竜巻は水と一所に矢のように高く高くはせのぼりました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日犬が又縁側を通ると、猫は畳の表を爪で力一パイバリバリと掻きむしっています。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中湯が沸騰て来たから例の通り氷のように冷た飯へ白湯を注けて沢庵をバリバリ、待ち兼た風に食い初めた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――人も立ち会い、抱き起こし申す縮緬が、氷でバリバリと音がしまして、古襖から錦絵を剥がすようで、この方が、お身体を裂く思いがしました。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず同氏が地謡に座って謡いながら翁の前で行燈袴をまくって、毛ムクジャラな尻から太股まで丸出しにして痒い処をバリバリと掻きまわるような事があっても翁は見ないふりをしていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "合羽をバリバリに凍らせた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、その全収入を菓子屋に奉公するために、仕事着は、二着っきり、靴はなく、どんな寒い時もゴム裏｜足袋の、バリバリ凍ったのをはいていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "老先生は支那間の壁掛の蔭に行って立ちどまって、「バリバリ音が聞えているぞ」　とおっしゃった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バリバリ聞えてるの？",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "めざしは頭からバリバリ食べる。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三唖は土佐の生れで、現内閣のバリバリで時めいてる仙石貢の親戚である。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず現われて来るのは、市会議員の或る一派が往来のバラスや、市で使う石炭や、水道の鉄管や、又はあの大きな瓦斯タンクなぞをバリバリ喰っているところである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、膝頭の肉がかすかにバリバリと音をたてた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの母は歯が丈夫で、七十七歳で世を終るまで一枚も欠損せず、硬い煎餅でも何でもバリバリと齧った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "男学員ペンは上下の歯をバリバリ噛みあわせながら、額からはタラタラと脂汗を流していた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "バリバリと何ものとも知れず降りかかる。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の角に歩兵が散兵線を布いていると思うと、バリバリと小銃の音が凄まじく聞こえる。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の母は歯が丈夫で、七十七歳で世を終るまで一枚も欠損せず、硬い煎餅でも何でもバリバリと齧った。",
              "citation": {
                "source": "はなしの話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣幕のそとには二頭の馬が、バリバリ草を食っている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云はれてから、うまさうにバリバリ音をさせてたべはじめた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ、バリバリと垣根のやぶれる音がした。",
              "citation": {
                "source": "からたち",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は暫くぼんやりと何も考へてはゐなかつたが、突然、屋根の方を、ビユンと唸る音がして、つづいて、バリバリと何か裂ける響がした。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "係りの大谷検事は、当時所謂バリバリの検事だった。",
              "citation": {
                "source": "彼は誰を殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その毛は火のやうに光り、鉄のやうな爪で床を掻く音がバリバリと聞える。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠が壺をバリバリ引つ掻くとか、自身で火掻棒につまづくとかすると――さあ大変だ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉は――青桐の廣葉は、獅子がたてがみをふつてゐるやうに、葉を立てて、バリバリと、貪焚に、雨にぶつかつてゐる。",
              "citation": {
                "source": "夏の夜",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "くまは、後足で立ち上がったまま赤いランプの光におびえてか、爪をとぐねこのように、バリバリとそばの羽目板に爪をたてた。",
              "citation": {
                "source": "くまと車掌",
                "author": "木内高音",
                "note": "青空文庫"
              }
            }
          ]
        }
