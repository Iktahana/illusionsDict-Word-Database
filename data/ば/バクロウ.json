[
  {
    "uuid": "b09c5d04-1493-584c-a131-edb86cec4db1",
    "entry": "伯楽",
    "reading": {
      "primary": "ばくろう",
      "alternatives": [
        "はくらく"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cattle or horse trader",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "車中〔二〕稜堀山の巌の稜、　　一｜木を宙に旋るころまなじり深き伯楽は、　　しんぶんをこそひろげたれ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一（登場　枯れた陸稲をもっている）「稲の伯楽づのぁ、こっちだべすか。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四季の里は俳名｜馬好と号した常に馬を楽んだ風狂の伯楽が初めて営んだものだそうであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落では、いつの間にか彼を（伝平）とは呼ばずに（伯楽）と呼ぶようになっていた。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝平はそして（伯楽）と呼ばれることが限りもなく嬉しいらしかった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯楽も、馬々って、馬をほしがっていだっけ、駒馬さは手が届かなかったど見えで、牝馬にしたで。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒馬を貸して置く代わりに、伯楽から、牝馬を奪ってるって話でねえか。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯楽も、一年からなるのに、感付かねえのかなあ。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、伯楽は、馬どなるど、眼がねえからなあ。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、伯楽の方で、馬が……」「旦那様！",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伯楽は、なんのつもりで、馬を買ったんだべ？",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬を遊ばせて置いて、伯楽は自分で重いものを背負っているじゃねえか？",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸旗本早乙女主水之介、松平の御前にお目通り願わしゅう存じまするが、いかがにござりましょう」「なになに、旗本とな――」　声をきいて、源七郎君お自ら磊落そうにふり向くと、流れに垂れた釣竿をあやつりあやしつつ、じいッと退屈男をやや暫し見守っていたが、伯楽よく千里の馬を知るとはまさにこれです。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このだゞつ広いがらん洞には私の他に同居の者はＲとＺの二人の若い伯楽だつたが、彼等は近頃急に酒嫌ひになつた私に遠慮して斯様な場所で密かな酒盛を開いてゐたと見えるが、この時は私はそんな推察を回らせたわけではない。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは伯楽の堪七の顔である。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お天気でも変らなければ好いがね……」「さすがは東京の伯楽だと見えて、あの極道馬を見事に乗りこなすぢやないか！",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本探偵小説界の、伯楽の長たる森下氏が、既成文壇の人達へ、依嘱するのも結構であるが、斯ういう人達へ慫慂して、探偵小説を作らせたなら、更に一層結構かもしれない。",
              "citation": {
                "source": "探偵小説を作って貰い度い人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "では厭でも小酒井不木氏、森下雨村氏、松本泰氏、こういう人達にお願いし、是非伯楽になって貰い、驥北の野でも散歩して貰い、所謂千里の駒なるものを、至急目付けて貰うより、他に手段は無さそうである。",
              "citation": {
                "source": "日本探偵小説界寸評",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日｜伯楽のやうな男が二人づれで、青木家の厩の前で切りにドリアンの品定めをしてゐるので、雪子は不快に思つて訊ねると、「あんたは御存知ないんですか、ドリアンを受とりに来たんですよ、村長さんの御いひつけで――」　と空々しくいひ放つた。",
              "citation": {
                "source": "ダイアナの馬",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯楽が、ドリアンの手綱を引いて門を出て行かうとした時雪子は、吾を忘れて、常々から、ドリアンにだけ通じる意味の最も鋭い口笛を鳴した。",
              "citation": {
                "source": "ダイアナの馬",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見た伯楽は眼の色をかへて、暴れ馬を取りおさへにかゝつたが、馬のたゞならぬ気合におそれをなして（馬は二人の男に蹄をあげて飛びかゝりさうな勢ひを示した。",
              "citation": {
                "source": "ダイアナの馬",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あべこべに伯楽に向つて追ひかけさうになつた。",
              "citation": {
                "source": "ダイアナの馬",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "田地もあったが、種馬を何十匹となく飼っておいて、それから仔馬を取って、馬市へも出せば伯楽が買いにも来る――。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今｜伯楽の一顧を得て、奔※して千里を致すの思があります。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは馬政紀、馬記、元享療牛馬駝集、伯楽相馬経等の諸書に従い、彼の脚の興奮したのはこう言うためだったと確信している。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "千里の馬も伯楽がどうとやらといいます。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです伯楽になっては。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千里の馬ありといえども、伯楽なきをいかにせん、千里のだちょうありといえども、きみらには価値がわからない」「文句をいわずに乗って見せたまえ」「しからば乗って見せてやろうか、だちょうの快足とぼくの馬術を見て、びっくりしてこしを抜かすなよ」　サービスはこういって、だちょうの首をしずかになでた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "其末孫或云伯楽或云連索、（注略）或云唐土。",
              "citation": {
                "source": "サンカ者名義考",
                "author": "――サンカモノは坂の者",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがよほど見分けにくい馬と見えて、名高いばくろうの名人でも、やはり首をかしげて考え込むばかりでした。",
              "citation": {
                "source": "姨捨山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
