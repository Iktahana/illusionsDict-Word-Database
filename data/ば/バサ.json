        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "オババサンニ可愛イ言葉。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも手紙の終りに『オババサマニヨロシク』とか『オババサマニ可愛イ言葉』とか書いている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "オババサマとは彼の妻の母であって、名義上、小泉家の養子たる彼にとっては、姑の義母に当る老婦人である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "バサバサと凍った雪を踏んで、月光のなかを、彼は美しい想念に涵りながら歩いた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓外、庭ノ黒土ヲバサバサ這イズリマワッテイル醜キ秋ノ蝶ヲ見ル。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声は又青ぞらの方まで行き途中から、バサリと樺の木の方へ落ちました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、穿いた草履が、笹葉でも踏む心持にバサリとする。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、今日の温泉旅館に宿泊する人たちは思い切ってサバサバしたものである。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろサバサバしている。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の私の態度と来たら、まるではたの人がはらはらしたくらい、不機嫌そのものであったから、もう私は嫌われたも同然だと、むしろサバサバする気持だったが、暫らくして来た返事は不思議にも気に入ったとのことで、すっかり驚いた。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙殺してしまうと、サバサバした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは送り狼になりたくたい」　そう思ったので、小沢はもうサバサバした声で言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、何かサバサバした気持だった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊都子のように問題がサバサバとあっけなく過ぎて行きそうには思えなかったのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪屋も畳屋も同じ手職稼業でたいした違いはないようなものの、おたかにしてみれば口惜しいほど格式が落ちたと思われ、だから断るにもサバサバした気持だった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかあさま……」「……何ですか……」「アノネ……おうちのお茶の間の壁が、こないだの地震の時に割れているでショ……ネ……ギザギザになって……あそこにどこかのオジサマやオバサマの顔があってよ。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オウマノ　ヲバサン、コノ　セカイハ　ナント　イフ　ウツクシイ　ヨイ　トコロデセウ」ト　花ノ　ヒトツガ　イヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オヤ、ヲバサン、アカンボガ　ウマレルノデスカ」「モウ　ウマレテ　ヲリマス。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オヤ　ミナサン」ト　ソノ　トキ　ウマノ　ヲバサンガ　イヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　ソノ　トキ　マドカラ　ミテ　ヰタ　オウマノ　ヲバサンガ、「テフテフデスヨ」ト　花タチニ　シラセマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オウマノ　ヲバサン　コンニチハ」「オヤ　テフテフサン　コンニチハ」「アカチヤンノ　オメメハ　アキマシタカ」「ケサ　ヤツト　アキマシタ」　ミルト　オウマノ　アカンボハ　ネワラノ　ナカデ　パツチリ　オメメヲ　アケテ　オトナシク　シテ　ヰマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミチコサン新美南吉　ミチコサンガ、コトリヤノ　マヘマデ　クルト、シラナイ　オバサンガ、ウバグルマノ　ナカノ　ニモツヲ　ナホシテ　ヰマシタ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミチコサンハ、オバサンノ　ソバニ　ヨツテ、「アカチヤン　ダイテテ　アゲマセウカ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「イイワ　オバサン。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　オバサンハ　アカチヤンヲ　ミチコサンニ　ダツコサセテ　クレマシタ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ　ウチニ　オバサンハ　スツカリ　ウバグルマノ　ナカヲ　カタヅケテ、「スミマセンデシタ、ホントウニ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
