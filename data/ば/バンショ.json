      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "guardhouse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三番と掛札した踏切を越えると桜木町で辻に交番所がある。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから元来た道を交番所の前まであるいてここから曲らずに真直ぐに行くとまた踏切を越えねばならぬ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳がお小夜に一杯呑めと盃をさし、Ｔ「其方を番所へ引ッ立てるとは申さん」　と言って、Ｔ「其処は魚心あれば何とやら」　と言って、Ｔ「身共の一味に加わらぬか？",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屋の亭主こそ実に迷惑で、それがために思いもよらない災難をうけて、一旦は召し捕られたり、その後もたびたび番所へ呼び出されたり、どうもひどい目に逢いましたが、右の事情が判って無事に済みました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑問の帯は辻番所にひとまず保管されることになって、そのまま二日ばかり経つと、ここにまた思いも寄らない事実が発見された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）７０＝（Ｆ・Ｉ）番所　漸く釈放されたお兼と敬四郎は迎えに来た松公と共に帰る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）70＝（Ｆ・Ｉ）番所　漸く釈放されたお兼と敬四郎は迎えに来た松公と共に帰る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、こいつはさっき一ぺん私が番所から追ひ帰したのです。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめへは行って番所に居ろ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分ののちこの変な行列があの番所の少し向ふを通ってゐた。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私があけ番の時、宵のうたゝねから覺めて辻へ出ると、こゝにつめてゐた當夜の御番が「先刻、あなたのとこへお客がありましてね、門をのぞきなさるから、あゝ泉をおたづねですかと、番所から聲を掛けますと、いや用ではありません――番だといふから、ちよつと見に來ました、といつてお歸りになりました。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕橋吾妻橋も過ぎて、蔵前通りを南へ、須賀橋といふにさしかゝりける折しも、橋のほとりの交番所にて巡査の誰何するところとなりぬ。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の静な時は大い角の龍が底に沈んだやうで、風がさら／＼と吹く時は、胴中に成つて水の面を鱗が走るで、お城の様子が覗けるだから、以前は沼の周囲に御番所が有つた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、交番所の巡査に呼び停められた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　巡査は京吉と靴磨きの娘を、交番所の中へ連れてはいった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、陽子を乗せたジープは、交番所の横を軽快な響きを立てて走って行った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そんな一寸した騒ぎのおかげで、到頭交番所の中にいる京吉には気がつかなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月ヶ瀬」は戎橋の停留所から難波へ行く道の交番所の隣にあるしるこ屋で、もとは大阪の御寮人さん達の息抜き場所であったが、いまは大阪の近代娘がまるで女学校の同窓会をひらいたように、はでに詰め掛けている。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが御番所の森です」　幽邃な左岸の林に釣人がいる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾谷の下る筏を見張った御番所の跡であるらしい。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "門番所の窓の下に行って、いちが「もしもし」とたびたび繰り返して呼んだ。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには某藩侯の辻番所がある。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも単に某藩侯とのみ記してあるが、下谷御徒町というからは、おそらく立花家の辻番所であろう。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辻番所の前を通りかかると、番人のひとりが彼の中間に眼をつけて呼びとめた。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　由来、武家の辻番所には「生きた親爺の捨て所」と川柳に嘲られるような、半｜耄碌の老人の詰めているのが多いのであるが、ここには「筋骨たくましき血気の若侍のみ詰めいたれば、世の人常に恐れをなしけり」と原文に書いてある。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに評議したところで、結局どうにも解決の付けようがないので、武勇を誇るこの辻番所の若侍らも伊平をそのまま釈放してしまった。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻番所でも相当に暇取ったので、長い両国橋を渡って御米蔵に近い稲城の屋敷へ帰り着いたころには、日もまったく暮れ切っていた。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとそれを報告するつもりで帰って来たのであるから、伊平は下谷の辻番所におけるいっさいの出来事を訴えると、八太郎は勿論、客の池部も眉をよせた。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件はそれで済んだのであるが、八太郎はまだ何だか気になるので、二、三日過ぎた後、下谷の方角へ出向いたついでに、かの辻番所に立寄って聞きあわせると、番人らは確かにその事実のあったことを認めた。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私のやり切れなかった心も知らず、まじめに言うので、私はいよいよやりきれなく、この世で一ばんしょげてしまいました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
