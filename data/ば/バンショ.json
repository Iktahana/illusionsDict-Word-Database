[
  {
    "uuid": "2f511c4b-347a-593e-b171-3ce1d2acb4bb",
    "entry": "番所",
    "reading": {
      "primary": "ばんしょ",
      "alternatives": [
        "ばんどころ"
      ],
      "is_heteronym": false
    },
    "grammar": {
