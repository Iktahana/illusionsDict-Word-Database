[
  {
    "uuid": "00efb495-ade8-58d6-9f84-8225fc064c7a",
    "entry": "番号",
    "reading": {
      "primary": "ばんごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "number",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして気をつけて見ると、そこらには、蹄の二つある足跡のついた岩が、四角に十ばかり、きれいに切り取られて番号がつけられてありました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一歩進んで姓名の代りに囚人のように三一六五八九二四といったような番号をつけるのも最合理的な一方法であるかもしれないが、そうなるのはやはり悲しい。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師が賛美歌の番号を知らすと、堂のすみから、ものものしい重い、低い調子でオルガンの一くさり、それを合図に一同が立つ。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の記号と、番号のはいった四角の杭が次々に、麦畑の中へ打たれて行った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "富沢は地図のその点に橙を塗って番号を書きながら読んだ。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉田は岩石の標本番号をあらためて包み直したりレッテルを張ったりした。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友はまた京都にいた時代、電車の窓と窓がすれちがうとき「あちらの第何番目の窓にいる娘が今度自分の生活に交渉を持って来るのだ」とその番号を心のなかで極め、託宣を聴くような気持ですれちがうのを待っていた――そんなことをした時もあったとその日云っておりました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "：入力者注　主に外字の説明や、傍点の位置の指定　　　（数字は、JIS X 0213の面区点番号、底本のページと行数）（例）※いたり、-------------------------------------------------------　旅行に就いて何か経験上の談話をしろと仰ゃるのですか。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何番という番号のついた売り場に妻子をつれて買い物に来ている人が幾組もある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた犯人と目星をつけた女の居所を捜すのに電話番号簿を片端からしらみつぶしに呼び出しをかける場面などもやはり一つの思いつきである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話の番号じゃあるまいし、ちゃんと正しい読みかたをしてもらいたいものだ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、電話の番号帳により、キヌ子のアパートの所番地を調べ、ウイスキイ一本とピイナツを二袋だけ買い求め、腹がへったらキヌ子に何かおごらせてやろうという下心、そうしてウイスキイをがぶがぶ飲んで、酔いつぶれた振りをして寝てしまえば、あとは、こっちのものだ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼女が、わざわざ遠方から大久保の自邸に呼び寄せているタキシーの番号を一々ノートに控えた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その番号から運転手の名前を探り出して、鼻薬を使いながら未亡人の行先を尋ねてみると、私の着眼が一々的中している事が裏書きされて来た。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処から出た爆薬だってことは直ぐに番号でわかるんですからねえ」　青年は深々と念入りにうなずいた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大急ぎで洋服を脱いで、衣桁に引っかけてあった浴衣に手早く袖を通し、泥だらけの洋服とワイシャツとズボンを丸めて、番号札のついた脱衣戸棚と天井裏との間に出来ている暗がりに突込んだ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の番号をチョット見上げながら静かに障子を開いた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様が門司から直方へ乗りつけたタクシーの番号までわかっているとは知らなかったろう」「どうもありがとう御座いましたわねえ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど御通知の番号の車で、この青年が見えましたから気をつけてお話を聞いておりますと、ポートサイドあたりへいらっした方にしては、すこし色が白過ぎるんですものねえ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばド・ヴァレーズ伯爵がけしからぬ犯行の現場から下着のままで街頭に飛び出し、おりから通りかかったマラソン競走の中に紛れ込み、店先の値段札を胸におっつけて選手の番号に擬するような、卑猥であくどい茶番はヤンキー王国の顧客にはぜひとも必要なものであろう。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、私は静かに眼を開き安静な気持ちで受験番号や名前も書き入れ、問題の解答を書き進めて行きました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家鴨料理ツール・ダルジャン　家鴨の番号数二万――八。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を出るとき家鴨の番号を記入したカードをマネージャーが恭しく客に差し出す。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お千世は引入れられたように返事して、二人の目の熟と合う時、自働電話に備付の番号帳がパタリと鳴る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのつめくさの花の番号を数えて行くというのだろう。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そら、ね、ごらん、そうだろう、それに番号がついてるんだよ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と十二人の兵隊がばんごうをいってしまいました。",
              "citation": {
                "source": "子どものすきな神さま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さくひんばんごう１。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さくひんばんごう２はこんなかんじ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さくひんばんごう１と２がだめだったから、めげてしまったんだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
