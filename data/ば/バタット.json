        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おやおやとおもっているうちに上からばたっと行李の蓋が落ちてきました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土神はいかにも嬉しさうににやにやにやにや笑って寝そべったまゝそれを見てゐましたが間もなく木樵がすっかり逆上せて疲れてばたっと水の中に倒れてしまひますと、ゆっくりと立ちあがりました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬屋のうしろのほうで何か戸がばたっと倒れ、馬はぶるっと鼻を鳴らしました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土神はいかにも嬉しそうににやにやにやにや笑って寝そべったままそれを見ていましたが間もなく木樵がすっかり逆上せて疲れてばたっと水の中に倒れてしまいますと、ゆっくりと立ちあがりました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして硝子にはげしく頭をぶっつけてばたっと下へ落ちました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸はややともすると読みかけている書物をばたっと取り落して眼がさめたりした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬屋のうしろの方で何かの戸がばたっと倒れ馬はぶるるっと鼻を鳴らしました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネネムは泣いてどなって森の中をうろうろうろうろはせ歩きましたがとうとう疲れてばたっと倒れてしまいました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く縄を、笠松博士を掴まえたから」　刑事達はそのポケットから麻縄を出しながらばたばたっと駈けて行った。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその煙草の火が蜻蛉の身体に触れたと思った瞬間に、既に首を失っている蜻蛉の屍は、ばたばたっと暴れまわった。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手に使えばたっといものですが、ぜひとも手にいれるべき第一のものとか、ごほうびとか思ってはこまります。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と、すぐばたばたっと附近から雁のように立った跫音を、兵部は、知っていたが、黙然と、空を見ていた。",
              "citation": {
                "source": "無宿人国記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ばたばたっと家の中へ、駈けこんで来て、姉へ告げた。",
              "citation": {
                "source": "無宿人国記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やい危ねえぞ」と長はライオンに呼びかける、「そっちいいくと捉まっちまうぞ、いっちゃだめだ、ええ、だめだってえにな、捉まっちまうったらな、ええライオンのばかやつら、こっちい来いってば」　ライオンは檻の罠にはいり、仕掛けの戸がばたっと落ちる。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髷の根がゆるんで揺れ、釵がばたっと落ちた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うるさいね」と女が眠ったまま云った、「しつっこい人だね、触らないでよ、うるさい」　そして、掛け夜具をもっと剥ぎ、ばたっと手足を投げだした。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウーム……」さしもの四郎も、二つ三つ、足をよろめかせたまま、ばたっと、そこへ昏倒してしまった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ半町ほど行くと、ばたっと、門人達の手へ仆れてしまった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "賊の頭目はばたばたっと、それへ向って逃げて行きながら、「燈を消せっ」　と呶鳴った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばたばたばたっと、犬のように迅く走り寄って、老先生の足元に、ペタリと額いた人間があった。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今――ばたばたっと夕闇を蹌めくように駈けて来た旅の浪人者があった。",
              "citation": {
                "source": "夕顔の門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物に衝き当った蝙蝠のように、お市が、門を出て来た出会い頭に、そこの土塀にぶつかって、ばたっと仆れたかと思うと、『た、助けて下さい。",
              "citation": {
                "source": "夕顔の門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その時、表へ出て行ったお次が、あれっと、悲鳴をあげて、ばたばたっと、逃げ惑うような跫音を立てた。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵部の痩せている体は、ばたっと畳へ投げ出されたが、手は放さなかった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばたばたっと駈けて来る跫音がした。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……先生ッ」「武蔵どの」　ばたばたっと、足もとへ転び伏すばかりに、駈け寄って来た者があった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
