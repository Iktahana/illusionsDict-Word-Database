          "literary": [
            {
              "text": "バラ園の端で振り返った。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸宅よりも古いチューダー様式建築で、豪華な門を備え、バラ園は一帯で有名だった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラ園の真上に月が静かに輝き、向こうの古い門を銀色に染める様は、過去二百年間変わらない情景だろう。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラ園の下で待っていますよ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "領主がいないから、スライトがきっと歓迎してくれます」第六十章　公表　長い間、全員でバラ園に座り、静かに公園を眺めていた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラ園は奥まった楽しいところなので、そちらへ行った。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
