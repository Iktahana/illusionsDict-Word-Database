    "definitions": [
      {
        "index": 1,
        "gloss": "balun (transformer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
