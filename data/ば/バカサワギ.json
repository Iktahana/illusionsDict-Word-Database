        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのあとに、知友に死去を披露して、ドンチャンのバカ騒ぎを一晩やりなさい。",
              "citation": {
                "source": "私の葬式",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当のバカ騒ぎでありアゲクが色々なことゝなる。",
              "citation": {
                "source": "釣り師の心境",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔っぱらって気が大きくなって、酒場へのりこんであれを飲めこれを食えというバカ騒ぎをやらかす。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すると、記代子さんは、皆さんとお友だちになりたくて、遊びに行かれたのでしょうか」「お友だちになりたいッてわけではないでしょうけど、男のお客さん方のように、バカ騒ぎしたいような気持――女ですから、バカ騒ぎはないでしょうけど、小説などにありますでしょう。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレがそれと入れ違いに大部屋へ戻った時は、だらしなくノビた奴も半分いたが、半分はまだバカ騒ぎの最中よ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろバカ騒ぎの最中だし、半分は酔い倒れていやがるし、ロウソクは薄暗えや。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、このケバケバしくグロテスクな生命力の誇示、そうぞうしい集団発狂のようなバカ騒ぎが、どうして死者への手向けなのだろうか？",
              "citation": {
                "source": "ジャンの新盆",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ二日も無節操なバカ騒ぎがあり、木曜夜オペラハウスの仮装舞踏会で頂点に達する。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん内側のバカ騒ぎが静まった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "神殿でバカ騒ぎを、月一回やる。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "小突き合いとか、バカ騒ぎとか、そのたぐいはない。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらないばかさわぎの映画よりも、もっと動いているのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
