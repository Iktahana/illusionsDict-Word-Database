[
  {
    "uuid": "165122ad-b0ca-55ed-bf29-faee4cb333c4",
    "entry": "蛮勇",
    "reading": {
      "primary": "ばんゆう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
