    "definitions": [
      {
        "index": 1,
        "gloss": "balcony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人々はドストエフスキーを読みバルザックを読み、※ルレーヌを読むが、そして面白いといふのであるが、果してそれらの「流れ」、つまり持続を面白いといつてゐるのであらうか、それとも部分々々を面白いと思つたものであらうか？",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "東郷提督の命令一下で、露国のバルチック艦隊を一挙に撃滅なさるための、大激戦の最中だったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎょっとして振りむくと、馬場の右脇にコバルト色の学生服を着た背のきわめてひくい若い男がひっそり立っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "云つてみれば、ポンプに於てバルヴは非常に大切だ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルトの空には玉子色の綿雲が流れて、遠景の広野の果の丘陵に紫の影を落す。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……王の射手エーナール・タンバルスケルヴェはエリック伯をねらって矢を送ると、伯の頭上をかすめて舵柄にぐざと立つ。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "セーフチーバルヴが、慌てて呻り出した。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働者のいない船が、バルコンを散歩するブルジョアのように、油ぎった海の上を逍遥し始めた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマシン油たるや、充分に運転しているジャックハムマーの、蝶バルブや、外部の鉄錆を溶け込ませているのであったから、それは全く、雪と墨と程のよい対照を為した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春の香水、ヴィオレット・ド・バルム」気が利き過ぎて却って張り合いがない。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルチック海から吹き渡って来る酷風が、街の粉雪の裾を斜に煽る。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしのバルドラの野原に一ぴきの蝎がゐて小さな虫やなんか殺してたべて生きてゐたんですって。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の友人の中には George Darwin も居たが、違った方面の友では Arthur Balfour すなわち後の首相バルフォーア卿と親交を結んだ。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先、一八六九年にロンドンで彼の学友アーサー・バルフォーアの二人の姉妹エリーノア（Eleanor）とイヴリン（Evelyn）とに紹介され、その後しばしば出遭う機会があった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七一年の五月にイヴリン・バルフォーアと婚約し、七月十九日に結婚式を挙げた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてアーサー・バルフォーアの近頃求めた No. 4 Carlton Gardens に落着いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病後の冬休みにはイタリアへ転地し、フロレンス近くのバルフォーア家の別荘に落着いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーサー・バルフォーアは手紙で彼を激励した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "義兄弟のバルフォーア、当時のアイルランド政務総監がターリングへ遊びに来た時は護衛の警官が十二人もついて来たりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味でジョルジュ・サンドやデューマやバルザックなどの出て来る社交場の光景なども面白い。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊の撲滅　北米バルチモアーでは蚊のためにいろんな病気の流行るのを防ぐために一昨年市会で二万円ほど支出して撲滅にかかったが、結果がよかったので今年また一万円ほど支出したそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空には今日もアドバルンと来やがらア」　装甲自動車の列。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもケエラの小さな館のいつも同じ部屋にゐるユゥジェニイと、あの虚榮の權化のやうなジュウル・バルベイ・ドオルヴィリとの二人が、共に彼のために日記を書いてゐたといふことを思つてみると、おほよそゲランの内部の擴がりの見當はつくはずだ。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、バルベイの死後公にせられた「メモランダ」は、彼の初期の詩「アマイイド」とすこしも矛盾はしてゐないのである。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達の曲芸団はマルセーユの興行を打揚げると、スペインのバルセロナの街に小屋を下しました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘がバルセロナの古い歴史を呼びさますようにえんえんと鳴る。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルセロナの市長夫妻が、古風なスペイン服で高い桟敷につくと、金と紅で美装した闘牛士の群が騎馬で出て来て、司会者の前で昔ながらの武士的な挨拶をするのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルザックの寝巻姿　数ヶ月後、妾達の東洋曲芸団の一行は、巴里のゲエテ街にいました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達の列車が巴里盆地にさしかかると、佐野は何の理由もなしに、巴里を極度に嫌がって、バルセロナを懐しがったりして、女のように神経質になっていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが寝巻姿のバルザックの像でした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
