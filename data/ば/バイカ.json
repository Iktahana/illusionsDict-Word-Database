[
  {
    "uuid": "bf3923d3-8a7e-55a7-8ee1-c3ca7bf57fc0",
    "entry": "貝貨",
    "reading": {
      "primary": "ばいか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
