          "standard": [],
          "literary": [
            {
              "text": "彼はバスケットを車室に置くと、その方へ行つてたのでその吹き出してるところも見せられた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の詩万歳だ」　彼はバスケットから葉書を出してさう書いて母に送つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "千の天使が　　バスケットボールする。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にはバスケット、足には下駄とな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、座席へバスケットを置くと、そのまま食堂車に入った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、彼が座席の上に置いてあったバスケットは、そこに無かった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてな、俺のバスケットをどこへ持って行きやがったんだろう。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスケットの中味を覗いたのたあ違うかい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃお前のバスケットかい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は少年の踏んでいるバスケットを顎でしゃくって見せた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ一体あのバスケットは、誰のものなんだい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが誰のものだろうが、そのバスケットは自分のものでなければ収拾する事が出来なかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏んづけちゃ困るね」「そんな大切なものなら、打っ捨らかしとかなけゃいいじゃないか」　少年は眼を瞑ったまま、バスケットから足をとった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だってバスケットを坐らせといて立っていたくねえや」「チョッ、喧嘩にもならねえや」「当り前さ」　少年は眼を開いた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらバスケットを取ってくんなよ」「ほら。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "物騒な話だ）　彼はバスケットを提げて、食堂車を抜けて二等車に入った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなバスケットや信玄袋の中から取り出した殘りものゝ鹽煎餅やサンドウイッチを片付けて居た生徒達の一人が、さういふものゝ包紙を細かく引き裂いては窓から飛ばせ始めると、風下の窓から手を出して其れを取らうとするものが幾人も出て來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が三毛猫だけ連れてもう一匹の玉の方は置いて行こうと云ったら、子供等がどうしても連れて行くと云ってバスケットかなんかを用意していた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……がしかし……仕事のむずかしいのはここまでで、アトは何でもありません」「そんなものですかねえ」「その水雷の外側をランチのバスケットか何かに見えるように籠で包んで、籤取りできめた五、六人がボートに乗って、舟遊びみたいな恰好でズット沖に出てしまいます。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなバスケットや信玄袋の中から取り出した残りものの塩せんべいやサンドウイッチを片付けていた生徒たちの一人が、そういうものの包み紙を細かく引き裂いては窓から飛ばせ始めると、風下の窓から手を出してそれを取ろうとするものが幾人も出て来た。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の子は恭しくバスケットから、狼煙玉を持ち出しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……燗をさせるのも面倒だから、バスケットの中へ持参のウイスキイを一口。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスケットボールが好きで、ＹＭＣＡへ行って、お夕飯ぎりぎりでなきゃ帰って来ないの、ほほほ」　子供のように夫を見做しているような彼女の口振りに、夫を愛していないとも受取れない判断を下すことは、復一に取ってとても苦痛だった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い服に、麻のあみぐつをはいて、うでにバスケットをさげていました。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "万年筆いかが」と、バスケットをあけて、受付の男の前につきだしました。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国人はバスケットの始末をして、ていねいにおじぎをして、出ていこうとしました。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスケットも、ちらほら見える。",
              "citation": {
                "source": "座興に非ず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスケットに、等閑に絡めたままの、城あとの崩れ堀の苔むす石垣を這って枯れ残った小さな蔦の紅の、鶫の血のしたたるごときのを見るにつけても。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスケットの、蔦の血を見るにつけても、青い呼吸をついてぐったりした。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
