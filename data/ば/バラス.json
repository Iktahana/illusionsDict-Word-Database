    "definitions": [
      {
        "index": 1,
        "gloss": "ballast (for the foundation of a road or railway track)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昼過ぎから猛烈な吹雪が襲って来たので、捲上の人夫や、捨場の人夫や、バラス取り、砂揚げの連中は「五分」で上ってしまった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人物が残した古文書的の遺産は、無駄なバラストとして記憶の重荷になるばかりである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その火葬場のすぐ上流は、発電所工事の砂やバラスの採集所になっていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺は、釣橋を渡ったり、新らしくできた道路を通ったり、そのまだ開通しない個所から急に、山の断崖を河原に下ったり、バラス採集所の掘り残しの狭い高いところを通ったりして、火葬場まで行かねばならなかった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の線路工事に必要な、コンクリ材料の砂やバラス、玉石などを、本流の川原からウインチで捲き上げようと云ふ段取りなのであつた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず現われて来るのは、市会議員の或る一派が往来のバラスや、市で使う石炭や、水道の鉄管や、又はあの大きな瓦斯タンクなぞをバリバリ喰っているところである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先、バラスや鉄管や石炭、木材、セメントなぞいう、自治制のうま味をタップリ含んだ「復旧」、又は「復興」と名づくる御馳走の材料がどれ位入るかわからない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のうちに源次の手でバラスが運ばれて、そこに山と積んである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラスが畚に入れられて下ろされる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介が覗いて見てゐると、駒平はそれらのバラスを、並べた石の裏側、一尺五寸ほどの空隙へぎつしり詰め込んでゐるのだつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラスが路面にはみ出してゐるやうな道なので、音は殊更に大きく、通り拔ける時、馬の手綱を取つてゐる男が何か云つたのも駿介には聞きとれなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは農閑期を利用し國道、縣道、村道の何れを問はず、あらゆる道路の修繕を引き受けてやるもので、川のバラスや砂の權利を持つことが出來、必要な時には村有林の木を伐り出す自由を持つことが出來るが、元來が奉仕的な仕事であるから、勞働に對する報酬は殆どなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兩方の端は太い角材でしつかり固め、ずり動かぬやうにし、その上にバラスと土をかぶせて、踏みしめ踏みしめ固めて行く。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "水はもう殆ど涸れてゐるが、河原にバラスや砂の豐富な川までは、ここから一番遠いのであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "土やバラスは豐富に使つて押し固めねば、しつかりした道は出來なかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日取りかかつた修繕箇所は、敷き並べた丸太の上に、土とバラスが交互に敷かれ、その上が踏み固められ、もう殆ど出來上つてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのあたり一帶の路面が、全體から見るとひどく窪んでゐたので、ずつと高めるために、バラスと土は多くいるのだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　処女航海から帰英した時、老船長イルベリイ氏は、ワラタ号に別に不完全なところはないが、只ドックへ這入るのにバラスト――安定を与えるために船底に積み込む砂、砕石、又は水の類――の重みを藉りなければならない程、すこし安定が取れていないようだということを、会社へ報告した。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラスか釣りあげるかの瞬間には、いかな名人でも心臓が高鳴る。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家は煤だらけにくすぶり返ッて、見る影もないアバラス堂で、稗史などによく出ている山中の一軒家という書割であッた。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯後藤睦美君が、バラスト管の代用品をこしらえてくれた。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ｍのスエ子に対する批評「バーバラスだ」とか「非常識だ」とか「たださえ人とかわって居るんだからね」等。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラスと砂混りの粘土で、どうにもならない盤が、掘り返されて、むき出しになってしまう。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あたしのいのちをカセにして、どうでもバラスはずはあるまいと、多寡をくくってるのかも知れないが、今日只今、もう命なんか惜しくない。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、仲間を呼ばうにも、手紙が出せないつていふ情ない状態で、やつとブラジルのトレスバラスつていふところへ出て、そこの日本人部落から一人二人引張つて行つて珈琲の栽培をはじめましたんですつて。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度田辺で会ひました父の友達つて申しますのが、そのトレスバラスから引つ張つて行つた仲間の一人で、父が一家を纏めて日本へ帰つて参りました後を、すつかり引受けてやつてゐるらしいんですの」　話の間、田沢は、時々、手酌で盃を満しては、飲み飲みしてゐた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う側の足の下のバラスの所ば掘つてくれ、さうすれば抜けるんだ！",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "与えられた仕事は京城市の東南の龍山にある漢江の河原に出て、朝鮮人のバラスとりの監督をするのである。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラスが十分入れられていない赭土道が、乱暴なトラックの往来で幾条も車軸がめりこむほどの深さにほじくりかえされている。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラストタンクを調整して、浸水させて、大混乱させろ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
