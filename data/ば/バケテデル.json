    "definitions": [
      {
        "index": 1,
        "gloss": "to become a wandering ghost",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれさ妄念が可恐しい、化けて出るからお止しよといえば、だから坊はね、おいらのせいじゃあないぞッて、そう言わあ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、普通の日本人の考慮から云うと、殺した方の人が化けて出るというのは、些と理屈に合わぬように聞えるが、何分にも其処が怪談、万事不可思議の所が事実譚の価値であろう。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは、まあ、自業自得で仕方がないとしても、あたしにまで、こんな赤い太鼓の片棒かつがせて、チンドン屋みたいな事をさせてさ、お母さんはきっと、お父さんをうらんで、化けて出るわよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か化けて出る因縁があるに相違ないと思いましたからね、思い切って聞いて試ようと、さあ、事が極ると日の暮れるのが待遠いよう。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「晩に雀が化けて出るぞ。",
              "citation": {
                "source": "周一と空気銃とハーモニカ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "女というものは殺すと化けて出るものである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが生きていればきっと仕返しをする、死ねば化けて出る、どっちにしても唯は置かねえから覚悟しろと、おそろしい顔をして散々に呶鳴ったそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅公が幽霊となって、時平のところへ化けて出るところをかいた、天神｜縁起の菅公の幽霊は、生前の菅公をそのままにかいてある。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『みんな、見物ばかりしてねえで、お酒でも買って上げな、そうしねえてと今夜この仏様がよ、打ち掛け姿で礼に廻って歩くと……』　爺さんが気味の悪い冗談をいうと皆も、『何も化けて出るこたありゃしまい、散々思いあって思う男と死に遂げるなんて、こんな甘い話があるもんかい。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか夜中に化けて出るといふのでも無いだらう。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "化けて出るいひまんねぜ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、化けて出るつて？",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し此の邊には顏の白い狐が化けて出るとは其後聞き及んだことである。",
              "citation": {
                "source": "温泉雜記",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど小説にかきつづりて世に伝へんとする好事家もなかりしかば化けて出る噂もほどなく消えてしまひけり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "本堂の縁にでも腰をかけて、お夏狐の化けて出るのを相待とうではござらぬか」　木村常陸介はこう云いながら伴侶の山尾を返り見た。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "化けて出るだけのね」　軽蔑しきった口調、たすからないほど冷めたい。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――岸田のその時の頭具合でなしには絶対に世の中へ化けて出る手だてのない、新鮮な化けもの達である。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それが何うしたんだ」「五つまでには、來なきやならないんだが」「誰が來るんだ、借金取か、叔母さんか」「そんな氣のきかねえ代物ぢやありませんよ」「叔母さんまで氣のきかねえ代物にされたのか、それぢや新造か年増か、どうせ宵の口から化けて出るエテ物だらう」　平次はからかひ面でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の踊り子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその懷ろ時計を搜せといふのか、弟子の爲三郎を殺した下手人を擧げろといふのか」「爲三郎なんか唯の奉公人で、殺されたつて化けて出る張合ひもない野郎だが、懷ろ時計はもつたいなくも上樣からのお預りの大事な品だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御時計師",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、その氣味の惡さといふものは、――なる程、殺されて化けて出るのは、大抵美い女ときまつてるやうだが、お多福ぢやあの凄味に出ませんね」「何をつまらねえことを。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もあんな女と三日も添ひ遂げた上ならコロリと死んでも化けて出るやうな未練がましいことはしませんがね」　そんな大平樂を言ふ八五郎です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒酒藥酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の良い娘は化けて出るほどの氣力もないらしいが、親の私は腹の蟲が納まらない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな慾張りは、幽靈火一つでもケチにするから、死んだつて化けて出る氣遣はありません」　何んと言ふ言ひ草でせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘の守袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの坊主が字なんか書いたら、夜な／＼ゲヂゲヂになつて化けて出るでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "闇に飛ぶ箭",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の良い娘は化けて出るほどの気力もないらしいが、親の私は腹の虫が納まらない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し嘗めて見ないか、八」「御免蒙りましょう、あっしはまだ死ぬのに少し早いようでもっともあんな女と三日も添い遂げた上ならコロリと死んでも化けて出るような未練がましいことはしませんがね」　そんな太平楽を言う八五郎です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "毒酒薬酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あってもなくてもいいのに、おしゃれだね、きみは、」「だって晩にはしくしくと何時までも疼いて、どうにも手がつけられないんですもの、おじさまがそんなに冷淡なこと仰有ると、化けて出るわよ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "一遍、男を振って置いて、自分で逢いたい時には化けて出るなんて、都合の好い化け者もこの世の中にはいるもんだナ、あばよ、一昨日お出でだ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論……剥製の鳥が化けて出るなどとという事も信じようとは思いません。",
              "citation": {
                "source": "廃灯台の怪鳥",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
