[
  {
    "uuid": "a409fc63-4f24-5ae5-abce-992bc2e6fe9e",
    "entry": "バイト",
    "reading": {
      "primary": "バイト",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
