      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "part-time job",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは科学的のアルバイトというものの本性に関する認識不足から起こる現象である。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日程経った頃だったろうか、千日前のお午の夜店で、夜店外れの薄暗い場所に、しかもカーバイト代を節約した一層薄暗い店を張っていると、おっさん一杯くれと若い男が前に立った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむなくアルバイトで図書整理の仕事を続け、気にかけてくれたバイト先の人の口利きで、編集プロダクションに紛れ込みました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "標準的に使われているフロッピーディスクの容量は、一・四メガバイトです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "メガは百万を意味しますから、一枚で百四十万バイト。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語一文字は二バイトで表現できるので、七十万字がおさまる勘定です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "広く使われるようになってきたＣＤ―ＲＯＭならさらに、フロッピーディスクの五百倍近い六百五十メガバイトまで入ります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生時代のミニコミ作りや出版社でのアルバイトでじょじょに慣れていったせいか、私自身はそれほど驚いた記憶はありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、編集プロダクションに籍を置いていた当時は、経験なしに入ってきたスタッフやアルバイトに、「こんなに手間がかかるんですか」と何度か呆れられました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＤ―ＲＯＭにおさめたエキスパンドブック版の容量は、最終的に六百十メガバイトほどになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの五百八十メガバイトを、動画が占めています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "費用を問い合わせてみると、代表的なプロヴァイダーの一つであるＩＩＪでは、十メガバイトの容量を借りるのに一か月で一万円かかると言います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、バイト先の旦那に生まれてはじめてキャバレーに連れていかれて悦楽の夜を過ごした翌日、感動の余り「生まれてはばれてキャバレてアワワ〜」としどろもどろにホステスの手厚いもてなしの一部始終の報告に及び、以来ヤツは好感度ナンバー・ワン男と化した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "冒頭の二十キロバイトの書き起こしはすでに完了し、残り百二十キロバイトの連載分を手直しして遅くとも十日後には渡さなければならない書籍用の原稿は！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホント、Ｍ島Ｙ子の言い草ではないが、半年かかって書き上げる直前まできたファイル三百キロバイト分をウイルスに破壊され、オレ様が自殺に及んだとすれば、『朝日新聞』は一体どう書いてくれるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "古川がアルバイトで勤めていた秋葉原の店に集まる、生まれはじめたばかりのマイコン・マニアの中には、早稲田大学の学生であるという西和彦という名の青年がいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来はＭＳ―ＤＯＳ用のこのマシンに１メガバイトちょいのＢＴＲＯＮのＯＳ（商品名はＥＴマスター）を載せ、別売のエディターをプラスすれば日本語ワープロとお絵書きにはすぐに使える。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろＲＡＭが百二十八キロバイトのオリジナル時代からマックに入れ込んだＴ田は、マック用に日本語ワープロが書かれるとすぐに飛び付いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "メモリを五百十二キロバイトに拡張した第二世代機に、プリンターと外部フロッピーディスク・ドライブ一台をくっつけたバンドル特価（言うまでもなくアップル用語で、特別に高いという意味だ）は、百万円を越えていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにそもそも、一バイトで文字を表現できる英語圏で作ったものを、後からわけのわからない文字のごちゃまんとあるところに持ち込んで二バイト文字に対応させようとするから、難しい点が出てくるし手直しの時間がかかる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この仕事は、「学生アルバイト」のはずだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の家庭の娘さんはアルバイトを考えずに、専門学校の生活を考えることは不可能になりました。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバイトを二つもって医学の勉強をしているひとを知っております。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバイトしている男女学生の生活は、経済安定本部の抽象性の修正者です。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、故人の遺族は思いがけなく主人の身の上におこった悲劇によって、妻は主婦として行手の寒さに身をふるわせ、子息たちは、アルバイト学生の境遇を、自身たちの明日の身の上にうけ入れにくく思っただろうということもありえないことではない。",
              "citation": {
                "source": "権力の悲劇",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子の学校などでも一日に百二十本のアイスクリームを売って、汗にまびれてけなげにアルバイトして勉強している学生と、文化的な外見をもちながら、生活の中心が全く腐敗してしまっている女子学生とがある。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもまじめな人たちはアルバイトまでして勉強しています。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
