          "literary": [
            {
              "text": "急いで死ぬるばかりが能ではないのだ。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "威張るばかりが能ではない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い伝統を重んじること、こればかりが能ではない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この主人公は「商人の務めは儲けるばかりが能ではない。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いこむばかりが能ではないではないか」ルスタムは音楽の響が一きわ高くなるのを待って云った。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "立っているばかりが能ではない。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠢動するばかりが能ではない。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "亢奮するばかりが能ではない。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "香港落ち、マニラ落ち、シンガポール将に落ちんとして、われわれは、相次ぐ海陸の大戦果に胸ををどらせてゐるのでありますが、お互にもう鼻を高くし合つてゐるばかりが能ではないと思ふのであります。",
              "citation": {
                "source": "優にやさしき心",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女も人間である」といふたてまへから、また、女であるがために差別待遇を受ける不満から、「女は女らしく」あるばかりが能ではないといふ結論が生れる場合がないではない。",
              "citation": {
                "source": "「女らしさ」について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで初めて大智恵者の花村甚五衛門様を思い出されて、久方振りでお館へ招んで、お前の技倆でこの難場を盛り返すようにと仰せられたそうだが、そこは執事のご筆頭だ、いかに主人の命令けでもへいへいするばかりが能ではない。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物価暴騰の声に、脅やかされているばかりが能ではない。",
              "citation": {
                "source": "友人一家の死",
                "author": "松崎天民",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、ただお辞儀しているばかりが能ではない。",
              "citation": {
                "source": "悦しき知識",
                "author": "――停年講義（昭和三十三年九月十六日）",
                "note": "青空文庫"
              }
            },
            {
              "text": "叱るばかりが能ではない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
