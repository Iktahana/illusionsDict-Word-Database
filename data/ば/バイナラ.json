        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このあんばいならば二三日ここを動かぬかも知れぬゆえ、もう駕籠に用はないと申すのじゃ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあんばいならば、大将め、ちょろまかした古島雛をどこかへ隠して、今ごろはぬくぬくしていやがるだろう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、かういふあんばいなら、しばらく放つておいても大丈夫だと彼はひそかに高を括つてゐた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さん、正三もこのあんばいなら大丈夫でしょう」　と満足の意を表した。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
