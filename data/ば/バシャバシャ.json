        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕方、仕事から引きあげて来ると、もう早い連中が、河の堤の青い草の上へ服をぬぎすてて、バシャバシャやってる。",
              "citation": {
                "source": "ソヴェト労働者の夏休み",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは雨が何しろ樋をはずれてバシャバシャ落ちる程の降りの日のことだが、それ程でなく、天気が大分怪しい、或は、時々思い出したような雨がかかると云うような日、一太と母親とにはまた別な暮しがあった。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バシャバシャと云う水のとばしる音、濡れそぼけて益々重くなった羽ばたきの音、彼等の口から思わずほとばしり出るよろこびの叫び。",
              "citation": {
                "source": "一条の繩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水溜りにくると子供達はバシャバシャ泥を飛ばして歩いた。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえる道の不快な感情、水たまりをバシャバシャ歩く気持。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この水たまりを同じバシャバシャ歩くのでも、主人公のモンゴリア人は真直、むきに歩く。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭い叫び声とバシャバシャ、バシャバシャ云う音に混って如何にも愉快な木の葉ずれが爽やかに子にも「此処許りは」と思わせた。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、バシャバシャと水をはねかえして、冷たい氷水を浴びたときだけ、わずかに、自分の生まれた北の故郷にいた時分のことを思い出したり、また、ちょっと、その当時の気持ちになったのであります。",
              "citation": {
                "source": "白いくま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵のほうは鮎子さんを引きずり降ろそうというので、水の底を潜ったり、バシャバシャ波を立てたりしながら、えらい勢いで攻め寄せてくる。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ暗な中、バシャバシャと背後から水が押し寄せて来て、明かりが消えた。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色の囚人服に灰色の囚人帽をかぶった雑役は、水気の多いその食べものを、乱暴にバシャバシャという音をたててわけていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、えづくように、バシャバシャいっていたあの音を思い浮べた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに降ると、仏壇のおいてある戸棚の中が大もりになって、バシャバシャしぶいた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "急にバシャバシャと水がひろ子の女学生靴へ入った。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子に（中国人の）湯を使わせているらしく、バシャバシャ水の音がした。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がバシャバシャ散る。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の池には、水浴をする子供等の群が絶えず、力強い日光のみなぎり渡る水面からは、日焼けのした腕や足が激しい水音を立てて出入し、鋭い叫び声に混ってバシャバシャ水のはねる音が遠くまで響き渡る。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "息がろくに出来ないようになっても、バシャバシャやらなかったところだけは買って下さるでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラスがこわれたところから雨がバシャバシャおちて、タライをおいても洪水でした、下駄ばきで台所やって居たから直って全くさっぱりしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅貨ほしさにもぐる小さな男の子もいたが、水晶のように澄んだ水の中で、バシャバシャやっている彼等の姿は、中々面白かった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "どしゃ降りの雨の中を、殆ど半マイルの間、急な坂の泥をバシャバシャやって登ると、彼等は立止り、道路の崖の側を指さした。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく、せせらぎの上へ首を延ばすことができたとき、顔からふきだす真赤な血潮が、せせらぎへバシャバシャ落ちた。",
              "citation": {
                "source": "紫大納言",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐州の城門へ馳け入ろうとすると、櫓の上からバシャバシャッと雨のような矢が降って来た。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊野杉の密林がバシャバシャとわれらの番傘に雫をそそぐ。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
