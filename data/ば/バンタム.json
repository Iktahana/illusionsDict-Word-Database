        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鳴く声バンタムに似たれど長く引かず、正月より七月の間に乾草や落葉を掻き集めた上に八より十二卵を生むという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "金徳一は、知る人ぞ知る、先のバンタム級の世界ベストテンに数えられた名選手でした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクシングのバンタム新人王だの何だの云ったって、丹下左膳現代版に太刀打ちできるもんかいな。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンタム新人王定夫君は、今しがた東京で私たちと別れて、サクラ拳闘クラブへ泊りに行った筈であった。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンタム級新人王の顔を知らない駅員はいない筈だ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンタム新人王なら小田原にいませんぜ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バンタムに新人倉田ありと言われるだけのお方は、さすが生れながらにして、骨の髄からのボクサーですよ、まさに敬服の至りです」　大矢警部が口をいれた。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンタム、即ち、チャボだからね。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し何よりも待遠しく思つて會ひたがつてゐるのはバンタムであつたらしい。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンタムと云ふのは小馬のことと知れたが、少年たちの話合つてゐるところでは、その優れた性質は名馬ブーシファラス以來どんな馬も及ばないのであつた。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのトロットの具合、あの走る姿、それから例の跳躍ぶり――全國どこの生籬だつてバンタムに飛越せないところはないのだ。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジョンがゐる、カルロだ、バンタムだ。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "老僕の傍には盛をすぎた一匹の獵犬と名だたるバンタム、これは小さな老ぼれの小馬で、もじやもじやの鬣に長い赤錆色の尾をたらし、睡たげに、温和しく路傍に立つて、やがて自分が忙しい目をすることなどは夢にも思ひ及ばぬ樣子であつた。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しバンタムこそは何よりも嬉しい遊び相手であつた。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "わづかにそれと見分けられるばかりだが、一人の婦人と二人の少女の姿が玄關に見え、わたしがお馴染になつた少年達がバンタム、カルロ、老僕ジョンと一緒に、一列になつて車道を進んで行くのが目についた。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼らがいちばん会いたくてたまらなかったらしいのは、バンタムだった。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンタムは近隣のどこの垣根だって飛びこせるのだ。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンタムもいるぞ」と叫んで、この楽しそうな少年たちは手をたたいた。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にしたがっているのは、老いぼれたポインター犬と、尊敬すべきバンタムだった。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンタムは鼠のような小馬で、たてがみはぼうぼうとして、尾は長くて赤茶色だった。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なんといってもいちばんこの子供たちの興味をそそるのはバンタムだった。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、わたしの小さな友人たちが、バンタムとカーロとジョン老人といっしょに馬車道を進んでゆくのが見えた。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "全日本バンタム一位ノ坂本春夫ガタイノバンタム一位ノシリノイ・ルクプラクリスヲノック・アウトシテ初代チャンピオンガ生レタアノ晩デスヨ、―――」ソノシリノイ・ルクプラクリスト云ウ名ヲ陸子ハ流暢ニペラ／＼ト云ッテ退ケタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
