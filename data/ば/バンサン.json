    "definitions": [
      {
        "index": 1,
        "gloss": "dinner (esp. a formal one)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "晩餐の時、ヘルンはいつも二三本の日本酒を盃で傾けながら、甚だ上機嫌に朗かだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀明水に達したるは午後七時に垂んとす、浅間社前の大石室に泊す、客は余を併せて四組七人、乾魚一枚、麩の味噌汁一杯、天保銭大の沢庵二切、晩餐の総べては是の如きのみ、葉マキ虫の葉を綴りて寝ぬる如く、一同皆｜蒲団に包まりて一睡す。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　外では、グラン・パレイの春のサロンから出て来た人がちらほら晩餐までの時間を持てあましている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮になって、一行が水神の八百松へ晩餐をとりに入ろうとすると、みち子は、柚木をじろりと眺めて「あたし、和食のごはんたくさん、一人で家に帰る」と云い出した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年ケルヴィン卿が化学会の晩餐演説でこの事を引合に出し、レーリー卿は十二歳のときに燐で指を焼いたそうだが、自分は八十二歳のときに全く同じ火傷をしたと云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物を更えて晩餐、食後新聞、雑誌、小説など。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一八年の暮バキンガム宮で大統領ウィルソンのために開かれた晩餐会に列席した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐後ミス・オーステンの小説『エンマ』を読んでいた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは晩餐だつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "父娘は夜な夜な「最後の晩餐」という敬虔な気持で言葉少なに美味に向った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はユーストンの地下鉄の乗換場附近にある玄関に、日章旗を交錯した日本料理店胡月の卓子で、外交官の松岡、画家の山中、トンテム・ハム・コートの伊太利料理店の主人と暗い東洋風の部屋で、日本食の晩餐後お互に深い沈黙に陥っていた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐後、妾達は静かに身上談などをして、夜を更かしたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の三｜本木の有志の方々から、こゝで一｜泊して晩餐と一｜所に、一｜席の講話を、とあつたのを、平におわびをしたのは、……かるがゆゑに袴がなかつた為ではない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日また別の席でこれらの人たちと晩餐を共にしてシュミット、ウィーゼ両氏の簡単な講演を聞く機会を得た。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫色のスウィートピーを囲んだ見合いらしいはなやかな晩餐の一団と、亀井戸への道を聞いた寒そうな父子との偶然な対照的な取り合わせが、こんな空想を生む機縁になったのかもしれない。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうさぎを捕獲すればテント内の晩餐をにぎわすことができるがなかなか容易には捕れないそうである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「晩餐会は中止にして下さい。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "開場式のお歴々の群集も畢竟一種の囚徒で、工場主の晩餐会の卓上に列なる紳士淑女も、刑務所の食卓に並ぶルンペンらも同じくギャングであり囚人の群れであるように思われてくる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐会で腹をかかえて哄笑するのもキュラソのビンで自分の肖像のどてっ腹に穴をあけるのも、工場と富とを投げ出してギャングの前にたたきつけるのもみんな自由へのパスポートである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時大佐は徐かに立上り、私に向ひ『吾等は之より一定の職務があるので、暫時失敬、君等は後に靜に休息し玉へ、私は八｜時※再び皈つて來て、晩餐をば共に致しませう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓の對端には、武村兵曹他三名の水兵が行儀よく列び、此方には、日出雄少年を中に挿んで、大佐と私とが右と左に肩を並べて、頓て晩餐は始まつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐後、喫茶がはじまると、櫻木大佐をはじめ同席の水兵等は、ひとしく口を揃へて『御身が此島へ漂着の次第を悉しく物語り玉へ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、一處になつて走廻つて居る内に、いつか仲がよくなつて、夕刻、家に歸つた時も、稻妻は此可憐なる少年と戯れつゝ、思はず二階まで驅上つて、武村兵曹に箒で追出された程で、日出雄少年は此犬の爲めに、晩餐の美味しい「ビフステーキ」を、其儘窓から投げてやつてしまつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の事だが、此日の晩餐は特に私の爲には愉快であつたよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　妖怪沙汰　泰助は旅店に帰りて、晩餐の前に湯に行きつ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にはじめぬことながら、ほとんどわが国の上流社会全体の喜憂に関すべき、この大いなる責任を荷える身の、あたかも晩餐の筵に望みたるごとく、平然としてひややかなること、おそらく渠のごときはまれなるべし。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから晩餐の御馳走になって、奥の間の最上等の座敷へ案内されて、ここを私の居間と定められたが、こんな立派な広いお座敷に寝るのは実に今夜が嚆矢だ、併し後で考えるとこのお座敷が一向に有難くない、思い出しても慄然とするお座敷であったのだ。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○二月二十五日、西園寺首相邸に晩餐会あり、芝翫、八百蔵、高麗蔵などの歌舞伎座幹部俳優みな招待せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、或る土曜日の夕刻から、智子は初めて浅原を晩餐に招いて、母親とひき合せた。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってきた時には、もうばんさんのために着がえをする時間になっているらしかった。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
