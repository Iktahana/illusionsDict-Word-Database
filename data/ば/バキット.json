    "definitions": [
      {
        "index": 1,
        "gloss": "snapping (e.g. branch)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
