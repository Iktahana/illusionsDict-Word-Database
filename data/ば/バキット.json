        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「僕は、つまらない男であるから、逢えばきっとがっかりなさるでしょう。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側の水楼に坐して此方を見る老人のあればきっと中風よとはよき見立てと竹村はやせば皆々笑う。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそれ自身では同じ事柄でも前後の関係がちがって来ればその内容もまたちがった意義をもって来ることは可能であるが、そういう場合でも同じ読者が見ればきっと「またか」と思うに相違ない。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし物好きな人があってこの模様を散らした着物でも作ればきっと面白い物が出来るだろうと思われる。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花といえばきっとあれを買うのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな状態がいつまでもつづけばきっと病気にかかるだろう。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "破壊的で壊家を生じ死傷者を出すようなのでも三四年も待てばきっと帝国領土のどこかに突発するものと思って間違いはない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏に銅の壺に水を入れ壺の外側を水でぬらしたきれで固くつつんでおくならばきっとそれは冷えるのだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る人が見ればきっとそれをよしとはしないだろうと私は思いました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は飯綱の法を修行したが、遂に成就したと思ったのは、何処に身を置いて寝ても、寝たところの屋の上に夜半頃になればきっと鴟が来て鳴いたし、また路を行けば行く前には必ず旋風が起った。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分なぞも資産家でさえあればきっとすばらしい贋物や贋筆を買込で大ニコニコであるに疑いない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、牛乳やいわゆるソップがどうにも臭くって飲めず、飲めばきっと嘔吐したり下痢したりするという古風な趣味の人の多かったころであった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから丸薬をのめばきっとみんなもとへ戻る。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど一つの難がある、それは女難だ、一生涯女に気をつけてゆけばきっと立派なものになる』と私の頭を撫でまして、『むむ、いい児だ』としげしげ私の顔を見ました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昆虫の研究者が蝶や蟻でも研究するように、この小略奪者たちの習性を研究する目的でいろいろの実験をしてみればきっとおもしろくまた有益だろうと思うが、自分にそれほどの暇も熱心もない。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの感情の道を辿って行っても真面目に突き詰めて行けばきっとその弾機に行き当るのでしょうか、必ず楽観に弾ね上って来ます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時僕たちにかけられたら花がみんな散ってしまってまるで実にならないだろう、だから前は本当にこわがったんだ、僕たちだってわざとするんじゃない、どうしてもその頃かけなくちゃいかないからかけるんだ、もう三四日たてばきっと又そうなるよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上助手の杉田も一伴だのに、二人ながら居ないとすればきっと、この附近に逃れておらるるだろう。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い事をすればきっとそれだけの罪をうけねばならんのです。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今も申し上げました通り、もし本当の神隠しならば格別、さもなければきっとわたくしが探し出して御覧に入れますから、まあ御安心くださいまし」と、半七は捜索を入れるようにきっぱりとこう云い切った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアは、「何でも狙えばきっとあたる鉄砲がいい」　と云いました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逸子、済まないが、仲通りの伊豆庄を起して、鮟鱇の肝か、もし皮剥の肝が取ってあるようだったら、その肝を貰って来て呉れ、先生が欲しいといえばきっと、呉れるから――」　珍しく丁寧に頼んだ。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頼み聴かずばきっと破門じゃぞ』源右衛門『ええ？",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人が狂人としての待遇を受くればきっと怒る。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが多年研究している秘密の薬剤があって、それを飲めばきっと癒るから、ふた月ほども続けて飲んでくれないかと言うんです。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんどきどんな所でも、枕につけばきっと朝までは正体もなく寝てしまうのが例であるのに、今夜にかぎって眠られないのは不思議である。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩下ら三人の未熟を笑ったのか、あるいは我れならばきっと仕留めてみせるという自信の笑いか、いずれその一つとは察せられたが、弥太郎は組内の古参といい、鉄砲にかけても老練の巧者であることを諸人もよく知っているので、さすがに正面から彼を詰問する者もなかったが、その不快が陰口となって表われた。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺せばきっと祟ります。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
