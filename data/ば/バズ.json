        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なまなかそれをいつかどな理由をつけて、その理由への対策を講じてみたつて、暗い女が明るくならうとしてアバズレになるみたいなもんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、疲れ果てた身体を固い竹の床の上に横たえて眠る――パラオ語でいえばモ・バズ、即ち石になるのである。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の所を煩悶解決所と心得て一人で喋舌って帰るのでね」　なぞとズバズバやるので、相当気の強い連中でもグラグラと参ってしまう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と逢つても体を崩さないといふところがある、福田平八郎は京都住ひではあるが、その点全く江戸人のやうな鉄火肌のところがあり、開放的でザックバランだ、おしやべりかといへば、どつちかといふと無口の方だが、開口一番するや思つたことをズバズバ言つてのけるといふ性格で彼の描く絵のやうに明確なものがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "但シ私産限度以上ニ及バズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "現今ノ武器ノ前ニ立チテ此等ニ尚武的價値ヲ求ムルニ及バズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は初めの中こそアバズレであったが、今ではまるで継子のように言葉も少くなって了っていたのである。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、あのアバズレ共が今になって何れ程私から新しい世界を見せられ、そこへ導かれたかは云う迄もないであろう。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴は何んでもズバズバ云ってのける癖があるので、地主から一番「にらまれ」ていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　帰りに健のところへ寄ると、佐々爺、武田の前で、伴がズバズバ云った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとかどの異端評論家（『国民新聞』記者命名）、サニズムの主唱者（『時事新報』記者命名）、社会主義研究者（『万朝報』記者命名）と人も許し自分も許していた大の男が、新しい女なぞというアバズレの小娘に、見事背負投げを食わされた形になったのだ。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "オソラヲ　ミレバズンズントオ山ノ　上ヲワタノヨニウイテル　クモモトビマシタ。",
              "citation": {
                "source": "未刊童謡",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原の改革はズバズバと行われた。",
              "citation": {
                "source": "最初の外国保険詐欺",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュッシャニオヨバズ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに単純な、無鉄砲な漁師どものアバズレ仕事とばかり思い込んでいたものだから、一気に片付けるつもりで追いまわしてみると、どうしてどうして。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同書の「凡例」に拠れば、始め福沢先生が同書の翻訳に着手されたが、「訳稿未ダ半ニ及バズシテ忽チ米利堅ノ行アリ、因テ約ニ命ジテ続訳セシム……茲ニ先生ノ栄帰ヲ待テ点閲ヲ乞ヒ」云々とあるから、この「政表」なる訳語は多分福沢先生が渡米前、即ち安政年間に新案されたものではあるまいかと思われる。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "アバズレでしかも一本気で、地獄へまでもといふ意気がある。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "露月はアッと叫びざま、虚空をつかんで呻いたが、呉羽之介は猿臂を伸して藻掻く相手を組伏せたまま、小刀｜逆手にズバズバと細首を掻き切って了いました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚その命令書には『追テ後日何等カノ命令アルマデハ本件ニ関シ総指揮官部へ報告ニ及バズ』と但書を書くから、予め諒承ありたい」　　　　　３　ゴンゴラ総指揮官は、遂に白紙命令書百枚を金博士に手交して、博士の手腕に大いに期待するところがあった。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "几帳の蔭につつましく坐り開け放された窓を通して黄昏の微芒の射し込んで来る中に頸垂れているその姿は、「芙蓉モ及バズ美人ノ粧ヒ、水殿風来タッテ珠翠｜香シ」と王昌齢が詠ったところの西宮の睫※を想わせる。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナースがそのことを過去のこととし、本人の記憶にないこととし、相当ズバズバ話す、そのサイコロジー。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "國文ノ規則ニ從ヒ省略セムト思ヘドモ力及バズ。",
              "citation": {
                "source": "桃花源記序",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、さすがに京のサバズシはイキの悪さを承知の上で、それを生かすように特別の工夫をほどこしたスシだから風味はわるくない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十八「さあ、いいかね、これから思いきったところをズバズバ言うよ、腹あ立っちゃいけねえよ、良薬は口に苦しといってね、いい医者ほど苦い薬を飲ませるんだぜ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから、遠慮なく、思ったところをズバズバ言うからね、苦いと思ったら、道庵は、さすがに医者だと思ってくんな――」　ガラリとこう変ってしまったのには、並みいる神妙な聴衆が、あっ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "自序に曰く「余カツテイヘラク、詩ノ道タルヤ精ナルヲ貴ビ多ナルヲ貴バズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺客ノ至ルヲ見テ大ニ驚キ蹶起スルモ及バズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "然レドモ人烟上国ノ中鎮ニ及バズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙に曰く、「秦漢以上文藻ヲ尚バズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
