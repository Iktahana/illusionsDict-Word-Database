        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを左へ曲るとウンテルデンリンデンですぐ右側の角がツォイクハウス、次が番兵屯所、その次が大学である。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物々しい番兵の交代はベルリン名物の一つであったが、実際いかにも帝政下のドイツのシンボルのように花やかでしかもしゃちこばった感じのする日々行事であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗食を与えられ、虐待され、身体中こづき廻され、番兵の命令によってこき使われる。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町も辻も落ち葉が散り敷いて、古い煉瓦の壁には血の色をした蔓がからみ、あたたかい日光は宮城の番兵の兜に光っておりました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん年老りの番兵だ。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふふふ青白の番兵だ。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううははは、青じろ番兵だ。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「のはらのまん中の　めつけもの　すっこんすっこの　栃だんご　栃のだんごは　　　結構だが　となりにいからだ　ふんながす　青じろ番兵は　　　気にかがる。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青じろ番兵は　　　ふんにゃふにゃ　吠えるもさないば　泣ぐもさない　瘠せで長くて　　　ぶぢぶぢで　どごが口だが　　　あだまだが　ひでりあがりの　　なめぐじら。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊吹山はあたかもこの関所の番兵のようにそびえているわけである。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "番兵たちや、あらゆる町の人たちが、まるでどきどきやりながら、矢を射る孔からのぞいて見た。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしまぎれに泣くものや、両手をあげて走るもの、じぶんで門をあけようとして、番兵たちに叱られるもの、もちろん王のお宮へは使が急いで走つて行き、城門の扉はぴしやんと開いた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの隅の小さな戸口から、ばけものの番兵に引っぱられて出て来たのはせいの高い眼の鋭い灰色のやつで、片手にほうきを持って居りました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「のはらのまん中の　めつけもの　すつこんすつこの　栃だんご　栃のだんごは　　　結構だが　となりにいからだ　ふんながす　青じろ番兵は　　　気にかがる。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青じろ番兵は　　　ふんにやふにや　吠えるもさないば　泣ぐもさない　瘠せで長くて　　　ぶぢぶぢで　どごが口だが　　　あだまだが　ひでりあがりの　　なめぐぢら。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "番兵が追掛けて其幾人を捕え、其幾人を殺したが、余の七八十人は山を越えて何処へか姿を隠して了った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わからぬことをいうなら、番兵を呼ぶだけだ。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、王女のお婿さまになる人のいうことに、むろん、番兵たちは従ったからです。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、御殿の門をくぐって、銀色の服を着た番兵を見たり、階段をのぼって、金ピカのお役人を見たり、キラキラした大広間へ通されたりすると、ぼうっとなってしまうんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、飼われている、ぼくのいいなずけの話によると、その子は、御殿の門をくぐって、銀色の服を着た番兵を見ても、階段をのぼって、金ピカのお役人にであっても、びくともしなかったってことだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀色の服を着た番兵と、金ピカのお役人が、ゆるしてくれっこないよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの御殿の前にも、小さな王子が番兵に立っていました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大変と、てんでに宝庫に駈け付けて調べて見ますと、番兵も庫の鍵もチャンとしていながら、中の刀と鉄砲だけ無くなっています。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「蓄音機は司令部へ行ったぜ」　と、若い当番兵が答えた。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ども十六人が、皆、頭から石油を浴びて、左右の袂に火薬を入れたまま石垣を登って番兵の眼を掠め、兵営や火薬庫に忍込みます。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳重に大高城を監視して居た、丸根、鷲津の番兵達は、はるかに雄叫びの声がすると思っているうちに、寺部、梅ヶ坪の城に暗をつらぬいて火が挙がるのを見て、驚き且ついぶかった。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
