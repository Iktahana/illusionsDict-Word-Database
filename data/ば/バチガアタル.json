    "definitions": [
      {
        "index": 1,
        "gloss": "to incur the wrath of the gods (e.g. by doing something immoral)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人間のお遺骨をそんなことしたら、それこそ罰が当たるというもんだよ」「じゃあ、どうしたらいいんですかね？",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままに見捨てていっては、神さまの罰が当たる。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一｜部始終をおばあさんは、おじいさんに話しますと、「それは、まさしく神さまのお授け子だから、大事にして育てなければ罰が当たる。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをしたら、罰が当たるといって承知をしませんでした。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "罰が当たるなら当たれ！",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に多胡辰敬の家訓のなかから、おのれを卑下すればわが身の罰が当たるという言葉を引いたが、この心持ちはこの書では非常に強く説かれている。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんてえ冷えだ、骨までみしみしいうわい、こんな日に出て来るなんてきっと仏さまの罰が当たるだ」「もう鴨もおしめえだ」　と片方が水洟をすすりながら云った。",
              "citation": {
                "source": "蜆谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつたい何がもとでそんな喧嘩をしてゐるのか、菊次さんがきくと、それは清造がおひる御飯をたべてゐたとき二粒ごはんをこぼした、おばあさんがそれを見て、「ばちがあたるから拾つて喰べよ。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨てりやばちがあたるもんを。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御飯粒を捨てたぐらゐでばちがあたるもんかい。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばちがあたるならこの足がいたむだらうに、ちくりともしませんだ。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかく、おくってくださったのを、気に入らないなどいって、ばちがあたるわ。",
              "citation": {
                "source": "田舎のお母さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなところからのぞいたら、ばちがあたる。",
              "citation": {
                "source": "曲馬団の「トッテンカン」",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、このいたずらによって、神さまのばちがあたるなどということは、ありはしないのだということを、諭吉ははっきりとしることができました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の意見にそむいてはばちがあたる！",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
