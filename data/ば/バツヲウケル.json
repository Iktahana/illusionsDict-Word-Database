[
  {
    "uuid": "270565cf-e211-55ec-8601-f4ab7bda9b37",
    "entry": "罰を受ける",
    "reading": {
      "primary": "ばつをうける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
