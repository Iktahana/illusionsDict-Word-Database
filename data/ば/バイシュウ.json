    "definitions": [
      {
        "index": 1,
        "gloss": "acquisition (esp. corporate)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
