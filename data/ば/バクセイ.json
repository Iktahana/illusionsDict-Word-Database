        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もし高山にありて、夜中、天狗が樹木を倒し、大石を投ずる音を聞くというがごときは、風音、瀑声、または走獣の音を誤り認めたるものなるべし。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "城松という盲人は、鳴滝の下で簫を吹くと、人ただ簫声あるを聞いて、瀑声あるを聞かなかったそうであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
