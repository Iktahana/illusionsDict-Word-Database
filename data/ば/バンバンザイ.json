    "definitions": [
      {
        "index": 1,
        "gloss": "matter for great congratulation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "将来の喜多流万々歳の瑞兆に外ならぬのである。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが導火線、類を以て集り、終には酒、歌、軍歌、日本帝国万々歳！",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子と、ラプンツェルも、此の五年後あるいは十年後に、またもや結婚をし直す事があるかも知れぬが、互いの一筋の信頼と尊敬を、もはや失う事もあるまいから、まずまず万々歳であろうと小生には思われるのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風であるから、同居人を取り巻くささやかな謎でさえ万々歳で、時間を惜しまず、解きほぐそうと躍起になるのだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は酒も好きだが、菓子も好きになつた（何もかも好きになりつつある、といつた方がよいかも知れない）、辛いものには辛いもののよさが、甘いものには甘いもののよさがある、右も左も甘党辛党万々歳である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本晴、天長節、万歳万々歳。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖戦第三年、興亜新春、万歳万々歳。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "花と兵隊もよい、火野葦平万々歳である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "波崎が恨みの刃をうけながら、却って「向ひ疵とほこられんが可笑し、才子の君、利口の君万々歳の世に又もや遣りそこねて身は日蔭者」になる直次郎。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――出征は勇躍万々歳でなければならず、人民のつつましい生活の中から働く男、経済の支柱が奪われてゆくに際しての家族たちの限りない不安。",
              "citation": {
                "source": "解説（『風知草』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新春の御祝儀万々歳御目出度、兼々御揃被遊御機嫌様宜しく入らせられ大寿至極恐悦奉申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に云く、多妻多男の法は今世を挙げて今人の玩弄物に供するの覚悟なれば可なりといえども、天下を万々歳の天下として今人をして後世に責任あらしめんとするときは、我輩は一時の要用便利を以て天下後世の大事に易うること能わざる者なり。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも我が日本国の独立して既に数千年の社会を維持し、また今後万々歳に伝えんとするは、自ずからその然る所以の元素あるが故なり。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は信じないだろうけれども」「え、僕が信じないって、そりァ、どういう意味だ」　僕は彼が変な事をいうので、急いで訊き返したが、彼はもう夢中で、「いやさ、君が信じようが信じまいが、僕の子供は僕にそっくりなんだぜ、丸々と肥った色の白い、とてもいゝ子なんだ」「二川家も之で万々歳だね」「そうだとも。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに打勝つとすれば、蜘蛛にとっては万々歳である。",
              "citation": {
                "source": "蜘蛛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いずれも皆忠臣の亀鑑、真の日本男児じゃ、ああこの人達があればこそ日本は万々歳まで滅びないのだ」　こうおじいさんがいったかと思うととっとと走っていく、その早いこと百メートル五秒間ぐらいである。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカグマ国人は、舞台のうえへ、しきりと声援と喝采とを送って、「イネ人を、みなごろしにしろ」「アカグマ国、万々歳！",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、海底から再び生れ出でたイネ帝国の万々歳を祝さねばなるまい。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなるとまことに万々歳なのじゃ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで八重子が妊娠したら、それこそ万々歳だ。",
              "citation": {
                "source": "人間繁栄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も最う一度そういう程度まで立戻る事が出来たとしたら、どんなに万々歳なお目出度かりける次第であろう……。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして世の中にこんな連中があればこそ仏様も立ちゆく訳で、万歳であり万々歳であろう。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「婆さんや、よろこびな――筆屋は万々歳だ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで、皇子誕生となれば万々歳じゃ」　とまるで既に皇子が誕生でもしたかのように、勇み立っていたし、世間でも、「勢に乗ってる平家のことじゃ、皇子誕生も間違いなかろう」　というのが、一般の噂であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間はお勝、あの女狐は一通りの悪者ではございません」「…………」「これにて御家は万々歳、安倍家の栄えは目に見えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "で例のごとく元日に天皇皇后両陛下、皇太子殿下の万歳を祝しましたが、山海三千里を隔てたるこのヒマラヤ山中において明治天皇陛下の万々歳を祝することの出来るのは実に愉快であると思うて覚えず嬉し涙に咽びました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝聖の儀式というのは神聖なる明治天皇｜陛下万歳万々歳、皇后陛下の万歳万々歳並びに皇太子殿下の万歳万々歳を祝願し、ついで日本国家の威力が旭日の輝くごとく万国に光被せんことを祝願するので実にめでたい願文である。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
