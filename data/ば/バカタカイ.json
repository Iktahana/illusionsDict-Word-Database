          "literary": [
            {
              "text": "こんな代物にバカ高い金を払ったら、名折れだぜ」　あわててのこったビールを飲みほし、ドッグをひっつかんで、慶一は高志を追った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "時世が変ってみれば、城山のテッペンがバカ高いので迷惑したのは政宗当人さ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがないと、気位のバカ高い奥方の典型で、可愛げなどの感じられないリリしさだが、童女めく痴呆さが色気をつくっている。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも無理に笑顔を作り、赤い唇が少し開き、両まなこを、趣味のいいバカ高いこしらえに泳がせた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性が好きなバカ高いくだらない物を長年、一族に提供してきた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンに着いたばかりで、ホテルはバカ高いですね。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
