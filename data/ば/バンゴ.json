    "definitions": [
      {
        "index": 1,
        "gloss": "language spoken by the Emishi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
