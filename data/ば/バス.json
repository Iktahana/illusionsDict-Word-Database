    "definitions": [
      {
        "index": 1,
        "gloss": "bus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "をばさんは、バスに乘つて、峠の下の吉田へ行つて、こたつをひとつ買つて來た。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はバスケットを車室に置くと、その方へ行つてたのでその吹き出してるところも見せられた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の詩万歳だ」　彼はバスケットから葉書を出してさう書いて母に送つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでアインシュタインが出て来てコロンバスの卵の殻をつぶしてデスクの上に立てた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千の天使が　　バスケットボールする。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にはバスケット、足には下駄とな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、座席へバスケットを置くと、そのまま食堂車に入った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、彼が座席の上に置いてあったバスケットは、そこに無かった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてな、俺のバスケットをどこへ持って行きやがったんだろう。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスケットの中味を覗いたのたあ違うかい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃお前のバスケットかい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は少年の踏んでいるバスケットを顎でしゃくって見せた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ一体あのバスケットは、誰のものなんだい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが誰のものだろうが、そのバスケットは自分のものでなければ収拾する事が出来なかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏んづけちゃ困るね」「そんな大切なものなら、打っ捨らかしとかなけゃいいじゃないか」　少年は眼を瞑ったまま、バスケットから足をとった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だってバスケットを坐らせといて立っていたくねえや」「チョッ、喧嘩にもならねえや」「当り前さ」　少年は眼を開いた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらバスケットを取ってくんなよ」「ほら。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "物騒な話だ）　彼はバスケットを提げて、食堂車を抜けて二等車に入った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡へのバスは吾々一行が乗ったので満員になった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島々からのバスの道路が次第々々に梓川の水面から高く離れて行く。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で乗客が減つたのでバスから普通の幌自動車に移された。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "澁川驛前にはバスと電車が伊香保行の客を待つてゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大多數の客はバスを選ぶやうである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の運轉手は、しきりにベルを踏み鳴らしながら、併しわり合にのんきさうな顏をしてバスに押し込む遊山客の群を眺めて居たのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も同行Ｓも結局矢張りバスのもつ近代味の誘惑に牽き付けられてバスを選んだ。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、バスを降りてから二人で一つづゝカバンを提げて、すぐそこの別館の戸口迄歩いて行つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバンをぶら下げて、悄々ともとのバスの待合所へ歸つて來たら、どういふものか急に東京へそのまゝ引き返したくなつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、歸ることは歸るとしても兎も角も其處らを少し歩いてから歸つても遲くはないだらうとＳがいふので、厄介な荷物を一時バスの待合所へ預けておいてぶら／＼と坂道を上つて行つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
