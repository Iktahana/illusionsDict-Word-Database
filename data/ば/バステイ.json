        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "早いとこ出発しないと、晩メシまでに帰れなくなる」　県道には路線バスが走っているが、バス停までは一本道で、その途上や停留所で、教師に出くわす危険性が高い。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "バス停からさき、どうするんだよ」　バス停から寮玄関までは、一〇分ほど歩かなくてはならない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五五（昭和三十）年五月、名古屋大学で開かれた電気通信学会で発表を行った渡部は、学会の副会長として出席していた玉川製造所長の小林宏治（のちの社長、会長）から、学内に設けられた臨時のバス停のそばで「一緒に帰ろう」と声をかけられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿見の前でスカートのヒップのあたりをひと撫でし、戸締りをして家をとびだすと、光明寺のバス停留所のほうへ、歩いて行った。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "バス停があったので近寄ってみたが時刻表はほとんど空欄で運行は一日に五便しかない。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "バス停留所の標識柱に、車体の端が触れた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行くぞ」と言って、またバス停まで戻る。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆるやかなカーヴの向こうへバスは見えなくなり、歩道のバス停に北原は視線を戻した。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ページめには、バス停でバスを待つ裕子のうしろ姿が、描いてあった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "横画面に描かれた、バス停の裕子の絵があった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私そのものよ、この絵は」「裕子さんを描いたからです」「あのバス停なのね」「そうです」「私の気持ちのなかまで描いてあるわ」「どんな気持ちだったのですか」「不安だったわ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お仕事のことで思いがけず人にお目にかかることになって」「家へ帰ってすぐに描きました」　バス停とその周辺、そして背後にある高台の住宅地などを、気の利いた省略のしかたで処理したなかに、バス停にひとりで立つ裕子のうしろ姿が描いてあった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バス停には、バスが来るまで、あなたとふたりでいたのよ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "最寄りの私鉄駅そしてバス停留所からの、自宅までの略地図を手紙で送ることを、五郎は約束した。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を下りて電器店の角を曲がり、バス停のほうへ歩いていくと、美容院やバー、ラーメン店、不動産屋があって、そこに焼き肉の店もある。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖の近くにあるバス停留所を降りると、湖まで普通に歩いて十五分だった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バス停留所から湖へ下りていく小径の入口まで、十分。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうね」「バス停まで歩きましょう」「ああ、うれしい。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "バス停の数で三つ先に、和食の店があるの。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院前というバス停から。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから、野田市へ」「ほら、いまひとつめのバス停があったわ」「ここはほんとに田舎だね」「東京よりこっちのほうがいいみたい。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京にいるよりずっといい」「さっき、三つめのバス停があったよ」「もうじき左へ入るの。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
