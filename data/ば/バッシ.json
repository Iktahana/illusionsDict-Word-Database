    },
    "definitions": [
      {
        "index": 1,
        "gloss": "removal of stitches",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "普通八日目に抜糸だそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うんや喜こばっし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（霞のような小川の波に、常夏の影がさして、遠くに……（細道）が聞える処へ、手毬が浮いて……三年五年、旅から旅を歩行いたが、またこんな嬉しい里は見ない、）　と、ずぶ濡の衣を垂れる雫さえ、身体から玉がこぼれでもするほどに若え方は喜ばっしゃる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減に遊ばっしゃったら、迷児にならずに帰らっしゃいよ、奥様が待ってござろうに。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "千石だろうと二千石だろうと、お気のままに江戸から取りよせて、たんと遊ばっしゃい」　嘲り顔に言ったその言葉を引きついで、露払いの弥太一といったあの小者までが、面憎く言い放ちました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の者残らずこれへ呼ばっしゃい」「手……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くこれへひとり残らず呼ばっしゃい」　いずれもいぶかりながら、書生、代診、下男、下女、残らずの雇い人たちがぞろぞろと出てくると、左右から手の林をつくって名人の目の前にさし出しました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に一段怜悧者にならッしゃると、仰向に轉倒ばっしゃらう、なァ、孃？",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仰向に轉倒ばっしゃらう、なァ、孃」と言ふと、阿呆どのが啼止って、「唯」ぢゃといの。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "只「嗚呼」とだけ叫ばっしゃい、たッた一言、戀とか、鳩とか宣言せられい。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
