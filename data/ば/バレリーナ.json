          "literary": [
            {
              "text": "（新しい包帯を巻いてやる）トレープレフ　うちと同じアパートに、あのころバレリーナが二人住んでいて……よくお母さんのところへ、コーヒーを飲みに来たっけ……アルカージナ　それは、おぼえていますよ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはぴったり身についた黒ビロードのバレリーナの軽快な姿で女体の上に立ちあがり、女体のスロープを山頂に向かってのぼりはじめた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "バレリーナニナロウト思ッテ、バーレッスンヲ一二年受ケタコトガアルノデ、チョットグライ立ツコトハ立テタンデスガ、サア今デモ立テルカ知ラ」ッテ、ソンナ話ヲシタコトガアッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バレリーナナンテ、足ノコトヲ考エルト見ラレタモンジャナイワ」「レペシンスカヤモソンナ足ヲシテルノカネ」「勿論ヨ、アタシダッテ練習中ハ靴カラタラ／＼血ヲ出シタコトガ何度モアッタワ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
