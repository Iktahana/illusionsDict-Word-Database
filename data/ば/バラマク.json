        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その癖、この通り、それはそれは勿体ないほど、ざくざくお宝をお運びで、嬢さんがまたばらばら撒く。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "利己、貪慾、無節制の一袋を、此処ら辺からばら撒くのだ。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまたしても逢ふほどの哥薩克たちを残らず寄せ集めて、飲めや唄への乱痴気さわぎをおつぱじめて、銭をばら撒く、火酒は浴び放題……美しい娘つ子には、そつとすり寄るやうにして、リボンだの耳環だの頸飾だのを、もてあますほど呉れてやる！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はほら地名や職業の名や数字を夥しく作品の中にばらまくでしょう。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリントアウトしてそこらじゅうにばらまくのは？",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方早く一洵君徃訪、同道して村瀬氏方へ推参、相客二人（支配人Ｆ氏、校長Ｓ氏）、酒は白鹿、寄せ鍋はぽつぽと湯気を立てる、主人夫妻は温情をばらまく、私も今夜はとりわけ野人の本領を発揮して、飲んだ々々食べた々々！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人問題を語る人は、あまりこの自覚という言葉を、そのものだけで世間にばらまくので、わたしたちはまるで道ばたに焼跡があるように、そしてそれを見なれてしまっているように、自覚という言葉を聞きなれて、しかもほんとうのその内容を知らないまま、ただ口伝えに繰返していると思います。",
              "citation": {
                "source": "自覚について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、私小説的なエッセンスとでも言えるものを、随所にばらまく結果ともなった。",
              "citation": {
                "source": "小説集「山吹の花」後記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはなあ、よく聴けよ、本の翼は、巴里の上空でばらまく。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは敗亡して、結構、ではやってみるがよかろうといって放りっぱなしておくと、果せるかな、叩きつけそこなって鮭をばらまく、そいつを大汗で掻き集めて罐へおしこむ、それをまたばらまくというえらい騒ぎになった。",
              "citation": {
                "source": "南部の鼻曲り",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガーエフ　妹は、まだ金をばらまく癖が直らんな。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆は必ずしも真ではないからかまわぬようなものであるが、そういう誤解の種をばらまく懸念は充分ある。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お辻、球のサツクを持つて来て、球台の上に球をばらまく。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小商人はこれでもう二日もこの停車場にお神輿を据えて、いろんな取卷き連にわいわい擔ぎ上げられながら、酒は浴びる錢はばらまくといった調子で、いまだに先へ行く列車に乘りこめずにいるのであった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、なぜ、こんなおめんをばらまくのでしょう」「それは、おうごんかめんが、このへんにあらわれるぞという前ぶれだよ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の新聞であれば、あえてそんな情報を世界にばらまくことはしない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールを大胆に横切りざま、うっかり手紙の束を袖に引っ掛けて床にばらまくへまをして、我が身の不器用さをののしった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
