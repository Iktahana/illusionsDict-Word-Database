          "literary": [
            {
              "text": "姿見の前でスカートのヒップのあたりをひと撫でし、戸締りをして家をとびだすと、光明寺のバス停留所のほうへ、歩いて行った。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "バス停留所の標識柱に、車体の端が触れた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最寄りの私鉄駅そしてバス停留所からの、自宅までの略地図を手紙で送ることを、五郎は約束した。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖の近くにあるバス停留所を降りると、湖まで普通に歩いて十五分だった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バス停留所から湖へ下りていく小径の入口まで、十分。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
