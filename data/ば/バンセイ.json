    "definitions": [
      {
        "index": 1,
        "gloss": "rough voice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と叫び、金盥も打ちつづけていまして、近所近辺の人たちも皆、起きて外へ飛び出し、騒ぎが大きくなるばかりでございましたので、おまわりは、蛮声を張りあげて、二階の者たちに、店の戸をあけろ！",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鴉声が蛮声に変った。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "観衆三百人、まず将軍の頭抜けて大きな蛮声に度肝を抜かれたのである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛮声終れば拍手｜急霰のごとし。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、あの雷の如き蛮声を張り上げる配属将校をさえ、実に容易に噴き出させる事が出来たのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と野田武蔵のたのもしい蛮声。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と打てば響く青砥の蛮声。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も本州の北端の宿へ来て、気宇が広大になつたのか、仰天するほどのおそろしい蛮声を張り上げた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大きく深呼吸を一つして、さらに蛮声を張り上げるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに、Ｎ君の気宇広大の蛮声には、度胆を抜かれたものらしい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　数枝は、呆れて、蛮声を発した。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笠井氏は既に泥酔に近く、あたりかまわず大声を張りあげて喚き散らすので、他の酔客たちも興が覚めた顔つきで、頬杖なんかつきながら、ぼんやり笠井氏の蛮声に耳を傾けていました。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の周囲にはいつのまにやら三等客の学生たちが有りったけの蛮声を張りあげていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁がイクラ教えてもその通りには決して出来なかったし、自分でも諦めていたと見えて思い切った蛮声を張上げて思う存分、勝手気儘な舞い方をした。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、慶一のアホだけで頭にきてんだからな」「慶一、野球部はまだやってるぞ」　と山崎が、ゴーレムのような蛮声でいう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏はねえのか、と酒の入った奴が蛮声をあげる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そのうち、正三もここでは皆がみんな蛮声の出し合いをしていることに気づいた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そのうち、正三もここでは皆がみんな蛮声の出し合ひをしてゐることに気づいた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇、剛健な気風を養ふと称して、近時、再びまた肩を怒らせ、一種の蛮声を張り上げるやうな学生の型を生ぜしめつゝあるのは考へものである。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意気は壮とするが、こればかりはねえ」　そういっているとき、受付の方角から、大きな蛮声がこっちへ響いてきた。",
              "citation": {
                "source": "空中漂流一週間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛮声といふ言葉ができてゐるくらゐだから、十分、声の文化性には関心をもつてゐる筈であるが、なんの必要あつてか、実に、奇々怪々な声を到るところできく。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "叫ぼうとこの自由だなんのほがらかに開けた正義だそうだ、ああ歌え、ああ叫べよ蛮声――その中に光っているもっとも聖らかなそして高貴な力、力、力、力新時代をここに打っ立てる歓喜の声彼等の暴虐のとりでを衝く声、声、声、声ああ素敵な……開け！",
              "citation": {
                "source": "労働祭歌（※）",
                "author": "松本淳三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桂鶴左衛門」「笑福亭松六」「月亭月松」　あとからあとから演説で潰してしまったような蛮声を張り上げて岡村は、芸人の名前を呼んだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は顫え上がって、両肘を突張り、狂気したような蛮声を上げた。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "離屋の敷居を跨ぐと同時に、「御用だッ」　八五郎は蛮声とともに、ガッキと組付いたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "密室",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥かの方から大山小太郎の蛮声が、真昼の街の空気に、遠慮もなく響いてくるのです。",
              "citation": {
                "source": "九つの鍵",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寄るな寄るな」　ガラッ八は精いっぱいの蛮声を張り上げてそれを喰い留めています。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はいよ、御免よ」　などと、八五郎は声を張りますが、場所が場所なり日和もよし、物好きでハチ切れそうになって居る江戸の野次馬は、事件を十重二十重に囲んで、八五郎の蛮声でも道を開いてはくれません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところ、文学の仕事をするものは、彼等の神経質さと、社会的未訓練から亢奮して、心の肌目の荒びた、強引な、力声と称する蛮声をあげ（詩人はまだその時期にいるが）ましたが、この頃はいくらか平正心に戻りかかってもいます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見はりは、水夫が引き受けた」　十六人のなかで、いちばんせいが高くて、声の大きい名物男、姓は川口、名は雷蔵という会員が、「せいの高い私が、いちばんいい。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
