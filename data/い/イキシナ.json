        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "行きしなに渋滞に巻き込まれたため、予定していた時刻より遅れて会議に到着しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "東京への行きしなに、景色の良いサービスエリアで休憩を取りました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "駅までの行きしなに、ふと立ち寄った書店で偶然にも探していた本を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "出張の行きしなに、車窓から見える緑豊かな田園風景に心が和んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "報道によると、事件は犯人が被害者の出勤の行きしなに発生したとみられています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あ、そういえば、公園の行きしなに新しいパン屋さんを見つけたんだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ハイキングの行きしなに、地元のお祭りの準備をしている様子を目にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "行きしなに、誰れでも外米は食いたくないんだから今度買ってきたら分けあって食べましょうと云って乗合バスに乗った。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "這入って行きしなに縄にふれると、向うで鈴が鳴った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを今夜のように、大勢引具して客となって来るのには、随分気を使ったことであろうと、店を出て行きしな、坂田がお内儀にしたていねいな挨拶が思い出されるのだった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て行きしな、伊都子は、「明日はもうお別れね。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て行きしな、自分の力で養えるようになったらきっと母を連れに来ますと雇人の森田に後のことを頼んだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばはんとうとう出て行きよったが、出て行きしな、風呂敷包持って行ったンはええけど、里子の俺は置いてきぼりや。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て行きしな、自分の力で養えるようになったらきっと母を連れに来ますと、集金人の山谷に後のことを頼んだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々龍吉の家にくるので知つてゐる須田巡査が出て行きしなに彼へ、「ねえ、小川君、實際こんなことがあるとたまらないよ。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度行きしなにコーヒーを運んで来る女の子とぶっつかりそうになると、ひったくるように茶碗を捉え上げて熱いのも構わずぐいぐい飲み干し、呆然となっている女の子や調理人達を尻目にあたふたと出て行くのだった。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後風邪の由聞知りたれば見舞に行きしなり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「予が覚えし頃より行はれしことなかりしが、その形にて刑場にて行はれしことあり、これは初めひきさらしの時自宅の前に連れゆき、数分時間馬を立て、その後刑場へつれて行きしなり」。",
              "citation": {
                "source": "せいばい",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかも行きしなに妹呉服の、咽喉を締めるという悪てんごうをして……」「気絶させたということではないか！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は出て行きしなに、パーヴェル・パーヴロヴィチの肩をぽんと叩いた。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルースも一緒に」　こうトリガーセンが玄関から出て、行きしなに怒鳴り散らした。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きしなに、よろずやのばあやんにも、ちょっときてもろてくれ。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりの少女が楽譜をもってためいきしながら藪のそばの草にすわる。",
              "citation": {
                "source": "マリヴロンと少女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにもひいきしないんだって、だから、僕、おとうさんのことを中立っていうのさ。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
