    },
    "definitions": [
      {
        "index": 1,
        "gloss": "painful experience",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その投機的な投資で多くの企業が痛い目を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "安易に個人情報を入力した結果、彼はフィッシング詐欺に遭い、痛い目を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "締切を甘く見た結果、徹夜で作業することになり、痛い目を見た経験から、以降は計画的に進めるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "規制当局は、安全基準を満たさない製品を販売した企業に、厳しい罰則を与え、痛い目を見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの時、もっとちゃんと確認しておけばよかった」と、彼は後悔した。まさに痛い目を見たのだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "楽して儲けようとする者は、大概、痛い目を見るものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "軽率な発言が原因で同僚との関係が悪化し、人間関係で痛い目を見ることもあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "なかば喪心の童子の鼻柱めがけて、石、投ぜられて、そのとき、そもそも、かれの不幸のはじめ、おのれの花の高さ誇らむプライドのみにて仕事するから、このような、痛い目に逢うのだ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さえあんなこしゃくなさしずをしなければ、私はこんな痛い目にもあわなかったんだよ。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればと云つて今自分がどんな反抗的計画を企てたところで、彼を痛い目に合はすことも出来ず「白川を優遇しなければならなかつたんだ」と思ひ染ませることも出来ない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公はもはや第一の通信を受けとるまへに、文豪になりそこねて痛い目に逢つてゐるのだから。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公はもはや第一の通信を受けとるまえに、文豪になりそこねて痛い目に逢っているのだから。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり明智光秀が小栗栖長兵衛に痛い目を見せられたばかりでは無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "果してそうであれば、傍杖を食ったおかみさんと自分はともあれ、主人が痛い目をみるのは是非ない事かとも思われた。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分が痛い目を見るだけだぞ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "袋小路に追いつめても、油断すると痛い目に遭います。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小厮、痛い目に逢わないうちに、返事をしろ、字が書けるか」「書けます」「そうか、それじゃ書け、婆あは、どうだ、婆あは書けまい」　お杉は文盲であった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、この節あ数寄屋町に居らあ、あの跳ッ返りめ、お先走りで、何でも来いだから、仁和加の時も、一本引ッこ抜いて使うんだからッて、それ痛い目に逢わないだけにして、本式に習いたいというので、お前ンとこの藤さんに仕込んでもらったな。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと気を許していると、浮き世離れした博愛主義者面で旧体制に挑む羽目になりますから、今後、電子本に味方する側からは、ずいぶん痛い目を見る人がでるでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに師匠とはいいながら、あまりに稽古が暴いというので、門弟のうちには窃かに左内を恨む者も出て来たが、その当時の駒込あたりには他に然るべき師匠もいないので、不満ながらも痛い目を忍んでいるのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと等しくて、マスクワキーインジアンも馬なかった昔は、かかる痛い目をせずに済んだのである。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて父やむをえず、板額は門破り、荒木又右衛門は関所を破る、常磐御前とここの城主はわが子のために、大事な操と陰嚢破ると、大津絵どころか痛い目をしてわれとわが手で両丸くり抜いた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど斬られたくば、痛い目に会わせてやろう！",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十五郎はもっと痛い目に会うているわッ、たわけものめがッ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "くくッて痛い目にあわさッしゃい！",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "身共もろ共痛い目にあわすはよいが、とくと先ずこれを見てから命と二人で相談せい！",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その二人を打ち殺したか」　脳を傷つけ、足を折り、さんざんの痛い目に逢わせたが、打ち殺すことを得ないでその行くえを見失ったと答えると、賈は嘆息した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟うに、私等親子の愛しみを受けて、曾て痛い目に遭った事なく、暢気に安泰に育ったから、それで此様に無邪気であったのだろうが、ああ、想出しても無念でならぬ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした人間といふものは、そのために後に手痛い目に逢ふことがあつても、それを幾度も繰り返してさへも、一向に性懲りのないものである。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五十八回　絵姿の眼　余は実に痛い目に遭った、真暗な一室へ閉じ籠められ、今は如何ともする事が出来ぬ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなものさせるから、痛い目をしたり不愉快な思いをする――と、じゃ誰もしないじゃないの」「――我慢していらっしゃい、いい子だから。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日痛い目を忍んで生きています。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　恐ろしいすばしっこさで、そのまま右門が表へ駆けだしたものでしたから、まだはっきりとわからないがだいたいめぼしのついた伝六も、しりをからげてあとを追いました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、昔と逆に、男がいたいめに合ふなんて、察しがなさすぎるよ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こっちへ来い、さわぐといたいめにあうぞ」　若菜はふるえあがった。",
              "citation": {
                "source": "伝四郎兄妹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出ていかないと、もっと、いたいめをみせてやるぞっ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でないと、いたいめを見せるぞッ。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
