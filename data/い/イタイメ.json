[
  {
    "uuid": "afbc079c-5385-5029-9efc-c615ba5980d6",
    "entry": "痛い目",
    "reading": {
      "primary": "いたいめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
