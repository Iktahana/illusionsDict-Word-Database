        "examples": {
          "standard": [
            {
              "text": "第一次世界大戦後、特定の地域が国際連盟の委任統治下に置かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "委任統治制度は、旧植民地の独立準備を目的としていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域はかつて某国の委任統治領だった歴史がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "委任統治のテニヤン、ヤップ、パラオ、サイパンはもちろん、時々は赤道直下のオーシャン付近からオーストラリヤ近くまでも延しますが、もちろん冒険ですから、運が悪いとやられてしまいます。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメット帽は、委任統治領では官吏だけのかぶるものになつてゐるらしい。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメット帽は、委任統治領では官吏だけのかぶるものになっているらしい。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "折を見て、連合国側にちょいと参加して、南洋の旧ドイツ領の委任統治地を稼いだし、青島に日本名で町名をつけることに成功したりした。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが委任統治領のグリニッチ島からは、東南へ八百キロくらいのところだ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その国際連盟というものは張学良の委任統治にしたほうが穏やかであろうという。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に南方の日本委任統治の島々から、蘭領印度地方に考へ及すと、語序は全く相違して居る様であるが、単に見た上の考へ方で、根柢の一致は多く求めることが出来るのである。",
              "citation": {
                "source": "熟語構成法から観察した語根論の断簡",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヨルダンのかなた」というのはこの地方の名称で、一名ペレヤとも言い、ガリラヤと同じくヘロデ・アンチパスの領内でありました（この地方は今日でもトランス・ジョルダン〔すなわち「ヨルダンのかなた」の意〕と呼ばれ、イギリスの委任統治地となっている）。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ第一次戦争が終り、旧ドイツ領の裏南洋が日本の委任統治領になった時、静雄は初代の民政署長になった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事は国際連盟本部の委任統治に関するものであった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュネーヴの思い出　国際連盟の仕事は、委任統治委員会の委員というので、日本の役人ではなく、日本側で指定した向うの人間になっていた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、満州は日本の生命線だの、南洋の委任統治諸島は日本の「海の生命線」だのという、甚だ「唯物論」的な宣伝が一頃〔軍部〕自身によって行われたからである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
