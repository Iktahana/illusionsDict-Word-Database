        "examples": {
          "standard": [
            {
              "text": "彼女は結婚式の二次会で、真紅のイブニングドレスを華麗に着こなしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パーティー会場には、様々なデザインのイブニングドレスをまとった女性たちが集まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特別な日のために、母と一緒にデパートでイブニングドレスを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "小郷虎吉が君勇や市龍や鈴子や弓子を連れて、キャバレー歌舞伎のホールへはいって行った時、イブニングドレスとジャズとステップの雰囲気の中で、最も新しい色彩を放ったかと、ふと錯覚を起させたのは、君勇の古風な島田であり、鈴子の舞妓姿であった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田や舞妓姿の時ならぬホールへの侵入という不意打ちの効果は、新スタイルのイブニングドレスさえふと古風に見せたくらい、それほど新しい感じがあった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
