    "definitions": [
      {
        "index": 1,
        "gloss": "woman who missed the chance of getting married (because she is too old)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "盆休みに帰省するたび、親から「行き遅れだの何だの」と小言を言われるのが苦痛でならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この歳まで独身だと、親戚の間では完全に行き遅れ扱いなのよ」と彼女は自嘲気味に笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周りの友人が次々と家庭を持っていく中で、自分だけが世間に取り残された行き遅れのように思えて焦りが募る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昭和の時代には、二十代後半にもなれば「行き遅れ」と見なされることも決して珍しくなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「行き遅れなんて失礼な。私は自分の意志で今の生活を選んでいるのよ」と彼女は毅然と言い放った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職場の飲み会で、上司が独身の女性社員を「行き遅れ」と揶揄したことが問題視された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "手紙ではときどき矢代は妹を慰めていたが、見舞いに行き遅れていたことは、汽車に乗ってからもやはり後悔めいた気持ちがした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
