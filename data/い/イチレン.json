        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この歌の二連目は、特に歌詞が心に響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は朗読会で、お気に入りの詩の一連を感情を込めて読み上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この連の終わりで、情景が一気に変わるのが面白いね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
