        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は両親にとって目に入れても痛くない一塊肉であり、過保護に育てられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "老夫婦は一塊肉である一人息子を事故で失い、深い悲しみに暮れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "後継者として厳しく育てられてきたが、彼女もまた両親の愛を一身に受ける一塊肉であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私は心配になるからだらうと思つてそつと枕元に行つて見るとおいよさんは其一塊肉のために私に訴へるのであつた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりはその始め、一種異様の、強項漢なりし一郎の、変れば変る変りかた、為也が前には骨なく我なく、ただこれ感激てふ熱血の通ふ、一塊肉と、なり果てしぞ、不可思議なる。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
