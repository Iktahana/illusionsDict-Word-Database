[
  {
    "uuid": "eb410fb8-31ec-5996-81b9-95b1c3701e3c",
    "entry": "一徹",
    "reading": {
      "primary": "いってつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
