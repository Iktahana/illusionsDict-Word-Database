    "definitions": [
      {
        "index": 1,
        "gloss": "to be fired up with enthusiasm for accomplishing something",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
