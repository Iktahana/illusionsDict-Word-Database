        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この大会で優勝するぞ！」選手たちは監督の熱い言葉に意気に燃えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい事業のビジョンに共感した若き起業家たちは、寝る間も惜しんで開発に意気に燃えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域活性化のために立ち上がったボランティアたちは、困難なプロジェクトにも意気に燃えて取り組んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の夢だったプログラミングスキル習得に、彼は定年後も意気に燃え続け、毎日学習を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "被災地の復興支援に駆けつけた若者たちは、その使命感に意気に燃え、精力的に活動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "未知の病原体の解析に成功した研究チームは、さらなる治療法開発に意気に燃えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今度こそ、この資格試験に合格するぞ！」彼女は決意を新たに、学習計画を立て直し、意気に燃えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
