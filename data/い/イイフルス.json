    "definitions": [
      {
        "index": 1,
        "gloss": "to say repeatedly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
