        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "暴力団による威迫行為は、決して許されるものではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、相手からの威迫にも屈せず、自分の信念を貫き通した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は、証人に対する威迫があったとして、慎重に捜査を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "死の如く静なる、冷やかなる、暗き、深き森林の中に坐して、此の如きの威迫を受けないものは誰も無からう。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と鬼のやうになつて、威迫したんでせう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十六講　ゾパル再び語る第二十章の研究◯ヨブは十九章において大なる啓示に接して光明全心に漲るに至り、今は友の上に優逸なる信仰の地歩を占むることとなりて、今までは友に撃たれつつありしに今は威迫を以て友に臨み得るに至った。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さも無いとことに於いては、この破邪の杖が、ずうんと、飛んでゆくぞよ」　雪之丞は、怪しくも、この低い、地を這うような音声に威迫された。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪路失踪以来、何度か、母親と彼とを威迫すべく訪れた、横山五助だということは、次の刹那に、すぐに思い出せたのであろう。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉幕府の要路者は日蓮への畏怖と、敬愛の情とをようやくに感じはじめたので、彼を威迫することをやめて、優遇によって懐柔しようと考えるようになった。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちへ向いても手足を延ばす余地を持たず、資本と強権との鉄条網をめぐらされて、機関銃と爆撃飛行機とに威迫されて、最後の生命線まで逐ひつめられてゐる無産窮民――即ち土民の心情とは縁遠いものだ。",
              "citation": {
                "source": "農本主義と土民思想",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "威迫されるような光景に、吾れ知らず懐中の赤ン坊を抱きしめているのである。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐原屋が絞め殺されているのを見た時、とっさにみなの頭にひらめいたのはこの考えだったが、そのやり方になんともいえぬ凄いところがあって、闇討ちや刀槍の威迫にはいっこう驚かぬ剛愎な連中も、さすがにどうも膚寒い気持で、その話にだけはなんとなく触れたくなく、諜しあわしたように口を噤んでいた。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "反乱軍のこの唐突な背反の動機は、ポチョムキンが、王党の、参謀本部附武官を威迫して、王女の自動車を狙撃させた陰険なからくりが士官の遺書から暴露したためだった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "李光明一派の莫大な報酬を手に入れるつもりで、例の、皇帝を日本官憲の手にかけさせるという、あの条件の方もやらせようとあなたを威迫した。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とおそろしい威迫を感じる声で、ズカリとくるなり足をあげて、般若丸を構えていた竹童の小手を横に蹴った。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味で私は本当の漫画と低級なポンチあるいはくすぐり画とを区別したい。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはくらみまた燃えて、　　降りくる雪の縞なすは、さは遠からぬ雲影の、　　　　　日を越し行くに外ならず。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先哲いはく……君子はあやふきに近よらず、いや頬杖で讀むに限る。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章をひきのばす努力のため、簡潔と明快と生気がまず失われ、文章は冗漫になり、あるいはくどくなり、あるいは難解にして無意味な言葉の羅列になった。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女は水に落ちたとき、きゃっとたかいさけび声を立てたとおもうと、ほのおのような目をした、大きな、黒いはくちょうになって、おさえられている手の下で、ばさばさやりました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "二どめに、水からでてくると、黒いはくちょうはもう白くなっていて、首のまわりに、黒い輪が、二つ三つのこっているだけでした。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　うちよせられた海草の上に、白いはくちょうの羽根が十一枚のこっていました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて高く舞り上がって、下をみると、紺青の海のうえに立つ白いあわは、なん百万と知れないはくちょうが、水のうえでおよいでいるようでした。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルナルドオのいはく。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハツバス・ダアダアは冷笑の調子にていはく。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはこれに便を得て、友の臂を把りていはく。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我傍を過ぐとて、我を顧みて冷笑ひていはく。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "友は指を堅てゝ我を威すまねしていはく。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "エネエアスが歌にいはく。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "友は遽に我｜臂を把りて、人にも聞ゆべき程なる聲していはく。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルナルドオは語を繼ぎていはく。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは平生｜夢寐の間に往來する所の情の、終に散じ終に銷すること此飛泉と同じきを想ひて、忽ち歌ひ起していはく。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年紀元節号「日本及日本人｣に、山内嵒氏いはく、雲南の大理府はこの草の原産地で、外国人はじめてこの花を広東で見た時、何の花ぞと問ふと大理牙（ダリヤです）と答へたるをそのまゝ花の名としたのだと。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
