  {
    "uuid": "5cb82b33-e77b-5b09-97ee-c22d96d8e80e",
    "entry": "威迫",
    "reading": {
      "primary": "いはく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
