        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古くなったセーターの袖口から、赤い毛糸が一縷だけほつれて垂れ下がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "軒先に張られた蜘蛛の巣が一縷、朝露に濡れて朝日の中でキラキラと光った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "煙突からは、細い一縷の煙が風に流されることなく真っ直ぐに立ち昇っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
