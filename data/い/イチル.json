          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "医師から手術の成功率は低いと宣告されても、家族は一縷の望みを捨てなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "遭難から三日が経過したが、救助隊はまだ生存しているという一縷の可能性にかけて捜索を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "圧倒的に不利な裁判だったが、新たに見つかった証拠が彼にとっての一縷の光となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分も新しい主婦の晴れやかな顔を見て、何となくこの店に一縷の明るい光がさすように思うた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれほど偶然的でない色々な災難の源を奥へ奥へ捜って行った時に、意外な事柄の継起によってそれが厄年前後における当人の精神的危機と一縷の関係をもっている事を発見するような場合はないものだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで医者ならば生き返らせることができるかとの一縷の望みをかけて、いっせいに医者に思いをあつめた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我邦の昔の「歌垣」の習俗の真相は伝わっていないが、もしかすると、これと一縷の縁を曳いているのではないかという空想も起し得られる。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡すかぎり、両側の森林これを覆ふのみにて、一個の人影すらなく、一縷の軽煙すら起らず、一の人語すら聞えず、寂々寥々として横はつて居る。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の空澄み渡って三里隔つる元越山の半腹からまっすぐに立ち上る一縷の青煙すら、ありありと目に浮かんで来る。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがやつぱり不治なぞといふことはないだらうと、私は猶｜一縷の望みは消さないで持つてゐたことに、誇りをさへ感じた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは晩春の頃からころころと啼き始めて、やがて湧き立つ様に野をこめる蛙の声が、どんなにめずらしくなつかしく、かやの稚い心をそそる夜も、秋祭りの野太鼓が、しきりに響いて渡る頃であっても、かすか乍らも澄み透って一縷の哀調を運ぶ横笛の音なのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へて見ると隨分覺束ない事だが、夫でも一縷の望の繋る樣にも感じて、吾等は如何にもして生命のあらん限り、櫻木大佐の援助を待つ積りだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから約一時間ばかりも経ったと思う頃、彼はあなたの大きい岩の狭間から、一縷の細い煙の迷い出づるを見た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその一縷の望みも絶え、今はその死を安からしめるために人々は集まり、慰めの言葉で臨終を見送ろうとするのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "努力して事に從ふのは素より立派な事では有るが、猶其の中に一縷の厭惡の情や苦痛の感の存するのを認め得べきである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は叫ばむとするに声｜出でず、蹶起きて逃げむと急るに、磐石一座夜着を圧して、身動きさへも得ならねば、我あることを気取らるまじと、愚や一縷の鼻息だもせず、心中に仏の御名を唱へながら、戦く手足は夜着を煽りて、波の如くに揺らめいたり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、まだ、かすかに一縷の望みがあったのでした。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし、心では一縷の望みを捨て切れなかった。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば深更｜一縷の燈火をもお貞は恐れて吹消し去るなり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、決して、虚飾や、阿諛からではなくて、如何なる場合にも他人に一縷の逃げ路を与えて寛ろがせるだけの余裕を、氏の善良性が氏から分泌させる自然の滋味に外ならないのです。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは不安ながらも一縷の望みをつないでいたのであるが、その縁談がいよいよ破裂と定まって源兵衛夫婦の失望はいうまでもなかった。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の問題もあるが、しかし、今よるべき一縷の糸もない新子のよりどころない心の寂しさが、そう決心させたのかもしれない。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（やっぱり病気だったのやわ）この考えは一縷の希望として秘めて置いたのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうではなくつて、意外にも又一縷の希望が萌して来たからでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　橘之助は垢の着かない綺麗な手を胸に置いて、香の薫を聞いていたが、一縷の煙は二条に細く分れ、尖がささ波のようにひらひらと、靡いて枕に懸った時、白菊の方に枕を返して横になって、弱々しゅう襟を左右に開いたのを、どうなさいます？",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし果してさるものありとせば、好しこの身自由となりし時、所有不幸不遇の人をも吸収して、彼らに一縷の光明を授けんこと、強ちに難からざるべしとは、当時の妾が感想なりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや一縷の望みを掛けているものならば、なおさらその覚悟の中に用意が無ければならぬ。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や一縷の望を掛けて居るものならば、猶更其覺悟の中に用意が無ければならぬ。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで醫者ならば生返らせる事が出來るかとの一縷の望をかけて、一齊に醫者に思ひをあつめた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲州屋に取っては、それがおぼつかない一縷の望みであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨブは大苦難の真只中にありて前後左右を暗黒に囲まれつつ、一縷この光明を抱いたのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
