          ],
          "literary": [
            {
              "text": "育英塾というのが昔あったんだそうだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうそう、仁田さんは育英塾に行ってたんだったな。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "育英事業　インフレーションによる学生生活の困難は、大半の学生に校外勤労による学費の補充をよぎなくさせている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は旧藩主の育英会から奨学資金を貸与されてここの高等学校を出たので、何年ぶりかの京都を享楽しようかと思ひ立つたのだ。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全国でも侯爵の県下の図書の豊かさは、一般に鳴り響いていることだったが、育児事業の完備と育英奨励も、これまたともに有名だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　高等小学校は、空堀筋、骨屋町角の、育英第一高等小学校というのである。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常小学校は、桃園を、高等小学校は、育英第一を（この三年時分から、先生に反抗するのを憶えた）、中学は、市岡を（ここで、物理の大砲という綽名の先生が、私を社会主義者だと云った。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日我國に於て、育英の任に當る教育家は、果して如何なる人間を造らんとして居るか。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日我国に於て、育英の任に当る教育家は、果して如何なる人間を造らんとしているか。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は営々として育英事業に尽瘁することここに三十有余年、此の如きは真にはじめてのことではないか！",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "西氏が前に家塾育英舍を開かれた時の通規に、「読書はなるたけ黙読せよ。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「和泉太郎、十六年二ヵ月、出生地はサイパン島……聖ジョセフ学院中学部一年Ｂ組、アダムス育英資金給費生……父はサイパン支庁の気象技師で、昭和十五年の死亡。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "余ヤ菲才浅学ニシテ府県ニ文部省ニ奉職シ育英ノ任ニ叨リ、尺寸ノ功ナク、常ニソノ職ヲ曠シクセシコトヲ羞ル耳。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや当今の教育英学を尊んで漢学を卑しむ。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから中村屋の西隣りに育英堂という新聞配達店があったが、借財整理のために、土地二百九十坪家屋つきで三万五千円で売りたいといい、私に交渉があった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――佃が死んだ――「遺児の育英資金を募集しているんでね、立つ前に、応分のことをして来た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父様が、その育英資金に加わって下すったの、ありがとうございました」　その晩、一日の終りにいつもそうして時をすごすとおりアーク燈にてらされている公園の木立を見おろすホテルの部屋の窓ぎわに立って、伸子は、公園の散歩で父からきいたことを思いかえしていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この頃方々に育英会というものがあって、時としては、いわゆる秀才をして、カフヱー通いを覚えさせるような事をしているが、この際それらに方向転換を要求して見る必要がありはしないか、などと考えたりした。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十八　漸く「育英會寄宿舍」とある大きな表札を見た時三藏は蘇生したやうに覺えた。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "育英會へ出掛けうか。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三藏は育英會寄宿舍の賄方と心易くなつて其周旋で或金貸しから今朝十圓の金を借りたのである。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日育英會寄宿舍の賄方の周旋で或金貸から借りた十圓の金、實はこれは北湖先生に返金する積りで調達したのであつた。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い返してみると、育英館の塾で三年いっしょでしたが、そのころから始まったようで、たぶん彼の人柄のためでしょう、いかにもしぜんなものですから、私のほうでも知らぬまにそれを受入れる習慣が付いてしまったようです。",
              "citation": {
                "source": "失蝶記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢然として野に下った彼は、百歩を退いて育英の事業に身を挺しようとしたのではなく、むしろ彼の政治的理想を将来につなごうとする積極的な動機が期せずして「東京専門学校」という形をとってあらわれてきたのである。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老先生は、六十余年横浜の教育界にあって育英につくされて来たが、関内芸妓をあげて遊ぶのは初めてだと仰っしゃった。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお互にさっきの事には小指の先でもさわらない様にいくえいくえにもおしつつんで心のすみの方につくねて居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
