    "definitions": [
      {
        "index": 1,
        "gloss": "to pray",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日の出と共に、彼は神殿で静かに祈りを捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "亡くなった祖母の冥福を祈り、お墓で手を合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「どうか、この願いが叶いますように」と、彼女は星に祈りを捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また精霊の降ると云い救われると云うのも、室の中あるいは戸外で神を念じ、祈りを捧げる時に生じることが多い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう目を閉じて、神に祈りを捧げるのがよい頃合であろうか。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると勇子は起きて昇る朝日に祈りを捧げる。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は　常春藤の籠にもり或時は　石蝋の壺に納め心　はるばると、祈りを捧げる　神よ、四時の　ささやかな人間の寄進を　納め給え、と。",
              "citation": {
                "source": "五月の空",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は十字架の前にひれ伏し、もう一度熱心に祈りを捧げる。",
              "citation": {
                "source": "誘惑",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああウラゴーゴル」　ドクトルは、神に祈りを捧げるときのような恰好をして、天を仰いで歎息をした。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、今はもう対照の漠然とした自分の内心の愛に祈りを捧げるような心持ちで、長い間息をこらしていた。",
              "citation": {
                "source": "運命のままに",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しい乍らもしつかりした聲で『神樣々々』と申しますので、最後の祈りを捧げるのだと知つて人々が耳をひきたてました。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昔、神功皇后の新羅征伐の時も、味方の勢が弱く今にも破れそうな時、皇后が天に祈りを捧げると、三羽の霊鳩がとんできて、戦はたちまち逆転、皇后の勝利となったことがある。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、天皇平安の祈りを捧げるために預っていた、如意輪観音の本尊も取上げられた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、乾し草の寝床で、ネロがおずおずと、痛ましい様子で偉大なルーベンスにお祈りを捧げるのも聞いていました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "退嬰期の古きものどもの中にはそれらの山脈に奇妙な祈りを捧げる者がいた――が、それらに近づいた者もその彼方に何があるか推測してみようとした者もいなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "基督教徒は、受苦聖母の前でどんな祈りを捧げるのであろうか。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（ハイミスはまるで彫像に祈りを捧げる尼僧のように目を伏せた）「それではと」彼はまた言い始めた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方は人より威張ったことなど決して言われませんでした、誰も傷つけず、そして決して人に悪いことはなさいませんでした」　二人の牧師、子供の合唱隊それに用務員が来て、無料で祈りを捧げるほど宗教が裕福でないこの時代としては、七〇フランに見合うだけの奉仕をしてくれた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち神はいつも自分の頭の上に位する天にいるものと思い、人が死ねば霊魂は天に昇るものと定め、神を呼ぶには、天に在ますわれらの神と言うて、それからめいめいのいのりをささげる。",
              "citation": {
                "source": "我らの哲学",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
