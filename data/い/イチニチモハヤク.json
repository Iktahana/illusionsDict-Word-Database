    "definitions": [
      {
        "index": 1,
        "gloss": "as soon as possible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一日も早く元気になって、また一緒に旅行に行こうね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この案件については、一日も早く結論を出していただきたいのですが。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「原因が究明されて、一日も早く解決されることを願っています。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ご注文の商品を一日も早くお手元にお届けできるよう、手配いたします。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「被災地が一日も早く復旧できるよう、私たちにできることをしたい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「締め切りが迫っているので、この資料を一日も早く確認してください。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この件は、一日も早く方向性を決める必要がありますね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本人は一日も早く西洋崇拝を根柢から断絶すべきである。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も早く「世界空中写真帳」といったようなものが完成されるといいと思う。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で一日も早く百円の金を作るが第一と、今度はそれのみに心を砕いたが、当もなんにもない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も卒業までと思ったろうし、又大学までとも志して居たろうけれど、人は一日も早く独立の生活を営む方が可えことはお前も知って居るだろう。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一日も早く独立の生活を営み得るようになり、自分は大塚の家から別れ、義弟の秀輔に家督を譲りたいものと深く心に決する処があったのです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初父はこれを許さざりしも急にかれの願いを入れて一日も早く出立せよと命ずるごとくに促しぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の事実をわれわれが一日も早くしかも誤謬によってはなはだしく曲げゆがめられた形で知らなければならない必要がどこにあるか私にはわからないのである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日本の一流の映画家、音楽家、俳人が力を合わせて、西洋人に先鞭をつけられないうちに、一日も早くオリジナルで芸術的でしかも大衆的におもしろい俳諧連句的映画の創作に着手する事を切望するものである。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の朝燕は、今日こそはしたわしいナイル川に一日も早く帰ろうと思って羽毛をつくろって羽ばたきをいたしますとまた王子がおよびになります。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長々御世話になってありがたかったがもう私もこの世には用のないからだになったからナイルの方に一日も早く帰ってくれ。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下を旅行する多くの人のために、吾人は一日も早く草津行赤馬車の全滅を祈るものである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "善は急げとか云いますから、一日も早く御婚礼を済まして、妾も安心したいと思うのですが……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お岩は貞女で、再び世帯を持つときの用意として年々の給料を貯蓄しているばかりか、その奉公している屋敷内の稲荷の社に日参して、一日も早く夫婦が一つに寄合うことが出来るようにと祈願していた。",
              "citation": {
                "source": "四谷怪談異説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人に対しては、せいぜい心をつけて一日も早く伜のゆくえを探し出せと命令した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これからどちらへ……」「どこという的もないが、ともかくも江戸じゅうを毎日歩いて、一日も早く探し出したいと思っているので……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も早く復活再刊の日が来ることを祈ります。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、英語は斯ういう風にやったらよかろうという自覚もなし、唯早く、一日も早くどんな書物を見ても、それに何が書いてあるかということを知りたくて堪らなかった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども人は一日も早く、そこから這いあがらなければいけません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も早く西洋の科学を消化して列国に拮抗しなければ、支那もまた、いたずらに老大国の自讃に酔いながら、みるみるお隣りの印度の運命を追うばかりであろう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと戦うには、彼の虎穴に敢然と飛び込んで、一日も早くその粋を学び取るより他は無い。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北条も此方に対しては北条｜陸奥守氏輝が後藤基信に好みを通じて以来仲を好くしている、猿面冠者を敵にして立上るなら北条の亡ぼされぬ前に一日も早く上州野州武州と切って出て北条に勢援すべきだが、仙道諸将とは予てよりの深仇宿敵であり、北条の手足を※ぐ為に出て居る秀吉方諸将の手並の程も詳しく承知しては居ぬ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も早くあの人を殺してあげなければならぬと、私は、いよいよ此のつらい決心を固めるだけでありました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは詩人たる自分としても、殊に一家の窮境を救ふ為めにも、どうしても一日も早く完成させねばならなかつたのである。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれはおたがいに協同努力して一日も早くこの大負傷をいやすことにつとめなければなりません。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此の礁が一日も早く除れまして、此の荒海を往来する諸人をお助けくださいますようにお願いいたします。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみれば、埋めてある財を一日も早く取出したいと思っているに相違ない。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も早く逐い出してください。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も早く江戸へ帰って療治をしなければなるまいかとも思った。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
