    "definitions": [
      {
        "index": 1,
        "gloss": "just now",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あ、今しも、あの鳥が飛んでいったぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この書類、今しも書いたばかりだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、彼がここにいるなんて。今しも会ったばかりなのに。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "やれ、嬉しや、たすけを求めて叫ぼうとして、窓の内を見ると、今しも燈台守の夫婦とその幼き女児とが、つつましくも仕合せな夕食の最中である。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも、その向いの家の表に訪れる浪人がある、後姿（大吉らしい）。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも長屋のお内儀二三人、ワイワイ話している。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも浪人者は若侍の一太刀受けてあッと倒れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半次行こう」と今しも大吉、　表の戸開けた時「御用」と一人の役人うって来る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも、その表に立ち止った一人の武者修業の侍（早水団九郎）　のこのこ門内へ入る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎心得て袍褞の儘、大悦びで、今しも殿様が、文六に金子を与えんとする時、　ヒラリと二階から、その中へ、とび下りた団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "義母は今しも下を向て蒲鉾を食ひ欠いで居らるゝ所であつた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口の彼方は長い縁側で三｜人も小女が坐つて居て其一人は此方を向き今しも十七八の姉樣に髮を結つて貰ふ最中。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "男体山麓の噴火口は明媚幽邃の中禅寺湖と変わっているがこの大噴火口はいつしか五穀実る数千町歩の田園とかわって村落幾個の樹林や麦畑が今しも斜陽静かに輝いている。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "影のごとき人今しも広辻を横ぎりて小橋の上をゆけり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる人類生活の条件と因縁とを離れて、自分自身の運命を絶対の自由さに支配し得る唯一無上の快い刹那は、今しも眼前数秒の裡に迫っている。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がある日、犬がちょいと台所へ来てみますと、コワ如何に……猫は今しも戸棚の中から大きな牛肉の一きれを引きずり出そうとして夢中になっている処でした。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いさま往来にはい上がって、今しもかじ棒を上げかけている車夫に土を投げつけた。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるから彼には同車の人々を見ること殆ど他界の者を見るが如く、彼と人々との間には越ゆ可からざる深谷の横はることを感ぜざるを得なかつたので、今しも汽車が同じ列車に人々及び彼を乗せて石狩の野を突過してゆくことは、恰度彼の一生のそれと同じやうに思はれたのである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が今しも車窓より眺むる処の雲の去来や、樺の林や恰度それであつた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今しも御最後川を渡りて浜に出で、浜づたいに小坪街道へと志しぬるなり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉がその単調な眠そうな声で鳴いている、寂とした日の光がじりじりと照りつけて、今しもこの古い士族屋敷は眠ったように静かである。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾個かの皿すでに洗いおわりて傍らに重ね、今しも洗う大皿は特に心を用うるさまに見ゆるは雪白なるに藍色の縁とりし品なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも一曲が終わったらしい、聴者の三四人は立ち去った。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲終れば、音を売るものの常として必ず笑み、必ず謙遜の言葉の二三を吐くなるに反して、彼は黙然として控え、今しもわが吹き終った音の虚空に消えゆく、消えゆきし、そのあとを逐うかと思わるるばかりであった。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて小石の上に、今しも一つの蝶がとまり、淡い、それでゐてくつきりとした影を落としてゐるのでした。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてもその夜は暑かりしや、夢の恐怖に悶えしや、紅裏の絹の掻巻、鳩尾を辷り退いて、寝衣の衣紋崩れたる、雪の膚に蚊帳の色、残燈の灯に青く染まって、枕に乱れた鬢の毛も、寝汗にしとど濡れたれば、襟白粉も水の薫、身はただ、今しも藻屑の中を浮び出でたかの思がする。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも汝が試みつる、苦痛を以て推して可なり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも船首甲板に於ける一等運轉手の指揮の下に、はや一｜團の水夫等は捲揚機の周圍に走せ集つて、次の一｜令と共に錨鎖を卷揚げん身構。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度洋とて千尋の水深ばかりではない、斯く立浪の騷いで居るのは、確に其邊に大暗礁の横つて居るとか、今しも我が弦月丸の進航しつゝある航路の底は一面の大海礁で蔽はれて居るのであらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と叫ぶので、愕いて頭を上げると、今しも一個の端艇が前方十四五ヤードの距離に泛んで居る、之は先刻多人數が乘つた爲に、轉覆した中の一艘であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私は昨夜海に浸つて、全濡になつた儘、黎明の風に寒相に慄へて居る、日出雄少年をば膝に抱上げ、今しも、太陽が暫時浮雲に隱れて、何となく薄淋しくなつた浪の面を眺めながら、胸の鏡に手を措くと、今度の航海は初から、不運の神が我等の身に跟尾つて居つた樣だ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、今しも射殺したる猛狒の死骸に眼を注いで『實は先刻急に思ひ立つて、此兵曹と共に遊獵に出たのが、天幸にも君等をお助け申す事になつたのです。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言ひながら今しも懷かしき母君の噂の出でたるに、逝にし夜の事ども懷ひ起して、愁然たる日出雄少年の頭髮を撫でつゝ『私はどうも春枝夫人は、其後無事に救はれた樣に想はれる。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
