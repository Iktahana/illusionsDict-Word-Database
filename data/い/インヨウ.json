[
  {
    "uuid": "032c6e73-6c02-58eb-bfea-b1039fe66290",
    "entry": "引用",
    "reading": {
      "primary": "いんよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
