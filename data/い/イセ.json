[
  {
    "uuid": "ee178fb0-6fd9-5dee-abf2-98563cb81d1c",
    "entry": "五十瀬",
    "reading": {
      "primary": "いせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "many torrents",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その渓谷を削り出した川は、五十瀬の響きと共に轟いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "登るにつれて水の音が大きくなり、ついに崖を流れ落ちる五十瀬を目にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "氷河の融水は数多の五十瀬を形成し、谷底を削り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その地域は、カヤッカーを惹きつける急流の連なりである壮大な五十瀬で知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古地図には、危険な五十瀬を特徴とする川に沿った道が示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "五十瀬と澄んだ淵を持つその人里離れた山間の小川は、手つかずの自然美の光景を提供した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "三河の山村ではこういうさいに、七ヵ所で水を浴びるので七瀬垢離といい、遠州の気多川すじではまた五十瀬百瀬などといって、だんだん上流のほうへ場所を変えて、水垢離を取ってお参りをする者もあるということである。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨百姓達の方は、その態度が心許ないせゐではないが、何分嶄新なその耕作法は、聴けども聴けども分らない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも手むかいせずに、こっちの殴った手へべっとりくっついて来る」急に真剣そうに声をひそめて、「あいつ、菊の手を平気で握りしめたんだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついせんだって僕は太宰治という男に逢ったよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ざしが強いせゐであらうか。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がいせんの折、陛下の御前に立ち、「なんの！",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、がいせんでございませうや。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままた犬の話などを持ち出しては、調子に乘つていい氣になつてゐるやうで、まるで見つともないのですが、私の家の小さい庭は日當りのよいせゐか、毎日いろんな犬が集まつて來て、たのみもせぬのに、きやんきやんごうごう、色んな形の格鬪の稽古をして見せるので實に閉口してゐます。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候はづれでそして休日でもないせゐか他にお客は一人もなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もうそこに鳥捕りの形はなくなって、却って、「あゝせいせいした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また窓の外で足をふんばってそらを見上げて鷺を捕る支度をしてゐるのかと思って、急いでそっちを見ましたが、外はいちめんのうつくしい砂子と白いすゝきの波ばかり、あの鳥捕りの広いせなかも尖った帽子も見えませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい美しい桔梗いろのがらんとした空の下を実に何万といふ小さな鳥どもが幾組も幾組もめいめいせわしくせわしく鳴いて通って行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このリンクの御客が概して地味で真面目で威張らない人の多いせいかもしれない。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うことの書けないのは世の中のせいかというような気もするが、これも猫の穴掘りと同様に実は自分の筆の通じが悪いせいかもしれないのである。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人体の周囲の空間が大きいせいかもしれない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はどうした訳か、この人の使用する青や緑と朱や紅との強い対照の刺戟が性に合わないせいでもあるか、どうも親しみを感じる訳に行かない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「健やんが云よったが、今日び景気がえいせに高等商業を出たらえらい銭がとれるんじゃとい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こっちの鍬はこんまいせにどうも深う掘れん。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな土を遊ばすは勿体ないせに。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「温くうなって歩きよいせに、ちっと東京見物にでも連れて行って貰おういの。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳が悪いせいか、「かん」が悪いせいか、本物の演説を聞くのでも骨の折れるくらいであるから、完全でない機械で変形された音波の混乱の中から、変形されない元の波を読取ることはなかなか困難である。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳は六畳いっぱいに吊られていて、きのう今日はまだ残暑が強いせいであろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱし、ここにゃ、日本の軍隊がいないせいだな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝや、それでも市に行きゃえらい者が多いせにどうなるやら分らんて。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校へやったんじゃが、うまいこと嘘をつかあ、……まあ、お前んとこの子供はえらいせに、旦那さんにでもなるわいの、ひひひ……。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、もう積金も何もえいせに、その警察へ何するんだけは怺えておくんなされ！",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから瀬川の鉄橋のたもとから髪の長いせいの低い太った人が出て来ます。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉吉はせいせいしてそれでもまだどこかに溶けない熱いかたまりがあるように思いながら小屋へ帰って来た。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もうそこに鳥捕りの形はなくなって、却って、「ああせいせいした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
