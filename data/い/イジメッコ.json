          ],
          "literary": [
            {
              "text": "二六　いじめっ子　幼稚園にはいっていた僕はほとんど誰にもいじめられなかった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし小学校へはいるが早いか僕はたちまち世間に多い「いじめっ子」というものにめぐり合った。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いじめっ子」は杉浦誉四郎である。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今漫然と「いじめっ子」の心理を考えている。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いじめっ子と、いじめられっ子とである。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも、せんだんは双葉より芳しく、強烈な腕ッ節に物をいわせて、いじめっ子の特権を誇示していた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる『いじめっ子』だ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の周囲にもやはりいじめっ子というものがいた。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら、おれも殺すぞッ」　克彦は、両手に靴を持って、泣きわめきながら、いじめっ子に向かって行く幼児のようになって、めちゃくちゃな力をふりしぼった。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
