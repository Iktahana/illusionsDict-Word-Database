        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仕事柄、彼は家を外にすることが多く、週末もなかなか家族と過ごせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は家を外にするのが好きで、休日はいつもどこかへ出かけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「最近、お父さん、家を外にすることが増えたわね。」「ええ、新しい趣味ができたみたいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生時代はサークル活動で家を外にする時間が長かったが、それが今の自分を形作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が小さいうちは家を外にすることが難しいが、大きくなればまた旅行にも行きたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は定年退職後もボランティア活動に精を出し、毎日家を外にする生活を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家を外にする機会が多いと、外食ばかりになってしまいがちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "許嫁のお萬を嫌つて、どうしても祝言しないばかりでなく、ツイ家を外にすることが多くなつたから、亡くなつた主人も支配人の半九郎（お萬の父）への義理で、若旦那を勘當したに違ひない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "雛の別れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "許嫁のお万をきらって、どうしても祝言しないばかりでなく、ツイ家を外にすることが多くなったから、亡くなった主人も支配人の半九郎（お万の父）への義理で、若旦那を勘当したに違いない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雛の別れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "金五郎は、家を外にするようになった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
