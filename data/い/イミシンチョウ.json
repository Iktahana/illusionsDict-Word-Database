[
  {
    "uuid": "9c7ef342-5bb3-50cf-acc5-497fa91950c6",
    "entry": "意味深長",
    "reading": {
      "primary": "いみしんちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
