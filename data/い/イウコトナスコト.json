        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あの新任の課長は、言うことなすことが鼻につくんだよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "反抗期に入った息子は、親の言うことなすことすべてに反発するようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼女は言うことなすことが上品で、育ちの良さが端々に現れているね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プロの勝負師ともなれば、対局中の言うことなすことすべてに何らかの意図が含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今の彼は言うことなすことが裏目に出てしまっていて、少し同情するよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "時代の寵児となったその起業家は、言うことなすことが即座にSNSで拡散され、トレンドを作り出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うちの孫は、言うことなすことが妙に大人びていて驚かされるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女の言うことなすこと、彼女の身ぶり物ごしのはしはしにも、微妙な、ふわふわした魅力が漂って、その隅々にまで、他人には真似のできぬ、ぴちぴちした力が溢れていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもノズドゥリョフが大の嘘つきで、彼の言うことなすこと何一つ信用の出来ないことは百も承知でいながら、しかも尚その彼に助けを求めるのだからおかしい。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ先帝を惜しみ奉らないものはない中で、ことにその悲しみを深くしたものは、言うことなすこと周囲に誤解された慶喜であろう。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二　ラエーフスキイがナヂェージダ・フョードロヴナに嫌悪を感ずるのは、なによりもまず、彼女の言うことなすことことごとく嘘乃至は嘘らしく見えてならぬからである。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「言うことなすことがよ。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は自分の言うことなすことはいつも覚えてるフランス人じゃないか。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや嫉妬深い女においては、彼女がいかに純潔で世帯上手であっても、その言うことなすことことごとく、何かとげとげした不愉快なものを感じさせずにはいない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
