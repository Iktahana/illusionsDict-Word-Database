[
  {
    "uuid": "d843180c-284a-5ba9-9437-631203ac69b0",
    "entry": "一日の長",
    "reading": {
      "primary": "いちじつのちょう",
      "alternatives": [
        "いちにちのちょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
