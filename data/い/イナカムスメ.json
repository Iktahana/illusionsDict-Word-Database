    "definitions": [
      {
        "index": 1,
        "gloss": "country girl",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は都会から来た人ではなく、純粋な田舎娘だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "絵本に出てくるような、健気な田舎娘のイメージ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "村のお祭りで、艶やかな着物姿の田舎娘たちが踊っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "都会の生活に憧れる田舎娘の物語。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "田舎娘は矢張り田舎娘だとさえも思ってはいないようだ。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴子は田舎娘に扮して、絣の着物の裾から白い脛を出していた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に類型的な田舎娘の扮装だったが、冴子はどうみても田舎娘になり切れなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その女優たちは舞台へ出ているのか、暖簾をあげて覗くと、鏡台――といっても、棚の上にのせられるような小型の鏡だが――の前に、冴子ひとり田舎娘の扮装のまましょぼんと坐ってるだけだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もところ／″＼の草を取つた、たまさかお化粧した田舎娘の顔のやうにまだら／＼だ！",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、「へへん」と田舎娘のような笑い方をして、まじまじむす子を見入っていると、むす子は眼を外らし、唇の笑いを歯で噛んでいった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャネットは全くみなし児の田舎娘として年頃近くまでロアール地方で育ったのであった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも意識し尽せぬ深い天然の力が、白痴であれ、田舎娘であれ、女に埋蔵されてゐて、強い情熱の鈎にかゝるときに等しくそれが牽き出される。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、小手しらべに田舎娘をだましてみて、女ごころというものを研究し、それからおもむろにドンファン修行に旅立とうという所存でいたのに、その田舎娘ひとりの研究に人生七十年を使ってしまったという笑い話。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、きつと、鎌倉時代によそから流れて来た不良青年の二人組が、何を隠さうそれがしは九郎判官、してまたこれなる髯男は武蔵坊弁慶、一夜の宿をたのむぞ、なんて言つて、田舎娘をたぶらかして歩いたのに違ひない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、上れとも云わなければ茶一つ出そうともしない代り、自分も付合って家へ上りもしないでいるのは、一つはお浪の心安立からでもあろうが、やはりまだ大人びぬ田舎娘の素樸なところからであろう。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天象、地気、草木、この時に当って、人事に属する、赤いものと言えば、読者は直ちに田舎娘の姨見舞か、酌婦の道行振を瞳に描かるるであろう。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巳之吉は森からの帰りに渡船に乗ったところで、風呂敷包を湯とんがけにした田舎娘が乗っていた。",
              "citation": {
                "source": "雪女",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いくら田舎娘だって、まだ泳ぐには。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「粋」という字に羽織を着せたような米朝の噺に、田舎娘が町の若い衆にのぼせ上がるように胸ときめかせてしまうオレは、正統派として育った枝雀の芸も正直見てみたい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ大騒ぎになって、近所の人達が駈けあつまると、女は十九か二十歳ぐらい、色白の小綺麗な娘ですが、見るからに野暮な田舎娘のこしらえで、引っ詰めに結った銀杏返しがむごたらしく頽れかかっていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもひと月ほど前の事だそうで、門前町のはずれに住んでいる塩煎餅屋のおかみさんが、茗荷谷の方へ用達しに出ると、その途中で花星のお住を見かけたのですが、お住は二十歳ぐらいの小綺麗な田舎娘と一緒に歩いていたそうです」「その田舎娘というのは縛られていた女か」と、半七はあわただしく訊き返した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は若粧りを得意として、実際はもう二十四、五であるにも拘らず、十八、九か精々｜二十歳ぐらいの若い女に見せかけて、殊更に野暮らしい田舎娘に扮していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女房や童女など、京のよい家にいた人などを何かの縁故からたくさん呼んだりして、たいそうなことを娘のためにしているらしいから、それでただの田舎娘ができ上がったら満足していられないわけだから、私などは娘も相当な価値のある女だろうと思うね」　だれかが言う。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ十六と十七の田舎娘ですから、こんな悪い奴に出逢っては赤児も同然、どうにも仕様がありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎左衛門の方でも野暮がたい田舎娘などを貰う気はなかった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつは毒々しい赤いカンナの花、ひとつは田舎娘に似たモモの花を私は思ひ浮べた。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "羞恥感情を亡くしたクレオパトラよりも、初心な田舎娘の方が、どれほど男の心を捕えるかわからない。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の一行の外には、洋服を着た会社員らしい二人連と、田舎娘とその母親らしい女連が、乗り合わしているだけである。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、それまでそのような雑誌に手を触れたことすらありませぬホントの田舎娘で御座いました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の茶畠に、笠を被った田舎娘の白い顔や雨に濡れた茶の芽を貫目にかけて筵にあける男の顔や、火爐に凭りかかって、終日好い声で歌をうたう茶師のさまなどが切々に思い出されて来る。",
              "citation": {
                "source": "新茶のかおり",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは貴婦人どころか、ただのいなかむすめとしか、おもわれないふうをしていました。",
              "citation": {
                "source": "灰だらけ姫",
                "author": "またの名「ガラスの上ぐつ」",
                "note": "青空文庫"
              }
            },
            {
              "text": "しらが頭に、白いあごひげのはえた、七十にちかいようなおじいさんと、十六―七のいなかむすめと、十二歳ぐらいの男の子と、としとったばあやとの四人ぐらしです。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなかむすめは、あまり美しくありませんし、男の子も、黒くよごれたきたない顔をしています。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それを聞くと、いなかむすめのマユミさんが、両手を頭にあげて、女のかつらを、スッポリとぬいでみせました。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
