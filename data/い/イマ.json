  {
    "uuid": "07b0bb48-8a1a-5658-9f39-f55f0de00026",
    "entry": "今",
    "reading": {
      "primary": "いま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "now",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ごめん、今向かっている途中だから、あと10分くらいで駅に着くよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "さっきまで激しく降っていた雨が、今になってようやく小降りになってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "あの時素直に謝っていれば、今頃こんなに気まずい思いをせずに済んだはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "冬の野原を夏の風が行くに煙が去つた情熱の火が突進するブツカルものもなく――だから不可ない昔からあつたものだのに今新たに起つたものだそれを如何して呉れるい横から眺めてゐるな誰の罪でもない必要ぢやない欲しいだけだ",
              "citation": {
                "source": "情慾",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に女には今日の表現が明日の存在になるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、今日はよいお天気です。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人となつた今日でさへ、さうした悲運はやみはせぬ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代といふ今は尠くも、あんな具合な元気さでゐられる時代ではないのです。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今晩かなしげに、かうして沈んでゐる僕が、輝き出でる時もある。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がもしそのことを欺いたとして、当今人々は云ふのである、「それはお前だけのことだ、お前の註文があるだけのことだ」と。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかく、それらの音楽によつて多くの人々が、好い気持にされてゐるのだから文句はないのだが、然しもと／＼気分の暈縁なぞといふオボコイものを聴いて喜んでゐる連中が取引のこととなると俄然骨ばつてくるし、而も楽々骨ばれるやうに前以て備へてゐるので、「音楽と世態」なぞと今並べてみたくなるのである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら詩性に乏しい現今は、兎角、あまりに貧弱なモチーフを取上げることから、多くの詩が妙な複雑に堕しがちである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がこのことに意を用ゐて呉れゝば、彼の詩は今後もつと迫力を持つこととならう。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて暫く案じた揚句、大抵はお断りすることとなるのでありますが、今もよつぽどお断りしようかと思つた所でありました。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、一つには私が今迄に、詩人である人と余りおつきあひして来なかつたといふことに過ぎないのかも知れません。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし相手がやはり詩人である場合は、随分容易に話が通じ、又互ひに利するのかも知れませんが、今の所私は、詩論といふものは殆んど無益だと諦め切つてゐる有様です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "超現実派の詩論なぞも読んでをりますが、そして所々非常な卓見にも遭遇しますが、要するに読んだ後では「今時誰も結論には到達しないのだ」といふ何時も乍らの呟きを繰返さなければならない始末です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の所猶概して印象の羅列以上のことを為し得てゐるとは思へませんが、あれらの努力が何時の日か一個完成したものに迄到達しないものではありますまい。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や、観念なぞ、無用の長物といつた有様である。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、「元気でないものはどこか間違つてゐる」といふが如き常識を以て、昨今のインテリ達を見た場合、創作家よりも翻訳家の方が、「間違つてゐない」といふことにもならう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今茲に、強ち観念を強調してゐるのではない。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今の如く、交際ばかりがうまくて、仕事はその交際のお景品のやうにしてゐるインテリが、インテリの中で比較的景気のよい方に属するといふが如き、そんな有様では、もともと冠履転倒である。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の云ひたいことは、今や、衣食住だけ足りれば好い人達の時勢だといふことである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに不思議な運命のそれ自体単純にして、それを織成す無限に複雑な因子の離合の間に、今や我々に既に分つたことは、宮沢賢治は死後間もなく認めらるるに至つたといふことである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年、「宮沢が死んだ」と聞いた時には、大変気の毒に思ひました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の我々の感性に近いもの、寧ろ民謡でさへある殉情詩が、此の殉情的な国で、今迄読まれなかつたなぞといふことは不思議だと、今度此の全集の第一巻が出た後では、諸君も必ずやさうお思ひになることと思ひます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は多くを申しません。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピカソ　当今、我々は落付いてはゐない。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、今仮りにその原因がシカと答解されたとしても、無数の現象の総和である現状は、直ちにどう変るものでもあるまい。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の詩を辿り乍ら、この稿を書いてゐる今、色々と心に浮ぶことを、何の反省をも加へずに、唯々書誌してみたいと思ふ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて、今よりも、子供の時分の方が、よつぽど海は好きだつたやうだから、してみると今よりも、あの頃の方が「こころまゝ」だつたのだらうか？",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
