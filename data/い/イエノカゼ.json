[
  {
    "uuid": "9861b1ae-3492-5e5c-8308-c7880f417944",
    "entry": "家の風",
    "reading": {
      "primary": "いえのかぜ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
