    "definitions": [
      {
        "index": 1,
        "gloss": "family tradition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "我が家では、客をもてなす際にはまず温かいお茶を出すのが家の風となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は「困っている人がいれば助けるのが、うちの家の風だからね」とよく言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎年元旦には家族全員で近くの神社へ初詣に行くのが、代々受け継がれる家の風だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この繊細な陶芸の技は、代々この家に伝わる家の風であり、門外不出とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は何事も丁寧にこなす。それも彼の家の風、とでも言うべきか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い家にはそれぞれ異なる家の風があり、それがその家の歴史を物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「失敗を恐れず挑戦する。それが我が家の風だよ」と父は笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "君は僕を非難して「大家の風格」がないと言ふ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯のつけようも効々しい女房ぶり、しかも何となく奥床しい、上品な、高家の風がある。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飛騨もかうして見ると、大家の風貌があるな。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにしてわが民族精神には、生に対する逞しい健康な気力がもとより備わっており、虚を去って実を採る、真実の理想家の風格があるので、進んでこの大乗の真理を歓迎し文化発展の動力に使ったのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯のつけやうも効々しい女房ぶり、然も何となく奥床しい、上品な、高家の風がある。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼方此方へ往って、何処の家の風呂でもおかまいなしに覗き込んで泣いていたが、終いには空の浴槽の中へ裸体で入っていたり、万一これをさまたげる者でもあると、火をつけようとするのに手がつけられなかった。",
              "citation": {
                "source": "風呂供養の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世のいわゆる「万鍾我において何をか加えん」の気骨も、炯々たるその眼光も、痩浪人の徒らなる誇負から離れて、既に堂々たる一家の風格を備えて来た。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老大家の風俗小説らしく昔の夢を追うてみたところで、現代の時代感覚とのズレは如何ともし難く、ただそれだけの風俗小説ではもう今日の作品として他愛がなさ過ぎる……。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがだん／＼募つて來ると村の隅から隅までふら／＼と押し歩いて小娘でもある家の風呂を覗くといふやうになる。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所隣のものは皆おすがの家の風呂を貰ひに來る。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母は夕方、構造を連れて畑のなかを通って、或る家の風呂へ入らして貰ひに行くのだった。",
              "citation": {
                "source": "棉の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふくろさんはもともとさういふ考へで、つまり実家の風には終ひまで弓を引かう……浦賀のおぢさんにさへ楯を突いて……」　小園は泣いてゐた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "角筈に住む水彩画家の風景画に私は到る処で出逢った。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥は寝所へ入ってからも、自分の知っているそういう家の風をいろいろ話して聞かした。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本でいう大作家の風格というものの内容は、古い文人時代の内容から、社会性においてそう大して新しくなっていると思われないのである。",
              "citation": {
                "source": "冬を越す蕾",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の風呂はポンプがこわれて駄目だから、夕方になると、円覚寺前の小料理やのようなところへ風呂と食事に出かけたりした。",
              "citation": {
                "source": "夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家の風呂場は裏の方にあつて、栓が長く背戸の小溝の上に出てゐるのも、文吾はよく知つてゐた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ吾家の風だな……多摩川ではむしむししてゐたけれど、吾家はこんなに凉しい風が吹く。",
              "citation": {
                "source": "多摩川",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも不思議のようにあるが、是れは如何しても私の家の風だと思います。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女の贋手紙夫れから塾中の奇談を云うと、そのときの塾生は大抵みな医者の子弟だから、頭は坊主か総髪で国から出て来るけれども、大阪の都会に居る間は半髪になって天下普通の武家の風がして見たい。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時の欲のために人の子を禽獣のごとくに使役し、一家の風俗を乱りて子孫の教育を害し、禍を天下に流して毒を後世に遺すもの、豈これを罪人と言わざるべけんや。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の友だちとは、俳人の露柴、洋画家の風中、蒔画師の如丹、――三人とも本名は明さないが、その道では知られた腕っ扱きである。",
              "citation": {
                "source": "魚河岸",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて行って見ると、此処の家の風呂場で、風呂桶に裸体で立って居る彼が、細い強そうな紐で、首をつって居る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家の風は父母の心を以て成るものなれば、子供の習慣は全く父母の一心に依頼するものというて可なり。",
              "citation": {
                "source": "教育の事",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家の風をも　吹かせてしがな」と言つた風の、伝統に執する必要のない町人の家庭では、あきらめも早い。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはなにも、これら新作家の才能を例外なく稀有なものだと推賞する理由にはならぬが、それぞれに専門家的な手腕と、稟質的な特色とを発揮して優に一家の風格を示し、且つ、何れも、日本人離れのした緻密な力作を提げて登場して来たことは、誠に前代未聞である。",
              "citation": {
                "source": "新撰劇作叢書刊行について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして此渇仰の大家の風貌に初めて接したのは『塩釜街道に白菊植ゑて何を聞く聞く、ソリヤ便りきく』の名邑を去る一里余、あやめが浦の海水浴場地の一ホテルに於てでした。",
              "citation": {
                "source": "漱石さんのロンドンにおけるエピソード",
                "author": "夏目夫人にまゐらす",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
