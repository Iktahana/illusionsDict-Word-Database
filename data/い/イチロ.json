    "definitions": [
      {
        "index": 1,
        "gloss": "straight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "列車は雪原を抜け、一路北へと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "優勝報告のため、選手たちは一路故郷を目指してバスに乗り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "頂上を目指して、ただ一路険しい山道を登り続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "緊急の連絡を受け、私は一路病院へと車を走らせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かつて菊池寛氏は某所に於て、今日の如き科學時代には、詩は衰滅の一路をたどるのみだと言つたが、この「科學時代」といふ言葉を、もし菊池氏の主觀に於て、夢を忘れた小常識人や、世渡り上手の小才智人のみが横行する時代、即ち要するに「小常識的俗物時代」といふ意味に解するならば、正にまちがひなく眞理である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬返しより太郎坊まで、羊歯の小自由国や、蘚苔の小王国を保護して、樅落葉松の純林、戟を揃へて隣々相立てるあり、これありて裾野の柔美式なる色相図に、剛健なる鉄銹色を点し、無敵の冬をも呵して、一路空山｜料峭の天に向ひて立つものあるなり。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日目に少しよくなったので、四人｜舁の椅子にのって山を下り一路ケンブリッジに帰った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近藤｜浩一路氏は近年「光」の画を描く事を研究しているように見える。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は亜丁湾を横切って孟買に一路船が進行をつづけるころになると急にアラビア海に顔をうつしてお化粧を始めてしまったのです――。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "近藤浩一路の四五点はおもしろいと思って見た。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば源森川の一路はその関するところ甚だ少からざる重要の一路たり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一条の水路は甚だ狭隘にしてかつ甚だ不潔なれども、不潔物その他の運搬には重要なる位置を占むること、その不快を極むるところの一路なるをも忌み厭ふに暇あらずして渠身不相応なる大船の数※出入するに徴して知るべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一条の水路もまた不潔と狭隘とを以て人の厭ふところなるが、これまた湿気排除のためと漕運の便とのために重要の一路たらずんばあらず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば三味線堀は今も既に不忍の池の余水を受くるといへども、なほこれを修治拡大して立派なる渠となし、また一路を分岐せしめて、竹町仲徒士町等を経て南の方秋葉の原鉄道貨物取扱所構内の水路に通じ、神田川に達するに至らしめなば、漕運の利は必ずしも大ならずとするも衛生上の益は決して尠少ならざるべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きのうの我れに飽きる人」の取るべき向上の一路に進まなければならない。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、若葉、青葉、雲いろ／＼の山々、雪を被いだ吾妻嶽を見渡して、一路長く、然も凸凹、ぐら／＼とする温泉の路を、此の親仁が挽くのだから、途中すがら面白い。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天に達するの正しい路は感傷の一路である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの虫の好きと一路通ずるものがありはしないか。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つね日頃より貴族の出を誇れる傲縦のマダム、かの女の情夫のあられもない、一路物慾、マダムの丸い顔、望見するより早く、お金くれえ、お金くれえ、と一語は高く、一語は低く、日毎夜毎のお念仏。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかの、あざ笑いの言葉も、このごろは、なくなって、枕もとの電気スタンドぼっと灯って居れば、あれは五時まえ、消えて居れば、しめた五時半、ものも言わず蚊帳を脱けだし、兵古帯ひきずり、一路、お医者へ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんづまりのどん底、おのれの誠実だけは疑わず、いたる所、生命かけての誠実ひれきし、訴えても、ただ、一路ルンペンの土管の生活にまで落ちてしまって、眼をぱちくり、三日三晩ねむらず考えてやっと判った。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を誤る者は多方にして、功を成す者は一路のみ。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し一路坦々砥の如く、而も春風に吹かれ、良馬に跨つて旅行するならば、努力は無い樣なものの、全部の旅行がさうばかりは行かぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "那須野が原へかかつて雨煙が野を籠めて路に塵も無く、一路坦々、砥の如く平らかに矢の如く直くして、目地遙かに人影を見ざる中を、可なりの速力で駛らせると、恰も活動寫眞を觀るが如くに遠くの小さな物が忽ち中位になり、大きくなつて、そして飛ぶやうに背後へ、抛げ遣るが如くに過ぎ失せてしまふのも一種の快味がある。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一路、生活の、謂わば改善に努力して、昨今の私は、少し愚かしくさえなっている。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）この笑いの波も灯のおかげ、どうやら順風の様子、一路平安を念じつつ綱を切ってするする出帆、題は、作家の友情について。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南関の上空よりそのまま一路ただ大阪へ大阪へと飛ぶ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、また私たちは、高原の、一路坦々たる、大虎杖の林の中に在る私たちを見出した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは生活の不如意に堪えながら側目もふらずに努力の一路を進んで来たのが、いくらかの成効に恵まれて少し心がゆるんでくる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "機は一路ワシントンへ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "片意地ではない、家のためだとはいうけれど、疳がつのってきては何もかもない、我意を通したい一路に落ちてしまう。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神を嘲る悪人にして成功また成功の一路を昇る者は決して少なくない。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ汽車にて本庄まで行き、それより児玉町を経て秩父に入る一路は児玉郡よりするものにて、東京より行かんにははなはだしく迂なるが如くなれども、馬車の接続など便よければこの路を取る人も少からず。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろんぼの兒は乳をのみ、頭をなんとなく撫でらるる快さに靜こころなくつく呼吸の、出で入る呼吸の、光澤のある母の皮膚を、なめらかなその胸をまた滑らかに撫でかへす…………夏の午過ぎ、ついちろちろと鳥のこゑ、水平線のかがやきは銀を流して一線に。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "voyage",
