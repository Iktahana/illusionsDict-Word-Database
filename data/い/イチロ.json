        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友人たちの見送りを受け、彼の乗った船は一路平安の旅路についた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "どうか一路ご無事で帰られますよう、心からお祈り申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼の前途には、希望に満ちた一路が開けているように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "旅立つにあたり、父はただ「一路平安」とだけ書いた手紙をくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
