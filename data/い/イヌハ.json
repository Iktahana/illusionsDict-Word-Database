        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「猫も可愛いけど、散歩に連れて行けるから私は断然犬派だな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自他共に認める犬派で、スマホの待ち受けも実家の柴犬にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「犬派と猫派で論争しても、結局はどっちも可愛いっていう結論になるよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どうしたんだろう、奥には誰もいぬはずだがと思って、不審にしてしばらく聞いていたです。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人が魅力を持つばかりでなく中納言の姿もまた趣味の高い女が興味を覚えるのに十分なものであるから、愛に報いぬはずはない、よい一対の男女であるから、相思の仲にもなるであろうと、こんな御想像のされるために、宮はわびしく腹だたしく、ねたましくお思いになった。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしお役にたつような男はかわるがわる差し上げてあるのですから、ただ今お話のようなとんでもない事件がありますれば私の耳にはいっていぬはずはございませんとお取り次ぎをもって申していただいて来ました。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「埋もれた青春」、その一つ一つに特別な感じと思いをうける、私にはそんなにはなされないほどのものではないけれ共一番始めにある埋れた春の幼い二人の子供の気持には落椿のはかなさといぬはりこの色の様に平凡なものでありながらはなれがたいなつかしみをうけた。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワカルパアチャポ、ワカルパアチャポ……あいぬは滅びるか。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベスは、スイート・ピイ、もくせい草、ひえん草、なでしこ、パンジイ、よもぎなど、古風な香りゆたかな花や、小鳥の餌になるはこべ、子猫のためのいぬはっかなどをうえました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "コリーいぬは　さえた　そのあたまを　かたむけながら、　はなしに　ききいりました。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと　コリーいぬは　そとへ　でまして。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "コリーいぬは　みみを　かまれていて、　こいぬたちは　どちらも　へろへろ。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぬは　ほえますし、　おとこのこは　あつまって　とおりで　くちぶえを　ふきますし、　すいじがかりも　おおわらいして、　すみこみの　おてつだいだって　かいだんを　かけのぼったり　おりたり、　それから　カナリアまで　ぴーぴー　ゆげを　ふくみたいに　うたうのです。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぬはぼうおういぬはぼうおう、ねこはみゅうみゅう、おぶたはぐるんぐるん、ねずみはすけえく。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "まこと神技の武術を身に持つ者なら、一兵卒たりとも、これを用いぬは、国家への不忠である。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なお筑前どののいわるるには、それ程の忠臣を殉じさせ、彼の忠魂に報いぬは、敵たりとも、心なきわざ、かつは中国の名族毛利に、全土の半ばを割かしむるのも気のどくの至り、五ヵ国の移譲の約束であるが、われは三ヵ国を取り、残り二ヵ国は宗治の忠節に免じておもどし申さん。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
