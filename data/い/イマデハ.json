[
  {
    "uuid": "9349872b-d9f1-5ba5-8de1-7bf943597d6b",
    "entry": "今では",
    "reading": {
      "primary": "いまでは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
