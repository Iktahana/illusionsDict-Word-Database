  {
    "uuid": "87926b2f-7414-56cd-a32d-1dcc73579fcd",
    "entry": "伊人",
    "reading": {
      "primary": "いじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Italian (person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ルネサンス期、多くの伊人芸術家がフィレンツェで才能を開花させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "かの高名な伊人デザイナーが手掛けたドレスは、洗練された美しさで人々を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "訪日中の伊人要人と、経済協力について会談が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "本場の味を追求するそのレストランは、シェフも給仕も全て伊人で揃えているというこだわりようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は、まるで古典映画から抜け出てきたような、物憂げな表情の伊人だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "セリエAで活躍する伊人ストライカーが、今季の得点王に輝いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "旅行先の小さな村で出会った伊人の老夫婦は、とても親切に道案内をしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "王国の賛沢な偕調が部屋を満たして、アングロサクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族｜希臘人、オットマン帝国の土耳古人等に交って、東洋の黄色な悲劇的な顔が七分の運と三分の運命に対する己惚れをもって、千金を夢みているのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はマダム・レムブルグの家でアングロ・サクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族｜希臘人の商人、オットマン帝国の土耳古人等と夜食を共にするのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はマダム・レムブルグの家でアングロ・サクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族希臘人の商人、オットマン帝国の土耳古人等と夜食を共にするのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニグロの中にも印伊人を凌ぐ学者がいるのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五世紀に伊人ポッジオが金銀よく汚れた物を浄くする一例として書いたは、ある富有な僧、極めて犬を愛し、その死するやこれを人間同様寺の墓場に葬った。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "同行者は日本歴史地理学会出張員藤井、宮崎の両文学士と芦田伊人氏とで、別に、九州における熱心家にその人ありと知られたる小倉中学校長文学士伊東尾四郎君は、わざわざその任地から来会され、遺蹟報告者熊毛郡視学西原為吉君をはじめ、有志の人々六七名、また案内かたがたともに登山せられた。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちや（茶）の、めいじんなり。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吾は再び拔き足して、母の傍に忍び寄ると、其の新らしいじんきの束を攫つて、更に物蔭へ隱れた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原・新町・島原等に於ける遊郭の本格的な遊びをするお客をだいじんと言ふ語で表してゐる。",
              "citation": {
                "source": "巫女と遊女と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おじいさんは、垣根のきわに植わっている、まだつぼみの堅いじんちょうげの葉についたどろを洗ってやりました。",
              "citation": {
                "source": "生きぬく力",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行ってはならん、そちを、だいじんにしてやるぞ！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこのドブの蓋の上の狭い通路をはさんで両側から、家々が背を向けようどころか、対々に堂々と正面向きで相向つてゐる賑はしさが、この細長いじんみちの尽きぬ面白さであつた。",
              "citation": {
                "source": "両国界隈",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんうえの姫君はお茶々どのと申し上げて、まだいたいけなお児でござりましたが、このお児が後に太閤殿下の御ちょうあいをおうけなされ、かたじけなくも右だいじん秀頼公のおふくろさまとおなりなされた淀のおん方であらせらりょうとは、まことに人のゆくすえはわからぬものでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがなきあとの菩提をとぶらい、子どものせいじんをみとゞけるこそ、つまたるものゝ勤めではないか。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで双方たいじんのまゝ三月がすぎ、四がつになりましてからいよ／＼とのさまもやながせ表へ御発向でござりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノロちゃんは、木のぼりのめいじんで、きょうは、スギの木にのぼらなければならないだろうと思って、そのよういをしてきたのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "木のぼりのめいじんのノロちゃんが、高いスギの木のてっぺんへのぼりましたが、はいるあななんて、どこにもありません。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、どんなにんげんにでも、どんなどうぶつにでもばけることのできるせかい一のめいじんだよ」「それじゃ、おじさんは、かいじん二十めんそうだな」「うふふふ……、そのとおりだ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうごんかめんこそ、人々からこわがられていたかいじん二十めんそうなのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、とうとうかいじん二十めんそうのすみかをつきとめたのだ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、かいじん四十めんそうとよんだほうがおきにいるかね」　あけちたんていは、林さんのかおをまっこうからゆびさしながら、はげしくいいました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たけしくんのおとうさんが、いい人だとあんしんしていた林さんが、きくもおそろしいかいじん四十めんそうだったとは。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "このかいじんは、へんそうのだいめいじんで、四十もちがったかおをもっているというので、四十めんそうとあだ名されていたのです。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴったりみについたくろシャツとベレーぼうのかいじん四十めんそうは、ペリスコープのつつに目をあてて、水の上のようすをながめていましたが、ぱっと、サーチライトの光が見え、それがこちらをおっているように思われたので、いそいで、ペリスコープをひきさげてしまいました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが、手じょうやぶりのめいじんだということをしらないのか」　パチンと音がして四十めんそうのりょう手から、手じょうがはずれてしまいました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "９二十めんそうのゆくえ　かいじん四十めんそうは、夜の東京港で、水上けいさつのモーターボートの上から、海の中にとびこんで、そのままゆくえ知れずになってしまいました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいじん四十めんそうのもとの名は、かいじん二十めんそうです。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "10ポケット小ぞう　かいじん二十めんそうが、たけしくんときみ子ちゃんのおとうさんのほうせきをねらっているというので、たけしくんの家では、いつも、げんじゅうな見はりがついていました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "六人が、このへやでがんばって見はっていれば、いくら、かいじん二十めんそうでも、ぬすみ出せるわけがありません」「わたしも、電話で、そういってやったのです。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "15黒いかげ　明智たんていと、おおぜいのおまわりさんに取りかこまれたかいじん二十めんそうは、屋根に上がって、そこから、まるでスーパーマンのように、空へとんでいってしまいました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
