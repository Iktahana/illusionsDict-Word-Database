    },
    "definitions": [
      {
        "index": 1,
        "gloss": "great person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史に名を刻んだ偉人たちの足跡を辿るべく、各地の記念館を丹念に巡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小学校の図書室で読み耽った偉人伝が、困難に立ち向かう今の私の精神的な支柱となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「歴史上の偉人といえども、一人の人間として苦悩し、泥臭く足掻いた時期があったはずだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "医学の飛躍的な発展に生涯を捧げた偉人の功績を称え、郷里の公園に銅像が建立された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は単なる成功者ではなく、人類の進歩に無私の精神で貢献した真の偉人と呼ぶべき人物だろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ああ、あのような偉人に一歩でも近づけるよう、日々自らを律して研鑽を積みたいものです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スピーチの掉尾を飾るべく、聴衆の勇気を奮い立たせる偉人の名言を引用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しからば子規子は、何をもって偉人なるか、予の考うるところをもってせば、一、天稟之脳力、二、絶対的態度すなわちこれなり。",
              "citation": {
                "source": "絶対的人格",
                "author": "正岡先生論",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに偉人は自覚的成功なし、活動に起り活動に終るは偉人の常なるがごとく、古今東西の偉人多くはしかるを見る、豊公の如き奈翁の如き、彼らは活動を知って満足を知らざるに似たり、偉人の成功は活動にして偉人の満足又活動に存するか。",
              "citation": {
                "source": "絶対的人格",
                "author": "正岡先生論",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対的態度　天質において偉人たりし子規子は人格においても偉人なり、そは子規子生涯を通じて一貫せる態度の絶対的なりしにあり。",
              "citation": {
                "source": "絶対的人格",
                "author": "正岡先生論",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教や伝説や偉人やその他一般に過去を題材とした新しい画から「新しい昔の幻像」を吹き込まれた例を捜してみたが容易に思い出せない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「偉人の容貌には奧深き美がある」といふことは、たしかに眞實である。",
              "citation": {
                "source": "室生犀星の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる思想上の偉人は結局最も意気地のない人間であったという事にでもなるだろうか。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し心とからだの安息を与えて、思いのままに彼の欲する仕事に没頭させた方が、かえって本当にこの稀有な偉人を尊重する所以でもあり、同時に世界人類の真の利益を図る所以にもなりはしまいか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊崇している偉人や大家がたちまちにして凡人以下になったりするのではだれでも不愉快である。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉人として、人の称讃を受けるくらいのことはそうむずかしいことではないとはっきり感じたのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古今東西に亘って輩出した哲人、偉人、英雄の殆んど大部分が、それぞれ信仰を以て心身の拠りどころとし、充分の活躍をなしたのは明白な事実であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か昔の偉人の言葉に、「あまり無頓着にやった仕事も本当でない、あまり凝り過ぎた仕事も本当の仕事でない」というのがあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　袂を支える旅僧と、押揉む二人の目の前へ、この時ずか、と顕われた偉人の姿、靄の中なる林のごとく、黄なる帷子、幕を蔽うて、廂へかけて仁王立、大音に、「通るぞう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の白熱した信仰體は、一種の偉人崇拜體に化してしまつた。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも前記三氏の場合、その三偉人はおのおの、その時、奇妙に高い優越感を抱いていたらしい節がほの見えて、あれでは茶坊主でも、馬子でも、ぶん殴りたくなるのも、もっともだと、かえってそれらの無頼漢に同情の心をさえ寄せていたのである。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのように私は元来、あの美談の偉人の心懐には少しも感服せず、かえって無頼漢どもに対して大いなる同情と共感を抱いていたつもりであったが、しかし、いま眼前に、この珍客を迎え、従来の私の木村神崎韓信観に、重大なる訂正をほどこさざるを得なくなって来たようであった。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖人偉人帝王豪傑は、星辰之に符し、雲氣之に應ずるものとして信ぜられて居たことは、歴史や雜書が吾人に語るところであるから、望氣の術が軍陣以外の事を包含して居たことも自ら明らかである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里、若しくは日本高円寺の恐るべき生活の中に往々見出し得るこの種の『半偉人』の中でも、サミュエルは特に『失敗せる傑作』を書く男であった。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兄は、」いかに言論の自由とは言っても、それは少しここに書くのがはばかりのあるくらいの、大偉人の名を彼は平然と誇らしげに述べて、「いいですか？",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の尊敬する偉人ルーズベルトが、両国交戦国に与へたる平和談判開始の警告也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉人と貧困の親善なる何ぞそれ斯くの如きや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から偉人には奇蹟が携わる、日を見て、月を見て、星を見て、いや、ちと大道うらないに似て来たかね。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "改革家として敬宇先生は無論偉大なる人物にあらざるも、保守家としての敬宇先生は、少くも思想界の一偉人なり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "福沢翁と敬宇先生とは新旧二大潮流の尤も視易き標本なり、吾人は極めて疎略なる評論を以て此二偉人を去らんとす。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども、　　　　　戦争に対する偉人の理想　は、労苦を以て敢て喪敗せざるなり。",
              "citation": {
                "source": "想断々（１）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは桃青を俳道の偉人として尊敬すると共に、馬琴を文界の巨人として畏敬せざるを得ず。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちや（茶）の、めいじんなり。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吾は再び拔き足して、母の傍に忍び寄ると、其の新らしいじんきの束を攫つて、更に物蔭へ隱れた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原・新町・島原等に於ける遊郭の本格的な遊びをするお客をだいじんと言ふ語で表してゐる。",
              "citation": {
                "source": "巫女と遊女と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おじいさんは、垣根のきわに植わっている、まだつぼみの堅いじんちょうげの葉についたどろを洗ってやりました。",
              "citation": {
                "source": "生きぬく力",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行ってはならん、そちを、だいじんにしてやるぞ！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
