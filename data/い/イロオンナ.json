    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good-looking woman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それともお新の云うように、いい加減のこしらえ事をして何処かの色女のところに隠れ遊びをしているのかと、お徳は半信半疑のうちにその夜をあかした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなしい板塀の圍ひの中でおれの色女が泣いてる聲をきいた夜つぴとへだ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そも粋と呼ばるゝ者、いかなる性質より成れるか、そも売色女の境遇より、如何なる自然の心を読み得るか。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「色女が死ぬるのだよ、悲しくはないかね」　讓の眼前には永久の闇が来た。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「色女が死ぬるんだよ、悲しくはないかね、」　譲の眼前には永久の闇が来た。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶と淡巴菰の接待をして、蛇の色女に嘗められるような話を聞こうというのじゃ。",
              "citation": {
                "source": "涼亭",
                "author": "――序に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『親なしに臥せる旅人』と思ってください」　と言いながら、御簾のほうへからだを寄せる源氏に、典侍はいっそう昔が帰って来た気がして、今も好色女らしく、歯の少なくなった曲がった口もとも想像される声で、甘えかかろうとしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなきゃ、おめえの色女かなんかが、一座のはやし方をでも勤めているはずだが、どうだ、違うか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来日本の学生は外国の文字に勝手な意味をつけるので、漢字でもそうだそうですが、Ｂの字を臀部の恰好に考えたり、ＩＷを色女なぞと読んで見たり、実にどうも……」　と先生は茶を飲んだ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とか「男同志でも、お前達位仲が好かつたら、色女などは欲しくはあるめえよ。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それとも色女かえ」　半七は笑いながら訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が可哀そうのようで」「此方の身も可哀そうだ」「それは色女に逢えないからでしょう」　二人の神経が段々｜尖って来た。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が可哀そうのようで」「此方の身も可哀そうだ」「それは色女に逢えないからでしょう」　二人の神経が段々尖って来た。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かういふ住ひで色女と一緒に暮して見るのも面白からうぢやアないか？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「色女と暮しながら、原稿を書いたり、讀書したりするにやアいい、ね。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下女奉公の口がありましたが、病氣でつとまらないからよしました」とあつたので、若しそれを氷峰にでも見られて、お前の色女は下女になつたのかなど冷かされては、今度もしかの女を札幌へ呼んだ時の自分の威嚴に關すると思つたからである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾でもない、色女でもない！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　加集はこちらを尻目にかけて、はしごを下り始めた時、義雄は言葉で追ツかけた――「貴さまのやうな奴が、ね、自分の色女をおしまひにやア賣り飛ばすのだぞ！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「學校がきまつても、金がつづかにや駄目ぢや――」かの女は下のかみさんを思ひ出したかして、「下のはな、色女であつたのが、かみさんを追ひ出して這入つたんやさうや。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうしたらヤングの畜生めスッカリ浦塩の警察を舐めてしまったらしく、今度は配下の水兵にお金を遣るかどうかして、めいめいの色女を十何人も軍艦に担ぎ込んで、上海かどこかの市場に売りに行こうとしやがった。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男でありながら、その顔の輪廓といひ表情といひ歩くときの様子から椅子に腰かける動作まですべてが媚を含めた色女みたいにいきでいろつぽくて会ふ人毎に柔らかい心を起させるものである。",
              "citation": {
                "source": "谷丹三の静かな小説",
                "author": "――あはせて・人生は甘美であるといふ話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻介の野郎ときては、十手をちらつかせて大ボラを吹きまくるくせに、この土地では色女が一人もないというシミッタレた野郎である。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "飛燕流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼太郎はいつになく酔払って、「お照、お前がおいらの娘でなくって、もしかこれが色女だったら生命も何もいらないな。",
              "citation": {
                "source": "雪解",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "色女なら一人ぐらいは居たかも知れませんが、あッちこッち手当り次第、別にこれという極った女は少いようで。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがあんたの何か名誉になるとでもいうんですかい――あっしずれの色女だということがさ？",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはお召とか縮緬とか云うものでもあろうか、芝居に出て来る色女や色男の着ているようなぞろりとした裾が、足の甲を包んで、ともすると砂地へべったりと引き摺るほどに垂れ下っている。",
              "citation": {
                "source": "母を恋うる記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへんな気の入れかたでね、舟からあげたときなどは、涙ぐんでおろおろしていました……父親の色女に惚れてならんという法律はないわけだから……」　主任が閉てきるような調子でいった。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かの女房で、誰かのいろおんなだよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、運転手の想像によると、撲った男はいろおんなを豹一にとられたのか、それとも「オリンピア」に頼まれてやったのかどちらかだというのであった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
