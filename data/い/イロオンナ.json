[
  {
    "uuid": "9cc5ab28-41f9-57c3-ab0a-ccb342fae5df",
    "entry": "色女",
    "reading": {
      "primary": "いろおんな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
