    "definitions": [
      {
        "index": 1,
        "gloss": "stern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "裁判官は、被告人の弁論を終始厳めしい表情で聞いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "校長先生は、問題を起こした生徒たちに厳めしい顔で注意を促した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の冒頭、部長は参加者全員に厳めしい声で「今日の議題は非常に重要だ」と切り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "違反者に対する厳めしい罰則が導入され、規律の維持が図られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖父は、孫のふざけた態度に「もう、そんなことは許さんぞ！」と厳めしい顔で言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "外相は、他国の挑発行為に対し、断固として厳めしい反対の意を表明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古代の神殿では、厳めしい儀式が執り行われ、参加者は静粛を保っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その城は、断崖の上にそびえ立ち、厳めしい外観で侵入者を威圧していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "坊さんはしばらく息をこらして気を取り直しそれから厳めしい声で願をたててから昨夜の続きをはじめました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瓔珞のかがやきと黒い厳めしい瞳。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳めしい鉄門の鉄柵越しに門前の様子を見定めると、電光の様に小潜りを出た。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし私の胸｜摶つた希望は今日を、厳めしい紺青となつて空から私に降りかゝる。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、形は著しいものではない、胸をくしゃくしゃと折って、坊主頭を、がく、と俯向けて唄うので、頸を抽いた転軫に掛る手つきは、鬼が角を弾くと言わば厳めしい、むしろ黒猫が居て顔を洗うというのに適する。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに又この頃は、日ごとに軍服｜厳めしい兵隊さんが帰省して来るというので、急に村の注意を惹き出した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　十四　円に桔梗の紋を染めた、厳めしい馬乗提灯が、暗夜にほのかに浮くと、これを捧げた手は、灯よりも白く、黒髪が艶々と映って、ほんのりと明い顔は、お町である。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "尠なくともかの女にはそう感じられ、ささやかな竹垣や、厳めしい石垣、格子のカナメ垣の墓囲いも、人間の小さい、いじらしい生前と死後との境を何か意味するように見える。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いろんな場合で葛西氏は、自ら力をこめて、厳めしいスタイリストの面目を発揮した。",
              "citation": {
                "source": "断想的に",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此処から入りますよ」　一つの厳めしい門がすぐきた。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は上りになって、クルックスベリーの丘の肩のところに行ったら、我々は老樫樹の中から屹立している、厳めしい廃院を見た。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、形は著しいものではない、胸をくしや／＼と折つて、坊主頭を、がく、と俯向けて唄ふので、頸を抽いた転軫に掛る手つきは、鬼が角を弾くと言はば厳めしい、寧ろ黒猫が居て顔を洗ふと言ふのに適する。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、苦しい／＼と唸るので、わたしは慌てゝ宿からサイダーをもらつて介抱すると、やがて泥酔の彼は、バネ仕掛のやうに飛びあがつて、不動の姿勢と同時に、厳めしい挙手の礼を保つのであつた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "などといふ厳めしい号令がかかつた。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲冑に身をかためた厳めしい武士も、毛鞘の刀をさした立派な大将も、すつかりてれてしまひました。",
              "citation": {
                "source": "泣き笑ひ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コムピーエの森だな、藤屋氏にとつての――」崖から崖へ差し渡した橋を渡るとピエル・フオンの館の厳めしい門である門の傍に丸型の実物大のブロンズの楯が掛つてゐる。",
              "citation": {
                "source": "ピエル・フオン訪問記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の祖母と相談をいたしましてお返辞をするといたしましょう」　こんなふうにてきぱき言う人が僧形の厳めしい人であるだけ、若い源氏には恥ずかしくて、望んでいることをなお続けて言うことができなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大変と尚更あわてゝ「お嫁さん……待てい」「お嫁さん……待つてくれい」　と死に物狂ひにその後を追ひかけましたが、とうとう画は森陰にある国の王城厳めしい高壁を越えてその中に這入つてしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大変と尚更あわてゝ「お嫁さん……待てい」「お嫁さん……待つてくれい」　と死に物狂ひにその後を追ひかけましたが、とうとう画は森陰にある国の王城の厳めしい高壁を越えてその中に這入つてしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が私の極印を押された許可状を持たずに、霊から引放した肉だけにお前の身売りをすると、そこに実質のない悪魔というものが、さも厳めしい実質を備えたらしく立ち現われるのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又お前が肉から強いて引き離した霊だけに身売りをすると、そこに実質のない天使というものが、さも厳めしい実質を備えたらしく立ち現われるのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの芳流閣の一番頂上の真青な屋根瓦の上に跨って、銀色の刀を振り上げております犬塚信乃の凜々しい姿や、厳めしい畠山重忠の前で琴を弾いております阿古屋の、色のさめたしおらしい姿を、繰返し繰返し夢に見るので御座います。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから押絵の下絵は、お母様が錦絵を二十枚ばかり持っておいでになるのと、お弟子から借りてお写しになった沢山の下書きの中から生れて来るのでしたが、優しいのや厳めしいのが見ているうちに出来てくるその面白さ……。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボール紙の鎧甲に身を固めた厳めしい武士が、馬に乗つて行つた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたのやうな厳めしい眼で、注意されてゐるかと思ふと安心なのです。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、ミツキイの入浴中、それは恰も国境を警備する番兵のやうな厳めしい顔をして、短銃を握つたまゝ張り番をしてゐるのであつた。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかめしい城郭のようなライブラリーも柔らかで憂鬱な霧の薄絹に包まれている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・バビロンの白煉瓦の高層な建物から流れるワルツの曲が街角に直立した赤い帽子の印度巡査をモスモロスの道化役者風にしたててバビロンの入口の廻転ドアの前に金モールのいかめしい英国人の門衛が莞爾とした笑いをたたえている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前だけ聞いたところではたいそういかめしいお役所のような気がして、書類の山の中で事務や手続きや規則の研究をしている所かと想像していたのであるが、事実はまるで反対で、それは立派な応用科学研究所であって多数の実験室にはそれぞれ有為な学者が居て色々有益で興味のある研究をしているのであった。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場も、塀も、社宅も、すべてが、いかめしい棘だらけの鉄によって庇護されている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
