        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あの警備員さんの顔、なんだか厳めしくて、ちょっと怖いね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館の規則は厳めしく、展示品には一切触れないよう厳重に注意が促されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の進行役を務める上司の厳めしい表情は、参加者たちに緊張感を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "厳かな儀式の開始にあたり、神官は厳めしい声で祝詞を奏上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お父さんの顔が厳めしいから、今日はもうお菓子は我慢しよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政府は、感染拡大防止のため、より厳めしい外出制限措置を導入すると発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
