[
  {
    "uuid": "1d61f3a9-02f9-59fe-bf09-baadb7cb1e53",
    "entry": "厳めしい",
    "reading": {
      "primary": "いかめしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
