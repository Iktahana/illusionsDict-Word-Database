[
  {
    "uuid": "e454d092-bcd2-5087-b44e-c19d3ed98cb0",
    "entry": "言いながら",
    "reading": {
      "primary": "いいながら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
