    },
    "definitions": [
      {
        "index": 1,
        "gloss": "with these words",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「もう疲れたよ」と言いながら、彼女は延々と続く階段を登り続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「これは君へのプレゼントだよ」と言いながら、彼はそっと箱を差し出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさかこんなことになるとは思わなかった」と言いながら、彼は首を振った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「よく見ててね、こうやるんだよ」と言いながら、ベテラン職人は細かな作業を実演した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「それは規則違反だよ」と言いながら、警備員は立ち入り禁止区域のロープを直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫、もうすぐ着くから」と言いながら、母親は迷子の子供を優しくなだめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「これが伝説の秘宝か！」と言いながら、冒険家は埃をかぶった宝箱を叩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "筆者がかつて評論した、有名なヘルンのエッセイ『ある女の日記』も、校本に拠るところがあるとは言いながら、実はその愛妻節子夫人を、半面のモデルにしたものと言われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた是非に参る、と、話のお土産』など言いながら、後ではいつも少し凋れて『しかしあなたの帰り、十時、十一時となります。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそんなてれかくしの冗談を言いながら、プラアゲ、プラアゲ、となおも低く呟きつづけている馬場を無理、矢理、自動車に押しこんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思慮分別の深い結納のお使者は、ひどく酔いました、これは、ひどく酔いました、と言いながら、紋附羽織と白足袋をまた風呂敷に包んで持って、どうやら無事に、会津藩士の邸宅から脱れ出ることが出来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はなんのかのと、不足は言いながらも、しんみりと落ち着いた心持ちで、花袋が読めた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉門次が一行の案内を務めるのは、言うまでもない、雨でグッショリ濡れた青草や、仆れている朽木からは、人の嗅覚をそそるような古い匂いがして、噎びそうだ、足が早いので、一丁も先になった嘉門次は、私を振り返って「他所の人足は使いづらくて困る」とブツブツ言いながら、赤石の河原に出た。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仲間にも話して聞かせる」と御礼を言いながら工事道具を肩にかけた。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十団子も小粒になりぬ秋の風という許六の句にあるその十団子を、もとこの辺で売ってたのだが」　主人はそう言いながら、一軒の駄菓子ものを並べて草鞋など吊ってある店先へ私を休ませた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはつまり例外なんで、二類に分れて混ずることなしと言いながらしかも例外、すなわち分れていない例がある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると田口の主人と話してから二週間もたった後のこと、夜の十時ごろでした、もう床につこうかと思っているところへ、「先生、お寝みですか」と言いながら私の室にはいって来たのは六蔵の母親です。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　哀れな母親は、その子の死を、かえって子のために幸福だと言いながらも泣いていました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ教授は長い竹箸でその一片をつまみ上げ「この中にはずいぶんいろいろなえらいものがはいっていたんだなあ」と言いながら、静かにそれを骨壺の中に入れた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものはありませんでしたよ」言いながら小僧は他所のをやっつけに行こう行こうとしてうわの空になっている。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっこいしょ、どっこいしょ」　お早うを言いにあがって来た信子は「まあ、温かね」と言いながら、蒲団を手｜摺りにかけた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またあちらでは女の子達が米つきばったを捕えては、「ねぎさん米つけ、何とか何とか」と言いながら米をつかせている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中に牛が見えるぜ」と言いながら弟をだました。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この教程は今考えてみると偶然とは言いながら実によくできていたと思う。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いやどうもありがとう」と言いながら何か書き留めていた手帳をかくしに収めた。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら、そろそろ梯子を上り始めて、私はその親子の姿を見て、ああ、あれだから、お母さんも佐吉さんを可愛くてたまらないのだ。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の作品を、そんなに悪く言いながら、この兄ご自身の作品は、どうかということになれば、そうなると、なんだか心細いものでした。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言いながらも僕たちは、三日に一度はその若松屋に行き、そこの二階の六畳で、ぶっ倒れるまで飲み、そうして遂に雑魚寝という事になる。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言いながらも、また、心の隅で、それでもどこか一ついいところがあるのだと、自分をたのみにしている頑固なものが、根づよく黒く、わだかまって居るような気がして、いよいよ自分が、わからなくなります。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言いながら、私はわくわく興奮しだした。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が市場のラジオの前に、じっと立ちつくしていたら、二、三人の女のひとが、聞いて行きましょうと言いながら私のまわりに集って来た。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は意外なようにしばらくじっとカムパネルラを見ていましたが、急いで、「では、よし」と言いながら、自分で星図を指しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人はしばらく棚をさがしてから、「これだけ拾って行けるかね」と言いながら、一枚の紙切れを渡しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう涼しいからね」　ジョバンニは立って窓をしめ、お皿やパンの袋をかたづけると勢いよく靴をはいて、「では一時間｜半で帰ってくるよ」と言いながら暗い戸口を出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると耳に手をあてて、わあわあと言いながら片足でぴょんぴょん跳んでいた小さな子供らは、ジョバンニがおもしろくてかけるのだと思って、わあいと叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが迎いにきたんだ」　カムパネルラは、なぜかそう言いながら、少し顔いろが青ざめて、どこか苦しいというふうでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀河だから光るんだよ」ジョバンニは言いながら、まるではね上がりたいくらい愉快になって、足をこつこつ鳴らし、窓から顔を出して、高く高く星めぐりの口笛を吹きながら一生けん命延びあがって、その天の川の水を、見きわめようとしましたが、はじめはどうしてもそれが、はっきりしませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
