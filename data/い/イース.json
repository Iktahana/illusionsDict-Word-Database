    "definitions": [
      {
        "index": 1,
        "gloss": "Ys (mythical city in Brittany)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
