        "examples": {
          "standard": [
            {
              "text": "「私、春先よりも秋のイネ科の花粉症がひどくて、この時期は鼻水が止まらないの」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ススキやエノコログサも実はイネ科の植物で、道端でよく見かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "竹や笹も分類上はイネ科に属すると知って、少し驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "広大な草原に広がるイネ科の植物たちが、風を切り裂くような音を立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "オウクランドに、看護婦修業時代の友人でアグネス・ワットというのが居て、このアグネスの許へ、遊びに行きたいから金を送って呉れとアイネから言って来たので、アグネスが、病院が休暇になる前に送金してやると、其の金でアイネは、二月二十二日にこのオウクランドのアグネス・ワットの家へやって来たのだった。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
