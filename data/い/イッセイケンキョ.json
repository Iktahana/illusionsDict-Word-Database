        "examples": {
          "standard": [
            {
              "text": "県警は組織的詐欺グループの拠点を突き止め、早朝からメンバーの一斉検挙に乗り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "繁華街の違法客引きを根絶するため、昨夜、警察官数百名による一斉検挙が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "違法薬物の密売ルートが特定され、主要な売人たちが一斉検挙されたというニュースが流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「いずれ一斉検挙になるだろう。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一斉検挙をするということが出て居ります。",
              "citation": {
                "source": "美しく豊な生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この奸吏共の悪事が安永三年の八月に至って抉剔され、一斉検挙となったのである。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴動―――コンミュニストの一斉検挙。",
              "citation": {
                "source": "獄内にてドイツの同志を思う歌",
                "author": "――高知牢獄にて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このようすじゃ、四朗もあぶないな」　赤羽工兵隊の工作班にいる四朗のことが心配になってきたらしく、克巳は爪を噛みながら考えていたが、煙草に火をつけると、「今朝、あるところで聞いたんだが、四五日前から、憲兵隊が一斉検挙をやっているらしいね。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
