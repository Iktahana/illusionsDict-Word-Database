        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おじいちゃん、今年の田んぼは稲虫の被害がひどいね」と、孫が黄金色の穂を悲しそうに見つめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無農薬栽培に挑戦しているが、稲虫との知恵比べは想像以上に過酷な闘いだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔の農村では、松明を掲げて稲虫を追い払う『虫送り』の行事が各地で行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "稲虫の一名｜稲別当、それを斎藤別当に因んで実盛というに及んだ由（『用捨箱』下）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度四つ角に立っている旧世紀遺物の鐘閣の前へ出ると跼っていたおいぼれの乞食達は手をさし伸べ、きたならしい乞食の子供達はどこからともなく稲虫のように群がって来た。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村で、昔から例外なく考へて居たのは、稲虫の出るのは死霊の祟りだと謂つた風に考へて居た事である。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "実盛人形は全国に分布して居るが、此は田の虫を誘うて連れて行くとも、又、稲虫を撒き散らすものとも、ちようど逆なことを、一つの物の上に考へて居る。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏から秋口へかけて、稲虫や流行病といふと、必思ひ浮べられた人々が、さう言ふ風にあつたのである。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の終り、夏に先だつて流行する疫病を予防する為の踊りであつたが、其元は、稲虫を払ふ踊りである。",
              "citation": {
                "source": "盆踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人はすべて物を並行的に考へるのが例で、田に稲虫が出ると、人間にも疫病が流行すると考へて居た。",
              "citation": {
                "source": "盆踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くは、田の神の犠として大切がられたので、牛の肉を喰べた為に稲虫が発生した、などゝ言ふ附会説が出来たのも、やはり此が、神の食物と考へられて居た、印象から出て居るのだと思はれる。",
              "citation": {
                "source": "田遊び祭りの概念",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其から、稲虫のつかぬ様に願ひ、其に関聯し易い悪霊を退散させようとしたのだ。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "田の稲虫から、又、其家主等の疫病を、直に聯想して、奈良以来、春・夏交叉期の疫病送りの踏歌類似のものと見做される様になつたのだ。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、木の花の散ることの遅速によって、稲の花および稔りの前兆と考え、できるだけ躊躇わせようとしたのが、意義を変じて、田には稲虫のつかぬようにとするものと考えられた。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、田の稲虫とともに村人に来る疫病は、逐わるべきものとなった。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁人形が稲虫になる、と信ぜられたのも無理はない。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　草人形の信仰我が国の伝説では、稲虫の発生に於ては、尠くとも横死した人の化成を、原因と説いてゐる様である。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し此考へは、尠くとも送り人形の正統ではなく、寧、怨念を懐いて殺された者が、稲虫になると言ふ考へ方の、元をたづねて見なければならない。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又佐倉宗吾郎も、死んで稲虫になつたと言はれてゐる。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に不思議な事は、壱岐の島に於ては、熊治右衛門以下三人の兇徒が、刑死して居るが、其は明治少し前の事で、伝説でも何でもない、明らかな事実であるにも拘らず、此にも、稲虫になつた話がついて居る。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、農村の生活に於ては、稲虫――其他、田の凶害――と怨念、或は刑罰とは、常に一続きに、聯想せられたのである。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で、佐倉宗吾郎の如き義人を考へると同時に、熊治右衛門の如き悪徒すらも、死んで稲虫になる事が出来た。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此から見ても、稲虫の話には、どうしても、送り人形の草人形の信仰が、結びついて居るものと見なければならない。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初年まで、年が悪くて、稲虫がついたとか、悪疫が流行したとかすると、盆に、二度目の正月をしてゐる。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "よごとを唱へると同時に、齢（よ）と穀（よ）とを荒す、疫病・稲虫を使ふ事も出来た。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も稲虫払ひには、草人形を担ぎ廻つて、遠方に棄てる。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲虫が皆附いて行つてしまふと考へるのである。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、木の花の散ることの遅速によつて、稲の花及び稔りの前兆と考へ、出来るだけ躊躇はせようとしたのが、意義を変じて、田には稲虫のつかぬ様にとするものと考へられた。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、田の稲虫と共に村人に来る疫病は、逐はるべきものとなつた。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は蛙、夏は稲虫、秋は蝗まろ。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はそこに自分の過失を償い、生かし、いなむしろその過失によっていっそう完きものに近づく知恵を獲得することができたと思っている。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は厭世を越えたるいなむしろ厭世そのものの中に見いだされたる楽天観をいうのである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、私がここに語りたいのは、この当為にはけっして抵触せずに、いなむしろこの当為を践み行なわんために、愛より必然に分泌せらるる二つの機能についてである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
