[
  {
    "uuid": "2a382a28-69b7-58f3-b645-c20d4054e070",
    "entry": "潔し",
    "reading": {
      "primary": "いさぎよし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
