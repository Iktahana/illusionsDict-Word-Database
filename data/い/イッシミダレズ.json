        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "儀仗隊の兵士たちは、一糸乱れず整列し、規律の正しさを示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はデスクの上を常に一糸乱れず整理しており、必要なものをすぐに見つけられるようにしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "30人のダンサーたちが一糸乱れず踊る姿は、圧巻だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "乗組員は上下を通じて、英国海員が伝統的に血に持つ沈着と機敏と勇敢さをもって一糸乱れずに行動したと言われている。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚太爺は枯木一束くくるにも一糸乱れずといふ風にくくらねば気が済まぬ質で、それを整然と炭焼小屋同然の家のまわりに積みあげて置くのが自慢だった。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから頭を洗ってからポマードか何かをこってりとなすりつけ、一糸乱れずてかてかに光らせることである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いつたやうな風で、互ひに即くまい即くまいと努めながら、それでゐて、要所要所は一糸乱れず呼吸が合つてゐたので、秀吉は期待した以上の面白い能を見ることができて満足したといふのである。",
              "citation": {
                "source": "演出",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が其共同生活の為に一糸乱れず自治的労働にいそしむ様は、実に涙ぐましい程立派なものである。",
              "citation": {
                "source": "吾等の使命",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その駅で乗り降りをしたものならすぐに気のつくぐらゐ万事に行き届いた駅で、ちようど乗換駅である関係から、駅員の指図に従つて、乗客は一糸乱れず、しかも、和気あいあいと車を降り、車に乗るといふたのもしい駅であるが、私はこの駅長とたびたび雑談を交す機会があつた。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが秩序整然、一糸乱れずという具合に行ったものですから、葬式は団に限るということになりました。",
              "citation": {
                "source": "冠婚葬祭博士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが又秩序整然一糸乱れずに行きましたから、評判を博して、御長女のを仰せつかりました。",
              "citation": {
                "source": "冠婚葬祭博士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて市電市バスの同盟罷業だが、争議団は東交幹部四十五名の解傭や、一般解傭の威嚇や、従業申し出での誘惑にも拘らず、一糸乱れず合理的に且つ合法的に罷業を行っていると伝えられている。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風なひさし髪に一糸乱れず結び上げ、りゅうとしたお召、縫いのある黒地の帯、小柄だががっちりとみが入った風采。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは狂熱的、昂奮的、反抗的であることは勿論だが、そのうちに、冷静なる史的根拠と、お銀様独断の順序が、一糸乱れずに存在していることはいるらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
