        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その温泉地では、硫黄泉特有の香りが辺り一面に漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "肌に良いと評判の硫黄泉にゆっくり浸かり、旅の疲れを癒した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "火山活動が活発な地域には、多くの良質な硫黄泉が湧き出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古くから湯治場として栄えたこの地には、豊富な湯量の硫黄泉がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "透明度の高いエメラルドグリーンの硫黄泉は、訪れる人々を魅了する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この硫黄泉は本当に温まるわね、体の芯からポカポカする」と友人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "源泉かけ流しの硫黄泉は、その鮮度と効能が格別だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "硫黄泉の成分分析を行い、その泉質が健康に与える影響を研究する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "加藤温泉とて、思いがけずも、一軒の家あるに、如何なる泉質かと鼻にて先ず知りしが、手を入れて、硫黄泉なるを確めぬ。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら好い温泉でも、酸性泉や硫黄泉では女には強過ぎた。",
              "citation": {
                "source": "女の温泉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫黄泉のききめばかりではない。",
              "citation": {
                "source": "夏遠き山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな一度は、ぱらちぶすに罹り、島の硫黄泉で、腹を損じた。",
              "citation": {
                "source": "鵠が音",
                "author": "島の消息",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵王山の麓に湧出る硫黄泉の湯尻が、一つの大きい滝瀬をなして流れてゐる。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫黄泉を源とする酢川の橋から石を投げたりなんぞして、しばらく歩くと、道端に五六本の漆の木がある。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日その準備をしてゐるんで、こつちでも氣が氣でないもんだから、此間から毎日酒ばかし飮んでゐた」木管でひいてる硫黄泉のドン／＼溢れ出てゐる廣い浴槽にふたりでつかりながら、自分は久しぶりで孤獨から救はれたホツとした氣持で、おせいに話しかけたりした。",
              "citation": {
                "source": "血を吐く",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために女は私とのあひゞきの始まりは常に硫黄泉へ行くことを主張した。",
              "citation": {
                "source": "いづこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し名に負ふ温泉は、今も華氏百〇四度の温度を保つて硫黄泉として存在して居る。",
              "citation": {
                "source": "温泉雜記",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅馬附近にはチヴオリへ行く道にバーニと稱する驛があり、今も臭い硫黄泉が出てゐることは、車中からも旅客が見る處である。",
              "citation": {
                "source": "温泉雜記",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために女は私とのあいびきの始まりは常に硫黄泉へ行くことを主張した。",
              "citation": {
                "source": "いずこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方へ下ると、多くの山は水際から直に聳えるらしく、その殆ど全部が火山性で、それ等の多くは煙を噴く火孔や、湯気を出す硫黄泉を持っている。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "アバノはパドヴァ近くの硫黄泉で有名な温泉地であってピエトロ・ダバノの名前はこの生まれた場所に由来している。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
