          ],
          "literary": [
            {
              "text": "いの一番に言わなきゃァならねェ肝心なのを忘れて居たよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のダルマさんが向う鉢巻でタワシ細工の熊に乗っていの一番に飛び出す。",
              "citation": {
                "source": "キューピー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の触出しについて、梟娘は何うしてもいの一番に願ひ出なければならないのであつたが、その家が富裕であるので、親たちも遠慮して差控へてゐるのを、町役人どもが相談して先づ親たちにも得心させ、その次第を書きあげて差出すと、係りの役人も額を皺めた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いの一番のお弟子入よ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたいだッて、たましいはあらア、ね」吉弥は僕の膝に来て、その上に手枕をして、「あたいの一番好きな人」と、僕の顔を仰向けに見あげた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "シー子の前では又、お前こそ俺のいの一番のシー子さんだと言明する。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「有一館の時代だったら、金硫黄と塩酸加里で覘われるところだったね」「そうだなあ、曰く伊沢道之、曰く山田三造、そう云う壮士に、いの一番に覘われているところだったね」　二人は無邪気に笑い合った。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いの一番に参詣して一年中の福徳を自分一人で受ける考え――朝はちょっと人が薄く、午前十時頃からまた追々雑踏するが、昼の客は割合にお人柄で、夕刻から夜に掛けてお店者並びに職人のわいわい連中が押して来て非常な騒ぎとなる。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "熊手を拵えて売ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとダシヌケに、ヤンチャを言っているお客さんの子供を抱き上げて、頬擦りをしてキャッキャと笑わせたり、十銭で三つぐらいの一番｜高価いお蜜柑を一円ばかりも買って来て、黙って私たちにバラ撒いたままプイッと外へ出て行ってしまったりしてトテモ気まぐれな人なのです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いの一番の筆頭は華族様、富豪なぞいう御方々で、東京では勿論の事、日本でも上流のパリパリ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いの一番に飛び出したのは真っ黒々の唐金のお釈迦様でした。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "検校はどんな音楽会でも、平曲だけは別物だといつて、いの一番に語らなければ承知しなかつたものだが、この日は一先づ琵琶を膝の上に置いて世間話をした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹違いの一番｜年長の弟、これも今では有望な医学士だ。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹違いの一番年長の弟、これも今では有望な医学士だ。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "この学校が出来て最も新らしい所へいの一番に乗り込んだ者は私――だけではないが、その一人は確かに私である。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いの一番にあらわれた神楽乙女は鈴子であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それよりも、前に述べたように、このエヴァンス技師――彼は職業柄 Sparks という綽名で通っていた快男子風の一種変った人物だった――が、もう十分間起きて無電機に向っていたら、いの一番にタイタニックのＳＯＳを把握して、何の事はなかったのである。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "検査官の一番偉い人が十貫目という字と私の顔を見比べて、どうかお大切になさいといって、いの一番で解放してくれたものである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ初めてという時に、その先頭を承るところのいの一番に乗り出すところのものは、よほどの勇気ある者でなければならない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも私はいつも新時代のいの一番を試み相勤める人達の勇気に対してかなりの尊敬を払っている。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "検査官の一番偉い人が十貫目と云う字と私の顔とを見比べて、どうかお大切になさいと云って、いの一番で解放してくれたものである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ついに二年前の昭和×年六月九日に、当時復活した所払いを、いの一番に適用されたので、やもなく騎西一家は東京を捨て、生地の弾左谿に帰還しなければならなくなってしまった。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沢小使いの一番おそれていたのは体操の先生の阪本少尉であった、かれは少尉の顔を見るといつも直立不動の姿勢で最敬礼をするのであった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "いの一番にこの川を見つけたのは、肥え太った鮭の群ででもあったろうか。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕まったのは、名簿のいの一番にあったイタリー人イグナチオ・ヴィテリオである。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸へ着いた時も、いの一番に飛び上がつて、いきなり、磯に立つて居た鼻たれ小僧をつらまへて中学校はどこだと聞いた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸へ着いた時も、いの一番に飛び上がって、いきなり、磯に立っていた鼻たれ小僧をつらまえて中学校はどこだと聞いた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がいの一番で、そうだろう、先約なんだから、これからは、僕の承諾なしに、マダムには指一本さすこともならない……とこういうわけさ。",
              "citation": {
                "source": "田舎者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その香いのいちばん奥に、中年の男に特有なふけのような不快な香い、他人ののであったなら葉子はひとたまりもなく鼻をおおうような不快な香いをかぎつけると、葉子は肉体的にも一種の陶酔を感じて来るのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前の大きなちゃぶ台をかこんで、右側に太郎と健がならび、左側に秀子とおばあさん、おじさんの真向かいのいちばん上り框に近い場所にお母さんがすわった。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
