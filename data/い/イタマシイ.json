[
  {
    "uuid": "e3e91039-ebeb-5c9a-a168-b2eb0629c2fc",
    "entry": "痛ましい",
    "reading": {
      "primary": "いたましい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
