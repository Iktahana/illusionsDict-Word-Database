    "definitions": [
      {
        "index": 1,
        "gloss": "pitiful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "連日のように報じられる痛ましい事故のニュースに、日本中が深い悲しみに包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "被災地の無残な光景はあまりにも痛ましく、現場に立った誰もが言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦争という痛ましい歴史を繰り返さないために、私たちは過去の過ちを学び続けなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "怪我を負いながらも必死にコートへ戻ろうとする選手の姿は、見るに痛ましく、観客席からは溜息が漏れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「幼い子供たちが犠牲になるなんて、本当に痛ましい事件ですね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「丹精込めて育てた果樹園が、たった一夜の嵐で全滅してしまうとは、なんとも痛ましい限りだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "晩年の八雲は、痛ましいまでその仕事に熱中した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして實に長い間、見るも無慙な、悲壯な痛ましい戰が續けられた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした痛ましい人生と、その實生活の日記とを、著者はすべて此等の詩篇に書いたのである。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまたそれによつて、僕等の孤獨な詩人の嘆きが、文壇の一部にも共通する嘆きであり、日本現代文化の矛盾と悲劇を内容するところの、痛ましい實相であることを知つて悲しくなつた。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の痛ましい悲壯な生涯は丁度ローマの哲學皇帝、背教者ジユリアンの悲劇を聯想させる。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に彼の場合は、敵も味方も悲劇であり、戰爭そのものが痛ましい宿命だつた。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしすぐと笑っているさまは、打たれたことをすっかり忘れてしまったらしく、これを見て私は、なおさらこの白痴の痛ましいことを感じました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はまず城山を捜すがよかろうと、田口の僕を一人連れて、ちょうちんの用意をして、心に怪しい痛ましいおもいをいだきながら、いつもの慣れた小道を登って城あとに達しました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかれと対座してその眼を見、その言葉をきくと、この例でもなお言い足りないで、さらに悲しい痛ましい命運の秘密が、その形骸のうちに潜んでいるように思われた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の前には美しく完成さるべかりし藝術品の痛ましい破片がある。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二三日また身体の具合がよくないそうで」「まあ……」　おぬいさんの顔には痛ましいという表情が眼と眉との間にあからさまに現われて、染まりやすい頬がかすかに紅く染まった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸を隔てて子供の泣く声は憐れにも痛ましいものであつた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんつぁんの顔には油汗のやうなものが浮いて、見るも痛ましい程青白くなつてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの若さで、あいつの生命はすつかり世帯くづれがしてゐると、それを私は痛ましいやうな気持で考へたりした。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチェこそは、実に近代の苦悩を一人で背負つた受難者であり、我々の時代の痛ましい殉教者であつた。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして此所に、親たちの痛ましい決意がある。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞでさへ何うして独逸に復讐してやらうかと考へ続けに考へて来た彼等が、愈となると、却て其独逸の為に領土の一部分を蹂躪されるばかりか、政庁さへ遠い所へ移さなければならなくなつたのは、彼等に取つて甚だ痛ましい事実である。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇長の遺書と前後して新聞紙上にあらはれた広瀬中佐の詩が、此遺書に比して甚だ月並なのは前者の記憶のまだ鮮かなる吾人の脳裏に一種痛ましい対照を印した。",
              "citation": {
                "source": "艇長の遺書と中佐の詩",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛ましいとは思ひながらも、むきに腹を立ててしまつた先生の姿を見てゐると、やつぱり可笑しさが先に立つて、私も吹き出した。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に入れられて水でびしよびしよに濡れた若い娘たちの痛ましい笑顔は、儀式といふ崇高な藝術的活動の裏にかくれた 〔e'rotique〕 であつたに相違ない。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "調和を失せる痛ましい日本が、一方に勤倹尚武を鼓吹しながら、同時また恁んな近代的情調を日比谷公園裏に蔵して居るといふ矛盾を笑はずには居られなかつた。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女」といふ考へが頭の底にこびり着くのは、男の一生の痛ましい革命の始まりである。",
              "citation": {
                "source": "いろ／＼の言葉と人",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の無邪気な利己主義が、痛ましい程愛他的傾向になり初めました。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか痛ましい気持がするではないか。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して各々の急所急所をきゆつと凝視めて、痛ましいほどの凌辱を相互に続ける、その恐怖と、憎々しさ、私は電球の尖をキツと差向けたまま、まるで青ざめはてた大刀の魚のやうに立ち竦んだ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "みだりに嘲り笑うよりも、むしろ気の毒な痛ましい人々ではあるまいかと思われた。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は痛ましい斷末魔の苦痛に水の中に仆れた儘、四本の肢で※いて、すんすんと泣いたが、其聲が段々弱るにつれて、肢も段々動かなくなつた。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかっているのは、銀子が失われたという、痛ましい事実だけなんだ」「…………」　土門はわけのわからぬ唸り声を出したが、いきなり、「握手しよう」と北山の手を握った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように痛ましい不始末は忘れるままがよいのではあるが、しかるべき配慮さえあれば、この一件を著してもよかろうと思われる。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいたましい最後の均一！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
