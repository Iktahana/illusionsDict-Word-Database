[
  {
    "uuid": "88cfa30a-b8ed-566a-be1e-f0a55b220094",
    "entry": "色目",
    "reading": {
      "primary": "いろめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
