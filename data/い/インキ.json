  {
    "uuid": "5fa7c639-70ed-5a3a-93bd-e12838a29fb8",
    "entry": "インキ",
    "reading": {
      "primary": "インキ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ink",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雨はまだ降るだらうかインキ壺をのぞいてニブリ加減をみよう",
              "citation": {
                "source": "（ツツケンドンに）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日を反映さする金茶色の唐松と、輝やく紅葉――そのくせ、もう枯れ枯れに萎び返って、葉の尖はインキを注したように、黒くなって、縮れている――で、夏ならば緑一色のちょんぼりした林が、今朝は二、三倍も広くなったような気がする。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "空が光ってキインキインと鳴っています。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時誰かの万年筆のインキがほんの少しばかり卓布を汚したのに対して、オーバーケルナーが五マルクとかの賠償金を請求した。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気な連中のうちの一人の江戸っ子が、「それじゃインキがどれだけ多くついてもやはり同じ事か」と聞いた。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか君の言行の影に、田舍新聞の印刷インキの臭ひがした。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この詩集に※入した金泥の口絵と、赤地に赤いインキで薄く画いた線画がその形見である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この赤い絵は、劇薬を包む赤い四角の紙に赤いインキで描かれてあつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なぜかなつかしくって、息子がインキで罫紙に書いた手紙を、鼻さきへ持って行って嗅いで見た。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑事が小卓のコップのそばにあった紙袋を取り上げて調べているのをのぞいて見たら、袋紙には赤インキの下手な字で「ベロナール」と書いてあった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぼこれと同大のガラス板に墨と赤および緑のインキでいいかげんな絵を描いたのをこの小さなスクリーンの直接の背後へくっつけて立てて、その後ろに石油ランプを置くだけである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青と赤のインキで塗った下手な鳥の絵のぼやけた映像を今でも思い出すことができる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の白地に黒インキで印刷した文字もあった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の野分しば／＼して、睡られぬ長き夜の、且つ朝寒く――インキの香の、じつと身に沁む新聞に――名門のお嬢さん、洋画家の夫人なれば――衣絵さんの（もう其の時は帰京して居た）重態が、玉の簾を吹ちぎり、金屏風を倒すばかり、嵐の如く世に響いた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリジナルは児童用の粗末な藁紙ノートブックに当時｜丸善で売っていた舶来の青黒インキで書いたものだそうであるが、それが変色してセピアがかった墨色になっている。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空が光ってキインキインと鳴ってゐます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "点けっ放しの百｜燭光に照らされたインキの文字がまだ青々していた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "セピアのインキで細かく書いたノートがいつも机上にあった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上にはラムプとインキ壷と硯箱とのほかに何んにもなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "インキの壺を、ふらここの如くに振つて、金釦にひしやげた角帽、かまひつけぬ風で、薄髯も剃らず遣放しな、威勢の可い、大學生がづか／＼と入つて來た。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――前刻、菅さんに逢つた時、私は折しも紅インキで校正をして居たが、組版の一面何行かに、ヴエスビヤス、噴火山の文宇があつた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "教へをうけようと、電氣を點けて、火鉢の上へ、あり合せた白紙をかざして、その紅いインキで、ヴヱスビヤス、ブエスビイヤス、ヴエスヴイヤス、ヴエスビイヤス、どれが正しいのでせう、と聞き／＼――彩り記した。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の代からの印刷業で、日がな一日油とインキに染って、こつこつ活字を拾うことだけを仕事にして、ミルクホール一軒覗きもしなかった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトンはインキの名。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトンはインキの名です。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車で下関へ着いたのは四時頃、茶碗、シヤボン、本、小刀、インキ等を買ふ、そして本町の馴染の宿へいつて荷物を預け、浴衣に着換へて、日和山公園へ登つて下つて、地橙孫居を訪ねた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "小いさな髑髏の印のついたレッテルに、赤いインキで（空虚の充実。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうち悲哀に包まれた人々の環視のうちに、注射の利き目は次第に衰え、銀子の目先に黒い幕が垂れ、黒インキのようにどろどろした水の激流に押し流されでもするように、銀子は止め度もなくずるずる深く沈んで行き、これが死ぬことだと思った瞬間に、一切が亡くなってしまった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
