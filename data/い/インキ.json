[
  {
    "uuid": "c612c5d8-0959-50e7-b915-a1c92a1728d9",
    "entry": "陰気",
    "reading": {
      "primary": "いんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gloomy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰しも陰気よりは陽気の方が凡そ好きなのに相違はないのに、「陽気な文学を」といふのが一つの文学上の提案となるためには少しくましな何事かであらねばならぬ。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと悪い場合を想像すれば、文学の雑文を書かうとして、何の文学に関するネタもない所から、どうも鬱々として、その揚句、「一体全体文学が陰気だぞ！",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "化物屋敷の一件以来、おそらくは『面白いの家』という言葉などが、一種の反語として家族中に流行し、すべての不潔の家、陰気な家などを指す代名詞になったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まえにも何回となく言って言い馴れているような諳誦口調であって、文章にすればいくらか熱のある言葉のようにもみえるが実際は、れいの嗄れた陰気くさい低声でもってさらさら言い流しているだけのことなのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて陰気くさくつて而もバラ／＼だ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "分つてゐてなほ分つてゐないと同様な態度で生きてゐなければならないかゞ分らなければならない――それは人が卑屈になるからだ、必要以上に陰気になるからだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした所は、単に温泉町そのものの気分が田舎めいて陰気くさいばかりでなく、周囲の自然そのものからして、妙に百姓じみて感じが重苦しい。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鮮緑といふやうな明るい感じがすきだから、百姓風のぢみくさい気分は陰気でいやだ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりそれは、田舎の湯治場にみる「賑やかな陰気さ」の反対である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦や娘は台所で立働いているのを裏口の方から見かける事があるが、一体に何処となく陰気なこの家内のさまは、日を経るに従うて自分の眼に映る。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰気な根津辺に燻ぶっていて、時たま此処らの明るい町の明るい店先へ立つと全く別世界へ出たような心持になって何となく愉快である。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを自分だけが陰気な穴の中で聞いているような気がする。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一体どうするのが、俺には一番いいのだろう）　彼は、暑さにジタバタする子供の寝顔を、薄暗い陰気な電燈の光に眺めた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "節はなるたけ陰気なのがいい。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼炭だぞ、泥炭があるぞ、さてこそこの平はもと沼だったな、道理でむやみに陰気なやうだ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一ぺん郷国へ帰りましてね、あすこも陰気でいやだから今度はこっちへ来たんです。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板から降る白墨の粉のような、暗い冷たい霧の粒が、そこら一面踊りまわり、あたりが俄にシインとして、陰気に陰気になりました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしボルツマンは陰気でアインシュタインは明るい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たましひが耳をすますと、陰気くさい声をして、黄いろい娘たちが合唱してゐる、合唱してゐる、波止場のくらい石垣で。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わたしはどこへ行くのか知らない、わたしのゆく道路の方角では、長屋の家根がべらべらと風にふかれてゐる、道ばたの陰気な空地では、ひからびた草の葉つぱがしなしなとほそくうごいて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、昨日、一昨日、俺の心をひどく陰気にしたものもそれなのだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは目を高い腕附きの椅子からそらして、ちよつとアウグステをばさんの陰気な額の上に休ませて、更に一転して、大いに意味ありげに女主人イレエネの顔に注いだ。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだん陰気なくせに、一たん向けられると、何という浅ましくがつがつ人情に饑えている様子を現わす年とった男だろうと思う。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "磨硝子色に厚みを保って陽気でも陰気でもなかった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくして彼は変に陰気な眼つきで健二の顔をうかゞいながら、「お上に手むかいしちゃ、却ってこっちの為になるまいことい。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の二階というのは、見た処、極く軒の低い家で、下の屋根と上の屋根との間に、一間の中窓が窮屈そうに挾まっている、其窓先に軒がさも鬱陶しく垂れて、陰気な影を窓の障子に映じている。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と云っていいか分らないが、妙にきらきら明るくていて、それで陰気なおどろおどろしい景色である。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたはおれが直接に出張って行くから案内してくれ」　あくる日も秋らしい陰気な雨がしょぼしょぼ降っていたが、熊蔵は約束通りに迎いに来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎の机の上で、今朝出掛に有合せの赤いんきで書いた覚書である。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
