[
  {
    "uuid": "b5408625-78ac-599c-bdfe-64417723ab9f",
    "entry": "忌み嫌う",
    "reading": {
      "primary": "いみきらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
