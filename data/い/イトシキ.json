          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遠い故郷に住む愛しき家族へ、無事を祈る手紙を綴った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "若き日の思い出は、今も胸に宿る愛しき宝物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "写真の中で微笑む、今は亡き愛しき友の顔が忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "筑波｜嶺に、雪かも降らる、否諾かも、愛しき児等が、布乾さるかも　山の祖神は、平地に禿立している紫色の山を望み、それは筑波という山であって、それには人身の形をした山神が住んでいることを聞き知った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、お互に愛しきったか何様だか、イヤお互に底の底までは愛しきれなかったに違無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗は秀吉の男ぶりに感じて之を愛したには相違ないが、帰ってから人に語って、其の底の底までは愛しきらぬところを洩したことは、尭雄僧都話に見えて居るとされている。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ、さは赤裸なる、盲ひなる、ひとり笑みつつ、声たてて小さく愛しき生の臍をまさぐりぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "子が死にて愛しき時計、形見よと、父は後愛で、命よと、いとほしと、日も夜も持ちき。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳河女学校にて額髪の笑ふ女童このごとくあどなきものを恋ふとありにし我老いぬただに愛しき額髪の面あげてあるその子ら見れば夏ごろも匂ふ少女は朝ひらくからたちの花と清しかるべし中学伝習館にて我、中学伝習館を学業卒へずして去りぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは畫工を愛しき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は無論弟を愛しきつてゐたからだ。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "Pan「愛しき Pipias よ、故郷を思ひ起すな、囚はれの女王様よ。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎ても亡びんうたかたの身にしあれば、息ある内に、最愛しき者を見もし見られもせんと辛くも思ひ決め、重景一人｜伴ひ、夜に紛れて屋島を逃れ、數々の憂き目を見て、阿波の結城の浦より名も恐ろしき鳴門の沖を漕ぎ過ぎて、辛く此地までは來つるぞや。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "初々しい坊ちゃん坊ちゃんした十三の私はだだをこねては姉たちを悩ましたが、もともと父や姉たちを愛しきっているのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は今に至るまで彼女を愛しき。",
              "citation": {
                "source": "「或る女」についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓉子がいつまでも僕を愛しきって行かれるかを。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾ち殿騰戸より出で迎えます時、伊邪奈岐命語りたまはく、愛しき我那邇妹命、吾汝と作れりし国未だ作り竟らず、故れ還りたまふべしと。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども愛しき我｜那勢命入り来ますことの恐ければ、まづ具に黄泉神と諭はん、我をな視たまひそ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川のやうに涙を流して愛しきれる気がした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは烏啼天駆です、愛しきお嬢さん――では恋を得ることは困難であろう。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            },
            {
              "text": "み吉野の玉松が枝は愛しきかも。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "』夫の聲は荒浪を裂く銛の音、――『愛しきわが妻よ、まぼろしのその古鏡偸み見て、さてこそ汝は――』『われはげに、われは嫉みぬ、尊かる淨土の寺の尼君の來まさざりせば身亡せけむ、おのれその時。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛しき児等が布乾さるかも（巻十四）といふ歌が、万葉集の東歌の中にある。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新嘗に我が夫をやりて、斎ふ此戸を（巻十四）鳰鳥の葛飾｜早稲を嘗すとも、その愛しきを、外に立てめやも（同）と言ふ名高い万葉集の東歌と、御祖神の宿を断つた富士の神の口実（常陸風土記）などに、其俤を留めてゐる。",
              "citation": {
                "source": "稲むらの蔭にて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "にほとりの　葛飾早稲を贄すとも、彼の愛しきを、外に立てめやも（万葉集巻十四）それから又斯ういふ風な歌は、皆前に言つた家族の出払つて、其後へ神が這入つて来ることを詠んだもので、此は非常に厳粛な宗教的年中行事でありまして、さうした夜に神の外に、男の忍んで来るといふ筈がない。",
              "citation": {
                "source": "古代生活に見えた恋愛",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳰鳥の葛飾｜早稲を贄すとも、彼愛しきを、外に立てめやも誰ぞ。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、長い間、悲惨のうちにも頼りきり愛しきって、崇拝に近い感情を寄せていた母親なのだ。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "新嘗に我が夫をやりて、斎ふ此戸を鳰鳥の葛飾早稲を新嘗すとも、その愛しきを、外に立てめやもとある。",
              "citation": {
                "source": "方言",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代日本語の習慣で言ふと「愛しき何某」、もつと古い言ひ方だと、語根風になつたかなしを用ゐて「愛し何某」と言ふ所だ。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉集巻十四の二首の東歌「にほとりの葛飾早稲をにへすとも、その愛しきを、外に立てめやも」「誰そや。",
              "citation": {
                "source": "まれびとの歴史",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、明らかに戸を押ぶる者は、まれびとの変形であり、その愛しきと言ふのも、おとづれる神を恋愛にうつして歌うたものと見るべきである。",
              "citation": {
                "source": "まれびとの歴史",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏は毎日でかけて行って、今日こそ染めて貰ひたい今日こそ染めて貰ひたいとしきりにうるさくせつきました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜蜂よ、蜜蜂よ、月をも日をも飛び越え、奥の奥なる空に往ゆき通い神のいぶきを汝が背にいのちの香油を、蜜蜂よ、やよ、いとしき、わが子に。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
