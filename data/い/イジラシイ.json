[
  {
    "uuid": "e1c7f25a-d46f-5d42-93ca-0c3b555627c8",
    "entry": "可憐しい",
    "reading": {
      "primary": "いじらしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
