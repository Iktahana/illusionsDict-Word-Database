          ],
          "literary": [
            {
              "text": "そういうところへ入ってきたのですが、こんな可笑しい言い間違いに今日の市民生活の全面が実にまざまざとうつっていてどんなに色んな証明書がいるかということが現れています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に言い間違いをしても機嫌が悪い。",
              "citation": {
                "source": "人生正会員",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は今、魚の群を見物するために、一番高い所へ案内しますといったが、それはいいまちがいだろう。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
