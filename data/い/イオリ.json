    "definitions": [
      {
        "index": 1,
        "gloss": "hermitage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山奥にひっそりと佇むその庵で、老詩人は晩年を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭の片隅に小さな庵を建て、趣味の陶芸に没頭する日々だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "茶の湯の精神を重んじる師は、簡素な庵で弟子たちを指導する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "都会の喧騒を離れ、彼はこの静かな庵に心の安寧を求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅の途中で一夜の宿として、山中の庵に立ち寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "画家は、自然光が差し込む庵で、ひたすら筆を走らせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "早朝、庵から聞こえる読経の声が、村人たちの目覚めを促した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「書斎というよりは、まるで隠者の庵のようだね」と友人は笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "凧のかげ夕方かけて読書かな夕立やかみなり走る隣ぐに沓かけや秋日にのびる馬の顔鯛の骨たたみにひらふ夜寒かな秋ふかき時計きざめり草の庵石垣に冬すみれ匂ひ別れけり　彼の俳句の風貌は、彼の人物と同じく粗剛で、田舎の手織木綿のやうに、極めて手触りがあらくゴツゴツしてゐる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬近し時雨の雲も此所よりぞ　洛東に芭蕉庵を訪ねた時の句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その崇拝する芭蕉の庵を、初めて親しく訪ねた日は、おそらく感激無量であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に年経て、古く物さびた庵の中には、今もなお故人の霊がいて、あの寂しい風流の道を楽しみ、静かな瞑想に耽っているように見えたか知れない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冬近し」という切迫した語調に始まるこの句の影には、芭蕉に対する無限の思慕と哀悼の情が含まれており、同時にまた芭蕉庵の物寂びた風情が、よく景象的に描き尽されている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "から鮭も空也の痩も寒の内　雲水に似た旅人芭蕉も、時には一定の住所に庵を構えて、冬の囲炉裏を囲みながら、侘しく暮していたこともある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昔思ふ草の庵の夜の雨に涙なそへそ山ほととぎす」これは「盧山雨声草庵中」といふ句のある白楽天の漢詩を日本風に訳したものだと言ふ。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武林無想庵氏の話によると、この余裕性をもたない都市は、世界で紐育と東京だけださうだが、それでもまだ喫茶店があるだけ、東京の方が大阪よりましかも知れない。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなども具体的内容は覚えていないが、この記事で窺われた当時の根岸子規庵の気分と云ったようなものだけははっきり思い出すことが出来る。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝ曇り初めし空に篁の色いよ／＼深くして清く静かなる里のさまいとなつかしく、願わくば一度は此処にしばらくの仮りの庵を結んで篁の虫の声｜小田の蛙の音にうき世の塵に汚れたる腸すゝがんなど思ううち汽車はいつしか上り坂にかゝりて両側の山迫り来る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯横町は右下半に曲線を描いて子規庵は長さ一センチくらいのいびつな長方形でしるされてある。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今久し振りにこの図を取出して見ていると三十年前の子規庵の光景がありありと思い出される。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その線路の右端の下方、すなわち紙の右下隅に鶯横町の彎曲した道があって、その片側にいびつな長方形のかいてあるのがすなわち子規庵の所在を示すらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ向う側に寒川氏の家があって、その隣が子規庵である。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、根が骨太の岩乘なからだであつたから、十日も經たぬうちに全快し、食慾は舊の如く旺盛で、色慾などもちよつと出て來て、よせばよいのに、またもや兎の庵にのこのこ出かける。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかしてこの自分の庵の附近から去つてもらひたくて、またもや惡魔的の一計を案出する。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに、草の庵とはいへ、まあ、結構な身分と申さざるを得ないであらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その草庵の垣根越しに、そつと覗いてみた者は、なあんだ、とがつかりさせられる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお爺さんの草庵の周圍の大竹藪にも、無數の雀が住んでゐて、朝夕、耳を聾せんばかりに騷ぎ立てる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀明水に達したるは午後七時に垂んとす、浅間社前の大石室に泊す、客は余を併せて四組七人、乾魚一枚、麩の味噌汁一杯、天保銭大の沢庵二切、晩餐の総べては是の如きのみ、葉マキ虫の葉を綴りて寝ぬる如く、一同皆｜蒲団に包まりて一睡す。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢庵漬の重石程な岩石の破片が数町離れた農家の屋根を抜けて、囲炉裏へ飛び込んだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛け取りに来た車屋のばあさんに頼んで、なんでもよいからと桂庵から連れて来てもらったのが美代という女であった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、この辺で事件は落着にしてもらいたい」　昭青年はこれを機として落髪して僧となり、別に河辺に鯉魚庵を開いて聖胎長養に入ったが、将来名器の噂が高い。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さす手ひく手の妙、面白の振りの中に錆びた禅味がたゆとうとて珍重されたのは、鯉魚庵の有力な檀越となって始終、道味聴聞の結果でありました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "聯の句は幾若葉はやし初の園の竹山桜思ふ色添ふ霞かな　主人は案内を知っていると見え、柴折戸を開けて中庭へ私を導き、そこから声をかけながら庵の中に入った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この庵の創始者の宗長は、連歌は宗祇の弟子で禅は一休に学んだというが、連歌師としての方が有名である。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長雨のふらくやまねば二荒の瀧見の旅を行きがてにすも根岸庵よりされ歌来る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "道のほとりに咲く草花、あからむ覆盆子などさすがになつかしくて根岸庵のあるじがり端書をやる。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "直に根岸庵を訪いて華厳の滝壺にて採りたる葉広草、戦塲が原の菖蒲の花など贈る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "下甲板の新嘉坡へ行く印度の行商人相手の物売りが上陸してしまうと汽笛が垂直に空から落下傘となって人々のうえに舞いおりる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
