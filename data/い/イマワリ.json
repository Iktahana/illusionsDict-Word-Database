[
  {
    "uuid": "95811752-eb25-53f1-ab5f-eed5585c4b89",
    "entry": "居回り",
    "reading": {
      "primary": "いまわり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
