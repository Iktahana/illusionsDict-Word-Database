        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「『紅』という漢字は、糸偏に『工』と書くんだよ」と母が教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "習字の時間、先生が「糸偏のつく字は、線の太さに気を付けて」と注意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は漢和辞典をめくり、糸偏の部首を持つ漢字を片っ端から調べていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "スマートフォンの画面に指で糸偏を書いて、目的の漢字を検索する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "そういうときにはやはり酒を飲まないとへんになるから飲む。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大久保」でくさってると、川口松太郎見物してゝ老けは全くうまいとへんなものを感心する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
