          "standard": [
            {
              "text": "「イタタ、タンスの角に足の小指をぶつけてしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「イタタタ！ 急にふくらはぎがつって動けない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「イタタ……。最近は立ち上がる時にどうしても腰が痛むんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「イタタ、そんなに強く腕を掴まないでください。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「イタタ、このお茶、淹れたてでかなり熱いね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「イタタタ。静電気のパチッという衝撃で指先がしびれた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「イタタ、裁縫中に針の先でうっかり指を突いてしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ヒラガナトカタカナハ相前後シテ生レタラシイガ、前者ハ毛筆ト和紙ニ対シ適合性ヲ持ツテイタタメ今日マデ愛用サレタニ反シ後者ハ適合性ヲ持タナカツタタメ、一千年ノ間カエリミラレルコトガナカツタ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「啖付いても大事ないかえ」「歯が立ったなら鰻を今一パイ喰わせる……アイタタタ……待て……待てチウタラ……」　廊下を通りかかった女中が吃驚したらしく襖を開けたが、木乃伊親爺の二の腕に付いてる濡れた歯型を見ると、呆気に取られたまま突立っていた。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイタタ、まあひどいのネ此の児は。",
              "citation": {
                "source": "熊と猪",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイタタ、何といふ乱暴な子だらう、此の子は。",
              "citation": {
                "source": "熊と猪",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろあれの親も、盗人じやあないが、お金を遣ひ込んで這入つたんだといふからね』　折しも次間に人の気配、奥様誰ぞと声かけたまへば、大村でござるといふ声の、噛付くやうに聞こへしにぞ、さてはと奥様お奥へ逃入りたまふに、三もとつかは流しもとへ退らむとしての出合頭、ぬつと入来る一郎に突当られてアイタタタタ。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「ア痛、アイタタタッ……」　跛をひきながら、草むらよりころげだしたのは竹童である。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
