        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "１月は正月休みがあり、帰省や挨拶回りで親戚一同が顔を合わせる機会が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今年の１月は例年に比べて冷え込みが厳しく、日本海側を中心に記録的な積雪となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "１月の第２月曜日は「成人の日」に定められており、全国各地で華やかな式典が催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "１月に入ると、受験生はいよいよ大学入学共通テストに向けた本格的な追い込みの時期を迎える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しい手帳の１月のページを開き、真っさらな紙面に今年一年の抱負を書き留める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "１月の茶席では、宮中の「御引実」にちなんだ新春の菓子として、白味噌餡のごぼうを包んだ「花びら餅」が供される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "１月下旬から２月にかけては、一年のうちで最も気温が下がる時期であり、インフルエンザの流行もピークを迎えることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "明治39年１月『馬醉木』署名　　　　左千夫",
              "citation": {
                "source": "八幡の森",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『文藝』1937年１月号）-----------------------------------------------------------------　貸家札　熱帯地方の砂漠の中で、一疋の獅子が昼寝をして居た。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "良夜１月の夜のよう枯れし白樺なる。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　国際間の調和　欧米先進諸国の多くがすでに保護期間を「死後70年」としており、アジア太平洋地域においても、シンガポールが本年７月「死後70年」を採用し、オーストラリアでも来年１月に延長されることが確実視されている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正12年１月23日〜旭川新聞）------------------------------------------------------------------焼かれた魚　白い皿の上にのつた焼かれた秋刀魚は、たまらなく海が恋しくなりました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正12年１月23日〜旭川新聞）焼かれた魚　白い皿の上にのつた焼かれた秋刀魚は、たまらなく海が恋しくなりました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和３年１月「中央公論」）",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和３年１月19日〜25日「時事新報」）",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治41年１月「趣味」）",
              "citation": {
                "source": "背負揚",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正13年１月「改造」）",
              "citation": {
                "source": "余震の一夜",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正15年１月「文芸春秋」）",
              "citation": {
                "source": "倒れた花瓶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "（日本近代文学館・小田切進編、講談社発行「日本近代文学大辞典」昭和53年１月18日第三刷を参照した。",
              "citation": {
                "source": "風狂私語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "（詩神第五巻第一号　昭和４年１月発行）",
              "citation": {
                "source": "跡",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九二九、一一、九）（南方詩人　昭和５年１月発行）",
              "citation": {
                "source": "身辺雑記",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ある長篇の一節）（一九一九年六月）（「新潮」大正９年１月号）",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（'29年１月１日号）",
              "citation": {
                "source": "日本趣味映画",
                "author": "溝口健二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は1831年12月29日に病気になり、続く熱病によって1832年１月４日に死亡した。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "村には下痢が何例かあったが１月９日の晩まで新しいコレラの病例は無く、その晩から次の朝までに13人が病気になった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレラの最初の例と大発生のあいだに数日が過ぎているので、汚れたリネンを洗った水が小川に流れこんで、１月の９日から10日の晩に病気になった13人に病気を感染させたものと思われる。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸籍本署長官がロンドンで1853年８月における流行の初めから1854年１月の終了までのコレラで死亡したすべてのリストを刊行したので、サザック・アンド・ヴォクソール会社とランベス会社が水を供給している、テムズ川の南岸の種々のサブディストリクトにおける死亡者数を加え合わせることができるようになった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会への報告によるとサザック・アンド・ヴォクソール社は1853年１月１日から12月31日のあいだ40,046軒の家、ランベス社は同じ時期に25,107軒の家に供給していた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "サザック・アンド・ヴォクソール社の水をグレイアム、ミラー、ホフマンの諸氏が1851年１月後半に調べたときに1.99グレインの塩化ナトリウム、すなわち今年の９月の12分の１または1854年11月21日の15分の１、しか含んでいなかった(16)。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "１月か２月後で木の桶を開くと、かなりの量の炭化水素や硫化水素が逃げ出し、水は黒くほとんど我慢できないほどひどい。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に酒精を漉して分けてそれに残りの材料を混ぜ、樽に１月置くと、瓶に詰められるようになる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで瓶に詰めてもう１月冷やすと使えるようになる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「１月17日に北からのハイフライヤー・コーチの旅客たちがいつものようにニューアーク（イングランド北部）で食事をとった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして１月のあいだ胸、胃、腸に膨満感を伴う熱と重さを感じた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、初版刊行の１月も経たないうちにアークムは図書館の本を破いた罪で告発され帰国せざるを得なくなった。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「芸術新潮」７巻１号、1956年１月）",
              "citation": {
                "source": "「ぴ・い・ぷ・る」",
                "author": "芥川紗織",
                "note": "青空文庫"
              }
            },
            {
              "text": "膳の上を見ると、主人の言葉にたがわず、かのひめいちがついている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
