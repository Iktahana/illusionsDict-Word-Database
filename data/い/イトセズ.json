          "literary": [
            {
              "text": "従って吾々はその旨初めから何等左翼文化団体との関連を意図せず、また希望もしなかったのである。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "雰囲気や匂いを意図せず、的確という事だけを心掛けるといいと思います。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            }
          ]
        }
