        "examples": {
          "standard": [
            {
              "text": "会議中、彼は意図せずしてプロジェクトの核心に触れる発言をしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "散歩の途中、意図せず迷い込んだ小道で、思いがけず素敵なカフェを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女の何気ない一言が、意図せず彼の心を深く傷つけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "古いアルバムを整理していたら、意図せず昔の恋人の写真が出てきてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "従って吾々はその旨初めから何等左翼文化団体との関連を意図せず、また希望もしなかったのである。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "雰囲気や匂いを意図せず、的確という事だけを心掛けるといいと思います。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
