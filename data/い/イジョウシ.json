        "examples": {
          "standard": [
            {
              "text": "現場の状況から、これは事故ではなく異状死の可能性が高いと判断しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "検死の結果、外傷の痕跡から異状死として扱われるべきだと報告書に記載した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域で不審な死が相次いでおり、警察は異状死の関連性を捜査している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、あの人が？まさか異状死だったなんて、信じられないわ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事故死と異状死の区別は、法医学において重要な判断基準となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遺族は、当初の病死という説明に納得がいかず、異状死としての再調査を求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
