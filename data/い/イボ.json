[
  {
    "uuid": "6b083fa1-ac3f-520e-9a8d-30d17e2a0f58",
    "entry": "異母",
    "reading": {
      "primary": "いぼ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
