    },
    "definitions": [
      {
        "index": 1,
        "gloss": "different mother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は異母兄弟とはあまり交流がなかったが、互いに敬意を払っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史上の偉人の中には、異母を多く持ち、複雑な家庭環境で育った者もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、お兄さんって私と異母なの？」「そうだよ」と、思わぬところで家族の秘密を知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "異母妹の才能に触発され、自分も芸術の道に進むことを決意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば、「妹」という語は「伊毛」とも「伊母」とも「以母」「移母」「異母」「伊慕」「伊茂」「伊暮」とも書いている。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "異母妹のナターリイは、老人の死骸に打倒れて泣いた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お艶にはなお、これが伯母だとか義姉だとか異母妹だとか、他人を勝手に引張って来て勝手にそう思い込み、そう思い込むが最後、その通り肉身の気持になれる幾人かの女性がある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "索麪の関町掛け竝めて玉名少女が扱きのばす翁｜索麪は長きしら糸手うち索麪戸ごと掛け竝め日ざかりや関のおもてはしづけかりにし山間は貧しき関のありやうを暑き日ざしにて敢て見て過ぐ恩賜の時計南関田町の島田家は我が母の異母姉の家なり。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三枚橋辺にて高貴の内政たる異母姉に面したる時の感慨は女性らしき思想を一変して、あはれわれも女に生れ出たる上は、三千世界の遊冶郎を蕩かし尽さんとの大勇猛を起さしめたり。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ宋の公女だった頃異母兄の朝という有名な美男と通じていたが、衛侯の夫人となってからもなお宋朝を衛に呼び大夫に任じてこれと醜関係を続けている。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然自分の異母弟の一人が選ばれるものと考えていたは、一寸妙な気がした。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "當然自分の異母弟の一人が選ばれるものと考へてゐたは、一寸妙な氣がした。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝……四月二十七日の午前十一時頃の事、雨の音も静かなＱ大医学部、大寺内科、第十一号病室の扉を静かに開いて、私の異母弟、友石友次郎が這入って来た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に異母兄に当る織田信広や、岩倉城主織田信安等の叛乱があったが、みな信長に平定せられた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに兄は先妻の子で務のためには異母兄であるが、親のように平生家の面倒を見てくれているので、気の小さな務は宅地をなくしては兄に顔を合せることができなかった。",
              "citation": {
                "source": "白っぽい洋服",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの情の薄く我儘な私と三つ違いの異母姉さんも可哀い姿で踊った。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの情の薄く我儘な私と三つ違いの異母姉さんも可哀い姿で踊つた。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人の異母兄たちが、ずらりと食卓をかこみ、大急ぎでかつこんでゐた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の順吉も悲しくなつて泣いたが、その小さな心は、父や異母兄たちへの怒りよりも、母への愛と憎しみとで一ぱいだつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この笑いを作者は、惨酷に甚兵衛を扱いつづけていた継母、異母弟への報復の哄笑として描き出している。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かというに九年も前の話だから……しかも十七ばかりに成る、妹のような娘から、唯一度の接吻を許されたのだから……　その娘は腹違いの妹の学校友達で、お新と言って、色の黒い理窟好な異母妹とは大の仲好だった。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑中休暇で娘達も家に居る頃で、毎日のようにお新は異母妹の許へ遊びに来た。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "異母妹とお新とは、互に堅く腕を組合せて、泡立ち流れる潮の中を歩いたことを思出した。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は娘達の髪はまだ赤かったが、でも異母妹から見ると、麦藁帽子を脱いだお新の方は余程黒かったことを思出した。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもお新は異母妹と一緒に、度々旅舎へ遊びに来たが、彼の方では遠くでばかり眺めていた。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人の側に、山本さんは遠慮勝に腰掛けて、往時お新や異母妹と一緒に菖蒲田の海岸を歩いた時の心地に返った。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "友江田先生とミチ子との関係は異母の兄妹であることが判った。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして忠兵衛の異母兄で十人衆を勤めた大孫某を証人に立てて、兄をして廃嫡を免れしめた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔いざ渡せかし　おいぼれめ〕宮沢賢治「いざ渡せかし　おいぼれめいつもこゝにて日を暮らす」すぱとたばこを吸ひやめて何を云ふともこの飯の煮たたぬうちに　立つべしや芋の子頭白髪しておきなは榾を加へたり",
              "citation": {
                "source": "〔いざ渡せかし　おいぼれめ〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　パパには鋸楽師のおいぼれを連れて行くことを云い出した。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいぼれとただ呼ばれる老人は鋸を曲げながら弾いていろいろなメロディを出す一つの芸を渡世として場末のキャフェを廻っていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしおいぼれがいやだなんて云ったらぶんなぐっても連れていくよ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マギイ婆さんとおいぼれがやって来た。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マギイ婆さんは鋸楽師のおいぼれを連れて自分の部屋へ引きとった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
