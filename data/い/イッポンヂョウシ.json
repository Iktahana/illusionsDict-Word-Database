          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼のプレゼンテーションは、内容が良かったのに、一本調子の話し方で眠気を誘われたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この曲、サビはいいんだけど、AメロとBメロが一本調子すぎて単調に聞こえるんだよな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もっと抑揚をつけて話したらどう？この一本調子じゃ、聞いている人が飽きちゃうよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "物語の展開が一本調子で、途中で読むのをやめてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そこにはむやみと生硬の漢語や、俗悪で不自然な言葉のアクセントや、中学生じみた幼稚な興奮や、およそさうした類の低能な感傷的表情を、むやみと鼓張した態度で一本調子に並べたてられて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟲が一本調子に靜かになき續けてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの人も台詞をひどく伸ばして、しかも抑揚の少い一本調子の英語で押通しているのが耳障りでした。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本調子の棒読みだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘ごころだとて何で一本調子ばかりでいましょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞う金の額を一銭に限るということも誰教えねど自ずと経験から、慾無しと呼ばれることが却って取得の多いのを白痴の一本調子に覚え込み、永年それを金科玉条にして護り通して来たのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "力を籠めて言った京子の声が竹筒を吹いた息のようにしゃがれて一本調子に口から筒抜けて出た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だしきに到っては元来｜上懸の発声と仮名扱いを以て謡うべき観世流の人々までが、滔々として翁一流の下懸式｜呂張を根柢とした豪壮一本調子な喜多流｜擬いの節調を学び初め、観世流の美点を没却した憾があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津利彦氏のは声が全く潰れた張りばっかりの一本調子で、どうかすると翁の声と聞き誤られた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした結果になったのは、自分の心の上にも、一本調子になれなかった責があるし、美沢にも多少の責任はあるが、半分までは妹が悪いのだと思っていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、僕がさっきちょっと骨を折って君に詳しく話した、あの隠された品物を捜す場合にとる、警察の一本調子な方針についてのあらゆる考えだね、――ああいう考えはみんな必ず大臣の心に浮んだろう、と僕は感じた。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分等の豚肉などと共に三つ葉とか春菊とかを買つて來ると、初めてそれに氣がついたやうに、それからはまた幾久しく一本調子にその一種の野菜が膳に上る。",
              "citation": {
                "source": "一家",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり杉浦の無邪気な一本調子の無作法なところが、かえって侯爵などという社会上の慣習に包まれている人には、気に入るに違いない。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家令とか家職とか、その周囲の人たちが、社会上の虚礼に囚われて、遠い所からのみ、ものをいっている時に、杉浦のような一本調子の向う見ずの剽軽者が、ぐんぐん突っ込んで行くところが、かえってああした人たちの気に入るのに違いない。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その侯爵の冗談に、愛嬌に、気の早い一本調子の杉浦が、有無をいわせず、食いついたのです。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "融通のきかぬ一本調子の趣味に固執して、その趣味以外の作物を一気に抹殺せんとするのは、英語の教師が物理、化学、歴史を受け持ちながら、すべての答案を英語の尺度で採点してしまうと一般である。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の変化もなく悔悟もない一本調子の生活ほど、気をいらだたせるものはない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "男も女もまるで小説中の人物であるかのように頭がすっかり一本調子になって、僅かの事にも感謝したり感激したりする状態であった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し工藤は、龍吉などゝ同じやうに、かういふインテリゲンチヤがどし／＼運動の中に入つてきて、自分達の持てない色々の方面の知識で、ともすれば經驗の少ない向ふ見ずな一本調子になり易い自分達の運動に、厚さと深さとを加へなければならない、と思つてゐた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの過程は一本調子に変化なく行われたのではありません。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本調子に事件を追い、細い心理の解剖に頭の良さを誇るというより、三十枚足らずの短篇の中へ、複雑多様の筋を罩め、それを穏かに解きながら、音楽も聞かせ色彩も見せ、興味本位の探偵物ながら、芸術的表現をも忘れない。",
              "citation": {
                "source": "日本探偵小説界寸評",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ、低い音が木綿糸のやうな太さで、一本調子に引つ張られ、また木綿糸のやうにちよつと途切れては、また繋がれたりしてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上原は、田舍者らしい頑固さや一本調子ではなく、幅も深みもある人間だつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "口々に囀るような一本調子である。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　君の口から生意気な一本調子が自然にすべり出る。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから一本調子でやって行くといっても、目的があって、そこへやろうという意味において一本調子であるけれども、或る人に云わせれば、どこに終局の目的があるか分らないという位、弾力をもって強く柔軟にやってゆくのです。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家だからと言って絵を描くばかりの一本調子では、どうも考え方にしても描き方にしても固苦しくなり窮屈になると思う。",
              "citation": {
                "source": "画道と女性",
                "author": "――喜久子姫御用の「春秋屏風」その他――",
                "note": "青空文庫"
              }
            },
            {
              "text": "風変わりな一本調子で押し通して、いいかげんに転向することを知らない人はかわいそうだ。",
              "citation": {
                "source": "源氏物語",
                "author": "蛍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、人間つて、たゞ働く爲だけで生きてゆけるものなのかしら、いくら、かうした非常な世の中だつて、そんな人間のおもひやりなンてものが忘れられて、たゞがらがらとネジを卷くみたいに一本調子に働いてはゆけないと思ふのよ。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
