[
  {
    "uuid": "f7e45b88-dacb-59c2-8331-dcf912ded09a",
    "entry": "炒め煮",
    "reading": {
      "primary": "いために",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
