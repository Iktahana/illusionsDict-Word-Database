          ],
          "literary": [
            {
              "text": "拓本職人は石刷りを法帖に仕立てる表具師のようなこともやれば、石刷りを版木に模刻して印刷をする彫版師のような仕事もした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ石刷り職人の癖に」そして先生といって呉れるものは料理人だけだった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻物ですか、それとも石刷りですか」と訊いた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本のうつしたるれいとして、私しがうちでならひよりた、いしずりのかくなじのおりでほん　これはお前さんにあげておまへさんもならいよりた本なり。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年九月か　坂本乙女あて",
                "note": "青空文庫"
              }
            }
          ]
        }
