    "definitions": [
      {
        "index": 1,
        "gloss": "obstinacy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その企業は、合併条件の主要な一点において、意地ずくで譲歩を拒否した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "わざわざ自分でやると言い張ったのは、単なる意地ずくだったのかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "党内からの反対意見にもかかわらず、大臣は自身の政策を意地ずくで貫き通した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "劣勢にもかかわらず、選手は意地ずくでボールを追い続け、ついに逆転のチャンスを掴んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いやだ！」と子供は意地ずくで部屋から出ようとしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "二人の間には、長年のライバル関係からくる、互いに譲らない意地ずくがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かれが最初に強情を張っているのは、一日でも生き延びようとする執着心か、あるいは係りの役人たちに対する一種の反感から湧いて来た意地ずくか、いずれはそんなものであったらしいのであるが、今日の彼は寧ろ一種の虚栄心ともいうべきものに支配されていた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "のう、駕籠屋、駕籠屋、こうならば身共も意地ずくじゃ、刀にかけても一匹釣らねばならぬ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はこの男の意外な行動にちょっと呆気にとられましたが、そうなると、もう意地ずくです。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は、林右衛門も意地ずくじゃ。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女にはね、旦那が二人あって、双方が意地ずくで、身受の金を競り上げにかかったのです。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地ずくで貰わないのかと聞いたら、あるいはそうかも知れないと云い切った。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう意地ずくで、眼の眩むのを我慢して、一歩一歩ずり下りる、が、ベールエックから五時間もかかって、漸くリュチーネの流れのふちに辿り着いた時には、路ばたの草の上に仰むけに倒れたまま、もうどうしても動けなくなった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々の薬をのんだがキキメが見えず、修学旅行などはズッと欠席していたが、いッそ人中へだしたら意地ずくで何とかなるかも知れないと、両親のさとしを受けて、十六の年に悲愴な覚悟をかためて修学旅行にでた。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は、百姓総代として町人｜気質の旦那衆に対抗して来た意地ずくからも、伝馬所の元締役その他の人選については、ひどく頭を悩ましていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、こうなれば意地ずくだ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、女房に命じて、温泉を加熱する装置を施してもいいか、ときかせると、「それは勝手だが、あんなもの、温泉と思っちゃいかん」　と、全然ここの温泉を軽蔑しきっていたそうで、婆さんが絶え間なくタオルで全身摩擦しながら意地ずくでつかっている温泉とは何度ぐらいだろうと興にかられたが、調査もせずに引越した。",
              "citation": {
                "source": "温浴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、あなた、意地ずく、ヤケで力んでいらッしゃることですよ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから意地ずくで生きのびてやらアね。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "和泉の国の人は皮肉とも悲しみとも分けがたいものを、津の国の人は持って行きどころのない混乱を、そしてそれらはお互の意地ずくで何処までも打通さなければならない、ぎりぎりの処におしよせられていた。",
              "citation": {
                "source": "姫たちばな",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなりゃあ意地ずく！",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地だよ台察児、意地ずくだ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な意地ずくからこんな出鱈目を申立て、愛する蕗子の死後を涜して実に彼女に対して申しわけのないことですが、聞いている中谷は見る見る真蒼な顔をして、額に脂汗をにじませ、今にも倒れそうな状態でした。",
              "citation": {
                "source": "流転",
                "author": "山下利三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯うなると私も意地ずくで早く起きる。",
              "citation": {
                "source": "朝起の人達",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うせ意地ずくだから引き合わない。",
              "citation": {
                "source": "首切り問答",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元はと言えば門弟共の啀み合いからであったが、互に若気の至り、引くに引かれぬ意地ずくになって、出逢い頭に果し合いをしてしまったものだ。",
              "citation": {
                "source": "禁断の死針",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やす子　随分意地ずくね（目に止まらぬ寂しき笑）……無理にかけようとは申しませんことよ。",
              "citation": {
                "source": "宵（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに至ってドチラにも多少の意地ずくが見えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれひとりぐらいは、連れて行ったらどうじゃ」「いや、ひとりが、かえって目立ちません」　官兵衛もまた意地ずくのように、妻子へ何のことばもかけずに、ぷいと室を出るや否、姫山の丘を、もう馬に鞭打って、駆け下りていた。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナスターシャはとうとうむっとして、意地ずくでゆすぶり始めた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのためにそうねばっているのだ、意地ずくか、それとも住み馴れた家へのみれんか。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "おくめ殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "書けるものなら」「書くとも」　と私は意地ずくにも稿を起さなければならないことになった。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで草ッ原へ逃げ込む、果ては双方意地ずくでいがみ合いつつ、どうやらよたよた乗れることになり、桜田門まで遠征、それが途中三度も下りて休憩という始末、いやはや初期のサイクリストあんまり自慢にならぬ。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど公綱の放言自身も、好んでみずからこの“意地ずく”のかたちを周りに拵えていたものであることは否めまい。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆくからには、楠木と勝負を果たし、這奴を生け捕って帰るか、難波の洲に、この身が屍をさらすか、二つに一つあるのみでおざる」　つまりは、大言のてまえ、公綱の陣頭指揮は、意地ずくからの出発だった。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
