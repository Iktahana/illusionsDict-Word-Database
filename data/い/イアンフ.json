        "examples": {
          "standard": [
            {
              "text": "第二次世界大戦中の慰安婦問題は、国際社会で長年議論されてきた歴史的課題だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの歴史研究者が、当時の公文書や関係者の証言に基づき、慰安婦制度の実態解明に努めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "元慰安婦の女性たちが自らの体験を語り継ぐことで、戦争の記憶が次世代に伝えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人権問題として捉えられることの多い慰安婦問題は、国際的なシンポジウムでも頻繁に取り上げられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "教科書では、慰安婦問題が戦争による女性への影響を示す事例の一つとして紹介されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "芸者とは云つても、軍で呼びよせた慰安婦である。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――海防の収容所に集つた女達には、看護婦や、タイピストや、事務員のやうな女もゐたが、おほかたは慰安婦の群であつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにも、沢山日本の女が来てゐたのかと思ふほど、それぞれの都会から慰安婦が海防へ集つて来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「慰安婦にはシナの女もいるのかい」「シナの女は駄目」「駄目と言うと？",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
