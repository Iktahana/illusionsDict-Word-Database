    "definitions": [
      {
        "index": 1,
        "gloss": "(period of) one year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はこの一年間、厳しい経済状況の中、会社を立て直すために尽力した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "留学生活の一年間で、彼女は飛躍的に語学力を向上させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この庭は一年間を通して様々な花が咲き、訪れる人々の目を楽しませる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新製品の開発には、構想からリリースまで一年間を要した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は一年間毎日欠かさずジョギングを続け、体重を10キロ減らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域では、一年間の平均降水量が例年よりも少なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「本当に、この一年間は色々なことがあったね。」と、友人はしみじみと語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」彼は目覚めに夜着から頭を出す、恰度其の時のやうに彼が学校に対する過去一年間を振返つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが何だかモヤモヤと温い摺鉢のやうなものが脳膸の天井に蓋さつてるやうで、過去一年間の其処にある何にも彼の頭に蘇りはしなかつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一八九六年まで十一年間この職をつとめた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この電線に障害を与えた者は一年間の禁錮に処せらるるという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国での統計に拠れば、過去二十一年間に過失から起った火災の損害は金高にして二億六千六百三十四万〇五十八ドルになる勘定だという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は元日以來一度も病臥に及んだ事なく、生れて初めての輝かしき記録だつたが、やつぱり一年間とは通せなかつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからなお一年間辛抱しなければ内地へ帰れないのだ。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は来し方の一年間を思いかえした。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからさき、一年間、お互いに助け合って生きて行かなければならなかった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからさき、一年間を、自分の好きなようにして暮してやろう。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の友人は、労働歌を歌っていて、ただ、それだけで一年間尾行につき纒われた。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高取は一年間の勤めを了えて、二年兵になったその日に、歩哨に立っている場所を離れて鶩を追っかけまわした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼らの二人ともが、土に帰る前の一年間を横たわっていた、白い土の石膏の床からおろされたのである。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この結果としてこの一年間にいろいろの珍しいレコードが多数にできあがった。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は一年間に宴会に出席すること四百回、しかも毎回欠かさずに卓上演説をしてのけたそうである。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の二年から三年にあがった夏休みの帰省中に病を得て一年間休学したが、その期間にもずっと須崎の浜へ転地していたために紅葉の盛りは見そこなった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれは、ほんの一年間だけの狂態であった。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年の月日は忽ち逝き、僕は首尾よく学校を卒業しましたが、猶お養父の言葉に従い、一年間更に勉強して、さて弁護士の試験を受けました処、意外の上首尾、養父も大よろこびで早速其友なる井上博士の法律事務所に周旋して呉れました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は田舎教師としてこの所に一年間滞在していた。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は今ワイ河畔の詩を読んで、端なく思い起こすは実にこの一年間の生活及び佐伯の風光である。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日の新聞広告だけから推算しても一年間に現われる書物の数は数千あるいは万をもって数えるであろう。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして父の信用に依ツて多少の金も借入れる、また自分の持ツてゐた一切の貴重品を賣拂ツて、節約してゐたら、お房｜母子諸共一年間位は何うか支へて行かれるだけの用意をした。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年間も方々の病院をつれ歩いてみても、睫毛や眉毛を蝕んで行く皮膚病に悩まされたこともあり、子柄がわるい代りに病気がないのが取柄だと思うと、親がバタヤで質が悪く、絶えず金の無心で坐りこまれたりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、この一年間というものは、あなたの心の中に、しっかりと、ぼくを入れておいてくれましたね。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍隊なんてのは、つまらないが、しかス、僕はこの一年間に於いて、生活の自信を得たですね。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには、勾当二十六歳、青春一年間の日記だけを、展開する。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七百頁の「葛原勾当日記」のわずかに四十分の一、青春二十六歳、多感の一年間だけを、抜き書きした形であるが、内容に於て、四十余年間の日記の全生命を伝え得たつもりである。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの家の屋賃は、もともと、そっくり僕のお小使いになる筈なのであるが、おかげで、この一年間というもの、僕は様様のつきあいに肩身のせまい思いをした。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もこの一年間というもの、青扇のためにずいぶんと心の平静をかきまわされて来たようである。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
