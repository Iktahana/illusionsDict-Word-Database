          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "フランシスコ・ザビエルらによって結成されたイエズス会は、大航海時代の波に乗って東アジアへと勢力を広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日本におけるキリスト教の歴史を語る上で、イエズス会宣教師たちの果たした役割は極めて大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "イエズス会は古くから教育活動を重視しており、世界各地で大学や中等教育機関を運営している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はイエズス会の修道院で数年間の修練を積み、司祭として叙階された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "第266代教皇フランシスコは、史上初めてイエズス会出身者として教皇の座に就いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まさにイエズス会は、カトリック教会の反宗教改革において中核的な役割を担った組織と言えるでしょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦国時代の九州には、イエズス会を介した南蛮貿易によって富を築いた大名も少なくなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一方、紹介役のソテロは、日本の布教がイエズス会に牛耳られているのが不満で、自己の所属するフランシスコ会にも司教をおかせ、自分が司教になりたい考えであった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の本心は、支倉一行が出発しないうちから、すでにイエズス会に見破られていた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "司教のセルケイラはイエズス会総長に宛てて、政宗の本心はヤソ教ではなくて、通商であり、彼の領地へフランシスコ会の僧が続々くるようになると、家康の怒りをかって政宗は滅亡するだろう、と手紙している。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼きイエズス会の修道院である。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼きイエズス会の修道女たちは、幼きイエズスに仕えた聖母マリアの模倣をしようとしているのではあるまいか？",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、この聖ヤコボ喜左衛門さまについては、備前の生まれで、イエズス会に入り、天主堂の門番を勤めていたということと、死んだときが六十四歳で、二十六人のうちのいちばん老人だった、ということのほかには何もわかっていない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前、私はカリフォルニアの田舎で、イエズス会の神父さんとキリスト教の厳格さについてかなり激しい議論をしたことがある。",
              "citation": {
                "source": "“指揮権発動”を書かざるの記",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "1537年にもう１人の巡礼がヴェネチアで働き、６人の信徒（イエズス会創立者たち）に出会うことになった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "長期間の試練の後にイグナチオ・デ・ロヨラ（イエズス会初代総長）は非常に異なる世界の征服を開始した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "１人は数年のあいだに解剖学で革命を起こし、もう１人は20年のあいだに大学の管理者、王の助言者、およびローマン・カトリック教会における最も有名な修道院（＊イエズス会）の創設者になった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世紀の後になってイエズス会の神父たちがこの皮を小包にしてローマに送りそこからこの会の僧侶たちに配布してマラリアの治療に使われた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って「イエズス会士たちの木の皮」と呼ばれるようになった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初はかなりの反対がありこの薬はイエズス会士が導入したのでプロテスタントは好まなかった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方のようなイエズス会員はほんとうに殺人に賛成してるのですか？",
              "citation": {
                "source": "手早い奴",
                "author": "THE QUICK ONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "南では反宗教改革が進行しイエズス会が勝利した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁気による傷の治療法についてイエズス会に向けた短い原稿が無関係な人の手に落ちファン・ヘルモントの意志に逆らって出版され宗教裁判所の忌諱に触れた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "同郷のイエズス会士が２人を金持ちの医師バリヴィに紹介し２人は養子となり財産が遺された。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "この職はこれまでイエズス会修道士により独占されており彼らはウィーンで全能であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "検閲部局からイエズス会修道士を完全に除外することはできなかったが彼らの権力をかなり制限することができた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大学の他の学部の改革に関連してイエズス会と衝突したがここでも同様に彼らの権力を制限することができた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず彼はラスタットのピアリスト（聖職者修道会）およびボッケンハイムのイエズス会で教育を受けた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じように17世紀の終わる前にイエズス会士キルヒャーはペスト患者の膿と血液に小さい虫と彼が考えたものを顕微鏡下で見た。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーベンスはアントワープでイエズス会士について勉強しており聖イグナティウス・ロヨラ（＊イエズス会の創立者）が悪魔払いをして死んだ小児を蘇生させている２枚の大きな絵と数枚のスケッチを残している（図25）。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "この主題への第３で重要な資料は好学のイエズス会士キルヒャーの「マグネスあるいは磁気学についての３巻の著書」でありこれは1641年にローマで始めて出版された(15)。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
