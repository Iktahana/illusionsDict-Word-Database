[
  {
    "uuid": "7bff48ba-0c96-5666-b6da-2c06811cde42",
    "entry": "鼬ごっこ",
    "reading": {
      "primary": "いたちごっこ",
      "alternatives": [
        "イタチごっこ",
        "イタチゴッコ"
      ],
      "is_heteronym": false
    },
    "grammar": {
