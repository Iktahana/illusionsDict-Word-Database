        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "末寺にはインカムベントと称するものあり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "インカムベントのほかにキュレートと称するものあり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄では河童のことをカワカムロともインカムロともよんでいる。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "またインカムロのインというのはこちらの海ということだから、沖縄では海にも河童がいるということになる。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
