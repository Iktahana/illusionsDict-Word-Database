    "definitions": [
      {
        "index": 1,
        "gloss": "taxi decorated with anime characters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駅前で偶然見かけた痛タクが、自分の推している作品のラッピングだったので、思わず二度見してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、あの痛タク、内装までキャラクターで埋め尽くされてる！ すごい気合だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地域活性化プロジェクトの一環として、地元が舞台のアニメ作品とコラボした痛タクが期間限定で導入された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「せっかく聖地巡礼に来たんだから、移動は奮発してあの痛タクを予約してみようよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "痛タクは単なる移動手段を超え、ファン同士の交流や作品への愛を表現する文化的なプラットフォームとしての側面も持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "市街地を走る痛タクの鮮やかなグラフィックは、歩行者の目を引き、図らずも作品の宣伝効果を生んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まさか痛タクで出張先のホテルまで乗り付けることになるとは……。でも、運転手さんの作品愛が深くて楽しかったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "左側の横町一パイに重なり合って行列していたタクシーの先頭の一つが彼に向って手をあげて見せた。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関まえについたタクシーは空車で、それを見て、慶一はホッとした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂口は公園の角まで馳って、やっと空いたタクシーを見つける事が出来た。",
              "citation": {
                "source": "Ｐ丘の殺人事件",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "同伴していたタクマ少年は、分かりませんと答えた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山の大通りをはしっていたタクシーは前をゆく電車と、板を積んだ荷馬車とに行手をさえぎられて、不機嫌そうにスピードをおとし、徐行しはじめた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうなってみると、美穂ちゃんのあの絵が、いっそう貴重なものになるわね」　待ってもらっていたタクシーへ、ふたりは戻った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "筈見の霊前に合掌して、待たしといたタクシーで、えびすへ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつのありかを捜索する手数が、省ける訳ですからね」　彼は三谷を励ます様にして、先に立って、玄関に待っていたタクシーに乗った。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い自動車　怪老人は、原っぱを出て、大通りまでくると、そこを走っていたタクシーを呼びとめて、乗りこみました。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
