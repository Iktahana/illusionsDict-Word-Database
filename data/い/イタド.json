[
  {
    "uuid": "bbcb42a1-4743-53f3-9c00-cb41a44ed1f2",
    "entry": "板戸",
    "reading": {
      "primary": "いたど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
