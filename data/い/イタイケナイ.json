        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その幼気ない瞳に嘘偽りはなく、ただ純粋に大人を信頼していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初めて見たシャボン玉に、幼気ない顔を輝かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女はまだ世間知らずで、その幼気な性格では詐欺師に騙されてしまうだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "道端で鳴いていた子犬は、その幼気ない鳴き声で人々の同情を誘った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遠い記憶の中にある、母の歌声はいつも幼気で優しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、きれい！」と、幼気ない声で彼女は空を見上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "幼気ない子供の目には、世界はまだ希望に満ちた場所として映っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "どうしても工場になくてはならない熟練工や、いたいけない、七ツか八ツの少年工や少女工までが、蒼くなって、どんよりとした、悲しげな眼で、生殺与奪の権を握っている日本人をだまっておがむように見るのだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ巴の紋のに、大小をさした、いたいけない子供役者の写真姿で、市村座五月狂言、力弥何々と役者の名前が赤く摺つてある。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまりに花がいたいけないので街で百姓から買って来たまでなんです」その時自分の飲み代まで角井が払いをすましている様子なのを見て、彼はきまり悪くなったのか、慌しく田中の方へ廻って来て袖を引張りつつせき込みながら、「田中君、田中君、実は君に折り入っての話があるんだよ」　と哀願するように呻いた。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだいたいけない少年の黒吉は、恐ろしさにオドオドして、「済みません、済みません」　そんな事を、呟くようにいうと、ぼろぼろに裂けた肉｜襦袢の、肩の辺を擦りながら、氷のように冷めたい床の上に、又無器用な体つきで、ゴロンゴロンと幾度も「逆立ち」を遣り直していた。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
