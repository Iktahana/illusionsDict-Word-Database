        "examples": {
          "standard": [
            {
              "text": "この茶碗は糸じりの作りが滑らかで、畳に置いた時の座りが良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "陶芸家は、器の糸じりに自身の銘を小さく刻み込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "古い茶碗の糸じりには、長年使われてきた歴史を感じさせる土の風合いが残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "鑑定士は、まず器を裏返して糸じりの削り方や土質を注意深く観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "碗のいとじりが小さな輪を膳の上に描いた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "庖丁は砥石でしかとげないと思っていた茂緒に、茶碗のいとじりで庖丁がとげることを教えてくれたのも扶佐子だった。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
