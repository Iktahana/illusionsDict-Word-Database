[
  {
    "uuid": "fbe8c379-3c37-59d1-b3f8-a31006d0469d",
    "entry": "田舎",
    "reading": {
      "primary": "いなか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
