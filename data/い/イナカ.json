        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "都会の喧騒に疲れて、時々無性に田舎が恋しくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "お盆には久しぶりに田舎へ帰って、祖父母に顔を見せるつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "私の田舎は、夜になると満点の星空が広がる静かな町です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は田舎の出身だが、それを感じさせない洗練された振る舞いをする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
