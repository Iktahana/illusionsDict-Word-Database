    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "country gentleman (esp. one that's slightly unrefined)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は地元の名士で、少し野暮ったいところもあるが、誰にでも親切な田舎紳士として慕われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ツイードのジャケットを羽織った彼は、まるでイギリスの小説に出てくる田舎紳士のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その田舎紳士は、自分の広大な土地を村の子供たちのために公園として開放している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "高崎中学を終えてから、各地の医専の入学試験を受けている最中、リョウマチにかゝり、少青年期の大事な部分を実家で療養に暮すうち中学生上りともつかず田舎紳士ともつかない鵺の青年になったらしい弟は、せめて生活の業にもと近頃では鍼灸師の資格試験の準備中なのでありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　田舎紳士は宿場へ着いた。",
              "citation": {
                "source": "蠅",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と田舎紳士は横からいった。",
              "citation": {
                "source": "蠅",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　馬車の中では、田舎紳士の饒舌が、早くも人々を五年以来の知己にした。",
              "citation": {
                "source": "蠅",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "農婦は田舎紳士の帯の鎖に眼をつけた。",
              "citation": {
                "source": "蠅",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろの田舎紳士も泣いた。",
              "citation": {
                "source": "春秋座の「父帰る」",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し父とは年齢の離れた三十前後の若者で、重なる遊蕩によつて独特の人品を具えた田舎紳士であつた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十才の田舎紳士が人前を怖れることなく奇声を発して女給を愛撫してゐるが、そのことが高級なる社交、ならびにその大精神になんの差しさはりがあるものぞと高説をなす人士があれば、私もまつたく同感であり、敢て異説をとなへやうとは思はない。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は昔気質のイギリスの田舎紳士の標本としては相当なものですが、このごろでは、純粋にそうしている人はほとんど見うけられなくなってしまいました。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "髯を生し洋服を着てコケを脅そうという田舎紳士風の野心さえ起さなければ、よしや身に一銭の蓄なく、友人と称する共謀者、先輩もしくは親分と称する阿諛の目的物なぞ一切｜皆無たりとも、なお優游自適の生活を営む方法は尠くはあるまい。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は貧乏｜御家人の跋扈せし処今は田舎紳士の奥様でこでこ丸髷を聳かすの地、元より何の風情あらんや。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一〇八）スミス博士は曰く、『穀物の輸入に対する高い関税とその輸出にに対する奨励金を設けることによって、田舎紳士は製造業の行為を模倣したように見えた。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同様な施設によって、穀物の名目価格すなわち貨幣価格が引上げられる時には、その真実価格は引上げられず、我が農業者または田舎紳士の真実の富は増加せられず、穀物の栽培は奨励を受けない。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて田舎紳士は、穀物輸入禁止及びその輸出に対する奨励金に、啻に一時的のみならずまた永久的の利益を有っているが、しかし製造業者は、貨物の輸入に対する高関税及びその輸出に対する奨励金を設けることに、何らの永久的な利益も有たない。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って私は、田舎紳士は穀物の輸入を禁止することに、製造業者が製造財貨の輸入を禁止することに有っているほどの大きな利益を有つものではない、というスミスの意見には同意せずして、彼らは遥かに優れた利益を有つものであると主張する。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし地代が創造されかつ田舎紳士が穀物の自然価格の騰貴に利益を有つのは、この差違によるからである。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "スミス博士は、製造業者の利益を田舎紳士の利益と比較せずにそれをその地主の利益とは極めて異るところの農業者の利益と比較すべきであった。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的上品な嗜好をもった田舎紳士だったのです。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリヴィエはその田舎紳士をきらいだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしフランス中流のカトリック教徒の田舎紳士の間では、いつも財嚢と財嚢との捜し合いである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで自分自身に立派な矜りをもち、田舎紳士が孤立状態のために独りよがりになることがあるように、いささか独りよがりにさえなつていた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "持ち衣装を全部捨てて、典型的な田舎紳士になろう」　ノース地方のとある大邸宅に住んでいるのがフィリックス・グライド、英国系アメリカ人、合衆国で莫大な財産を築いたとのうわさだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、別に男振がどうこうと云うのではないが、如何にも田舎紳士と云う感じで、なるほど好人物らしくはあるけれども、知的なところが全くない顔つきをしていた。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠地に白い立縞のある背広に開襟シャツを着た、色の黒い、頭髪を綺麗に分けて撫で着けた、何となく田舎紳士と云う感じのする、痩せた小柄な人物で、膝の間に洋傘を挟んでその上に両手を重ね、さっきはその上に頤を載せていたのが、今はうしろへ凭りかかっていて、頭の上の網棚に真っ白なパナマ帽を置いている。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時彼女はこの男の容貌が如何にも田舎紳士臭く、知的なところが少しもないのが気に入らなかったので、義兄の親切な斡旋があったにも拘らず、我が儘を云って断ってしまったのであったが、あれから十余年の歳月を経た今見ても、矢張この人は田舎臭い顔をしている。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "………彼女はそこまで考えつづけて来て、自分が今頃あの田舎紳士の妻になっていたら、―――と思うと、負け惜しみでも何でもなく、決してその方が幸福であったと云う気はしないのであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年来たときに、初めて診察に立会ったのだが、母のかかりつけだそうで、六十歳ぐらいの、ごく温和な、昔よくいわれた「田舎紳士」といったふうな人柄であった。",
              "citation": {
                "source": "ばちあたり",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五郎さん」「へい」　般若の五郎も、もう、自分の身元引請人になってくれた奇妙な田舎紳士が、何者であるかを知っていた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "1768年におけるイギリスの田舎紳士の夕食は次のようであった(8)。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
