    "definitions": [
      {
        "index": 1,
        "gloss": "private opinion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はラーメンには一家言あって、スープの出汁から麺の硬さまで細かく語りだす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "オーディオに関しては一家言ある父が、新しいスピーカーの音質を熱心に評価している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "推理小説にかけては一家言ある友人も、この作品のトリックは見抜けなかったようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "故に牧水氏を始めとし、前田夕暮氏でも齋藤茂吉氏でも、當時の歌人は皆僕等の詩を理解して居り、常に一家言の批評を持つてた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦節は貞くす可からずの一句、易の爻辞の節の上六に、苦節、貞くすれば凶なり、とあるに本づくと雖も、口気おのずから是道衍の一家言なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒薔薇栽培にも一家言を持っていた。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢判断にも一家言を持つこのオレが分析すれば、ＦＭ　ＴＯＷＮＳという可能性を秘めた原石にオレはもう一化けを期待しているということなのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "司馬遷の時は、歴史の編纂は、之によつて一家言を立て、自分の創作とするつもりがあつたのが、後にはその意味が變つて、人のものを編纂することになつた。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれどもこれ一家言のみ。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句を以て最上の文学と為す者は同じく一家言なりといへども、俳句もまた文学の一部を占めて敢て他の文学に劣るなし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎俳句の将来についての一家言――俳句は畢竟階級的なものではありえない、階級意識を高唱するには川柳的なものが出来るであらう、そして大衆的娯楽文芸として俳句は堕落すると共に、詩としても高上し純化するであらう、それが真の俳句であり、芸術家の芸術であり、純日本的なユニイクなものである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く本私刑史、曰く支那刑法史、曰く経子一家言、曰く周易一家言、曰く読書五十年、この五部の書が即ちこれである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは其書の善悪を知らぬが、要するに一家言である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛至上主義者も、この事件について、一家言をたてるものも、家庭にあって、子女を前にしては、説が矛盾するといった。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は此方面に就ては省略し、たゞ哲學史と哲學との關係に就て學風の推移を考察し、之を自家所見の圈内に導き入れて一家言を提出し、以て此變移を體驗し又誘導せられた先覺に對する賀壽記念の料に充てんとするのである。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "定メテ其ノ心ニ逆カフコトモ有ランナレド、ソハ余ガ一家言トシテ宥シ給ヒネ。",
              "citation": {
                "source": "好古小言",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常にお世辞のいい同氏の反駁を、僕が取立ててかれこれ云ふ筋合でもなし、殊に、演出に関する興味ある一家言は、僕を首肯せしめるに足るものであつた。",
              "citation": {
                "source": "稽古のしかた",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し然りとすれば、其れは雄が大なる心得違で、賦には賦の體あり、一家言を論述するには又た論述の體があつて、兩者を混同することは勿論惡い。",
              "citation": {
                "source": "楊雄と法言",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は理想國の名を、如何にも地方の學者らしく、字面からこじつけ引きよせた一家言であつたのだらう。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも一家言をもち、自信をもち、放言し、自分が行くところ可ならざるはない「器用人」だと思い込んでいる人のことをゲーテはいうのである。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来一家言は論理性の欠如をその特質とする。",
              "citation": {
                "source": "一家言を排す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池寛の「話の屑籠」は現今文壇における一家言の代表的なものであつて、一部識者の好評を得てゐることは、我国の教養がその真実の論理的訓練に不足してゐることを明かにしてゐるにすぎない。",
              "citation": {
                "source": "一家言を排す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてそれを書きました時は、一家言として、自分の一己の主張があつて書いたのであります。",
              "citation": {
                "source": "支那の書目に就いて",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "史記を見ると、いろいろのものを集めて一纏めにして自分の一家言を作るのであると云つて居る。",
              "citation": {
                "source": "支那の書目に就いて",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那では之を一家言と申しまして、皆人によつて言ひ傳へが違ふので、即ち異部名字と同じやうなことであります。",
              "citation": {
                "source": "大阪の町人學者富永仲基",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつきり分りよいのが卜筮でありますが、左傳・國語の卜筮に關したことは、日本でも卜法の上から注意した人がありまして、谷川龍山といふ人が「左國易一家言」といふ本を作つた位であり、それに左傳・國語の卜筮に關した記事が大方載つて居ります。",
              "citation": {
                "source": "支那歴史的思想の起源",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の議論に就いては私は餘り贊成をせぬ所もあり、又贊成をする所もありますけれども、南北の書派の議論は阮元の一家言で、私は全部贊成を致しませぬ。",
              "citation": {
                "source": "弘法大師の文藝",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで見ると、甲部は藝文志の六藝略に當り、乙部では、古諸子は諸子略に當り、近世子家は漢以後晉までに著述されたものであり、兵書と兵家とに分けたのは、兵書は兵家の如く一家言をなしたものでなくして、普通の軍事に關したものを云ひ、術數は藝文志の數術であるが、恐らく方技を含むのであらう。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは別に子部として何等一家言をなすものでもなく、何等特別の技術・藝術をなすものでもないが、何がなし世間のことを一般の人が知る必要より類書類が多く出來た。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが婦人れんになると、何につけてもめいめい小うるさい一家言をもちだすものだし、当のマーシェンカなどは、首飾りをもらってから、さめざめと泣きだしたものだった。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかり日頃の一家言といったようなものをお話させていただきます。",
              "citation": {
                "source": "芸術的な書と非芸術的な書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "カキツバタ一家言花がつみまじりにさけるかきつばたたれしめさして衣にするらん　　　　公実狩人の衣するてふかきつばた花さくときになりぞしにけり　　　　　　　基俊　カキツバタは誰れもよく知っているアヤメ科イリス（Iris）属の一種であって lris laevigata Fisch. の学名を有する。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
