[
  {
    "uuid": "524e4111-68ea-53c9-8d1e-b4e99e3f0f72",
    "entry": "何方",
    "reading": {
      "primary": "いずち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "which way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "風の吹くまま、いずちともなく歩き続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「主君はいずちへ向かわれましたか。お姿が見えませぬが」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都を追われ、いずちへ落ち延びるべきか途方に暮れる一行であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "音信不通となって久しいが、今はいずちの空の下で健やかに暮らしているのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "浮き草のように、いずちへ流れていくとも知れぬ不安定な身の上を嘆く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夢か現か、いずちよりともなく美しい笛の音が響いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "仮りに何方かに決つた所でそれで何か出て来るといふわけのものでもありますまい。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは何も何方に近いから良いとか悪いとかいふのではなくて、尠くとも一般からは却て短歌より発展して出来たものとされてゐる新短歌が却てその精神に於て俳句に近いといふことを注意してみたかつたまでである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（独語つ）何方でもよかつたのに………。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……フン、そりや彼奴の云ふのにも本当はある――」「けれどもだ、……けれどもそれでは此方が困る……」　そこへ、「何方にも一理ある場合は親の方を子は聴入れなくつちやァ不可ない」といふ、常々云つてる言葉が飜然浮ぶと、彼は解決を得た喜びに敷居の辺りを意気ある眼で睨んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が心の何方に走れりとも知らで、乳に倦きれば乳房に顔を寄せたるまゝ思ふ事なく寐入し児の、頬は薄絹の紅さしたるやうにて、何事を語らんとや、折々曲ぐる口元の愛らしさ、肥えたる腮の二重なるなど、かかる人さへある身にて、我れは二タ心を持ちて済むべきや。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しやと思って女を呼んで、　「あれは何方様だい」と訊く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　これでは何方が病人か分なくなつた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が次第に強くなつたので外面の模樣は陰鬱になるばかり、車内は退屈を増すばかり眞鶴の巡査がとう／＼『何方へ行しやいます。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "呪はれた母と娘とは何方が先に禍を受けるのであらうか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州筋近来の凶作に此寺も大破に及び、住持となりても食物乏しければ僧も不住、明寺となり、本尊だに何方へ取納しにや寺には見えず、庭は草深く、誠に狐梟のすみかといふも余あり。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」園は俯向いたが、「――何方まで。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これから何方までお帰りです。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、糸目の着加減を両かしぎというのにして、右へでも左へでも何方へでも遣りたいと思う方へ紙鳶が傾くように仕た上、近傍に紙鳶が揚って居ると其奴に引からめて敵の紙鳶を分捕って仕舞うので、左様甘く往くことばかりは無かったが、実に愉快で堪えられないほどの事におもって居たのです。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は何方なんです、牛と薯、エ、薯でしょう？",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし最後に一｜言しますがね、僕は人間を二種に区別したい、曰く驚く人、曰く平気な人……」「僕は何方へ属するのだろう！",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし最後に一言しますがね、僕は人間を二種に区別したい、曰く驚く人、曰く平気な人……」「僕は何方へ属するのだろう！",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「其處へ玉のやうな霰が飛ぶんだ……」「そして、八田潟の鮒と戰をしたら、何方が勝つ？",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「蛙は何方の味方をする。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此から何方へ行らつしやる？",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今灯を点けたばかり、油煙も揚らず、かんてらの火も新しい、店の茣蓙の端に、汚れた風呂敷を敷いて坐り込んで、物｜馴れた軽口で、「召しませぬか、さあさあ、これは阿蘭陀トッピイ産の銀流し、何方もお煙管なり、お簪なり、真鍮、銅、お試しなさい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、何方でも、早く橄欖島に到着した方は、向ふ一週間の間、其島の附近で待合はせ、一週間※て後も他の一方が見えぬ時には、最早運命の盡と覺悟を定める筈であつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と帽子を取って目深に被り、戸外へ出づればかの男は、何方へ行きけん影も無し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、何方も沸切らぬ堅い談話はまたの日するとして面白く談話そうではないか。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へい、何方で、」と云ふのが、赤ら顏の髯もじやだが、莞爾と齒を見せた、人のよささうな親仁が嬉しく、「道修町と云ふだがね。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方かと言へば、私の作などの中には、景色を見てから、人物を考へ出した場合が多い。",
              "citation": {
                "source": "小説に用ふる天然",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々もこうして暢気に遊び歩いていても、二人の中の何方かは運命の頸環に見放された野犬であるかも知れない。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根の関はいずちなりけんと思うものから問うに人なく探るに跡なし。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の下のいずちに、人を流さぬ川があろうぞ。",
              "citation": {
                "source": "雪の武石峠",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいずちに人を呑まぬ地があろうぞ。",
              "citation": {
                "source": "雪の武石峠",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
