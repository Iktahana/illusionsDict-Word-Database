    "definitions": [
      {
        "index": 1,
        "gloss": "milestone (1 ri apart)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旧中山道を歩いていると、街道脇に苔むした古い一里塚を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "この画期的な新薬の承認は、がん治療の歴史において大きな一里塚となるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "プロトタイプの完成は、長大な開発プロジェクトにおける最初の一里塚に過ぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "江戸時代の旅人は、一里塚の木陰でわらじを脱いで足を休めたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、それだけにまた、自分にとっては三十余年前の冬のある曇り日のこの珍しい体験が、過去の想い出の中に聳え立った一里塚のように顕著な印象を止めているものと思われる。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭く科学と限らず一般文化史上にひときわ目立って見える堅固な石造の一里塚である。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの出現するのにおのずから場所が定まっている傾向があり、たとえば一里塚のような所の例があげられている。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和六年八―十月、渋柿）　　　　　六　月花の定座の意義　連句の進行の途上ところどころに月や花のいわゆる定座が設定されていて、これらが一里塚のごとく、あるいは澪標のごとく、あるいは関所のごとく、また緑門のごとく樹立している。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、障子を開けて、そこが何になってしまったか、浜か、山か、一里塚か、冥途の路か。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔も近江街道を通る馬士が、橋の上に立った見も知らぬ婦から、十里｜前の一里塚の松の下の婦へ、と手紙を一通ことづかりし事あり。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹狩が遠出をした、姫路野の一里塚のあたりをお見な。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月　向日葵、向日葵、百日紅の昨日も今日も、暑さは蟻の數を算へて、麻野、萱原、青薄、刈萱の芽に秋の近きにも、草いきれ尚ほ曇るまで、立蔽ふ旱雲恐しく、一里塚に鬼はあらずや、並木の小笠如何ならむ。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　来る時は気がつかなかつたが、時に帰がけに案山子の歩行く後から見ると、途中に一里塚のやうな小蔭があつて、松は其処に、梢が低く枝が垂れた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、氣候の循環によつて示される尺度によつて、吾々人間生活の中に起りつゝある變轉の進路に一里塚の道標を打込むといふことが出來ないので、從つて四月の風も九月の風も、名前がちがふだけの恆信風であつて、嬉しさや淋しさの連想を伴ふ春風秋風では決してあり得ないのである。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松があって雑樹が一叢、一里塚の跡かとも思われるのは、妙に低くなって、沈んで島のように見えた、そこいらも水が溢れていよう。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが秋の暮だと、一里塚で消えちまいます、五月の陽炎を乗って行きます。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹が横に、大く枝を張った、一里塚のような松の古木の下に、いい月夜でしたが、松葉ほどの色艶もない、藁すべ同然になって休みました。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに一つ、僕が『代表的人物』を讀んだ時に、そのふちへ書いて置いた覺へ書きを拔いて見よう――これは寧ろ渠の云つたことで、今の僕が持つて居る考へだといふのではない，『人物の要は天眞を發揮するにある、原因の化身にある、未然の前兆にある、進歩の一里塚たるにある。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が眼にては、唯官能上に快きばかりなる無意識形美より、美術の奧義、幽玄の境界なる小天地想までは、抽象的より、結象的に向ひて進む街道にて、類想と個想（小天地想）とは、彼幽玄の都に近き一里塚の名に過ぎず。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "門松は冥途の旅の一里塚に過ぎない。",
              "citation": {
                "source": "土民生活",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは古木と古碑との様子の何やらいわれがあるらしく、尋常の一里塚ではないような気がしたので、立寄って見ると、正面に「葛羅之井。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅路時代の一里塚だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、彼は信濃と美濃の国境にあたる一里塚まで、そこにこんもりとした常磐木らしい全景を見せている静かな榎の木の下まで歩いた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく彼はそこに足を休めていると、ちょうど国境の一里塚の方から馬籠をさして十曲峠を上って来る中津川の香蔵にあった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠の上の国境に立つ一里塚の榎を左右に見て、新茶屋から荒町へ出た。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠村組頭の平兵衛が家はその部落の中央にあたる一里塚の榎の近くにある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川何代将軍かのお成りの名園の名残り、無量寺の小庭、一里塚の榎、先日物故した常磐津松尾太夫の稽古所。",
              "citation": {
                "source": "滝野川貧寒",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "『元日や冥途の旅の一里塚、目出度もあり目出度もなし』栄一はその小さい悲しい貧民の死にたゞ何とも云へぬ苦痛を感じた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "また何々塚・何石・何岩の類は、これも一里塚なり岩なりの名になっていたものを採ったのだから、塚や岩の命名法を調べる人に委ねてしまってもよい。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは一里塚と言った。",
              "citation": {
                "source": "老人と孤独な娘",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして電光のように時おり苦患を中断する歓喜の瞬間をば、成長の一里塚として全力をもってつかまねばならぬ。",
              "citation": {
                "source": "ベエトォフェンの面",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとにも、「一里塚地下道」、「東今の２踏切」、「千光寺前踏切」などなどが続く。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜもっと、活路をお取りなさらぬのだ」「活路は、今歩いている、この道こそ、拙者にとっては活路です」「冥途の道でなくば、倖いだが――」「或はもう、今越えたのが三｜途の川、今踏んでゆく道が一里塚、行くての丘は針の山かもしれません。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
