[
  {
    "uuid": "d8d4d4da-5d5c-54b4-8918-89826a567599",
    "entry": "息切れ",
    "reading": {
      "primary": "いきぎれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
