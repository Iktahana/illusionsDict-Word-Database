    "definitions": [
      {
        "index": 1,
        "gloss": "it's tactless to state the obvious",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
