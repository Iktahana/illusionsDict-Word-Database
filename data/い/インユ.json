  {
    "uuid": "75b0c77e-45db-5988-b096-a49f76f4fb09",
    "entry": "引喩",
    "reading": {
      "primary": "いんゆ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "allusion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はスレードの詐欺に対して、ふざけた引喩をしたところ、彼は有罪と無罪とを混同しないようにと、はなはだ熱心にわたしに向かって警告した。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五に、ギリシャ、ローマの神話及びイギリス古傳説からの引喩の續出。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "新修「ロミオとヂュリエット」の序",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和八年七月十日余丁町にて譯者〔備考※〕　神話や傳説からの引喩は初學者には註釋なしでは解らない。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "新修「ロミオとヂュリエット」の序",
                "note": "青空文庫"
              }
            },
            {
              "text": "即「諺」「序歌」の如き引喩を否定して、自身の場合を明示する方法なのである。",
              "citation": {
                "source": "副詞表情の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
