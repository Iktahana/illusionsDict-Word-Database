[
  {
    "uuid": "2f7e0287-8abb-52f2-a130-7baf37f8dd93",
    "entry": "居住まい",
    "reading": {
      "primary": "いずまい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
