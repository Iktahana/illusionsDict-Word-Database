    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(one's) seating posture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "話が核心に触れると、彼は居住まいを正してこちらを真っ直ぐに見据えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「居住まいを正しなさい」と師匠に一喝され、道場に一気に緊張が走った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "老紳士の凛とした居住まいには、積み重ねてきた品位と風格が滲み出ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "茶室に足を踏み入れると、亭主の静かな居住まいに圧倒され、自然と背筋が伸びた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ただ椅子に腰掛けているだけなのだが、彼の居住まいには隙がなく、独特の威厳を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「居住まいを正して伺わねばならないお話です」と、客人は神妙な面持ちで語り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重大な知らせを前に、彼はそれまでのリラックスした様子から一転、居住まいを正した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "婦人はあわただしく蹶ね起きて、急に居住まいを繕いながら、「はい」と答うる歯の音も合わず、そのまま土に頭を埋めぬ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくのことで唾を呑みこんで、居住まいをなおしながら下を向いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややしばらく思案しているらしかった小母さんは、きゅうに居住まいをなおして園の方にまともに顔を向けた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同級生の急死の報を得て、その夜にまとめられた追悼文の凛とした厳しさには、居住まいを正させる力を感じました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして雲が空を動くたびごとに、山は居住まいを直したかのように姿を変える。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　すうと門をはいって、すうと木立ちをくぐり、あごをなでなでご後室の隠居住まいにはいっていった名人の姿を知って、待ちかねたように出てきたのはそのご後室です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "座にい並んだ十数人の武士ども、そこでちょっとばかり居住まいを直し、固唾を呑むような格好をした。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと机の前に据わっているのだから、誰に障子を開けられても好いのであるが、思っていた事を気が咎めて、慌てて居住まいを直さなくてはならないように感じた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝見したことないわ」　困ったような、はにかんだような笑いかたをして多喜子はちょっと居住まいをなおした。",
              "citation": {
                "source": "二人いるとき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先へ読み進んで、朝子は涙も渇いた二つの眼を瞠って居住まいをなおした。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちてきた穴はほとんどまっすぐだし、第一、なんの足場もないから、その穴へ飛びつくこともできぬのだ」「伊賀の暴れん坊と丹下左膳、この穴の底に同居住まいとは、気のきかねえ話だなア。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、吉野の山から若木は残して、山の様を模すようこちらに植え替えれば、春には雲の上に居住まいしているような眺めとなって、一段の景色であろうな。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩特等席に座りたかったらできるよ」　ムーアが両手を両膝において居住まいを正し、「どうも。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいずまいを正して、掩いかぶさるようにその上にのしかかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼女は華車な両肩がぴんと尖った更紗模様の古風な上衣を着て、行儀よくいずまいしたまま、青年の後姿を腹立しげに睨むより仕方がありませんでした。",
              "citation": {
                "source": "恋",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者はおどろいていずまいをつくろった。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、顔かたちから、いずまいの美しいけだかいことといったら、世の中にくらべるものもないくらい、りっぱな、りりしい人でした。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　吉弥はちょっとぎゃふんとしたようであったが、いずまいを直して、「聴いてたの？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の男は、それで、手を離して、膝を立てて、袴の襞を正しく、いずまいを直した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあいつのまに……」彼女はあわてていずまいをなおして、ほつれ毛をかき上げた。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがすむと僕は少しいずまいをなおして、夫人に向かった。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、そう云えば、時にはあの尖端に燈火を点けることもございました……年に一度か二度のことですが、なんでも、いつもより少し遠く、沖合まで帆走する時の、目標にするとか申しまして……」「ははあ」　と東屋氏はいずまいを改めて、「いや、随分いい眺望ですなあ」「お気に召しましたか？",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "象皮病で死んだと言う事は余り聞かないが、旧態通りに治癒るって事は、ま、大体絶望らしいな」と助役はここで一寸いずまいを正して、「……どうやらこれでこの事件も幕になったらしいね……あの豚の轢殺事件が、こんな悲劇に終ろうとは思わなかったよ……いや、僕の手抜かりだった。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神輿の御座船は一｜際美しい屋形船で、旗｜幟や、玉｜串などの立ち並ぶ下に、礼装した神官たちがいずまい正し、伶人が楽を奏でるなかに、私の鈴子は美しい巫女の装いして、今宵は化粧も濃く匂うばかりに立ちまじっているのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に御息所がいざって来る気配がしたので大将は少しいずまいを直した。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを合図に子供たちはいずまいを正し、ごくりと唾をのみこむ音が聞えるのであった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼女は端然といずまいを正して、南さんにお茶をすすめていた。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあ、ではあの女装の……女装の男は勘助殿とやらで」　もうすっかりおちついて、いずまいを直した熊太郎は、しかし十分敬意を払い、謹んだ言葉つきでそういった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、お手紙が」　「あ、乃舅だな」　壮夫はちょいといずまいを直して、封を切り、なかを出せば落つる別封。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、お手紙が」「あ、乃舅だな」　壮夫はちょいといずまいを直して、封を切り、なかを出せば落つる別封。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
