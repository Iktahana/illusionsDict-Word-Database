        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔いざ渡せかし　おいぼれめ〕宮沢賢治「いざ渡せかし　おいぼれめいつもこゝにて日を暮らす」すぱとたばこを吸ひやめて何を云ふともこの飯の煮たたぬうちに　立つべしや芋の子頭白髪しておきなは榾を加へたり",
              "citation": {
                "source": "〔いざ渡せかし　おいぼれめ〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず裏の畑の茄子｜冬瓜小豆人参里芋を始め、井戸脇の葡萄塀の上の棗、隣から貰うた梨。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱田の八剣森陰より伏し拝みてセメント会社の煙突に白湾子と焼芋かじりながらこのあたりを徘徊せし当時を思い浮べては宮川行の夜船の寒さ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原の草を縛り合わせて通りかかった人を躓かせたり、田圃道に小さな陥穽を作って人を蹈込ませたり、夏の闇の夜に路上の牛糞の上に蛍を載せておいたり、道端に芋の葉をかぶせた燈火を置いて臆病者を怖がらせたりと云ったような芸術にも長じていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗惡のポンチ畫には、笑ひたくても笑へないが、小川芋錢の山水に噴き出すことがあるのと、同斷である。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、そしてお芋をやろうね」「ああ、いいとも、公園に行くんだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地の間にあるものは唯向ふの森と家と芋畑とそして一枚のスケッチ板ばかりであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦和の停車場からすぐに町外れへ出て甘藷や里芋やいろいろの畑の中をぶら／＼歩いた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間迄青かつた筈の芋の葉は數日來の霜に凍てゝすつかりうだつたやうになつたのが一つ／＼丁寧に結び束ねてあつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後四時にはもう三代吉の父親の辰五郎が白米、薩摩芋、大根、茄子、醤油、砂糖など車に積んで持って来たので少し安心する事が出来た。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日では場末の荒物屋芋屋でもこれを使っている。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして蝸牛の需要は秋から冬にかけてであるため、その頃になると蝸牛は土の中にもぐってしまうから、養殖者は丁度芋を掘るように木の棒で掘り出さなければならない。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お峯は車より下りてさん、あれ三ちやんで有つたか、さても好い處でと伴なはれて行くに、酒やと芋やの奧深く、溝板がた／＼と薄くらき裏に入れば、三｜之助は先へ驅けて、父さん、母さん、姉さんを連れて歸つたと門口より呼び立てぬ。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐の貧乏士族としての我家に伝わって来た雑煮の処方は、椀の底に芋一、二片と青菜｜一とつまみを入れた上に切餅一、二片を載せて鰹節のだし汁をかけ、そうして餅の上に花松魚を添えたものである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "襲撃者は鳶以上であるのに爆撃される市民は芋虫以下に無抵抗である。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その少し前にこの夏泊った沓掛の温泉宿の池に居る家鴨が大きな芋虫を丸呑みにしたことを想い出していた。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い芋虫と真紅の肉片、家鴨と眇目の老人では心像の変形が少しひど過ぎるが、しかしこの偶然な一と朝の経験から推して考えてみるとフロイドの「夢判断」の学説も、そのことごとくが全くの故事付けではないかもしれないという気がして来るのである。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから少し方面はちがうがあまり評判のよくなかった芋銭の「石人」などからも何事かを教えられた。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋銭氏の絵には時々心臓が働いているように見えるのを頼もしく思う。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米が少ないので毎日芋を喰わされる。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた茶碗を洗い、土のついた芋の皮をむいた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、家の中には、温かい囲炉裏、ふかしたての芋、家族の愛情、骨を惜まない心づかいなどがある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩には夜なべに、大根を切ったり、屑芋をきざんだりする。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう芋を掘る時分かな。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、芋が食いたいなあ！",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲田桑畑芋畑の連なる景色を見て日本国じゅう鋤鍬の入らない所はないかと思っていると、そこからいくらも離れない所には下草の茂る雑木林があり河畔の荒蕪地がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風にそよぐ稲田、露に浴した芋畑を自然観賞の対象物の中に数えるのが日本人なのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍の畑で芋を掘上げている農夫に聞いて、見失った青梅への道を拾い上げることが出来た。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茂兵衛ドンの猫は家の雛を捕ったんじゃで……魚でも、芋でも、何でも盗むんじゃ。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、じいさんは云って、自分で掘って来て蒸した芋を頬ばった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
