            }
          ],
          "literary": [
            {
              "text": "「そいつの売り込んだ金魚は勿論いか物に相違ありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "元吉や惣八が、人殺しにかかり合いのないことだけは明白ですが、金魚の方は、ほん物かいか物か、とうとう判らないことになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、こんな変りものは買う方も悪いということになっていましたから、たといいか物を売り込んだことが知れても、重い罪にはなりません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "似合わぬものはつまりニセ、いか物はいけない、いか物はいけない！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い博奕打ちがいか物の賽を使うように、まかないがこの男の弁当箱には秘密の印を附けているなぞと云うものがある。",
              "citation": {
                "source": "食堂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "教経は、平家第一といわれる程の弓の名人であり、豪勇を以て知られた男であったが、舟軍には舟軍の仕方があると、鎧直垂を着けず、唐巻染の小袖に、唐綾縅の鎧を着け、いか物作りの太刀を佩いた身軽ないで立ちで、次から次へと矢をくり出した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "商賣女のいか物喰ひだよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒酒藥酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼なんか見えないといふのは大嘘で、按摩なんかぢやありませんよ」「先刻、小判が出たと聽いて飛出した樣子ぢや杖にも及ぶまいな」「それから、お萬と來ちやいか物喰ひで大變な女で、宅の市と親しくなつて、伊八との間に喧嘩が絶えなかつたさうですよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘の守袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売女のいか物喰いだよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "毒酒薬酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、大正昭和と俳句隆盛時代の経過するうちに、栄養に富んだ食物も増し料理法も進歩したことはたしかであるが同時にビタミンの含有比率が減って来て、缶詰料理やいかもの喰いの趣味も発達し、その結果｜敗血症の流行を来したと云ったような傾向がないとも限らない。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下り坂の茶店で休んだときにそこのお神さんが色々の火山噴出物の標本やラヴァやカメーの細工物などを売付けようとしたが、こしらえもののいかものだけはわが地質学者を欺く訳に行かないのがおかしかった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果はいかものか失敗かである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が洋行の際に持って行って帰った記念品で、上面にケー・ナツメと書いてあるのを、新調のズックのカヴァーで包み隠したいかものであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて仏国にソンネット詩形を取り入れたとき、多少この詩形の規則をはずれたようなものを作ったものもあって、いかもの扱いにされたことであったが、それでもその規則はずれの自由さはほんのわずかの程度のものであった。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくの研究が「いかもの」の烙印を押されるような気味が感ぜられるからである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかもの食いの名人だけあって堂脇の奴すぐ乗り気になった。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いかものも、あのくらゐに成ると珍物だよ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも、私は東京のもっている青春のいかものさ加減に、反抗したのである。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にはまたとんだいかものが紛れ込む。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつアひでえキャッキャッになりやがった」　と、坂野を残して行く皮肉さを、ひそかに砂利のように噛んでいたが、しかし、この場の空気をにやにや見ているほど、京吉はいかもの食いではなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物や商品のいかものが市民に及ぼす害毒は、腐敗した議員たちのそれに比べたらそれほどでもないであろう。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでも道具屋の惣八がいかものを持ち込んだとか云って、ひどく立腹していました」「お葉という女は宗匠の妾ですかえ」「さあ」と、其蝶は少し云い渋っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きさまも途方もねえいかもの行者に化かされたな」「何をめっそうなことをおっしゃいますか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "その野郎をかぎ出しゃ、自然といかもの作りの人形師もわかるだろうし、わかれば盗まれた真物の行くえにも眼がつく道理じゃねえかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとばかり、いかもの食いがすぎますぜ」　さかんに伝六が正面攻撃をしていたちょうどそのときでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、そこの古道具屋、そちはもっといかものをつかまされないように、じゅうぶん目ききの修業をいたし、ずんと家業に精を出さねばならぬぞ、最後に質屋のおやじ、そのほうはこの近藤右門をののしったばかりではなく、恐れ多くもお上一統を卑しめたと申すが、どうじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の心得として、虚飾や、いかものの化粧が、実に無価値であることを、教えられるより、細々、一々、実際について、批評される。",
              "citation": {
                "source": "追想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父、母は物質的な人なのに、その娘は病身なせいかもののあわれを早く知って、精神的ないい性質を持っているのです。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の詩人きどりではいかものなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二銭団洲とは、下谷の柳盛座で、二銭の木戸銭で見せていた、阪東又三郎が、めっかちではあるが団十郎を真似て、一生の望みが叶って、歌舞伎座の夏休みのあきを借りて乗り出したことがあったのを、いかもの食いの見物が、つねづね噂に聞いた二銭団洲を見にいった。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
