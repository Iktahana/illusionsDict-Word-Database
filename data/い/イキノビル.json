[
  {
    "uuid": "c8d046ae-c3e1-5725-9197-dce36544cef4",
    "entry": "生き延びる",
    "reading": {
      "primary": "いきのびる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
