        "examples": {
          "standard": [
            {
              "text": "この地域では生垣によく犬黄楊が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "犬黄楊の低木は、手入れがしやすく庭木として人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "秋には犬黄楊の小さな実が赤く色づく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "総｜檜の木口｜数寄を凝らし、犬黄楊の籬の裡、自然石の手水鉢あり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬黄楊らしかつたが、殆んどその木ばかりの茂つた所もあつた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初は下生えの少ない椈の大森林の中を登るので至って暢気であったが、千三百米位から喬木が減じて次第に藪が甚しくなり、令法や石楠や、犬黄楊などの密叢が最も人を苦しめる。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其瘤までは令法、犬黄楊、楢、米躑躅、七竈の類が邪魔をするけれども、通行は割合に楽である。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
