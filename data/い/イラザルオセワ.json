          "literary": [
            {
              "text": "「何がなんだと、いらざるお世話だ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いらざるお世話だと云いたげであった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふふん、さてはあの人と……」「いらざるお世話、よござんすよ」「観音様へ参詣しお賽銭ぐらいは上げるだろうね」「おや、そいつは本当だね」　いい捨ててお色は戸外へ出た。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらざるお世話で、莫迦にしているよ」いよいよ慣れ慣れしい相手の様子に、彼女は一層腹を立て、心の中でこう怒鳴ったが、でもやっぱり黙っていた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いらざるお世話だ、こん畜生」　小男は勇敢に毒吐いた。",
              "citation": {
                "source": "柳営秘録かつえ蔵",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
