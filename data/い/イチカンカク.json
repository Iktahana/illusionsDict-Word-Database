[
  {
    "uuid": "bcf4d690-2b12-50ba-963b-13f9f4c2ffb2",
    "entry": "位置感覚",
    "reading": {
      "primary": "いちかんかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
