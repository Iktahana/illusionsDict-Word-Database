          "literary": [
            {
              "text": "やさしいお手で縫うて貰うているうちに、どちらが先にどうなったやら、――それからあとは言わぬが花よ。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれの夢をいかに解釈し利用するかについては、言わぬが花であろう。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あとは言わぬが花。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は言わぬが花でしょう。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五〇歳過ぎであるが、人生の関心は言わぬが花だ。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
