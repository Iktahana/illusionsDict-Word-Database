[
  {
    "uuid": "26a43b54-9a6f-5b05-b015-94f10cc87f54",
    "entry": "今のまま",
    "reading": {
      "primary": "いまのまま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
