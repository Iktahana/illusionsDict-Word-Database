        "examples": {
          "standard": [
            {
              "text": "インコにイカの甲をケージにつけておくと、くちばしを研いだりカルシウムを摂取したりできて便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "爬虫類の飼育では、カルシウム不足を防ぐためにイカの甲を設置することが推奨される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の万年筆では、イカの甲から抽出した墨（セピア）がインクとして使われることもあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統工芸の職人が、細かい作業のために道具の刃をイカの甲で軽く研ぐことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "水族館では、展示されているコウモリダコ（イカの仲間）の体内に、硬いイカの甲があるのが観察できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この鳥、いつもイカの甲をかじってるけど、そんなに好きなのかな？」と友人が尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ヒナ鳥の成長期には、イカの甲を細かく砕いて餌に混ぜると、骨格形成を助ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
