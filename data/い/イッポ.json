        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "テストの点数がほんの一歩だけ上がったけど、まだまだ努力が必要だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今日の進捗は、目標達成にはほんの一歩足りなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の説明は分かりやすくなったが、まだ一歩理解が足りない部分がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
