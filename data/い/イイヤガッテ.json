    "definitions": [
      {
        "index": 1,
        "gloss": "don't try and tell me that!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「勝手なことばかり言いやがって。少しはこっちの身にもなれよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「自分だってできてないくせに、よくもまあ偉そうなこと言いやがって」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「散々人の悪口を言いやがって、今更仲良くしようだなんて虫が良すぎる」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいつ、俺の前で平気であんな嘘を言いやがって。絶対に許さないからな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「正論ばかり言いやがって。世の中理屈だけじゃ通らないこともあるんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「全部お前のせいだろうが。どの口がそんなこと言いやがって」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「親父が学生は金を持つと為にならんて言いやがって、ちょっとも送ってくれないから困るよ」と赤井は別に赧い顔もせずに言った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密の何のと言いやがって！",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿なことを言いやがって……」　正勝は侮蔑の微笑を含みながら吐き出すように言って、紀久子の肩へそっと手を回した。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様は、そんなことを言いやがって、わっちの顔を潰しやがるな――こら賀川、貴様は俺の顔を知っていやがるだろう。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「からかっているわけじゃねえが、親分が患った日にゃ、御府内は闇だ」「お世辞なんか言いやがって、馬鹿野郎ッ」「へッ、お出でなすったね、その威勢のいい馬鹿野郎が聞きたかったんだ」　ガラッ八は掌で、自分の額を一つポンと叩くのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺という支配人が居るのに、東京ビルの主任だなんて新聞にいいやがって、怪しからん奴だ」　プリプリと足立支配人は怒りながら、向うへいってしまった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とかいいやがって、ああ、いまいましいズボンだ！",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
