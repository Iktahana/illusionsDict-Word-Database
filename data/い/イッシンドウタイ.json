[
  {
    "uuid": "64f93b18-0076-5f62-a9c7-6f33e38c13d6",
    "entry": "一心同体",
    "reading": {
      "primary": "いっしんどうたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
