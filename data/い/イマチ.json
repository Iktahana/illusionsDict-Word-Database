        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "縁側で茶をすすりながら、友の来訪を居待ちする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "立ち疲れたので、ロビーのソファで居待ちすることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "秋の夜長、虫の音を聞きながらのんびりと居待ちを決め込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ははあ角口に隠れていて、居待ち討ちにしようというのだな」　葉之助は用心した。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔭へ身を隠した小一郎は、刀の鯉口をプッツリと、切り、ソロリと抜くと左手を上げ、タラリと下がった片袖の背後へ、右手の刀を隠したが、自然と姿勢が斜めになる、鐘巻流での居待ち懸け、すなわち「罅這」の構えである。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊太郎も中段、心押し静め、既に十数人斬り斃しながら、腕にも肩にもしこり一つ来ない、柔い体を柔く保ち、仕掛けては行かぬ「居待ちがけ」に、しっくりと構え呼吸を整えた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも関らず宗三郎、進まず退かず居待ち懸け、生え抜いたように立っている。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はいつになくはればれと微笑み、私の肩をぽんと叩いて、「日本で一番よいまちだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは別なことだが、いまちょっと胸に浮んだから書いておく。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座通りといふ賑やかな美しいまちがある。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲府は、日ざしの強いまちである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと言ったって、狭いまちのことだもの。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまちょうど、池のまん中にいるではありませんか。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お月さまは、いまちょうど、水いろの着ものと取りかえたところでしたから、そこらは浅い水の底のよう、木のかげはうすく網になって地に落ちました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お月さまは、いまちやうど、水いろの着ものと取りかへたところでしたから、そこらは浅い水の底のやう、木のかげはうすく網になつて地に落ちました。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待「いや、勿論私のところにあるのですがね、いまちょっと切れていますから、証明書を書いて上げます。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまちよいと中腰になつてます、あれですよ、」と指さして居ると、おもちやもふつとこちらを向いた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまちょうど五時でございます」　「うん、わしはゆうべ一晩ねむらなかった。",
              "citation": {
                "source": "四又の百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、井菊屋はほとんど一方の町はずれにあるから、村方へこぼれた祝場を廻り済して、行列は、これから川向の演芸館へ繰込むのの、いまちょうど退汐時。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまは、いまちょうど、しずもうとするところだったのです。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "しずかな、いいまちです。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船橋市は、泥海に臨んだかなり大きいまちであった。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の姉の學校は下の姉の學校よりも小さいまちにあつたので、お土産も下の姉のそれに較べていつも貧しげだつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは別なことだが、いまちよつと胸に浮んだから書いておく。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河村清一博士の蕈の図譜がいまちよつと見当らぬから、其名を知る由がないが、其一つ一つの大さは小指の先ほどであつた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うるさいね、いまちょいと出懸けるんだから。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが皇子はご即位になるまえに、お身持ちの上について、ある言うに言われないまちがいごとをなすったので、朝廷のすべての役人やしもじもの人民たちがみんな皇子をおいとい申して、弟さまの穴穂王のほうへついてしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし足の惡いまち子は、すぐに疲れるので、やがて靜かなカフエーかレストランドに入らなければならなかつた。",
              "citation": {
                "source": "追憶",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしもいまちょっと思いついたこともあるのです」　冬木刑事も長谷川との協力を有利とみたものかとうとう我を折って、今後は二人で助け合うことをかたく誓い、互いにこれまで知っている材料や意見を提供し合った。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまちょうどひげを剃っておりますから。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんなら、いまちょいとお仕事が、おあんなさるのですって」　雪子夫人は、お饒舌をしたあとで、娼婦のように、いやらしいウインクを見せたのだった。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面の中にもぐっていて、青空が見えるはずがない」　正吉は、うっかり思いまちがいしていたことに気がついて、顔があかくなった。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまちよつと東京へ歸つてをりますが。",
              "citation": {
                "source": "七つの手紙",
                "author": "或女友達に",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
