    "definitions": [
      {
        "index": 1,
        "gloss": "sitting while waiting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
