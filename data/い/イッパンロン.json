[
  {
    "uuid": "1030f2b9-c56d-5da9-afea-73cb4c196e6a",
    "entry": "一般論",
    "reading": {
      "primary": "いっぱんろん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
