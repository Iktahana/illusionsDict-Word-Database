        "examples": {
          "standard": [
            {
              "text": "育英大学は、地域活性化を目的とした新たな産学連携プロジェクトを発表しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの受験生が、育英大学のオープンキャンパスに訪れ、キャンパスの雰囲気を肌で感じていました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は育英大学卒業後、IT企業でAIエンジニアとして活躍しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "育英大学の〇〇教授の研究室では、環境問題解決に向けた革新的な素材開発が進められています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「将来のことを考えると、育英大学の〇〇学部で専門知識を深めたいんです。」と、彼女は熱く語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末には、育英大学の学園祭で、学生たちの活気あふれるパフォーマンスや模擬店を楽しむことができます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "本学（育英大学）は、国際的な研究ネットワークの構築を目指し、海外の大学との連携を強化しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
