    "definitions": [
      {
        "index": 1,
        "gloss": "breathing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "集音マイクが、ゴール直後の選手の激しい息遣いを鮮明に捉えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "背後から忍び寄る者の荒い息遣いを感じ、彼女は思わず足を止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "腕の中で眠る赤ん坊の、規則正しく穏やかな息遣いに心が安らぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この古い路地裏を歩くと、かつてここで暮らした職人たちの生活の息遣いが伝わってくるようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "緊張のあまり、自分の荒い息遣いばかりが耳元で大きく響いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "満員のホールは、聴衆が息遣いさえ潜めるような独特の静寂に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "役者の繊細な息遣いまでもが、劇場の最後列まで真っ直ぐに届く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "皆の穏やかな息遣い。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリウェザー氏のため息めいた細い息遣い。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く、暗く、冷たいその切れ味には、疾走する者の荒い息遣いより、いつ吸っていつ吐いているのか分からない、薄紙一つも揺らさない沈黙がよく似合った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそんなことをほざく奴には、ＴＭＮだとか B'z だとかいった連中の、人の息遣いの欠如したブザー早押しクサレ音楽を、反吐を吐くまで聞かせてやるからな。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々訊くと、予てから猫の産月が近づいたので、書斎の戸棚に行李を準備し、小さい座蒲団を敷いて産所に充てていたところ、昨夜は宵から容子が変なので行李の産所へ入れるとは直ぐ飛出して息遣いも苦しそうに※々啼きながら頻りと身体をこすりつけて変な容子をする。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、男の苦しそうな息遣いが、聞えるばかりで、相手は身動きもしないようであった。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "息遣いも剣気も、刺客の迫って来たらしい気配は何一つきこえないのである。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――同時になにか悶えるような息遣いがきこえたかと思うと、小女の花簪が、リンリンとかすかに鳴った。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぽつりと声が切れたかと思うと、しばらくうしろで新兵衛の荒い息遣いがきこえていたが、やがてばたばたと駈け出した足音があがった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして烈しい息遣いをしながら、おりおり目を開いて渇きを訴えた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お銀は畳の上へ転がりだして、もがきつかれて急しい息遣いをしながら眠っている子供の顔を眺めて、落胆したように言い出した。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄司氏はすぐ隣に接して支倉の息遣いを聞きながら、落着き払って裁判長に答弁をしていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは、ズカズカと夫の傍へ寄って、じっと痩せ衰えた顔と激しい息遣いを見て居られたが、お眼に涙が光っていた。",
              "citation": {
                "source": "愛の為めに",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイプライターの前に坐って激しい息遣いを落ち着かせていると、野田が青白い顔をして傍に寄ってきて、小声で退けたらすぐに例のところへ来てくれと囁いた。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ私だって、あの人の側では荒い息遣いをしてもいかず、自分の動悸でさえ、水面が乱れてしまうことぐらいは承知しているのですけれど、あの熱情を、貴方に代えて向ける人と云えば、時江さん以外に誰がありましょうか。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ、お前がその畔で、荒い息遣いをしたり、飛び込んだりなどするものだから、いつも泉の面が波紋で乱れていて、きまって抱き寄せようとすると、あの娘の姿は消え失せてしまうのでした。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡で若草は弥々伊之助の事が心配になり、クヨ／＼思うから、漸々と御飯も食べられないようになりました、永煩いの処へ食が止ったゆえ若草は次第に痩せ衰え、ホンと云う息遣いが悪うございまして、泣いてばかり居ります。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "物かげに身を潜めている陳君は、このとき、全身の血のたぎるのを感じ、荒々しい息遣いになって来た。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその日｜中死生の間をさまよい、私の家で卒中の発作に罹ったあの老海賊のように荒い息遣いをしていた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの二十歩ばかり歩いただけなのに、もう疲れてしまったらしい、喘ぐような息遣いをしながら、そのベンチに腰を下ろした。",
              "citation": {
                "source": "初雪",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸次に、速い苦しげな息遣いの合間合間に、こう言うのが聞えて来た。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして息遣いを落著かせてしっかりさせようとする彼の努力のために脣はぶるぶる震え、その脣からは血の気がさっと心臓へ戻った。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "息遣いが荒くなり、それもだんだん間遠になって来る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬も私たちの足元で、姿は見えず、ただ喘ぐ息遣いだけが聞えていた。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は暫くぼんやり妻の顔を眺めていたが、せめてこの安らかな息遣いだけを、相手として、コップの酒を傾けた。",
              "citation": {
                "source": "夢幻泡影",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "三平などはあれを飲んでから、真赤になって、熱苦しい息遣いをした。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の向うから、バタバタという足音が、はげしいいきづかいとともに近づいたと思うと、「ま、間にあったか！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、不思議なことに、怪物の胸もとあたりから、妙ないきづかいが聞え、先生をおどろかした。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの、はげしい、いきづかいを、腹話術で、うまく聞かせたのだ。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎君のいきづかいが、はげしくなってきました。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
