[
  {
    "uuid": "538eed88-f358-55b0-b73e-4ed48b145d90",
    "entry": "板ガラス",
    "reading": {
      "primary": "いたガラス",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
