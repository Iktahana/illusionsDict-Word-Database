          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "提出された申請書類に、添付すべき資料の遺脱が確認されたため、再提出を求める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "過去の報告書から、重要なデータが遺脱されている可能性が指摘された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この解析では、ノイズ除去の過程で微小な信号が遺脱しないよう細心の注意を払う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "データベースの正規化を行う際、関連するレコードの遺脱はデータの一貫性を損なう主要因となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ごめん、さっきのメールで、取引先への返信を遺脱してた！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このリスト、名前が遺脱されている人がいないか、もう一度確認しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うっかりして、お礼の品を遺脱したまま送ってしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "殊ニ有隣舎所在ノ地ノ風土人物ニ関スルヤ予ハイマダカツテソノ地ニ抵リシ事ナキヲ以テ鄙著ノ遺脱｜謬誤最甚シキモノアルガ如シ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠近法がひどく間違っている上に、町の幅を広く書き過ぎたが、これ等の実行上の過誤と共に、この絵には多くの遺脱の過誤もある。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで代は甚だしいヂャナリズムでいつぱいだつた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葬ひみたいだつたよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はとう／＼たまらなくなつて出来るだけ声の調子を穏当にした積りで、「そんなに泣かせないだつて、もう少しやりやうがありさうなものだがな」　と云つた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでから急いだつてなんにならう……だがこんなことを考へるのも可笑しい、うん、可笑しい。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、肩を持たれたまゝ、右の跛の黒どのは、夫人の白魚の細い指に、ぶらりと掛つて、一ツ、ト前のめりに泳いだつけ、臀を搖つた珍な形で、けろりとしたもの、西瓜をがぶり。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああまあいいあんばいだつた。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘ははだしで歩きにくかったので、急いだつもりだが、阿倍野橋まで一時間も掛った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の便所はきれいだつたが（安宿の便所は殆んど例外なしにきたない）私の夢はいやにきたなかつた。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたはらでとつぜん大砲が発砲されたやうなぐあいだつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、みんなは新太郎ちやんのことを、まるで見落としてゐるみたいだつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌は、別に身投げとか覚悟とかさういつた思ひ詰めたものでもない、何か死とすれ／＼に歩み沿つて考へ度い気持ちで一ぱいだつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小径は、いつか東村と来た時に黒い矢車型のげんげの莢でいつぱいだつた。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好いわよ、そんなに気まりを悪るがらないだつて、」　お幸ちやんの首つたまを抱いてゐる学生が口を挟んだ。",
              "citation": {
                "source": "雨夜詞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、三百年のあいだつとめて、あたしたちの力のおよぶかぎりのいい行いをしつくしたあと、死なないたましいをさずかり、人間のながい幸福をわけてもらうことになるのです。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、肩を持たれたまゝ、右の跛の黒どのは、夫人の白魚の細い指に、ぶらりと掛つて、一ツ、ト前のめりに泳いだつけ、臀を揺つた珍な形で、けろりとしたもの、西瓜をがぶり。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "様あ見やがれ、」というと、嶮のある目を屹と見据え、今なお座中に横わって、墨色も鮮に、五千疋とある奉書包に集めた瞳を、人指指の尖で三方へ突き廻し、「誰を煽いだつもりだよ、五千疋のお使者が御紋服の旦那だと思うと、憚んながら違います。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "粘質壌土ではあり、土鼠穴は十分に塞いだつもりだったので、これ以上は手の下しようが無かった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうなつてからいくら騒いだつてもうおつつかない。",
              "citation": {
                "source": "爪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「止せば好かつたのに……」「いくら急いだつて町まで行つたら、今の間には合はなかつたでせう、どうしたと思つて？",
              "citation": {
                "source": "ランプの便り",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何もそんなに肚を立てないだつて好いぢやありませんか――」　彼は私の姿を弱々しく見あげながら、悲しさうにつぶやくのであつた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「煽がないだつて好いのよ、何か手に持つてゐなければ格構がつかないわよ、煙草ばかりプカ／＼喫されてゐるのも困るからね。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「教へないでも覚えるだけのことは覚えるだらう、覚えなければ覚えないだつて好いぢやないか。",
              "citation": {
                "source": "秋・二日の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「寒い思ひをして泳いだつて見物人が居なくつちや、馬鹿／＼しいな！",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でも僕の家の先祖は、こゝの家のけらいだつたんだつてね。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐野郎……空呆けるない、あたいだつて皆な知つてゐるんだぞ。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」　さう云へば、さつき、叔父様の胸で泣いてしまつた時のあたしの声は、何となく、鵞鳥に似てゐる見たいだつたが、若しや叔父様が兄様にそんなことを告げたのではなからうか？",
              "citation": {
                "source": "鵞鳥の家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の胸はいつも異様な酒の酔で陶然としてゐる見たいだつたから、そんな光景が一層不思議な夢のやうに映つた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何だか好くはわけがわからなかつたけれど、妾が此処に泊つてゐることを誤解してゐる見たいだつたわ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
