        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このプロジェクトの言い出しっぺなんだから、最後まで責任持ってよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい企画の言い出しっぺになったのはいいが、まさかこんなに手間がかかるとは思わなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「週末、みんなで集まって何か新しいことやろう！」って、俺が言い出しっぺだから、まずは場所探しから始めるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "結局、やるって言い出したのは君なのに、途中で「やっぱり無理」とか言うのは、言い出しっぺのくせに無責任すぎる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今回の政策変更の言い出しっぺである大臣は、記者会見でその意図を改めて強調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅行の計画で、いつも誰か一人が「ここに行こう！」と言い出しっぺになって、みんなをその気にさせるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっとこの件、仕切り直そうよ」って言ったのは私だけど、まさかこんなに大ごとになるとは思わなかったわ。「もう、あんたが言い出しっぺなんだから、なんとか収拾をつけてよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ＤＴＰの言い出しっぺが目を付けたのも、ここでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルはＰＤＡという名前の言い出しっぺになったが、マイクロソフトも同じような観点から家電への進出を狙っている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＲＯＮの仕様は、いいだしっぺの坂村健さんによって全て決定される。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
