        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "潮だまりを覗き込むと、岩の隙間に張り付いた磯巾着が、ゆらゆらと触手をなびかせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "クマノミは磯巾着の触手の中に隠れることで、外敵からの攻撃を巧みに回避している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "磯巾着は、外敵からの刺激を受けると一瞬で触手を内側に巻き込み、その名の通り巾着袋のような形に凝縮する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "触手にある刺胞から毒を出す磯巾着は、不用意に素手で触れると皮膚が炎症を起こすことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "有明海周辺では磯巾着を「ワケノシンノス」と呼び、味噌煮などにして食べる食文化が今も根付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、この磯巾着、指でつつくとぷにぷにしていて面白い感触だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砂地に生息する種類の磯巾着は、体の大半を砂の中に埋め、触手だけを地上に出して獲物を待ち伏せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、見て！岩陰の磯巾着が小さなエビを捕まえて、ゆっくり口に運んでいるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "が、遠くに離れてゐた私達の眼に、先生の紫ずんだ唇が磯巾着のやうに開閉し、それにつれて左右に撥ねた一文字髭が鳶の羽根のやうに上下するのが見えたかと思ふと、先生はもう降壇されてしまつた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の眼は、無料宿泊所の新らしい木札に、磯巾着のように吸いつけられたのだ！",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "破船の板や丸太や縄切れや、ブリキが岩の間に落ち散り、磯巾着が取りついているのでござります。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肩が凝ってやりきれない……頭に口があるのは、磯巾着くらいのものだが、こんな恰好で飯を食うなんてのは、人間業じゃないな」　賢夫人は、箸の先に飯粒をためたまま、「なにが、どう人間業でないんです？",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは、いそぎんちゃくだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜の根は貪婪な蛸のように、それを抱きかかえ、いそぎんちゃくの食糸のような毛根を聚めて、その液体を吸っている。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそぎんちゃくも、手をひろげている。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "にな貝のからをいそぎんちゃくに差しこむと、あわててしぼんで、まるで巻きたばこをくわえたようになるのがことに面白かった。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
