    "definitions": [
      {
        "index": 1,
        "gloss": "to lay the foundation (for)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
