[
  {
    "uuid": "3eb39cc6-3833-50dd-beee-996ea5baf0c6",
    "entry": "意識下",
    "reading": {
      "primary": "いしきか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
