      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "subconscious",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい環境への適応は、意識下で徐々に進行していくものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の言動の端々には、相手への配慮が意識下に見え隠れしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "広告の戦略は、消費者の購買意欲に意識下で働きかけるよう綿密に練られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ストレスが溜まると、意識下で身体に様々な不調が生じることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の経験から培われた感覚は、意識下で正確な判断を導き出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「どうやら、意識下でずっとそのことを気にしていたようだ」と、彼は小さく呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――表現上における反性格とは、實には性格の中に存しながら、觀念が行爲の表象に現はれて來ないもの、したがつて生活の意識下に沈熱して、不斷に爆發の機會をねらつてゐる所の、一の人格的イデヤを意味してゐる。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かの女も画家も、意識下に直助によつて動揺させられるものがあり、二人ともめい／＼勝手にあらぬことを云つてるやうで、しかも、心肝を吐露してる不思議な世界を心に踏みつつ丘の坂道を下つた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり信用のおけぬ潜在意識下に何か私の顕在意識と異った思想が埋没されていて、それが浅間しくも夢の姿で現れて来るのか？",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい、これが明瞭に意識の上に現われておらぬにしても、意識下において何か原因がなければならぬ。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしまた、意図せざる結果として、客観的には人類の進歩性を後へひっぱる権力に利益を与えることになったのならば、それは如何なる意識下の力――作家ジイドが好んで潜入し、格闘するところの無意識の力に作用されてであるのか。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために翻って、どんなに製作に向っての無私が必要だか、意識下の均衡が大切だか思い知らされているといえるのである。",
              "citation": {
                "source": "透き徹る秋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑は豊里のイメージにつながり、そこでの苦闘を意識下で反芻することになるのだろうか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "意識下で、一つの言葉が響きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その鍵は、パッケージソフトが握っている」　そう確認するとき、浜田は意識下で、アメリカでの体験を反芻していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇備考　斯様に偉大な内容を持つ細胞の大集団が、脳髄の仲介によって、その霊能を唯一つ、即ち各細胞共通、共同の意識下に統一したものが人間である。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の鼻唄は「多分死にはしないだらう」といふ意識下の確信から生れ、「必ず死ぬ」ときまつたときには、自ら別の態度を要求される。",
              "citation": {
                "source": "死と鼻唄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鼻唄は「多分死にはしないだらう」といふ意識下の確信から生れ、死といふものを直視して祖国の危難に赴く人の心ではない。",
              "citation": {
                "source": "真珠",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、あなた方の心は、もう、死を視つめることがなくなつたが、その代りには、あなた方の意識下の確信から生還の二字が綺麗さつぱり消え失せてゐたのだ。",
              "citation": {
                "source": "真珠",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦場の兵隊達は死の不安を視つめてゐても、意識下の確信には常に生還の二字があつて、希望の灯をともしてゐる筈なのだ。",
              "citation": {
                "source": "真珠",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは、絶えず意識下に、ひとつの願望をひそませてゐる。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、あくまでも、個人々々の意識下にひそんでゐる願望であるから、つまり前に述べた無意識に憧れる「理想」そのものであるから、自覚的にそれとはつきり明言するものはないにきまつてゐる。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの意識下には、水泳はタイムだから、せり合わなくとも、いずれはタイムが証明する、という鷹揚な気持があってのことだろうと思う。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻視というものは、意識下の固定観念の反射からおこる錯覚の一種にすぎないことを、白川は知っている。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼームスなどに云わせると副意識下の幽冥界と僕が存在している現実界が一種の因果法によって互に感応したんだろう。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今度の紀州行きの決心も、多分、あの時の「浜木綿」の名が意識下に働いてゐたためではなからうかと。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくは、当惑するような記憶の空白を擬制記憶で埋めるべく意識下の精神機能が努め、その結果異様に空想的な斑気が起こるのであろう。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音程は広範囲に及び、何か潜在意識下の記憶によって、私は不安を、また暗い恐怖感をすら覚えたのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲のアーキテクチャと僅かに判別できる壁面のアラベスク模様とがひたすらに五点からなることが、我々には逃れる術のないやり方で朧げに邪悪な何かを仄めかし、ある意識下の恐怖に触れるような感じを与えたのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "全てを見ておかなければという純然たる原始的な焦燥感か、あるいはそこまで原始的ではないにせよ同じくらい意識下の努力だったのかもしれない。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは体験に即し、事上に錬磨の功を積んで得られた意識下の能力なのである。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活に一貫した自立性を求めて行くアンネットの理性と情緒的な物との見かたが、この作品では、一方を人間的高度の知的な物として、他の一つを意識下の血の力として見ているような点が、何か私達の生活の現実が、到達している生活の実際よりも、歴史的に一段階前のもののように思われます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "意識下に眠っていた嫌悪のかたまりが、いきなり現実のシチウに刺戟されて直結したような感じであった。",
              "citation": {
                "source": "黄色い日日",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うにこの幽霊はあまりの悲しさに意識下に葬って置いた記憶が年月を経てその悲しさのゆるむのを待って意識の蓋を突き上げてその姿を現わしたわが悲しみの映像であったに相違ない。",
              "citation": {
                "source": "幽香嬰女伝",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはいかなる怨恨憎悪をも意識下に埋没しては置かなかったから。",
              "citation": {
                "source": "幽香嬰女伝",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
