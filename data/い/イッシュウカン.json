    "definitions": [
      {
        "index": 1,
        "gloss": "one week",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "インフルエンザにかかり、一週間も会社を休んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "図書館で借りた本は、一週間以内に返却しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "来週から一週間、家族でハワイ旅行に行く予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "大隅君は、結婚式の日まで一週間、私の家に滞在する事になっているのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸衣裳の用意も無い事はないのだが、それも一週間ほど前から申込んでいただかないと困るのです、という返事であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間に一遍くらいはきっと廻って来るが、いつ来ても同じような話ばかりしている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間、全一週間、そのために寝たっきり呻いていた、足の傷の上にこの体を載せて、歩いたので、患部に夥しい充血を招いたのに違いなかった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "市の中學から恐らく一週間ぶりに歸つた子供は此一夜を父母と同じ苫の下で明かさうとするのであらう。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間と保った試しはないぜ」彼女はこんな言葉を使うようになった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "滞在一週間ほどすると、電気器具店の蒔田が、老妓から頼まれて、金を持って迎えに来た。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十年ほど前にはＨ博士の助手として、大湯｜間歇泉の物理的調査に来て一週間くらい滞在した。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またもし「一週間内に東海道の大部分に降雨あるべし」との予報をなし得たりとせば、東京市民にとりては極めて漠然たる印象を与うべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地の事は少しも分りません、早慶戦でＫＯが勝った事を一週間ばかり前に同盟通信のカメラマンに聞きました。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ達のネタを一週間以内にもってくれば手附の十倍の報酬を進呈するわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤めてゐる大連のＭ會社の或る仕事のために、私がハルピンへ來たのは、その一週間程前の事だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、またそれ程に同君の心を荒ませ、生活を散文化させ、性格を暗い否定主義に誘つた町の空氣を思ふと、一週間の滯在の間に受けた色色な印象、見聞のすべてが一層切實なものに感じられた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前發作で五日一週間を臥床して、それが鎭まる前にはきつと九度、四十度の發熱がお極りだつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間ほどするうちに、それまで、全く枯野だった草原が、すっかり青くなって、草は萌え、木は枝を伸し、鵞や鶩が、そここゝを這い廻りだした。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原は一面に霧がかゝって、つい半町ほどさきさえも、見えない日が一週間ほどつゞいた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間ばかりたった後のことだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あと一週間になった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間ばかり外米混入の飯を食いつづけた後、一日だけまぜものなしの内地米に戻ると、はじめて本当に身につくものを食った感じで、その身につくものが快よく胃の腑から直ちに血管にめぐって行くようで、子供らは、なんばいもなんばいも茶碗を出すのである。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏に呉れてやる女には、これはよいことだが、一週間に一度だけ内地米を食って息をついていた子供らにはこれはなか／＼慰められないおお事である。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　入営してから、一週間ばかりが、実に長かった。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　それから一週間ほど、それ等の汚れた豚は昼夜わめきつづけていたが、ついに、一ツ一ツばた／＼斃れだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれども君は、かの後の事はよく知るまい、まもなく君は木村と二人で転宿してしまったから……なんでも君と木村が去ってしまって一週間もたたないうちだよ、ばあさんたまらなくなって、とうとう樋口をくどいて国郷に帰してしまったのは。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "初は一週間の病気届、これは正規で別に診断書が要らない、其次は診断書が付て五週間の欠勤。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間も田舎へ行っていたあとで、夜の上野駅へ着いて広小路へ出た瞬間に、「東京は明るい」と思うのであるが、次の瞬間にはもうその明るさを忘れてしまう。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際新しいステッキを買うとあと一週間ぐらいは勉強ができるという人もいるくらいである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以前には一週間くらい泊りがけで出かける事にしていたが、そうするときっときまったように誰かが転地先で病気をした。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みそさざい」という名前をつけて一週間に一回くらいずつ発行したのが存外持続して最近には第九号が刊行されたようである。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二度とも一週間の練兵休で、すぐまた、勤務につかせられたよ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
