[
  {
    "uuid": "22e481b5-3b96-54cd-b11f-50689403f81f",
    "entry": "石橋",
    "reading": {
      "primary": "いしばし",
      "alternatives": [
        "せっきょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
