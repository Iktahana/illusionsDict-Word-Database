        "examples": {
          "standard": [
            {
              "text": "「異議あり！ その決定に否やを唱える権利が我々にはあるはずだ」と代表者が声を張り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "役員会で出された再建案に対して、出席者の誰もが否やを言えない重苦しい空気が流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やるかやらないか、今すぐ返事を聞こう。否やはあるまいな？」と社長は鋭い眼光を向けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
