          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うわっ、ひどい土砂降り！」玄関のドアを開けるや否や、激しい雨風が室内に吹き込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "合図のチャイムが鳴るや否や、生徒たちは一斉に校庭へと駆け出していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は帰宅するや否や、カバンを放り出して冷蔵庫の中の冷えた麦茶を煽った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "凌雲閣上人豆のごとしと思う我を上より見下ろして蛆のごとしと嘲りし者ありしや否や。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彩色と云っても絵具は雌黄に藍墨に代赭くらいよりしかなかったが、いつか伯父が東京博覧会の土産に水彩絵具を買って来てくれた時は、嬉しくて幾晩も枕元へ置いて寝て、目が覚めるや否や大急ぎで蓋をあけて、しばしば絵具を検査した。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボースンとナンバンとが、サロンデッキに現れるや否や、彼は遠方から呶鳴った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸氏は男が女の許へ帰るが否や、どんなにか二人の間に劇的な、再会のよろこびが叙されたかを想像することでせう。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに足痕が泥につくや否や、火山灰がやって来てそれをそのまま保存したのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理的自然現象を限定すべき条件等がすべてこれらの有限なる独立変数にて代表され得るや否やは別問題として、現在の物理学的科学の程度において、従来の方法によりて予報をなし得る範囲は如何なるべきかが当面の問題なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は一町ほど先へ行ってから、気がついて振り返るや否や、あれッと叫んで駆け戻ってきた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お増は長い話を終るや否やすぐ家へ帰った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "着たままで寝ていた僕はそのまま起きて顔を洗うや否や、未だほの闇いのに家を出る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の幹や枝の弾性は果してその重量に堪え得るや否や覚束ない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵はその酒場を出るや否や自分の襟をとって離さなかった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその女を見るや否や、靜かに歩き出した。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかに日が暮れ出すや否や、犬どもは、一匹づつ、扉の隙間から出て行つた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛まれるや否や、その下らない奴は、直ちに悲鳴をあげた。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、頤の下へ手をかけて、片手で持っていた単衣をふわりと投げて馬の目を蔽うが否や、兎は躍って、仰向けざまに身を翻し、妖気を籠めて朦朧とした月あかりに、前足の間に膚が挟ったと思うと、衣を脱して掻取りながら下腹をつと潜って横に抜けて出た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　説明も形容も何もない――燐寸を摺ると否や、アルコールに火をつけるのであるから、言句もない。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大噐氏にちょっと会釈するや否や、若僧は落付いた、しかしテキパキした態度で、かの提灯を持って土間へ下り、蓑笠するや否や忽ち戸外へ出て、物静かに戸を引寄せ、そして飛ぶが如くに行ってしまった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゐのこ雲　蝶々雲は古き歌に見えたりや否や知らず、ゐのこ雲といへるは仲正の歌に見えたり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "望雲楼　東坡が望雲楼の詩に、陰晴朝暮幾回新、已向虚空付此身、出本無心帰亦好、白雲還似望雲人、といへる、さすがにをかしからぬにはあらねど、なほ下の心のあるやうにて、白雲点頭すべきや否や覚束無し。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "八雲立つの神の御歌を解きて、その時立ちし雲は天地のみたまの顕はせりし吉瑞にて、いともくしびなる雲なりけむなど橘の守部が云へるは、当れりや否や、知らず。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "約言すれば物理学その他物理的科学の系統はユニークであるや否やということである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候がちがうのか、それとも実が実として存在する期間が短く、実がなるや否や爆裂して木っ葉みじんになるためなのか、どうか、よく確かめようと思っているうちに帰京の期が迫って果たさなかった。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラシを板の上に置くや否や、そいつがぼうっとかすんで無くなって、風がどうっと室の中に入ってきました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに足痕が泥につくや否や、火山灰がやって来てそれをそのまゝ保存したのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、お熊……お前はまあ何と言う……ダダ……誰が斯様なこと、したかいなあ……」　そのアトから人を分けて入って来た半白髪の恰幅のいい老人は、女房の肩ごしに娘の死骸を一眼見るや否や、両手をシッカリと握り合わせたまま石甃の上にドスンと尻餅を突いてしまった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　これを聞くや否や、ラクダルは手に持て居た無花果を力任かせに投げて怫然と親父の方に振り向き『此兒を私の弟子にするといふのですか貴樣は？",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしのやうな小国の王の杯は受けぬと言ふのか、恩知らず奴ツ」彼はこう叫ぶやいなや、その大杯を丈の高い蘭人の額にハツシとぶつけた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような律動のある相が人間肉体の生理的危機であって不安定な平衡が些細な機縁のために破れるやいなや、加速的に壊滅の深淵に失墜するという機会に富んでいるのではあるまいか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は今日まで、貝原との約束をどう薫に打ち明けようか、思いなやんでいたのである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦線のひっぱくは、彼をして内部に思いなやんでいることを打ちあけるひまを与えなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
