    "definitions": [
      {
        "index": 1,
        "gloss": "regular",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仕事帰りに、行きつけの居酒屋で冷えたビールを一杯飲むのが何よりの楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこのイタリアン、僕の行きつけなんだけど、特に手打ちパスタが絶品なんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は行きつけの美容院で、長年指名している担当者にカットを任せている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学生時代から通い詰めた行きつけの喫茶店が、建物の老朽化で閉店してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「週末は行きつけの古本屋へ足を運び、掘り出し物を探すのが習慣になっています」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出張でこの街に来るたびに必ず立ち寄る、行きつけの定食屋がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は地元で顔が広く、商店街のあちこちに行きつけの店を持っているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もつとひどいのは、或る夜行きつけの珈琲店に行つたら、女給が「昨夜遲くなつてお歸りが困つたでせう」といふ。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行っても行ってもそこまで行きつけないような不思議な気持になるのだ。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何より楽しみに行きつけた夜学校の日曜日の会にも行くのをやめて、力三の高下駄を少し低くしてもらつて、それをはいて兄を助けた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共は、それから、行きつけの港の、砂浜にあるパブリック・ホテルへ女を買いに出かけた。",
              "citation": {
                "source": "シルクハット",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　行きつけの家で松島はしばらく小菊を呼んでいた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "永瀬はこの土地で呼ぶばかりでなく、時には神楽坂へもつれて行き、毘沙門横丁の行きつけの家で、山手の異った雰囲気のなかに、彼女を置いてみたり、ある時は向島の一号である年増の家へも連れて行き、彼女を馴染ませてみようともした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目彼の女を見され、即座に法衣を着た巌と成つて、一寸も動けまい、と暗の夜道を馴れた道ぢや、すた／＼と小家へ帰つてのけた……　翌朝疾く握飯を拵へ、竹の皮包みに為て、坊様を見舞に行きつけ…靄の中に影もねえだよ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、行きつけた赤城の小沼の水底から鱗の閃きを見たという風に人に吹聴しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事が終りかけた時、姉の圭子は、以前からの話の続きらしく、「私が、ご案内してもよろしいんですが、開幕前で、何となく落着けませんし、妹ならもう行きつけているんですから。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ行きつけの茶屋へあがって、蝶子を呼び、物は相談やが駈落ちせえへんか。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きつけの店を一廻り廻ってしまうと、すっかり気がぬけたようになって、行先を思案するために突立っている彼等の顔は、どれも間が抜けて、憂欝そうだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざっとこんな風だったから、豹一のようになんの気取りもなしに、行きつけの飯屋へはいるような容子でぶらりとはいって来るのは珍らしいのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――朝になって、その哀れな男は、そのボートが、毎日行きつけている場所に――おそらく、勤務のために行かねばならぬ場所に――拾い上げて繋いであるのを見つけて、言いようのない恐怖に打たれる。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜、町のそちこちにある自分の行きつけの酒場の一つからひどく酔っぱらって帰って来ると、その猫がなんだか私の前を避けたような気がした。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は猫のいなくなったことを悔むようにさえなり、そのころ行きつけの悪所でそれの代りになる同じ種類の、またいくらか似たような毛並のものがいないかと自分のまわりを捜すようにもなった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生行きつけた家なので勘次は極り惡相に坐つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　好子と二人で、或ひはお客をつれて行きつけてゐる支那料理屋では満員であつた。",
              "citation": {
                "source": "水ぎわの家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも行きつけの踊り場だけに、アトホームな感じがした。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも毎日銀行へ金を取りに行きつけた者に対する口ぶりである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの事件があってから二三日たったある日のこと、僕は夕刊の締切がすんで、大組ができあがってから、社会部長の成田さん（これも仮名）、だかと行きつけの喫茶店へ珈琲をのみに行った。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つなぞが解けたかと思や、また妙ななぞをおかけになりますが、まさかあっしをからかっているんじゃござんすまいね」　しかし、右門は答えずにぷいと表へ出ていくと、行きつけの権十郎床で、何を考え出したものか、しきりと念入りに月代を当たらせました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが行きつけの揚げ屋でござります」　退屈男は躊躇なくあとを追いました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "行つた先は、父のゐた時分から家の行きつけの心安い海水浴の宿屋であつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあどうぞ……」　行きつけのうちと見えて、下へも置かない歓待ぶりです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、彼は行きつけの本屋に寄って、電話を借り、Ｓにかけた。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新井田の方はあと廻わしだ」そう彼はまた独りごちて、狸小路のいきつけの蕎麦屋にはいった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機にのっていかないと、あそこまでいきつけないのではないか」「えっ、飛行機だって。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒロのいきつけの食堂では、世界各地にいる七人の子供たちのうち五人が、今年のクリスマスにはヒロに帰って来る、と女主人はうれしそうに語っていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきつけの食堂の前を、僕はゆっくりと通過した。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何軒ものいきつけの店をめぐっては酒を飲む、という種類の酒飲みでもなかった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
