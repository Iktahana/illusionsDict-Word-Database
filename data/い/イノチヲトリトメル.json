        "examples": {
          "standard": [
            {
              "text": "彼は大事故に遭ったが、奇跡的に命を取り留めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "医師たちの懸命な治療のかいあって、瀕死の重傷だった患者は命を取り留めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "銃で撃たれた主人公が、次のシーンで命を取り留めていたので安心した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "幸なことに、その毒薬が、遮光の着色壜にでなく、普通の硝子壜に長年月の間入れられていて、可なり変質していたため、充分に利かず、彼女は生命を取り留めることが出来た。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは生命を取り留めることができましょう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
