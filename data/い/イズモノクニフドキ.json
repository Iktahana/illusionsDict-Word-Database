    "definitions": [
      {
        "index": 1,
        "gloss": "Izumo Fudoki (description of the culture, climate, etc. of Izumo province; 733 CE)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
