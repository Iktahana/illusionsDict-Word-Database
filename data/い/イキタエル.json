          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "懸命な救急隊員の処置も虚しく、搬送された男性は病院に到着する前に息絶えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深い傷を負ったその狼は、森の奥深くで誰に看取られることもなく静かに息絶えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最後の力を振り絞って犯人の名を告げると、彼は満足げな笑みを浮かべて息絶えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "崩落した建物から救出された幼い命は、懸命の蘇生措置も届かず、間もなく息絶えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "老王は愛する家族に見守られながら、穏やかな眠りにつくように息絶えたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ああ、やっと楽になれる……」と呟くと、病床の老人はそのまま息絶えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "蝉の声もいつかきこえず、部屋のなかに迷い込んで来た虫を、夏の虫かと思って、団扇ではたくと、ちりちりとあわれな鳴声のまま、息絶える。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "両人が息絶える前に、他の者が部屋の中へ入り込み、短刀を抜き去り、警察に通報し、駐屯兵から軍隊式の応急手術を受けた。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤「アー」　という声諸共にパタリと倒れて息絶える。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノドを突こうと、毒薬を飲もうと、私がのたうって息絶えるまで、眉ひとつ動かしもせず、ジッと見つめているのだ。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ私たちが初めて知りあひ、恋らしいものをして、一日会はずにゐると息絶えるやうな幼稚な情熱のなかで暮してゐた頃、私たちは子供ではない、と矢田津世子が吐きすてるやうに云つた。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ私たちが初めて知りあい、恋らしいものをして、一日会わずにいると息絶えるような幼稚な情熱のなかで暮していた頃、私たちは子供ではない、と矢田津世子が吐きすてるように云った。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提樹の明るい枝に病弱な鹿笛の音は息絶える。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪三好達治十一月の夜をこめて　雪はふる　雪はふる黄色なランプの灯の洩れる　私の窗にたづね寄る　雪の子供ら小さな手が玻璃戸を敲く　玻璃戸を敲く　敲く　さうしてそこに息絶える　私は聽く　彼らの歌の　靜謐　靜謐　靜謐",
              "citation": {
                "source": "雪",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十字架の上にイエスが息絶えるまで、御自身の目をおおい耳をふさいでこらえてい給うた父なる神は、いまや潮のごとき愛をイエスにそそぎ始めておられたのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家はこの世のほかの妖美に酔いしれて、女と折り重なって息絶えるであろう。",
              "citation": {
                "source": "「悪霊物語」自作解説",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがもしなくなる時には、空気がもしなくなる時には、われわれは息絶える。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと数十秒のちには、砂浜に自らを叩きつけ、草地を越えて這いあがりつつ息絶える運命だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、目的の人物の首にまいた布が恐ろしい力で収縮し、その人物はもがきながら息絶えるのである。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "…）　嚔　ひとつ　ふいに、　わたしの前にゐた暁ちかい夜が、ぐつたり息絶える。",
              "citation": {
                "source": "雪",
                "author": "高祖保",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
