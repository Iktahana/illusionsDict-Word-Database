          ],
          "literary": [
            {
              "text": "あたたかな砂浜には人が多ぜいいかなごを漁る網を曳いて居た。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "至るところ、てんぐさが干してある、わかめがほしてある、いかなごが干してある。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなご、まて貝、がどう、そんなものを煮て貰ってたべた。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなごにまづ箸おろし母恋し五月十二日　紀州和歌浦、望海楼。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
