        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "瀬戸内海に春の訪れを告げるイカナゴ漁が解禁され、港は早朝から活気に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "神戸の住宅街では、三月になると各家庭からイカナゴのくぎ煮を炊く甘辛い香りが漂ってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「新鮮なイカナゴが手に入ったから、今日は奮発して釜揚げをたくさん作りましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "イカナゴは水温が上昇する夏季、砂の中に潜り込んで「夏眠」という休眠状態に入る珍しい習性を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "成長したイカナゴは地方によって「フルセ」や「カマスゴ」と呼ばれ、素干しや天ぷらにして食される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "近年の記録的な不漁により、イカナゴの稚魚であるシンコの価格はかつての数倍に跳ね上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鮮度の落ちやすいイカナゴを美味しく食べるには、水揚げ直後のものを素早く加工することが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あたたかな砂浜には人が多ぜいいかなごを漁る網を曳いて居た。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "至るところ、てんぐさが干してある、わかめがほしてある、いかなごが干してある。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなご、まて貝、がどう、そんなものを煮て貰ってたべた。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなごにまづ箸おろし母恋し五月十二日　紀州和歌浦、望海楼。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
