    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese sand lance (Ammodytes personatus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
