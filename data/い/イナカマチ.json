    "definitions": [
      {
        "index": 1,
        "gloss": "country town",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末は、静かで空気のきれいな田舎町でのんびり過ごしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この田舎町には、昔ながらの商店がいくつか残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、夏休みは毎年、祖父母の住む田舎町で過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大学進学を機に、この田舎町を離れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "普通の田舎町らしい――漁師町らしい――気分と、温泉町らしい特異の気分とが不調和に混同して、妙に落付きの悪い安価の印象をあたへる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太利のナポリ辺へ行くと、市街の家並が不均斉で、登つたり降りたり、中庭を突つ切つたり、路地から路地へ曲つたりする迷路のやうな市街が多いといふことを聞いてゐるせいか、伊香保の町の裏通りを歩くと、何となく南欧の田舎町といふ感じがする。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のいる温泉地から、少しばかり離れた所に、三つの小さな町があった、いずれも町というよりは、村というほどの小さな部落であったけれども、その中の一つは相当に小ぢんまりした田舎町で、一通りの日常品も売っているし、都会風の飲食店なども少しはあった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所に現実している物は、普通の平凡な田舎町。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日知らん顔をして学校に出ると、狭い田舎町の事とて、新聞の消息欄の中に「有島武郎氏○○館止宿」などゝ出ているのを発見した事などを思い出します。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、りんご園のあいだに教会の立っている小さな田舎町があります。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」第三十一夜「ある小さい田舎町でのことでした」と、月が言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアハアアアハア……」空家の傀儡踊　みんな田の草を取りに行っていたし、留守番の女子供も午睡の真最中であったので、只さえ寂びれた田舎町の全体が空ッポのようにヒッソリしていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今過ぎて来た田舎町の店々に熟れ切つて赤黒く光つて居た柿の実の色が眼に残つて居る。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙間から田舎町の静かな屋並びが覗かれます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に田舎町にしては小ざっぱりとして閑かであった。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風が朝から晩まで吹いて、見るもの聞くもの皆おおいなる田舎町の趣きがある。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "島民の姿の見えないソンソンの夜の通りは、内地の田舎町のような感じだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの年輩の男は普通慣れたことを変えないから、楽しげなフロリダの風土からイングランドの田舎町の侘びしい生活に喜々として転じはしない。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある田舎町からは、一見したところでは何うしても日本人としか思へないやうな朝鮮人が大きな包を持つて乗つた。",
              "citation": {
                "source": "山のホテル",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬吉とおくみとは、北越のある田舎町を故郷に持つて居た。",
              "citation": {
                "source": "海の中にて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ私は西国のある淋しい田舎町にすんでおりました。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、小さな田舎町の事ですから、巡査派出所、町役場等で問い合せた結果、間もなく片山助役の註文に符合する様な葬具屋の無い事が判りました。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "四面山で囲まれた小さな田舎町、その中央にある大きな白壁造、そこに郵便脚夫が配達すると、店に居た男がそれを奥へ持って行く。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雄は雪の深い十五里の山道と雪に埋れた山中の田舎町とを思い遣った。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは其処から一里に近い田舎町の旅舎に昨夜わざ／＼やつて来て宿を取つてゐたのであるが、その出した名刺を見た村長は、俄かに言葉を丁寧にして、紳士の綺麗な顔を恐る／＼見た。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "半は甍で半を板葺きの田舎町が。",
              "citation": {
                "source": "赤い鳥居",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "白壁がをりをり交つてゐたりするジツクザツクした田舎町が。",
              "citation": {
                "source": "赤い鳥居",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついさきまで町の医者の二階のガラス窓に夕日が金属か何かのやうにピカと光つてゐたのであつたが、それも全く消えて、今は半ば※エルのやうな夕靄に包まれたその田舎町が。",
              "citation": {
                "source": "赤い鳥居",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "号外の来るたびに、田舎町の軒には日章旗が立てられ、停車場には万歳が唱えられ、畠の中の藁屋の付近からも、手製の小さい国旗を振って子供の戦争ごっこしているのが見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月にはいってから、にわかに暑さが激しく、田舎町の夜には、縁台を店先に出して、白地の浴衣をくっきりと闇に見せて、団扇をバタバタさせている群れがそこにもここにも見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提樹の下に牛遊ぶ「大いなる田舎町」の趣きも見えぬ。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大きい田舎町めいた、道幅の広い、物静かな、木立の多い、洋風｜擬ひの家屋の離れ／″＼に列んだ――そして甚※大きい建物も見涯のつかぬ大空に圧しつけられてゐる様な、石狩平原の中央の都の光景は、やゝもすると私の目に浮んで来て、優しい伯母かなんぞの様に心を牽引ける。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）の一　通行少き青森街道を、盛岡から北へ五里、北上川に架けた船綱橋といふを渡つて六七町も行くと、若松の並木が途断えて見すぼらしい田舎町に入る。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前、外国人である父の友達が滞在した時、ここの田舎町の家具屋で急拵えにつくつた箱のやうな寝台があつた。",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
