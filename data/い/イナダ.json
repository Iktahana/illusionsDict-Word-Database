[
  {
    "uuid": "920e3f6c-6e2b-5f89-b8e5-2c2d11fb0bc8",
    "entry": "稲田",
    "reading": {
      "primary": "いなだ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "paddy field",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "春になり、水が張られた稲田が鏡のように青空を映している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夕日に照らされて、稲田の穂が黄金色にきらめいていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夜の稲田からは、カエルの大合唱が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "自転車で風を切りながら、どこまでも続く緑の稲田の脇を走った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしある時、ヘルンが案内して連れ出した所は、暗い闇夜の野道の中に、小高い丘があるばかりで、周囲は一面の稲田であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一面、稲田の中で蛙が雨のように鳴いていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "右には未だ青き稲田を距てて白砂青松の中に白堊の高楼｜蜑の塩屋に交じり、その上に一抹の海青く汽船の往復する見ゆ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは薄曇りの風の弱い冬日であったが、高知市の北から東へかけての一面の稲田は短い刈株を残したままに干上がって、しかもまだ御形も芽を出さず、落寞として霜枯れた冬田の上にはうすら寒い微風が少しの弛張もなく流れていた。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北緯四十一度を越えても稲田の黄熟しているのに驚く。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "倶知安の辺まで来るとまた稲田がある。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまで行っても稲田は追っかけて来るのである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十一年一月の「早稲田文学」に現れた、花袋の代表作の一つであろう。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばドイツの「ウェッターロイヒテン」は稲妻と物理的にはほとんど同じ現象であってもそれは決して稲田の闇を走らない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソビエトロシアの映画監督が「日本」のフィルムを撮って露都で公開したとき、猫の額のような稲田の小区画に割拠して働く農夫の仕事を見て観衆がふき出して笑ったという話である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲田桑畑芋畑の連なる景色を見て日本国じゅう鋤鍬の入らない所はないかと思っていると、そこからいくらも離れない所には下草の茂る雑木林があり河畔の荒蕪地がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風にそよぐ稲田、露に浴した芋畑を自然観賞の対象物の中に数えるのが日本人なのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町から東のＯ村まで二里ばかりの、樹蔭一つない稲田の中の田圃道を歩いて行った。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔盆地に白く霧よどみ〕盆地に白く霧よどみ、　　めぐれる山のうら青を、稲田の水は冽くして、　　花はいまだにをさまらぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と家内に一言して、餌桶と網魚籠とを持って、鍔広の大麦藁帽を引冠り、腰に手拭、懐に手帳、素足に薄くなった薩摩下駄、まだ低くならぬ日の光のきらきらする中を、黄金色に輝く稲田を渡る風に吹かれながら、少し熱いとは感じつつも爽かな気分で歩き出した。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙で包んだ花鉢をだいじにぶら下げて車にも乗らず早稲田まで持って行った。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い稲田が一時にぽっと霞んだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、代表的な学校、（帝大、早稲田、慶応、目白女子大学、東京女子医専など）をえらび、毎月連載したいと思います。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅は田畑の真中に在って、三島の町の灯さえ見えず、どちらを見廻しても真暗闇、稲田を撫でる風の音がさやさや聞え、蛙の声も胸にしみて、私は全く途方にくれました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲田もほとんど刈り取らる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば君が住まわれた渋谷の道玄坂の近傍、目黒の行人坂、また君と僕と散歩したことの多い早稲田の鬼子母神あたりの町、新宿、白金……　また武蔵野の味を知るにはその野から富士山、秩父山脈｜国府台等を眺めた考えのみでなく、またその中央に包まれている首府東京をふり顧った考えで眺めねばならぬ。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "西片町にしばらくいて、それから早稲田南町へ移られても自分は相変わらず頻繁に先生を訪問した。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか早稲田の応接間で先生と話をしていたら廊下のほうから粗末な服装をした変な男が酔っぱらったふうでうそうそはいって来て先生の前へすわりこんだと思うと、いきなり大声で何かしら失礼な口調でののしり始めた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨終には間に合わず、わざわざ飛んで来てくれたＫ君の最後のしらせに、人力にゆられて早稲田まで行った。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう同門下の人たちと先生没後の今日、時おり何かの機会で顔を合わせるごとに感じる名状し難いなつかしさの奥には、千駄木や早稲田の先生の家における、昔の愉快な集会の記憶が背景となって隠れているであろう。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "円山｜曰く『どこで修業するつもりだ』、『Ｗ専門学校に行って矢部さんの講義を聞こうとおもう』、『札幌から紹介状でも貰ってきたか』、『来ん』、『じゃ俺が書くからこれから行ってみろ』……辞儀を一つする……貰いものの下駄をはく……歩く（ここは長し）……早稲田という所は田圃の多いところだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀が饑餓という因により、羽翼の羽ばたきという縁によって稲田のところへ飛んで来て、稲穂を啄もうとするのが果であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、今朝もそのままな、野道を挟んだ、飾竹に祭提灯の、稲田ずれに、さらさらちらちらと風に揺れる処で、欣七郎が巻煙草を出すと、燐寸を忘れた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　渠は稲田雪次郎と言う――宿帳の上を更めて名を言った。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……俺みたいなだらしのない意気地なしを、君は二人と知っちゃいまい……美代子さんだって、君があんまり素気なくしてちっとも一緒にいて可愛がってやらないから、それに今迄不仕合せに暮していたもんだから、つい頼りなくなっちまったんだ。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
