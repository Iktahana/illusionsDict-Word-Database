    "definitions": [
      {
        "index": 1,
        "gloss": "Ishihara faction (of the Liberal Democratic Party)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
