[
  {
    "uuid": "ccf4d2b5-d930-5ead-833a-557be948a759",
    "entry": "斎垣",
    "reading": {
      "primary": "いがき",
      "alternatives": [
        "いかき"
      ],
      "is_heteronym": false
    },
    "grammar": {
