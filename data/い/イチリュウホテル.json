        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わあ、さすが一流ホテル！ ベッドの寝心地が家とは全然違うし、アメニティも豪華！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一流ホテルのコンシェルジュに相談したら、入手困難だと思っていた観劇チケットをあっさり用意してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ロビーに足を踏み入れた瞬間、一流ホテル特有の静謐な空気感とアロマの香りに包まれて背筋が伸びた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一流ホテルのディナーなんて緊張しちゃうけど、今日は特別な記念日だし思いっきり楽しもうね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "こうしたニューヨークで一流ホテルの生活が出来たのも、日本のプリマドンナだったからだと、今も当時を思い出して感慨に堪えません。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "『スラヴャンスキイ・バザール』――モスクヴァの一流ホテルの一つ。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェノア、ナポリ、マルセーユなどの一流ホテルに泊って、新航路開発の豪奢な披露宴をやっている。",
              "citation": {
                "source": "悪の花束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、一流ホテルへ移って、新航路開発のレセプションをやった。",
              "citation": {
                "source": "悪の花束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに巴里一流ホテルのパンも、料理屋のパンも第一色が黒く、味も悪く、粗悪だったので、「有名な巴里のパンも中村屋のパンに劣ること数等だ」とうっかり同行の人々の前で口を辷らしたので、大勢の人々から「それ手前味噌が始まった」と笑われた。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上海蔵寺三郎は、外国を二三度廻って、一流ホテルの絶対に臭気の無い、磨き抜いたような便所にも入り、給仕にチップをやる骨も心得、テーブル・スピーチなども、極めて要領よく当らず触らずにこなす呼吸も呑込んで居りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "食魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この部屋には、一流ホテルの名誉心の一つになっている、あのおごそかな静寂が領していた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
