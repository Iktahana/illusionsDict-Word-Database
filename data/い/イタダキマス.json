[
  {
    "uuid": "2e919fb3-c734-5204-9616-6b5c77fbee21",
    "entry": "頂きます",
    "reading": {
      "primary": "いただきます",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thank you (for the meal just served)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「湯気が立っていて美味しそうですね。それでは、頂きます。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-exp"
              }
            },
            {
              "text": "「お言葉に甘えて、手作りのお菓子を頂きます。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-exp"
              }
            },
            {
              "text": "「今日は奮発してステーキを焼いたよ。さあ、みんなで頂きます！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-exp"
              }
            },
            {
              "text": "「お先に頂きます。午後の会議に遅れてしまいそうなので、失礼しますね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-exp"
              }
            },
            {
              "text": "「獲れたての新鮮な海の幸、ありがたく頂きます。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-exp"
              }
            },
            {
              "text": "「冷めないうちに頂きます。いつも美味しい料理をありがとう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-exp"
              }
            }
          ],
          "literary": [
            {
              "text": "（そいじゃ頂きますよ。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　私は思わず箸を置いて、（さあどうぞお構いなく、とんだご雑作を頂きます。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが直に御案内致します、手早く御支度をなすって頂きます。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思えばさばさばして別の事もなく普通の月日に戻り、毎日三時のお茶うけも待遠しいくらい待兼ねて頂きます。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――御深切は頂きます。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――有難う御座います、では差し上げさして頂きます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "では失礼さして頂きます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではわたくしの未熟な考えを其儘申し上げさせて頂きます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方にこうして頂きますより殺されます方がどんなに心安いか分りません。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は下ってますけれど、そんな事に掛けては仙人ですから、食ものに毒も薬もないんですが、実を入れて、……何ですか、お聞き下さるようですから、一段語りましてから御祝儀を頂きますわ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と極附けたまうを鼻ではじき、「ふむ、どうもしやあしねえ、下さるものを頂きますのさ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四五里日帰りにいたしまして、へい、何、そのくらいの事は、あの娘にゃわけなしで、手前どもが朝飯を頂きます時分、もう真鶴を越して、お関所にかかりましたという話。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合　はい、お代のかわりに頂きます。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは構わないで、湯にでも入ったら可かろうと、湯治の客には妙にそぐわない世辞を言うと、言に随いて、ではそうさして頂きます、後生ですわ、と膠もなく引退った。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからプリンス・チャーミングと呼ばせて頂きますわ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だけがお相伴さして頂きます」　私はまたしても、河沿いの家の人事に絡み込まれるのを危く感じたが、それよりも、いまの取り止めない状態に於て、過剰になった心にああいう下町の閉された蔵造りの中の生活内部を覗くことに興味が弾んだ。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで失礼ですが、略式に願って、料理屋のものでご免を頂きます」と叮嚀に一礼した。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見た娘は「私もお手伝いさせて頂きますわ」　と云ったきり、私たちから離れて、すっかり事務所の男達の中に混り、野天風呂も沸せば、応接用の室を片付けて、私たち女二人のための寝室も作った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは呼ばせて頂きます。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが直に御案内致します、手早く御支度をなすつて頂きます。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大きに、お世話、御主人様から頂きます。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へい、……こっちの湯どのは、久しく使わなかったのですが、あの、そう言っては悪うございますけど、しばらくぶりで、お掃除かたがた旦那様に立てましたのでございますから、……あとで頂きますまでも、……あの、まだどなたも。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごめん下さいまし、お札を頂きます。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　や、頂きます、ト、ト、ごぜえやさ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　私は思はず箸を置いて、（さあ何うぞお構ひなく、飛だ御雑作を、頂きます。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に相談相手といってはなし、交番へ届けまして助けて頂きますわけのものではなし、また親類のものでも知己でも、私が話を聞いてくれそうなものには謂いました処で思遣にも何にもなるものじゃあございません、旦那様が聞いて下さいましたので、私は半分だけ、荷を下しましたように存じます。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうおつもりにして頂きます」と言って、最後の盃を伏せてからは、池上がいくら強いても頑固に断って、額や手首にハンカチを運ぶのに忙しいだけでありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝで失礼さして頂きます」　といいました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「卵の雛が孵りましたのです」　と、私たちに告げると、ほく／＼して「ちょっと失礼さして頂きます」と言い捨てさま、風呂敷を布くやら伏せ籠を用意するやらして、抽出しの中の雛子を外に移し出すのを、葛岡も面白がって手伝いまして、どうやら台所の土間の伏籠の中に雛子を納めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、一本だけにしていただきます。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
