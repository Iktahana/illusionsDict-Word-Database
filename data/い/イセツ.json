[
  {
    "uuid": "a54be605-74dd-51b9-817d-8df89c7f9c1d",
    "entry": "異説",
    "reading": {
      "primary": "いせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "different view",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の最期については諸説あり、暗殺されたという異説も根強く囁かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定説を覆すような大胆な異説が発表され、歴史学会に大きな波紋を広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "委員会の決定に対し、一部の専門家からは真っ向から対立する異説が唱えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「それはあくまで異説の一つに過ぎないけれど、検討してみる価値は十分にありそうだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この地名の由来には古くからいくつかの異説が存在し、今なお結論は出ていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "作家の真意を読み解こうとする新進気鋭の研究者による異説が、文学界で注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その主張は、主張としてはそれに対して異説を唱えることも出来ましょうけれども、契沖の見出した古代の事実、すなわち古代の文献においては発音が同じで区別し難い仮名が立派に使い分けてあるという事実は、何人といえども疑うことは出来ないものであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また雷鳴の音響の生因について種々の考えがあげてあるが、この問題については現在でもまだ種々の異説があるくらいである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死因の斷定に對して一人だけ異説をもつものがある。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　醉つ拂つたか、寢込んだか、馬方め、馬鹿にしやがると、異説、紛々たる所へ、提灯片手に息せいて、馬の行つた方から飛び出しながら「皆さん、晝すぎに、見付けの米屋へ來た馬です。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに就いて、こういう異説がまた伝えられている。",
              "citation": {
                "source": "四谷怪談異説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小唄にも（鼓をポント打ちゃ先斗町）とあるよ」　と、乙な異説を持ち出す人もある。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で諸家のコンメンタアルに異説のある難句が、枚挙するに遑あらぬ程である。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっともお説にたいして、わたくしは異説をさしはさむものであります。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし佐橋甚五郎が事に就いて異説を知っている人があるなら、その出典と事蹟の大要とを書いて著者の許に投寄してもらいたい。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "上古の支那の政治の實相は或は墨子の言の如くであつたかも知れぬが、それは暫く保留して置く問題として、夏・殷・周に至つては君主政體が確立してゐるのだから、周制を是とする儒家とは此點に於ても墨家は異説であるに相違無い。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じアシャンチー人の中にも異説ありて最初不死の報を承ったは綿羊だが、途上で道草を食う間に山羊がまず人間に死の命を伝え、それを何事とも知らず無性に嬉しがって御受けした此方人は皆死ぬという由（ベレゴーの『シェー・レー・アシャンチー』一九〇六年板一九八頁）。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "前出ハヌマン猴王の素性について異説あり、羅摩の父ダサラダ子なきを憂い神に牲すると、牲火より神現じ天食を王に授く。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゼムリヤ号事件については原子爆弾説が圧倒的だった中に、水戸君はワーナー先生と同様に、大西洋にゼムリヤ号事件の鍵があると主張して断然異説をたてていた人です」　と、ホーテンスは博士に紹介した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "末盧を肥前の松浦とし、伊都を筑前の怡土とし、奴を儺縣、又那津、不彌國を應神天皇の誕生地たる宇瀰に當つることは本居氏以來、別に有力なる異説もあらざればすべて之に從ふ。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる種類の注には、唐初に顏師古の漢書の注、章懷太子の後漢書の注などがあり、これは三國志の注ほどは異説を集める考へはなく、本文の解釋が主であるが、中には異つた言ひ傳へをも取入れてあつて、後の研究に役立つものもある。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人より異説を立てることを好まないが、いつもそれに従うこともまた常識として赦されない。",
              "citation": {
                "source": "北京と巴里（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはひとり東洋人ばかりでなく、西洋人にとつてもまた大切なことで、これまで幾度かその讀み直しが行はれ、そこから獨逸流の新解釋も生れ、佛蘭西風の見方も起り、トルストイのやうな人の異説ともなつた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴントのような専門の大家に対して異説を立てるのははなはだ恐縮ですが、私のは、こう行かないと説明になりませんから、こうしておきます。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分はなにもわざとつむじ曲りに異説を唱えているわけではなく、昔から度々先人のくりかえしている極めて陣腐な説を自分流儀にくりかえしているだけの話で一向奇抜でも珍奇でもないのだ。",
              "citation": {
                "source": "変なあたま",
                "author": "――最近の心境を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」仏滅の年については今日においても種々の異説がある。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにこれについては種々の異説がある。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥陀の本願はこの仏〔以下欠〕五　社会的生活　浄土真宗における真俗二諦論は異説の多い教義である。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "降つて三世瑞仙直温の時に及んで、始て異説が筆に上せられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに此に一異説がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒医談に楸字の異説がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし児童養育の責任を有する者の何人なるべきかについては、もちろん諸君の中に種々の異説があるであろう。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし此の詩に関しては、嘗て欧陽修が夜半は鐘鳴の時に非ずといふ説を出してから、異説百出、或は之を以て早暁の詩となし、夜半といふは極めて早きことの誇張と解する者あり、或は夜半鐘と云ふのは鐘の名であるとなす者あり、或は蘇州の寺に限り夜半に鐘を鳴らしたのだらうと説く者あり。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その六　――放翁絶句十三首和訳（つけたり、雑詩七首）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「負けまじき」の解釈には思ひの外異説もあるらしい。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一国の人々の思想が悉く統一されたり、何事に就ても異説がないとしたら、社会は如何にして進歩があろうか。",
              "citation": {
                "source": "自由の真髄",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリームの香味にも店によって著しい相違があって、これがなかなかたいせつな味覚的要素であることもいくらかはわかるようである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
