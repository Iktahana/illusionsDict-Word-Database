        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "外に出て冷たい夜風に吹かれた途端、さっきまでの酔いが一遍に覚めてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女の明るい笑顔を見ただけで、残業続きの疲れが一遍に吹き飛んだ気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "社長がすごい剣幕で怒鳴り込んできたことで、和やかだった会議室の空気が一遍に凍りついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
