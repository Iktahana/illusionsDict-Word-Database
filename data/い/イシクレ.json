        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "道の真ん中に小さな石くれが落ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は海岸で珍しい形の石くれを拾い集めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "足元に転がる石くれに躓きそうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭の通路に敷き詰めるため、たくさんの石くれを用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは川原で石くれを水面に投げ、水切りをして遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地震で崩れた壁から、無数の石くれが散乱していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この小さな石くれ一つにも、地球の歴史が刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "名誉も幸福も天の恩恵も凡て目下の小生は路傍の石くれと同一、何らの身を飾るべき宝玉のたしにも為つては呉れない。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八っちゃん十だけ白い石くれない？",
              "citation": {
                "source": "碁石を呑んだ八っちゃん",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉のやうな色をしたその獣の背は、夕日の中を、まつしぐらに、木の根石くれの嫌ひなく、何処までも、走つて行く。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "石くれがごろごろとして、短い草が風になびき、向こうの方には、さびしい丘がつづいていました。",
              "citation": {
                "source": "赤いガラスの宮殿",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹原光る　いなづまのすぢ照り　かげり　はげしくなりて、のぼり来し石くれ道に　霧はひ来たる草かげに石を並べて　あはれさは、幼き仏　あまた立つなり草かげの　無縁仏のあはれなるところをすぎて　つゞく岩原たちまちにおり来　はれゆく夜はの霧。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚の銅貨、時には銀貨、それから石くれ、骸骨、血まみれの死体、あるいは紙入れの中の紙片のように四つにたたまれた幽霊、あるいは何にもないこともある。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "故国のうちに起臥してる間は、その街路も自分に無関係なものであり、その窓も屋根も戸口もつまらぬものであり、その壁も没交渉なものであり、その樹木もありふれたものであり、自分がはいりもしないその家は何の役にも立たないものであり、踏み歩くその舗石は単なる石くれであると、人は思うものである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が足に踏みにじり、炉のうちに投じ、溶解し、沸騰せしむる、あの賤しき石くれも、やがては燦爛たる結晶体となるであろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
