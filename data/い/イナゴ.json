    "definitions": [
      {
        "index": 1,
        "gloss": "rice grasshopper (of genus Oxya)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供の頃、祖母の家に行くと、よく稲子を捕まえて遊んだものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "信州の郷土料理には、稲子のつくだ煮という珍しい一品がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "秋の田んぼ道を歩いていると、足元からたくさんの稲子が飛び跳ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それは毛虫か稲子が頭をちぎられた位にしか感動を受けていない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岐阜県××町、――里見稲子、二十七、と宿帳に控えたが、あえて誌すまでもない、岐阜の病院の里見といえば、家族雇人一同神のごとくに崇拝する、かつて当家の主人が、難病を治した名医、且つ近頃三由屋が、株式で伊勢の津に設立した、銀行の株主であるから。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "理論家窪川鶴次郎は彼女に手を出して手を噛まれた――小説といふ彼女に窪川稲子の嫉妬が小説を書かせるほど彼女は利巧者で、小説家で黒襟をはずしてアッパッパを着る時代性も承知してゐる。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「処女地」に出てゐる河井稲子氏の「夕食」といふのは、ほんの短いものだがつかまへどころに妙味がある。",
              "citation": {
                "source": "海浜日誌",
                "author": "六月創作評",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は当時に至るまでの大衆生活の歴史の一部として自己の過去を見直そうとする意欲も文学の欲望となって、中野重治氏「第一章」「村の家」、窪川稲子氏「鉄屑の中」「一包の駄菓子」、窪川鶴次郎氏「一メンバー」、橋本英吉氏「炭坑」、中條百合子「乳房」、立野信之氏の長篇「流れ」等が現れた。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野重治氏「一つの小さい記録」「小説の書けぬ小説家」窪川稲子氏「くれない」等はかかる情勢の裡にあって、日常生活の様相においてさえも新たな一つの歴史の段階に入らんとしつつある階級人のそれぞれの苦痛の姿を語った。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一冊は最近中央公論社から出版された窪川稲子の初めての長篇小説と云うべき「くれない」である。",
              "citation": {
                "source": "はるかな道",
                "author": "――「くれない」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、窪川稲子さんに会ったら、或る若い勤労婦人のひとで、この小説を読んだ感想に、アグネスがどうしてああいう風に男を反撥してゆかなければならないのか、その点があの小説ではよくのみこめなかったと云ったという話が出た。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔陸前国気仙郡、今の猪川村に稲子沢長者という長者があった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "数多の下女下男があるなかに、稲子沢の寝手間取りとて、年中ごろごろ寝てばかりいて食っている手合いも多かった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "窪川稲子と一緒にそういう場所に出ることが一度ならずあった。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間或る席で、児童文学を専門にしている男のひとが、佐多稲子さんに、子供の本を書きたいと思いませんかと訊いたとき、稲子さんは、さあと云って、そう思わないという意味の答えをしたら、訊ねた人は大変案外そうに、そうかなア、と小首をかしげる表情をした。",
              "citation": {
                "source": "子供のためには",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲子さんは二人の子供たちをもっているし、生活の全面に、いかにも情のふかい人だから、その児童文学をやる人は、そういう稲子さんが子供たちのために書くということを自然に可能と思ったのであったろう。",
              "citation": {
                "source": "子供のためには",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窪川稲子さん、壺井栄さんなどとの互の心持の関係は、友情もひととおりのものでなく、そういうところまで行っているのだと思う。",
              "citation": {
                "source": "なつかしい仲間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄さん、稲子さん、私、三人仲間がもっともっと年をとって、いろんな思いを互に経て、益々その老いて若き仲間ぶりを発揮したら、さぞや愉快なことであろうと思う。",
              "citation": {
                "source": "なつかしい仲間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪をひいて臥ていた稲子さんのわきに坐って、私が一生懸命その心持を話したら、稲子さんは、ふっと笑った顔になって、もし男のカッスルが生きのこる方だったら踊ったかもしれない、と云った。",
              "citation": {
                "source": "表現",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐多稲子、松田解子、平林たい子、藤島まき、壺井栄などがそうである。",
              "citation": {
                "source": "明日咲く花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日作品を書いている佐多稲子、平林たい子、松田解子、壺井栄など。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その四号から、翌年発行が出来なくなるまで、佐多稲子さんが中心になって随分な努力をしたものだった。",
              "citation": {
                "source": "さしえ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐多稲子さんのところに、何年も前からマイヨールの「とげ」という小さい彫像があった。",
              "citation": {
                "source": "さしえ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああここに来ていると思ってながめながら、座布団の上に坐ったとき、わたしは、その彫像の飾りかたに稲子さんの感覚を実につよく感じた。",
              "citation": {
                "source": "さしえ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか佐多稲子が小説を書く人の心がまえとして、意識というと階級意識と限って考えられる傾きがあるけれども、階級についての意識ばかりでなく、生活のうちにふれてくるすべてのことに意識をもたなければならないという味わいの深い言葉を書いているのを読んだことがある。",
              "citation": {
                "source": "文学と生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実感の豊かで、強い内容は、稲子さんが云っているとおり、あらゆる場合めざめている意識をとおしてその人のうちにつみかさねられてゆく。",
              "citation": {
                "source": "文学と生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大会で民主的な文学作品について報告する責任をもった佐多稲子は、小説部会の評価が各作品について全く対立的である場合が多い、評論部会は、民主的文学の評価の基準について検討をするように、と要求した。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（佐多稲子が「わたしたちの文学」で云っているとおり創作の過程、手つづきとしてはそうである）。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐多稲子の作品をかたるとき、批評は生活派らしい座りかたになり、地声となっているが、論点は作者と読者を肯かせるところまで掘り下げられていなかった。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、綺麗ですね……」と、私は花立に※さつたコスモスの花を眺めながら云つたが、何となく何時ものやうな明るいなごんだ氣持にはなれなかつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの子供らがあひるを慣らしているのを見て、今まではいっこうにあひるに対する興味がないか、あるいは追い回す以外の可能性を考えなかった近所の子供たちも、とんぼをつかまえて来たりあき鑵にいっぱいいなごを取ってはあひるに食わせることを覚えて来た。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいなご新姐を抱くと思え。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖女たちは大よろこびで、草の中をかけまはつたり、小さな草の花の中へはいつて顔だけ出してお話をしたり、大きないなごにからかつたりして、おほさわぎをしてあそびました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
