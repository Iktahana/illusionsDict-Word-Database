        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "草むらでピョンと跳ねたのは、大きな稲子だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "壁に緑色の稲子が止まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "虫かごの中では、昨日捕まえた稲子たちが元気に動き回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
