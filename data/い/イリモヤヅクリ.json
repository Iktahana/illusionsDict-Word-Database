          "literary": [
            {
              "text": "法隆寺の建築に入母屋造りの多いこともここに関係がある。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄棟造りの単純明快なのに比べて、この金堂の屋根に複雑異様な感じがあるのは、入母屋造りのせいであるともいえよう。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし入母屋造りがみな同じ印象を与えるというのではない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
