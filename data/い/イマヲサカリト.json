[
  {
    "uuid": "ec3b431c-cf02-5db5-9a20-c24ff28b1342",
    "entry": "今を盛りと",
    "reading": {
      "primary": "いまをさかりと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in full bloom at the moment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "桜の花が、今を盛りと咲き誇り、多くの観光客を魅了していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼のキャリアは今を盛りと、公私ともに充実した日々を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台上の俳優は、今を盛りと輝き、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "屍肉の如く青白き花のみ今を盛りと咲き揃ひ居りしこそ不思議なりしか。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "可成り大なる老木もありて、花は今を盛りと咲き滿ちたり。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "名にし負ふ櫻の馬場、櫻樹數十章、今を盛りと咲きたれども、惜しや、雨に訪ひくる人もなし。",
              "citation": {
                "source": "北總の十六島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路の両側には、門々に今を盛りと樺火が焚いてある。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路の兩側には、門々に今を盛りと樺火が焚いてある。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨三の卓子のうへには彼女がおいて行つた植込みの草花が今を盛りと咲き乱れてゐた。",
              "citation": {
                "source": "質物",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十一　一門の采邑、六十餘州の半を越え、公卿・殿上人三十餘人、諸司衞府を合せて門下郎黨の大官榮職を恣にするもの其の數を知らず、げに平家の世は今を盛りとぞ見えにける。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今を盛りと庭の真中に開いて居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮮やかな色の花々が上段を縁どって生え、その真ん中には、豊満な、珍しいほど大輪の、赤い斑点のある黄ダリヤが、今を盛りと咲き誇っていた。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く春や葛西の男｜鋏刀して躑躅を切りぬ居丈ばかりに　今を盛りと咲き誇つてゐた躑躅も漸く散つて春も暮れようとする一日、一体に大きくなり過ぎてゐたそれらの躑躅の手入れに植木屋を入れた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "社頭から坂の両側に続いて桜が今を盛りと咲き乱れている。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は『あら面白の花や候、今を盛りと見えて候、何とて御当座などをも遊ばされ候はぬぞ』と人々から怪まれる。",
              "citation": {
                "source": "能楽論",
                "author": "野口米次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると花壇に五六本の白牡丹が今を盛りと咲いていた，その花の下に飼猫の「コロ」が朝日を一杯背中に受けて、つくねんとうずくまッていた「日向ぼこりをしているのか、居睡りをしているのか？",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田の面一般に白く、今を盛りと咲き競うは、中稲にて、己に薄黒く色つき、穂の形を成せるは早稲にやあらん、田家の垣には、萩の花の打ち乱れて、人まち顔なるも有り、青｜無花果の、枝も撓わわに生りたる、糸瓜の蔓の日も漏さぬまでに這い広がり、蔭涼しそうなるも有り、車行早きだけ、送迎に忙わし。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミモザと駝鳥の首のような、とぼけた竜舌蘭の花が、今を盛りと咲き乱れるキャンヌの公園では、はや朝から陽気な軍楽隊、エドゥアール七世の銅像の前を、テニス服を着て足早やに行くのは隣りの別荘の英吉利娘。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "謝肉祭の支那服　――地中海避寒地の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木のあいだをいくたびも廻り歩いたのちに、こわれた噴水のほとりに来ると、そのそばにはめざましい灌木があって、美しい花が今を盛りと咲き誇っていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラッパチーニの娘　アウペパンの作から",
                "note": "青空文庫"
              }
            },
            {
              "text": "路地を出でたる表通蕎麦屋の軒に藤の花今を盛りとさき匂ひたり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の群が空低く鳶に追われているその下に、石垣の端近く、羽毛のような葉をした喬木に黄色い小さな花が雨に打たれて今を盛りと咲き誇っているのが、射るように釘抜藤吉の眼に映った。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "年代の経った泉水木立がいかにも由緒あり気で、庭の若草も、今を盛りと茂り合っていた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "灌頂の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人共口を揃へて毒は裏庭に今を盛りと咲いて居る鳥冠の根を味噌汁へ摺り込んだものと分りましたが、誰がそんな事をしたのかとなると、まるで見當も付かないのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人とも口を揃えて毒は裏庭に今を盛りと咲いている鳥兜の根を味噌汁へ摺り込んだものと分りましたが、誰がそんな事をしたのかとなると、まるで見当も付かないのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の日よりも一両日余り過ぎ、満山の紅葉、今を盛りと色づいている頃。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦畑は四方の白雪｜皚々たる雪峰の間に青々と快き光を放ち、その間には光沢ある薄桃色の蕎麦の花が今を盛りと咲き競う、彼方此方に蝴蝶の数々が翩々として花に戯れ空に舞い、雲雀はまた華蔵世界の音楽師は我のみぞと言わぬばかりに謡うて居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい花（小木）が千載の古木と突兀たる岩の間に今を盛りと咲き競うて居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地域に蝟集するバラツク建てのノミ屋とパチンコ屋に、今を盛りと客がはいつている時刻で、それに東京では、新宿に次ぐ多数の乗客を呑吐するといわれる池袋駅で、その眼の先きから出火したのだから、駅前は身動きの出来ぬ雑沓で、悪くすると私など、押し倒されかねまじき形勢である。",
              "citation": {
                "source": "擬似新年",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな門柱から鉄柵が蜿蜒と列なって、その柵の間から見えるゆるやかな斜面の庭には遥かの麓まで一面の緑の芝生の処々に、血のように真赤な躑躅や五月が、今を盛りと咲き誇っています。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "花という花が、しかも、春、夏、秋、冬、どの季節もの花が、いまをさかりと、美しく咲きほこっているのです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花園には、いろいろの花が、いまをさかりと咲いていました。",
              "citation": {
                "source": "月夜とめがね",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "名ばかりの垣根で、育ちのわるい貧弱なマサキがまばらに立っているだけだが、その前の芙蓉が、いまをさかりと咲きほこっているので、花の陰になって、ひとのすがたは見えない。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
