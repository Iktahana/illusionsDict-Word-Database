[
  {
    "uuid": "185f3045-3649-595d-9408-771c964af8c2",
    "entry": "勇み立つ",
    "reading": {
      "primary": "いさみたつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
