      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to cheer up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "決勝の舞台を目前に控え、選手たちの表情からは勇み立つ様子が隠しきれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、やってやるぞ」と、彼は新しい背広に袖を通しながら勇み立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "難プロジェクトの成功という共通の目標に向かって、メンバー一同が勇み立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "獲物を発見した猟犬が、今にも飛び出さんばかりに勇み立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "久しぶりの海外遠征が決まり、応援団は「いよいよ出番だ」と勇み立って準備を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝説の宝の地図を手に入れた冒険者たちは、未知なる世界への期待に勇み立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『やつちまへ』『疊ん仕舞へ』彌次馬の聲援、畢竟は我が味方と、芳は勇み立つて、無手と對手の襟髮を掴むや、馬手の下駄は宙を飛んで、その頬桁を見舞はんとす。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "キイテ　タイソウ　ヨロコンデ「ヨシヨシ　ワタシモ　コノコブヲゼヒトモ　トツテ　モラヒマセウ」　と勇み立つ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大約道の四五里も進んだと思ふ處から山は益々深くなり、路はだん／＼と險阻になつたが、元氣なる武村兵曹は、何んでも日沒までには二十｜里以上を進まねばならぬと勇み立つ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は止みたりや、天は如何にと云へば、弟、雨は猶降れゝど音も無き霧雨となりたり、雲の脚｜断れて天明るくなりたれば、やがて麗はしく晴れん、人々の言葉も必ず空頼めなるまじと勇み立つて云ふ。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "客たちは後から骨身も融けるほど打ち解けさせられた中に人情の機微を学ばせられ、世路に勇み立つ底力を与えられた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのアメリカ・インヂアンの着物を常住服として勇み立つてゐる――。",
              "citation": {
                "source": "喜劇考",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、その話を僕が昨ふ山番に告げたら、手を打つて悦び――そんなら、その袋一杯、わたしが森の土産をつめこんで、吃驚りさせてやりたいものだ――なんて大いに勇み立つて、さうだ、ほんのさつき、これと同じ位ひに大きいランチ袋をかついでから、橇を引いて出かけて行つたよ。",
              "citation": {
                "source": "祝福された星の歌",
                "author": "An episode from the forest",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからお前は誠実を見出したところに勇み立つがいい、恐れることはない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "決戦……と葉子はその勇み立つ心の底で叫んだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地は勇み立つようにしてまた土の上にしゃがみこんだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへこれが今や全国的の流行で踊りとなれば老若の別もないとは云ふものゝ、まさか素面では――とたぢろいて二のあしを踏む者も多かつたが、仮面をかむつて、――といふ智慧がつくと、われもわれもと勇み立つた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と勇み立つてゐた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　信一郎に、説き圧されてゐた三宅は、援兵を得たやうに、勇み立つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し重いけれど、かうして歩けば途中が威張れて安全だといふので、下男は勇み立つて歩き出した。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "東南風が大分吹いて来たから日暮までにうんと獲れるだらう、明日は到底網は下ろして置けないから、向でも今日一日に出来るだけ獲らうと磯二は途々勇み立つて言つた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには勇み立つた遠藤も、さすがに胆をひしがれたのでせう、ちよいとの間は不思議さうに、あたりを見廻してゐましたが、忽ち又勇気をとり直すと、「魔法使め。",
              "citation": {
                "source": "アグニの神",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待てよ」　富士男は勇み立つ三人をとめて、かれ草をあつめてそれに火をともし、洞穴へさしいれた、そうして空気に異状がないのを見て、一同は洞穴のなかへはいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とあつたに、大男は大いに勇み立つて、「如何にも、その流沙河とやらの渡し守になり申さうずる。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "関西では碁が優勢になると「どうぢやどうぢや」と勇み立つ。",
              "citation": {
                "source": "市井閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "関さんの勇み立つこと。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まづ最初にこの子のところへまはつて――」　と、勇み立つこと限りもない。",
              "citation": {
                "source": "探偵の巻",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家の近所と、主人と一しょの時だけは無性に勇み立つ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳よりな話ね、今晩はあたしにも見せてね」と勇み立つ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇み立つ青春の意気も亦た丑松の心に強い刺激を与へた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軒を済ませて畑路伝いに隣へ行けば、もう蚊帳を吊っているのが見えて、ここにも怪我人がいるわいと、勇み立つ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "要領のいい奴らで、戦争を遊山と心得てかりそめにも勇み立つようなところがない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台全面の軍勢、勇み立つ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの若者などは、かえって、いさみたつようにみえました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
