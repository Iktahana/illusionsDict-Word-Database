        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "近年、プラスチックごみが海から陸まで至る所で発見されており、海洋汚染が深刻化しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "IoTデバイスの普及により、私たちの生活空間の至る所にセンサーが配置され、データ収集が行われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域の地質調査では、太古の火山活動の痕跡が至る所で見つかっています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "春になると、公園の至る所に桜の花が咲き誇り、人々を楽しませます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この商店街では、手作りの雑貨や食品を扱う店が至る所にあり、散策するだけで楽しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あれ？このデザイン、街の至る所で見かけるね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「子どもの落書きが、家の壁から近所の公園まで至る所に広がっていて困っています。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "實に私は、至る所にこの「鬼」の形相を見た。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが即ち文化の余裕といふものであり、昔の日本の江戸や、今の仏蘭西の巴里などで、この種の閑人倶楽部が市中の至る所に設備されてるのは、文化が長い伝統によつて、余裕性を多分にもつてる証左である。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "至る所のイルミネーシヨン。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に「思ひ出」の驚くべきはその至る所の頁をあけても芳烈無比な詩的靈魂が高調されてゐる事である。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが道中では至る所さるすべりと蓮の花だつた。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀の大野、根生の濱を歩行いた時は、川口の洲の至る所、蘆一むらさへあれば、行々子の聲が渦を立てた、蜷の居る渚に寄れば、さら／＼と袖ずれの、あしのもとに、幾十羽ともない、くわらくわいち、くわらくわいち、ちよツ、ちよツで。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「恨み重なるチャンチャン坊主」が、至る所の絵草紙店に漫画化されて描かれていた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の名は、餓鬼、天人、妖精等と呼ばれ、我等の身邊に近く住んで、宇宙の至る所に瀰漫してゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に至る所に、人間の生活があるところには、それと同じやうな階級に屬するところの、樣樣の神神の生活がある。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして世間のだれよりもよく、父の實際の敵――戰士であるところの父は、社會の至る所に多くの敵をもつてる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣質のあらゆる方面、趣味の至る所の傾向に、互に矛盾し反對する二つのものが、全然不調和に對立してゐることをＳは明らかに自覺してきた。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中至る所太郎兵衛のうわさばかりしている中に、それを最も痛切に感ぜなくてはならぬ太郎兵衛の家族は、南組堀江橋際の家で、もう丸二年ほど、ほとんど全く世間との交通を絶って暮らしているのである。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は踏みにじられ、軟らかな土の上には、足跡が至る所についていた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "儒の至る所は孔丘なり、墨の至るところは墨其師を售るを務むるの説に生ず、二師の道の本より然るに非ざる也、孔子は必ず墨子を用ゐ、墨子は必ず孔子を用ゐん、相用ゐざれば孔墨たるに足らず、とさへ言つてゐる。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たま／＼古い落葉をかいてゐると、素足の足の裏をさすものが至る所にある。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角後漢以後の交通は餘程頻繁なものであつて、其の時代に於ける支那の鏡鑑は至る所の古墳に發見せられ、而して支那に於いても各時期に亙る所の形式を、我が古墳出土の鏡鑑に於いて殆んど悉く具備してをると云うてよい位である。",
              "citation": {
                "source": "日本上古の状態",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスラエル教の大行者、島原神父のご神殿は、この天が下、人あるところ、至る所にござるぞよとな。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通例無秩序の状態を名づけるのにギリシア語のカオス（Chaos）を用いるが、これは元来物質の至る所均等な分布を意味する。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "『すべての出来事並びにすべての物の形の変転を支配する自然界の法則と規則は常にかつ至る所同一である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "海は初め全地球を覆っていたから今日至る所で古昔の貝殻が発見される。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "星雲内は至る所非常に寒冷であるので滴粒の表面には星雲ガス特に炭水化合物や酸化炭素の一部が凝縮する、そうして滴粒が互いに衝突するとそれが膠着してしまう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、ある我らの地球と同様に表面が固結した天体があって、その雰囲気の高さが甚だ高く、もはやその中での重力を至る所同大と見なすことができないような場合である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、こういう過程は幾度となく繰り返され得るわけで、かくして『永遠な時を通じ、あらゆる空間を通じて至る所にこの驚異が行われるであろう』と信じていた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "生物が輻射圧の助けを借りて一つの遊星からずっと遠方に隔絶した他の太陽系中の一つの遊星に移るということが可能であるためには、太陽系の境界以外の宇宙空間が至る所低温であり、そのために生命の機能が著しく低下し、そうしてそのために幾百万年の間生命が保存されるということが必要条件である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の東京市、ことに場末の東京市には、至る所に此種の家が散点してゐる、のみならず、梅雨に入つた蚤の如く、日毎に、格外の増加律を以て殖えつゝある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "至る所の港から私に絵葉書をよこした。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「極暑九十七度九分、山々に未だ雪あるに呆れ候、一昨夕、稀なる夕映、望遠鏡にて西山一帯を眺めいたるところ、駒ヶ岳の絶巓、地蔵の頭、間の岳、農鳥の絶頂なる、各三角測量標を、歴々と発見いたし候」（七月十八日）、この時の感じは、何だか自分が観て、Ｎ君に知らせているような気がした。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、瞳にもみえざる、このかすかな卵のかたちは楕円形にして、それがいたるところに押しあひへしあひ、空気中いつぱいにひろがり、ふくらみきつたごむまりのやうに固くなつてゐるのだ、よくよく指のさきでつついてみたまへ、春といふものの実体がおよそこのへんにある。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたるところで小鳥らの囀りがする。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その岩が雨に洗い出されて山のいただきには奇巌がいたるところに露出している。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
