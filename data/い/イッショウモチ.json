          "literary": [
            {
              "text": "余計な者連れて来やがって、一升餅損したぞ。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歳祝に行ったって一升餅持って帰れめえし、それより後のチャセゴの来ねえうちに早く寝た方がいい。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升餅くらいで、一里からの雪路、吉田様まで、誰が行くものか。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
