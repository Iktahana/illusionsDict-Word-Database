        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一歳の誕生日を迎えた息子が、一生餅を背負って必死にハイハイする姿に、家族全員で声援を送った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわあ、重たい一升餅を背負わされて泣きべそをかく孫を見て、おじいちゃんは目を細めて笑っていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「食べ物に困らないようにとの願いを込めて、伝統に則り一升餅でお祝いをすることにした。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "余計な者連れて来やがって、一升餅損したぞ。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歳祝に行ったって一升餅持って帰れめえし、それより後のチャセゴの来ねえうちに早く寝た方がいい。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升餅くらいで、一里からの雪路、吉田様まで、誰が行くものか。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
