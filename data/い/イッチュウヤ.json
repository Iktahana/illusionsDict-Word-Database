[
  {
    "uuid": "4695b18d-a0b4-58ff-9357-04a02e71e83e",
    "entry": "一昼夜",
    "reading": {
      "primary": "いっちゅうや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
