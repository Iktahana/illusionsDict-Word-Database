    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rice plant (Oryza sativa)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台風が近づいているので、倒伏しないか心配そうに稲の様子を見守る農家の姿があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、風に吹かれて稲の穂が波打つ景色、本当にきれいだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "収穫を間近に控えた稲が黄金色に輝き、重そうに頭を垂れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今年は日照時間が十分だったので、稲の生育は例年になく順調だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしある時、ヘルンが案内して連れ出した所は、暗い闇夜の野道の中に、小高い丘があるばかりで、周囲は一面の稲田であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一面、稲田の中で蛙が雨のように鳴いていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お稲荷さまを拝んでしまったあとの空虚を知らない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲がもうだいぶ高くなつて、路にそつてる箇所はズツとホコリで殆んど黒くなつてるのが、熱い上に熱くした。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲荷を祭つた小さい山の、赤い数々の鳥居が何がなし気になつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三囲の稲荷堤上より拝し、腹まだ治まらねば団子かじる気もなく、ようやく百花園への道札見付けて堤を右へ下り、小溝に沿うてまがりくねりの道を行く半町ばかり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右には未だ青き稲田を距てて白砂青松の中に白堊の高楼｜蜑の塩屋に交じり、その上に一抹の海青く汽船の往復する見ゆ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは薄曇りの風の弱い冬日であったが、高知市の北から東へかけての一面の稲田は短い刈株を残したままに干上がって、しかもまだ御形も芽を出さず、落寞として霜枯れた冬田の上にはうすら寒い微風が少しの弛張もなく流れていた。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこちに稲を刈っている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか要太郎が見えなくなったと思うていると遥か向うの稲村の影から招いている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の上で稲を扱いている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "須崎のある人から稲荷新地の醜業婦へ手紙を託されたとか云って、それを出して見せびらかしている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生涯の出来事や光景が、稲妻のように一時に脳裏に閃いたと思うとそれは消えて、身を囲る闇は深さも奥行も知れぬ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒込の富士から神田明神、深川八幡の境内、鉄砲洲の稲荷、目黒｜行人坂などが、その主なる場所であった、がそれも、今ではお伽噺になってしまった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの山の裾へひろがるところの、違い棚のように段を作っている水田からは、稲の青葉を振り分けて、田から田へと落ちる水が、折からの旱天にも滅げず、満々たる豊かさをひびかせて、富士の裾野のいかにも水々しい若さを鮮やかに印象している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "室へ戻って、友人にハガキを書いていると、富士の雲が引いて取ったように幕を明け、銀磨きの万年雪が、巨獣の斑紋のように二筋三筋キラリと光って、夏の富士にして始めて見るところの、威嚇的な紫色が、抜打に稲妻でもひらめかしそうに、うつぼつと眉に迫って来る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は稲扱きの小閑を盗んで村民運動会である。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日からまた稲扱きに寸暇もない。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲の正当な発育には一定量の日照並びに気温の積分的作用が必要であって、これが不足すれば必ず凶作が来る。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の方へ下りる坂脇の稲荷の鳥居も、柱が立って桁が落ち砕けていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい稲の香がする。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲の花の匂いがする。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒るときは、山腹にかみなり稲妻を起し満山は暗くなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとでも自分にだらしがないところが眼につくと、自分で不安なのだ」「何だか知らないが、欲しいものがあったら、遠慮なくいくらでもそうお云いよ」　初午の日には稲荷鮨など取寄せて、母子のような寛ぎ方で食べたりした。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が何やら判らないで、一度稲妻のように掠れ合った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手の渚には、波がやさしい稲妻のやうに燃えて寄せ、右手の崖には、いちめん銀や貝殻でこさえたやうなすすきの穂がゆれたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲光が二｜度ばかり、かすかに白くひらめきました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北上川沿岸の平野には稲が一面に実って、もう刈入れるばかりになっているように見える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜仙台の新聞で欠食児童何百という表題の記事を見て来たばかりの眼には、この目前見渡す限りの稲の秋は甚だそぐわない嘘のような眺めであった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北緯四十一度を越えても稲田の黄熟しているのに驚く。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
