    "definitions": [
      {
        "index": 1,
        "gloss": "to recover consciousness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
