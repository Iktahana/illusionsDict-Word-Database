          ],
          "literary": [
            {
              "text": "いつになったら意識が戻るのか、それまでは、そして一対の目が物に怯えて空虚を見つめる時のくるまでは、人間の心は故郷を失ったのである。",
              "citation": {
                "source": "レンズとフィルム",
                "author": "――それも一つの性格である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになったら意識が戻るのか、それまでは、そして一対の目が物におびえて空虚を見つめる時のくるまでは、人間のこころは故郷を失ったのである。",
              "citation": {
                "source": "物理的集団的性格",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "意識が戻るまで、近くにいなければなりません。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
