          ],
          "literary": [
            {
              "text": "武家で手にあまる道楽者などがあると、戸障子を釘づけにした暗いひと間をあらかじめ作っておいて、親類一同が立会いで本人に一間住居を言い渡す。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "次は何の誰……」　裁判長がそう判決を言い渡すと、僕等のうしろに立っていた巡査の一人が、さあ行こうと言って一緒にそとへ連れて出た。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "事前に方針を明かすことで抵抗の芽が頭をもたげることを恐れた大内は、機構改革の方針を支配人の渡辺和也にも伏せ、この一件に関しては発表の直前になって言い渡す形をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "意外や、衣子がキリキリとマナジリを決し絶縁を言い渡す。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日、社告を言い渡す。",
              "citation": {
                "source": "カストリ社事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い渡すべき件があるから、この召喚状持参の上、自身出頭のこととある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくすることによって裁判官は欺かれて、離婚を言い渡す。",
              "citation": {
                "source": "嘘の効用",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お裁きを言い渡すのが先、相談はあと。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司は調べた後その人に「あなたは汚れている」と言い渡す。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、即ち君、これは学生の義務というものじゃからね、などと言い渡すのだった。",
              "citation": {
                "source": "勉強記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おのおの太刀は背中に背負え」　陶山義高は、言い渡す。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごちそうがけっして食後の卓上演説を必要とするほどりっぱなものではなかったのはもちろんであるが、わたしは食事がすんだところで、いまがちょうど仲間の者に二言三言いいわたす機会だと感じた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、そのことを、いいわたすために、わざわざ、もどってきたのだ。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "風来の魯智深とやらには、試みにまず、その菜園目付役でもやらせて御覧じあっては」「むむ、衆意同案とあれば」　一山の断により、さっそく首座（僧職）がその旨を、智深にいいわたす。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
