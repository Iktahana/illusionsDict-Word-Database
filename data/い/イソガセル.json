[
  {
    "uuid": "a5534189-73f1-5ca3-a4d2-8a849aa38c41",
    "entry": "急がせる",
    "reading": {
      "primary": "いそがせる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
