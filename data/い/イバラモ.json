        "examples": {
          "standard": [
            {
              "text": "この池には絶滅が危惧される茨藻が自生している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "メダカの産卵床として、水槽に茨藻を入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "水質浄化のため、休耕田に茨藻を繁茂させる試みが行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "山の樹木も、いばらも、笹も、人間と全く無関係に生きてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くつはカレンを、いばらも切株の上も、かまわず引っぱりまわしましたので、カレンはからだや手足をひっかかれて、血を出してしまいました。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、王子は、森にむかってずんずん進んでいきますと、大きな木も低い木も、草やぶもいばらも、みんな道をよけて通しました。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
