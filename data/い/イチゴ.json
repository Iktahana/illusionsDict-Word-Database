[
  {
    "uuid": "51d37c91-b316-5725-bf5a-46ef284438d3",
    "entry": "一期",
    "reading": {
      "primary": "いちご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
