    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's whole life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "修行僧として一期を全うし、多くの弟子に見守られながら静かにこの世を去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一期の末に、ようやく真理の片鱗に触れられた気がする」と、老僧は感慨深げに呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一期の計を若いうちに立てることは、悔いのない人生を歩むための第一歩である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は一期をかけて、この山村に伝わる古い民俗行事の調査と記録に没頭した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これが一期の別れになるかもしれぬが、どうか息災で」と、老人は遠くへ旅立つ友の肩を叩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつて一期の栄華を極めた権力者も、晩年は人里離れた庵で静かな余生を送ったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "富も名声も、長い歴史の流れから見れば一期の夢のごとく儚いものに過ぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "奈良朝以前を第一期とし、平安朝から室町時代までを第二期とし、江戸時代から現代までを第三期とする。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　第一期の音韻　第一期は奈良朝を下限とする各時代である。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良朝にいたって、はじめてかような資料が比較的豊富に得られるのであるから、第一期の音韻を研究しようとするには、どうしても先ず奈良朝のものについてその時代の音韻組織を明らかにし、これを基礎として、それ以前の時代に溯るのほかないのである。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五）「うめ（梅）」「うま（馬）」「うまる（生）」「うばら（薔薇）」のようなマ音の前の「う」は、第一期においてはｕ音であったと思われるが、平安朝に入ってから、次のマ行音またはバ行音の子音（ｍｂ）に化せられてｍ音になった（仮名では「む」と書かれた）。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　連音上の法則の変遷（一）　第一期においては語頭音として用いられなかったラ行音および濁音は、多くの漢語の国語化または音変化の結果、語頭にも用いられるようになった。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一期は所謂新體詩時代であつて、その完成者は島崎藤村氏等である。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから芥川氏の現在を見て誰しも気附くに違ひない事は、その創作集「羅生門」「傀儡子」時代に一期を畫して完成された芸術的境地に、云ひ換へれば、何時か其処に生じて来た作風の型に自ら飽き足りなくなつたらしい氏は、その境地を踏み出さう、その型を突き破らうとして、明に未に苦しみ続けてゐる事である。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等みな生物の形をとって、この一期の戦いに味方となって呉れ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしら彫金師は、一たがね一期です。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　義作は掌でべたべたと顔を撫でて、「串戯じゃあがあせん、私ゃ一期で、ダーだと思ったね、地ん中へ顔を埋めてお前さん、ずるずると引摺られたから、ぐらぐらと来て気が遠くなったんで。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは、きみの口から聞かしてくれた……無論私も知っている……運八のために、その一期の無念の時、白い幽霊に暖められながら、雪を掴んで鶏の目を彫込んで、暁に息が凍った。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まことや泰助が一期の失策、平常のごとく化粧して頬の三日月は塗抹居たれど、極暑の時節なりければ、絵具汗のために流れ落ちて、創の露れしに心着かず、大事の前に運悪くも悪人の眼に止まりたるなり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秋は夜とも分かず晝とも知らず朧夜に迷出でて、あはれ十九を一期として、同國浦崎と云ふ所の入江の闇に身を沈めて、蘆の刈根のうたかたに、其の黒髮を散らしたのである。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これは一期じゃ、何としょう。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生はすべて一期一会のこころだ。",
              "citation": {
                "source": "鉄鉢と魚籃と",
                "author": "――其中日記から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは第一期のことだったが、この世界もようやく活気づこうとする秋のある日のことで、彼女はその日も仲通りの銭湯から帰って、つかつかと家の前まで来ると、電話があったらしく、マダムの常子が応対していた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが、この世に生れる前と、生れてからとで経験しました、第一期、第二期の生活では、それが教えられずにしまいました。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等を鼈四郎は、病友が一期の名残りと思えばこそ奔走しても望みを叶えさしてやるのだが、病友はこれ等を娯しみ終りまだ薬の気が切れずに上機嫌の続く場合に、鼈四郎を遊び相手に労すのにはさすがの鼈四郎も、病友が憎くなった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の物笑い、一期の不覚。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老眼に涙を浮べて、御尤の御仰と承わりました、然らば某も一期の御奉公、いさぎよく御先を駈け申そう、と皺腕をとりしぼって部署に就く事に決した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは是れ一期の大事到来と、千丈の絶壁に足を爪立て、万仞の深き淵に臨んだ思がしたろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "憐れむべし剛勇みづから恃める相馬小次郎将門も、こゝに至つて時節到来して、一期三十八歳、一燈｜忽ち滅えて五彩皆空しといふことになつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども世俗の見解には堕ちぬ心の明鏡に照らして彼れ此れ共に愛し、表面の美醜に露｜泥まれざる上人の却つて何れをとも昨日までは択びかねられしが、思ひつかるゝことのありてか今日はわざ／＼二人を招び出されて一室に待たせ置かれしが、今しも静顫へて一心に唯上人の一言を一期の大事と待つ笑止さ。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人間ノ浮生ナル相ヲツラツラ觀ズルニ、オホヨソハカナキモノハ、コノ世ノ始中終マボロシノゴトクナル一期ナリ、――てれくさくて讀まれるものか。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、五年まえに、半狂乱の一期間を持ったことがある。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に於ける第一期社會主義運動は不思議にも日露戰爭と密接な關係を以て終始した。",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて第一期社會主義運動は衰頽の氣運と共に明治三十九年を迎へた。",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女等がかざしの玉の赤玉に似たるいちごを採りつゝありく奧山の道のへに咲く草花をうらめづらしみ見せまくもとなおぼつかなき歌なり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はそこで木いちごの実をとってわき水につけたり、空を向いてかわるがわる山鳩の鳴くまねをしたりしました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い夕かげが流れて、そこらの垣根の木いちごの花だけが白くういている道を、腹いっぱいたべた牛と、日ごろのご恩をかえしたつもりの和太郎さんが、ともに満足をおぼえながらのろのろといきました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
