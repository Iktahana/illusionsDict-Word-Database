          "literary": [
            {
              "text": "ねずみのしっぽを引き延ばしてひけば一弦琴になり、今まいた豆のつるをよじて天に登ることもできる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "使女Ｂ　白い駒に乗り、水浅黄の袍を着け、銅の楯と象牙の笛と、猫目石で象眼した一弦琴を持った二十五、六の音楽家は何んと美しい方ではござりませぬか。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
