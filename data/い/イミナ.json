    "definitions": [
      {
        "index": 1,
        "gloss": "real name (of a deceased person or a noble)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この祭には諱忌のあるものは配偶さえ戸外へ避けしめる例であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「諱三路の×さアん、いらっしゃいますか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来訪の諱五路の骨董屋と、母が話相手をしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちは当局の忌諱に触れるような映画も憚りなく作って、そして会員ばかりでこっそりと見て娯しむことが出来ます。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々の諱は汝の附くるに任せる。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文皇帝｜諱は允※、太祖高皇帝の嫡孫なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈何せん寒微より起りて、智浅く徳｜寡し、といえるは、謙遜の態度を取り、反求の工夫に切に、諱まず飾らざる、誠に美とすべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "信曰く、殿下｜爾したもう無かれ、まことに事あらば当に臣に告げたもうべし、殿下もし情を以て臣に語りたまわずば、上命あり、当に執われに就きたもうべし、如し意あらば臣に諱みたもう勿れと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "巍至誠至心、直語して諱まず、尊厳を冒涜す、死を賜うも悔無し、願わくは大王今に於て再思したまえ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝孺の集は、其人天子の悪むところ、一世の諱むところとなりしを以て、当時絶滅に帰し、歿後六十年にして臨海の趙洪が梓に附せしより、復漸く世に伝わるを得たり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝の諱は允絶えて又｜如何ともする能わず、仲の兄｜馳還ってに至り、光固汝頴の諸州に托鉢修行し、三歳の間は草鞋竹笠、憂き雲水の身を過したまえりという。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝勇武を負い、毎戦｜危きを冒す、楡木川の崩、蓋し明史諱みて書せざるある也。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは奥州鎮護の大任を全うするに付けては剛勇の武士を手下に備えなければならぬ、就ては秀吉に対して嘗て敵対行為を取って其｜忌諱に触れたために今に何の大名にも召抱えられること無くて居る浪人共をも宥免あって、自分の旗の下に置くことを許容されたい、というのであった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "西のの諺、痛刻ならざるにあらず、たゞ其の狠毒の極汚穢を諱まざるを病む。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも間接に山城河岸の父子をして忌諱を知らしむる媒となったであろう。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼名勝千代、天文五年十六歳で将軍足利義晴より諱字を賜り、晴信と称した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ忌諱に触れていた連中は、捕えられた。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "会沢伯民は、諱は安、通称正志斎とも言はれた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海石は仙人だ」　それは山と石の字を合わすと岩の字になるが、それは呂仙の諱であった。",
              "citation": {
                "source": "劉海石",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば最後に彼は「これをもて我れ自ら恨み（自己を諱み嫌い）、塵と灰との中にて悔ゆ」と悔改の涙を出すに至ったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は孔、諱は丘、字は仲尼。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『扶桑列女伝』に、名妓八千代、諱は尊子、勝山、諱は張子など記しあるも、遊女の本名を洩らすと、彼はわが妻になる約束ある者など言い掛くる者が出るから、尊者の忌名と等しく隠した故、諱と書いたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那では天子の諱を隠す余り、どう読むか判らぬ新字を拵えたさえある（一八九五年板、コックスの『民俗学入門』五章。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "予の寡聞を以てしても、甲教師は超人哲学の紹介を試みたが為に、文部当局の忌諱に触れたとか聞いた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "艶書、バイオリン弾奏、文学書閲読、遊廓散歩等の悪事を発いて制裁を加へる一味の不良正義党が学生間に自づと組織されて、彼はその党の一員だつたが、彼等のその他の生活は悉く当局の忌諱に触れることばかりで、その方面では彼は煽動的張本人であつた。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、かつて『平民新聞』に記載したクロポトキン翁の「青年に訴う」というのが政府の忌諱にふれたので、先月の末に東京地方裁判所で、秩序壊乱の廉とかによって軽禁錮一カ月半の宣告を下されたのであります。",
              "citation": {
                "source": "お別れ",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川達三の小説が軍事的な意味から忌諱に触れたのもこの年の始めであった。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、私がそんなことを考えているすぐ隣の部屋で夕飯のしたくをしているみな子の物音を聞くと、絶対に、たといみな子が人殺しをしてもそんなことはできぬという気がしたのであった。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "きたないみなり、粗末な食べ物。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "申すまでもなく因縁とは、「因縁生起」ということで、世間のこといっさいみなことごとく因縁の和合によって生じ起るということである。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
