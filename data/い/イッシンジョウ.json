    },
    "definitions": [
      {
        "index": 1,
        "gloss": "personal (affairs, reasons, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "一身上の都合により、本日の会議は欠席させていただきます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は一身上の事情で、急遽実家に戻ることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "役員会では、一身上の問題に関する議論がなされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "部内の世話は勿論、部員学生の一身上の心配までした。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋だったかしら、なんでも青井の家に小作争議が起ったりしていろいろのごたごたが青井の一身上に振りかかったらしいけれど、そのときも彼は薬品の自殺を企て三日も昏睡し続けたことさえあったのだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、やがて冷い渋茶を一パイ飲むと、やはり持って生れた吶弁で、「こんな事は今度の事件と全然、関係の無い、私の一身上のお話ですが……」　と恐縮しいしい自分が谷郷村に赴任した理由を詳しく話し出した。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、女の本能の無意識な自衛的手段でしょうなあ」「ははあ、そして、それは、何年前位から始めなさった」　場所柄にしては、あんまり素朴に一身上の事実を根問い葉問いされるものと、かの女はちょっと息を詰めて口を結んだが、ふだん質問する人達には誰へも正直に云っている通りに云った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども将軍家の御一身上に於いては、御難儀、御心痛の事もそれは少からずございましたでせうが、それと同時に、このとしあたりが最も張り合ひのございました時代のやうに見受けられぬ事もないわけではございませんでした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の一身上に於いても、いついかなる事が起るか予測出来ない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は、へんなところで自分の一身上の鬱憤をはらした。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は僧の一身上に関することで、自分に係合いはないのであるが、後者は自分にも何かの係合いがあるらしい。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな朝野の名士連は、皆、法螺丸に一身上の秘密や弱点を握られているか又は、彼等自身が法螺丸の巧妙、精密を極めた話術に魅せられて、法螺丸にそれだけの実力があるものと信じさせられているのだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし君の一身上に就いては、将来共に及ばずながら力になって上げるから、あまり力を落さない方がいいだろう。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度もよくは分らなかつたが、とにかく一身上の事で是非お願ひしたい事があつて京都からやつて來た、といふ事だけは分つた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "青年僧と叡山の老爺",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の一身上の事に就いてだがの」　纔にかく言ひしのみにて、彼は又｜遅ひぬ、その髯は虻に苦しむ馬の尾のやうに揮はれつつ、「いよいよお前も今年の卒業だつたの」　貫一は遽に敬はるる心地して自と膝を正せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれがほかの新聞であったら、倉地の一身上の危機でもあるのだから、葉子はどんな秘密な運動をしても、この上の記事の発表はもみ消さなければならないと胸を定めたに相違なかったけれども、田川夫人が悪意をこめてさせている仕事だとして見ると、どの道書かずにはおくまいと思われた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、私の一身上から言つても、半ば以上を旅に費したりして、しみじみ筆硯に親しんでゐる暇がなかつた。",
              "citation": {
                "source": "心の階段",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度もよくは分らなかったが、とにかく一身上の事で是非お願いしたい事があって京都からやって来た、という事だけは分った。",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて二葉亭の一身上の或る重要な問題について坪内博士と談合した時、二葉亭の心の中は多分こうであろうと推断して博士に話した。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その他に一身上の咄は何もしなかったかい？",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女が一身上の不安を感じたり、とんでもない虚栄心を起して、事実無根の事を喋舌りまわったりするのが、いつも月経前の二、三日の間に限られている理由もやっとわかりました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその時、ただ、一身上の都合で立候補を断念すると簡単に声明しただけだったが、それには私だけしか知らない奇妙な事情が伏在していたのだ。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして誰が何ときいても、ただ一身上の都合一点張りで押しとおしてしまった。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一身上のことは努めて隠蔽する癖のある、長広幸人について、私はこれだけしか知らないのである。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにね、僕は一身上のことで、是非とも君に相談になつて貰ひたい話があるんだが、諾いて呉れる？",
              "citation": {
                "source": "露路の友",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論降りる――と雪子は答へる――それで吾々の一身上に就いての相談は何も彼も頓挫してしまふのが常例なんだよ。",
              "citation": {
                "source": "ダイアナの馬",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は順吉の一身上のことをそう簡單には考へなかつたのである。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石は、だが一身上の必要から、やっぱりいやな大学にも出かけなければならず、そのいやな大学の講義に当時の胸中の懊悩をきわめて意力的にたたきこんで、彼の最大不機嫌中に卓抜な英文学史と文学評論とを生み出した。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日御仲人様がおいでになりまして、私の手紙に対するあなたの御返事を承わり、且つ、あなたの御一身上の秘密を伝えききましたとき、嬉しいというよりも、むしろびっくりしてしまいました。",
              "citation": {
                "source": "秘密の相似",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木の許へ捨吉が齎して行った一身上の報告は田辺のお婆さんをも悦ばせた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "此何分宜しく頼むの頼むは本当の意味の頼むか、又は単に辞令上の頼むか不明だけれども、平岡の一身上に急劇な変化のあつたのは争ふべからざる事実である。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の勢で変な議論をしたものだから、肝心の一身上の話はまだ少しも発展せずにゐる。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
