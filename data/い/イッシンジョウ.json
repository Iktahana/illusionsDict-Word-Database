[
  {
    "uuid": "4e5e6089-c181-521a-baf3-efc3858bbad5",
    "entry": "一身上",
    "reading": {
      "primary": "いっしんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞"
      ],
