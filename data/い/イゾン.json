[
  {
    "uuid": "e003553d-5d4d-5301-aeb9-66407102181c",
    "entry": "異存",
    "reading": {
      "primary": "いぞん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
