        "examples": {
          "standard": [
            {
              "text": "店舗のリニューアル工事を行うため、三月十日から一週間ほど一時休業いたします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「駅前のカフェ、店主の体調不良でしばらく一時休業するみたいだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "記録的な大雪に見舞われ、市内の主要な商業施設は軒並み一時休業に追い込まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "機器の重大な故障が判明したため、安全確認ができるまでアトラクションの運営を一時休業する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいにく、本日は社内研修のため全支店において一時休業とさせていただいております」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世界的な半導体不足の影響を受け、自動車メーカー各社は国内工場の一時休業を決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ようやく改装が終わって、来週から一時休業が明けるんだってね。楽しみだわ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
