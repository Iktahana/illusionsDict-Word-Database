[
  {
    "uuid": "fe03c2cf-03a3-5aa4-a5f5-b3e2d9c60ce7",
    "entry": "一如",
    "reading": {
      "primary": "いちにょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
