        "examples": {
          "standard": [
            {
              "text": "イズベスチヤ紙は、政府高官の談話として、次期国防予算の大幅な増額を報じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旧ソ連時代、政府機関紙であったイズベスチヤは、共産党機関紙のプラウダと並ぶ二大紙として君臨していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「昔はよく、プラウダには真実がなく、イズベスチヤにはニュースがないなんて皮肉を言ったものだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "外交官たちは、イズベスチヤに掲載された短い論評から、ソ連の対外政策の微妙な変化を察知しようと腐心した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "イズベスチヤの電子版を確認すると、大統領令の施行に関する詳細な解説記事がトップページを飾っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ロシア情勢の専門家は、イズベスチヤが報じた停戦条件の内容について「極めて慎重な観測気球ではないか」と分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
