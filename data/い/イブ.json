    "definitions": [
      {
        "index": 1,
        "gloss": "eve (esp. Christmas Eve)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "クリスマスイブには、家族みんなでご馳走を食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大晦日のイブは、静かに家で過ごすことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "明日は大切なプレゼンがあるから、そのイブの今日は早く寝よう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イブの夜、街はイルミネーションで輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで例へば謂ふ所の問題劇を書いたイブセンだつて、自身も云つた通り慥かに「人生のために書いたのではない」のであつて、偶々人生で問題になり勝な素材を用ゐたに過ぎぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどことなくイブセンの描いたのに似たような強い女も出て来た。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかめしい城郭のようなライブラリーも柔らかで憂鬱な霧の薄絹に包まれている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかへって見ると、車室の中の旅人たちは、みなまっすぐにきもののひだを垂れ、黒いバイブルを胸にあてたり、水晶の珠数をかけたり、どの人もつつましく指を組み合せて、そっちに祈ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者のＭ君は積分的効果を狙って着実なる戦法をとっているらしく、フランス文学のＮ君はエスプリとエランの恍惚境を望んでドライブしているらしく、Ｍ夫人の球はその近代的闊達と明朗をもってしてもやはりどこか女性らしいやさしさたおやかさをもっているように見えた。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドストエフスキー、セルバンテス、ホーマー、ストリンドベルヒ、ゴットフリード・ケラー＊、こんな名前が好きな方の側に、ゾラやイブセンなどが好かない方の側に挙げられている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下に挙げてある頁数は、エヴェリーマンス・ライブラリーの中のこの書物の頁数である。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで大勢のギリシア学者が寄合い討論をして翻訳をした、その結果が「ロイブ古典叢書」の一冊として出版され我邦にも輸入されている。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "イブセンのような細工もありません。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれを危険だとして公にしないとすれば、トルストイでもイブセンでも、マアテルリンク、ホフマンスタアルでも、現代的思想の作というものに、一つとして翻訳して好いのは無いのです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の年齢と同じだけのイブニング・ドレス。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフタヌーンのスカートは短くイブニングのスカートは長い。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――クリスマス・イブは、おまいの古巣へ行って踊るか。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ちょいと君はこんどのクリスマス・イブには妾になにを贈ってくれる？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物客が、ドライブしてやって来る。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかえって見ると、車室の中の旅人たちは、みなまっすぐにきもののひだを垂れ、黒いバイブルを胸にあてたり、水晶の珠数をかけたり、どの人もつつましく指を組み合せて、そっちに祈っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはコンステイブルの画を一枚思い出している。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、昨年の夏であったか、ある日｜丸善の二階であてもなくエヴリーマンス・ライブラリーをあさっているうちにLucretius: Of the Nature of Things. A Metrical Translation by William Ellery Leonard.というのが目についた。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンローの第三巻はこの人の対語訳で、同じものがボーンのポピュラー・ライブラリーの中にも出ているそうであるが、自分はまだこの訳を読んでいない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、これら眼前の問題に対していくらかでも知識を得たいと思ってライブラリーを渉猟しても満足な答解を与えてくれるものはまれである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シェークスピアとかドストエフスキーとかイブセンとかいう人々は、人間生死の境といったような重大な環境の中に人間をほうり込んで、試験檻の中のモルモットのごとくそれを観察した。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の所へある日遠方の富裕な地主イブラヒム・ベグ・ハジからの手紙をもった使いが来て、「入れ歯を一そろい作ってこの使いの者に渡してくれ」とのことであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後この歯医者がカシュガルに器械持参で出かけるついでの道すがらわざわざこのイブラヒム老人のためにその居村に立ち寄って、かねての話の入れ歯を作ってやろうと思った。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた○○などで全国の科学研究機関にサーキュラーを発して、数々のかなり漠然たる研究題目とそれに対して支給すべき零細の金額とを列挙してそれらの問題の研究引受人を募ることがあるようであるが、あれなどもやはりこのイブラヒム老人の入れ歯の注文とどこか一脈相通ずるところがあるような気がするのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそう言えば結婚でも就職でも、よく考えてみればみんなイシャクの入れ歯をイブラヒムの口にはめて、そうして歯ぐきがそれにうまく合うように変形するまで我慢できるかできないかを試験するようなものかもそれはわからないのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかえって見ると、車室の中の旅人たちは、みなまっすぐにきもののひだを垂れ、黒いバイブルを胸にあてたり、水晶の数珠をかけたり、どの人もつつましく指を組み合わせて、そっちに祈っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは英語はわかるかい、ね、センド、マイブーツ、インスタンテウリイすぐ長靴送れとこうだろう、するとカルクシャイヤのおやじめ、あわてくさっておれのでんしんのはりがねに長靴をぶらさげたよ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかへつて見ると、車室の中の旅人たちは、みなまつすぐにきもののひだを垂れ、黒いバイブルを胸にあてたり、水晶の數珠をかけたり、どの人もつつましく指を組み合せて、そつちに祈つてゐるのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アダムとイブが、神様を信心し過ぎて肉慾を軽蔑している間は、子供が生まれなかった。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お医者様の御診察ではその前にお二人で××にドライブをなすったのが悪かった……ナル程。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
