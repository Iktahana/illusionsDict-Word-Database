        "examples": {
          "standard": [
            {
              "text": "どんなにわがままを言っても、末っ子は親にとっての愛し子だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は戦乱の中、たった一人の愛し子を必死で守り抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「行ってまいります、お父さん」「おお、気をつけて行けよ、私の愛し子よ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "愛し子よ、めでよ、足音、息の緒のすこやけき揺り。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮肉以上の解答を、真実人生を愛し子を愛する母は求めている。",
              "citation": {
                "source": "是は現実的な感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあお入り、愛し子よ！",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "啻に出産老病の一事のみならず、人間の子にして父母を親しみ父母を慕い、父母にして子を愛し子を親しむは、天性の約束なるに、女子が他家に嫁したればとて、実の父母を第二にして専ら舅姑の方を親愛し尊敬して孝行せよとは、畢竟出来ぬ事を強うるものと言う可し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その感謝の心は『日の子』を書いて自分を彼れの愛し子、隱し子であると言つた時吾が心は言ひ知れぬ歡びに溢れてしまつた。",
              "citation": {
                "source": "太陽の子",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞かせてよければ、愛し子が心のうちでは夢にまで恋いこがれているであろう母親のことである。",
              "citation": {
                "source": "ある完全犯罪人の手記",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の惨苦に沈む世の親たちが愛し子を殺す心の切なさが今こそ、しみじみとわが心に迫る。",
              "citation": {
                "source": "親馬鹿入堂記",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはよいが、体をこわしてはなるまいが」と、慈円は愛し子を諭すようにいった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すると近日、愛し子の顔を見られるのじゃな」「ただ愉しみはそれのみでございまする」「さもこそ」　義貞はふと、とろんとした眼に物を忘れて、「うれしかろ」　と、かさねて言った。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした中で、縁につながる尼御前が、わが身ばかり、愛し子との対面を、よろこんでもおられぬと申すのじゃな。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女十四歳、むずかしいとしごろだ。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は型のくずれたソフト帽をやにわに頭から取って、そのさきを左手で握って、右手でぐいとしごいた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
