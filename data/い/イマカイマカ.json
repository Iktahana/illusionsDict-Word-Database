    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eagerly (waiting)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ファンたちは、憧れのスターが登場するのを今か今かと待ち構えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "注文した限定モデルの時計が届くのを、彼は数日前から今か今かと楽しみにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "合否の結果が届く郵便受けを、受験生は今か今かと覗き込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "関東震災後の復旧測量では毛無山頂上で二十八日間がんばって天城山の頭を出すのを今か今かと待っていた人がある。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年上の子、先に立ちてこれらに火をうつせば、童らは丸く火を取りまきて立ち、竹の節の破るる音を今か今かと待てり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さま、お妃さま、それに宮廷じゅうの人々が、お姫さまのところでお茶を飲みながら、息子の来るのを、今か今かと待っていました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、町から来た楽隊が賑やかな音楽を初めて、時間が来たことを知らせましたので、みんな神様の前に集まって、礼服を着た神主と一所に、珍らしい夫婦の豚吉とヒョロ子が来るのを今か今かと待ちました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、お父さんは、お前が言い出すのを今か今かと待っていたのだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今か今かと、ペテロや、ほかのわかものが、がいせんしてくるのを、まっていました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さん狐は、心配しながら、坊やの狐の帰って来るのを、今か今かとふるえながら待っていましたので、坊やが来ると、暖い胸に抱きしめて泣きたいほどよろこびました。",
              "citation": {
                "source": "手袋を買いに",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯者は、私のこんな下手な作品に対しても、わざわざペエジを空けて置いて、今か今かと、その到来を待ってくれているのである。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日夕がたになると、家族は囲炉裡を取りまいて、吉弥の口のかかって来るのを今か今かと待っている。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎晩、今か今かとその時機を待っているうちに或る朝の事、霜の真白い、月の白い営庭の向うの獄舎へ提灯が近付いてゴトゴト人声がし始めたので、素破こそと皆｜蹶起して正座し、その方向に向って両手を支えた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どろぼうたちは、せまいかめの中で、じっとしんぼうしながら、あいずがあるのを、今か今かと待っていました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はここで――この部屋で――その男の来るのを今か今かと待ちかまえている。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れると例の如く、高源寺には大勢の参詣人が詰めかけて、お線香を供えるのもあり、お賽銭をあげるのもあり、いずれも念仏合掌して、今か今かと待ち受けていましたが、どういうわけか、今夜に限って地蔵さまは身動きもしない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福の足音が、廊下に聞えるのを今か今かと胸のつぶれる思いで待って、からっぽ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は私が可笑しさを堪えてゐるなどゝいふことは夢にも知りませんから、今か今かと待つて居りました。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "王様は今か今かとお嫁さんの笑ふのを待つてをりました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋはもつと美しい色彩を今か今かと期待した。",
              "citation": {
                "source": "くづれた土手",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはその美しさを今か今かと期待した。",
              "citation": {
                "source": "くづれた土手",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただベルギー人の中でゼラール中尉一人だけは、独軍の国境突破の報を今か今かと待ち受けていた。",
              "citation": {
                "source": "ゼラール中尉",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような淫らがましい事をお願いしてよいやらわるいやら分らぬのでござりますけれど、わたしひとりの力では工夫もつきませなんだゆえ、先程からお帰りを今か今かとお待ちしていたのでござります」「そうか。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "来たら退屈払いにひと泡吹かしてやろうと、朱緞子の大座布団にふっくらと陣取りながら今か今かと待っていたのに、どうしたことか宿改めの係り役人達は、待てど暮らせどそれらしい者の姿すらも見せないのです。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "目ざしているところも不思議だが、今か今かと油断なく駕籠の中から左右へ目を光らしていたのに、出る気色もない。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は後に一年も経てから嵐に襲われ狂う空の叫びも知ったが、その日はただ唖然とし、畏服してその怒りの鎮まるのを、今か今かと待つばかりであった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "村同志の人々も皆その婚礼の日が来るのを楽しみにして今か今かと待ちかねていましたが、最早その日まで三週間しかないという時になって、大変な御布告が藍丸王の御言葉だといってこの湖の岸に伝わりました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは息をつめて、その人の来るのを今か今かと待設けていました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は女給たちのとめて呉れるのを、いまかいまかと待つてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は女給たちのとめて呉れるのを、いまかいまかと待っていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるすぎはそはそは窓に立ってシラトリ属の帰るのをいまかいまかと待ってゐました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王様はお妃の笑ふのを、いまかいまかと待つてをりました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪魔は承知して、ごそごそと土の中にもぐり込んでしまひました、女の子は、悪魔がたくさんの美しい着物をもつてくるのを、いまかいまかと、まつてをりました、しかしなかなか現れません、そのうちに女の子は地面をいつまでも見てゐることが退屈になりました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
