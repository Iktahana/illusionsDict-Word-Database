[
  {
    "uuid": "9536493b-d45a-5dc0-94c0-b1472fbf2bca",
    "entry": "今か今か",
    "reading": {
      "primary": "いまかいまか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
