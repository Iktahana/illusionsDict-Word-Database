        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "生きた化石として知られるシーラカンスが、深海で泳ぐ姿がカメラに捉えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "語学留学の醍醐味は、教科書にはない、現地の人々が日常的に交わす生きた言葉に触れられる点だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「九死に一生を得たが、あの時は本当に生きた心地がしなかったよ」と彼は震える声で語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "単に貯め込むのではなく、自分を磨くために生きた金を使うことこそが、真の贅沢と言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "震災の記憶を単なる過去の記録に留めず、防災のための生きた教訓として未来へ繋いでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "市場の生け簀には、生きたままの新鮮な魚介類が所狭しと並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古びた手記を読み解くうちに、数百年前にここで暮らしていた人々の生きた息遣いが伝わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ケチなこつたと云つて呉れるな、子供つぽい考へだとも云つては呉れるな、誰でもが各自持つてるおきまり自問自答の二つ三つ、それこそは生きた詩であらうから。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢見ることによって生きた詩人等は、また夢見ることの中で死ぬのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの海岸の城下まちにも、大砲の音が、おどろおどろ聞えて来て、まちの人たちも、生きたそらが無かったのでございましょうが、私は、そんなこととは知らず、ただもう妹のことで一ぱいで、半気違いの有様だったので、何か不吉な地獄の太鼓のような気がして、ながいこと草原で、顔もあげずに泣きつづけて居りました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私は生きたかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども一方に、「生きたい！",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲では只、茫漠たる焼野に建物が建つたためには、人知れぬ努力があつたのだし、ジイドのあの反省的で堅忍な調子を想起され度、芸術の容易でない時代に生れ、その時代を生きたのであることを云へばよいのである。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら彼の場合は、芥川氏等の場合とちがつて、余技が単なる余技に止まらず、余技そのものの中に往々彼の作物を躍如とさせ、生きた詩人の肉体を感じさせるものがある。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば彼が陶器骨董を愛玩する時、その趣味性の道楽が直ちに彼の文学となり、陶器骨董の触覚や嗅覚がそれ自ら彼の生きた肉体感覚となるのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "杳として眺望すれば街路を這ひ行く蛆蟲ども生きたる食餌を暗鬱にせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の遠い先祖は、冬の来る前に穴を掘り、熊や狐やの獣と共に、小さくかじかまつて生きたへて居た。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがもし他の色々の鳥にも応用されるとなれば、鳥を少しも傷つけないで、生きた健全な標本を得るための一つのいい方法になるかもしれないという空想も起って来る。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は、それから十年、幸福な老人として生きたといふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな小さな穴からは、丈夫な生きた人間が「一人」で、縄梯子を伝って降りるより外に、方法は無かった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る小驛で停り合はせた荷物列車の一臺には生きた豚が滿載されて居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壺や林檎も面白くない事はないが、折角「生きた自然」の草木が美しく、其れに戸外が寒くなくて好い時候に、室内の「｜死んだ自然」と首引をするのも勿體ないやうな氣がした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はともかくこうして二十七まで生きたんだから、もう死んでもいいのだと思うのだが。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾多の生きたる実例、または、歴史的の例証は、もはや筆者を俟たれずとも読者諸氏に於いて充分知悉せらるるを信じます。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きた世間といふものは、たゞもう濁った大きな川だ。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きた哲学は現実を理解し得るものでなくてはならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、意味および言語と民族の意識的存在との関係は、前者が集合して後者を形成するのではなくて、民族の生きた存在が意味および言語を創造するのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は単に生きた教科書であって自然科学その物については何の得る所もないのである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術家は画法に囚われて自然を見なくなり、宗教家は経典に囚われて生きた人間を忘れ、学者はオーソリチーに囚われる。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれらは単に見る人の知識となるばかりでなく、一つ一つの生きた体験になるのである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授用フィルムに簡単な幻燈でも併用すれば、従来はただ言葉の記載で長たらしくやっている地理学などの教授は、世界漫遊の生きた体験にも似た活気をもって充たされるだろう。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首一首を詠んでそれぞれ生きた感情に触れ、更に全体を読去って、また全体から受ける共鳴の響きが、暫くの間読者の胸に揺らぐを禁じ得ないのである。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁天の白露を帯びたこの花の本当の生きた姿が実に言葉通り紙面に躍動していたのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしだってわからないわ、どこへもいきたくないわね。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが自然を系統化するために用いきたった思考形式の機巧の中に最初から与えられたものの必然的な表象を近ごろになっておいおい認識しつつあるのではないかという気がするのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その天国とかいうところへのぼっていきたいわ」「そんなことを考えちゃいけないよ」と、おばあさまが言いました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、ぼくは、外の広い世の中へ、出ていきたいんです！",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
