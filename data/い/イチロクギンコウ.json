          "standard": [
            {
              "text": "今月も家賃が払えず、泣く泣く祖父の形見の時計を一六銀行へ持っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "給料日前になると、彼はきまって一六銀行ののれんをくぐり、カメラを預けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "あの角の一六銀行の主人は、品物の価値を見極める目がなかなかに厳しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "若い頃は着物を一六銀行に入れたり出したりして、なんとか食いつないでいた時期があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
