        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "午前10時、観光列車はゆっくりとホームを離れ、景色の良い区間へと行き始めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "朝のラッシュアワーが始まり、人々は足早に職場へと行き始めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ガイドの合図とともに、登山隊は夜明けと共に山頂を目指し行き始めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "朝刊を積んだ配達車は、集配所を出て、各家庭へと行き始めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのニュースを聞いて、観衆は興奮して会場の外へと行き始めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "天気が良かったので、子供たちは公園へ遊びに行き始めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もうこんな時間だ！早く行かないと遅刻しちゃうよ！」と友人が言い、私たちは慌てて家を出て行き始めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今までの白ゆもじを燃え立つような赤ゆもじに改良したり、饂飩屋にいた時分の通りの真白な襟化粧を復活させたりするばかりでなく、その襟化粧と赤ゆもじで毎日毎日福太郎の帰りを途中まで出迎えに行き始める。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、グルーシェンカのところへ行き始めると同時に、おれはもう許婚でもなければ、誠実な人間でもなくなってしまったんだよ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "真空管やコンデンサー、抵抗など一つ一つの部品の働きを知り、各々の部品が結びつく必然性に納得がいきはじめると、ラジオはまるで精緻な生き物のように思えてきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになったら、人々は、アリアドネの糸をたどって、そのもとの入口に帰っていきはじめるのか。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
