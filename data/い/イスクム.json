    "definitions": [
      {
        "index": 1,
        "gloss": "to be unable to move while seated (because of fear, surprise, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "目の前に現れた巨大なヒグマを前にして、登山者は恐怖のあまりその場に居すくんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "面接官の鋭い視線に射抜かれ、彼は椅子の上で思わず居すくんでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "父の激しい怒声がリビングに響き渡り、子供たちは部屋の隅で小さく居すくんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "突然の激しい地響きと轟音に、私は立ち上がることもできずただ居すくむことしかできなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "上司からの執拗な叱責が続き、新入社員は身を縮めてただ黙って居すくむばかりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あなたにだけは打ち明けましたが、もしも私があなたすらも偽って死んだとすれば、死後の淋しさに堪えられないでしょう」　茫然と居すくむ百合子をのこして、令嬢は静かな足どりで自室への階段を登って行った。",
              "citation": {
                "source": "南京虫殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝アこの女――」　と左膳、かたわらにいすくむお蓮様へ、キラリと一眼をきらめかせたのち、「汝アこの女と、同じ穴の狸だな、イヤさ、同臭のやからだな」　ぐっと調子をさげて、「おもしれえ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとしまつは、よしなに頼む」　片隅にいすくむ萩乃へ、ジロッと一眼を投げて、左膳、廊下へ出た。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
