[
  {
    "uuid": "ee4411a2-e165-501c-884f-6947d31417cb",
    "entry": "言い切る",
    "reading": {
      "primary": "いいきる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
