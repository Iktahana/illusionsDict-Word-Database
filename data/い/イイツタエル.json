[
  {
    "uuid": "56211ade-c32a-57ba-a0cb-4acd995a23ea",
    "entry": "言い伝える",
    "reading": {
      "primary": "いいつたえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
