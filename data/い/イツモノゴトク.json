          ],
          "literary": [
            {
              "text": "自分はいつものごとくに、おんぼという姉とおんもという妹とをいっしょに背負うて、しばらく彼らを笑わせた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関長がいつものごとくに祈祷をした。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどそれでも帰りにはいつものごとく、心じょうぶに愉快になって、それほど失望するにも及ばないような心地で帰られた。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とんちゃんとんちゃん」という声も、いつものごとくにかわいかった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、女はすこしも刺激に感じない、しかも、いつものごとく男を酔わせる調子で、「お金は、あすこじゃいただけないのよ」と言った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものごとくおしゃべり屋伝六が、年じゅう忙しくてたまらないといったふうに、せかせかしながらやって来ると、しょうぜんと顔の青ざめた見知らぬ若者が、おどおどしながらへやのすみにうずくまっていたものでしたから、よほど不意を打たれたとみえて、遠慮もなく例のお株を始めました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどがいして田舎は平和で、夜はいつものごとく竹藪の外に藁屋の灯の光がもれた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆は、昨夜八時少し前にいつものごとくお湯に行き、それから八百屋へ買い物に行って、十時頃帰ったのですが、応接室にあかりがついていたので、不審に思って見にいったのであります。",
              "citation": {
                "source": "玉振時計の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ペタルを踏み出す父の後から、子供たちの高次郎氏を送り出す賑やかな声が、夫人の声と一緒にいつものごとく変らずに聞えていた。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中はいつものごとく御看病と称えて。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "上と下とに顔見合わせて、辰弥はいつものごとく笑うて見せぬ。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に景色をみるでなく、いつものごとく、ぼんやりとしてました。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も、二人のまわりには、いつものごとく、人が黒山のように集まっていました。",
              "citation": {
                "source": "港に着いた黒んぼ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、猫の頭をなでて、いつものごとくかわいがってやったのであります。",
              "citation": {
                "source": "少年の日の悲哀",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤犬も、お経のあげられる時分には、ちゃんときて、いつものごとく瞼を細くして、お経の声を聞いていました。",
              "citation": {
                "source": "犬と人と花",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものごとく、にこにことして煙草を吸っていたおじいさんは、その日にかぎって、常よりは元気なく、「もう、私は、なんにもいらないから。",
              "citation": {
                "source": "犬と人と花",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、男はいつものごとく考えながら歩いてきました。",
              "citation": {
                "source": "犬と古洋傘",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、町へ着くと、いつものごとく仕事にとりかかりました。",
              "citation": {
                "source": "犬と古洋傘",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、いつものごとくほがらかで、口笛をそれに合わして、家に帰るべく駅の方へ歩いていました。",
              "citation": {
                "source": "夕焼けがうすれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんは、いつものごとくゆったりとした調子で、「まちがっているって、どんなことかな。",
              "citation": {
                "source": "世の中のために",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いつものごとく、外から声をかけました。",
              "citation": {
                "source": "さびしいお母さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、いつものごとく授業が始まりました。",
              "citation": {
                "source": "空晴れて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜家は、いつものごとく時計が十｜時を打つと寝につきました。",
              "citation": {
                "source": "火事",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかたなく、いつものごとく、子守歌をうたって聞かせるのです。",
              "citation": {
                "source": "雲と子守歌",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、野原を越え、山を越えてくると、光った川がいつものごとく目に入りました。",
              "citation": {
                "source": "もずとすぎの木",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "門から流れ出る生徒らを、二人の若い保姆が、たがいに十五、六｜人ずつ引きつれて、いつものごとく、道を左右に、途中まで見送ったのであります。",
              "citation": {
                "source": "少女と老兵士",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "前ぶれとして、いつものごとく、驟雨がやってきました。",
              "citation": {
                "source": "台風の子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　町へくると、いつものごとく、トラック、自転車、自動車が走っていました。",
              "citation": {
                "source": "太陽と星の下",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝のこと、東の空がやっとあかくなりはじめたころ、いつものごとく舟を出そうと、海岸をさして、家を出かけたのであります。",
              "citation": {
                "source": "羽衣物語",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
