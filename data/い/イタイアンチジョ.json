        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "警察は、土砂崩れの現場から発見された身元不明の遺体を、市内の遺体安置所に収容した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "病院の地下にひっそりと佇む遺体安置所は、冷たく静謐な空気に包まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "震災の被害が大きかった地域では、中学校の武道場が臨時の遺体安置所として利用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ご遺体は現在、地下の遺体安置所に安置されておりますので、面会をご希望の際はお申し付けください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "葬儀場が混み合っていたため、火葬の日まで近隣の民間遺体安置所に預けることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海難事故の犠牲者を収容するため、港の倉庫に臨時の遺体安置所が急遽設けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "司法解剖の結果を待つ間、遺体は大学の医学部内にある遺体安置所に厳重に保管された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "コロッセウムのスポリアリウム（spoliarium）は古代において遺体安置所に相当するものであった。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
