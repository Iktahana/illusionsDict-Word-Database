    "definitions": [
      {
        "index": 1,
        "gloss": "with energy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祭りの担ぎ手たちが、神輿を担いで「わっしょい、わっしょい」と威勢よく町を練り歩く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "試合開始の号令と共に、選手たちは「おう！」と威勢よく声を上げ、一斉にグラウンドへ駆け出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "少年は「行ってきます！」と玄関のドアを開け、威勢よくランドセルを揺らしながら学校へ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は会議で「その件は私に任せてください！」と威勢よく宣言し、見事プロジェクトを成功させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "年の瀬の魚市場では、競り人の威勢のいい声が飛び交い、活気に満ち溢れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "消防団の出初式で、団員たちが梯子乗りの妙技を披露すると、観衆から威勢のいい掛け声が飛んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は酔うと「昔は俺も悪かったんだ」などと威勢よく語りだすが、誰も本気にしていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "空には、晴れた空の一部分に黒い濃い雲形定規のやうな雲があつて、一寸欠け初めたばかりの月が、みえたり隠くれたり、可なり威勢よく渡れ亙つてゆくのが見られた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢よく流れる小川だけがその日の記憶として残つてゐる。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮なくべたべたと威勢よくやつてくれ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは俄かに顔いろがよくなって威勢よくおじぎをすると台の下に置いた鞄をもっておもてへ飛びだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分よりは一つ年上の甥のＲが煙草を吸って白い煙を威勢よく両方の鼻の孔から出すのが珍しく羨ましくなったものらしい。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手先の松吉が神田三河町の半七の家へ威勢よく駈け込んで来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "投げた時、偶と渠は、鼓打である其の従弟が、業体と言ひ、温雅で上品な優しい男の、酒に酔払ふと、場所を選ばず、着て居る外套を脱いで、威勢よくぱつと投出す、帳場の車夫などは、おいでなすつた、と丁と心得て居るくらゐで……電車の中でも此を遣る。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして再びエンジンの爆音を立てて威勢よく軽井沢のほうへ走り去ったのであった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし山頂から視角にしてほぼ十度ぐらいから以上の空はよく晴れていたから、今に噴煙の頭が出現するだろうと思ってしばらく注意して見守っていると、まもなく特徴ある花甘藍形の噴煙の円頂が山をおおう雲帽の上にもくもくと沸き上がって、それが見る見る威勢よく直上して行った。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはにわかに顔いろがよくなって威勢よくおじぎをすると、台の下に置いた鞄をもっておもてへ飛びだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニは俄かに顏いろがよくなつて威勢よくおじぎをすると、臺の下に置いた鞄をもつておもてへ飛びだしました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが象が威勢よく、前肢二つつきだして、小屋にあがって来ようとする。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく車が来て田浦は帰り、続いて大森も美麗な宿車で威勢よく出て行った。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幌人車が威勢よく駆けている。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時赤羽行きの汽車が朝日をまともに車窓に受けて威勢よく走って来た。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "車は通らず、雨傘も威勢よくポンと轆轤を開いたのでは、羽目へ当って幅ったいので、湯の帰りにも半開、春雨｜捌きの玉川｜翳。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も水へ飛込み兼ねない勢で、台所へ出ようとすると、姉は威勢よくそこへ帰った。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と膝を丁と支くと、颯と掻巻の紅裏を飜す、お孝は獅子頭を刎ねたように、美しく威勢よく、きちんと起きて、「でも、さすがに土地の姉さんだねえ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ありや、と威勢よく頭突に屈んで、鼻息をふツと吹き、一散に黒く成つてがら／＼と月夜を駈出す。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へッ、」と云って、威勢よく飛んで帰る。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　慶造は威勢よくぽんと一ツ胸を叩いた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かご用でございますか」　ホモイができるくらい威勢よく言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』言下に武村と呼ばれたる兵曹は、つと進寄り威勢よく少年を抱上げて『ほー、可愛らしい少年だ、サア私の頭へ乘つた／＼。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と威勢よくテーブルの上を叩き廻すと、皿は跳つて、小刀は床に落ちた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵曹は猶も威勢よく『ね、此自動鐵檻車が出來て見なさい、如何な危險な塲所だつて平氣なもんです、猛狒や獅子が行列を立てゝ襲つて來た所で、此方は鐵檻車の中から猛獸共の惡相を目掛けて、鐵砲玉の御馳走でもしてやるばかりだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とよごれくさつた半纏だが、威勢よく丼をたゝいて見せて、「何、何をしたつて身體さへ働かせりや、彼女に食はせて、乳はのまされます。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小脇に威勢よく引抱えた黒塗の飯櫃を、客の膝の前へストンと置くと、一歩すさったままで、突立って、熟と顔を瞰下すから、この時も吃驚した目を遣ると、両手を引込めた布子の袖を、上下に、ひょこひょことゆさぶりながら、「給仕をするかね、」と言ったのである。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひイよめ、　ひよめ、　だんご、やらないけれど、　くウぐウれッ　するとひよめは、やはりいせいよく、くるりと水をくぐったのであります。",
              "citation": {
                "source": "一年生たちとひよめ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか女中が火を運んで来たとみえて、火鉢に炭火がいせいよく起こっていて、茶道具などもきれいに掃除してあった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、モーティが、赤い塗りたてのサイドカアまでつけて、いせいよく立っているのです。",
              "citation": {
                "source": "やんちゃオートバイ",
                "author": "木内高音",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
