            }
          ],
          "literary": [
            {
              "text": "勝たなければ生きて行けない単純な選手だ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日南洋から手紙が來て「東京の家にはお前の唯一人の叔母たる小生の母と、小生の妹と家内と三人で侘しく留守をしてゐるから一度訪ねて行きなさい」とそれに書かれてありましたが、私はそれに返事して「僕にはとても行けない。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と何の事やら、わけのわからんやうな事を悟り澄ましたみたいな口調で言ひ、兩腕をうしろに組み、ひとり家を出て、あちらこちら海岸を逍遙し、苅薦の亂れ出づ見ゆ海人の釣船　などと、れいの風流めいた詩句の斷片を口ずさみ、「人は、なぜお互ひ批評し合はなければ、生きて行けないのだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはほんの一例であるが、まあ、たいていこんな按配で、とても讀んで行けない。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと悠くり歩かなけや、父ちやんは附いて行けないよ」「引つ張つて上げようか」　と、一年生の女の児が、私の手を引つ張つて、グイグイと先きに立つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてだ」「お嫁に行くということは私が向うの人のものになってしまうのだから、その人が承知してくれないじゃ、一緒に行けないのよ」「お蘭さが誰かのものになるというだかね」「そうよ」「ふーむ」　白痴の心にもお蘭が自分から失われ、自分は全く孤立無援で世の中に立つ侘しさがひしひしと感じられた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにおれはここを出て行けない。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝灰岩が青じろく崖と波との間に四、五｜寸続いてはいるけれどもとてもあすこは伝って行けない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ行くと云ったものの、直ぐには行けないようになってしまった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし直ぐあの酒場には行けない。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし為吉は、これからさき、五六反の田畑を持った百姓では到底食って行けないのを見てとっていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一と通りの労力を使っていたのではやって行けない。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に割って二十五円、一家は妻に二十になるお菊と十八になるお新の二人娘で都合四人ぐらし、銀行に預けた貯金とても高が知れてるから、まず食って行けないというのが世間並みである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "例を車夫や職工にとって、食って行けないはずはないと主張するのである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "土匪は遉がに、あの世へ持って行けない金銀の器物はほしがらなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての思念にまとまりをつけなければ生きて行けない、そんなけちな根性をいつたい誰から教はつた？",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいっしょに行けない。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝灰岩が青じろく崖と波との間に四五寸続いてはゐるけれどもとてもあすこは伝って行けない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからトランクと一緒に俥に乗って町を通り国道の松並木まで来ましたが平太の村へ行くみちはそこから岐れて急にでこぼこになるのを見て俥夫はあとは行けないと断って賃銭をとって帰って行ってしまひました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいつしよに行けない。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてだ」「お嫁に行くということは私が向うの人のものになってしまうのだから、その人が承知して呉れないじゃ、一緒に行けないのよ」「お蘭さが誰かのものになるというだかね」「そうよ」「ふーむ」　白痴の心にもお蘭が自分から失われ、自分は全く孤立無援で世の中に立つ侘しさがひしひしと感じられた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だつて、君の内はお邸だから、廣い座敷を二つも三つも通らないと、母さんや何か寢て居る部屋へ行けないんだもの。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくたちは行けないだろうかねえ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも無風帯のはじの方から舞い上ったんじゃ中々高いとこへ行かないし高いとこへ行かなきゃ北極だなんて遠い処へも行けないから誰でもみんななるべく無風帯のまん中へ行こう行こうとするんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝行つた處は暗い道だの危ない橋だのが澤山あつて、大佐の叔父さんや此叔父さんのやうに、成長な人でなければ行けない處、日出雄さんの樣に小さい人が行くと、屹度泣きたくなる程恐い處なんだから、默つて行つたのだよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "此紀念塔の建てられた深山までは、危險だから誰も行けない、行かなければ其樣な證據物のある事は知らないで居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも男の子は強いし、わしも二人はつれて行けない。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜あかしはしても、朝湯には行けないのである。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "べにやで会うように御手紙いただいたけど、都合が悪くて、行けないから、ちぎり家の別館へ来てくれるように、ことづけてくれって……」「ちぎり家……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、まさかアベノの宿屋へも行けない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
