        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ああ、愛しの君、どうしてそんなに美しいんだ」と彼は芝居がかった口調で言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "久しぶりに帰省し、愛しの我が家でゆっくりと羽を伸ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "長年の夢だった愛しのクラシックカーを、ついに手に入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "余は胸がドキドキする、是を思うと余は迚も盗坊などに成れる性質でない、最愛しの秀子が為なればこそ斯様な事もするが金銭の慾などの為なら、寧ろ餓え死ぬ方が幾等気楽かも知れぬ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛しのフローラよ、そもじの悩みは、貴い涙となって、父の顔の上に落ちまするぞ」　フローラは、無限の感動をこめて、じっと紅琴の顔を見つめている。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは愛しのあの子が國へ歸るのだ。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車を転がすなか目に映るのは、ジョン・フェリアさんといとしのルーシィ、闇のなかから私を見つめ微笑みかけるその姿は、この部屋に皆さんを見るのと同じくらいはっきりでした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈夫の中にも丈夫らしきさすがの丹濃も、馬を差置いていとしの妻を抱きよせた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いとしの男よ、田舎の人はいゝ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとしのカチユーシヤ　いとしのカチユーシヤ　　　　１ぐいぐい陽向葵の花は延びて行つた油陽照りの八月だ！",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとしのカチユーシヤよ！",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、この迷迭香でもフルール・ドウ・ルシイ――いいえ｜百合の花でも、どっちでもいいのだけれどきっと凋んでしまうにきまってますわ、父の没くなりました時、それは立派な最期でしたけど」　と、弥生の春の花薔薇、いとしのオフェリヤは、そうして残りの花を、舞台の縁にふり撒くのだった。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっぽを　ひとふりして　くすくすわらい　――　「いとしの　グディ、　きのみが　たわわだ。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリザベスは峻烈な手紙を、彼女の「正しくして信じるにたる、いとしの従弟」に書いた。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとしのこがらがさきょうもとおれかしやさしのこがらがさきょうもとおれかし　私はきき惚れた。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが苦しみを柔らげんとならばわれを伴え海へ海へ、海へかくてわがいとしの者はわれを愛す海へ、海へ命の限り汝を愛す（松藤訳）次のようなものもあった(29)。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "タランチュラ蜘蛛には非ず、大なるもそはびんより出づるぶどう酒そは汝のいずこを咬みしや、わがいとしの者よわれに示せ、そはいずこおお汝の足ならば、おお乳房ならば（松藤訳）他の人たちは歌詞を限りなく繰り返した(30)。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに立っていたのは、いとしの黄金仮面！",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日間の生埋の間、一瞬たりとも忘れなかった、わがいとしの妻の声だ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五六年はエルヴィス・プレスリーとリトル・リチャードの年であると共に、『いとしのシンディ』がヒットした年でもある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いとしのシンディ』も『ハウンド・ドッグ』も、共に七九セントだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとしの妻と寢たならば、刈り取つた薦草のように亂れるなら亂れてもよい。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとしのエイミイは青い眼、金髪の巻き毛で、強面の酋長の膝にちょこんと座り、酋長の数珠球で遊び、ちっとも怖がらなかった。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだよ、きみはいとしのジェシだ」　その優しい言葉にジェシはぞくぞくした。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとしのメアリですね。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとしの男がそばにいる。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとしのビートリスは宙ぶらりんの状態に違いない。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨晩はファンが近寄って来て、いとしのアデラ・ベーンを手離さなかったものですから」「あなたがアデラ・ベーンですか。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いとしの妻に、四万ポンドとまでは言わないがそれぐらいの宝石を贈った。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
