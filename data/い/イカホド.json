[
  {
    "uuid": "6377f581-9659-5d98-8f9a-1f4712d41e38",
    "entry": "如何ほど",
    "reading": {
      "primary": "いかほど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
