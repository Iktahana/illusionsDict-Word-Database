      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "how much",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "報道によると、今回の金融危機による市場への影響は如何ほどと見られているか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このアンティーク時計の現在の相場は如何ほどでしょうか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「目的地まで、あと如何ほどで到着しますか？」と、運転手に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "実験で得られたデータの信頼性は如何ほどか、厳密な検証が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「提示された買収額は如何ほどになりますか？」と、担当者は静かに問いかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その提案がプロジェクトの成功に如何ほど貢献するかは、まだ未知数である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "甚大な被害をもたらしたとされる今回の災害、その規模は如何ほどであったのか、調査が進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この場合に起る地震の強弱の度を如何ほどまで予知し得べきか。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒の老成後の倫理道徳観が中学校で教わった所と如何ほど懸隔しても仕方がない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり面白過ぎたような考案ではあるが、如何ほどまで電気が万能な勢力であるかという一例として御紹介するのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば作家が著作集を出す時、後記というものを書くけれど、それは如何ほど謙遜してみたところで、ともかく上梓して世に出す以上、多少の己惚れが無くてはかなうまいと思うが、どうであろうか。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その苦しみが如何ほど深くとも、それはしかくあるべき事で、それは些かも矜りとす可きでは無い。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "書けぬと決れば、如何ほど彼が逞ましい離れ業に長けてゐるとは云へ、此処に至つてはそんな芸当はおそらく役立ずに決つてゐる。",
              "citation": {
                "source": "三田に来て",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ペタルが前輪の中心にあつて、把手とすれ／＼に着いてゐるサドルに懸けると両膝のかたちがバツタのやうに曲つて、膝小僧がぬつと前へ突き出るといふ格構だから、十八九にもなる娘となれば、如何ほど僕にすゝめられても撮影のために勇姿を示すわけには行かぬだらう。",
              "citation": {
                "source": "写真に添えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑には、煙草のみが植ゑられ、米は産せず、云ふまでもなく酒の醸造は適はぬわけであるから、酒の味を知る者とてもなく、更に如何ほど自家に産出しようとも煙草の自家製は国法に依つて厳禁されてゐるが故に喫煙者すらも見出せなかつた。",
              "citation": {
                "source": "その村を憶ひて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "占星術や錬金術から独立したときの天文学や化学が如何ほど幼稚で粗笨であらうとも、依然として、それらは、最も精巧な占星術や錬金術よりも、理論的には遙かに進歩したものであると同じである。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何ほど慎み深い心からでもそれ以上の質問は私の念願をさへぎつた。",
              "citation": {
                "source": "サロメと体操",
                "author": "ヘツペル先生との挿話",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼から掬ひあげたばかりの青みどろを如何ほど大騒ぎをして実験したからといつて、アミーバが見つかる筈がありません。",
              "citation": {
                "source": "女優",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "などゝいふ掛け声が如何ほど颯爽たる趣きであらうとも、所詮私には風を切つて乗り込む勇気は持てぬのだ。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ういふものか、いや、それは私の心底に真の愛情が湧かぬ為だらうが、如何ほど私が奴の空機嫌をとつても一向に慣れるけしきもなく、その憎態な嘶きで飼手を飛びあがらせたり、尻尾の房で面体を振り払つたりするばかりであつた。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "直覚説は簡単であって実践上有効なるにも拘らず、これを倫理学説として如何ほどの価値があるであろうか。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に如何ほどの強度が如何ほどの継続に相当するかを定むるのは極めて困難である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい如何ほどの重病たりとも、当日の導師の務めは拙僧かならず相勤め申す。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何ほどこれを続けてゐようとも、この頭に空想の花が咲く筈はない――どうかして、この昼夜の転換を治したいものだ。",
              "citation": {
                "source": "極夜の記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "主義の項目を如何ほど暗記しようとしても、それの中心たる、これでこそ生きているという終極の安心は得られないでしょう。",
              "citation": {
                "source": "今日の女流作家と時代との交渉を論ず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学者などと云う者は縦しや如何ほど悪党でも、腕力で以て直接に人と格闘して取り挫ぐなど云う了簡はないもので、一身の危い様な場合には兎角に逡巡する者だよ、殊に此の様な室へ余が独りで忍び込んで居る所を見ては、何の様な命知らずだろうと奥底を計り兼ね、余が彼を恐れるよりも彼一層余を恐れたと見える。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何ほど聖純な祈願も、祈願する者は、私共である。",
              "citation": {
                "source": "断想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何ほど撫でさすりあやしてやつても無效で午前中彼は全く恐怖の戰慄の中にあつた。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの才能はかつてその個人的な豊富さで世界に注意を促したが、晩年のゴーリキイはソヴェト同盟という歴史に新たな人類の社会的地盤の上において、個人的才能というものが如何ほどの社会性・国際性において実りうるものであるかという典型をしめした。",
              "citation": {
                "source": "私の会ったゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間的欲求の真実に立って生れたことは事実であるが、その半面には、『白樺』の人道主義が、個性の完成を社会条件と照し合わせず、内面的の可能でだけ見るそのことに、明治四十年末から大正初頭にかけての日本の社会が面していた反動の情勢が如何ほど相殺の力で作用していたかという機微をもうかがい得る。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　さて如何ほど種々なる人間學、そしてそれに相應して如何ほど種々なる史觀が從來歴史に於て現はれたかを立入つて檢討することは今の問題でない。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "否な当事者はまして読者諸氏にいかほどか優つた二人の激越が徐々にそのクライマックスに近づきつつあるのを感得しつつ、久々の対面の機を待ちかまへて居たか知れませんでした。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいかほどまでに蝗の記述が戦闘飛行機に当てはまってもそれは決して科学的の予言とは名づけ難いであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このきばでいかほどものの命をとったか。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって僕がいかほど芝居通になったところで、全然君と同じ観察点に立って、芝居を見得るかどうだか疑問であるが、その辺はどうだろう。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたに嫁をやるわけじゃあるまいし、桑盛様が浄土宗ならば、いかほど金銀を積んでも、またその御総領が御発明で男振りがよくっても、私は、いやと申します。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一株はいかほどと訊けば十錢にてよからむと言ふ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
