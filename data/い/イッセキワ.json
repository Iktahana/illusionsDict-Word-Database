        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨晩、キャンプファイヤーを囲んで、みんなで各自の一夕話を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の語る一夕話はいつも面白く、座談を盛り上げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅の途中で出会った人から、忘れられない一夕話を聞かせてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "こんな雨の夜には、暖かい飲み物を片手にゆっくりと一夕話に花を咲かせたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "『著作堂一夕話』に出た富士の残雪、宝永山辺｜凹かな処に人形を成す年は豊年で、見えぬ年は凶作、これを農男と名づくとあるに似居る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "燒物一夕話　　　區別　科學的の分け方もありますが、私どもは簡單に土燒、燒しめ、石燒位の言葉で現はしてゐる。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燒物一夕話區別　科學的の分け方もありますが、私どもは簡單に土燒、燒しめ、石燒位の言葉で現はしてゐる。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　翌日彼はふとＪ新聞の演藝一夕話と云ふ噂書の一欄を見た。",
              "citation": {
                "source": "虎",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "与君一夕話一　人も、厩の馬も、寝しずまったころを、ここの一室では、燭の光をあらためて、さあこれからと、杯を分け持つ夜半だった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半兵衛は筆をとって、裏面へ、与君一夕話勝読十年書　と書いて、「殿のおいいつけなので、ぜひなく汚しました」　と、さしだした。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し百人一首｜一夕話に、夫人在原氏は国経の館から時平に拉し去られる時に、既に敦忠を懐妊していた、されば敦忠はまことは国経の胤であるが、夫人が本院へ移ってから生れたゝめに、時平の子として育てられたのであると云う記事が見える。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだとすれば、敦忠は少将滋幹の実弟になる訳であるが、一夕話の記事は何に基づいているものか、筆者はその出所を詳かにしないけれども、或は当時世上にそう云う風説もあったのであろうか。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎座の読者大会では、昼夜にわたって、たくさんな読者にまみえ、平家について一夕話をこころみたが、心にある何分の一も話せなかった気がしてならない。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
