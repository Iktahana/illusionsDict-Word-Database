[
  {
    "uuid": "c45c6747-63a8-550e-a4ab-42453a973b02",
    "entry": "致し方",
    "reading": {
      "primary": "いたしかた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
