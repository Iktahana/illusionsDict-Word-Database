    "definitions": [
      {
        "index": 1,
        "gloss": "fully",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「国民の期待に遺憾なく応えるため、政策の実行に全力を注ぎます。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ベテランシェフは、食材の持ち味を遺憾なく引き出し、絶妙な一皿を完成させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その画家は、鮮やかな色彩感覚を遺憾なく発揮し、見る者を魅了する作品を描き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "トップアスリートは、日頃の鍛錬の成果を遺憾なく発揮し、自己ベストを更新した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "研究チームは、最新鋭の観測機器を遺憾なく駆使し、未知の天体現象の証拠を掴んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「我々は、この歴史的プロジェクトの成功のため、ここに集結した英知を遺憾なく結集し、前進いたします。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「新しいソフトウェアの機能を遺憾なく使いこなせるよう、マニュアルを熟読しました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "蕪村とちがって、芭蕉の研究は一般に進歩しており、その本質の哲学や詩精神やも、既にほぼ遺憾なく所論し尽されてる観がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙万象の秋、人の心に食い込む秋思の傷みを咏じ尽して遺憾なく、かの芭蕉の名句「秋ふかき隣は何をする人ぞ」と双壁し、蕪村俳句中の一名句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春夏秋冬昼夜の別は勿論の事、複雑な諸星の行動も遺憾なく理解する事が出来る。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のごとき単純な側面観によって科学と芸術との任務や領域を遺憾なく説明しようというのではない。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論其の当時にあっては予も総べての希望を諦め老親の膝下に稼穡を事とする外なしと思ったが、末子たる予は手許に居るというても、近くに分家でもすれば兎に角、さもなければ他家に養子にゆくのであるから、老親の希望を遺憾なく満足させるは、少しく覚束ない事情がある。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ひ換へると石川君は、自分の考へた通りに、其要求の通りに作物が遺憾なく目的を達して居るのである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は不幸にして未来派の画やカンジンスキーのシンクロミーなどというものに対して理解を持ち兼ねるものであるが、ただ三色版などで見るこれらの絵について自分が多少でも面白味を感ずる色彩の諧調は津田君の図案帖に遺憾なく現われている。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "處で、そのよき文藝的内容を捉へながら、而も、それを映畫的に殆ど遺憾なく生かしたものと云へば、私はヤニングス主演の「最後の人」を今でも忘れ難く思ふ。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、比の作品中の逸品とも云ふべき「或る日の大石内蔵之助」の中で、氏が内蔵之助の心理の底に捉へてゐるものの如きは、その明智の冴えを遺憾なく語つてゐるものであらう。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子電子の存在を仮定する事によって物理界の現象が遺憾なく説明し得られるからこれらが物理的実在であると主張するならば、雷神の存在を仮定する事によって雷電風雨の現象を説明するのとどこがちがうかという疑問が出るであろう。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体が耐震耐火のルネッサンス擬いという、故伯爵の凝り性と用心深さを遺憾なく発揮したものであった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "親しかった人々は追悼会や遺作展覧会を開いてくれ、またいろいろの余儀ない故障のために親戚のものだれ一人片付けに行く事のできなかった遺物の処理までも遺憾なく果たしてくれた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我国が日清戦争に於て日露戦争に於て、世界の歴史を飾るべき光栄ある大勝を得しは、兵器の力彼に勝りしが為にあらず、黄金の力彼より大なりしが為にも非ず、其最大原因は、我が勇敢なる祖先の伝へし日本武士魂が、遺憾なく発動せし結果に他ならず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "椽も遺憾なく照らし暖められている。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五年間はアンナの金でアンナと一緒に、そして次の六年間は訣れた後のわたしのためにアンナがわたしにくれた金で、わたしはわたしを遺憾なく燃した。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この予想は過去一歳有半の長舞台に於て遺憾なく実現せられたり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "従て本集の編纂に際しては特に自信ある代表作物のみを精査し、少年時の長篇五六及その後の新旧作七十篇の余は遺憾なく割愛したり。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、彼らの亡国的感情が、その祖先が一度｜遭遇した時代閉塞の状態に対する同感と思慕とによって、いかに遺憾なくその美しさを発揮しているかを。",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから仕手方を本位とする地謡、囃子方、狂言等に到るまで、同曲の荘厳と緊張味とを遺憾なく発揮し得なければ、如何に達者な仕手方（翁自身）と雖も十分の舞台効果を挙げる事が出来ない筈である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の鼻の動的表現が無から有を生じた事は、かようにして遺憾なく証明されるのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそこに鼻の表現の使命が遺憾なく裏書きされているのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "名優の鼻　　　　　　　――悪魔式鼻の表現（二）　昔から名優と名を付けられた程の人々は、その身体のこなしや眼や口の表現は勿論、鼻の表現までも遺憾なく支配し得たものと認め得べき理由があります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどこの間われは遺憾なくこのまつりの興を受用し盡せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作にあってはスティーヴンスンの作家的短所は影を潜め、長所は遺憾なく発揮されている。",
              "citation": {
                "source": "宝島",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに当時の神学思想が遺憾なく表われておるのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず一節―七節を見よ、ここにビルダデの神学思想は遺憾なく表われている。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに予蠍を小さい壺に入れ細かい金網を口に張って蓋とし置くと、蠍先生追い追い壺の内壁を這い上って件の網の表を這い、予をして遺憾なくかの櫛の作用を視察せしむ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼独特の領域にして、北欧の風雪が培かつた奇峭、峻厳、冷酷の気は、あの粗ツぽく力強い筆致に遺憾なく描破されて居る。",
              "citation": {
                "source": "文壇一夕話",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学思想が事実と言ふものに立脚して、昔の文芸を遺憾なく改革して了つたのは！",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、太平洋戦争のときに、わが国の技術の欠陥をいかんなく曝露してしまったのだ。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
