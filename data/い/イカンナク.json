[
  {
    "uuid": "220463ed-a611-5f91-bba4-39fb685b4174",
    "entry": "遺憾なく",
    "reading": {
      "primary": "いかんなく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
