        "examples": {
          "standard": [
            {
              "text": "来月より、新卒採用の　一次選考　が開始される旨、企業から発表があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "書類選考を通過した候補者は、面接に進む前に、さらに　一次選考　の筆記試験を受ける必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "応募者多数のため、希望する職種によっては　一次選考　で多くの候補者が絞り込まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "オーディションの　一次選考　では、まず基本的な歌唱力と表現力が審査された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "全国高校生コンテストの　一次選考　を突破し、二次審査に進むことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "AO入試では、志望理由書と調査書による　一次選考　ののち、面接が実施される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「明日の　一次選考　、緊張するな」「大丈夫、君ならできるよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
