          ],
          "literary": [
            {
              "text": "千葉を遁げる時からたしなんだ、いざという時の二品を添えて、何ですか、三題話のようですが、凄いでしょう。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、――いざという時になった今、鈴子はさすがにふるえ上っていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただの学者、政治家と思われている人でも、いざという時には、非凡な武技を発揮した。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストだって、いざという時には、やったのだ。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら、マニラ行きの旅費に……」「知らん土地やなし、旅費はのうても、いざという時になったら、泳いででも行くわいな」　歯の抜けた顔で笑ったが、他吉はすぐしんみりして、「――それにこの金の中には、君枝が下足番をして貰た金もはいってるんや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンスを踊らせても、玉を突かせても、マージャンを打たせても、何をやらせても、京吉は天才的な巧さを発揮したが、とくにマージャンの場合、京吉の巧さとは、いざという時には、無理なパイでもツモってみせるという闘志と勝負運の強さだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病者の方がいざという時には狂暴な行動をやりがちなのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざという時には突き飛ばしてやる気で随いてきたのだが、抱かれると安子の方が燃えた。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の信一は京都｜下鴨の質屋へ年期奉公していたが、いざという時が来るまで、戻れと言わぬことにしてあった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "出掛けしなに妻や子供たちにも、いざという時の準備を命じた。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、侍の姿で入り込むわけには行きませんから、いざという時には何に化けるか、どの人もふだんから考えているんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際この女のためならば、命もいらないと思い込んでいるとしても、いざという時にその命を思い切ってそこへ投げ出すことの出来る人間ではありません。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "須山は自分のまわりに仲間を配置して、いざという時の検束の妨害をさせる準備をしておいた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は二等の方が乗客が少なく、したがって知人にあうプロバビリティが少ないと判断して、二等の切符を買ってきたのであるが、いざという時になって、ふっと気が変わって三等に、しかも一番こみあっている箱を選んで、それに乗った。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざという時にびくともしない沈勇ぶりは、さすがにたのもしい限りだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをして体を弱らせておいては、いざという時に思いきった働きができないではないか」　川上は部下を励ましたり叱ったりした。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはやはり、金塊を売る契約をして、いざという時に真鍮の中へ鉛を入れて同じ目方にしたものを渡すのである。",
              "citation": {
                "source": "錬金詐欺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、既成の倫理学の概念や習俗の力は、いざという時、どれ程の力を持っているのかは疑います。",
              "citation": {
                "source": "偶感一語",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざという時は下がっている輪を強く引き、出口を破り開けて下さい。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア作家は階級文化の前衛としてもとより、いざという時はペンを銃と持ちかえることを拒みはしないであろう。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　きのうも一昨日も、いざという時になると、この若者が自分の名を口にした記憶が、新な戦慄をルスタムに与えた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざという時には、そのまま甲板の上で人を乗せて、高い舷側から水面へ下ろすのである。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "露助という奴は、いざという時になると、お先きまっくらに何でもさっさとやっつけてしまうものだが、セリファンも次ぎの四つ角へ来ると、いきなり右へ曲って、『えい、野郎ども、しっかり頼むぜ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、どうしてもつきあわなければならなかったら、なるべく金持の子供とつきあうがいい、そうすれば、いざという時にはお前の助けになるからな。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠君愛国を無暗に振り廻わして、天下を闊歩している不真面目な人よりは、寧ろ退いて一身を守っている人の方が、いざという時に天下国家のためになりはせぬか。",
              "citation": {
                "source": "人格を認知せざる国民",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざという時には、甲府行きの汽車にひかれて死ぬ事も賑やかな甘酢っぱい空想。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、いざという時には、電光形の進路をとるんです。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れるというよりも、いざという時になってもなお、船を焼かずに済せることが余りに多い。",
              "citation": {
                "source": "風景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上へ又重ねては、いざという時に働けまい、と思ったが、然し、荒木の一行が、昨日から見えなかったから、半兵衛も（寒いのに、耐えきれまい。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから考えていなければ、いざという時には間に合いません。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
