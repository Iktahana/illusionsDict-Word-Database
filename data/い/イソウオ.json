[
  {
    "uuid": "0d78f51f-f6e8-5d11-b305-dfb9de67e972",
    "entry": "磯魚",
    "reading": {
      "primary": "いそうお",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
