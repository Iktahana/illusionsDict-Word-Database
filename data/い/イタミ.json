    "definitions": [
      {
        "index": 1,
        "gloss": "pain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "急に鋭い痛みが走り、その場に崩れ落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "痛みをこらえて、最後まで走り抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "失恋の痛みは、時が経つにつれて少しずつ和らいでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "患者の痛みに寄り添う医療のあり方が問われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ううっ、まだ傷口に痛みが残っていて、思うように動けないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "増税による国民の痛みは、想像以上に大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "相手の痛みを知ることで、本当の優しさが生まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『この痛み、もう大きの、参りますならば、多分私は死にましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが血のように赤く鮮明に印象されることは、心の傷いた空虚の影に、悔恨の痛みを抱きながらも、悲壮な敗北の意気を感じさせずにいなかったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちと人が悪いようなれども一切｜只にて拝見したる報いは覿面、腹にわかに痛み出して一歩もあゆみ難くなれり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かへつて、近所の人が、同情して、どういふわけでそんな瘤が出來たのでせうね、痛みませんか、さぞやジヤマツケでせうね、などとお見舞ひの言葉を述べる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしく鋭い痛みだつた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩一歩の足の痛みと、「今日からの生活の悩み」が、毒蛇をつッついたのだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋山は陸面から八十尺の深さに掘り下げた、彼等自身の掘鑿を這い上りながら、腰に痛みを覚えた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その痛みは大して彼に気を揉ませはしなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋山は、ベルの中絶するのを待っている間中、十数年来、曾てない腰の痛みに悩まされていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、彼が、痛いのは腰だ、と思っていたのに、川上の捲上線に伝って登り始めるのと、カッキリ同時に、その腰の痛みが上の方に上って来るのを覚えた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹はむしゃくしゃすると同時に堪えぬなつかしさの痛み、悔いないでよいことへの悔い――そういったことでごちゃごちゃになっていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは腰の痛みの軽い日は、杖に縋りながらでも、笠寺観音から、あの附近に断続して残っている低い家並に松株が挟まっている旧街道の面影を尋ねて歩いた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう物の運動に関係した問題に触れ初めると同時に、今までそっとしておいた力学の急所がそろそろ痛みを感ずるようになって来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロレンツのごとき優れた老大家は疾くからこの問題に手を附けて、色々な矛盾の痛みを局部的の手術で治療しようとして骨折っている間に、この若い無名の学者はスイスの特許局の一隅にかくれて、もっともっと根本的な大手術を考えていた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この急所の痛みは、他の急所の痛みが消えたために一層鋭く感ぜられて来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいくら念仏を唱えても、今の自分の心の痛みが少しも軽くなると思えなかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には痛みなしに歯を抜くためテスラ電流を用いる事。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛みが突きつめれば突きつめるほど小砂は真珠になる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた友の肉体に潜んだいろいろな苦悶と疾患とが、友を非常な神経質な針のさきのやうなちくちくした痛みを絶えず経験させた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりでゐることを、ひとりで祈ることを、ひとりで苦しみ考へることを、ああ、その間にも彼の疾患は辛い辛い痛みを加へた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世にも稀有な鬼才をもちながら、不幸にして現代に認められることが出来ないで、あまつさへその若い生涯の殆んど全部を不治の病床生活に終つて寂しく夭死して仕舞つた無名の天才画家のことを考へると、私は胸に釘をうたれたやうな苦しい痛みをかんずる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、そこ拭いとけ」Ｓ＝屋根裏　痛みに夢中の石松。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）　＝（Ｆ・Ｉ）夜の町　惨々な目に遭って節々の痛みに足を引き摺り乍ら帰って来る典六。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "下腹で空腹の時のような痛みがする。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "この長い手紙、と云ふよりもこの部厚な手記を前觸れもなく突然私の手から受け取つた時、お前がどんなに怪しんで胸を轟かすか、そして、またこの手記の一句一節を次第に辿つて行く時に、お前の心がどんなに痛み、どんなに悶えるか、それは私によく分つてゐる。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この手記に書かれてゐる事柄をお前に打ち明けようとして、私が四月餘りをどんなに苦しみ、どんなに惱んで來たか、それはこの手記を讀んでみれば自然お前にも分るだらうと思ふが、きつとお前の痛み悶えと、その強さは少しも變らないに違ひない。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その日も、その翌日も、檢温器の示すお前の體の高い熱や、またお前の訴へる腹部の痛みを單純な膓加答兒ぐらゐに思ひ過して、お前自身も私も深くは氣に留めなかつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、コロロホルムの麻醉に、手術の痛みも、夢中な自分の詞も、私の苦悶も、私の昏倒も、そしてすべての人達の懸念も焦慮も知らずに過ぎたに違ひないお前を、何となく一番幸福者のやうに感じたのだつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『死がすべてを葬つてしまつた今、この手記の發表は藤子に取つて何等の心の痛みともなるまい‥‥』と、水野はこの手記に添へて私に書いてゐる。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ兄は手に水桃をささげもち、いつさんにきみがかたへにしたひよる、この東京の日くれどき、兄の戀魚は青らみてゆきて、日毎にいたみしたたり、いまいきもたえだえ、あい子よ、ふたり哀しき日のしたに、ひとしれず草木の種を研ぐとても、さびしきはげに我等の素脚ならずや。",
              "citation": {
                "source": "幼き妹に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "damage",
