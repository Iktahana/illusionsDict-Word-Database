          "literary": [
            {
              "text": "いざ行かん露もつ尾花をみなへし目うつりのよき野辺の秋見に武人。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは行かんいざ行かん。",
              "citation": {
                "source": "偏奇館吟草",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ行かんヒマラヤの雪ふみわけて　　　　法の道とく国のボーダに　ボーダというのはチベットの国の名でサンスクリット語でそういうのであります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道の果てるところまで、いざ行かん。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
