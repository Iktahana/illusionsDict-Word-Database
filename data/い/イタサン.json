[
  {
    "uuid": "dd3725bf-1fae-5717-9e87-62adccae4eab",
    "entry": "板さん",
    "reading": {
      "primary": "いたさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
