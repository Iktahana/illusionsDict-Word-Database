        "examples": {
          "standard": [
            {
              "text": "プロジェクトの重大な遅延を知り、部長は怒り心頭に達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政府の不正行為が暴露され、国民は激しく怒り心頭に達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の友人に裏切られた彼は、怒り心頭に達して声を荒らげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "法廷で証拠が偽造されていたことが明らかになり、検察官は怒り心頭に達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、そんなことを！」と、被害者は怒り心頭に達して叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "何度頼んでも改善されない状況に、彼はついに怒り心頭に達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の研究成果が、単なる計算ミスで覆される可能性を知り、研究者は怒り心頭に達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
