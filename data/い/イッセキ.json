    "definitions": [
      {
        "index": 1,
        "gloss": "one boat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "港には漁船が一隻、静かに停泊していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "湖の上を、観光客を乗せたボートが一隻ゆっくりと進んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "難破船の破片とともに、小さな救命ボートが一隻、海岸に流れ着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「青島には巡洋艦が一隻と、駆逐艦が四隻も碇泊してるのよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の入口の暗礁へ一隻の駆逐艦が打つかって沈んでしまったのだ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年研究して自信のついたころ、やはりおなじ師命をうけてペッケンにおもむくトオマス・テトルノンという人と、めいめいカレイ一隻ずつに乗りつれ、東へ進んだ。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤネワを経て、カナアリヤに至り、ここでまたフランスヤの海舶一隻ずつに乗りかえ、とうとうロクソンに着いた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝永五年の夏のおわりごろ、大隅の国の屋久島から三里ばかり距てた海の上に、目なれぬ船の大きいのが一隻うかんでいるのを、漁夫たちが見つけた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、その日の黄昏時、おなじ島の南にあたる尾野間という村の沖に、たくさんの帆をつけた船が、小舟を一隻引きながら、東さしてはしって行くのを、村の人たちが発見し、海岸へ集って罵りさわいだが、漸く沖合いのうすぐらくなるにつれ、帆影は闇の中へ消えた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は好奇心の余り、小樽港に碇泊している船について調べて見たが、一隻の軍艦もいないことを発見した。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七回　印度洋の海賊水雷驅逐艦か巡洋艦か――昔の海賊と今の海賊――海底潜水器――探海電燈――白馬の如き立浪――海底淺き處――大衝突　私が一心に見詰めて居る間に、右舷に緑燈、左舷に紅燈、甲板より二十｜尺以上高き前檣に閃々たる白色燈を掲げたる一隻の船は、印度洋の闇黒を縫ふてだん／″＼と接近して來た。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が弦月丸が將に子ープルス港を出發せんとした時、何故ともなく深く私の眼に留つた一隻の怪の船を。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』の號令の下に、軍艦「日の出」の士官水兵は勇氣百倍、息をもつかせず發射する彈丸は、氷山碎けて玉と飛散る如く、すでに度を失つて、四途路筋斗の海賊船に、命中るも／＼、本艦々尾の八｜吋速射砲は、忽ち一隻を撃沈し、同時に打出す十二｜珊砲の榴彈は、之れぞ虎髯大尉の大勳功！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程吾々凡人より高く一隻眼を具して居ないとあんな御手際は覚束ない。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ二隻のランチに一隻ずつ曳かれた私たちの大｜団平船が、沿岸に蘆荻が繁って、遥かの川上に中部樺太の山脈が仰がれ、白樺、ポプラ、椴松、蝦夷松の林を左右に眺めて、一時間も幌内の大河を溯航した壮快さを伝えて置きたい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ一隻の舟が著いて、中から江戸の相撲が大勢出た。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾百種の新聞雑誌に散見する議論にはすこぶる高尚なるも多きを、余は通信員となりし日より、かつて大学にしげく通いし折、養い得たる一隻の眼孔もて、読みてはまた読み、写してはまた写すほどに、今まで一筋の道をのみ走りし知識は、おのずから綜括的になりて、同郷の留学生などの大かたは、夢にも知らぬ境地に到りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八九年の三月、アピア湾内には、米艦二隻英艦一隻が独艦三隻と対峙し、市の背後の森林にはマターファの率いる叛軍が虎視｜眈々と機を窺っていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像を絶した大暴風雨がまる一昼夜続いた後、前日の夕方迄｜碇泊していた六隻の軍艦の中、大破損を受けながらも兎に角水面に浮んでいたのは、僅か一隻に過ぎなかった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従士曾根孫六進んで水に入り、一隻を漕ぎ還ったので、次々に船を拉し来って全軍を渡す事が出来た。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一隻は翅を近き巖の頂に斂めて、晴れたる空の日を凝矚すること、其光のあらん限を吸ひ取らんと欲する如くなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一隻は高く虚空に翔りて、大圈を畫し、林すを見る。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "母鳥は悲鳴して、巖角なる一隻の雛を顧みるに、こもいつか在らずなりて、首を仰いで遠く望めば、只だ一黒斑の日に向ひて飛ぶを見き。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その迅雷風烈を放ち出す手は、また一隻の雀をだに故なくして地に墮すことなきなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち一隻の舟ありて、漁父等の立てる岬の下より、弦を離れし征箭の如く、波平かなる海原を漕ぎ出で、かの怪しき島國の方に隱れぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸邊には一隻の帆船を繋げるを見る。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "母これを銜えて巣に奔り帰りその子を｜是個の山猫来れり云々、只見る一隻の班爛虎〉」とあり云々」、これも伯欽が勇を恃んで虎を山猫と蔑語したのだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "（原注二一）「月曜日に税関付きの荷揚げ舟の船夫の一人がセーヌ河を流れる一隻の空ボートを見つけた。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾百種の新聞雜誌に散見する議論には頗る高尚なるも多きを、余は通信員となりし日より、曾て大學に繁く通ひし折、養ひ得たる一隻の眼孔もて、讀みては又讀み、寫しては又寫す程に、今まで一筋の道をのみ走りし知識は、自ら綜括的になりて、同郷の留學生などの大かたは、夢にも知らぬ境地に到りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊家甚だ喜び、延き入れると、僧その僕に街東第幾家に往って、花雌鶏一隻を買い来らしめ、殺し煮て肉を折り、盤に満て霊前に分置し、その余りを食い、挨拶なしに去った。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには一隻の舟が絶えず波に漂つてゐる……。",
              "citation": {
                "source": "旅から帰つて",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争が始まる前は、神戸の微々たる貿易商であったのが、偶々持っていた一｜隻の汽船が、幸運の緒を紡いで極端な遣繰りをして、一隻一隻と買い占めて行った船が、お伽噺の中の白鳥のように、黄金の卵を、次ぎ次ぎに産んで、わずか三年後の今は、千万円を越す長者になっている。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
