        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "空が急に暗くなり、何か忌まわしいことが起こる前兆のように感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その古い屋敷からは、常に忌まわしい気配が漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "警告もなく突然鳴り響いたサイレンは、忌まわしい事態を予感させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
