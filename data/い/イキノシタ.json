        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "突然の訃報を聞いた時、彼女は思わず息の下をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "急な上り坂を全力で駆け上がると、激しい運動による息の下がついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "暗闇から何かが飛び出してきたかのような音に、彼は「ひっ！」と息の下を漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "医師は、患者の異常なバイタルサインに一瞬息の下をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "信じられない光景を目の当たりにして、観衆は一斉に息の下をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "背後から急に名前を呼ばれ、作業員は驚いて息の下をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "苫がばらばらと煽ったが、「ああ」と息の下に叫ぶ声。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お沢　（息の下にて言う）俳優です。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、苦しい息の下から一ことそう言うのさえやっとで、何か冗談を言おうと思っても、すぐ吐きそうになり、黙って這うようにして衣服を取りまとめ、スズメに手伝わせて、どうやら身なりを整え、絶えず吐き気とたたかいながら、つまずき、よろめき、日本橋の待合「さくら」を出た。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、苦しい息の下から囁く。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と息の下で詫びまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、今、たえだえの息の下にこの手紙をかくのです。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い息の下にスヤスヤと眠って居られるばかりである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢が覚めたように、起上って、取乱した態もそのまま、婦同士、お綾の膝に乗掛って、頸に手を搦みながら、切ない息の下で、（済まないわね。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はの際に赦したと、俺が一言云つたらば、あの苦い息の下から嬉いと言つたが、宮、貴様は俺に赦されるのがそんなに嬉いのか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は苦しい息の下で、泣きながら男に詫びた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、かわいそうとおぼしめしくださりましたら、はようこれなる書き置きをご覧くださりませ」　苦しい息の下からあえぎあえぎ語り終わると、女は用意の一封を右門の手に渡しておいて、ばったりそこへあけに染まりながらうち伏しましたので、右門も今はなんじょうちゅうちょすべき、ただちにその封を押し開きました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "次右衛門は刃物で喉と胸を刺されていたが、微かな息の下で云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわててとんで來た法廷警固の看守たちが彼の兩腕をおさへ、折重なるやうにしてそこへ引き据ゑたあとあとまでも苦しい息の下から彼は喚きつゞけてゐた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女が別れのときに苦しい息の下から言わんとした意味はよく私にわかっていた。",
              "citation": {
                "source": "三角形の恐怖",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ赦して下さい」と苦しげな息の下から止ぎれ止ぎれに言って、あとはまた眼を閉じ、ただ荒い息づかいが聞えるばかりでした。",
              "citation": {
                "source": "臨終まで",
                "author": "梶井久",
                "note": "青空文庫"
              }
            },
            {
              "text": "喘ぎかかる息の下から仏壇を仰いだ。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い処女が若い男の息の下に抱きすくめられたその瞬間の様な海のはげしい乱調子な鼓動はそのトキーントキーンと云う音を空の末地球全体にひびかせて千世子の前にせまって来た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿駒は苦しき息の下より、「いやとよ。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "百歳に近い老人が死床にいて、苦しい息の下から遺言をするような場合も、音声は相当ゆがんでいるであろう。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはともかく、人殺しみたいに、ぼくのくびをしめるとはなにごとだ」　隆夫は苦しい息の下から、あえぎあえぎ、相手をののしった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星人の、のたうち廻るのを押さえつけながら、先生は苦しい息の下に、なおも敵の体に気をつける努力を忘れなかった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その苦しい息の下からも、二人を相手にすることは忘れなかった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が恋したのはこんな夜であった」コンラは息の下に云った。",
              "citation": {
                "source": "かなしき女王",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "コルマックは太陽の光のような様子をしていると彼等は言った、そして太陽の火のような、と息の下につぶやく一人の女があった。",
              "citation": {
                "source": "琴",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『では妾は形ばかり主馬之進様の妻となり……』こうして妾は良人の死後……」「その御先代の死態だが……」　いよいよ迫る死の息の下で、主馬之進は云いついだ。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも断末魔の息の下で、「主水様、この世の名残りに、お目にかかれて本望でござんす……二人一緒に旅はしましたが、とうとう最後まで赤の他人……今はやっぱり陣十郎殿の女房……良人に討たれて死にまする」「討て主水！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」暴風雨の中の呻き声　致死期の苦しい息の下からこう妹に掻き口説かれても紋十郎は応とも云わず、さりとて否とも云い兼ねてただいつまでも黙っていた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦し気な息の下から、彼は弱々しい声で、「保元平治の乱以来、たびたびの合戦に殊勲を立て、太政大臣に昇り、帝の御外戚にまでなることができ、思い残すことはないが、唯一つ、伊豆の流人頼朝の首を挙げなかったことだけが心残りだ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第六巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「用人の進藤市太郎は、最初惡人に引摺られたが、美しい奧方と一緒に居るうち、本當に惡い望みを起して、奧方に無禮なことをしたのさ――、末期の苦しい息の下から、奧方の方を拜んだと聽いて俺は大方察したよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "第廿七吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭の忠五郎は重態でしたが、毒を盛つたのが若旦那の重三郎と聽かされると、「惡いことは出來ません、皆んな私の至らぬことから起つたことで御座います」　と、苦しい息の下から懺悔をします。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
