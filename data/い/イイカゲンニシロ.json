          "literary": [
            {
              "text": "田島はおどろき、「バカ野郎、いい加減にしろ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを信ずる奴があったら「へえ柿江がかい」と愛嬌にしないとも限らないし、しかしたいていの奴は「ガンベのちゃらっぽこもいい加減にしろ」と笑ってしまうに違いない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘を救うために、証拠にその着物がいるんだ」針助「そんなこと、おれは知らん」小沢「白っぱくれるのはいい加減にしろ、唖の娘に今日刺青をしたのは誰だ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘も、いい加減にしろ。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦土の中の片隅の話をとらえて「浪花ッ子の意気」とは、空景気もいい加減にしろといいたかった。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり世界第一等の色気の深い香水の材料になります訳で、今の林君の話のスカン何とかチュウ処の鯨よりも日本の鯨の新婚旅行の涎の方が何層倍、濃厚いそうで……」「オイオイ仁三郎……ヨタもいい加減にしろ」　林技師がタマリかねて口を出した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減にしろ、伝馬まで乗り逃げやりやがって。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "出たらめもいい加減にしろ」　腕を捻じあげられて、藤助は意気地も無しに泣き叫んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "真逆学生たちに「講義なんかいい加減にしろといわれたから」と云って退場するわけには行かないから、急用だといって講義を打切った。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "親泣かせ兄弟泣かせもいい加減にしろ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いい加減にしろよ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減にしろ」「あら。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、冗談もいい加減にしろ」と、私もしまいにはたまらなくなって、言った。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くあきれて物がいえないとは、お前のことだ」「いい加減にしろ、ひとを小ばかにすることは……」「だって、今日はイネ国滅亡の日だ。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白ばっくれるのもいい加減にしろよ。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜口　馬鹿もいい加減にしろ。",
              "citation": {
                "source": "喪服",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵜瀞　　（起つて行つて納富を席につかせ、無理に盃を押しつける）納富　　よし、よし、もう少しだから……（起たうとするが、鵜瀞は起たせない）金田　　おい、鵜瀞君、いい加減にしろよ。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつその心配はいい加減にしろという奴を頼んで見給え。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノッケから、いい加減にしろよ」「ホントなんです。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのなにか、私、お六ちゃんに不都合でも」「ナナ、なにを言やがるんでえ」　なめるのもいい加減にしろと言わないばかりの顔をして、「白ア切るならこっちで言ってやらあ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いい加減にしろイ、大馬鹿野郎」　目と目があうとすぐいった、ガクガク入れ歯を噛み鳴らしながら。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトで小父さんがうんと美味しい南京豆買ってやるからな」「この馬鹿野郎、いい加減にしろ」　あっけにとられていた男の子が廊下の彼方へ行ってしまったとき、白いほど青くなって飛び込んできた師匠の三遊亭圓朝だった。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお目覚めになるまでに帰りますから――」　本庄は苦い顔をして、「いい加減にしろよ。",
              "citation": {
                "source": "魔性の女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いい加減にしろ」「私の希望をのべているのよ」　彼はカチカチと歯を鳴らしながら、「悪女の深情けとは君のことだ。",
              "citation": {
                "source": "魔性の女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのつもりでいるか知らないが、あんな好人物を弄ぶのはいい加減にしろ。",
              "citation": {
                "source": "雪間",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "運がよいのか悪が強いのかお前みたいにズルイ奴はいないよ、十二年も生きのびるなんていい加減にしろと、萩原朔太郎は笑いながらいうかも知れない。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生いい加減にしろい！",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、いいかげんにしろ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志は軽くあしらって、「野蛮人、いいかげんにしろよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐れってば」「いやだよ」「いいかげんにしろ」　慶一も、ムキになったことが恥ずかしくなり、高志からすこし離れてソファに坐った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
