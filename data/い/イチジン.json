    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gust of wind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "窓を開けた途端、一陣の風が吹き込み、デスクに置かれた書類を派手に散らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蒸し暑い午後のグラウンドに一陣の涼風が吹き抜け、球児たちは一時の涼を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "行き詰まった組織に一陣の風を吹き込むべく、外部から若手コンサルタントが招致された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "激しい雷雨の前触れか、一陣の不気味な風が木々を大きく揺らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山頂の峠を越えると、一陣の突風が容赦なく登山客の体を煽った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "春の訪れを予感させる一陣の温風が、凍てついた街の空気をわずかに和らげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「嘘ですよ」一陣の風がスケッチブックをぱらぱらめくって、裸婦や花のデッサンをちらちら見せた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又五分位すると不意に思出したやうに一陣の風がどうつと吹きつけてしばらくは家鳴り震動する、又ぴつたりと止む。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また五分くらいすると不意に思い出したように一陣の風がどうっと吹きつけてしばらくは家鳴り震動する、またぴたりと止む、するとまた雨の音と川瀬のせせらぎとが新たな感覚をもって枕に迫って来る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一陣の風小高い丘を襲えば、幾千万の木の葉高く大空に舞うて、小鳥の群かのごとく遠く飛び去る。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この哀れなる姿をめぐりて漂う調べの身にしみし時、霧雨のなごり冷ややかに顔をかすめし時、一陣の風木立ちを過ぎて夕闇｜嘯きし時、この切那われはこの姉妹の行く末のいかに浅ましきやを鮮やかに見たる心地せり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　この時、風一陣、窓に近き栗の梢を魔ありて揉みしようなる音す。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその時なんという事なしに矛盾不調和を感ずる一方では、またつめたい薄暗い岩室の中にそよそよと一陣の春風が吹き、一道の日光がさし込んだような心持ちもあった事を自白しなければならない。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の上に立てられた三十年の空しい樓閣――それは今跡方もなく一陣の嵐に頽れてしまつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一陣の迅き風、一同｜聳目し、悚立す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "理学士は、それともなく石滝の奥ではないかと、ふと心着いて恍惚となる処へ、吹落す疾風一陣。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が歇んだので未醒画伯戦場ヶ原の真中へ三脚を立て、悠々写生を初めたところが、折悪しく吹き捲くって来た一陣の烈風に、画板を吹っ飛ばされ、絵の具は躍り出す、いやはや大｜狼狽。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "響は忽ち海上に當つて、天軸一時に碎け飛ぶが如く、一陣の潮風は波の飛沫と共に、サツと室内に吹付けた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人も大きに喜びたまい、睦じやかなる談話の花を、心無くも吹散らす、疾風一陣障子を開けて、お丹例のごとく帯もしめず、今起き出でたる風情にて、乱れ姿に広袖を引懸け、不作法に入来りて、御両方の身近に寄り、突然匍匐になりて頬杖つき、貞子の顔を上眼にじろじろ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の高信さんの籌略によつて、一陣の鋭兵が懷に伏せてある。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風一陣、さら／＼と木の葉を渡れり。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い革包を柳の下枝にかけて、帽子をぬいで、洋服のボタンをはずして、額の汗をふきながら一杯八厘の甘露を啜っている時、どこから吹いて来るのか知らないが、一陣の凉風が青い蔭を揺がして颯と通る。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一陣の風がスケツチブツクをぱらぱらめくつて、裸婦や花のデツサンをちらちら見せた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一陣の風が吹いて、漁船のあたりからおびただしく春の枯葉舞い立つ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花園の奇しき美の秘訣を問わば、かの花作りにして花なるひとり、一陣の秋風を呼びて応えん。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "林房雄トイウ名ノ一陣涼風ニソソノカサレ、浮カレテナセル業ニスギズ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一陣の風はさっと起って籠洋燈の火を瞬きさせた。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一陣風が吹くと、姿も店も吹き消されそうで哀な光景。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と一声｜屹となって、膝を向けると、疾風一陣、黒雲を捲いて、三世相を飛ばし来って、主税の前へはたと落した。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に一｜本、榎を植ゆ、年經る大樹鬱蒼と繁茂りて、晝も梟の威を扶けて鴉に塒を貸さず、夜陰人靜まりて一陣の風枝を拂へば、愁然たる聲ありておうおうと唸くが如し。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風一陣吹き出でて、船の動搖良激しくなりぬ。",
              "citation": {
                "source": "旅僧",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上甲板の欄干に凭りて秋天一碧のあなた、遠く日本海の西の波に沈まむとする落日を眺めつゝ、悵然たる愁懐を蓬々一陣の天風に吹かせ、飄々何所似、天地一沙鴎と杜甫が句を誦し且つ誦したる時、その船の機関長とか云ふ赭髯緑眼の男来つて、キヤン、ユウ、スペーク、エングリツシ？",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "棟近き山の端かけて、一陣風が渡つて、まだ幽に影の殘つた裏櫺子の竹がさら／＼と立騷ぎ、前庭の大樹の楓の濃い緑を壓へて雲が黒い。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "間広き旅店の客少なく、夜半の鐘声｜森として、凄風一陣身に染む時、長き廊下の最端に、跫然たる足音あり寂寞を破り近着き来りて、黒きもの颯とうつる障子の外なる幻影の、諸君の寝息を覗うあらむ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井方の第一陣、磯野丹波守は勇猛無双の大将だ。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "vanguard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
