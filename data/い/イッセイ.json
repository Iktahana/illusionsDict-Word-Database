    "definitions": [
      {
        "index": 1,
        "gloss": "simultaneous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "号砲とともに、数百人のランナーたちが一斉にスタートラインを飛び出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "春の陽気に誘われるように、公園のチューリップが一斉に花を開かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「安全確認！よし！」というリーダーの声に合わせ、作業員たちが一斉に持ち場へ戻る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それ等の者が、彼が渡り廊下に掛かるや「頼むぞ」といふ眼差を一斉にさし向けた時に、彼の頭の中では「よろしい！",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が這入つた時、教師達は誰も話をしてはゐなかつたが、それと知ると其処にゐた全部の者は一斉に、不馴れな人間に対する心意気のない、畏敬の表情を作つて差向けてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然向うの家の板塀へ何か打っつけた音がしたと思うと一斉に駆け出してそれきり何処かへ行ってしまった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後七時になるとレストラントの扉が一斉に開く。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三人がいよいよ成功してそのアメリカ人を取巻いて巣へ引上げようとかかるとみんな一斉に、「家族万歳！",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一人が云ひますとその人たちは一斉にジョバンニの方を見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一斉にその青じろい美しい時計の盤面を見あげながら。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草がみな一斉に悦びの息をします。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間に、よほどのぼんやりでない限りのすべての観客のおのおのの大きくみはった二つの眼が一斉にこの不幸な犯人の左の顋下の大きな痣に注がれるのはもとより予定の通りである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで約一キロメートル前方の山腹で一斉射撃の煙が見えたら、それから一秒余おくれて弾が来て、それからまた二秒近くおくれて、はじめて音が聞こえるわけである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏瓜の花が大方開き切ってしまう頃になると、どこからともなく、ほとんど一斉に沢山の蛾が飛んで来てこの花をせせって歩く。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリの夜の正零時に信号を発すると、海上の船は一斉に時計を験して幾何の遅速があるかを知る事が出来る。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客、動揺して一斉に一方を見る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家臣が一斉に頭を上げると、ナンとどれもこれも繃帯だらけ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓にゐる丈の人の手に持つてゐた武器は、大層嬉しさうなのと、それ程でもないのとの別はあつても、皆多少の忙はしさを見せて働いてゐたのだが、それが一斉に運動を止めた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の銅羅が暁を破ると見送人達は鉄梯子を下りて対岸に並ぶと、二度目の銅羅と一斉にわめき出す。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから牧師の祈りと、熱心な説教、そしてすべてが終わって、堂の内の人々｜一斉の黙祷、この時のしばしの間のシンとした光景――私はまるで別の世界を見せられた気がしたのであります。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一人が云いますとその人たちは一斉にジョバンニの方を見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人びとは一斉に息を殺してその微妙な音に絶え入っていた。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは日のよくあたる風の吹く、ほどよい湿度と温度が幸いする日、杉林が一斉に飛ばす花粉の煙であった。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心持よほどの大蛇と思った、三尺、四尺、五尺四方、一丈余、だんだんと草の動くのが広がって、傍の渓へ一文字にさっと靡いた、果は峰も山も一斉に揺いだ、恐毛を震って立竦むと涼しさが身に染みて、気が付くと山颪よ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "国賊逆徒、売国奴、殺せ、撲れと、衆口一斉｜熱罵恫喝を極めたる、思い思いの叫声は、雑音意味も無き響となりて、騒然としてかまびすしく、あわや身の上ぞと見る眼｜危き、ただ単身なる看護員は、冷々然として椅子に恁りつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と一斉に声を合わせるトタンに、故郷も、妻子も、死も、時間も、慾も、未練も忘れるのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も墨を敷いたやうなプラツトホームは、ざあ／＼と、さながら水が流れるやうで、がく／＼こう／＼と鳴く蛙の声が、町も、山も、田も一斉に波打つ如く、夜ふけの暗中に鳴拡がる。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、遠くに、行々子が鳴きしきつて、こゝに蛙がすだく――其の間を、わあーとつないで、屋根も門も見えないで、あの、遅桜の山のうらあたり、学校の生徒の、一斉に読本の音読を合はす声。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいのひとたちは祖母のまわりに駈せ集い、一斉に鈴虫みたいな細い声を出して泣きはじめた。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こどもが水へ落ちたんですよ」一人が言いますと、その人たちは一斉にジョバンニの方を見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」森が一斉にこたえました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」森は一斉にこたえました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しらない」と森は一斉にこたえました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
