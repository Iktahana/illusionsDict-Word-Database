    "definitions": [
      {
        "index": 1,
        "gloss": "provincial dialect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "電話の向こうから聞こえる祖母の田舎言葉に、心が和んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "面接では、つい田舎言葉が出ないようにと気を張っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は普段は標準語だが、地元の友達と話す時はバリバリの田舎言葉になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "小説の中で効果的に使われる田舎言葉が、物語に深みを与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "変な田舎言葉を笑われそうな気がした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それを嫁にどう云っていゝか、田舎言葉が出るのを恐れて、たゞ「ヘエ／＼」云っているばかりだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは田舎者だけにわかる心理で、田舎言葉を丸出しにしても笑われるし、また努力して標準語を使っても、さらに大いに笑われるような気がして、結局、むっつりの寡黙居士になるより他は無いのである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は紋切型の田舎言葉を書くように大阪弁を書いているのである。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて十分許りの間、田舎言葉で密々話し合つた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――たゞ私は、田舎言葉のまゝで無造作に放つた老爺の明るい、一つの声が、今でも耳に残つてゐる。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゴロスケつて何さ、田舎言葉は止めて下さいよう。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親も話はよくする方だったが、彼女の田舎言葉は十のうち九までは通じないのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地方の細かい双方の話題が暫く高田と梶とを捨てて賑やかになっていくうちに、とうとう栖方は自分のことを、田舎言葉まる出しで、「おれのう。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、私も田舎言葉になったりする。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が駅々へ着くたび昔聞き馴れた田舎言葉がなつかしく耳に響いて来る。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぢや僕も二十四で御嫁を御貰ひるけれ、世話をして御呉れんかなと田舎言葉を真似て頼んで見たら、御婆さん正直に本当かなもしと聞いた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ僕も二十四でお嫁をお貰いるけれ、世話をしておくれんかなと田舎言葉を真似て頼んでみたら、お婆さん正直に本当かなもしと聞いた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかと言つて、日本の田舎言葉はこつちが不案内である。",
              "citation": {
                "source": "クロムランクとベルナアルに就いて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "原作の会話は、勿論、所謂「田舎言葉」の写実ではなく、十分様式化され、洗煉され、詩化された独得のスタイルであるからさういふ味も訳語のうちに現はしたい。",
              "citation": {
                "source": "クロムランクとベルナアルに就いて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは私の聞きづらがっている、それらの田舎言葉さえ、何んだか遠い見知らない土地に来てそれを聞いてでもいるかのように、私にはなつかしく思われた。",
              "citation": {
                "source": "三つの挿話",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は冗長な田舎言葉で、越後亀田在の栃倉重吉と名乗り、連れは妹の八重であると名乗りをあげた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の見る所では、これは東京在来の町言葉で、「おとうさん」と云い、「おかアさん」と云い、或は略して、「とうさん、かアさん」と云うのは田舎言葉から転化して今は一般の通用語となったものである。",
              "citation": {
                "source": "申訳",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、おじいさんは田舎言葉でいいました。",
              "citation": {
                "source": "雪の上のおじいさん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふゥン、あっちア景気アよかどだい」「なンのああた、同じこッてすばい」　ツイ鷲尾も田舎言葉になりながら、店先へ入っていった。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "がやつと、それが田舎言葉の「べえ」の真似だといふことを知つて、私は思はず噴出してしまつた。",
              "citation": {
                "source": "打出の小槌",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷町の宵の口はかえって、深更よりものしずかで、いずれよからぬ場所へ通う勤番者のやからであろう、酔った田舎言葉が声高におもて通りを過ぎて行ったあとは、また寂然とした夜気があたりを占めて、水を含んだ風がサッと吹きこんでは弥生の枕もとをつめたくなでる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒をしました』と、浅野すかさず『鼻はだ迷惑いたしてござりす』ござりますを仙台の田舎言葉で浅野さんはござりすと言いました。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしが取り次いであげたから――なんですか、田舎言葉の、ゴツゴツした。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずこの種の地方語はいわゆる田舎言葉としておいおい擯斥せらるるようになった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎言葉には古言のまゝをいひつたへてむかしをしのぶもあれど、言の清濁をとりちがへて物の名などのかはれるも多し。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、学識と天分とを、豊に持った、青年教授として、好意に満ちた副島氏の紹介につれて、壇に上せられた自分が、どうしてこんな、田舎言葉が分らないと、白状出来よう、こう云って、正隆の頼りない、孤独な自尊心が呻くのである。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎すっかり田舎言葉で「いがねえか」など尻上りに云っている由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり田舎っぽい日にやけた顔色になって、落付いた少年ぽさで、田舎言葉で、見ちがえるようです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は、だからすぐ自然田舎言葉になって、周囲とも自然にとけ合ってしまうのね、先生もいい先生ですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
