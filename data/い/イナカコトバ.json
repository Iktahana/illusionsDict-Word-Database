[
  {
    "uuid": "a606885e-d840-58cb-8206-b9198638958a",
    "entry": "田舎言葉",
    "reading": {
      "primary": "いなかことば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
