          "literary": [
            {
              "text": "否も応もなく、私は出席せざるを得なくなったのである。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　否も応もなく、押しつけてしまうのだ。",
              "citation": {
                "source": "田園の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "店はだんだん寂れて、この盆には否も応もなく夜逃げでもしなきゃなるまい――と言っていました」「で？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年ぶりに盛岡へ出て来た父が、私の頭を見てキモをつぶし、否も応もなく、床屋の強制執行をされたこともあるが、これから話すのは、その少し前である。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして私は名刺を引ったくり取って否も応もなく外へ飛び出した。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "正篤には供のゆるしを得てあったのだが、間際になってその係りから云いわたされ、いやもおうもなく江戸に残されてしまった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
