[
  {
    "uuid": "55da136b-c80e-55bf-9d63-7d928de3f29d",
    "entry": "今も",
    "reading": {
      "primary": "いまも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
