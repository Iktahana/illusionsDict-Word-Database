          "literary": [
            {
              "text": "丹波、丹後の方から出て来る要所で、おそらく生野鉱山の開発と密接な関係があったらしい。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生野鉱山においでになりました山口青邨先生をお迎へしての句会は、夜でございますので帰る汽車がございません。",
              "citation": {
                "source": "椿子物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　しょうねんたんていだんのたったひとりのしょうじょだんいん、宮田ユウ子ちゃんは、ルビーでできた赤いカブトムシをもって、じぶんのうちのせっこうざいくのこうばにはいって、なにかやっていました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
