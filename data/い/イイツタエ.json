[
  {
    "uuid": "7f3a93aa-07d8-5264-9bf9-37f9f7da9c2d",
    "entry": "言い伝え",
    "reading": {
      "primary": "いいつたえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
