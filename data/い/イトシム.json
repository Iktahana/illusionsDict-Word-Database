[
  {
    "uuid": "1983c554-5f70-598a-b765-2c55c636a0ed",
    "entry": "愛しむ",
    "reading": {
      "primary": "いとしむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to love",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は古くなったぬいぐるみも、思い出が詰まっているからと愛しんで使い続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "過ぎ去った青春の日々を、懐かしく、そして愛しむように思い返す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は自らの作品を深く愛しんでおり、一つ一つに特別な思い入れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この土地の豊かな自然を愛しみ、後世に残していく努力が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "かの女の一般の若い生命を愛しむ母性が、この青年に向ってむくむくと頭を擡げる、この青年はどうかしてやらなければいけない。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ん坊が起きるじゃないか」　千代重がこんなにずけずけいうときは最も相手を愛しむ気持に充たされているときなのだ。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は尊み敬えと教うれば、舅姑は固より尊属目上の人なり、嫁の身として比教に従う可きは当然なれども、扨親しみ愛しむの一段に至りては、舅姑を先にして父母を後にせんとするも、子たる者の至情に於て叶わぬことならずや。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔だったらわたしなど、下々ものがこんなことを言ったら、慮外ものと、ポンとやられてしまうのであろうが、みんなが武子さんを愛しむ愛しみかたがわたしにはものたらない。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫に対する愛が、彼女にあれば――子を思う誠があれば――そうした間違いが、どうしてしでかされようかとは、誰人も思うところであるし、寛治氏が妻を愛しむ心が深ければ、そうした欠陥が穿たれるはずはないとも思うことでもあるが、人間は生ているかぎり――わけても女性は感情に支配されやすい。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に子を教うるがためには労を憚るべからず、財を愛しむべからず。",
              "citation": {
                "source": "教育の事",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸歌舞妓の歴史を愛しむ二老人にとつては、堪へられぬものがあつた。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは姉が須永に対する義理からでもあろうが、一つは自分に子のできないのを苦にしていた矢先だから、本気に吾子として愛しむ考も無論手伝ったに違ない。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を戒めても犒うても、其｜語つきには、おのれを叱り、我を愛しむ心とおなじ心持ちが感じられる。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "至極の大聖すら尚ほ子を愛しむ心あり。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "みゝずのたはこと（廿八版）　秋漸く深く自然も粛して人も自ずから真面目なる季節、燈下書に親しむ都門の読書生も、短日を愛しむ地方の勤労者も、課余業間時に『みみずのたはこと』を把りて其一二節を誦し見よ、自己及び自己の周囲に対し恒に新にして親切なる或る啓示と情味と従って力とを与えられん。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ雲から声が出て、「これは我が愛しむ子なり、汝ら之に聞け」という言を、三人の弟子は聞いた。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「汝はわが愛しむ子なり、我汝を悦ぶ」という声を聞いた。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天より声｜出ず、汝はわが愛しむ子なり、我汝を悦ぶ」。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもがはっきり向きを変えて、真正面から神の聖顔を見た時、その瞬間に「汝はわが愛しむ子、我汝を悦ぶ」という声を聞きます。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただちに雲が起こり来たってイエスをつつみ、雲の中から「これはわが愛しむ子なり、汝らこれに聴け」との厳かな神の御声がペテロたちの耳を打ちました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてイエスの変貌と、モーセ、エリヤの物語と、これらすべての出来事を冠するものとして「これはわが愛しむ子なり」との神の御声が響いたのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはその愛しむ子である。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　葡萄園のお話は、祭司長・学者・長老たちを農夫に譬えて諷刺せられたにとどまらず、イエス御自身の神から遣わされし者であること、しかも神の愛しむ子であり給うことを表明せられたものである。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前坂君への感謝の心と私の作歌を愛しむ心とを合せたものです。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイと吸い込まれるように迷れて来た蛍が、団扇の端にとまッたので、それを愛しむかのような沈黙をふとまもった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生のように惜しめと正成が言ったわけではあるまいが」「…………」「死ぬであろう戦場へおもむくのも、じつは命を愛しむわが命がさせていると、この心のあやしさ、正成もまた観きわめておる。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "強悪正成一人の罪としておけ……」「…………」「よいか、くるしむなればその心でなお一命を長らえて、次代の世の償いに生きて行くのが真に命を愛しむというものだ。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは己れと己れ等をいとしむ響を持つてゐた。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　和尚さんは、この一生懸命に喋る若者を、いとしむやうにやさしく見ながら、いひたいだけいはせてやつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いとしむような、艶やかな愛嬌に溢れている夫人の顔を、それ以上見るのが恥かしく、青年はまた視線をそらした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく融も、長いあひだの色々の場合に於ける自己保存の必要から、対立的に自我的にならずにはゐられない事情もあつて、彼女が母を失ふまでは、本当に彼女をいとしむことが出来なかつた。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひきり惨めな自分になることが、そして自分を無残に踏みつけてしまふことが、何より自分をいとしむ手段であるやうな、せつない口惜しい思ひがした。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一層文子をいとしむ心になるのであつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "由子は自然に目を伏せて、己れをいとしむ思ひのために淋しくなつてしまふのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
