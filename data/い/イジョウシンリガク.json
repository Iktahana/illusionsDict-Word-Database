        "examples": {
          "standard": [
            {
              "text": "大学で心理学を専攻するなら、異常心理学は避けて通れない科目だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事件の背景にある心理的な要因について、異常心理学の専門家が解説を加えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "臨床現場では、患者の行動を理解するために異常心理学の知見が活用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "異常心理学の研究は、精神疾患のメカニズム解明や新たな治療法の開発に不可欠な貢献をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近、人間の心の複雑さに興味を持ち、異常心理学に関する本を読み始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このセミナーでは、異常心理学における最新の理論と実践について議論する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "オカルティズムや異常心理学にはいささかなりと興味を持ったことがなかった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
