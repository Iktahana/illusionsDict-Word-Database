          "literary": [
            {
              "text": "言うに事を欠いて、この台察児に向って降伏をすすめるとは何ごとだ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうにことをかいて、金持の守護神の碑かとはなんだ。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
