[
  {
    "uuid": "a9e0d74b-d6fa-5012-b4ad-215751364c51",
    "entry": "行くあて",
    "reading": {
      "primary": "いくあて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
