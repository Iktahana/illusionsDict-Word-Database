[
  {
    "uuid": "faa0c5e4-edc5-5340-ae10-fe6d48a91d80",
    "entry": "息継ぎ",
    "reading": {
      "primary": "いきつぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
