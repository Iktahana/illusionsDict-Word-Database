          "standard": [
            {
              "text": "子供が落ちないように、庭に洗濯物を干すための物干し竿に頑丈な糸を張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テントを設営するために、ポールとペグを使ってロープ（糸）をピンと張る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "網戸の破れた部分を補修するため、新しい網の縁に沿って糸を張って固定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "遂に、他の者よりは大胆な、或はずつと辛抱のない、一匹の虫が、悪い場所を横ぎつて、切られた一方の端から、他の端へとその糸を張る。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
