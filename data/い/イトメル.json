    "definitions": [
      {
        "index": 1,
        "gloss": "to shoot dead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "猟師は、狙いを定めて一発で大鹿を射止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はコンテストで最優秀賞を射止め、一躍有名になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "長年の片思いの末、ついに彼は学園のマドンナの心を射止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "オリンピック選手は、金メダルという大きな目標を射止めるために日々練習に励む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "唱は蛍をあつめて東京の友達へ贈らうとしてゐたが、その間にも鼬を射止めるべく銃を抱へて、まことに殺伐な蛍狩りともつかぬ異様ないでたちだつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今パパがウールトオの狂犬を射止めるからな」　子供は此方へ振りむいた。",
              "citation": {
                "source": "生さぬ児",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを転がすか投げ上げるかして動いている所を横から射止めるのである。",
              "citation": {
                "source": "初旅の大菩薩連嶺",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶫を射止めるということはたとえ油囀りの最中の動かぬ姿勢であったにせよ、細かく顫えるはしばみの枝の中では、枝をくぐってひとなみの技では容易に射止められるものではなかった。",
              "citation": {
                "source": "姫たちばな",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本で金的を射止めるから」「へエ」「お前の顏を見ると、大概の的は逃げ出すよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本で金的を射止めるから」「ヘエ」「お前の顔を見ると、大概の的は逃げ出すよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "……野猿の群に射ちかける空鉄砲の音は、そのまま信之助の命を射止めるもののように思われる、割り竹で追い立てる下男たちの姿は、傷ついた信之助を追い廻す幕吏の手を想像させるのだ。",
              "citation": {
                "source": "春いくたび",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細面のところは兄に似ているが、唇もとの凛として力のある線、人を見るときの眸子の射止めるような光りは、兄と違って熱狂することを知らない、しずかな、むしろ冷たくさえある理知の質をあらわしている。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その射止めるような、じっと見上げるまなざしが、縋りつきたい気持を表白しているもののように大助には思えた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "射止めるようなはげしい双眸の光りが示すように、極端に世間と人を疑い惧れていたが、それさえ暫くは忘れはてた様子だった。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤尾は硬ばった顔をしてじっと障子のあなたをみまもっていた、あの射止めるようなまなざしである、額のあたりが石にでもなったように白く固くなってみえた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊千代はその眼を射止めるように見ながらいった。",
              "citation": {
                "source": "菊千代抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一矢で射止めることができると存じたゆえ、一矢だけ持って出たのでござる」「さもござろう」幸之進はにっと笑った。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一矢で射止めることができるのに、なんのために二の矢を持つ必要がござろうか。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓道の作法とは命矢を持つにあるのではなく、一矢で射止めるところにあるのでござる。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……このたびこそは一矢で射止めるに相違ございません、御心易く思召されてしかるべく存じまする」「そうか、そうだったか」光政はふたたび頷いた。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学趣味のある紀代子は豹一の真赧に染められた頬をみて、この少年は私の反撥心を憎悪に進む一歩手前で喰いとめる為にしば／＼可愛い花火を打ちあげると思った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうお察しでしょうが、あの船は、外部からの極めて大きな圧力に耐えるように、そして熱線を完全に防ぎ、それから放射性物質の浸透を或る程度食いとめるように設計されてある、つまり結局、原子爆弾の恐るべき破壊力にも耐えられるだけのことが考えられてあるんでさ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝都の四周を守る防空飛行隊と、高射砲の偉力とは、ついに敵機の侵入を完全に食いとめることができたのだった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを税関が喰いとめる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一八年に露西亜から独立したばかりで、そのとき四箇月間「人民の家」と称する共産党政府に苦しめられたことを人々はまだ悪夢のように語りあい、ソヴィエットの風が北部西欧へ侵入してこようとするをここで食いとめる防壁をもってみんな自任している。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢代は千鶴子と一緒にまた街を歩いていくに随い、食事場だけとは限らず、少し大きな商店はどこも店を閉めていて、どの入口のところにも店員の通いを喰いとめる罷業委員が張番をしていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "決河のように南下して来たロシヤの勢力を、身をもって喰いとめるのはその土地にいるものの豪胆さだけだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ塗料というのは、その恐るべきＢＢ火薬の爆破力を食いとめる力のあるふしぎな新材料であった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、いつも、蟻田博士の用意しておいた遮蔽網は、怪力線をくいとめる。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、常に自信と争わねばならず、何等か実質的に自信をともかく最後の一歩でくいとめる手段を忘れることができない。",
              "citation": {
                "source": "いずこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体の条件がよければマラリヤ療法でくいとめることができるが、僕の居たとき病棟の廊下をうろついていた四十ぐらいの女の脳梅毒患者は、もう肉体力がなくて、マラリヤ療法を施し得ず、仕方なしに、ペニシリンを打ったり、人工栄養などで、ようやく生きて、痴呆状態で廊下をうろついている始末であった。",
              "citation": {
                "source": "精神病覚え書",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二日目は、第一日目に看破した秘伝を用いて、三千円とちょッとだけの損失でくいとめる。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "からくもリンリの方をくいとめたが、流汗はくいとめることができなかった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "停電を見こしてこういう型、つまり危くズリ落ちそうなところで着物をおさえてくいとめる型を発明したとするなら、臨機の商才しかも必ずしもワイセツではなく、このへんは大阪商人の鬼才たるところであるかも知れん。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
