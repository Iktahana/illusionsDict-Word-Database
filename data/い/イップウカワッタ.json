[
  {
    "uuid": "2d69f5ac-a062-5ea1-ab5a-051333dadf08",
    "entry": "一風変わった",
    "reading": {
      "primary": "いっぷうかわった",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
      "ctype": null,
