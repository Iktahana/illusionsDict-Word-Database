    "definitions": [
      {
        "index": 1,
        "gloss": "controlling foreigners by foreigners",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
