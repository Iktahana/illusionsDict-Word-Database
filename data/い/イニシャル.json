        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "プロジェクトのイニシャル段階では、まだ方向性が固まっていなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼が提案した計画は、イニシャルレビューで却下されてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イニシャル設定が複雑で、使い始めるまでに時間がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
