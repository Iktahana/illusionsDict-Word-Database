[
  {
    "uuid": "5dbe0478-c310-578a-bc15-530d6b009166",
    "entry": "居候",
    "reading": {
      "primary": "いそうろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lodger who pays nothing for room and board",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大学進学を機に、しばらく叔父の家に居候することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "居候の身なので、せめて家事くらいは手伝わないと肩身が狭い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は画家として成功するまで、実家に居候しながら創作を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "突然家を追い出され、友人のアパートに居候させてもらうしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "主君を失ったその浪人は、旧知の友人を頼ってしばらくのあいだ居候の世話になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "定職に就かず姉の家に居候しては、遊んで暮らしている彼の将来が案じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "居候とはいえ、家のことを何もしない彼の態度に、家族は不満を募らせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「いつまで兄貴のところに居候しているつもりだ？」と、彼はバツが悪そうに俯いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "誠に晩春より初夏へかけ（ここの赤裸々となるは、夏期わずかの間に候）最も歴々と仰がるべく、夏にても、形は明確に、白雪山を埋むる今にても、こを恋人とせる小生の目には、同じ雪に蔽われながらも、この鳥形のみは粗き山の膚（元より白色）の中に、滑らかに平に浮び出で居候が、認められ候。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学がキャピタリズムやミリタリズムやないしボルシェヴィズムの居候になっているうちは、まあ当分見込がなさそうに思われる。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居候の書生に主人の先生が示す恩愛です。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩地の台所から音信れたら、叔父には内証で、居候の腕白が、独楽を廻す片手間に、この浦船でも教えてやろう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひき更えて小野の方は、画学校時代にこそ秀才で通ったこともあるが、彼の奉じている浪漫主義の影が薄れ無論天性の不勉強も祟って、今では全く尾羽打ち枯らしてしまって、ただ学生当時からの情誼で葛飾の画室を半分貸して貰いながら居候同様に同居しているわけであった。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも何か居候のような気がして、これが自分の家という感じがしなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は二度も罹災して、とうとう、故郷の津軽の家の居候という事になり、毎日、浮かぬ気持で暮している。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がこの家へ来てからは、道化を演ずる張合いさえ無く、ただもうヒラメと小僧の蔑視の中に身を横たえ、ヒラメのほうでもまた、自分と打ち解けた長噺をするのを避けている様子でしたし、自分もそのヒラメを追いかけて何かを訴える気などは起らず、ほとんど自分は、間抜けづらの居候になり切っていたのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と居候の弟は、おっかなびっくり合槌を打つ。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居候の弟も、話が小説の事になると、いくらか専門家の気むずかしさを見せる。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、しくじったと居候はまごつき、「しかし、私は、どうも利休をあまり、好きでないんです。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の居候になっていながら、兄を一本まいらせようなんて事はしたくない。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居候でなくったって、私はいままで兄と競争しようと思った事はいちども無い。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、わが家にいながら、まるで居候の気持だった。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒不足の折柄、老生もこのごろは、この屋台店の生葡萄酒にて渇を医す事に致し居候。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい悪い事を、次々とやらかすので、ついには北さんのお宅の二階に押し込められて、しばらく居候のような生活をせざるを得なくなった事さえあった。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は焼け出されて津軽の生家の居候になり、鬱々として楽しまず、ひょっこり訪ねて来た小学時代の同級生でいまはこの町の名誉職の人に向って、そのような八つ当りの愚論を吐いた。",
              "citation": {
                "source": "嘘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "興世王もこれには憤然とせざるを得なかつたが、根が負け嫌ひの、恐ろしいところの有る人とて、それなら汝も勝手にしろ、乃公も勝手にするといつた調子なのだらう、官も任地も有つたものでは無い、ぶらりと武蔵を出て下総へ遊びに来て、将門の許に「居てやるんだぞぐらゐな居候」になつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「王の居候」だからおもしろい。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "居候の興世王は面白づくに、親分、縋つて来る者を突出す訳にはいかねえぢや有りませんか位の事を云つたらう。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのひと、あたしを女優にするんだと、ずいぶん意気込んでいるんだけれど、どんなものだろうねえ、数枝だって、あたしがいつまでも、ここで何もせずに居候していたら、やっぱり、気持が重いでしょう？",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのひと、あたしを女優にするんだと、ずいぶん意気込んでゐるんだけれど、どんなものだらうねえ、数枝だつて、あたしがいつまでも、ここで何もせずに居候してゐたら、やつぱり、気持が重いでせう？",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『新ロマン派』も十月号より購読致し、『もの想う葦』を読ませて戴き居候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "末筆ながら、めでたき御越年、祈居候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樂しき時刻といふもの何日よりか小生には無くなり候、拂曉に起き出でて散歩でもしたら氣が清々するかと存じ候へども、一度も實行したことはなし、何か知ら非常に急がしき事の起り來るを待設くる樣の氣持にて、其日々々を意氣地なく送り居候、然し、強ひて言へば、小生にも三つの樂しき時刻（？",
              "citation": {
                "source": "一日中の樂しき時刻",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、居候の私に、代理として一杯、いんえただ一つだけ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれ居候みたいだろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村のママの居候だからね――と言おうとしたが、さすがにそれは言いだしかねて、「――それより、田村の帰り、お通夜には来ない方がいいぜ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三｜両清兵衛は、馬のいそうろうになったぞ」　友人たちは笑った。",
              "citation": {
                "source": "三両清兵衛と名馬朝月",
                "author": "安藤盛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
