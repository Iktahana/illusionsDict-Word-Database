[
  {
    "uuid": "852ea47d-4c48-5c25-b662-d1472c9fb0d4",
    "entry": "一水",
    "reading": {
      "primary": "いっすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
