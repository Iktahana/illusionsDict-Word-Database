        "examples": {
          "standard": [
            {
              "text": "集中豪雨により、川が溢水し、周辺地域に避難勧告が出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "田んぼの用水路が溢水し、あぜ道が水浸しになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "貯水タンクの管理を怠ったため、溢水事故が発生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "時季によって溢水するであろう河原が、ごろごろと岩をさらして白く乾いていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼がつきて、溢水の落ちる堰のほとりに二三の飲食店があるが、その手前まで来たとき、お通は思いきり端折っていた裾を下ろすために立ち止り、帯の間へ手をやった。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、雨が四カ月半も続き、セーヌ川の溢水が三度も起こった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "こねえだの爆発の時だって、ここの先生が身の皮あ、はぐようにしてよ、三日三晩いっすいもせず、食うものも食わねえで、まっ黒になってケガにんの看病したなあ、デニス、お前だって見ているんだ！",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
