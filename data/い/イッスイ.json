    "definitions": [
      {
        "index": 1,
        "gloss": "current (of water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "谷間を流れる一水のきらめきが目に眩しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "城の周りを一水が巡り、天然の堀となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "枯れ果てた大地に、ようやく一水の恵みがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "上流には支流ありて中川にも通ずるをもて船の往来も少からず、隅田川の方より綾瀬橋といへる千住道にかゝれる橋あたりを望めば、一水遠く東に入りて景色おのづから小幀の画を為す。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ浅草区一帯の地の卑湿にして燥きがたきも、この一水路によりて間接に乾燥せしめらるゝこと幾許なるを知らざれば、浅草区に取りては感謝すべき水路なりといふべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "百本杭の下浅草側を西に入る一水は即ち○神田川なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この川は吹弾歌舞の地として有名なる○柳橋の下を潜り、また浅草橋左衛門橋美倉橋等の下を経、豊島町にて一水の左より来るに会す。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一水は○神田堀の余流にして、直ちに東南に向つて去つて、中洲下にて隅田川に入るものなるが、日本橋区を中断して神田川と隅田川とを連ぬるこの水路の上に○柳原橋、緑橋、汐見橋、千鳥橋、栄橋、高砂橋、小川橋、蠣浜橋、中の橋、その他の諸橋は架れるなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "材木町、東福田町地先にてこの水路と会する一水は即ち○今川橋下を流るゝ神田堀にして、御城外濠より竜閑橋その他諸橋の下を経て来れるものなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて神田川は上に述べし柳原橋下の一流に会するところより上○和泉橋下を経て、昌平橋、万世橋、御茶の水橋、水道橋、小石川橋を過ぎ、飯田橋手前にて西北より来り注ぐところの江戸川の一水を呑み、飯田橋上流牛込揚場に至つて尽く。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の下流｜少許にして東に入るの一水あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪川は一之橋二之橋竪川橋三之橋新辻橋四之橋等の下を経て、大島村小名木村亀戸村深川出村本所出村等の間を千葉街道に沿ひ、終に中川逆井橋下流に出づる一水路にして、甚だ重要なる一渠なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天神川は亀戸天神祠前に流るゝを以て名づけられたる一水にして、南は砂村より北は請地村に至るまでの間を南北に流るゝ一渠にして、丁字形をなして請地にて会する一水は、西中の郷にて堀溜となれど、東は境橋下を過ぎて中川に達する六間川これなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中洲の対岸一水遠く東に入るものを○小名木川とす。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小名木川の大川に会するところより下少許にして、また一水の大川より東南に入るあり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "深川側は既に説けり、日本橋側にありては仙台堀の対岸に神田川に達するの一水西北に入るあり、（既説）中洲の背後より箱崎と蠣殻町との間に存する一水あり、油堀と大川との会するところより下流に豊海橋の下を潜りて西北に入る一水あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ西岸の方より記せば、永代橋より下流幾許ならずして西に入るの一小渠あり、三の橋二の橋一の橋の三ツの橋の下を過ぎて亀島橋下を流るゝ一水に会す。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "京橋下の一流は御濠の鍛冶橋南より比丘尼橋紺屋橋を経て来り、京橋の東炭谷橋白魚橋の下に出で、こゝにて南は真福寺橋下より来る一水と会し、北は兜橋より弾正橋下を経来れる一水と会し、桜橋東にてまた南より来る小渠と会し、遂に中の橋稲荷橋下を過ぎてこゝに来れるなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この流れより下流、本湊町船松町の間に一水あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "明石町居留地の間を南して新栄橋下の一水に通ず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "明石町の南○明石橋下の一流は、築地一丁目二丁目三丁目を廻りて流るゝ釆女橋万年橋祝橋亀井橋合引橋築地橋軽子橋備前橋小田原橋三の橋等の下の一水に通ずる流れにして、栄橋新栄橋の下を過ぎてこゝに落つるなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○南小田原町の南、海軍省用地の北、安芸橋の架れる一水は三の橋の下流にして、三の橋上流より南の方海軍省用地に沿ひて尾張橋下を過ぎ、浜離宮脇より澪に入るの水と通ず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○浜離宮の北、離宮と海軍省用地との間の一水は前に説きたる如し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三十間堀即ち真福寺橋の流れの続きにして、豊倉橋紀国橋豊玉橋朝日橋三原橋木挽橋出雲橋等の下を流るゝ一水は、前の一水と新橋の下、蓬莱橋の上にて丁字形をなして相会す。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "振鷺亭が意妓の口に、大河の恋風は浮気な頬をなぐり、内川の旭は眼が覚めてから睡しといひたるも、おもふに古石場町富岡門前町などの間を行くこの一水を指したるなるべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に一水の熊井町中島町の間を北に行きて油堀仙台堀を連ぬるあり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ○下田川と称する名称のことを未だ説かざりしが、明治以前の雑書に時に下田川の名を記すものは、別に一水の流れをなすありて下田川と呼ぶところあるにはあらず、実に永代橋下流即ち隅田川本流の佃島近きところを指していへるのみ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸の山は或時は右が遠ざかったり左が遠ざかったり、また或時は右が迫って来たり左が迫って来たり、時に両方が迫って来て、一水｜遥に遠く巨巌の下に白泡を立てて沸り流れたりした。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こねえだの爆発の時だって、ここの先生が身の皮あ、はぐようにしてよ、三日三晩いっすいもせず、食うものも食わねえで、まっ黒になってケガにんの看病したなあ、デニス、お前だって見ているんだ！",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
