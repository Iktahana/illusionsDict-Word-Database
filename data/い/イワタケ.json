    "definitions": [
      {
        "index": 1,
        "gloss": "rock tripe (edible lichen used as medication in Korea, China and Japan)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
