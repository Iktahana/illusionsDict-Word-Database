        "examples": {
          "standard": [
            {
              "text": "設備の老朽化に伴う改修工事のため、来月から第一体育館を一時閉鎖する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事故車両の撤去作業により、高速道路の下り線が一部区間で一時閉鎖された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「システムメンテナンスのため、オンライン決済サービスを一時閉鎖させていただきます。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "火山活動の活発化を受け、登山口から山頂にかけての遊歩道が一時閉鎖された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "濃霧による視界不良のため、空港の全滑走路が一時閉鎖される事態となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「えっ、お気に入りのカフェが改装で一時閉鎖なの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "経営の合理化を進めるため、地方支店の一部窓口を一時閉鎖することが発表された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "五十人以上の職工を有する工場は例外なく患者を出して一時閉鎖するのやむなきに至った。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校も一時閉鎖となる有様。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
