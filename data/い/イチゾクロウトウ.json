[
  {
    "uuid": "734e9ab9-8695-57eb-86ce-c826e1b73f93",
    "entry": "一族郎党",
    "reading": {
      "primary": "いちぞくろうとう",
      "alternatives": [
        "いちぞくろうどう"
      ],
      "is_heteronym": false
    },
    "grammar": {
