      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's family and followers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一族郎党を引き連れての引っ越しは、さながら大名行列のようだった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "選挙戦が始まると、候補者の一族郎党が総出で沿道に立ち、必死に支持を訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事業に失敗した彼は、一族郎党を路頭に迷わせるわけにはいかないと、死に物狂いで再起を図った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "正月には本家に一族郎党が集まり、家長を囲んで厳かに新年の挨拶を交わすのが古くからの習わしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこは一族郎党で結束が非常に固いから、余所者が入り込む隙なんて微塵もないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "政争に敗れた大臣は、一族郎党とともに住み慣れた都を追われ、北方の地へと下っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それで、今仮に詩的性情を持つ一青年があつたとして、かの成巧せる実業家、成巧せる政治家が、子供や孫、一族郎党でもゐなかつたとしたら、どんなに退屈するものであるかは、一寸理解され難いのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　牡雀と牝馬　百姓の家の中庭に、雀の一族郎党が集つた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二日の夕刻、和田左衛門尉義盛さまは一族郎党百五十騎を率ゐて反旗をひるがへし、故右大将家幕府御創業このかた三十年、この鎌倉の地にはじめての大兵乱が勃発いたしました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠置の陥る前、護良親王を迎へ奉つた楠木正成は、笠置陥落後も、関東の大軍を迎へて、奇計を以て之を悩ますこと二十日に及んだが、遂に孤掌鳴りがたきを知り、城に火を放つて自殺と思はせ、護良親王を擁し一族郎党を引きつれ、風雨に乗じて、姿を晦ました。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「奴等のことだから何時もイカサマ術を用ひて分捕つてはゐるんだが、吹雪男が現れてからといふものは皆なその化物にさらはれてしまつて素寒貧となり、音無の親爺をはじめ一族郎党は気狂ひ騒ぎでありますよ。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行とは竹内栖鳳氏の一族郎党、並に大元洋行のお上さんである。",
              "citation": {
                "source": "長江游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一族郎党を父につけて、之を秀吉の陣に送り約をまもる。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてお尋ねの時間に於ては、この室内に僕一人が残っていた――とこう申上げると、貴方は喜ばれるのでしょうが、実はその時間フルに、一族郎党ここに控えていたんです。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸国の源氏が一族郎党をひきつれて急を知って馳せ向う大昔を思いだしていたのだ。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い昔、西を追われたらしい高麗の豪族の一族郎党大人数が、舟で逃げてきて、ここに上陸した。",
              "citation": {
                "source": "曾我の暴れん坊",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大喜びなのは、神様の一族郎党で、大半の信徒を失い、箱根山中にとじこもって、ほかに住むべき屋根の下もないところへ、東京のマンナカへ進出できることにあった。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると、一族郎党、神様をまもって、再びトラックに分乗し、神殿に定められた寮へ落ちつく。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「楠木兵衛尉正成なども、いざ事あがりましたる際におきましては、一族郎党をこぞりまして、金剛山の険によりお味方｜仕ると力強き誓言、播磨の赤松則村も、必ずお味方仕ると、いさぎよき誓約にござりまする。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頼兼も多治見ノ四郎二郎も、敵ながら天晴れに討ち死にし、一族郎党一人残らず、この世を去ってしまったのじゃ。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしお待ち」　宮家は切れ長の睫毛の濃い、涼しい御眼をパチパチとさせたが、「そんな筈ではなかったがな」「正成討ち死ににござります……一族郎党もことごとく戦死で。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正成腹切って死んだそうな」「一族郎党みな死んだらしい」「大塔宮様もご薨去じゃ」　が、背後の山や谷には、五人十人と組をなして、落ちて行く城兵の姿が見られた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、信長の家臣であった、吉利支丹大名高山右近が、木村摂津守の謀反事件に坐し、節を曲げず信仰を捨てず、かえって大名の身分を捨て、一族郎党を引き連れて、大船に乗じ日本を去り、南洋に渡って行った時、これを助けて行を盛んにしたのも、御嶽冠者と鳰鳥であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおかげで、子供の多い一族郎党が、ひとりの迷子も出さずに四谷の親戚の家に着いたのである。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術院の首領であつた岡倉覚三氏が、一時収めてゐた羽翼を張つて、再び美術界へ乗り出さうとした時で、一族郎党とゝもに、その仲間や新聞雑誌関係者などを、自分の隠棲地の五浦へ招いて、門出の盛宴を催したが、その余興の一つは盆踊りであつた。",
              "citation": {
                "source": "月を見ながら",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "各※一族郎党を率ゐて、山を越え谷を越え、焼けつくやうな道を歩いてやつて来る。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "清盛は、一族郎党をその夜の内に、ひそかに西八条の邸に召集した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して暗君ではないし、地方の豪族の主人として教養もあるほうだったが、この世代に一族郎党を統率してゆくには、多分に欠けているものがあった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、別所一族が七千余人を以て守る三木城の本拠そのものは、いわゆる天嶮を占めているし、一族郎党の血にむすばれている強兵だし、加うるに、海路毛利方から新鋭の武器兵糧も充分に籠め入れてあっただけに、到底、短期間にこれを攻めつぶし得る見込みはなかった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに老齢でもあり隠居同様な身分の彼ではあったが、ひとたび息子の官兵衛が伊丹の獄に監禁され、以後の生死も不明と伝わるや、この自髪の老鶴は、「一族郎党の浮沈、正に今に迫る。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一族郎党二百人も、共に改宗した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の羅馬と交渉のあったどこの国の歴史を調べてみましても、ペレニウスのペの字一つ見当らないばかりか、その一族郎党と覚しき者の記載すら、一字一句も見当らないのであります。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一族郎党、さだめし勇み立って戦うことでありましょう。",
              "citation": {
                "source": "紫大納言",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の将頼、将文を留守におき、自身は将平以下、一族郎党を数多ひきつれて、深大寺の境内に、宿営していた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その陣地は、幾つにもわかれていて、東国に住む平家方として、名ある大将が、それぞれ一族郎党をひきつれ、ここへ会して、「叛乱の不平分子ども。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
