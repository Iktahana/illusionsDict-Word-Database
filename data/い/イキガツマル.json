          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "厳格な父との食事は、茶碗の音を立てるのさえ憚られるような息が詰まる時間だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなに見つめられると息が詰まるよ」と、彼女は照れくさそうに視線を外した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "九回裏二死満塁。球場全体が、息が詰まるような緊迫感に包まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あまりに美しい夕景を前に、私は思わず息が詰まる思いがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒とコンクリートに囲まれた生活に、ふと息が詰まるような感覚を覚えることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "監視カメラに見守られたオフィスでの作業は、自由がなくて息が詰まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "締め切った室内は、埃と湿気で息が詰まるほど淀んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「さっきもいう通り、来年の三月には国へ帰って身請けの金を持って来る」「ほんとうざますか」「嘘はつかない」　次郎左衛門は息が詰まるほどに苦しくなった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が眩んで息が詰まる位ドエライ、モノスゴイものであった。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "息が詰まる」「何んで俺が血迷うものか。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い葛湯を呼吸するばかりに気息が詰まる。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "田鍋課長は先刻から愕きの連続で、息が詰まる想いだった。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五六歩よろけると、息が詰まる様で、たまりかねて荷を下ろす。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざあざあっと落ち来る太い雨に身の内｜撲たれぬ処もなく、ぐっと息が詰まる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたし一人で淋しいから、茂ちゃん、泊っておいでなさいな」「息が詰まるじゃないか、おばさん、どうしても放さなけりゃ、あたい、口笛を吹いて狼を呼ぶからいいや」「何ですって、狼を呼ぶ……？",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「胸苦しや息が詰まるわ！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第次第に息が詰まる。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横になると息が詰まるのだ。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しまいには、もう一分もこの病室にいたらきっと息が詰まる、とそんな気がする。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "息が詰まるような重苦しさだった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで文次ははじめて死に花の現物を手にとって見たわけだが、なるほど、小さいくせにまことにいやなにおいがして息が詰まるようだ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸田は息が詰まるやうで返事が出来なかつた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外へ出れば日光が恐いし、室内にゐれば息が詰まる。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは一日｜厭に暑くて、何やら気になるように、10840息が詰まるように蒸々していた。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにでも貼ってあったディ・ライ・アグリオン、龍蝶だ」　危うく息が詰まるところだった。",
              "citation": {
                "source": "理想",
                "author": "THE IDEAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い冬のあさ、小川でおしめを洗つているあなたの腕の、ももの肉を植えた個所がちぢれてくるということをきいたとき、私は息が詰まるような思いがしました。",
              "citation": {
                "source": "いまだ癒えぬ傷あと",
                "author": "――放射線火傷で右手をうしなつた木挽きの妻と河原にうつ伏せて死んでいた幼女に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜之助、その煙を払いながら太刀をつけて島田の周囲をグルグル廻っているうちに、眼が眩んで鼻血が出て、そこへ香の煙が濛々と捲いて来て息が詰まる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「己は息が詰まるような気がした。",
              "citation": {
                "source": "みれん",
                "author": "シュニッツレル　Arthur Schnitzler",
                "note": "青空文庫"
              }
            },
            {
              "text": "半歳ぶりで思いもかけぬ友の消息を得た嬉しさを、しみ／″＼と味わう暇もなく、自分の一生の運命にかゝわる重大な問題を、不意に鼻先へひろげられた彼は、暫く息が詰まるような、眼が眩むような心地に襲われて、戦慄しながら立ちすくんで居た。",
              "citation": {
                "source": "二人の稚児",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ていても息が詰まるようです。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やっぱり兄さんを疑っているの」「もう、その話は止してくれ給え、何だか息が詰まる様な気がする」「だって、一人でくよくよしてたってつまらないよ。",
              "citation": {
                "source": "疑惑",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ痛てえ、もう少しで息が詰まるとこだ。",
              "citation": {
                "source": "前途なお",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りにも突然で、不意打ちのため、フェンウィックは驚いて息が詰まるばかり。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、いきがつまるようなこともなかった。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
