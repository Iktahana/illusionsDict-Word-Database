[
  {
    "uuid": "e536fc88-9a19-5643-895c-9540e4eb847e",
    "entry": "印紙",
    "reading": {
      "primary": "いんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
