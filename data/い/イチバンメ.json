          ],
          "literary": [
            {
              "text": "――それは私共の第一番目の仕事であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目は「賀殿」というのであった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の一番目の嬢さんがまだ子供の時分この半身像にすっかりラヴしてしまって、おとうさんの椅子を踏み台にしては石像に接吻したそうです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目「嘆きの天使」はかつてスタンバーク監督ディートリヒ主演の映画を見ていたので、それとこれとを比較して見るという興味があった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目の同じようなシーンでは観客はまだそこに現われる群集の一人一人の素性について何も知らなかったのであるが、この二度目の同じ場面では一人一人の来歴、またその一人一人がアルベールならびに連れ立った可憐のポーラに対する交渉がちゃんとわかっている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　三人姫君「オヤオヤオヤ」と、一番目の娘と二番目の娘とは顔を見合せた。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マア何んと云う巨大な流星でしょう」と、一番目の娘も二番目の娘も眼を円くして叫んだ。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目の娘も二番目の娘も、森林を探検し得なかった臆病が露顕して真赤になった。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言は一番目「三国無双瓢軍扇」、二番目「ざんぎりお富」にて、権之助、左団次、仲蔵、半四郎、翫雀ら出勤す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年（癸酉）　一八七三○三月、村山座の一番目「酒井の太鼓」にて、権之助の酒井左衛門尉と菊五郎の鳴瀬東蔵との渡り台詞に「かく文明の世の中に、開化を知らぬは愚でござる」といい、観客はその時代違いを咎めずして、大いに喝采せり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、新富座の一番目「赤松満祐」中幕「勧進帳」二番目リットンの翻案「人間万事金世中」、大入りにて、六十余日を打ち続け、京浜在留の外国人より、引幕を贈りて総見物あり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目は「川中島」、二番目は「大丸屋騒動」。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七年（甲申）　一八八四○四月、新富座の一番目に「二代源氏誉身換」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目に左団次の「碁盤忠信」、二番目に菊五郎の「筆売幸兵衛」、いずれも初演にて好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○四月歌舞伎座にては一番目を「千本桜」に換え、二番目をそのままにして、菊五郎が河内山を勤めたるも、不入りに終る。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会の懸賞募集脚本に、長谷川時雨女史の史劇「花王丸」当選して、一番目に上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御褒美で、アアは王様の国を半分と一番目のお姫様を、サアはまた残りの半分と二番目のお姫様を貰って、二人共王様になり、お父様とお母様を半月宛両方へ呼んで、大威張りをしているところまで見えました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一番目は、開橋式が済んで間もない夜の八時頃、千住の紙工場に通っているお時という女工が、橋の中程、ちょうど女工の怪死していた上の方まで往くと、霧の中から真黒な目も鼻もない滑面の樽のような顔がぬっと出て、お時の顔を下から上へ撫であげた。",
              "citation": {
                "source": "堀切橋の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの児は、それ、墨の中に雪だから一番目に着く。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と異な声で、破風口から食好みを遊ばすので、十八になるのを伴れて参りました、一番目の嫁様は来た晩から呻いて、泣煩うて貴方、三月日には痩衰えて死んでしまいました。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御褒美で、アアは王様の国を半分と一番目のお姫様を、サアはまた残りの半分と二番目のお姫様を貰って、二人共王様になり、お父様とお母様を半月｜宛両方へ呼んで、大威張りをしているところまで見えました。",
              "citation": {
                "source": "奇妙な遠眼鏡",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィリアムソン君、ね、カラザース君、ウードレー君、――」「いや、その第一番目のは嘘だ。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目がロイロットさんの寝室、その隣が姉、次がわたくしのになっております。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪事には強い同族的類似性があってね、一〇〇〇の事件の詳細を自家薬籠中のものにして、一〇〇一番目の事件が解けないとすれば、それこそ奇妙な話。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "『拾得欄』の一番目に載っていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯りが暗いので全体に物凄い影がさして、紫色の耳から頸へかけての肉の色が、一番目立ってはっきりと見えた。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして第三百一番目の石蓋をよく調べて見たが何も別段異状はない。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛妓に言付けて、座敷を斜に切って、上口から箪笥の前へ引返すと、一番目の抽斗が半ば開いていた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "コスモスは白い花が一番目に立つ。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に見物人の中にまぢつて、一番目立つた汚ないぼろぼろ服をきて一番先頭に立つて門の開かれるを待つてゐて下さい」　とかういつてトムさんのお嫁さんは今日王様の家来に連れられていつてしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
