          ],
          "literary": [
            {
              "text": "いい意味での善良な国民、穏和な意味でのプロレタリアは、実際めいめいのまじめな仕事に真剣に従事している限り、拙速主義の疑わしい知識に飛びついて朝夕心を騒がせ気をいら立てる必要は毛頭ないのである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは全くいい意味で貴族的だねえ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい意味での青年の客氣といふものが無邪氣に出るのである。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい意味での女らしさとか、悪い意味での女らしさということが今日では大して怪しみもせずにいわれ、私たち自身やはりその言葉で自分を判断しようともしている。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからのいよいよ錯雑紛糾する歴史の波の間に生き、そこで成長してゆくために、女は、従来いい意味での女らしさ、悪い意味での女らしさと二様にだけいわれて来ていたものから、更に質を発展させた第三種めの、女としての人間らしさというものを生み出して、そこで自身のびてゆき、周囲をも伸してゆく心構えがいると思う。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のはじめての小説が発表されてから、母は、自分の満たされなかったいい意味での好学慾と、わるい傾向としての学問的世間的虚栄心とをごったまぜして、情熱的に私に集注しはじめた。",
              "citation": {
                "source": "母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうのは極めて自然な気持で、人生に対する見方や、気持の上に、あるいい意味での余裕ができた時に、そういう興味が起るもののような気がします。",
              "citation": {
                "source": "十年の思い出",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことを考えると、私は今何だかいい意味でだが笑えて来る。",
              "citation": {
                "source": "窪川稲子のこと",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロの技術者としての経験を積んでもいい意味でのアマチュアリズムを失わない男で、こんなオモチャじみたものの設計となると、他の人間ならふくれかねないものを、後藤はかえって嬉々としてアイディアをひねってくる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを大づかみに一括して「趣味」といふのだらうが、自分に出來ないことを羨ましがるのも、いい意味での趣味だ。",
              "citation": {
                "source": "水",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやだわ」　幸子には、いい意味でぼんやりなところがあり、朝子の動揺している心持を知っていても、実感としては、わからないらしかった。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は、もつと生活の中に、いい意味での芝居を造り上げなければならないのです。",
              "citation": {
                "source": "芝居と生活",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも女の云ふことは、誰でも聴くといふところに帰着するわけで、これは立派なフエミニズムで、いい意味での女性崇拝だ。",
              "citation": {
                "source": "文芸雑談",
                "author": "――某氏との談話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい意味でもわるい意味でもこのハイカラといふ言葉が専ら使用されてゐた。",
              "citation": {
                "source": "旧東京と蝙蝠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにもいい意味での封建の磨きのかかったような料理であった。",
              "citation": {
                "source": "牧野伸顕伯の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろは、いい意味でさえも野心の閃きというようなものが無さすぎる食卓に、技師は一種の騒々しさ、ソヴェト風な景気よさのような雰囲気をもたらした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらにとっては、大河は、最初の朝の板木一件以来、いわば、いい意味での一種の変人であり、何かしら人の意表に出るような親切をやって喜ぶ性質の人であった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこやらしず心がかえって来たのかしら（いい意味でよ）。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくどさがない、いい意味でも。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこといってとりたてて目にたつのではないがすべてが尋常に人好きのするほうであった顔になにかいい意味で技巧のかおりのする彫刻的な美しさがそわっている。",
              "citation": {
                "source": "妹の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなのは、けしからん生活力を湧き立たせることだが、いい意味での生活力も湧き立たせる。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさにショート・パンツの女王として撮った彼女の写真を、学校の新聞に一ページ大で掲載し、いい意味で評判になった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "つましい性格、いい意味で、つましいこと。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
