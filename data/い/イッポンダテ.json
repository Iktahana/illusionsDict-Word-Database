        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "来月、あの有名なオペラ歌手が、オール・リサイタル（一本立てのコンサート）を開くらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "展覧会では、孤高の画家が残した一点の絵画に焦点を当てた一本立ての展示が話題を呼んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台は、若手俳優が一人で演じきる一本立ての劇だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
