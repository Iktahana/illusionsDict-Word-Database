    "definitions": [
      {
        "index": 1,
        "gloss": "sweet potatoes baked in hot stones or pebbles",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
