        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "政府は、今日の臨時国会で医師法の改正案を提出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この症例は、医師法に定められた守秘義務に抵触する可能性があるため、慎重な対応が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "患者側は、医師法違反を理由に損害賠償を請求する意向を示している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "無免許医による医療行為が問題視される中、医師法に基づく免許制度の厳格な運用が改めて問われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "医学部では、臨床実習を通じて医師法に則った医療倫理や患者への接し方を学ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「医師法が定める基準を満たさない医療機関に対しては、行政指導を強化する必要がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "医師法｜違反になりはしませんか」　相手は静かに私の瞳を凝視した。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫草に欺瞞されて、医師法違反を敢えてされたのです」　相手の顔が突然、悪魔のように険悪になりました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "築地の曼陀羅病院長と仰言る方ですが……そうです、そうです……聞いた事のない病院ですが……例の彼女一流の芝居に引っかかって医師法違反までさせられたという事実を説明しに、わざわざ僕の処に来ておられるのですが。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活難という悩みはどの職業にも共通ですけれど、医師はそれ以外に医師法や刑法の窮屈な条文から起る種々な悩みがあります。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師法というものがあって、拙者が人助けのために精神病院を開業することができないのは実に残念至極である。",
              "citation": {
                "source": "深夜は睡るに限ること",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
