          ],
          "literary": [
            {
              "text": "きかなくてもいい時間をきいたのである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家の外塀を乗り越えて、三毛猫、白猫、黒猫、実にいろいろ近所の猫たちが入れかわり立ちかわりやって来ては、そのまま黙って通り過ぎてゆくものもあり、朝や午後からの陽あたりのいい時間には手すり廊下の一個所で、まことに心持ちよげに一刻の睡をむさぼってゆく。",
              "citation": {
                "source": "画室談義",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、もう、お目ざのおうたをうたってもいい時間ね。",
              "citation": {
                "source": "金のくびかざり",
                "author": "小野浩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからソーホー街へ出掛ければいい時間である。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしたは公休日の前日だから、いい時間にいらっしゃらないと何にもありませんよ」七月○日　○ちゃんが愈※明日出発。",
              "citation": {
                "source": "日記",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "役にも立たぬ手なぐさみや、一つ話題のくどくど話に、一日で一番いい時間と最上の精力をとられて、とどのつまり残るものといったら、何やらこう尻尾も翼も失せたような生活、何やらこう痴けきった代物だが、さりとて出て行きも逃げ出しもできないところは、癲狂院か監獄へぶち込まれたのにそっくりだ！",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚八とても目にアリアリと残っている情景、気色のいい時間ではないらしく、目をとじて、顔をふせたが、フシギや甚八の面色は土色に改まり、額に汗がうき、彼は握りしめた手をひらいて、急いで胸をかきわけるようにしたと思うと、前へのめって、畳をむしり、「ウッ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、戻ってもいい時間だ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、あした、あなたのいい時間によりましょう」　キャルディネ通りの下宿の経営者はふるい軍人あがりらしい老人であった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもいい時間です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えながら歩くこと、すなわち逍遙すること、それは哲学者にとってはいい時間つぶしである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食を食べ終えると、ちょうどいい時間となった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、夕食にちょうどいい時間になる」　海に沿ったハイウエイまで降りていき、再び海沿いを走った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰るのにちょうどいい時間だ、と彼は思った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食の進行に合わせて、五人はそこでいい時間を過ごすことが出来た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
