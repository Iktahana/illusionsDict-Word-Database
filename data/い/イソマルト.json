        "examples": {
          "standard": [
            {
              "text": "この美しい飴細工は、湿気に強いイソマルトを使うことで作られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "砂糖の代わりにイソマルトを使用したお菓子は、カロリーを抑えたい人に人気があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "糖尿病患者向けの食品には、血糖値への影響が少ないイソマルトがよく利用されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イソマルトは砂糖に近い自然な甘さがあり、後味がすっきりしているのが特徴です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新製品のチョコレートバーには、虫歯になりにくいイソマルトが配合されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自宅でシュガークラフトに挑戦する際、イソマルトを使えばプロのような仕上がりになります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
