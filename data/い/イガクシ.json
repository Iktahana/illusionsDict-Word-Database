[
  {
    "uuid": "0bf08a06-3025-5167-b0fa-6d30bff9be03",
    "entry": "医学史",
    "reading": {
      "primary": "いがくし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
