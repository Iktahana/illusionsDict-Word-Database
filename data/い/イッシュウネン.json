    "definitions": [
      {
        "index": 1,
        "gloss": "one full year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "近所のカフェが、開店一周年を記念してセールを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "私たちは、結婚一周年のお祝いにレストランで食事をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "バンドの結成一周年ライブは、多くのファンで満員になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "あしたは、姉さんの結婚満一周年記念日だそうだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時頃一緒に家を出て、途中、銀座に寄って、姉さんの結婚一周年記念のお祝い品を買った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三人の一周年号に出した「闘戦勝仏」といふ西遊記から材を取つたものが、処女作だらう。",
              "citation": {
                "source": "貧しき文学的経験（文壇へ出るまで）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「闘戦勝仏」は「十三人」の一周年号の時、同人が皆んな揃つて書くと云ふのだつたが、私は慥か、夏で、田舎へかへり、海へばかり這入つて居て、何も書けなかつた。",
              "citation": {
                "source": "あやふやなこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど亡き鳩を葬つた日の一周年にあたり、村の人が集まつてその塚に小さい碑を立てた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "日支事変一周年、正午のサイレンと共に黙祷、あゝ……あゝ。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は南京攻略一周年、いろ／＼のことを考へさせられた、――日本の事、支那の事、亜細亜の事、そして自分の事。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百十日、興亜奉公日一周年記念日、関東震災記念日。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう立札は一周年が過ぎたら取りこめられてもいいのではないだろうか。",
              "citation": {
                "source": "今日の耳目",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしたちは、こうして営々と三百六十五日を生きとおして今日に至っているのだが、さて、平和・民主の一周年を迎えたという晴々とした歓喜の表情は、おたがいの眼の裡にきらめいているだろうか。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女にとっては継子である嗣子夫妻との間に理解を欠き、亡夫の一周年でも過ぎたら、どうにかして、彼等は全く絶縁した生活を講じなければならない状態に成って来たのです。",
              "citation": {
                "source": "ひしがれた女性と語る",
                "author": "――近頃思った事――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ヤ一周年ノ忌辰ニ値ヒ、思旧感今ノ情ニ堪ル能ハズ、聊カ懇々ノ襟懐ヲ陳ズ。",
              "citation": {
                "source": "祭舌文",
                "author": "成島柳北",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三田の文人中近く海外より歸來せしもの文明を一覽して甚しく余が藝術家としての態度の不眞面目なるを攻撃したりと聞く」といふ一事より出發して先生の「文明一周年の辭」は起草せられしものなりとぞ。",
              "citation": {
                "source": "貝殼追放",
                "author": "「文明一周年の辭」を讀みて",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月六日◯広島へ原子爆弾投下の一周年なり。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　父の一周年記念日なり。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一周年前彼等が斗満に着いた其｜翌日も雨だった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年丁度引越しの一周年に、彼女はまた手土産を持って訪ねてくれた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの月がちようど新憲法実施一周年にあたるところからも、私の注意は、国の制度と社会生活の実態との関係に向けられたわけですが、そも／＼、日本の現実の社会と、新憲法の精神との間に、極めて不自然な開きがあるということを気づかぬものはひとりもいますまい。",
              "citation": {
                "source": "Ｓ夫人への手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "トヨタ自動車一周年を迎へて豊田喜一郎　昨年［一九三五年］十一月二十一日にトヨタ自動車が始めて形となつて皆樣の前に表はれたのでございますが、當時、私はノツピキならぬ用事のため、滿洲に旅行して居りました。",
              "citation": {
                "source": "トヨタ自動車一周年を迎へて",
                "author": "豊田喜一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国｜御用掛の交代に、江戸城を中心にした交易大評定のうわさに、震災後めぐって来た一周年を迎えた江戸の市民は毎日のように何かの出来事を待ち受けるかのようでもある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "この横浜は来たる六月二日を期して、開港一周年を迎えようとしている。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　近づいて来る六月二日、その横浜開港一周年の記念日をむしろ屈辱の記念日として考えるものもあるような、さかんな排外熱は全国に巻き起こって来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて滞留一周年の実地見学で、私はいよいよ北海道が将来有望の地であることを信じ、とりあえず相当の土地を札幌郊外に購入することを思い立って、出資を郷里に求むべく大いに望みを抱いて帰郷した。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一周年の命日には、厳粛な法要が営まれて、その後で、佐瀬弁護士から関係者一同に申上げ度いことがあるからというので、かつて遺言状を披露した時の顔ぶれを別室に揃えました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "音盤の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうじき父の一周年になります（一月三十日）。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつのタオルでともに手を拭い、洗面台の鏡に映っているヨシオに、「今日は一周年よ」　と、直子は言った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草奥山の植六を私の父が引き受けて花屋敷と改称、花卉盆栽のほかに虎熊などの動物を加えて開業ちょうど一周年。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出て、川口と話をする、三月を一周年記念興行として、脚本募集をしようと決定。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネ後、先日募集した一周年記念の脚本にいゝのがないので、こっちで書かうと、みやこで、菊田に「黄金狂時代」のアイデアを話す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪松坂屋ホール、新館一周年記念の会へ（150）、客とても敏感で、感じよかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
