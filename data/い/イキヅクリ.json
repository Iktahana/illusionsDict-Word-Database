    "definitions": [
      {
        "index": 1,
        "gloss": "sashimi prepared from live fish, arranged in its original shape",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "獲れたてのヤリイカを活き造りにすると、身が透き通っていて、口の中で上品な甘みが広がります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『うわあ、すごい！』と、運ばれてきた鯛の活き造りの豪華さに、家族全員が目を輝かせた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職人の鮮やかな手捌きによって、生け簀から揚げられたばかりの鯵がまたたく間に活き造りへと仕上げられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『見て、まだぴちぴちと動いているわ！』と、活きの良さを証明するかのような活き造りに驚きの声が漏れる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "活き造りならではのコリコリとした力強い歯ごたえは、鮮度を極めた魚でしか味わえない贅沢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "玄界灘の荒波で育った真鯛の活き造りは、遠方から訪れる美食家たちの最大の目当てとなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "活き造りは、魚を捌いた後も元の姿を保つように盛り付けるため、目でも楽しむことができる日本料理の真骨頂といえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "満座無言のなかで、注ぎきられたのと差出されたのとどちらが先だったかいまは忘れたが、いきづくりを肴に飲み回しの儀式であると辛うじて私は了解した。",
              "citation": {
                "source": "加波山",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
