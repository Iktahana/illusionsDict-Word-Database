          ],
          "literary": [
            {
              "text": "さういふ軽蔑のされ方ならその叔母のみならず毎度のことで、そんなことで腹が立つのでもなかつたが、何がなし癪に障つて、トラックの上にゐて顔に当る朝風は自分の一切合切をみる／＼削り減らしてしまふやうに感じられる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後不覚になつて、どうして寝床にはいつたやら、いつ寝たやら、一切合切不明なり、しかも些の不都合なし、善哉々々。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてＳさんの如く、実質に於いては、到れりつくせりの心づかひをして、さうして何やらかやら、家中のもの一切合切持ち出して饗応しても、ただ、お客に閉口させるだけの結果になつて、かへつて後でそのお客に自分の非礼をお詫びしなければならぬなどといふ事になるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切合切づぶ濡れだ、私ももとより一｜途もの。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切合切照りかへせ、私ももとより命がけ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一切合切種切れで、肴も附け合せも何にもありゃしねえでがす。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何もかもが、一切合切、妻のこと、子供のこと、その他で持ち切っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、この問題が、「いつかは現われるが、まだいつかそれはわからない」ような状態で、一、二か月も続くとすれば、彼は自分と三上との二つの行為をくるめて、道徳的にも、法律的にも――もしありとすれば――物質的にも、一切合切を自分で責任を背負った方がどのくらい楽だったかしれなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで何から何まで一切合切での総勘定が三百円で立派にこの仕事は出来上がるというのでありました。",
              "citation": {
                "source": "佐竹の原へ大仏をこしらえたはなし",
                "author": "高村光雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、一切合切思考するということがいけないのだから、その覚悟で一年を暮すよう。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "欝々として楽しまない、幸にしてＫ社から句稿料が届いたので街へ出かけて二三杯呷る、その勢で山口へ行く、飲んで酔うてＳ屋に泊る、前後不覚、一切合切が空つぽになつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな女のことは、一切合切しやべり立てて、隣り近處へ顏向けの出來ないまでにしてやるんだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯二杯三杯飲んだ（断つておくが藷焼酎だ）、いゝ気持になつて一切合切無念無想。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の持論から割り出すと、今川であれ北条であれ、浅井であれ朝倉であれ、世のいわゆる武人なるものは、一切合切野蛮人なのさ」「それはまたなぜでございますな？",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに税関役人が親切に残しておいてくれた、頬の肌理をよくするための石鹸が五つ六つ――それだけで一切合切だった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切合切が、何時も風呂敷包み一つの私である。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古新聞を焚いて茶をわかしていると、暗澹とした気持ちになってきて、一切合切が、うたかたの泡より儚なく、めんどくさく思えて来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだって生きていたって不必要な人間なんだと考え出してくると、一切合切がグラグラして来て困ってしまう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古新聞を焚いて茶をわかしていると、暗澹とした気持ちになって、一切合切が、うたかたの泡より儚なく、めんどくさく思えて来る。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりではないあの黒い門もなにもかも、一切合切燃えてしまったのだ。",
              "citation": {
                "source": "江木欣々女史",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな男があれば、心の中の一切合切その男に任せて、逢ひ通さうと思ふのに。",
              "citation": {
                "source": "地唄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの妾は浅草の、銀杏茶屋のお色でございます」　――それから田沼に懇望され、その妾になろうとしたこと、可愛い恋人と切れたこと、妾になることが止めになったこと、今日呼び出しを掛けたところ、恋人が昨日屋敷を出たきり、今に帰って来ないこと――一切合切打ち明けた。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……『秘密の鍵は第三の壁』……何だか些少も解らねえ……何でもいいや、一切合切、みんな姐ごに話してやろう」　こんなことを口の中で呟きながら、風船売の少年は、障子の穴から覗いている。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "是が一切合切の金なのである。",
              "citation": {
                "source": "日本の眞の姿",
                "author": "竹越與三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことの言い訳は一切合切やらないのである。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自家のお春っ子お兼っ子に一貫目何銭の掻き賃をくれて、大急ぎで掻いた繭を車に積んで、重い車を引張って此処其処｜相場を聞き合わせ、一銭でも高い買手をやっと見つけて、一切合切屑繭まで売ってのけて、手取が四十九円と二十五銭。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして精巧な策略を仕遂げた詐欺師のやうな落付いた満足を覚えたが、ふと自分に返ると、苦りきつた気持で、頭の中の映像を大急ぎで一切合切掃除するやうにした。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切合切投げ出してしまうのが一番だ。",
              "citation": {
                "source": "顔",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな風に使われているのか一切合切わからないのだから、来るべき苦情が来ないのも心細さのタネになるらしい。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、男物のいっさいがっさいをおっぽり出して、いささか溜飲を下げ、お角は床についたが、まだなんだか癪に残るようなものがあって、蒲団から首を出して煙草をのんでおりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
