          "literary": [
            {
              "text": "見てもらえば分るでしょうが、私達の花卉はシリー諸島の物よりずっと活きがいいです。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうのお肴はいきがいいね」と祖母は叔母に、空嘯いて話しかけた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            }
          ]
        }
