    "definitions": [
      {
        "index": 1,
        "gloss": "have a good day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "（夫が仕事に行く時に）「いってらっしゃい、お昼ご飯はお弁当よ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "（友人が旅行に出かける時に）「道中気をつけてね、いってらっしゃい！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "（店員が顧客を見送る時に）「またのお越しをお待ちしております。行ってらっしゃいませ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そっちへ行ってらっしゃい。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行ってらっしゃいまし。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいとも、ゆっくり行ってらっしゃい」　道子はわれ知らず顔をほころばした。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「行ってらっしゃい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり下りると、「へい、行ってらっしゃいまし。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根行一「御機嫌よく行ってらっしゃいませ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉五郎どのが見えましたらば、宜しくお伝えください」「行ってらっしゃい」と、留吉も丁寧に会釈した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行ってらっしゃいよ。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「リョーニャ、月曜日に行けたらエーゴル・マクシモヴィッチのところへ行ってらっしゃいよ、ね？",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「叔父さんのところへ来るかい」「いや」　油井が、みのえの方は見ず、「じゃ、奥さん行ってらっしゃい、私、みのえさんを家まで送って行きますから」と云った。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして紀久子が、「行ってらっしゃいまし」と声をかけると、父はそれへ頷きもせずステッキの握りへ片肘をのせて心もち前屈みに向う側の窓へ顔をむけたなりで行ってしまった。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった二分間……」「じゃ、行ってらっしゃい。",
              "citation": {
                "source": "碧眼",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝湯にはいって、講釈の寄席へ昼寝をしにゆくのを毎日の仕事にしていたが、あんまり口やかましいので、佃島の庭の梅が咲いたからお訪ねなさい、桜がよいでしょうから行ってらっしゃいと、私の父の閑居に体よく追払われては来た。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "また細君のみと子夫人が、背中の上の方に閂のかかった薄鼠色の看守服の良人を門口まで送って出て、「行ってらっしゃい。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "行ってらっしゃい」　と高くつづけさまに云って手を振り、主人の見えなくなるまで電柱の傍に立ちつくしている姿も、これも雨が降っても雪が降っても毎朝変らなかった。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、私はもう十幾年間、「行ってらっしゃい。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "行ってらっしゃい」　とこう呼ぶ加藤家の元気の良い声をどれほど聞かされたことかしれぬ。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一寸お母さんが、急用があるそうでなア、周章てて来ていなさるで……」「そう、じゃそっと行ってらっしゃい」　先生は立ち上った啓吉の肩を押して、扉の出口へ連れて行った。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞子は流石にしょんぼりしている啓吉を見ると、何となく心痛いものを感じたが、「じゃ、お教室へ行ってらっしゃい。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くヨリ子の処へ行ってらっしゃい……何を愚図愚図……」　夫人に突き飛ばされて、よろめきながら二郎氏はポケットから一掴みの札束を出した。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く塩原へ行ってらっしゃい」と云って笑った。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたまってバスを待っていて、「よく気をつけて行ってらっしゃいね」と繰返し云っている。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時も女は一寸ふり返ったっきり又ふり返って「行ってらっしゃい」とも云わなかった。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新田先生は、博士について行って、また千二少年に会ってみたい気がしたが、しかし少し別に考えることがあったので、「じゃあ、行ってらっしゃいまし」　と、玄関で博士を送り出したまま、自分は急いで研究室の方へ引返した。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょっちゅう男が変っているが事情に全然変化のないのは庄吉で、ちかごろでは卑屈になって、アラ、そう、忘れた、先生、と二人の男女が立ち上ると、皆まできかずエヘヘ行ってらっしゃいなどと、あさましい。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "事情を言や分ってくれるんだ」「あなた行ってらっしゃい」「オレはいけねえや」「だって親友じゃないの」　庄吉が暗然腕をくんで黙りこんでしまうと、さすがに自分も失踪から戻ったばかり、宿六の古傷もいたわってやりたい気持で、「じゃア、行ってくるわ。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "『君達、むこうへ行ってらっしゃい！",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "エピホードフ　（しゃがれ声で）ご心配なく、行ってらっしゃいまし。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソーニャ　行ってらっしゃいね、ワーニャ伯父さん。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さあ、はいってらっしゃい』と、おばさんは言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
