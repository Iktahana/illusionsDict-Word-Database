        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しく来た上司は、部下に威張り散らすことしか能がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は権力を手に入れると、途端に周囲に威張り散らすようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "自分の意見が通らないとすぐに威張り散らすのは、彼の悪い癖だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "訳もわからないで無暗に威張り散らすのが御役人だと思っていた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも運好く成功した人間共は、其の幸福と云うことは一向顧みないで、始めから自分達が優者である如く威張り散らすのである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は政江に押しつけられて、児子家の女中を嫁にしたが、その嫁が何かにつけて政江の指図をうけて威張り散らすので、亭主の威光が少しもないという理由で、政江を恨んでいるのだった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本官の奴等平生餘り威張り散らすから少し懲らしてやれといふので僕が行つて見ると大層裝つて居るが假病である。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「怪しからんぢやないか、断りもなしに他人の小屋に這入り込んで吾もの顔で威張り散らすとは何たる事だ。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニーチェは重荷を担いで、苦しまぎれに威張り散らす。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはあらゆる階級――零落した旧家の子弟、劇場の女たち、狡猾な悪漢、幇間、威張り散らす乱暴者のたぐいを招いて遊びました。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大なまくら、威張り散らすだけで、いざとなつたら、何んの役にも立たなかつたでせうよ」　徳川の直參も太平に慣れて、そんな心細い武士が次第に殖えて行くのを防ぎやうもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "井戸端の逢引",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、嫌われ者は、尾張と薩摩で、これはどうかして三年に一度ぐらい、この関所へかかることがあるが、金は使わないくせに威張り散らすという廉で、関の上下におぞけを振わせたものだそうです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "また地道の商人やその他の平民に向って、折助は士分面をして威張り散らすことがあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白根山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "高杉妙子、菊田をカサに着て威張り散らすとて評判悪し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のよわ味をかくそうとして、いばりちらすなんて、よくないことだ」　こういわれて、さすがの怪外人も、こまった様子です。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして地位があがると、いばりちらす。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "攻め取りさえすればいいんだから」「そしてグウグウ寝ていやがる」「眼がさめると、おれたちがこしらえた汁や飯をたらふくくらって、自慢話でいばりちらす……考えてみると、兵糧方はわりがわるい」「オイ、ぐちをこぼしてもしかたがねえ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
