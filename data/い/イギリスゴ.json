          ],
          "literary": [
            {
              "text": "本人はイギリス語を解せざれども、発音に由りて判断したりと云ふ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス語の分からないスパニア人は、発音から推測してイギリス人だらうと云ふ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ミスはひつくりかへるほどびつくりして、お部屋へかへつても、フランス語とイギリス語を、ごつちやに、くちびるの上でぶつけ合せました。",
              "citation": {
                "source": "かたつむり",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス語に飜訳されるのは、ある意味に於ては、むしろ作者の耻辱だと思はれるやうなところすらある。",
              "citation": {
                "source": "J. K. Huys Mans の小説",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "賑かなイギリス語で草をはやし、素樸なラテン語で垣をめぐらそう。",
              "citation": {
                "source": "私の果樹園",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "――日本には、イギリス語のジプシーといふのが一番よく知られてゐます。",
              "citation": {
                "source": "エミリアンの旅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれをイギリス語、フランス語、ドイツ語、イタリー語、フレミッシュ語、およびデンマーク語で公表することにした。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "（古いイギリス語でアースは「熊」であり、アールは「大なる」または「驚くべき」の意味）そこでみんな彼をアーサアと呼んだ。",
              "citation": {
                "source": "北極星",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはイギリス語ではなしかけて見た、たぶんどこか南の方からの人と思ったから。",
              "citation": {
                "source": "漁師",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さま、ぼく、歌を歌ってみましょうか」　こう言ってかれは、イギリス語の悲しいような歌を歌った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえにイギリス語を教えだしたのもそのわけだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはイギリス語をごくわずかしか知らなかったが、マチアはガッソーの曲馬団でいっしょに働いていたイギリス人から、たんとことばを教わっていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたち二人はグリーン（緑）というイギリス語がどういう意味だか知っていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おえはわたしたちのことばがわからないのだから、はじめはすこしきまりが悪いかもしれないが、じきにイギリス語を覚えて、兄弟たちと話ができるようになるだろう。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがもうすこしイギリス語を知っていたら、たぶんかれの言ったことばがわかったであろうが、わたしの聞き得たかぎりでは、ポリスメン（巡査）ということだけであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると祖父はわたしたちの一人がイギリス語を話したので、すこしきげんを直したように見えた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親はわたしの言ったことをイギリス語に翻訳した。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはしじゅうわたしのほうをふり向いてみながら、イギリス語でわたしの父に話しかけた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはイギリスに来てから、かなりうまくイギリス語を使うことを覚えた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえはイギリス語がわかるか」と巡査はたずねた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュヴェグラアの『哲学史』のイギリス語訳をほねをおって読んだのも、このころであったように思うが、それを読むだけの素養などはなかったに違いないから、読むには読んでも実は何もわからなかったであろう。",
              "citation": {
                "source": "学究生活五十年",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりの給仕が歩きまわって、食事の用意ができたとイギリス語で知らせた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はイギリス語を話していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一学は外から呼ばれた声に大きな驚異を持ちながら、筆を、うつしかけたイギリス語の雁皮の帳面の間へはさんで、あわただしく立って窓の障子を押開き、「どなたでござる」「駒井だ」「ええ、殿様でございましたか？",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、古いフランスの通俗語の上に、プロヴァンス語、スペイン語、イタリー語、地中海の海港の言葉である東方語、イギリス語、ドイツ語、フランス・ロマンとイタリー・ロマンとローマ・ロマンとの三つの種類のロマン語、ラテン語、それから、バスク語、及びケルト語。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス語をとれば――bishop ―― bichot, 司教。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼女が一人で住むことのできる室が必要なんです」「――では、ここはひろすぎますわ」　機智のこもった主婦の視線が、ベレーをかぶって、パリ風というよりはイギリスごのみの学生風ななりをして窓から景色を見ている伸子をちらりと見直した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
