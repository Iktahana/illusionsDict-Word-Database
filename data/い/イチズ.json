[
  {
    "uuid": "5555352d-3b61-5f52-b8c5-bfa2cfde000c",
    "entry": "一途",
    "reading": {
      "primary": "いちず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
