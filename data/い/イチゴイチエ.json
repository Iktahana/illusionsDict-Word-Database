    "definitions": [
      {
        "index": 1,
        "gloss": "once-in-a-lifetime encounter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「旅先での出会いは一期一会ですから、この縁を大切にしたいですね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "千利休が説いた一期一会の精神は、現代の接客におけるホスピタリティの原点とも言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台俳優は、その日の観客との一期一会の時間を共有するために、日々の稽古に心血を注ぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "露店で偶然見つけた古い絵葉書との出会いも、また一期一会の不思議な巡り合わせである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一期一会のつもりで、本日の講演も一言一句を疎かにせずお話しさせていただきます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雲の形や日の差し方は刻一刻と変化しており、風景写真との出会いはまさに一期一会だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人生はすべて一期一会のこころだ。",
              "citation": {
                "source": "鉄鉢と魚籃と",
                "author": "――其中日記から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一期一会　もはや、五月の空には、あの勇ましい鯉幟が、新緑の風を孕みつつ、へんぽんと勢いよく大空を泳いでいます。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の道は、一期一会の心をもたぬものには、ほんとうに味わわれませんが、人生のことも、やはり同じです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "△一期一会の人生である、その時その場のその物をしみ／″＼と味はへ、私は山を観るとき、空を仰ぐとき、草に触れるとき、人に接するとき、酒を飲むとき、飯を食べるとき、……すべてのものをしみ／″＼と味ふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄太君に返事の手紙を書いた、緑平居訪問の同行を断つたのである、それはまことに一期一会ともいふべきよろこびであり、同時にかなしみではないか、君のあたゝかい心、そして私のかたくなな心、私は書いてゐるうちに涙ぐましくなつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……高崎市の安宿に寄ると、ふしぎや、また例のルンペン君に出会つた、人生万事如是々々、そして人生はまた一期一会だ（但会一処でもあるが）、幸にして持合があるので、ビールとビフテキとをおごつてあげた、彼のよろこび、彼のかなしみ、それは私にもよく解る、君よ幸福であれ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は最後の一夜といふので、みんないつしよにしみ／″＼と語つた、一期一会の人生ではあるが、縁あらばまた逢へるであらう。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一期一会、いつも、いつも一期の会。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "定石”　　　　　　　　　　　　たくあん破れて縫うてあるもの閑古鳥よ啼け古雑誌を読みつゝ水声山色老人――“得何和”“一人を楽しむ”旅していると、一期一会をしみ／″＼感じる、山を歩いてゐると和敬清寂を考へる。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "逢ふは別れのはじめといふ、いつも一期一会である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶道に於ける、一期一会の説には胸をうたれた、そこまで到達するのは実に容易ぢやない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の具合が悪くて、ぶつつり切れゝば、虎の子の二両二分はそのまゝ不人情に風のまにまにどこかの屋根裏か路地へ一瞬にして消えてしまふのだから、元々足場の悪い、屋根で揚げる凧は、切れたら最後と、いつも一期一会の張り切つた気組みだつた。",
              "citation": {
                "source": "両国今昔",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶の方に「一期一会」という言葉がある。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「和敬静寂」の四字も有名だが、私はこの「一期一会」の方が一段と特色ある言葉のように思われてならぬ。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
