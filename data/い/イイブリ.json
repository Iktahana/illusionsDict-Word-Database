[
  {
    "uuid": "fcf57d6a-0733-5f04-806e-81665b154832",
    "entry": "言いぶり",
    "reading": {
      "primary": "いいぶり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
