[
  {
    "uuid": "ada6e785-7c35-5ecb-ac04-26e2fec9c787",
    "entry": "い文字",
    "reading": {
      "primary": "いもじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
