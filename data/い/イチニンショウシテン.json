        "examples": {
          "standard": [
            {
              "text": "ゲームの世界に没入するため、「一人称視点」でのプレイを好むゲーマーは多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小説では、主人公の感情や思考を深く描くために「一人称視点」が採用されることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "VR技術の進化により、まるで自分がその場にいるかのような「一人称視点」の体験が可能になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドキュメンタリー映画で、被写体自身がカメラを回すことで、よりリアルな「一人称視点」の映像が制作された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事件の証言は、「一人称視点」での詳細な記憶に基づいており、その信憑性が問われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研修では、顧客の立場に立って考えるため、「一人称視点」でシミュレーションを行うことが推奨されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このカメラは一人称視点で撮影できるから、臨場感がすごいよ」と友人が興奮気味に話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "完翻訳について「時間からの影」に続いて、一人称視点のを訳してみました。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
