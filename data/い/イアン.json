        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "社員の慰安のため、毎年恒例の温泉旅行が企画された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "被災者の心に寄り添い、温かい慰安の言葉をかけるボランティアの姿があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長時間のデスクワークで疲れた体を癒やすには、アロマバスが何よりの慰安だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠く離れて暮らす家族からの手紙は、彼にとって何よりの慰安だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日々の厳しい訓練の合間に、故郷の歌を口ずさむことが兵士たちの小さな慰安となっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まあ、気にしなくても大丈夫だよ。」と優しく声をかけられ、心がいくぶん慰安された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "失意の底にあった私を慰安しようと、友人がお気に入りの映画を見せてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "儲けにこそならなかつたが、詩は彼女の大切な慰安だつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーペンハウエルの哲学は、この点で僕等の心理を捉え、孤独者の為に慰安の言葉を話してくれる。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、「寵を蒙むる者を憎むは、己れ自ら寵を望む也、之を有せざる者の怒るは、之を有する者を侮蔑して自ら慰安する耳。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園にうず高く落ち敷く落葉、落ちる前の乾燥した黄褐色の木の葉を盛り上げた深い森林――この際、彼には何か神秘的な特殊性を包蔵する境区として結局はこの境区の何処かに彼の一寸ものに触れれば吼え出し相な頭の熱塊を溶解してしばらく彼の身心の負担を軽くして呉れる慰安の場所もあるように思えた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの最も人間的な人間固有の享楽と慰安に資料を供給する専売局の仕事はこの点で最も独自なものであると云われるかもしれない。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の慰安の心よりは、余義ない気持の勝った歌である。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアカデミックな芸術に食傷したものの眼には不思議な慰安と憧憬を感ぜしめる。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで塹壕中でのいろいろの慰安とか、士気を鼓舞する手段が講ぜられました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰安のため二日も三日も自分の仕事を放棄するようでは、もはや塹壕戦ではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、慰安なり休養なりは、その塹壕に即した（より添った）ものでなければなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "設備極楽、いろいろの設備でだいぶ公衆慰安の目的のものが増えて来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の友を求めることに気がつかず、こんな女づれを相手に僅かな慰安を捜求めてあるく男の惨めさは、此意味に於て哀れなものと云はなければならない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "たつた一人の俺の陣地に忍びこんで来て、俺の疲と寂寥とに僅ばかりの慰安をでも与へてくれるのは此女だけである、俺は安心して此女の腕によりかかつて眠れる。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、陸軍病院の慰安のための見物がえりの、四五十人の一行が、白い装でよぎったが、霜の使者が通るようで、宵過ぎのうそ寒さの再び春に返ったのも、更に寂然としたのであった。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　二月の半ば、余寒の風のまだ肌にとげとげしいころ、銀子は姉芸者二人に稲福、小福など四五人と、田所町のメリンスの風呂敷問屋の慰安会にサ―ビスがかりを頼まれ、一日｜鶴見の花月園へ行ったことがあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩はただ私への「悲しき慰安」にすぎない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心のいたく疲れた人、重い惱みに苦しむ人、わけても孤獨を寂しむ人、孤獨を愛する人によつて、群集こそは心の家郷、愛と慰安の住家である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心のいたく疲れた人、重い惱みに苦しむ人、わけても孤獨を寂しむ人、孤獨を愛する人にとつて、群集こそは心の家郷、愛と慰安の住家である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーペンハウエルの哲学は、この点でよく僕等の心理を捉へ、孤独者の為に慰安の言葉を話してくれる。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの恐しい小説『罪と罰』『白痴』『カラマーゾフの兄弟』『死人の家』等が、私にたまらないほど大きな慰安と感激と驚異とをあたへたことは言ふ迄もない。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ人たちの作品は私に多くの『慰安』をあたへる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藝術の權威を信じない私にとつて、詩を魂の慰安として無意義に人生を空費した私にとつて、その墓銘こそ悲しい運命の微笑を語るものです。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家自身の態度としては、芸術が慰安的な「悲しき玩具」であろうとも、或は生命がけな「真剣な仕事」であろうとも、批判する側には関係がなく、何れにせよ表現の魅力を有し、作品として感動させてくれるものが好いので、芸術の批判は芸術に於てのみなされるのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心のいたく疲れた人、思い悩みに苦しむ人、わけても孤独を寂しむ人、孤独を愛する人によつて、群集こそは心の家郷、愛と慰安の住家である。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女自身のむす子と別れて後の淋しい生活を想像して見ても、むす子が行く華やかなモンパルナスのキャフェの夜の時間を想うことが、むしろ、かの女の慰安でさえある。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで恋愛ではないと云つてゐた小布施と桂子の交情に、桂子が顧みていくらか忸怩としてゐたことは、男からの体臭的慰安だつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その當時私にとつて、どんな本でも休養と慰安であつたからである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　など頗る卑怯な当りさわりのない挨拶を交すだけで、藤野先生から言いつけられたような慰安激励の話題を一つも持ち出す事が出来なかった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は当番の看護婦が、交代に二人ずつ附添うので、ただ（御気分はいかがですか、お大事になさいまし、）と、だけだけれども、心優しき生来の、自から言外の情が籠るため、病者は少なからぬ慰安を感じて、結句院長の廻診より、道子の端麗な、この姿を、待ち兼ねる者が多い。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "及びもしないあんな男をいきなり一言二言はなしてそんなことを考えるなんてあることでない。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
