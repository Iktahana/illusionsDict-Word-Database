          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "磯辺に打ち寄せるいさら波が、心を穏やかにする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風のない湖面には、いさら波一つ立たなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "川底のいさら石が、陽光を受けてきらきらと輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "足元に広がるいさら石を踏みしめながら、海岸を散策した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜が明ける頃、窓の外にはいさら雪が舞い始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コートの肩にいさら雪が積もり、冬の訪れを感じさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "砂時計の中をいさら砂が静かに落ちていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ある花はこんなに細小でまたある花は途方もなく大きい。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに珍しき町の名に、大衆免、木の新保、柿の木畠、油車、目細小路、四這坂。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女相愛して後始めて社界の真相を知る、細小なる昆虫も全く孤立して己が自由に働かず、人間の相集つて社界を為すや相倚托し、相抱擁するによりて、始めて社界なる者を建成し、維持する事を得るの理も、相愛なる第一階を登つて始めて之を知るを得るなれ。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は劣情と呼び、或は聖情と称ふ、何を以て劣と聖との別をなす、何が故に一は劣にして、一は聖なる、若し人間の細小なる眼界を離れて、造化の広濶なる妙機を窺えば、孰を聖と呼び、孰れを劣と称ぶを容るさむ。",
              "citation": {
                "source": "「桂川」（吊歌）を評して情死に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "細小竹のへろ／＼矢。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋マッチが一箱、二インチほどの獣脂蝋燭が一本、ＡＤＰ印のプライヤ製パイプ、長刻みの板煙草を半オンスばかり詰めた海豹皮の煙草入れ、金鎖の付いた銀時計、ソヴリン金貨五枚、アルミニウムの鉛筆入れ、書付け数通、ワイス社（ロンドン）の刻印がある細小で硬い刃の象牙柄ナイフが一振り。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "精密仕事のために作られた細小の刃。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一山に寺々を構えた、その一谷を町口へ出はずれの窮路、陋巷といった細小路で、むれるような湿気のかびの一杯に臭う中に、芬と白檀の薫が立った。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が尋ね求めるものは、若し桶の中に存在するとしても、細小なものであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三女史に対して捧げている前述のような尊敬は尊敬として、たとい三女史の博詞宏弁を以てしても私の意見の自信を覆えさない限り、私はその十字火を凌いで三女史の前にこの細小の自己を主張せねばなりません。",
              "citation": {
                "source": "平塚・山川・山田三女史に答う",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は濶大に一人は細小なるが、打ち連れて物語などして行くさまなり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その円錐花叢は疎にしてその小穂は数少なく、かつ狭長なり、花はメダケよりは一層細小にして、かつ疎々に小軸の両側に互生し、その色紫を帯ぶ。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハチクの花状はマダケとは大いに趣を異にしその円錐花叢は短くして小箒状に簇集し苞ありと雖ども小形にしてその苞頭の小葉また甚だ細小なり。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種名の pumila とは矮小ナあるいは細小ナ意味の語であるが、しかし元来この樹は高大なものであるにかかわらず、こんな学名がついたのは、それがシベリアからの灌木状のものであったので、その命名者がこんな種名を用いたゆえんであったのであろう。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば本当の果実とはどこをいっているかというと、それはその放大せる花托面に散布して付着している細小な粒状そのもの（図の右の方に描いてあるもの）である。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘太夫を巡って１　両国橋を本所の方へ渡ると、江戸一番の盛場となり、ことに細小路一帯には、丹波から連れて来た狐爺とか、河童の見世物とか和蘭陀眼鏡とかそんないかがわしい見世物小屋があって、勤番武士とか、お上りさんとか、そういう低級の観客の趣味に、巧みに迎合させていた。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんここにも細小農の分裂は行われたが、垣内山の存在はなお一つの余裕であって、他に比べると共住者の相助がやや容易に行われ、大地主の圧迫は垣内以外の地よりも少なかったかと思われる。",
              "citation": {
                "source": "垣内の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台に噛ぶり付いて瞬きせず仲蔵に見入って居る老いさらばえた浪人体の老武士がある。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老人が「何処へとは知れた事Ｔ「老いさらばえた　此の命　伜の役に立てて来る！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もこの老いさらぼえた山人に何とはなしに畏怖の念をいだいていたが、しかしその「山オコゼ」というのがどんなものだか知りたいという強い好奇心を長い間もちつづけていた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔の頂の洗いさらされた石材には貝がらの化石が一面についている。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌も　酒も　戀も　月も　もはやこの季節のものでないわたしは老いさらぼつた鴉のやうによぼよぼとして遠國の旅に出かけて行かう。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、良寛禅師の書を、あんな風におもていさらしておくのは、勿体ないことです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体は大きくないが、骨組はがつちりしてゐて、顎や頬骨の張つてゐるあばた面の老人が、老いさらばひ、夕闇に一人で飯を喰べて居る姿はさびしかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上の紅葉が水のまにまに流れて来て、蛇籠の籠目や、瀬の縁に厚い芥となつて老いさらばつてゐた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火のない炉、炉棚の上の古いさら、天じょう、黒いふしあな、かべにえぐられたくぼみの中のキリストの像、かべとゆかのさかいで、二つにおれているじぶんのかげぼうし、かげぼうしの横にいる鳴かないコオロギ、それからそれへと、目をうつしていきました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の庵室には上手を向いて老いさらばった老僧が眼を瞑って端座している。",
              "citation": {
                "source": "或る秋の紫式部",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――そんなへなちょこな考えでいさらしたんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞳を定めて見れば、老いさらぼうた翁媼が蹲っている。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "狼、のしのしと出でてうかがうに、老いさらぼいたるものなれば、金魚麩のようにて欲くもあらねど、吠えても嗅いでみても恐れぬが癪に障りて、毎夜のごとく小屋をまわりて怯かす。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
