    },
    "definitions": [
      {
        "index": 1,
        "gloss": "artwork on wood, canvas, metal sheet, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この博物館の特別展では、貴重な江戸時代の板絵が多数展示されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "板絵に描かれた緻密な筆致は、当時の絵師の高度な技術を示唆しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "先日発見された古墳から、彩色された板絵が出土し、専門家がその年代を調査しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "オークションに出品されたこの板絵は、現代アートとしても評価が高く、予想落札価格を大きく上回りました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖母の家には、昔ながらの風景が描かれた木製の板絵が飾られており、懐かしい気持ちになります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この板絵、すごく渋いね！」と友人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "板絵の保存には、湿度管理が特に重要であり、専門の修復家が慎重に作業を進めています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "絵かきの中にも看板絵書き、職人的絵書きと呼ばれる、事物の描き方が世俗的な常識的世界を一歩も出ない人々が少くないこれらの職人的画家達の批評家としては、職人的美術批評家の存在はゆるされるだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤けた壁のところには、歳暮の景物に町の商家で出す暦附の板絵が去年のやその前の年のまで、子供の眼を悦ばせるために貼附けて置いてある。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてその色彩には好んで赤と藍とを混和せしめたる極めて明快なる林檎色の緑を用ひ文化以前の木板絵に見るが如き色調の美妙を示す所あり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "八王子へ出かけて行って、作平が、もと玉川一座の種板絵描きだったということをさぐり出して来なかったら、とてもこの謎々はとけなかったかも知れません。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "日高川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「看板絵をかいても見たが、やはり駄目だ。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょいと見ると、かれの正面の××館の看板絵にもなまなましいペンキ絵の女の顔が、するどく光った短刀を咥えて、みだれた髪のまま立っているのであった。",
              "citation": {
                "source": "幻影の都市",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれにとって、もはや一切の流旗や看板絵や、わずかに棄てられたアニタ・スチュワードや、鯉の胴体や、なやましげに紫紺の羽織をきた女や、下駄ずれの音や、しぶとく垂れている柳や、さては、そこにある交番の巡査のさびしげな赤い肩章まで、かれのからだに響き立てて、一種の花のようにむら咲きをはじめたのであった。",
              "citation": {
                "source": "幻影の都市",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川達三は腕達者なところを一つ揮って看板絵のような小説をつくったらしいが、これは発禁となり、目下編集責任者・作者・名儀人が法律問題にかかっている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "師宣や鳥居派初期の古板絵入本など、たまたま出れば一枚看板で大したもの、すべて軟派物は草子類、洒落本、狂歌書、演劇書類など品払底のためたいていは珍本扱い、ことに歌麿、広重、北斎あたりの彩色入りは百円二百円と驚かされる。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "塀の内側からお粂が一枚の板絵図を抛った。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『あっ』『何者だっ』　羽織をつかんでいる間に、板絵図の割れた一方を溝の中へ落してしまった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――油断も隙もならないぞ、清水』　溝を覗いて、板絵図の半分を抓み上げた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすこし見えなかったら、倉橋が見に行こうと云っていたところ』『――ちと、こよいに迫る仕事があって』『店にか』『なんの、吉良のほうに』『何かあって』『されば、矢頭、その土産を、御一同へお目にかけてみい』　右衛門七が、燈りの下に出して見せたのは、半分に割れた板絵図だった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈八は、冷えたのを飲して、『なんだ、あれは』『つまらぬ事だ』『然し、あんなに泣いて云い訳しているものを、殺しかねないような権まくで責めているではないか』『先頃、大工小屋から、御邸内を改築した折の板絵図が紛失なったのだ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――板絵図を盗んで、持ち出したのはお前だろう』『そ、それは、存じません』『お前の親元は、大工の棟梁だというではないか。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人にかくして書く文もあろうじゃないか』『それにせよ、先頃の板絵図の事は』『あんな物が、よしや、誰の手にわたろうと、何にほどの役に立つか。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿のお居間に近い御文庫のうちから、先頃紛失した板絵図どころではない、公儀へお届けの地割図面と、お邸の間取図の二｜帖の写しが、いつの間にか失くなっているのじゃ』　聞いているうちに、吉五郎の顔いろには、憤かッとしたものが漲っていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私の抛った板絵図は、首尾よくあの方の手に入ったかしら？",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢頭右衛門七が、お粂の恋をうけて、その一心で持ち出させた板絵図と、十郎左の齎したそれとを綜合して見ると、もう吉良邸の坪、間取、長屋、その他の位置は、内部に入って見るように明かに察しられた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして其の機嫌が恢復しかけたのを見て「どうした、それでも汝りや氣につたか、おつかゞ物はみんな汝がもんだかんな、俺ら汝ツ等がだとなりや幾ら困つたつて、はあ決して質になんざ置かねえから、大事にして汝能うく藏つて置いたえ」と彼は滿足らしく見えた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の満しがたい欲望と美しい花のような世界といかになり行くかを知らぬ自己の将来とを考える時は、いつも暗いわびしいたえがたい心になった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い声ですからよく判りませんが、ふたりで話しているらしいので……」「男の声かえ、女の声かえ」「どっちも男の声のようで……」「その男が何を話していたえ」「それがはっきりと判りませんでしたが……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "女「眼が開いたえ……だから馬鹿には出来ないものだよ、本当に神さまの御利益だよ、併しまア見違へるやうな好い男になつたよ。",
              "citation": {
                "source": "心眼",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "至って殺風景な部屋で、なんの部屋飾りもなく、年々の大福帳と、大倉式の古風な金庫が一つあるだけでございます」「ハバカリは、どうしていたえ？",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものをも言わず踏みこんだ泰軒、サアッと敵の輪陣を左右に分けておいて、さっそくのつばくろ返し手ぢかの小松数馬の胸板を刃先にかけてはねあげたから、いたえず数馬、※ッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の中に投げこんでおいたえだは勢いよく燃え上がって、小屋のすみずみの暗い所まで照らしていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんのお帰りを待ちかねていたようです」「で、おまえはどう思っていたえ」「わたしはリーズが、お父さんのお帰りのところを見なければいいと思っていました」　しばらく沈黙が続いた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本年は前厄でございます」「たいそう若く見えるね」「御冗談で」「ところで、お神さんが殺された時は、何をしていたえ」「階下に居りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二本の脇差",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は、泥棒の顔を見たそうだが、どんな人相をしていたえ」　と平次。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "赤い痣",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき、龍睡丸につんでいたえものは、ふか千尾、正覚坊三百二十頭、タイマイ二百頭と、たくさんの海鳥であった。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
