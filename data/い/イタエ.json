[
  {
    "uuid": "7cf3ab5c-61de-5fd1-98c5-0f1c846823fa",
    "entry": "板絵",
    "reading": {
      "primary": "いたえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
