[
  {
    "uuid": "8e947fe0-5a63-5c7b-a149-e45a20007f22",
    "entry": "猪の子",
    "reading": {
      "primary": "いのこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
