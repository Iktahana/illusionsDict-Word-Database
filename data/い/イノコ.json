    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wild boar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山道を車で走っていると、突然猪の子の群れが目の前を横切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この辺りでは、畑を荒らす猪の子への対策が急務となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "猟師は、罠にかかった猪の子を慎重に運び出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "毎年猪の子に旦那の家から部落中に配ってくれる団子は、その年に限って、おりくの家へだけは呉れなかった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど家猪を飼う事早く絶え果てたから正にイと名づくるものがなくなり、専らイノシシすなわち野猪をイと呼び、野猪の子をイノコと心得るに至った。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時唱う歌の一つに「猪の子神さん毎年ござれ、祝うて上げます御所柿を、面白や云々」、『華実年浪草』十に、ある説に亥子餅七種の粉を合せて作る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドの野猪は日本や欧州のと別種だが、やはり共同して勇戦すると見え、カウル英訳『仏本生譚』巻二と四に、大工が拾い育てた野猪の子が成長して野に還り、野猪どもに共同勇戦の強力なるを説いて教練し、猛虎を殺し、またその虎をして毎に野猪を取り来らしめて、分ち食うた仙人をも害した物語を出して居る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪の子」と説けばよい。",
              "citation": {
                "source": "形容詞の論",
                "author": "――語尾「し」の発生――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なア、畜生でも……これは屹度この小い熊の子の為に親同志が喧嘩をして死んだのだらう……」と云つてゐる時、藪の蔭からコソ／＼と小い猪の子が出て来て、直ぐ逃げてしまひました。",
              "citation": {
                "source": "熊と猪",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はＭの字で始まるものを揃えて、まず羊、｜猪の子、鱈、小海豚というふうに、順々に出させたとかいうことである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "野猪の子でも兎でもむささびでも愛すことが出来たが、狐だけは憎かった、また、怖かった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて猪の子でも出て来ねば」「まだ季節が早い」　ふたりは、疲れた脚を、草に投げた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それくらいのことは、やる男だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分十歳くらいのことであったか、あるいは七、八歳だったかもしれない。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃のように暮しに心配がなくなりほんの気晴らしに外へ出るにしても、映画を見て、酒場へ寄って、微酔を帯びて、円タクに乗って帰るぐらいのことで充分すむ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまいのことを云ったのは結局混雑させただけだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "語感の強弱というくらいのことを外来語採用の標準とすることは断じてゆるせないと思う。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも、真黒な指の痕をつけている人は、名札の汚れなどという事には全然無関心な人であるというくらいのことは云われそうである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御馳走を喰えば栄養になり、喰い過ぎれば腹下りを起こすくらいのことは知っていたが、この、医学者でも物理学者でも何でもない助手Ｍ君の感冒起因説は当時の自分の医学上の知識を超越していたのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　私はそのころ下宿屋住まいでしたが、なにぶん不自由で困りますからいろいろ人に頼んで、ついに田口という人の二階二間を借り、衣食いっさいのことを任すことにしました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠はあの通りの病身ですし、わたくしもこの通り気の弱い方ですから、大師匠の眼を忍んで唯まあ打ち解けて話をするぐらいのことで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、ちっとぐらいのことは大目に見てやる方がいいぜ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ならば死骸の疵口をあらためただけで、人間が咬んだのか、獣が咬んだのか、そのくらいのことはすぐ鑑定が付くでしょうが、昔はそれがよく判らなかったんですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "討幕派の軍用費調達というほどの大仕掛けではなくとも、江戸をあばれ廻る浪士どもの運動費調達ぐらいのことは無いともいわれない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "式部が掛け合いのことはお豊ひとりの胸に秘めて、店の者にはいっさい秘密にしてあったのであるが、もう斯うなっては匿しても隠されないので、お豊は番頭どもを呼びあつめて、その秘密を打ちあけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "式部は加茂の社に知己の者があったので、祈祷や祓いのことなどを少しは見聞きしていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "これッくらいのこたァ、俺れでも知ってるぞ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それくらいのことは俺にだってある。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……先生はああ倒れたのか、苗が弱くはなかったかな、あんまり力を落してはいけないよ、ぐらいのことを云って笑うだけのもんだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の少青年時代に受けた文学的の教育と言えば、これくらいのことしか思い出されない。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一ぱいのこの湯でも、自然の現象を観察し研究することの好きな人には、なかなかおもしろい見物です。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑いころの昼席だと聴衆はほんの四五人ぐらいのこともあった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時にたとえばラジオによって全国に火事注意の警報を発し、各村役場がそれを受け取った上でそれを山林地帯の住民に伝え、青年団や小学生の力をかりて一般の警戒を促すような方法でもとれば、それだけでもおそらく森林火災の損害を半減するくらいのことはできそうに思われる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "infant wild boar",
        "register": "standard",
