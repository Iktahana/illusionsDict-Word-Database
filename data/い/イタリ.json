          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年の夢が叶い、皆様からの温かい祝福を受け、感激の至りです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このような歴史的な瞬間に立ち会えたことは、この上ない栄誉の至りです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "計画の最終段階で予期せぬ問題が発生し、プロジェクトが頓挫したことは、関係者一同、残念の至りです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "度重なる交渉の失敗は、事態を悪化させるばかりで、まさに泥沼の至りであった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の演奏は、長年の研鑽を経て、まさに芸術の至りと言える域に達していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "度重なる失言と政策の失敗は、政権の求心力低下という、まさに致命傷の至りであった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いやはや、こんなに手間がかかるとは、恐縮の至りですよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ええっ、あの有名な俳優が、こんな小さな舞台に？信じられない、驚愕の至りです！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "熱力学にエントロピーの観念の導入され、またエントロピーと公算との結合を見るに至りし消息もまたここに至って自ずから首肯さるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日夕より雨ふりいでて廿日に至りて猶やまず。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の如き鹽センベイにて晩酌する徒輩にとつて、室生君酒席の贅澤は羨望の至りである。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に至りてはそれも見あきてすたりぬ。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――供二人三人｜召連れ春風と言ふ遠がけの馬に乗り、塔のあたりに至り、岩窟堂の虚空蔵にて酒をのむ――とある。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤は即ち花の盛りの眺望好き向島堤の続きにして、千住駅を歴てこゝに至り、なほ遠く川上の北側に連なるものなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古より文人墨客の輩綾瀬以上に遡らずして、たまたまかゝる地あるを知らざりしかば、詩文に載せられて世に現るゝことなく、以て今日に至りしならん。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上流は小菅より浮塚に至りて、なほ遠く荒川より出で、こゝにて復荒川の下流の隅田川には入るなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この水路は狭けれども深くして、やゝ大なる船を通ずべく、業平町に至りて後左すれば、いはゆる○曳船川に出で、田圃の間を北して遠く亀有に達し、なほ遠くは琵琶溜より中川に至る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○外濠は神田堀より入りて、右すれば神田橋一ツ橋｜雉子橋下を経て俎橋下に至り、いはゆる飯田川となりて堀留に窮まり、左すれば常磐橋その他の下に出づべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の橋相生橋亀久橋等の下を経て、木場の北に至り、要橋崎川橋下を過ぎて横川に会し、なほ東して石小田新田、千田新田の間を通り天神川に会して終る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一支に入らずして本流を追ひて上れば、江戸橋下に至り○日本橋下に至り、終に一石橋下に至りて御濠に出づ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御濠は西の方滝の口に至り、南の方呉服橋八重洲橋鍛冶橋数寄屋橋に至るまで船を通ずべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて永代橋以南の深川寄りの方を記せば、熊井町より大島町に沿ひて越中島の北の方を、富岡門前町と並行して木場に至り、またその南の方を東して遠く洲崎の遊廓に達するの一渠あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌桂　木犀というもの、花は眼をたのしますほどにあらねど、時至りて咲き出づるや、たれこめて書読む窓の内にまでも其香をしのび入らせ、我ありと知らせ顔に園の隅などにてひそかに風に嘯ける、心にくし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し其人菊をめづること深くして、菊その情に酬ひざるを得ざるに至り、童子の姿を仮りて其人の前に現はれしことなどありて後、筆をとりて其おもかげを写したらんには、一ト入おもしろきものの成りたるならんとぞ微笑まる。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我邦にては、はやくより咲くもあれど、春に至りて美しく咲きこぼるゝを多しとす。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ皆朝顔のおかげといたく愛して翌年の夏に至りけるに、去年の花より多くの種残りて、さりとは数多生ひ出で、蔓の頃はさぞかしと思ひやらる。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し終に其の為めに叱られるには至りませんでしたが、今でも其疵痕は膝に名残りを止めてあります。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき三島で書いた「ロマネスク」という小説が、二三の人にほめられて、私は自信の無いままに今まで何やら下手な小説を書き続けなければならない運命に立ち至りました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤネワを経て、カナアリヤに至り、ここでまたフランスヤの海舶一隻ずつに乗りかえ、とうとうロクソンに着いた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎はわれを導きてその船室に至り、貴嬢の写真取り出して写真掛けなるわが写真の下にはさみ、われを顧みてほほえみつ、彼女またわれらの中に帰り来たりぬといえり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪先あがりの小径を斜めに、山の尾を横ぎって登ると、登りつめたところがつの字崎の背の一部になっていて左右が海である、それよりこの小径が二つに分かれて一は崎の背を通してその極端に至り一は山のむこうに下りてなの字浦に出る。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人は声はり上げて『わが心高原にあり』をうたい、『いざ去らば雪をいただく高峰』の句に至りて、その声ひときわ高く、その目は遠く連山の方を見やりて恋うるがごとく、憤るがごとく、肩に垂るる黒髪風にゆらぎ昇る旭に全身かがやけば、蒼空をかざして立てる彼が姿はさながら自由の化身とも見えにき。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "治子がこの青年を恋うるに至りしは青年が治子を思うよりも早く、相思うことを互いに知りし時は互いの命は互いの心に取りかわして置かれぬ、これ相見てより一月とは経たざる間の事なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが心のはげしき戦いは昨夜にて終わり、今は荒寥たる戦後の野にも等しく、悲風｜惨雨ならび至り、力なく光なく望みなし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆を走らして、おりおり嘆息つきつつ、『われ君を思い断たんともがきしはげに愚かの至りなりき。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セザンヌの絵のような境地に至りたいと思いながら、今までその内容すなわちそれまでに至る努力を考えなかった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに、かうした雑パクな云分といふものは、えてして散漫な現代の如き空気の中では一見よく響いたりするのだ。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまごまと情景を描いたりして諸君を退屈させようとは思はない。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
