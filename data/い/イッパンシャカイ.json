[
  {
    "uuid": "36828153-7e0c-5247-a155-0e30bb2c961e",
    "entry": "一般社会",
    "reading": {
      "primary": "いっぱんしゃかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
