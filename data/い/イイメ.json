            }
          ],
          "literary": [
            {
              "text": "そして大きなかわいい目をして私の顔を珍しそうに見ていました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこんどは、マタンの目の小さいのを見て、「あなたのおかあさんは、小さい、かわいい目だったと思いますが。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡に向うと、そのたんびに、うるおいのあるいい目になりたいと、つくづく思う。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい夕空を、ながいこと見つめたから、こんなにいい目になったのかしら。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と肉屋はこごんで、かるく犬ののどの下をもち上げながら、「へえ、かわいい目つきをしてるね、おまいは。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰れかまたちごた客が來たやうだ」と叫んで、お鳥のいい目はあの二階に立つてゐるのが小僧でもない、女中でもない、宿の主人やおかみさんでもないと嬉しがつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "果てもない広い森林と原野の間に自在に横行していたものが、ちょっとした身動きすら自由でない窮屈なこういう境遇に置かれて、そして、いくら気の長い、寿命の長い象にしても、十年以上もこうして縛られているのでは、そうそういい目つきばかりもしていられないではないかという気もした。",
              "citation": {
                "source": "解かれた象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはどうせ、ヨハンネスだけに、これまでのひとたちとちがったいい目が出ようとは、たれにもおもえなかったからでした。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "知死期は不思議のいい目を見せて、たよたよとして火鉢に凭った。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞世のかわいい目は「そうでしょう」と訴えているように見えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを葉子はかわいい目を上げて、無邪気な顔をして見やりながら笑っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はしごを上っていくんじゃあるめえし、一丁一丁ごていねいに調べなくとも、どうせしまいは土橋へ来ておちつくんだ、おちつくものなら、最終の一つをこのおいらのできのいい目玉でぴかぴかとのぞいてみりゃ、七駕籠ひとにらみにたちまちすっと溜飲の下がるような眼がつくよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦立てば焦立つほど、だがいい目は出ず、ついには骸子そのものに一つの意志があって、源吉の上にばかり意地わるく働きかけてくるような気さえするのだった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして實際を見りや、押し出された奴の方が、途中で投げ出した奴よりも、結局はいい目を見てるんだからな。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな惡うは思はれたくない、けどいい目はしたいといふ連中ばつかしぢやけに、あきやせん。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "また出て來た人々も、自分たちが少數者の犧牲の上に何かいい目をしてゐるといふやうな感じからまぬがれることは出來なかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（叡山へ登って、八郎太の、あの墓の中へ、綱手の鏡を、埋めてやったなら――）　月丸は、己の功名のために利用はしたが、好きであった綱手のために、あの世において、いい目を見せてやろうと、思った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、目をそらして見物の方を見ると、傍にいる女達が小さな可愛いい目を見はって、一心に舞台に見入っている。",
              "citation": {
                "source": "土淵村にての日記",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしておけば、スコールがあがったあとも、この場所へもどって来るのにいい目印になる。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でないといい目が見られないからなあ。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……豊ちゃんと俺らとのいい目がさ」「そうとも」と女の声が云った。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうとも二人のいい目がねえ。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこいつを持っていると、いい目が出るということだ……これはな、伝説による時は、支那から渡ったものだそうな。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がばかに大きくて、その大きな頭いっぱいに、大きな口がついていて、こまかいきれいな歯をくいしばって力んでいて、上唇に長い二本の髭をはやし、下唇に二本の短い髭をはやし、そのくせ、ごく小さなかわいい目でいつも笑っており、頭から尾へすーっとほそくなっています。",
              "citation": {
                "source": "山の別荘の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ何んて可愛いい目んめをして！",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三十年も己は方々の海をわたり※って、その間にゃいい目にも悪い目にも遭えば、もっといい目にももっと悪い目にも遭ったし、いい天気にも悪い天気にも遭ったし、食物がなくなったこともあれば、斬り合いをやったこともあるし、その他いろんな目に遭ったよ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでね、実際のところ、己ぁいい事をしていい目に遭ったってこたぁまだ一度だってねえ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "己に面と向って反対した奴で、その後でいい目に遭った奴は、一人だっていねえんだぜ、トム・モーガン。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "与えられた人こそ、いいめいわくかもわからない。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石段「いいめをみせたんですよ、だからいけなかったんです。",
              "citation": {
                "source": "誓之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
