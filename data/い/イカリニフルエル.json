        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "不正な取引の証拠を突きつけられ、彼は怒りに震えながらも平静を装おうとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プロジェクトの根幹を揺るがすようなミスを報告され、部長は怒りに震えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "友達に濡れ衣を着せられ、彼は怒りに震えながらも、どう反論すべきか言葉が出てこなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あれがファールじゃないだと？ふざけるな！」主審の判定に、選手は怒りに震え声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "虐待されている動物の姿を目にし、その場にいた人々は皆、静かに怒りに震え始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国王は敵国の非道な侵略の報せに接し、王座に座ったまま怒りに震えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長時間待たされた挙句、担当者の無愛想な対応に、彼女は奥歯を噛み締め、怒りに震えるのを必死でこらえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
