        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "車で田舎道を走っていると、見慣れない風景が広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末は、自転車で田舎道をサイクリングするのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、友達と田舎道を駆け回って遊んだ思い出がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の雨に、近くの田舎道に駆け込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "昼食の直ぐ前頃だし田舎道を通るものなんて殆どなかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑居鳥寺見ゆ麦林寺とやいふ　夏の日の田舎道、遠く麦畑の続いた向うに、寺の塔が小さく見える。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜に村の煮売屋などの二階から、大勢兵隊が赤い顔を出して、近辺の娘でも下を通りかかると、好的好的などと冷かしたり、グズグズに酔って二、三人も手を引き合うて狭い田舎道を傍若無人に歩いたりするのが、非常に不愉快な感じを起させた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　田舎道の道端に、牛が一匹つながれていた。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街から離れた田舎道を、なお、山奥へ、樹々が枯色をした深い淋しい林へ、耳の長い驢馬に引かれた長い葬式の列が通っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし吉田は誰もみな一日の仕事をすましてそろそろ寝ようとする今頃になって、半里もある田舎道を医者へ行って来てくれとか、六十も越してしまった母親に寝ずについていてくれとか言うことは言い出しにくかった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小時歩いていると今度は田舎道だった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川近くなって、田舎道の辻の或｜腰掛茶店に立寄った。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎道を歩いていると道わきの農家の納屋の二階のような所から、この綿弓の弦の音が聞こえてくることがあった。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど日本の田舎道に在る石地蔵の感じです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎道を乗合馬車が行くのを一台の自動車が追い駈けて行く、と前方の瀬戸内海に太陽が昇りはじめる、馬車の乗客が「おい、見ろ、昭和二十年の太陽だ」という――ただそれだけの何の変哲もない他愛もない夢であるが、この夢から私は次のように短かい物語を作ってみた。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほこりっぽい田舎道である。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高清水へは田舎道六十里あるというのであるが、早朝に出立して攻掛かろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども先輩達は長閑気に元気に溌溂と笑い興じて、田舎道を市川の方へ行いた。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "分けて、盂蘭盆のその月は、墓詣の田舎道、寺つづきの草垣に、線香を片手に、このスズメの蝋燭、ごんごんごまを摘んだ思出の可懐さがある。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここもとは茅屋でも、田舎道ではありませんじゃ。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一町ばかりを絶えず続いて、轟々と田舎道を、清水港の方から久能山の方へ走らして通る、数八台。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお家に帰る田舎道は、毎日毎日、あんまり見なれているので、どんな静かな田舎だか、わからなくなってしまった。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その、ちょっとあらかじめ御諒解を得ておきたいのですが、お客様が小人数で、車台が透いております場合は、途中、田舎道、あるいは農家から、便宜上、その同乗を求めらるる客人がありますと、御迷惑を願う事になっているのでありますが。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "左は、田舎道で、まず近いのが十二社、堀ノ内、角筈、目黒などへ行くのである。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　八「旦那様、この辺をお通り遊ばしたことがございますなら、田舎道などでお見懸けなさりはしませんか。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ暗がりの田舎道を、提灯つけて岸和田までひいて行った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年はもちろん健脚らしく、僕も足の弱い方ではないが、なにしろ七月の日盛りに土の焼けた、草いきれのする田舎道をてくるのだからたまらない。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家のまばらな田舎道のところどころに、大きい櫨の木が月のひかりを浴びて白く立っているばかりで、川らしい水明かりは見当らなかった。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪明りの狭い田舎道を半里ばかり行くと、道は漸く山にさしかかって来る。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の住まっている町から一里半余、石ころの田舎道をゆられながらやっとねえさんの宅へ着いた。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一体、私の妻は、こんな暁方の三時なんて云う時間にこんな田舎道に出かけていって何をしようと云うのでしょう？",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まきばを　あとにしたのは、　はれた　はるのひの　ひるさがり、　おかの　むこうまで　つづく　いなかみちを　すすみます。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "みずかきジェマイマは、　ひざし　あふれる　ひるさがり、　さいごの　いなかみちを　すすんでいきます。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
