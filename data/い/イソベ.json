        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "醤油の香ばしい匂いと海苔の風味が絶妙に合う、熱々の磯辺焼きを頬張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "お弁当のおかずとして定番のちくわの磯辺揚げは、青のりの香りが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "つきたての餅を小さくちぎり、醤油を絡めて海苔で巻いた磯辺は、いくらでも食べられそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "軽く炙ったホタテ貝柱を海苔で包んだ磯辺焼きは、海の幸の旨味を存分に味わえる一品である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "居酒屋のメニューでカマンベールチーズの磯辺揚げを見つけ、和洋折衷の意外な組み合わせに惹かれて注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
