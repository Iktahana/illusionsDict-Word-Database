          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末は家族で磯辺に出かけ、波打ち際で遊んだり貝殻を拾ったりして過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夕暮れの磯辺を一人散策していると、遠くに漁火が見え、旅情をそそられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この辺りの磯辺は岩場が多く、フナムシやカニなどの生き物を観察するのに最適な場所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "台風の接近により、磯辺一帯には高波警報が発令され、住民に注意が呼びかけられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "今日のお弁当のおかずは、母が得意な竹輪の磯辺揚げだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その旅館は磯辺に建っており、全ての客室から雄大な海の景色を望むことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夏の夜、磯辺に座り込んで満天の星を眺めるのは、何物にも代えがたい贅沢な時間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "春雨や小磯の小貝｜濡るほど　終日｜霏々として降り続いている春雨の中で、女の白い爪のように、仄かに濡れて光っている磯辺の小貝が、悩ましくも印象強く感じられる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "興津を過ぐる頃は雨となりたれば富士も三保も見えず、真青なる海に白浪風に騒ぎ漁る船の影も見えず、磯辺の砂雨にぬれてうるわしく、先手の隧道もまた画中のものなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の祝宴か磯辺の水楼に紅燈山形につるして絃歌湧き、沖に上ぐる花火夕闇の空に声なし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛飾の真間の磯辺から、武蔵野の小岫がほとり、入間路の大家が原、埼玉の津、廻って常陸の国に入った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの山を越す哀しい鳥の数も数え尽した」「もう、いいわ、じゃ、ね」さぬらくは玉の緒ばかり恋ふらくは不二の高嶺の鳴沢のごと駿河の海｜磯辺に生ふる浜つづら汝をたのみ母にたがひぬ",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナヴァラナが磯辺で甲斐甲斐しく海獣の料理をする場面も興味の深いものである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆり殿が赤児｜抱きて磯辺に立てるを視しは、われには昨日のようなる心地す」老婦は嘆息つきて、「幸助殿今無事ならば何歳ぞ」と問う。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助を中にして三つの墓並び、冬の夜は霙降ることもあれど、都なる年若き教師は源叔父今もなお一人｜淋しく磯辺に暮し妻子の事思いて泣きつつありとひとえに哀れがりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯辺に出て、かなたこなたを見廻したが、あの帆掛船の影も見えず、また、他に人のいるけはいもなかった。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても此浦は平家の一門果て給ひたる所なれば痛はしく存じ、毎夜此磯辺に出でて御経を読み奉り候。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時には引率の先生がまつさきに興奮して、私たちを海に向けて二列横隊にならばせ、「われは海の子」といふ唱歌を合唱させたが、生れてはじめて海を見たくせに、われは海の子白波の騒ぐ磯辺の松原に、とかいふ海岸生れの子供の歌をうたふのは、いかにも不自然で、私は子供心にも恥かしく落ちつかない気持であつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の天気はまんまるな天際の四方に白雲を静めて、洞のごとき蒼空はあたかも予ら四人を中心としてこの磯辺をおおうている。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯辺に立って四方を見まわせば、いつでも自分は天地の中心になるのである。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅虫というところまで村々｜皆磯辺にて、松風の音、岸波の響のみなり。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日がもう薄れて、波のモオンする響きがうら悲しく磯辺から響いて来る、植ゑ附けたばかりの樟の木山の下を通つて、松林の中で老爺に分れて伊良湖の村の中程へ出た頃は、夕方の冷たさが肌を襲つて来た。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯辺の草は亡霊の影をそだてて、わきかへるうしほのなかへわたしは身をなげる。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処か丘のあたりや、磯辺で歌って居る遊女の哀婉の調を帯びた恋歌の声が水のやうに、流れて来た。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "返へらざる世を悲しめば如月の磯辺の雪も度を超えて降る　早春大磯に滞在中、雪の余り降らない暖かい大磯には珍しい大雪が偶※降り出した。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧は磯辺に立つてゐる一本の松が、松風村雨の旧跡だと聞いて逆縁ではあるが弔つたと語る。",
              "citation": {
                "source": "能楽論",
                "author": "野口米次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんは大喜びで、さっそく細君携帯で仏蘭西の大磯辺に出かけます。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食後など、三人で磯辺を歩いたりすると、へんに話がちぐはぐになった。",
              "citation": {
                "source": "鳶と柿と鶏",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸｜磯辺まで行って来る」　こう家のものに話した。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝早く、彼は磯辺の温泉宿を指して発って行った。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日しか彼は磯辺に逗留しなかった。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯辺には、岩にぶつかって波がみごとに砕けては、水銀の珠を飛ばすように、散っていました。",
              "citation": {
                "source": "黒い人と赤いそり",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "物質文明からも、近代文化からも、全くかけ離れた荒涼たる磯辺で、人々は霧雨にぐっしょり濡れて、黙々として終日働いていた。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、西国の平家は昨年の冬の頃から、讃岐の屋島の磯辺を離れ、摂津の難波潟へ押し渡り、西は一の谷を城とし、東は生田の森を大手の木戸口と定め、一の谷から生田に至るまで、福原、兵庫、板宿、須磨に立てこもる軍勢、つまり山陽道八カ国、南海道六カ国、合わせて十四カ国を討ち従えて、その軍勢十万余騎と称された。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わが髮のゆきといそべのしら浪といづれまされりおきつ島もり」※取いへ（りイ有）。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
