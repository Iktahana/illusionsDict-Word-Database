    "definitions": [
      {
        "index": 1,
        "gloss": "soroban bead with value one",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
