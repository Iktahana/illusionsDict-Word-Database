          ],
          "literary": [
            {
              "text": "今日の食物――うどん一玉、ぬくめ飯一碗、香煎一杯、餅二つ、饅頭三つ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜一玉八銭、これも漬物にして天下一品。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根一本一銭、キヤベツ一玉四銭だつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「楊貴妃はじんぜうなるやせ容の人の如く想はるれど、天宝遺事に貴妃素有肉体、至夏苦熱、常有肺渇、毎日含一玉魚児於口中、蓋藉其凉津沃肺也と。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
