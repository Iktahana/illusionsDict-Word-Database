    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dried sea slug",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ホヤは仙台等の海に多く、科学上魚類に近い物ながら、外見｜海参に酷似す。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "予多くの支那旅行家より聞いたは、支那内地で金儲けは媚薬とか強壮剤とかに限る、現に日本始め南洋諸地からその種が絶えるまで採って支那へ売り込む海参、東海夫人、鰒は、彼らが人間第一の義務と心得た嗣子を生ましむる事受け合いてふ霊物と確信され、さてこそかくまで重大な貿易品となったのだと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那町｜傅家甸の新世界で、川鮑魚湯だの葱焼海参だのと呼号する偉そうできたない食を喫したのち、私たちは不可解な腕車をつらねて、喧騒と臭気と極彩色と殷賑と音響のなかを大通りキタイスカヤ街へ出た。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕の巣、鮫の鰭、蒸した卵、燻した鯉、豚の丸煮、海参の羹、――料理はいくら数へても、到底数へ尽されなかつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚のロースの葛掛や粉海老の海参じゃあんまり平凡だ。",
              "citation": {
                "source": "幸福な家庭",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季折々の年中行事は、自然に接し、又その中へはいりこみ、そしてそれをたのしむ方法として、祖先が長い間かかってつくりあげたもので春夏秋冬を通じてそれは如何にもたくみに配置されているように思われる。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　状勢がひっ迫するに従って、五六人の彼の同僚が、方々から、ここをめがけてはいりこんできていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳は、蒋介石の北上と共に、だん／＼はいりこんで来た南軍の密偵と、便衣隊について調べるため街に出かけたのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年という長い眠りにはいりこもうとするような自然は、それを眺める人の心を、寒く閉ざしていく静かさをもって、静かに最後の呼吸をしているようだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青島　　僕はかまわず堂脇の家の広い庭にはいりこんで画を描いていてやった。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂脇はこんなふうに歩いて、お嬢さんはこんなふうに歩いてそうして俺の脇に突っ立って画を描くのをじっと見ていたっけが、庭にはいりこんだのを怒ると思いのほか、ふんと感心したような鼻息を漏らした。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢は悪夢だつた、恩愛の夢、執着の夢だつた、それは断ちがたい人間の絆であり軛であつた、人間としてあたりまへのものであつたけれど、私としては――かふいふ生活にはいりこんだ現在の私としては捨てなければならない夢だつた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけは、月はかならず、まい晩きてくれたわけではありませんし、ときには一つ二つの雲が、わたしと月のあいだにはいりこんでくることもあったからです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ひきのハツカネズミは、モミの木のそばへよって、においをかいでいましたが、やがて枝のあいだへはいりこみました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな鏡のかけらは、幾人かの人たちの心の中にさえ、はいりこみました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもこれも、カイの目の中にはいりこんでいる、ガラスのかけらのしわざなのです！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "算数の計算のときにまちがった数が、いつのまにか、そこへはいりこんできたため、それを押し出そうとして、数たちが、今にも散らばろうとしているところだったのです。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてひどいあられなんだろう、と、お姫さまは、深いため息をつきつき、大いそぎでとんで帰って、窓から寝室の中へはいりこみました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まりは、幾年ものあいだ、といの中にはいっていたものですから、からだの中に水がはいりこんで、すっかり、ふくれあがっていたのでした。",
              "citation": {
                "source": "いいなずけ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒は、頭の中にまではいりこみました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途、買い物にでもまわったのであろうと思って、僕はその不用心にもあけ放されてあった玄関からのこのこ家へはいりこんでしまった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに太郎の仙術の奥義は、懐手して柱か塀によりかかりぼんやり立ったままで、面白くない、面白くない、面白くない、面白くない、面白くないという呪文を何十ぺん何百ぺんとなくくりかえしくりかえし低音でとなえ、ついに無我の境地にはいりこむことにあったという。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学界にも、そろそろこの宗教心がはいりこんで来ている。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Alles Oder Nichts　イブセンの劇より発し少しずつヨオロッパ人の口の端に上りしこの言葉が、流れ流れて、今では、新聞当選のたよりげなき長編小説の中にまで、易々とはいりこんでいたのを、ちらと見て、私自身、嘲弄されたと思いこみむっとなった。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで盗人の弟子たちが、｜釜右ヱ門は釜師のふりをし、海老之丞は錠前屋のふりをし、｜角兵ヱは獅子まいのように笛をヒャラヒャラ鳴らし、鉋太郎は大工のふりをして、花のき村にはいりこんでいきました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の方はお母さんのお腹の下へはいりこんで、そこからまんまるな眼をぱちぱちさせながら、あっちやこっちを見ながら歩いて行きました。",
              "citation": {
                "source": "手袋を買いに",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君の小さな口の中に、すずしい秋の朝が、ごっそりひとつはいりこんだみたいだ。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたものの、しかし雇われるところといってはマラバト・ナバトの兵営建築工事か、キャビテ軍港の石炭揚げよりほかになく、日給はわずかに八十セントで、うち三十五セントの食費を差し引かれるようではお話にならず、また、比律賓人の空家にはいりこんで自炊しながらの煎餅売りも乞食めく。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ物そうなので、町々では青年団なぞがそれぞれ自警団を作り、うろんくさいものがいりこむのをふせいだり、火の番をしたりして警戒しました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが或晩、だれかゞその畠へはいりこんで、玉ねぎを十ばかりぬすんでいきました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
