[
  {
    "uuid": "10c1c09d-f4aa-5839-b1db-c1a0ef408eaf",
    "entry": "海参",
    "reading": {
      "primary": "いりこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
