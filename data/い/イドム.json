      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to challenge to (a fight, game, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "格上のチャンピオンに、無名の新人が果敢に挑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼にチェスで挑んだが、あっさりと負かされてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「いつでもかかってこい。お前の挑戦、受けて挑むぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "で、親族の男どもが、挑む、嬲る、威丈高に成つて袖褄を引く、其の遣瀬なさに、くよ／＼浮世を柳隱れに、水の流れを見るのだ、と云ふ。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはこれを使って、ついにおまえをわたしの娘にし得なかった人生の何物かに向って闘いを挑むだろう。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "而るに為憲と貞盛等と心を同じうし、三千余の精兵を率ゐて、恣に兵庫の器仗戎具並びに楯等を出して戦を挑む。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮さえしなけりゃ、なに」　と、そう言って、また戦を挑む。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は崇高な気持で愛しているものにも、ふと昆虫のような本能で挑むことがある。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――幻法のこれや苦しき脅迫いと淫らかに蒸し挑む疾風のもとに、現れて真黒に歎く楽の船、生あをじろき鱶の腹ただほのぼのと、暮れがての赤きくるしみ、うめきごゑ、血の甲板のうへにまた爛れて叫ぶ楽慾の破片の砲弾ぞ慄ける。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる間も白銅のこひしさに通りすがる肥満女の葱もてる腕に倚りてうち挑む。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "挑むは季節、触るるは鋭き草の尖、沈まむとする太陽光はますます赤く。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかげを小舟はくだる、蒸し挑む靄のふるへに。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と顎を出す、眼で挑む、「旦那やア。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人は君新年に成つたらお互に堂々と論戰しようぢやないかと挑む。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋人を取られた（或いは取られたと考えた）女が、恋敵の所へ押しかけて行って之に戦を挑むのである。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫を奪おうとした憎むべきリメイに断乎としてヘルリスを挑むべく、海盤車に襲いかかる大蛸の様な猛烈さで、彼女はア・バイの中に闖入した。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　　五　桂木は伸びて手首を蔽はんとする、襯衣の袖を捲き上げたが、手も白く、戦を挑むやうではない優しやかなものであつた、けれども、世に力あるは、却つて恁る少年の意を決した時であらう。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと気を許していると、浮き世離れした博愛主義者面で旧体制に挑む羽目になりますから、今後、電子本に味方する側からは、ずいぶん痛い目を見る人がでるでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてパーソナルコンピューターと真っ向う勝負を挑むこうしたマシンを気合いを込めてぶつけるにあたっては、日本サンは既存のコンピューターの階層構造にうまく折り合いを付けるいい子では、もはやいられなくなるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四節までの友に対する語は、天地に挑むが如き元気｜充盈せるものにて、あたかもバイロンやニエチェの一篇を読むようであるが、これに反して二十五節以下は沈痛｜悲寥なる哀語である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに激語を放つとも、そのために地は棄てられず磐は移らない、神を挑むが如き大なる言を発するも、汝の言を以て地を破壊し磐を移らしむる事は出来ないというのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の後で、至純な恋の心がすつかりひねくれて了つた後で――つい近頃延子（島田）を想ふようになつたのであるが、その延子に対しても変な臆病さと、「一種の虚栄心とも云ふべき感情の戦ひ」を勝手に挑むでは、勝手に自らテレたりするやうな愚を、うつかり繰り返して了ふのであつた。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "美姫あり、西より来って妻となり、男子十一人出生も人を喰った話ですが、わけても江戸名代胆力無双のわが旗本退屈男を目前にして、道に喧嘩口論を挑む者あり、逃げるに如かずと当らぬ八卦を下すに至っては、一珍斎どころか大珍斎も大々の大珍斎でした。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "女、淫に走って自ら挑むは即ち淫婦なり、共に天を戴かずとな、女庭訓にも教えてあることじゃ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨　われ／＼が頭とたのむ水野殿に敵意を挟んで、とかくに無礼をはたらく幡隨院長兵衞、いつかは懲らしてくれんと存じて居つたに、その子分といふおのれ等が、わざと喧嘩を挑むからは、もはや容赦は相成らぬ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「苦労」のことを云ひ残したが、僕の運動は、後から後からおし寄せるあいつに向つて戦ひを挑む思案のやうだ、無意識的ながら――。",
              "citation": {
                "source": "駆ける朝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして力に余る困難に挑むことそれ自体が赤蛙の目的意志ででもあるかに考へてゐるやうな、私の迂愚を嗤ふであらう。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、いぎりすへ来て数週間、私たちはさらさら人のうらみを買うようなことをした覚えはないし、またわざわざこんな奇計を弄してまで、私たちに戦いを挑む人も理由も、見わたすところありそうに思えない。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "……よいことがある、自分は、ツランの主将として、イランの主将に一騎打を挑む。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両耳の上の塹壕に宣戦をいどむと私たちの国境から突然逃げ出してしまった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に田んぼ道を歩いているとどこからともなく小さな子供がやって来て、「おじさん、相撲取ろう」といどむ。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上記のシバテンはまた夜釣りの人の魚籠の中味を盗むこともあるので、とにかく天使とはだいぶ格式が違うが、しかし山野の間に人間の形をした非人間がいて、それが人間に相撲をいどむという考えだけは一致している。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われわれが頭と頼む水野殿に敵対して、とかくに無礼を働く幡随長兵衛、いつかは懲らしてくりょうと存じておったに、その子分というおのれ等がわざと喧嘩をいどむからは、もはや容赦は相成らぬ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
