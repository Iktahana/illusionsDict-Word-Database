[
  {
    "uuid": "478d0787-3c19-50e7-8168-5aa4347a3d90",
    "entry": "挑む",
    "reading": {
      "primary": "いどむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
