          ],
          "literary": [
            {
              "text": "だから、いつまで経っても、出世できない様子です。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつまで経っても、死ぬと云うことは許されない。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "峯はいつまで経っても憂愁の纏流から免れ得ないようである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後はいつまで経っても、もう蜂の姿は再び見えなかった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでも其のうちに正体をあらわすかと思って、死骸をしばらく見つめていましたが、おまきさんの顔はやっぱり人間の顔で、いつまで経っても猫にならないんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局彼はいつまで経ってもそこが動けないのである。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで経っても私の「疲労」は私を解放しなかった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで経ってもこれに（と言って姉を指し）よしやんに済まん、よしやんに済まんと言いましてなあ」「なんのお祖母さん、そんなことがあろうかさ、と言っているのに」　それからのお祖母さんは目に見えてぼけていって一年ほど経ってから死んだ。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清夫はお母さんのことばかり考へながら、汗をポタポタ落して、一生けん命実をあつめましたがどう云ふ訳かその日はいつまで経っても籠の底がかくれませんでした。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めの間こそは新井田氏もより進んだ発見が工作費用を節減するものと感じて根気よくその成就を待っているようだったが、計算の仕事がいつまで経っても片づかないのを知ると、そしてその問題が解決されても、日本ではそういう蓄音機を実際に製作するのが困難らしいということをほのめかされると、だんだん性急になってきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは夢のようでもあり、いつまで経っても同じ繰返しばかりで飽き飽きしても感じられた。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで経っても、なまぐさ坊主だ。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、いつまで経っても、この子は立派になりません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、いつまで経っても何一つ正確に描写する事が出来ない筈です。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからいつまで経っても、古いのである。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎりぎりに行きづまって、くるしまなければ、いつまで経っても青空を見る事が出来ないのだ、いまは、かえって、きのう迄の行きづまりに感謝だ、などと甘い感慨にふけっている形なのです。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、現役の陸軍中佐でございますが、ちっともふとらず、おかしなことには、いつまで経っても五尺一寸です。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、若い女人の肉体の美しさと、四季それぞれの食物の味に言い及んだとき、彼の言葉はいつまで経っても尽きぬもののように思われた。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことではいつまで経っても学べるわけがない。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハヤ実に……誠に、何も何も、それを怨むのじゃありやせぬけれど、いつまで経ってもこいつの憎いは忘れられませぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも得体の判らない家の生活に混っていると、いつまで経っても割り切れない奇数の出続ける数字を扱っているようなもどかしさから不安の気持に襲われました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野はことし十九で、東京へ出てから足かけ四年になるのであるが、元来が薄ぼんやりした質の男で、いつまで経っても山出しの田舎書生であった。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々思い出したように乱暴な飛躍と喚声と太鼓の強打とを伴うほか、いつまで経っても同じような単調な踊を、しょぼしょぼした目でじっと見詰めている。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体何事が起ったのだろうと、なおも一心に森の方を見つめておりましたが、いつまで経っても、森を出て行く人影らしいものは見えず、銃声に驚いたかして、原ッパを渡る鳥の姿さえ見つかりません。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで経っても、峻は依然として挨拶をせずに出掛けて行って、いつのまにかこっそりと帰って来ては本に噛りついているという具合だった。",
              "citation": {
                "source": "秋草の顆",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、お婆さんは、いつまで経っても、もう寝床に親しむことが出来なかった。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――最初、朝田が彼女をこの部屋に待たしておいたまま、いつまで経っても戻ってこなかった。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗客の影も形もなく、いつまで経っても運賃はもらえそうになかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで経っても、みんな子供です。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし問題の分析をせずに研究すればいつまでたっても要領を得ないで五里霧中に迷うような事になってしまう。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
