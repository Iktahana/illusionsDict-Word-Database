        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そんな犬猫のことでいちいち騒ぐのはやめにして、もっと大切なことに集中しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は重要な仕事だけでなく、犬猫のような細々とした業務にまで目を通す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部長は犬猫の報告書にも細かく修正指示を出してくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
