[
  {
    "uuid": "9b4285b8-d1b1-5080-98cc-a02e23a1115d",
    "entry": "生き返る",
    "reading": {
      "primary": "いきかえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
