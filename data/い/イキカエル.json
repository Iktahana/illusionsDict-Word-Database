      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to revive",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "絶望的だと思われたが、懸命な蘇生措置によって息を吹き返し、奇跡的に生き返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ふう、生き返る心地だ」と独り言を漏らしながら、熱い湯船に肩まで浸かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "真夏の炎天下を歩き回ったあとの一杯の冷たい麦茶は、まさに生き返る思いだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "廃校を利用した芸術祭の成功により、活気を失っていた過疎の村が再び生き返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長らく続いた日照りのあと、待望の雨が降ると、枯れかかっていた草花が一斉に生き返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最終回に逆転満塁ホームランが飛び出し、敗色濃厚だったチームの士気が一気に生き返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の温かい励ましの一言で、絶望の淵にいた私の心は救われ、ようやく生き返ることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "妻は自分を見るや泣き声を絞って、何だってもう浮いていたんですものどうしてえいやらわからないけれど、隣の人が藁火であたためなければっていうもんですから、これで生き返るでしょうか……。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿江は話の腰を折られて……「先生その人はそれからどうかして生き返るんだろう」　と一人の男生がその騒がしさの中から中腰に立ち上って柿江に尋ねた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一度殴れば生き返るのだ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、花子さんが私の生まれ代りの羽子のムクロジにあたたかい息を何べんもはきかけて下さいましたので、二千年も昔に生き返る事が出来たのです。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀久ちゃんが死んだからって、蔦が生き返るわけでもあるまいし……」「でも、わたし、人を殺したんだから、わたしも殺されるのが本当だと思うわ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて生き返るものがあるとも、そを殺す所以はない。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふくろのおきよは、今もいう通りのしたたか者ですから、今さら甚吉を下手人にして見たところで、死んだ伜が生き返るわけでもないので、慾にころんで仇の味方になって、甚吉は人違いであるということを世間へ吹聴すれば、それが自然に上の耳にもはいると思って、偽幽霊の狂言をかいたらしいのです。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり旦那方の御鑑定通り、伊兵衛を殺したのは甚吉の仕業と判っているのですが、今さら甚吉を科人にしたところで、死んだ我が子が生き返るわけでもないから、いっそ慾にころんだ方が優しだと考えて、甚吉の家から三百両の金を貰って、弟の伊八を幽霊に仕立てたのだそうです。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――生き返るにゃまだはええや！",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦三郎　勿論唯今となりましては、たとひ何と申したところで死んだ父が生き返るわけではござりません。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだおじいさんが、生き返るわけじゃ無いし……）　喜助の心は、どこまでも弱く、そして悧巧であった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあ井戸の水を汲んで来てくれ」「水を飲ませたぐらいで、生き返るでしょうか」「なんでもいいから、早く水を汲んで来い」と、長三郎は叱り付けるように叫んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も死んだ人の腸がいわば生きかえるのですから、殺人犯人によっては、殺された本人が生き返ると同じようなショックを与えるであろうと私は思いました。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "水でも呑ませば生き返るかと、四辺を見ると誰のか知らんが、酒を入れる旅行持の革袋が飛び散って居る、是屈強と取り上げて口を開けるとブランデー酒の匂いがあるから、之を彼の口に注ぎ込んだが、死んだ蛙の生き返る様に生き返った。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に秀子が死んだのなら、余は自ら制し得ぬ程に絶望すること無論であるけれど、何と云う訳か爾ほどには絶望せぬ、随分呼び活ければ生き返る様な気がする。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏、毎日々々暑さに苦しめられて終日病床にもがいた末、日脚が斜めに樹の影を押して、微風が夕顔の白き花を吹き揺かすのを見ると何ともいはれぬ善い心持になつて始めて人間に生き返るのであつた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "春になれば自然は生き返る、寒い間の潛勢力を一時に發揮してかかる。",
              "citation": {
                "source": "道學先生の旅",
                "author": "戸川秋骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると孫は、「お爺さん、お婆さん、あなたたちはよほど前に死んでしまったんじゃないんですか」というと、お爺さんがいうのに、「世の中では私たちを死んだというんだが、いわゆる死んだ人も世の中の人の忘れている間は死んだというんで、紀念してくれる人があるとその度ごとに生き返るんだ。",
              "citation": {
                "source": "「死」の問題に対して",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度これから生き返るのよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が忽然として彼の消失を感じ、一層強く我うちに生き返る感を持たないのは、彼と自分との人格的共通点のないことを意味する。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き返ることの出来ない処にそれが行つて居たのでしたらどうでせう。",
              "citation": {
                "source": "遺書",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい、生き返るような風が一としきり長峰の方から吹き颪して、汗ばんだ顔を撫でるかと思うと、どこからともなく蜩の声が金鈴の雨を聴くように聞えて来る。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生き返るのがいやなら、ここでいつまでも死んでいるがいい」「それよりも張を見てやろうよ」「張も死んだまねをしているのじゃないか」　山木と河合とは、張の方へ走り寄った。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠ったが最後葉之助は、生き返ることは出来ないだろう。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だってさ、生き返ることだってあるだろう。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、どうも生き返る見込みがなさそうだから、暑くならないうちに切り倒して、害虫の蔓延を防ごうということになったが、有力な反対が起った。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ねなかったら生き返るとも云った。",
              "citation": {
                "source": "浅間噴火口",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "別所が自殺するか生き返るかを、李は「絶大な興味で観察する」役目を自ら荷った。",
              "citation": {
                "source": "浅間噴火口",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が不思議な薬を持っておりますから、かならずいきかえるのです。",
              "citation": {
                "source": "封三娘",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
