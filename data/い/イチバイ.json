          ],
          "literary": [
            {
              "text": "人一倍の修業をしなけれあ、どんな天才だって落ちてしまいます。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私はこれまで滅茶な男のやうに言はれてゐるし、人と同じ樣に立小便しても、ああ、やつぱりあいつは無禮だ、とたちまち特別に指彈を受けるであらうから、旅に出ても、人一倍、自分の擧動に注意しなければ、いけない。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が人一倍、非力の懦弱者であるせいかも知れない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大したことでもないけれど、家庭的な悲劇といふものを何時も目の前にしてゐなければならない私は、そしてその悲劇なるものが常に我々のセンチメントのために悲劇であると観た私は、自分が人一倍感傷家であるといふことが歯痒ゆかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけにその印象はかえって一倍強烈であったのかもしれない。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の人が、セント・ジョルジ・ギルドの人たちのように、糸車を挽いて、木綿を手織って衣ているかどうかを知らないが、風呂の水も、雑用の水も、熔岩の下から湧く渓河から汲み上げて、富士の高根の雪解の水と雨水との恩恵の下に、等分に生きていることを思うと、富士の裾野の水々しさに、一倍の意義があると思われる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎になってしまってからの愛児の看護に骨を折るよりも、風邪を引かせぬ予防法、引いたときに昂じさせぬ工夫に一倍の頭を使う方が合理的である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其方も早くに二親とも世をさりしとか、我れも母なりし人の顏はしらで、育ちしは父上の手一つなれば、戀しさなつかしさは又一倍におぼゆるぞかし、平常はともあれ由縁ある日はこと更におもひ出されて、まぎらさんとても氣のまぎれぬは今日なり。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現はお坊つちやんじみてゐても、その機敏でよく氣のつくことは人一倍です。",
              "citation": {
                "source": "ふつくりとした人柄",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間の地は痩せて、一倍の苦労をしながら、収穫はどればもなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしげはともかく、六蔵のほうは子供だけに無邪気なところがありますから、私は一倍哀れに感じ、人の力でできることならば、どうにかして少しでもその知能の働きを増してやりたいと思うようになりました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一倍半の高さと、二倍の幅と、三倍の長さと、倍の機関銃を要する。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じようなのでまた直径が一倍半くらい大きいのがそろって集団をなしている。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "細工の大きい男は、それだけ、人一倍の修業が必要のようである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴室では神崎、朝田の二人が、今夜の討論会は大友が加わるので一倍、春子さんを驚かすだろうと語り合って楽しんで居る。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "垢染た煎餅布団でも夜は磯吉と二人で寝るから互の体温で寒気も凌げるが一人では板のようにしゃちっ張って身に着かないで起きているよりも一倍寒く感ずる。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服はびしょぬれになる、これは大変だと思う矢先に、グイグイと強く糸を引く、上げると尺にも近い山※の紫と紅の条のあるのが釣れるのでございます、暴れるやつをグイと握って籠に押し込む時は、水に住む魚までがこの雨に濡れて他の時よりも一倍鮮やかで新しいように思われました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人一倍美しいやさしい感情を持っていなかったのであったら、このような煩悶はおそらく有り得なかったのではあるまいか。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで特に雨の降る日などは、この金曜日が一倍苦になるのであった。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚をして人一倍の忠義ができる。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の青空を見上げると人は一倍寒さを感ずる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別過去や未来を思ふことはしないで、一を一倍しても一が出るやうな現在の中に、慎しく生きてゐるのだ。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして、釈尊をはじめ、古今多数の開祖、名僧知識たちは、大抵その欲望、煩悶の人一倍強かった人達でありまして、自分自身の克服解脱から割り出した宗旨、教義、修業法でありますから、それぞれ救い方に特色があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人一倍涙もろい性質に自分でも困っております。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不斷そんなしだらでない岩さんだけに、女房は人一倍心配し出した。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、」と尚ほ一倍、夜の更けたのが身に染みた。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断そんなしだらでない岩さんだけに、女房は人一倍心配し出した。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此男は正直だから、猛狒退治の手柄話は勿論、自分の大失策をも、人一倍の大聲でやツて退けた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから四年て、名殘なく全快して、今は人一倍に健全に、英國から新造軍艦の廻航中、此「日の出」に乘つて居る事は貴方も御覽の通りです。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子は、あまやかされて、育てられたうえに、人いちばい、ごうじょうときています。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
