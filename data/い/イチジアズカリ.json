        "examples": {
          "standard": [
            {
              "text": "デパートで買い物をする間、子供を一時預かりサービスに頼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "駅のロッカーがいっぱいだったので、手荷物一時預かり所にスーツケースを預けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行中、近所のペットホテルで愛犬の一時預かりをお願いすることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スキーを楽しむため、小さな子供はゲレンデの一時預かり施設に預けてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "傘は入口の一時預かりカウンターで預けてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新居への入居まで期間があるので、家財道具の一部を倉庫で一時預かりしてもらう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イベント会場では、貴重品の一時預かりは行っておりません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "最近では、ペットの一時預かりにまでビジネスを広げているが、魂は、物書きである。",
              "citation": {
                "source": "三重塔にて",
                "author": "福永信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
