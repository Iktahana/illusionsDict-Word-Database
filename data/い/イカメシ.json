    "definitions": [
      {
        "index": 1,
        "gloss": "Ikameshi (rice-filled squid)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "北海道の駅弁といえば、やはり定番のイカ飯は外せない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今日の夕食は、手作りのイカ飯にしようかと思って。下準備が大変だけど、美味しいから頑張るわ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この居酒屋では、醤油ベースでじっくり煮込んだイカ飯が人気メニューらしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃から、おばあちゃんが作ってくれるイカ飯が大好きだったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お土産店には、様々な地域の特色を活かしたイカ飯弁当が並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お弁当、今日何？」「んー、今日はイカ飯だよ！」「わー、いいね！私のも一口ちょうだい！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "楊林宮沢賢治エレキに魚をとるのみか鳥さへ犯すしれをのこ捕らでやまんと駐在の戸田巡査こそいかめしきまこと楊に磁の乗りて小鳥は鉄のたぐひかやひとむれさつと落ち入りてしらむ梢ぞあやしけれ",
              "citation": {
                "source": "楊林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかめしい城郭のようなライブラリーも柔らかで憂鬱な霧の薄絹に包まれている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれもいかめしく鎧を着こんでゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・バビロンの白煉瓦の高層な建物から流れるワルツの曲が街角に直立した赤い帽子の印度巡査をモスモロスの道化役者風にしたててバビロンの入口の廻転ドアの前に金モールのいかめしい英国人の門衛が莞爾とした笑いをたたえている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、心でそのいかめしさに反撥しながら、知らず／＼素直におど／＼した返事をした。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前だけ聞いたところではたいそういかめしいお役所のような気がして、書類の山の中で事務や手続きや規則の研究をしている所かと想像していたのであるが、事実はまるで反対で、それは立派な応用科学研究所であって多数の実験室にはそれぞれ有為な学者が居て色々有益で興味のある研究をしているのであった。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場も、塀も、社宅も、すべてが、いかめしい棘だらけの鉄によって庇護されている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　生徒は、いかめしげに叫ぶ。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の峯の天にいかめしくて、磧礫も火炎を噴くかと見ゆる夏の日、よろづの草なども弱り萎るゝ折柄、此花の紫雲行きまどひ蜀錦碎け散れるが如くに咲き誇りたる、梅桜とはまた異るおもむきあり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "信實の歌にては、夕立する頃の例のいかめしき雲を云へるが如く、後鳥羽院の御歌にては、たゞ美しき夕の雲をさし玉へるが如し。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう考えてみるとドイツ人の論文の中に、少なくもまれには、愚にもつかない空虚な考えをいかめしい数式で武装したようなのもある、そのわけが読めるような気がした。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫どもは気が付きませんでしたが、事務長のうしろの窓の向ふにいかめしい獅子の金いろの頭が見えました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "振りかえって見ると武之允といういかめしい名を寺の和尚から附けてもらった男で隣村に越す坂の上に住んでいる若い者でした。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろになってわれわれはそれを少しばかり整理しみがき上げて、そうしていかめしい学という名をつけたのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）神職　（威儀いかめしく太刀を佩き、盛装して出づ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき霧の向こうから、大きな赤い日がのぼり、羊歯もすぎごけもにわかにぱっと青くなり、蟻の歩哨は、またいかめしくスナイドル式銃剣を南の方へ構えました。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「取つた」と云ふことを云ひたくない為に、三度云ひ淀んだ被告の態度は、ある者をして吹き出させやうとしたが、自分が今いかめしい法廷の中に居るのであると気がついたとき僅に笑を噛み殺した。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓは銃につけ剣して、いかめしく身構えて、つまり見張りの役をしていたのだ。",
              "citation": {
                "source": "面会",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつくしい夢幻境が消えて、いかめしい現実境が来る、見ると、傍に老祖母がうとうとと睡っている。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時には、無論窓にいかめしい目かくしが下りていた。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "金モールのいかめしい制服を着た門番も、その他の誰も、私を怪しむ様子はなかった。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外を難解な、深遠のものとして、衆俗のむやみに触れるべからずと、いかめしい禁札を張り出したのは、れいの「勉強いたして居ります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさは、ただ、いかめしい気持、いや、しらじらしい気持といったほうが近いかも知れぬ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（伝兵衛）（いかめしく）その男と一緒になってから何年になる。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな、でたらめな歌をうたって、クルミのからのかぶさった名なし指を、まげたりのばしたりしながらやっていくと、いかめしい石のへいの下で、女の子がひとり、しょんぼりすわっていました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "武人はやはり合戦となると、御平常とがらりと変つて、いかめしく猛り立つもののやうでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉七は、いかめしい顔つきになり、真暗い窓にむかって独りごとのように語りつづけた。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といかめしい口調で言い、御奥へ引上げる城主に向って平伏し、「やれやれ、馬鹿どもには迷惑いたす。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
