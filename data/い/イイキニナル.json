          ],
          "literary": [
            {
              "text": "来年になるとあれがみんな二年生になっていい気になる。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洒落は漫才師でも言うぜ」　いい気になるなと、豹吉はうそぶいた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私はビイルを、がぶがぶ飲んで、「少し優しくすると、すぐ、程度を越えていい気になるし、ちょっと強く言おうと思うと、言われぬ先から、泣きべそをかいて逃げたがるじゃないか。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気になるてえと、またぽかりしょい投げを食わされるぜ」　たわいのない配下たちの、たわいないささやきを聞き流しながら、名人はしきりと行きかう人を物色していましたが、おりよく通りかかった金棒ひきを見つけると、しらばくれて尋ねました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍のものもあんまりさわぐからいい気になるのだ。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気になると恐ろしい。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは口が渇くほど腹が立ってきて、「アメリカが勝ったと思っていい気になるな」　と怒鳴りながら、懸命にはねかえしにかかったが、口惜しいが義足ではあがきがつかない。",
              "citation": {
                "source": "南部の鼻曲り",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "縹緻がよくたって、あまりいい気になるな」「わかった……あたしが笑ったんで、それで、むくれているんだわ……そんな恰好をしていないで起きなさいってば！",
              "citation": {
                "source": "生霊",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙を見せるといい気になるから、ほどよくあしらっていたんですわ」「そう言えば、宿でもそんなことを言われました。",
              "citation": {
                "source": "生霊",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてそういい気になるんです」　畜生、どいつがいいやがったんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気になるなよ　もうたくさんじゃわい　いなねば　上からけおとす！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかいお前、いい気になるなよ、こんな話はもうたくさんじゃ。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気になるなよもうたくさんじゃわい　いなねば上からけおとす！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな眼で見ると、あの子がいい気になるからおよしなさいよ。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分一人が百姓になっていい気になるなんどのケチな了見はフッツリとやめた。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これゃ、ちょっと口惜しいね」　すると後にいた松久が、「あまり、いい気になるといけないから、すこし、たしなめてやろう」　といって知世子のところへ行った。",
              "citation": {
                "source": "予言",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "安易に自分より知徳の劣った人と交っていい気になるのは禁物である。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "安易に自分より知徳の劣った人と交って、いい気になるのは禁物だ。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし一度真剣な不幸、こびを受け入れぬような、またいい気になることを許さぬような悩みにおそわれたが最後、これらの小さな幸福者であり物真似師である人々は、大変なことになってしまう。",
              "citation": {
                "source": "ルイスヒェン",
                "author": "LUISCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "（短剣を右手に逆手に持って、静かに力を入れながら）いい気になるのはよした方がいい私はいつでも音もなくお前さんがたの後ろにピッタリくっついて歩いてるお前さんがたの背中には、いつでも、これが突きつけられている人間は、薄い袋に入れた三升ばかりの血液に過ぎない。",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、いい気になることの危さとしてそれを云っていらっしゃる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "色男ぶって、いい気になるからこんな目にもあうのだ」　父が義兄にずけずけ云ったことばは余りに痛烈だったから、ぼくら小さい者の耳にも沁みた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし正篤はそれでいい気になるというふうはなく、二日おき三日おきくらいにでかけ、夜もあまり更けないうちにきちんと帰った。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人がいい気になるだけ、救われがたいもんでさア。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、すぐいい気になる彼でもない。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
