        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫は餅の位置を焼けたのと焼けないのと入れ替えてからこういった。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は独創的な研究によって人間の眼は獣類の眼と入れ替える事が容易で、且つ獣類の中でも豚の眼と兎の眼が最も人間の眼に近似している事を実験的に証明した。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、水筒に水を入れ替えて、またガソリンの爆音を立てさせた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早くお膳を下げて、お茶を入れ替えて来るのだ。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、『大百科事典』をより便利に活用できる準備が整ったのだから、自分が買ったものの器を入れ替えたいと私は考えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいったん書き上がった文章を見直し、前後を入れ替えたり字句を訂正したりといった推考の段階では、手書きが生きる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のコンピューター界に現われた鬼才二人は、コンピューターのメディアへの変質とＩＢＭ産業スパイ事件という歴史の転換をはさんで、標準と独創を百八十度入れ替えて対置した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばギターとキーボードの音の入れ替え。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギターとキーボードを入れ替えても、二人が同時に演奏すりゃどっちがどっちか分からない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出花を入れ替えてまいりました、さあどうぞ……」「あ、今おりて湖水のまわりを廻ってくる」「お二人でいらっしゃいますの……そりゃまあ」　女中は茶を注ぎながら、横目を働かして、おとよの容姿をみる。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらでもう料簡を入れ替えて、兄や自分の罪ほろぼしに六十六部となって廻国修行の旅に出ようと思い立った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "また肉の一片を肉を食うた跡へ入れ替える（フレザーの『金椏篇』一板二巻三章）。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よく気を入れ替えなんした。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い踵にからむ部屋着の裾にも雪の日の寒さは沁みて、去年の暮れに入れ替えたばかりの新しい畳は、馴れた素足にも冷たかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の大小はお里の着物や帯と入れ替えにして、無事に質屋の庫から請け出されていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その了見、そちも向後入れ替えたらよかろうぞ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "性根入れ替えると一言申さば、主水之介とて同じお旗本につらなる身、ことを荒立てとうはない！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "了見入れ替えて、お捜しなさいましよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへこの重いホスゲン瓦斯がやってきたものだから、これは温い空気と入れ替えに喜んで烟突を下ってゆく。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "破損箇所を知ると、船頭は漁夫を指揮し、マニラトワイン、南京麻等の新網を入れ替えてゆく。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりながら愚考はいたく異なり、和歌の精神こそ衰えたれ形骸はなお保つべし、今にして精神を入れ替えなば再び健全なる和歌となりて文壇に馳駆するを得べきことを保証致候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふかふかした絹布の座蒲団が、入れ替えたばかりの藺の匂いのする青畳に敷かれてあった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい足袋をはいて、入れ替えたばかりの青い畳のうえをそっちこっちわさわさ歩いているお増の衣摺れの音が忙しそうに聞えたり、下駄を出すお今の様子が、浮き浮きして見えたりした。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「節ちゃん、そんなとこに坐っていなくても可いから、お茶でも入れ替えて進げて下さい」　岸本は節子を庇護うように言った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "発注元のビジコンは、新しい電卓を作るたびに一から設計する代わり、ソフトウエアの入れ替えによっていろいろな機能を実現できる集積回路が作れないかと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "互換ベーシックの問題が発見された際、ＲＯＭが基板に組み付けてあるのでは筺体をはずしてから入れ替えてもう一度組み立てざるをえない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、心をいれかえたのよ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで皆も気をいれかえて、新らしい気もちになってかかれ、決して其の方たちにお咎めはない、お咎めがあれば拙者じゃ」　人夫たちの眼は活いきとした。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹がすいて口が水っぽくなって来ると、お庄は昼間しまっておいた、蒸した新芋の冷たいのを盆ごと茶箪笥から取り出して来て、また茶をいれかえなどした。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとさとった　親たちは、すっかり心を　いれかえて、笛吹男の　はなしをば石にきざんで　世にのこし、罪ほろぼしを　したという。",
              "citation": {
                "source": "魔法の笛",
                "author": "ロバアト・ブラウニング",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
