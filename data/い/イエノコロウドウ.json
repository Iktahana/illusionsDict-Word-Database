[
  {
    "uuid": "c799d7d5-5eab-5cf5-a968-025fc1b2531e",
    "entry": "家の子郎党",
    "reading": {
      "primary": "いえのころうどう",
      "alternatives": [
        "いえのころうとう"
      ],
      "is_heteronym": false
    },
    "grammar": {
