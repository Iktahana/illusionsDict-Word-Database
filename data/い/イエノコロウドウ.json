    "definitions": [
      {
        "index": 1,
        "gloss": "followers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "戦国時代の武将は、信頼できる家の子郎党を率いて戦場を駆け巡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの老作家には、長年彼を支えてきた家の子郎党のような編集者たちがいるよ」と友人は微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい事業を立ち上げる際、彼は昔からの家の子郎党とともに困難を乗り越えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "選挙戦では、候補者の家の子郎党が昼夜を問わず奔走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "城主が討ち死にしたと聞けば、家の子郎党は皆、仇討ちを誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引退した会長の周りには、いまだに家の子郎党のように慕う元社員たちが集まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "恩顧譜代の家の子郎党に取り囲まれた鎌倉時代の武士と比べると、幕末の武士達は、もう武士でなくなつてゐるわけである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすまた、もじり、棒、まさかり、こういうものだって馬鹿には出来ねえ、出来るだけ手入れをするがいい」　副頭領の楠右衛門、四人の小頭、十人衆、いわゆる家の子郎党が、クルクルクルクルと立ち働く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本何々学会という種類のものが夫で、主に例の研究室夫々の家の子郎党達の緩衝的外交地帯をなすものだが、同時に又研究室人の学界を一般社会に推し出すメカニズムともなっている。",
              "citation": {
                "source": "学界の純粋支持者として",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "聚楽第の西の花園の地に、手広い屋敷を営んで、家の子郎党も多少貯え、近郷の者には尊敬され、太閤秀吉にも認められ、殿上人にも親しまれて、のびやかに風雅にくらしていた。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の子郎党も多少はあり、家の生活も不自由はせず、父は学究でござりまして、心も寛く親切でもあり、そうして私といたしましても、自分で自分を褒めますのは、ちとおかしくはござりますが、まず悪人ではござりませぬ。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しも彼等がお通夜帰りに婚礼を訪れたとしたら、担ぎやの頑固ぢぢいは家の子郎党に棍棒を握らせて鏖殺しにするまでは腹の虫がおさまらないに相違ない。",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで家の子郎党たちは、取るものも取り敢えずに道庵先生の門を叩きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は、今晩は」　大尽の家の子郎党は、傾きかかった道庵先生の家の門を、荒々しく叩きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇都宮弥三郎頼綱が家の子郎党を従えて、済々として武蔵国を通ると、熊谷の入道直実に行き会うた。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞いて家の子郎党達が馳せ集まったので、弟子達軍兵済々として前後をかこみ、その数一千人余り、各々涙を流し悲しみを含んで輿を守護して行った。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸司諸役ことごとく更替して、大老の家の子郎党ともいうべき人たちで占められている。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ安政、万延のころに井伊大老を手本とし、その人の家の子郎党として出世した諸有司の多くは政治の舞台から退却し始めた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸はどんなに騒いでいるだろうかとも、江戸詰めの諸藩の家中や徳川の家の子郎党なぞはどんな心持ちで筑波の方を望みながらこの橋を渡るだろうかとも、そんな話は出なかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にも、徳川の家の子郎党の中にすら、この主人をよろこばないものがある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にイエノコと訓読して家の子郎党と並称せられたものは、すなわちもと中間男に相当する「侍」で、国法上この家人階級に当るものであった。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉門と多四郎とお妻と東馬、四人を乗せた駕籠を守り、十数人の嘉門の家の子郎党が、騒乱の領内から裏山づたいに、福島の方へ走り出したのは、それから間もなくのことであった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "能遠たちは、もはや敵わぬと思ったのか、家の子郎党たちが必死の防戦をしている中を、屈強の馬に乗って逃げ落ちてしまった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度屋島では、阿波民部重能の息、教能が、伊予の河野四郎が平家に背むいたのを攻めて、河野だけはうちもらしたが、家の子郎党、百五十人の首を取ってきたので、宗盛の宿所で首実験の真最中であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この私、鎌倉殿よりほかには、主という者を持たぬ身じゃ」　この様子に、景時の息子、景季、景高、景家始め、家の子郎党十四、五人も、てんでに打物をとり、今にもうってかかろうとする様子をみせた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "摂津源氏で、太田太郎頼基は、「門の前を黙って通させたらば、鎌倉殿のお覚えも悪かろう」　と、家の子郎党六十余騎を引き連れて、河原津というところに追い付いて攻め駆けた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前の国府にひと先ず落着いた義仲は、家の子郎党を一堂にあつめて会議を開いた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "外侍には家の子郎党などが肩を並べひざをそろえて、ぎっしり並んでいた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "月初めには、東、月末には西の方でございます、左様、その瀬の間はほぼ海面十町程でござりましょうか、ここならば馬もたやすく入れまする」　盛綱はこの話にすっかり喜んで、家の子郎党にも知らせないで、その男と二人で、案内されるままに瀬を渡ってみた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の子郎党が七騎後に続いた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、さしも腕に覚えの法眼湛増も、家の子郎党を数多く射たれ、わが身も傷を負って、命からがら本宮熊野へ逃げ帰ったのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "応挙の「蓬莱山図」と葉牡丹を根〆にした大きな苔松を背景にして、林謹直、道灌山前田組の大親分、それに林の家の子郎党が五人ばかり。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに満足な槍が三筋、弓が二た張、矢が二三十本、これらはすべて、昔の豪族が、家の子郎党の手で自分の家を護った時の遺風らしく、いつでも取出せるように用意してあったのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "門も木戸も内から鎖されたままになっていたといいますから、邸内に手引の者がない限り曲者は塀を越えて逃げたものと思わなければなりませんが、邸内に住んでいるのは、赤井左門の家の子郎党達ばかり、草履取りや仲間まで、千葉の領地から呼んだ正直者ばかりですから、そんな大それた人間は居るはずもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大盗懺悔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、騒ぎを聞付けて、多勢の家の子郎党達が駆け付けました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒木長者の屋敷へ着くと、その頃顔も名も売れた御用聞の銭形の平次が、神田からわざわざ駆け付けて来たというので、家の子郎党達は下へも置かぬあしらい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
