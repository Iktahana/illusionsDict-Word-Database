        "examples": {
          "standard": [
            {
              "text": "彼女はただの一般人ではなかった。その才能はまさに逸般人たる所以だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その発明家は、画期的なアイデアで同僚から逸般人だと見なされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ほとんどの人が台本通りに進む中、逸般人である彼はあえて即興に挑戦した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
