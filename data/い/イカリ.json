    "definitions": [
      {
        "index": 1,
        "gloss": "anger",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい税制に対する国民の怒りが、デモへと発展した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の無責任な言動に、彼女は抑えきれない怒りを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の遅刻の連絡に、「もう！本当に腹が立つ！」と彼女は怒りを露わにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "審判の不可解な判定に、選手は隠しきれない怒りを漂わせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "何度も同じミスを繰り返す自分自身への怒りから、彼は机を叩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議での建設的でない意見交換に対し、参加者からは静かな怒りの声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ああ、わが故郷にあるの日、終日怒りうゑを感じ、手を高く蒼天のうへに伸ぶ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂはまたそれを感ずるから、「君等の考へてることは違ふ」とかなんとかいふ、とまれ形勢は悪くなるから、それ聴く方は漸く面倒臭がりだすから、尚も云はうとすれば声は次第に金切声になるとか、怒りつぽくなるとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日所感萩原朔太郎朝鮮人あまた殺されその血百里の間に連なれりわれ怒りて視る、何の慘虐ぞ",
              "citation": {
                "source": "近日所感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年多少日本に幻滅を感じた時でさえも、他の外人が日本を悪意的に批評する時、いつも憤然として大に怒り、さながら自分の愛人を侮辱された時の騎士のごとく、鋭い反撃の槍をふるって突き当って行った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを憤慨しているが、むしろ彼の真の怒りは基督教に向っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に私は、その寛容に對して小癪に感じ、時に彼によつて憐憫される怒りを感じた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は怒りたくなったからです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひとは、恥ずかしくて身の置きどころの無くなった思いの時には、こんな無茶な怒りかたをするものである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人が、私の器量の悪口を言ふと、叔母は、本気に怒りました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人が、私の器量の悪口を言うと、叔母は、本気に怒りました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本気な従兄の怒りを恐れる気持をゴマカすやうに、Ｓ子は雪駄の音をペツタペツタさせて、オドケてみた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷山の嶋嶋から、幻像のやうなオーロラを見て、著者はあこがれ、惱み、悦び、悲しみ、且つ自ら怒りつつ、空しく潮流のままに漂泊して來た。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒りて書物を投げすてひとり校庭の草に寢ころび居しがなにものの哀傷ぞはるかに彼の青きを飛び去り天日直射して　熱く帽子の庇に照りぬ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と旦那は怒り、ぎよろりと妻子を睨んですつくと立ち上り、奧の薄暗い部屋に退却して、そつと鏡を覗き、がつかりして、「これは、駄目だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島太郎は、弟妹たちのそんな無遠慮な批評を聞いても、別に怒りもせず、ただ苦笑して、「好奇心を爆發させるのも冐險、また、好奇心を抑制するのも、やつぱり冐險、どちらも危險さ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは怒りやしませんね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "處女の怒りは辛辣である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉間には狐疑の深い皺がきざみ込まれ、小さい灰色の眼には淺間しい殺意が燃え、眞蒼な頬は威嚇の怒りに震へて、黒ずんだ薄い唇は嫌惡と侮蔑にひきつつたやうにゆがんでゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子は、決して怒りやしない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人が、私の器量の惡口を言ふと、叔母は、本氣に怒りました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑なの心は、理解に欠けて、　　なすべきをしらず、ただ利に走り、　　意気銷沈して、怒りやすく、　　人に嫌はれて、自らも悲しい。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神の翁に、噎返るような怒りと愛惜の念、また、不如意の口惜しさ、老いて取残されるものの寂しさがこもごも胸に突き上げて来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眷属中の良いところのものを一人で」と託ったが、男のこころまでかくも牽くということを聴くと、うらやましさが嵩じてなった嫉みは、更に毒を加えて燃えさせられ、激しい怒りとなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おら、嫌だと言ったんだけれど、みんなが無理に着せるんだよ」　四郎はお蘭の怒りに怯えながら言った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には怒りも憎みもします。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは私情の憎みや怒りとは違います。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年十二月、鉄塔）二　錨と怒り、いずれも「イカリ」である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒りを意味する choler はギリシアの胆汁のコレーから来ているそうで、コレラや gall や yellow なども縁があるそうである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ｇｒの代わりにｇｄを取ってみると、アラビアの動詞 ghadiba（怒り）の中に見いだされる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアの「怒り」gniev はギリシアの動詞 aganaktein の頭部に似ている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
