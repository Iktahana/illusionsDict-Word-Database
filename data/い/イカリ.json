[
  {
    "uuid": "98c0f8e3-31c0-58e4-954e-3b39a3f52096",
    "entry": "怒り",
    "reading": {
      "primary": "いかり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
