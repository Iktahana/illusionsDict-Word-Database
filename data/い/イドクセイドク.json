        "examples": {
          "standard": [
            {
              "text": "ライバル社のスキャンダルを暴露するとは、まさに以毒制毒の戦略だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "一部の抗がん剤治療は、強力な毒素でがん細胞を叩くという、以毒制毒の考え方に基づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "トリカブトの毒を薬として利用するなんて、昔の人は以毒制毒の発想を持っていたんだな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "野村の父は遂いに窮余の策として、お清の提案たる「以毒制毒」の方法に同意したのだ。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、以毒制毒の法則が使えるからです。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
