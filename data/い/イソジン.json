    "definitions": [
      {
        "index": 1,
        "gloss": "Isodine (iodine-based disinfectant)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
