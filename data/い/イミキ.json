    "definitions": [
      {
        "index": 1,
        "gloss": "Imiki (fourth highest of the eight hereditary titles)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
