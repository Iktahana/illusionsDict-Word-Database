        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "法廷での証言を拒むよう、組織の幹部が証人を威喝した疑いで再逮捕された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-thinking-exp"
              }
            },
            {
              "text": "借金の取り立てに際し、深夜に大声で怒鳴りつけるなどの威喝行為が繰り返されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-thinking-exp"
              }
            },
            {
              "text": "権力による威喝をもって相手を畏縮させ、無理やり不利な契約に署名させることは断じて許されない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-thinking-exp"
              }
            },
            {
              "text": "上司は威喝的な口調で部下のミスを執拗に責め立て、職場全体の士気を著しく低下させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-thinking-exp"
              }
            },
            {
              "text": "独裁政権は国境付近で大規模な軍事演習を挙行し、周辺諸国を威喝する意図を露骨に示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-thinking-exp"
              }
            },
            {
              "text": "「いかなる不当な威喝にも屈することなく、我々は法の正義を信じて最後まで戦い抜く」と弁護士は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash-thinking-exp"
              }
            }
          ],
          "literary": [
            {
              "text": "」　ふたたびミサコは肥大した女を威喝するように女記者に云った。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一寸軽蔑したいような気持になりましたが振り向いて指示された空を見た時、北の方に怪物のような大雲を見て何だか威喝されたように不安に胸がおどりました。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか別の客に向つて、あれほどの圧倒的な威喝を浴せた男であるからには、いつかは短気を起して私の上にも目ざましい罵りを加へるだらう――私はそういふ光景を自分の上に想像して、吾ながらの生気を呼び反したいといふやうな憐れな状態だつた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ふに秀吉往々威喝を用ゐて人を屈するを慣術とすれども、亦敢て籠裡の小禽をば無益に殺生せん暴人にはあらじ。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歩みに抗する一切の系統を　イバラを積重ねるふやけた脳髄を　戦争を強要する兵隊靴の威喝を歴史の教科書にまで叩込むんだ！",
              "citation": {
                "source": "イリイッチの長靴",
                "author": "佐藤武夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、二人の交通氏の方は、そんな未熟な威喝などを相手にするようすもなく、「冗談いうねえ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の威喝に欺かれ恐れて引きて可ならむや！",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』しか陳ずれば双の馬、主公の威喝恐れつゝ、激しく驅くる、然れども間なく忽ち勇猛の、アーンチロコス目前に、窪める狹き路を見る、冬の雨水｜滔々と集り寄せて道崩し、　420あたりをすべて推し窪め、深き低地となす處、他と衝突の患避け、そこに向へりメネラオス。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　445しか陳ずれば双の馬、主公の威喝恐れつゝ、激しく驅けて競爭の相手にすぐに近づけり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくともたいていは威喝だけで、事実捕獲をしようと迄はしなかった。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何者だッ、貴様は」　海部の安井民右衛門、胸を張って威喝した。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニのうしろには、いつから乗ってゐたのか、せいの高い、黒いかつぎをしたカトリック風の尼さんが、まん円な緑の瞳を、じっとまっすぐに落して、まだ何かことばか声かが、そっちから伝はって来るのを、虔んで聞いてゐるといふやうに見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、日頃いかつい軍曹の眼に感激の涙さへ幽かに染んでゐるのを見てとると、それに何とない哀れつぽさを感じて次から次へと俯向いてしまつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊長は、軍刀のつばのところへ左手をやって、いかつい眼で、集って来る百姓達を睨めまわしていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊長は、通訳からその意味をきくと、じろりと、いかつい眼で暫らくその男を睨みつけた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小川は、なお、一と時、いかつい眼つきで源作を見つめ、それから怒っているようにぷいと助役の方へ向き直った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といかつく京一に云いつけた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニのうしろには、いつから乗っていたのか、せいの高い、黒いかつぎをしたカトリック風の尼さんが、まん円な緑の瞳を、じっとまっすぐに落して、まだ何かことばか声かが、そっちから伝わって来るのを、虔んで聞いているというように見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……織次は、かつ思いかつ歩行いて、丁どその辻へ来た。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニのうしろには、いつから乗っていたのか、せいの高い、黒いかつぎをしたカトリックふうの尼さんが、まんまるな緑の瞳を、じっとまっすぐに落として、まだ何かことばか声かが、そっちから伝わって来るのを、虔んで聞いているというように見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニのうしろには、いつから乘つてゐたのか、せいの高い、黒いかつぎをしたカトリツク風の尼さんが、まん圓な緑の瞳を、ぢつとまつすぐに落して、まだ何かことばか聲かが、そつちから傳はつて來るのを愼しんで聞いてゐるといふやうに見えました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ問いかつ聞いているうちに夕暮近くなった。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋をはいた足のいかつい線も打ちこわしである。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆を折って世とともに濁波を挙げて笑いかつ生きんとしたること幾度なりしを知らざるは、たまたま我が耿々の志少なきを語るものにすぎずといえども、あるいは少しく兄の憐みを惹くものなきにしもあらじ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等甲板の船艙のつるつる光る白い壁に黒いかつぎのカトリックの尼さんが緑の円い瞳をそらに投げて竹の編棒をつかってゐる。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ丈の資金があるが、何とか利殖の方法があるまいかつて君に相談したんでせう。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜になつて、僕を電話で呼んで、手形の形式はいいかつて云ふんでせう。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ丈け男の詞がいかつく女の耳に響いた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のいかつい肩に陽の光がしきりに降り注いだ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い煉瓦の建物のある街角に立っていた肩のいかつい蒼白い顔をした青年が、私の腕を素早くとらえた。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
