[
  {
    "uuid": "3f9b036b-2d18-5af5-a4ee-2b250eb0584e",
    "entry": "何れにしろ",
    "reading": {
      "primary": "いずれにしろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接続詞"
      ],
