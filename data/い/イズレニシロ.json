      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anyhow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "天気がどうであれ、旅の計画は進めなければならない。何れにしろ、傘とレインコートは準備しておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プロジェクトの締め切りが迫っている。細かなバグはいくつか残っているが、何れにしろ、まずは主要機能を完成させることが最優先だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この状況は残念だが、何れにしろ、我々はこの事実を受け入れて前に進むしかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの時の会議、正確に何を話したか覚えてないんだよね。」「私もだよ。何れにしろ、結果的に問題は解決したから、まあいいんじゃない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "実験データに一部ノイズが混じった可能性があるが、何れにしろ、得られた結果から仮説を検証する価値はある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このモデルは機能が多いが、価格も高い。何れにしろ、予算内で収まるものを選ぶしかないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "賛否両論あるだろうが、何れにしろ、この政策は国民生活に大きな影響を与えることになるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "開化の段階の低いことが、一朝一夕にして高まることはなく、多くの個人の不撓の努力を要することは勿論でありますが、何れにしろ事態打開の先づ第一歩は、「若い身空でイヤな病気」と感ずる前に、「病気の軽重と処分の軽重」が判明に頭なり良心なりに来ること、それに違ひはないと思ふのであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "数にすれば少しでも、文学に無関係な文士なぞといふものが在るのは何れにしろ奇現象であるから、事実上は決して少い感じがするどころではない。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども何れにしろ、皺の出来るより前に彼は筆を取つてはゐない。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れにしろ今の苦艱から免れたい。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何れにしろ、私等の懐中さ這入る分にゃ同じことだから、地主としちゃ、やっぱり地代のいい方さ貸すことになるね。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小奴の母親は幼少のころ亡くなつたが、父親は、そのころ、――実の父親か義理の父親であつたかよく記憶はしてはゐないが、――何れにしろ父親は釧路駅の従業員をしてゐて小奴とは別居して暮らしてゐた。",
              "citation": {
                "source": "石川啄木と小奴",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しこれはむしろ２項の原因となるべき点が多いが、その何れにしろ、日本はソ連に対しては決戦戦争の可能性が甚だ乏しい。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、私にはあの上の山林を切り払うと水の加減がどうなるか、というような細かいことはわからないがね、何れにしろ、それがよくても悪くても、自分の田地なために、これ以上立ち入ったことをいうのは工合が悪い。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何れにしろ、今迄より貧しくなりはしないわね。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れにしろ、あのロットの妻の未練がましい心配に身を委せるのは、些と早すぎるつてことはあなたの常識が教へるでせう。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしろ稚純な心には非情有情の界を越え、彼と此の区別を無みする単直なものが残っているであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、それに、外国の有名な活動俳優も来るとかいうので……」「いずれにしろ、それじゃ大したこっちゃねえわけだね？",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしろ、前田弥平氏の計画の第一歩はとにかく成功したのだった。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいずれにしろ、私はいまや燃えるような希望の霊感を感じはじめ、とうとう、こっそりと、このうえ決して服従して奴隷扱いにされまいという断固とした決心を固めたのであった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるのなら、いずれにしろどちらかの立場を選ぶしかない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしろ松田優作を失ったこの世でオレが望むのは、ＦＭ　ＴＯＷＮＳのもう一化けである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに若井氏の心持も分って私もその厚志に感じてやっている仕事であるから、いずれにしろ、御返事をしなければならないが、返事をするとなると、申し訳をするよりほかない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏の製作に取り掛かったこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はいずれにしろ、不審｜訊問を避けるためにキチンとした身装をしていなければならなかったが、然し今のような場所で、八時というような時間に、洋服を着てステッキでもついて歩くことはかえって眼について悪かった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しいずれにしろ私は捕まってはならないとすればたった一つのことが残されていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それはいずれにしろ同じことだ。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしろ、真面目に今日恋愛と結婚を考える人は、その気持を相手の人にだけ寄せかけないで、自分の気持を自分でもって行くばかりでなく、相手の人の気持も自分があるところまでは、引き負い、引き立てて自分たちの幸福を日々の現実の中で捉えて行く心持がなければやって行けないと思います。",
              "citation": {
                "source": "女性の生活態度",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがいずれにしろ、文芸評論の使命がそこにあるとすれば、何故夫が少なくとも科学的なものでなければならぬかは、すべて明らかなことだ。",
              "citation": {
                "source": "文芸評論の方法について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "と僕は思ったけれど、僕の行く道はいずれにしろもう完全に封鎖されていた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、いずれにしろ広大なソヴェト同盟だ。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの何台かは、いずれにしろアスキーに渡る予定だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしろ、渡辺自身がもっとも確実な商品企画であると考えた、ビジネス用途を狙った一六ビット版のＰＣ―８８０１を仕上げるためには、情報処理はかなりの開発期間を要すると思えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしろここで、皮肉な倍音演奏をした悪魔を決定しなければならなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしろ、倍音が発せられた当時、ここには伸子のほか誰もいなかったのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしろ、これは他国を益するにすぎない。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷視、憎悪、侮蔑、嘲笑――そういった色が読みとれるような、また、謙吉の罵りに義憤を感じたのか、いずれにしろ、その情景には平常ならぬものがあった。",
              "citation": {
                "source": "方子と末起",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
