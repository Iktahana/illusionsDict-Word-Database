[
  {
    "uuid": "a7b96119-a8c6-577d-88ec-b548013edfda",
    "entry": "射返す",
    "reading": {
      "primary": "いかえす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
