          "literary": [
            {
              "text": "選りすぐりの人材を一本釣りしていったテイラーは、取り組むべき課題は研究者の自由裁量に任せた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の男、又一本釣り挙げしが、「型が気に喰はぬ」とて、亦、傍に見物せる男に与へたり。",
              "citation": {
                "source": "東京市騒擾中の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            }
