        "examples": {
          "standard": [
            {
              "text": "来月の学会に向けて、都心でアクセスしやすいイベント会場を予約した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "イベント会場の入り口で、スタッフが来場者の案内をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "このイベント会場は、最大で5000人を収容できる広さがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "コンサート当日は、イベント会場の周辺でグッズ販売が行われる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが少年の日の寝床に溢れたあの終わりを恐れる涙を、一九九〇年七月十一日、神宮球場脇のイベント会場、ＴＥＰＩＡで開かれたマイクロソフトワークス（以下ワークスと書く）の発表会場で、なんとオレはまざまざと思いだしてしまった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
