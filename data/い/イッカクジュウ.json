        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "北極圏の海に生息する一角獣は、その長い螺旋状の牙で知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "博物館で一角獣の骨格標本を見て、その想像以上の大きさに圧倒された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ドキュメンタリー番組が、氷の海を泳ぐ一角獣の群れを鮮明な映像で捉えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "qilin (Chinese unicorn)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
