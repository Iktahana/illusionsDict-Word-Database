          "literary": [
            {
              "text": "行く早々、俳人たちが店頭で俳句ばなしをするのを耳にし、やっと悲しさを忘れ、ツゲ材の稽古印に、印刀の持ち方など習う。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "印刻の夜業ランプには、硝子玉のレンズを掛けて、その明りの焦点に印面をおき、先の鋭い印刀で、パリッパリッと、微細な印字を彫ってゆくのである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
