        "examples": {
          "standard": [
            {
              "text": "近所の公園で、制服姿の家出少年が保護された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家出少年たちの多くは、家庭環境に問題を抱えていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "警察は、行方不明となっている家出少年に関する情報を広く求めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「また家出少年がニュースになっているわね。心配だわ。」と母親はため息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家出少年心理学という分野では、彼らの行動原理の解明が試みられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "駅前で一人でいる年若い少年が、もしかしたら家出少年ではないかという噂が流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "入社してきたかと思うと数日のうちに事故で入院してしまったり、家出少年が入社してきて、明くる日にはもう辞めてしまったり、出入りは意外に多い。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
