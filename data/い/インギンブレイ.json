    "definitions": [
      {
        "index": 1,
        "gloss": "superficially polite but actually rude",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
