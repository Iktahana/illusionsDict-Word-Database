          ],
          "literary": [
            {
              "text": "冷害や水害や、辛うじて一毛作しかできないという風土の貧しさや暗さは、雪国の農民住宅にも、町の庶民住宅にも生々しく現れすぎている。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち二年一毛作しか穫れない。",
              "citation": {
                "source": "捨てる文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦から見れば二年一毛作である。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん一毛作しか出来ない。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
