    "definitions": [
      {
        "index": 1,
        "gloss": "infrastructure as a service",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "弊社では、老朽化したオンプレミスサーバーの刷新にあたり、ＩａａＳの導入を決定しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ＩａａＳを活用することで、初期投資を抑えつつ、柔軟なシステム運用が可能になります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イベント開催時の急激なアクセス増に対応するため、ＩａａＳで構築されたインフラは自動的にスケールアウトするよう設計されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "複数のＩａａＳプロバイダーを比較検討した結果、運用実績とサポート体制が決め手となりました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新規事業の立ち上げにあたり、スピードを重視し、基幹システムをＩａａＳ上に構築しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業のＢＣＰ対策として、遠隔地にＩａａＳを用いた災害復旧サイトを構築する事例が増えています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "開発チームは、より高い自由度を求めてＰａａＳではなくＩａａＳを選択し、ミドルウェアの選定から行いました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アイアースとヘクトールとの決鬪、未決に終る。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイアース水陣を防ぐ（二十六日）。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "アキリュウス勇を奮つてアイナイアース及びヘクトールと戰つて之を走らす（二十七日）。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "※アイアース（テラモンの子＝テラモニデース）第二の猛將。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　余のここに来たるや、当地中学校フライアース・スクール（Friars School）校長、ウイリアムズ（Williams）氏の宅に同居す。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し寛大のアカイオイわが望むまゝ平等の　135戰利を我に與へなばわれ諾はむ、然らずば、親しく行きてアキリュウス、汝、或はアイアース、はたオヂュシュウス得しものを奪ひて共に歸るべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め來るはネストール、王イドメネー之に次ぐ、　405次ぐは二人のアイアース、同じく跡に續き來るヂオメーデース、第六は聰明理智のオヂュシュウス、更に英豪メネラウス、自ら來る、其兄の胸中の感、悟り得て招かれなくに來り訪ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロクリス族に將たるはオイリュースの子アイアース、＊テラモニデース・アイア，スに其の身長をくらぶれば遙かに劣り小なるも、鎗を取りてはアカイアと＊ヘルラス族を凌ぐもの、布の胸甲身に着けぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "557　アイアースの如き特に勝れし勇將に只二行を與ふるは怪むべし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "英武無双のアキリュウス並に彼の聯乘の馬も遙に優れども怒りて陣に退けば、テラモニデース・アイアース今人中に勝れたり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンキーセース生むところ、アイナイアース勇にしてダールダネスの兵率ゆ、アプロヂイテー、美の女神、　820イデーの丘に人間と契りて彼を生れしむ、アンテーノールの二人の子、戰術すべて巧みなるアルケロコスとアカマース、彼と並びて將となる。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "（XI 128―）プリアモス王第三にアイアース見て尋ね問ふ、　225『見よ彼秀れて偉なるもの、頭と厚き肩と共アルゴス人を凌ぐ者、かのアカイヤ人何ものぞ？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』垂絹長く面を掩ふ艶美の女性答へ曰ふ、『彼アイアース、すぐれたるアカイヤ軍の堅き城、こなたは英武イドメネー、＊クレーテースの衆中に　230神の如くに立ち上り、諸將士彼を取り圍む。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くの如くに英豪のアイア，スの手に斃さるるシモエーシオス塵に伏す、其アイアース目ざしつつ、プリアミデース・＊アンチポス群集中に槍飛ばす、覘は外れてオヂュシュウス率ゐたる伴リュウコスを、　490屍曳きずるままに打つ、鼠蹊のほとり丁と射て。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』アイナイアース、トロイアの將軍其時答へ曰ふ、『しか曰ふ勿れパンダロス、我々二人彼目がけ、戰車戰馬を驅り進め、武器を揮ひて彼を打ち、彼を試さん其前は局面何の變なけむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "295魂と力ともろともに、彼の體より逃れ去る其しかばねを、アカイアの將士奪ふを恐れたるアイナイアース、盾と槍とりて兵車を下り來つ、獅子の如くに身の威力信じ、倒れしなきがらをめぐり、身の前、長槍と圓楯かざし、大音に　300叫喚しつつ、なきがらを奪はんものを倒すべく、勢猛くめぐり立つ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂオメーデースこなたにはアイナイアース追ひ迫り、神アポローン應護の手、彼に延ばすと知り乍ら、偉大の神をいさゝかも恐れず、敵のアイネアス屠りて彼の戰裝のいみじきものを剥がんとし、　435飽くまで敵を倒すべく三たび激しく追ひ迫る、三たび燦爛の楯揮りてアポローン彼を追ひ返す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "また銀弓のアポローン一の幻影作り成し、アイナイアース及び其武具に全く似せしむる、――　450その幻影を取り圍み、アカイア及びトロイアの兩軍互に＊牛皮張る圓盾あるはその總の亂るる小盾其胸をおほへるものを打ち合へり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンキーセースうみなせるアイナイアース、猛き者、わがヘクトールもろともにわれの尊ぶ猛き者、倒る、いざ立て紛擾の中より勇士救ひ出せ！",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "540かなたダナオイ勇將を、ヂォクレースの二人の子、オルシロコスとクレ，トーンをアイナイアース打ち倒す、二人の父は堅牢に築かれし都市＊フェーレーに住みて家計は豐なり、ピュロスの原を貫けるアルペーオスの廣き河、河靈の裔は彼の父。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば山の頂に繁る叢林奧深く、母獸によりて養はれ長ぜし荒き獅子二頭、　555牧牛並に肉肥えし群羊屠り餌食とし、獸欄いたく荒らす後遂に主人の手にかゝり、其青銅の鋭刄に撃たれて斃れ伏す如し、二人正しく斯の如、アイナイアースの手によりて、打たれて伏して、おほいなる樅の倒れを見る如し。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "560其斃れしを憐みてアレースめづるメネラオス、燦爛、光る青銅の鎧穿ちて先頭に進みて槍を打ち揮ふ――アイナイアースの手に因りて斃れんことを望みたるアレース彼を勵ませり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイナイアース、メネラオス二將互に相面し、戰望み鋭刄の槍をおのおの振りかざす、アーンチロコス進み來て王にまちかく並び立つ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "570二人の勇士相並び助けて立つを眺め見て、アィナイアース勇猛の將軍乍ら引きかへす。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロイアの軍勢眞近く寄せ來り、戰術長けし二勇將メネステースとアンキァロス、同じ兵車にたちたるを打ちて倒せりヘクトール、其倒るるを憐みてテラモニデース・アイアース、　610近くに寄せて燦爛と光る大槍投げ飛ばし、アムピイオスを（セラゴスの子たる）武將を射て斃す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "テラモニデース、アイアース彼の帶射て影長き　615槍に下腹部貫ぬけば地響なしてどうと伏す、其戰裝を剥がんとしアイア，ス之に飛びかかる、トロイア軍は之を見て燦爛光る投槍を彼に飛ばせば楯の上其幾條はつき刺さる。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "テラモニデース・アイアース、アカイ軍の堅き城、　5眞先に立ちてトロイアの陣を破りて、光明を其友僚に齎しつ、トレーイクスの族中に至剛のほまれ＊アカマース、（ユウソーロスの子）を打ちぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカイアの勇將九人應じて立てる中、籤によつてテラモニデース、アイアース撰に當る。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時衆は高らかに其手を擧げて大空を仰ぎ、各神明に祈願捧げて陳じ曰ふ、『神、願くはアイアース、ヂオメーデース、あるは又黄金富める＊ミケネーの王に此籤落ちしめよ』　180180　アガメムノーン。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆は斯く曰ふ、ゲレーニャの老將兜打振れば、籤は兜の外に出づ、正しく衆の望むもの、アイアースのそれ、傳令使即ち之を手に取りて、右より始め順々に諸將のもとを巡り行く。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
