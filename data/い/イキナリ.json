    "definitions": [
      {
        "index": 1,
        "gloss": "abruptly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ちょっと、いきなりドアをノックしないでよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "午後の会議中、空が急に暗くなり、いきなり激しい雨が降り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は何も言わずに、いきなり立ち上がって部屋を出て行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "証券市場は、予想外の経済指標発表を受けて、株価がいきなり急落した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お前、いきなりどうしたんだ？顔色が悪いぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "講演の最中に、壇上のマイクがいきなり音を出さなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いきなりそんな大金、どこから持ってきたんだ？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」休職中尉の体操兼舎監の先生が行き成り私を列の前に引き摺り出した。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへやつて来た五十くらゐの女が、いきなりその二人に向つて、「わたしや勧進帳はだい嫌ひ、眠くなつちやつた」と云つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "來るといきなり、芥川君は手をひらいて僕に見せた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際その朝、彼は疾風のやうに訪ねてきて、いきなり二階の梯子を驅け登つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、あれほど禮儀正しく、應接の家人と丁寧な挨拶をする芥川君が、この日に限つて取次ぎの案内も待たず、いきなりづかづかと私の書齋に蹈み込んできた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川のむこうにいた女よりさきに菊ちゃんを見て知っていたような気もするのです」「まあ、いい」馬場はそう呟いて微笑んでみせたが、いきなり左手で顔をひたと覆って、嗚咽をはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が耕二の間の障子を開けると、「負けちやつた」と耕二はいきなりそれだけ言つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で悪い屑屋に雑誌を出すと、いきなり帯をしてハカリに掛ける。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして側目も振らずにいきなり電車へ飛び込んでしまった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長がいきなり「ノーフラージュ（難船）」と怒鳴ると、移動がぴたりと止まるのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも黒紋付に、歩くときゅうきゅう音のする仙台平の袴姿であったが、この人は人の家の玄関を案内を乞わずに黙っていきなりつかつか這入って来るというちょっと変った習慣の持主であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかつかと歩み寄つたＫ少尉、いきなりびんたの一つも張るかと思つたらさにあらず、『それ位にして置いて早く集つて下さい、濟まんが』とやつたものだ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡いおかみさんではないんだけれど、あの日は蟲のゐどころがへんだつたのでせう、いきなり、お照さんの舌をひきむしつてしまつたの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もしも涙がながれてきたら、いきなり私の上にうつ俯して、それで私を殺してしまつてもいい。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "浚渫船のデッキには、石油缶の七輪から石炭の煙が、いきなり風に吹き飛ばされて、下の方の穴からペロペロ、赤い焔が舌なめずりをして、飯の炊かれるのを待っていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "当主は、寝ている処を、いきなり丸太ん棒、それも樫の木の、潜り門用の閂でドサッとやられたので、遺言を書こうにも書くまいにも、眼の覚める暇がなかったのであった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕を高くした本田富次郎氏は、樫の木の閂でいきなり脳天をガンとやられた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギラギラする光の中から、地下室の監房のような船室へ、いきなり飛び込んだ彼は、習慣に信頼して、ズカズカと皿箱をとりに奥へ踏み込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見習は、いきなり駆け出した。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、うつかりいきなり行つたのでは斷られはしないかと聞いたら、そんなことはないといふ話であつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方のバックには構内の倉庫の屋根が黒く聳えて、近景に積んだ米俵には西日が黄金のやうに輝いて居り、左の方の澄み通つた秋空に赤や紫や色々の煙が渦卷き昇つて居るのが餘りに美しかつたから、いきなり繪具箱を柵の上に置いてＷＣの壁にもたせかけ大急ぎのスケッチをしようとした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると途中からもう一人同じ帽章をつけたのが乘り込んで、いきなり入口に近く腰掛けて居た一人の肩をたゝき「オイ、どうした」と聲をかけた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄に天井に白い泡がたつて、青びかりのまるでぎらぎらする鉄砲｜弾のやうなものが、いきなり飛込んで来ました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり霧積が入って来た。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていきなり川ばたの白い四角な家に入った。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていきなり「お履物はこちらへまはしましたから。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな子供のいきなりながされる模様を想像した。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　とジョバンニが思ひながら、大股にその街燈の下を通り過ぎたとき、いきなりひるまのザネリが、新らしいえりの尖ったシャツを着て電燈の向ふ側の暗い小路から出て来て、ひらっとジョバンニとすれちがひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、なんとも云へずさびしくなって、いきなり走り出しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりこっちも窓から顔を出さうとしたとき、俄かにその子供が頭を引っ込めて、こっちを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
