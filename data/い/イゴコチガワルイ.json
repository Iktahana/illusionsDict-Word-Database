        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいオフィスは広々としているが、まだ慣れないせいかどこか居心地が悪い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「知らない人ばかりのパーティーに一人で出席するのは、どうにも居心地が悪くてね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "嘘をついてしまった後は、彼と一緒にいても居心地が悪く感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高級レストランの堅苦しい雰囲気が、庶民派の自分には少し居心地が悪い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議で自分一人だけが反対意見を述べた後、部屋の空気が一変して居心地が悪くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「居心地が悪そうにそわそわしているけど、何か早く帰りたい理由でもあるの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年住み慣れた家も、家具をすべて運び出すと急によそよそしく、居心地が悪い空間に変わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「じゃ、おまえの知ってるのをかけてやる」「ビートルズぐらいしか知りませんよ、オールディーズは」　ビートルズがオールディーズと呼ばれる時代は、慶一には居心地が悪い。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて御身は貧弱で、散漫で、どうも居心地が悪い。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は文明化しすぎて、進歩的すぎて、故国では居心地が悪いので、そのため英国で長居しているのです。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
