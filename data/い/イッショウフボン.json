    "definitions": [
      {
        "index": 1,
        "gloss": "(strict) observance of the Buddhist precept of lifelong celibacy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「高僧として知られた彼は、一生不犯の誓いを守り抜き、清貧な生活の中で入滅した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「仏道に身を捧げるからには一生不犯を貫く覚悟だと、若き修行僧は厳しい表情で語った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「歴史に名を残すあの武将が、実は一生不犯を誓っていたという説には驚かされた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "先住の高風に比べれば百難あったが、彼も亦一生不犯の戒律を守り、専ら一酔また一睡に一日の悦びを托していた無難な坊主のひとりであった。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこそ、真理を探求する禅家では、思考の自由を確保するために、一生不犯の戒律をまもるのである、などといきまいた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
