          "literary": [
            {
              "text": "私は一揖して、直ちにキューを取つた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓で、彼が帽を脱ぐのに、驛員は擧手して一揖した。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の蓑紛々として桃花を點じ、微笑して一揖す。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の子供の助手も、両手を拱いたまま私に一揖しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村が俺と向ひ合つて腰をすゑて俺に一揖したから、俺はからかつてやつた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "もの／＼しく一揖して、「お、お、周南よ。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学円、高く一人｜鐘楼に佇み、水に臨んで、一揖し、合掌す。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小次郎法師は、寿くごとく、一揖して、「成程、尉殿だね。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "平に一夜、御住居の筵一枚を貸したまわれ……」　――旅僧はその時、南無仏と唱えながら、漣のごとき杉の木目の式台に立向い、かく誓って合掌して、やがて笠を脱いで一揖したのであった。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲と乙とは渠に向かいて慇懃に一揖して、「おかげでおもしろうございました」「どうも旦那ありがとう存じました」　弁者は得々として、「おまえさんがたも間があったら、公判を行ってごらんなさい」「こりゃ芝居よりおもしろいでございましょう」　乗客は忙々下車して、思い思いに別れぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者はその全体の風貌からいままでに知らなかった威圧をうけたので、思わず一揖した。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士、僧都、一揖して廻廊より退場す。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一揖して、タゴール老人の傍に坐った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "選ばれた使者は、李陵に一揖してから、十頭に足らぬ少数の馬の中の一匹に打跨ると、一鞭あてて丘を駈下りた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と一揖して、「面です……はははは面でござる。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士の前に一揖して、「お邪魔を。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、後を閉めようとして、ここに篤志の夜伽のあるのを知って一揖した。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」魚容は一揖して、「何せどうも、身は軽くして泥滓を離れたのですからなあ。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」侍臣はかう奉答して恭しく一揖した。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の物語をば笑しげに傍聴したりし横浜｜商人体の乗客は、幸に無聊を慰められしを謝すらんやうに、懇に一揖してここに下車せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "接待をしている人達も、名士達の前には、頭を幾度も下げて、その会葬を感謝しながら、信一郎には、たゞ儀礼的な一揖を酬いただけだった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "またおいでやす――」　一揖しながらくるりとうしろを向くと、ぴたり襖をしめきりました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お乗りなせえまし」　いたわりながら数寄屋橋へ引き揚げていくと、舌をかみ切ってひくひくと苦悶している玉ころがし屋のそばで、ぼうぜんと失神したようにまごまごとしていたあば敬の前に、老婆をずいと押しやりながら、あっさりと一揖していいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と少女は一揖して安永の側を離れた。",
              "citation": {
                "source": "牛を調弄ふ男",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "接待をしてゐる人達も、名士達の前には、頭を幾度も下げて、その会葬を感謝しながら、信一郎には、たゞ儀礼的な一揖を酬いただけだつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギンツェ営業部長　（一揖して）公爵閣下の仰せのとおり、いかなる障害、いかなる困難がありましても、吾人は決して、その困難、はたまた障害のために、両国の親交を損ずることはあるまいと信じます。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "喝采の中に彼女は愛らしく裾をつまんで、一揖して退いた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おおさようでござったか」陶器師は軽く一揖したが、「そうとは存ぜずとんだ失礼、平にご用捨くだされい。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巍々たる楼門、虹の如き長廊、噴泉玉池珍禽異獣、唱歌の声は天上より起こり、合唱の音は地上より湧く、忽ち、美人と童子とありて、遙かに望見して一揖す。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男はひょろ長い躯に、襟が後頭部までも被さりそうな、長い半木綿のフロックコートを著ていたが、片手にナプキンを掛けたまま素早く駆け出して、さっと髪を揺りあげるように一揖するや否や、木造の廊下づたいに、そそくさと紳士を二階の有り合わせの部屋へ案内して行った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
