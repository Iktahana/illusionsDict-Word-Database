    "definitions": [
      {
        "index": 1,
        "gloss": "to turn pale",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで衣服でも器具でも室内のものはほとんど皆本来の色を失うてしまうから家庭用には用い難い。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米も出来ず、果実も実らず、万事｜尽く生色を失う事となる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そらそら、すぐ色を失うくせに、……嘘なもんですか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "舍利が子を産むの、柘榴石が生長するの、黄玉が徐々に老いてその色を失うのということは、事実が有るにしてもそれは物理がそうさせるので生理の働きでは無いようである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし長い間には徐々にその黄色を失う。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄玉は或る程度の率で徐々にその黄色を失うのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一日インドの道人遣って来り、その指環に嵌めた層瑪瑙の力で即座にかの女を蛇の変化と知ったというのは、この石変化の物に逢わばたちまち色を失うからだ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただ古い物ばかりが尊いとする人々の言を容れて、ひたすら品をよくとのみ勉め、ついにこの物語に流れている情熱を棄てたなら、かえって原文の特色を失うにも至ろう。",
              "citation": {
                "source": "『新訳源氏物語』初版の序",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし李敬業の乱に当り、駱賓王の檄を読んだ時には色を失うことを免れなかった。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "師僧も父母も色を失うた。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "落窪物語なども、改作によつて平安朝の特色を失うた処もあり、文法も時代にあはなくなつて了うたらしく、偽作ではなくて、やはり書き継ぎ書き加へたものである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして世界中の人間は、はじめて耳にする怪魔ミミ族の来襲に色を失う者が多かった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガクゼン顔色を失うとは正にこのことで、朝から真ッ蒼の顔がさらにガクゼンと色を失った。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方にナホトカから祖国へ敵前上陸する集団発狂者があり、コミンフォルムの批判にシッポを垂れて色を失う集団発狂者がある。",
              "citation": {
                "source": "安吾巷談",
                "author": "野坂中尉と中西伍長",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが応待に現れた日本人の神父さんは顔色を失うぐらいに狼狽して、そんなものは出版したことがありません、そう云いながらソワソワと足もとが定まらないような様子にさえ見えた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども種彦が再び草稿の上に眼を注ごうとした時今度は何者か窃に忍寄るような跫音が聞えたので、いよいよ顔の色を失うと共に行燈の火を吹消すが早いか、種彦は一刀を手にして二階の丸窓をば音せぬように押開き庭の方を見下した。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "試煉の時がきたとき彼は色を失うかもしれない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば常に「石見の焼物」たる特色を失うことがないだろう。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日おり悪しく遠くの村の学校へ研究会に出かけていたクニ子が唇の色を失うほどあわててかけつけ、「お父さん」と、その胸をゆすぶった。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アメリカ人共は、これを聞いたら愕然として色を失うだろう。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　二十歳のころまでは太刀を帯びて侍奉公したこともある性善坊なので、刃を突きつけられたからといって、にわかに顔色を失うほどの臆病者ではなかった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、この君の眉目の麗しさは、金瓶の花も、玉盤の仙桃の匂いも、色を失うほどであった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに注ぐ王軍の新兵器に、泊兵も野に生色を失う事　彭※はおどろいた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根裏に躍る“牧渓猿”と、狩場野で色を失う徐寧のこと　※城城下、花の都。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女たちは色を失う。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはまた、草木の中を歩いて、紫、藍、紅、さまざまな花をもんで試みたが、どれも日光にあえば色を失うのみか、筆にかかる粘力がない。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おおっ、呉の大船隊が」　と、玄徳をはじめ人々がみな色を失うと、孔明は、舟手の者にすぐ進路を指揮し、「かねて予測されていたこと。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
