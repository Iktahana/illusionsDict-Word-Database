[
  {
    "uuid": "7ab38a37-ad27-54ee-9221-b7278e760f51",
    "entry": "言い返し",
    "reading": {
      "primary": "いいかえし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
