[
  {
    "uuid": "431dcb38-4d6c-58f3-8d66-1de4121e4499",
    "entry": "一儀",
    "reading": {
      "primary": "いちぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
