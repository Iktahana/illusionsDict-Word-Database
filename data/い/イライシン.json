    "definitions": [
      {
        "index": 1,
        "gloss": "spirit of dependence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
