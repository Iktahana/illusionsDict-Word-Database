[
  {
    "uuid": "14398cfc-33a0-533f-9bf3-78e6ed6a38c8",
    "entry": "意訳",
    "reading": {
      "primary": "いやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "free translation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どこまでも作り話だと思って読もうと勉めながら、おぬいは始めの方から意訳していった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを意訳しますと、「世の中の本当のことはあたりまえということだ。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが又そのうちに中学の三年か四年の頃、少年界か少年世界かでポーの「黒猫」の意訳を読んで非常に打たれたものでしたが、私の探偵小説愛好慾は、それ以来急激な変調を来したようです。",
              "citation": {
                "source": "涙香・ポー・それから",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場に於ける「神秘」を、僕は“Serpent of Eternity”の意訳から用ふるのであるが、神秘と永遠の分析に関して、凡そ意味ありげなる漠然たる言葉を排して、恢々たる煌星の姿を直言した斯の如き大演説に接した験しはなかつた。",
              "citation": {
                "source": "ユリイカ・独言",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "書中引用せる欧文は必要と認むるものにして原意を害なわずして翻訳し得るものは著者の意訳を附せり、しかれども訳し得ざるものまたは訳するの必要なきものはそのままに存し置けり、ゆえに欧文を解し得ざる人といえどもこの書を読むにおいて少しも不利益を感ぜざることと信ず。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、訳筆は努めて意訳を避けて、原文に忠ならんことを期した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "凡例",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭川はアイヌ語でチウベツ（忠別）と云ふさうな、チウは日の出、ベツは川、日の出る方から来る川と云ふ意味なさうで、旭川はその意訳だと先生が話された。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "原書のドイツ訳が既にオリジナルから必然的に懸け離れているであろうと思われるのを、更にもう一度日本語に意訳するのではどこまで離れてしまうか分らないであろうと思われた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "意訳すると豪胆、勇壮、この上なしの偉人という名前なんだから、大抵の奴が眼を眩わしたね。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に私たちは和漢の古文を読んだり、その講義を聴いたりする時、もとの古文のままでは受用していず、それを一々現代の言語に意訳して理解しています。",
              "citation": {
                "source": "教育の民主主義化を要求す",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以上は、判読的意訳である）そして、次の一文が続いていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "意訳すれば、「人生の終り――これぞすなわち深く人生の始めの作られし目的」　嗚呼実に然り。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、（私の場合のよい・わるいは別として）作者の側では、其方面から十分鍛へあげたものを土台にして居ないでは、人物や、事件が、歴史を単純に意訳なり、直訳なりしたに過ぎないことになるのです。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "意訳すれば、命を完了せしめると言ふ様にも説けよう。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下、大村藩の記録を意訳してみましょう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで位山とよび、船のついた山を船山という」　これはヒダの国守であった姉小路基綱のヒダ八所和歌集裏書きの意訳ですが、これがだいたいヒダの伝説の筋です。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで以下、適宜抄訳意訳に簡単な註釈も加え御紹介しておきたい。",
              "citation": {
                "source": "Ｊ・Ｄ・カーの密室犯罪の研究",
                "author": "井上良夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち 〔Ah! vous voila` monsieur.〕（意訳をすると「ああ、あなたですか」）　この一句は次のやうな、様々な感情を言ひ現はすことができる。",
              "citation": {
                "source": "物言ふ術",
                "author": "岸田国士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（日本訳聖書に「五厘ほどなり」とあるのは意訳であって、原文は「カドランスほどなり」である。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ある程度言葉を足していかないと日本語にしづらいため、意訳の要素が多く、正確な翻訳にはなっていないことを申し添えます。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでここでは若干意訳しておきます。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "くだけた意訳を試みてみた。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下、開運日輪抄の中のはなしを、柾木孫平治氏の口述体を取って、しかし文章はわたくしのものに直し、意訳的にぼつぼつ書いて行ってみる。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを意訳すると、次の六項目になる。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "格言を意訳すると「決心は巌でも徹す、我々が一緒になれぬことがあろうか」となる。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの言葉は決して私の発明ではなく、十九世紀の音詩人にして大評論家なる、ロバート・シューマンの言葉の意訳である。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも当て字のほうか、それとも意訳のほうか。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "意訳すれば「文学かぶれ」「学問中毒」か。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蓼食う虫も好き々々、ウェルギリウスの意訳です」家庭教師が言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、手におえないやくざ息子などあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
