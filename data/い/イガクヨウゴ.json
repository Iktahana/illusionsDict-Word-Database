        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「先生、今の説明、医学用語が多くて少し分かりにくかったです。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "患者さんに分かりやすく伝えるため、医療現場ではなるべく医学用語を避けて説明することが推奨されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新の研究論文を読むには、高度な医学用語の知識が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医学用語はラテン語やギリシャ語を語源とするものが多く、その成り立ちを知ることで理解が深まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "報道番組では、視聴者が混乱しないよう、テロップで医学用語の解説を入れる配慮が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子ども向け医療情報サイトでは、難しい医学用語を平易な言葉に置き換える工夫がされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人が病気になった際、初めて目にする医学用語の多さに戸惑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こうした錻力製の呼吸孔の事を医学用語ではカニウレと云うのだが、和訳したら金属製咽喉笛とでもなるのかな。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇跡の話には医学用語が使われ医学的表現で飾られたが、病気にたいする心の態度はヒポクラテス支持者のものではないしディオスコリデスの科学で訓練された同時代者ではもちろんない(25)。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダブリン大学出版部から1882年に出された非常に学問的な本で、Ｗ・Ｋ・ホバート師は聖ルカがギリシャ医学著者たちの医学用語に通じていたことを示している。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "多様な腺病（＊医学用語としては頸部リンパ節結核。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学用語のこの「消息子」とは何か。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
