    "definitions": [
      {
        "index": 1,
        "gloss": "dismantling a (historic) building and reconstructing it elsewhere",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明治時代の洋風建築が、都市再開発を機に広大な敷地を持つ野外博物館へ移築・保存された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ダムの底に沈むはずだった古民家を移築したのが、今の私の家なんですよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "武家屋敷の門を移築したという重厚な佇まいの料亭で、四季折々の懐石料理を堪能した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "解体された旧駅舎の柱や梁をそのまま活用し、市民交流施設として移築・再生するプロジェクトが始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、あそこに見えるのが、遠く離れた村からわざわざ移築されたと言い伝えられている由緒ある祠だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文化財に指定された茶室を移築するにあたり、宮大工たちが釘を一本も使わない伝統技法を忠実に再現した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "建物の老朽化と敷地の手狭さから、社殿を丸ごと安全な高台に移築する大規模な工事が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「そうだなあ、君、賭けてもいいが、一七〇〇年より前に建てられたまま移築されていない家十軒を当れば、その内八軒の地下室に何やら奇妙なものがあるのを見せて上げられるぞ。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時京都の教会は安土焼失の打撃で会堂建築などの資力を持たなかったのであるが、右近はそれが緊急の必要であることを説き、河内岡山の会堂を大坂に移す計画を立てて、その移築を自分の費用でやろうとさえ申出たのであった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "会堂の移築は一五八三年のクリスマスの頃にほぼ出来上り、そこで最初のミサを挙行した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまの上で小鳥たちが、とちの木の木立のなかから、ぴいちくち、ぴいちくちさえずっていました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「びいちくち、ぴいちくち、うちのひとがかえってきましたよ。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "（さやえんどう、さくらんぼう、どうしてこのごろは、うっとりとろりのしたきりすずめ）豊はちいちく、ちいちく啼く雀の声を眼をひらいたまま、夢のやうに聴いてゐた。",
              "citation": {
                "source": "藤の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かで大工が物を叩いて居る音が響き、ちいちく、ちちと雀の声が聞える。",
              "citation": {
                "source": "傾く日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀の親子は長いあいだぴいちくぴいちく村長さんと話していましたが、これも元氣で出て來ました。",
              "citation": {
                "source": "龜さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "李旦は笑いながら、「これゃもう、追いつめられるにきまったけん、羅針盤と象限儀をはずして、わからんところへ隠しておいちくれ」　と言いつけた。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ君、君は紙芝居であるけれどもが、君が辺見甚次君だろ、アハハハそんねな事、どうでもええわい、さ、ハーモニカ吹いちくれ！",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちいちくりひろげて見ると、たどたどしい言葉で、思いの丈をかき口説いた紋切型のものばかり、宛名はみんなお嬢様、――利吉より、となっております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
