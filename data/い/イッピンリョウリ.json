        "examples": {
          "standard": [
            {
              "text": "忙しい日の昼食は、カツ丼のような一品料理で手早く済ませることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この食堂は、ボリュームのある肉野菜炒めの一品料理が学生に人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "栄養バランスを考えて、一品料理のラーメンに野菜サラダをプラスした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
