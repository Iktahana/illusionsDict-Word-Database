[
  {
    "uuid": "e0f37695-96a3-5362-878e-c9d502f32ae0",
    "entry": "厭わしい",
    "reading": {
      "primary": "いとわしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
