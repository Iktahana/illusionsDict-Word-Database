        "examples": {
          "standard": [
            {
              "text": "危機に直面し、会社は一致結束して困難に立ち向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "組合員たちは、要求実現のために一致結束した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "リーダーの呼びかけで、メンバーたちは一致結束して目標達成を目指した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その点をつっこまれると、柴田は明かに狼狽の色を見せ、西田は全職工の一致結束を乱すとだけ云って、それから、改革を要する種々の細かな規定などをもちだして、くどくどと説き立てるのだった。",
              "citation": {
                "source": "立枯れ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "３．一國民の一致結束は、擧つて死地に赴くといふ際に於て最も力強いものである。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
