    "entry": "意気が揚がる",
    "reading": {
      "primary": "いきがあがる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
