[
  {
    "uuid": "e6fe22a3-3890-55e6-8de5-3d84910f42e7",
    "entry": "家の外",
    "reading": {
      "primary": "いえのそと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "outside the house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちが家の外で元気に遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「雨が降っているから、家の外に出るときは傘を持っていきなさい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "猫が「ニャーニャー」鳴きながら、家の外に出たがっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は家の外で誰かと長い時間話し込んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜遅く、ふと家の外から聞き慣れない音が聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "休日は、家の外の庭の手入れをすることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鍵を忘れてしまい、慌てて家の外まで取りに戻った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（Ｆ・Ｏ）Ｓ＝七五郎家の外（昼）　厩の中で馬に飼料をやりながら七五郎、傍の柵に凭れている石松と話している。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しこんなことが世間に洩れては家の外聞にもかゝはると云ふので、松村も勿論祕密を守つてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も御家の外聞にはかえられぬと云う者もあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ最初からあからさまに事情を打ち明けたら、こっちもまた分別のしようがあったかも知れなかったが、ひたすらに御家の外聞という事ばかり考えていた雪野は、何事も秘密ずくめで相談をまとめようと焦っていた為に、こっちの疑いはいよいよ深くなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから新張家の外郭を包む煉瓦塀にヘバリついてグルリと半まわりすると、裏手の小山のコンモリした杉木立の中に辷り込んだ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前なんぞは家の外まわりをみはって泥棒の用心さえしておればいいんだ。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前から用意のいいものは家の外に小屋掛けして寝起きしたり竹藪の中に仮住居をこしらえたりしていたが、もう家の中にいるものはなくなった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "理外の理さえありと聞くこは家の外の家ならんか。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭焼の竈は家の外、上のかたの奥にある心にて、家の左右には杉の大樹、薄なども生い茂っている。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は家の外からそのようすを見て、王さまの新しい服を仕上げるのにいそがしいんだ、と思わずにはいられませんでした。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊は家の外のまき小屋のうしろにつながれていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の外で、いきいきとしたバラの花にかこまれているのは、まことに気持のよいものです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に七年間一歩もこの家の外に出なかった僕が解放されるか否かも決定するのです。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の外には老人や青年が真黒に集まって、泥だらけの白骨を中心に、大評議をしている……というわけで……そこへ文作が帰って来たのであったが、女房の死骸を一眼見ると、文作は青い顔をしたまま物をも云わず外へ飛び出して、村の人々を押しわけて、白骨の置いてある土盛りの処へ来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその中に家の外側を七分通り巡って、ちょうど台所の裏手に当っている背戸の井戸｜端まで来ると、草川巡査はピタリと足を佇めた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真佐子の方から手ぶらで珍らしく復一の家の外を散歩しに来ていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間たって、家の外に出てみても、近所に友だちが遊んでいないことが多いので、そのたびに、友だちをさがして歩かねばならなかったからである。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔女と巨男がねむりについたころ、だれか家の外から戸をたたきました。",
              "citation": {
                "source": "巨男の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、主家の外に牛舎か何かの建増しをしている露人の一戸があった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狭屋の内には、菅公は失敗せる経世家、桃青は意気地なき遁世家、馬琴は些々たる非写実文人、西行は無慾の閑人となりて、白石の如き、山陽の如き、足利尊氏の如き、仰向すべきは是等の事業家の外なきに至らんこと必せり。",
              "citation": {
                "source": "人生に相渉るとは何の謂ぞ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "親類では夕飯の時刻だからと云って引留めようとしたが、許宣は家の外に幸福が待っているような気がして、家の内に置かれるのが厭だから、強いて傘ばかり借りて外へ出た。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "藝者といふ動物は見るのも氣にくはぬといふ博士であるから、家の外には嫉妬をすべき因縁がない。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには甚六も恐れをなして、村にいる山伏を頼んで祈祷をしてもらおうとすると、須弥壇が動きだしたり、榊立や山伏の錫杖が何人が投げるともなしに家の外へ飛んででたりするので、山伏も恐れて逃げて往った。",
              "citation": {
                "source": "一緒に歩く亡霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び血を見てみると、家の外の方へ往っていた。",
              "citation": {
                "source": "豕",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の事であったか、その時の事であったか、父の弟の五百枝と、末弟の林｜駒生と三人が、家の外に集まって下水の掃除をしていた姿を思い出す。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもう一度、大臣の息子を家の外に立たせておきました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "親類では夕飯の時刻だからと言って引留めようとしたが、許宣は家の外に幸福が待っているような気がして、家の内に置かれるのが厭だから、強いて傘ばかり借りて外へ出た。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、世高の体は自然とうごきだして、家の外へ出て城隍廟へ往った。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな声が、家の外まで……ねぇ、父さん、ねぇ、どうしたらいいの？",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
