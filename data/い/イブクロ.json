    "definitions": [
      {
        "index": 1,
        "gloss": "stomach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜の夕食は食べすぎたせいで、今朝は胃袋が重い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子猫は小さくても、すごい勢いでミルクを胃袋に収めていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緊張で胃袋が痛くなり、食欲が全くわかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "赤石山の、てっぺんへ、寝台へ寝たまま持ち上げられた、胃袋の形をしたフェットがあった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房子に足をとられたり、ガツガツした胃袋に足をとられたり、そう云う、俺だって、ざまあねえや、今まで足をとられていたじゃねえか。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "リゼットの疲れた胃袋に葡萄酒がだぶついて意地の悪い吐気が胴を逆にしごいた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダー、ダー、ダースコ、ダーダ、青い　仮面この　こけおどし、太刀を　浴びては　いっぷかぷ、夜風の　底の　蜘蛛おどり、胃袋ぅ　はいて　ぎったりぎたり。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、このオリジナリテというものは、胃袋の問題でしてね、他人の養分を食べて、それを消化できるかできないか、原形のままウンコになって出て来たんじゃ、ちょっとまずい。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその時ばけ物の胃袋の中でこの網を出してね、すっかり被っちまふんだ。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダー、ダー、ダースコ、ダーダ、青い　仮面この　こけおどし、太刀を　浴びては　いっぷかぷ、夜風の　底の　蜘蛛をどり、胃袋ぅ　はいて　ぎったりぎたり。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い細路を通って向うへ行ったら私の胃袋にどうかよろしく云って下さいな。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの妻の胃袋の中に凝固した血糊を見出した瞬間から、彼れはこれまでの生活の空虚さをしつかりと感じてしまつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊鑢の音よ、だみ声よ、老い疲れたる胃袋よ、雨の中にはとほく聞け、やさしいやさしい唇を。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはね、空気獣だなんていってるが、実はね、牛の胃袋に空気をつめたものだそうだよ。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛皮も胃袋もやってしまうから」　小十郎は変な気がしてじっと考えて立ってしまいました。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうだ諸君諸君が一寸菜っ葉へ酢をかけてたべる、そのとき諸君の胃袋に入って死んでしまうバクテリアの数は百億や二百億じゃ利けゃしない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」兵卒一「勲章と胃袋にゴム糸がついていたようだったなあ」兵卒九「将軍と国家とにどうおわびをしたらいいかなあ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はいかにもおずおずと振舞いはしたものの、彼女の胃袋は井深君の二倍の食慾をもってむさぼり食べた。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "先輩芸者の春次を初め、少し蟇口のふくれている芸者は、お膳のうえが寂しいと見ると、子供を近くの煮物屋へ走らせ、酒で爛れた胃袋にふさわしい、塩昆布や赤生薑のようなものを買わせ、朋輩芸者の前に出すのだが、きゃら蕗や葉蕃椒のようなものも、けんどんの隅に仕舞っておき、お茶漬のお菜にするのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが……胃袋を突き通した器械で……」　と云いかけて口籠もった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそのおかげで、私は汚ない二階に寝ころんだまま、煙草と、弁当と、書物の三道楽に浮き身をやつし得るありがたい身分になったわけであるが、同時にその道楽の結果として、自分の頭と、胃袋と、肉体とが日に日に頽廃して行く有様を自分でジッと凝視めていなければならなくなったのには少々悲観させられた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあはれな野獸のやうにふしぎな宿命の恐怖に憑かれたものどもその胃袋は野菜でみたされ　くもつた神經に暈がかかる。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外皮から、腦髓から、胃袋から。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもまだ不幸なことに、彼等の味覚は低劣であり、胃袋は駄菓子によって傷害されている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の空想の胃袋は、他のひとの五倍も広くて、十倍も貪慾だ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私には、あなたの胃袋や骨組だけが見えて、あなたの白い膚が見えません。",
              "citation": {
                "source": "思案の敗北",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呑まれた小宮山は、怪しい女の胃袋の中で消化れたように、蹲ってそれへ。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんは唾をのんで、「お米はいつもお情ない方だとばかり申しますが、それは貴方、女中達の箸の上げおろしにも、いやああだのこうだのとおっしゃるのも、欲いだけ食べて胃袋を悪くしないようにという御深切でございましょうけれども、私は胃袋へ入ることよりは、腑に落ちぬことがあるでございますよ。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の胃袋の加減や腹工合はどうであろうと、私が腑に落ちないと申しますのはここなんでございますが、その時はただもう冷汗びッしょり、穴へでも入りたい気になりまして、しおしお片隅の氷のような腰掛へ下りました。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして気がついてみると、まだ、トラのしたの上にころがったままで、いぶくろの方へのみこまれていくようすもありません。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、このトラののどのおくには、しょくどうも、いぶくろも、なにもないことがわかりました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
