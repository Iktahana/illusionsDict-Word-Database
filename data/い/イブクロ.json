        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食べ盛りの子供が三人いるので、うちの胃袋は底なしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "被災地に食料を届け、少しでも人々の胃袋を満たしてあげたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅先では、ご当地グルメで現地の胃袋を満たすのが楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
