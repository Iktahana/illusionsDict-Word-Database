        "examples": {
          "standard": [
            {
              "text": "子供の頃、寝る前に祖母がよくイソップ童話を読み聞かせてくれたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「酸っぱい葡萄」という慣用句は、イソップ童話の物語に由来することはよく知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イソップ童話は、動物を擬人化することで普遍的な人間社会の教訓を伝える古典である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代社会においても、イソップ童話が教えてくれる知恵や洞察は色褪せることがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "道徳の授業で、先生がイソップ童話の「ウサギとカメ」を引用して忍耐の大切さを説いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねえ、今日の絵本はイソップ童話がいい！キツネとブドウの話が読みたいな」と子供がねだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
