    "definitions": [
      {
        "index": 1,
        "gloss": "wholeheartedly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は一心にピアノの練習に打ち込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "失敗を挽回しようと、彼は一心に業務に取り組んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は孫の健康を一心に願っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこにふるへ、かくれつつうかがひのぞく榎あり、いのりつつ、一心に幹をけづりしに、樹樹はつめたく去り行けり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに一心にそれを疑ひたくなつたとするか、その疑はなければならないのは、良心があるからで、良心もなかつたら、疑つてさへみないであらう。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど要太郎は一心に田の中の一点を凝視めてその点のまわりを小股に走りながらまわっている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "省線に乘つてからも、あれこれ思ひ、南洋の從兄の健鬪を一心に祈つてゐました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも腕前の差がひどかつたならば、その時には臥薪嘗膽、鞍馬山にでもはひつて一心に劍術の修行をする事だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい緑色の野原や、小さな流れを、一心に走りました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの常さんて男、何といういやな人でしょう」　民子は襷掛け僕はシャツに肩を脱いで一心に採って三時間ばかりの間に七分通り片づけてしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一心に畳を見つめていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一心に自分で自分を励まし、元気をよそおうてひたすら母を慰める工夫をした。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍聴者は、みんな非常に真面目に黙って一心に下を覗き込んでいた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急速なるＦ・Ｏ）　＝（Ｆ・Ｉ）物部の家　仏前に雪枝が、父の無事なる事を一心に念じて居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて俺を一心に呪っていればいい。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　奧さんは一心に針を動かしながら、うつ向いたままさういつた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一心になっているので自分の近いたのに気もつかぬらしかった。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは経師職の息子に相違ないので、半七は草履の足音をぬすんで、そのうしろの大きい石塔のかげまで忍んで行って耳をすまして窺っていたが、弥三郎はなんにも云わずに唯一心に拝んでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな恐ろしいものが窺っているのかと、お蝶はいよいよ身をすくめて、ただ一心に机を見つめていると、障子は再び音も無しにしまって、縁側の足音はしだいに遠くなってゆくらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き血を吸いに来たのか、骨をしゃぶりに来たのかと、お蝶はもう半分死んだもののようになって、一心に衾の袖にしがみ付いていると、やがてその衣摺れの音は次の間へ消えて行ったらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ふだんから信仰する観音様や水天宮様を口のうちで一心に念じていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　取り落して人波に踏みつぶされないように、一心に、ひん握っている幹太郎の手鞄を群集の動揺の間隙に眼ざとく認めて山崎は訊ねた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　黙り屋の那須は一心にそれを読みかえしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すゞは、一心に、ミシンに注意を集中している。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」すっかり覚悟がきまりましたので目をつぶって痛いのをじっとこらえ、またその人を毒にあてないようにいきをこらして一心に皮をはがれながらくやしいというこころさえ起しませんでした。",
              "citation": {
                "source": "手紙　一",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある一つの窓ではレシーヴァを耳に当てて一心にラジオを聴いている人の姿が見えた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またあるところでは溪の闇へ向かって一心に石を投げた。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな一心にも可憐な求愛があるものだろうか。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竿を手にして、一心に魚のシメ込を候った。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が近寄ったのも気が付かぬか、一心に拾っては砂浜の高みへ投げ上げている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は買い物籠をかかえて、こまかく震えながら一心に一心に待っているのだ。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう少しの我慢じゃないか」　私たちは、三鷹の家主からの速達を一心に待っていた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　雪と月あかりの中を、汽車はいっしんに走ってゐました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
