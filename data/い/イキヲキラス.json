          ],
          "literary": [
            {
              "text": "それに不思議なことには、咳をするたびにぜいぜい苦しそうに息を切らすことだった。",
              "citation": {
                "source": "童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人たちが歌をうたう時に、お前は息を切らすようになるんだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い顔で息を切らすも、一瞬たりとも爵位と威厳を失うことは無かった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
