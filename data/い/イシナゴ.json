[
  {
    "uuid": "cdc67070-3196-571d-b14c-b0fb10597f9e",
    "entry": "石子",
    "reading": {
      "primary": "いしなご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pebble throwing game played by young girls",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔はよく、近所の女の子たちと集まって石子をしたものだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "石子は、小石を五つ使って遊ぶ、女の子たちの間で流行した伝統的な遊戯である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "おばあちゃんが、昔やった石子の遊び方を教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "民俗学者は、地域によって石子のルールや呼び名が異なる点に注目した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近の子供たちはテレビゲームばかりで、石子のような素朴な遊びを知らないのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お手玉やあやとりと同様に、石子も手先の器用さを養う昔ながらの遊びだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "縁側で楽しそうに石子をする女の子たちの笑い声が、のどかな午後に響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "灰色のまろき石子らはまろがし据ゑ、やをら爪立ちぬ、爺が肩よりのぞき見す。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡元朝の遺民｜陶宗儀の『輟耕録』四に、往々蒙古人雨を祷るを見るに、支那の方士が旗剣符訣等を用うると異なり、ただ石子数枚を浄水に浸し呪を持て石子を淘玩すと、やや久しくして雨ふる、その石を鮓答といい、諸獣の腹にあれど、牛馬に生ずるのが最も妙だと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何に致せ天下分け目の大戦さえ鮓答で決せらると信ぜられ、一二〇二年ナイマン部等の大聯合軍が成吉思およびアウン汗と戦う時、アウン汗の子、霧雪を興してこれを破ったもこの石子の神効に由るというほど故、これを手に入れんとて一切の所有物を棄てても十分引き合うべく、非常に高価な物だったらしい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ木馬水牢石子詰め蛇責め貢米賃（是は領主が年貢未進の百姓の妻女を拉致して犯したので、英國にもやゝ似たことが十七世紀までも有つて、ペピース自ら行つたことが其日記に出づ）其他確たる書史に書かねどどうも皆無で無かつたらしい殘酷なことは多々ある。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかんは不安らしく表をのぞいてゐると、路地の口より石子伴作は捕方の者ふたりを連れ、雲哲と願哲を先に立てて出づ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "君、こんどの僕の家は二階があるよと丸善の手代みたように群書堆裡に髭をひねりながら漱石子が話していられると、縁側でゴソゴソ音がする。",
              "citation": {
                "source": "僕の昔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山集甲子の詩に「題文晁画山為石子道」の七律、丁丑の詩に「次梧堂見寄詩韻兼呈混外上人」の七絶、庚辰の詩に「題石子道蔵松島図」の七古がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊尸耆利山で法敵に襲われ、石子責めに逢って殺された、目蓮尊者に比べてはこの身の殉教は数にも入らぬ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色白の下｜顋の張った小柄な男は警視庁の石子巡査部長だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石子君は当時刑事でね、支倉事件に最初に手をつけた人なんだ」　庄司氏の顔は今宵支倉事件を心行くまゝに語る機会を得た事を喜ぶように輝いていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初めは極く詰らない事からでしてね」　石子は語り出した。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの人を見下しながら、石子刑事は渡辺刑事と並んで目黒行の電車に腰を掛けていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、渡辺君」　石子刑事は囁いた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石子刑事は鳥渡不機嫌になった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も君の話だと白昼堂々と盗み出すと云うじゃないか」「そりゃそうなんだがね」　石子刑事は少し機嫌を直した。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石子刑事が、岸本清一郎と云う聖書販売人をしている青年の訪問を受けたのは三、四日前の夜だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は石子刑事が未だ所謂官服で神楽坂署内の交番で立番勤務をしていた時分に、交番の近所にいた不良中学生だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉の濃いきりっとした顔立の少年で、どことなく不良にして置くのは惜しいような気がしたので、石子刑事はそれとなく善導につとめたのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が家庭の事情で、どうしても学校を続けられない事になり、石子刑事も、いろ／＼尽力してみたが、遂に力及ばず、岸本青年はとうとう中学を中途で廃業して、聖書販売人になったのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今でも石子刑事の恩義を忘れないで、時折は刑事の宅を訪ねた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石子が私服に出世した時に一番喜んだのは本人の次には恐らく彼だろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩、岸本は暫くもじ／＼していたが、「石子さん、実は信仰仲間を傷つけたくないのですが、大分以前から聖書を盗む奴がいるのです。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石子刑事は大した事件だとは思わなかったが、快く引受けてやったのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺君、何分宜しく御助力を頼むぜ」　石子刑事は前途に何か期する所のあるように答えた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石子刑事は渡辺刑事を伴ってとある横丁に這入った。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの家なんだ」　石子は少し前方の可成大きな二階家を指し示しながら、「僕は兎に角当って見るから、君はこの辺で見張りをしていて呉れ給え。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもし僕が十分間出て来なかったら、なんとか旨い口実をつけて様子を見に来て呉れ給え」　渡辺刑事は石子が先輩振って指図がましく振舞うのが不愉快だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先輩と云っても石子はほんの少し許り早く私服になったので、年齢から云ってもどっちも三十には少し間のある位の若者に過ぎないのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
