        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "強豪校との一回戦は、序盤から激しい点の取り合いになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "甲子園での一回戦突破を目指して、部員たちは冬の間も過酷な練習に耐えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "昨年のチャンピオンがまさかの一回戦敗退を喫し、会場は騒然となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "故に第一回戦においては、彼らはなるべく穏かなる語を以てヨブを責め、彼らに責めらるるヨブはかえって真理の閃光を発しつつ、徐々として光明の域に向って進むのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、これまでの第一回戦では、古い道徳をわずかながら押しのけ得たと思っています。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の十二月八日、名古屋で、木村升田三番勝負の第一回戦があって、私も観戦に招かれた。",
              "citation": {
                "source": "将棋の鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の組だったら一回戦で負けてらア。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回戦で負けてるのが本当なんですな」「そんなにみんな強いですかね」「つまりウチが弱すぎるんでしょうな。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ見物にでかけることもあるが、甲子園での人気は大変なものだけれども、東京の予選なぞはおよそ侘しい限りで、戦争中のことであるが、当時黄金時代の日大三中と荏原中学が一回戦で顔があった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私が精神病院に入院中の出来事で、その一回戦は、木村が全然勝つた将棋に、深夜に至つて疲労から悪手の連発で自滅したといふ。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は第一回戦に木村がボケて自滅した新聞記事を読んで以来、この名人戦に興味を失つてゐたから、「木村があゝボケちやア、見物にでかけるハリアヒもないよ」　と云ふと、実に、その時であつた。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉清源と岩本本因坊の十番碁が読売新聞の主催で行われることになり、その第一回戦がこの旅館でひらかれたのである。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回戦に負けた良人は二回戦でイヨ／＼泥を吐いたのである。",
              "citation": {
                "source": "或良人の惨敗",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガル博士　第一回戦だ！",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新太郎君、一寸」　と○△第一回戦の朝、寛一君が思い余った。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
