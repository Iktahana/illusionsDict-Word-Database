    "definitions": [
      {
        "index": 1,
        "gloss": "gloomy and depressing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
