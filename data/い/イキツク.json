[
  {
    "uuid": "aca91c65-8536-57f0-97d5-cad47e2e2f91",
    "entry": "行き着く",
    "reading": {
      "primary": "いきつく",
      "alternatives": [
        "ゆきつく"
      ],
      "is_heteronym": false
    },
    "grammar": {
