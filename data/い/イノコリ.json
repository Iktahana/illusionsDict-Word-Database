        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "宿題を忘れた罰として、放課後の教室で一時間の居残りを命じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「えー、また居残り？ 早く帰ってゲームしようと思ってたのに」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "漢字の小テストで満点を取るまで、先生が居残りを許してくれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕暮れの誰もいない廊下を、居残りを終えた生徒が寂しげに歩いていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
