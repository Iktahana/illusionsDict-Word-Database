    "definitions": [
      {
        "index": 1,
        "gloss": "working overtime",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今日も居残りかぁ。先に上がっていいよ、これだけ終わらせちゃうから」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "居残りのメンバーで近くの居酒屋に寄り、その日のトラブルについて愚痴をこぼし合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定時を過ぎてもオフィスには明かりが灯り、数名が居残り作業を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あーあ、部長に捕まって居残り確定だ。映画の予約キャンセルしなきゃ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼等は、祖父の時代と同様に、黙々として居残り仕事をつゞけていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、その奥さんを幽かに慕っていたのでございますから、居残りを言いつけられても、かえって嬉しかったくらいで、別におそろしくも何とも思いませんでしたのです。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "避暑の客が大方帰ったので居残りの者は我儘放題、女中の手もすいたので或夕、大友は宿の娘のお正を占領して飲んでいたが、初めは戯談のほれたはれた問題が、次第に本物になって、大友は遂にその時から三年前の失恋談をはじめた。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "倶楽部員は二郎の安全を祝してみな散じゆき、事務室に居残りしは幹事｜後藤のみとなりぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤城の下男八蔵は、墓原に来て突当の部屋の前に、呼吸を殺していたりしが、他の者は皆立去りて、怪しと思う婦人のみ居残りたる様子なれば、倒れたる墓石を押し寄せて、その上に乗りて伸び上り、窓の戸を細う開きて差覗けば、かの婦人は此方を向きて横様に枕したれば、顔も姿もよく見えたり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女郎屋の朝の居残りに遊女どもの顔を剃って、虎口を遁れた床屋がある。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやれ生命を拾いたりと、真蒼になりて遁帰れば、冷たくなれる納台にまだ二三人居残りたるが、老媼の姿を見るよりも、「探検し来りしよな、蝦蟇法師の住居は何処。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、レヤチーズは、はじめてボートの支度を下知して、四、五の船客をまずボートに抱き乗せ、つぎに船員の、妻子のある者にも避難を命じ、自分は屈強のいのち知らずの若い船員五、六名と共に船に居残り、おのおの剣を抜いて敵兵の襲来を待機した。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその翌る日、信州の温泉地に向って旅立ったが、先生はひとり天保館に居残り、傷養生のため三週間ほど湯治をなさった。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に小人数ですから家族的気分でいいとかいいながら、それだけ競争もはげしく、ぼくなど御意見を伺わされに四六時中、ですから――それに商売の性質から客の接待、休日、日曜出勤、居残り等多く、勉強する閑はありません。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、何分｜昨日行啓の今晩ですから、居残りでかなり混雑していますし、宿でも町の方でもすっかり疲れ切っているので、どうにも行き届きませんでね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様子が可哀そうにもならないではないが、僕は友人とともに、出て来た菓子を喰いながら、誇りがおに、昨夜から今朝にかけての滑稽の居残り事件をうち明けた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、お袋が、それを悟ったか、悟らなかったか、「もう、先生、居残りは困ります、ねえ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが予備軍のくり出される時にも居残りになったんで、自分は上官に信用がないもんやさかいこうなんのやて、急にやけになり、常は大して飲まん酒を無茶苦茶に飲んだやろ、赤うなって僕のうちへやって来たことがある。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に仕事はしなくてもタイム・レコードで居残り割増金をくれることになっているからだった。",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木三枝子は、昼の仕事をなるべく残すようにして置いて、居残りの時間をつくるようにした。",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ肉が無くなって、群烏は二羽立ち、五羽立ち、むらむらぱっと大部分飛び立ち、あとには三羽、まだ肉を捜して居残り、魚容はそれを見て胸をとどろかせ手に汗を握ったが、肉がもう全く無いと見てぱっと未練げも無く、その三羽も飛び立つ。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五時になるっていうのに、居残りを志願した連中がまだ練習している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり度々校内に居残って書記さんと密談なんかなさると、居残りや宿直の先生たちに妙な意味で見咎められるかも知れないし、学校の外でも世間の人目がうるさいと言ったようなデリケートな教育家の立場をよく御存じの校長先生に取って、あの廃屋は何と言う便利この上もない密談の場所でしたろう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤のいるパラシュートでは、六時まで居残りのときは「弁当代を出して貰わなければ、どうもならん」と、云っている。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとにはＰのおじさん、すなわち小田刑事と令嬢と私たち二人の都合四人が書斎に居残りました。",
              "citation": {
                "source": "髭の謎",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "賃銀がこのように下っているだけでなく、軍需生産等の動いている産業では、居残り、夜業等の労働強化で、不衛生極まる施設の中で、身体はどんどん悪くなって行くばかりだ。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞仙が六十二歳を以て江戸に召された時、弟玄俊は六十歳を以て京都に居残り、幾もあらぬに死んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心臓はまだ怪しいときだったが、傍に妻子にいられる心配よりも、一人身の空襲下の起居の方が安らかさを取り戻すに都合は良く、食物の困難なら、庭の野草の緑の見える限りさほどのことではあるまいと思い、居残りを決行したのだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民のみとは限らず、一般人の間にも生じているこの不通線は、焼けたもの、焼け残り、出征者や、居残り組、疎開者や受入れ家族、など幾多の間に生じている無感動さの錯綜、重複、混乱が、ひん曲り、捻じあい、噛みつきあって、喚きちらしているのが現在だ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人の居残りの者がその儘囲炉裡端に集った。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は男に二カ月分の間代を払ってもらうと、体のいい居残りのままだったし、男は金魚のように尾をヒラヒラさせて、本郷の下宿に越して行ってしまった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上の電気時計はタッタ今午後の十時をまわったばかり……横啣えをした葉巻からは、紫色の煙がユラリユラリ……何の事はない、糞勉強のヘッポコ教授が、居残りで研究をしている恰好だ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして内地に帰って来て一箇月ばかりの間に飲み馴染んでいた灘の酒に、いよいよ別れて往かなくてはならぬと云う軽いのこり惜しさを感じて来た。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一種の興をひいたらしく、ほかの群れから食いのこりの握り飯を持って来たものがあったが、彼はそれをも快くむしゃむしゃと食った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
