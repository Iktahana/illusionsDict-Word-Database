        "examples": {
          "standard": [
            {
              "text": "英語において「I」は一人称単数の代名詞であり、文中のどこにあっても常に大文字で表記される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日本語では、場面や相手に合わせて「私」「僕」「俺」といった多様な一人称単数の表現を使い分ける必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の新作は一人称単数の視点で綴られており、主人公の繊細な心理描写が際立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ラテン語の動詞の活用表を、一人称単数の現在形から順に暗唱していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一人称単数で物語を書くときは、語り手が知り得ない情報をどう処理するかが腕の見せ所だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "論文の執筆において、一人称単数を用いるべきか客観的な三人称を用いるべきかは、学問分野によって作法が異なる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一人称単数現在なら hasami だからよく似ている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に、一番厄介な代名詞を外国語なみに簡単にするために、一人称単数、つまり、私とか、僕とかいふ代りに、たゞ、古語を生かして、わと言はう。",
              "citation": {
                "source": "菜の花は赤い",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
