        "examples": {
          "standard": [
            {
              "text": "夏の旬を迎え、産卵期を控えた石垣鯛が豊漁だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "本日の特別メニューは、新鮮な石垣鯛の姿造りです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "石垣鯛は、刺身でも塩焼きでも美味しくいただける高級魚として知られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "沖合の岩礁地帯で、石垣鯛の群れが確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お父さん、今日の魚はどれにしますか？」「うーん、石垣鯛がいいかな。刺身にしよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "近年、石垣鯛の養殖技術が確立され、安定供給が可能になってきている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "石垣鯛特有の、しっかりとした歯ごたえと上品な旨味が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
