[
  {
    "uuid": "52b67523-0be4-5460-bcbb-fd7579396ec9",
    "entry": "医務",
    "reading": {
      "primary": "いむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "medical affairs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは私であった……嘗てこの病院の医務局で勉強していた私に相違なかった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにその二年前の明治四十年、十一月十五日に陸軍々医総監に任ぜられ、陸軍省医務局長に補せられている。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自分の左脇にかかえるようにしてツネちゃんを療養所に連れ込み、医務室へ行った。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の怪我を聞いて父親の小使いが医務室に飛び込んで来た。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――オイ、医務室へ行って医師にすぐ来てもらえ！",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその男は大股で葉子とすれすれになるまで近づいて来て、「船室ならば永田さんからのお話もありましたし、おひとり旅のようでしたから、医務室のわきに移しておきました。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四五脚の椅子が食卓に背を向けてずらっとならべてある食堂の中ほどから、横丁のような暗い廊下をちょっとはいると、右の戸に「医務室」と書いた頑丈な真鍮の札がかかっていて、その向かいの左の戸には「No.12 早月葉子殿」と白墨で書いた漆塗りの札が下がっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船員はつかつかとそこにはいって、いきなり勢いよく医務室の戸をノックすると、高いダブル・カラーの前だけをはずして、上着を脱ぎ捨てた船医らしい男が、あたふたと細長いなま白い顔を突き出したが、そこに葉子が立っているのを目ざとく見て取って、あわてて首を引っ込めてしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船員は大きなはばかりのない声で、「おい十二番はすっかり掃除ができたろうね」　というと、医務室の中からは女のような声で、「さしておきましたよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんここが医務室です。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うとしばらくして医務室のほうから事務長のらしい大きな笑い声が聞こえて来た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして医務室の戸をさっとあけたらしく、声が急に一倍大きくなって、「Devil take it! No tame creature then,eh?」と乱暴にいう声が聞こえたが、それとともにマッチをする音がして、やがて葉巻をくわえたままの口ごもりのする言葉で、「もうじき検疫船だ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜の校舎なんて、人けはないし、物理実験室には鉱物標本もあるし、図書室には図鑑もあるし、医務室にはベッドだってあるんだから」「あのな、浅井。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとの二分を俯瞰すると、前方が中庭をはさんで並行した別の病棟で、西方に渡廊下をもって右折して続いた医務室などの建物があり、東方には病院の裏門が眼近に迫っていた。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は香ぐわしい空気を呼吸しながら、レントゲン室や、医務室の渡廊下を過ぎ左折して、しめやかな気の湛うている第二病棟の廊下を踏んだ。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百倍以上のものだと一層結構ですがね――」　すると、私の横に立っていた肥っちょのチョビ髭を生したＷ駅の助役が、傍らの駅手に、医務室の顕微鏡を持って来いと命じた。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、どうじゃな」　と、楊博士は、若き歯科医務長にたずねた。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "粥も今はのどを通らなくなって一週間を経たある日の午後、医務の主任が来て突然太田の監房の扉をあけた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥った医務主任がうつむきかげんにその後からついて行く。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これから医務室へ行こう。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "医務室には年とった看護人が一人いた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家の一人娘の遺品だという古ミシンをつかって、片手間に近所の人たちの簡単服だのエプロンだのの賃仕事をしているうちに、出入りのクリーニング屋から話がついて、衛生服や医務服の下請をするようになった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と訊き返したが、すぐにまた医者らしい冷静な威容を作って、医務局の方へ出て行くのだった。",
              "citation": {
                "source": "浅間山麓",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから医務監督、あれも暇人だから、どっかへ骨牌でもやりに行ってなきゃ、きっと家にいまさあ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者にも先刻お馴染の、いつも眼をパチパチやっている検事を初めとして、医務局の監督だの、トゥルハチェーフスキイだの、ベグーシキンだの、その他ソバケーヴィッチの謂ゆる娑婆ふさげどもが、次々に姿を現わしたのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察部長から医務監督にわたされ、医務監督から徴税代弁人に、徴税代弁人から建築技師へと……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "』医務監督は急に顔色を失った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も彼もがげっそり憔悴してしまって、裁判所長も痩せ、医務監督も痩せ、検事も痩せ、またいつもただセミョン・イワーノヴィッチと呼ばれて決して姓を呼ばれたことのない、人差指に大きな指輪をはめて、それを婦人連に見せびらかしてばかりいる男までが、げっそりと痩せ細っていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と云うとまた医務室へ這入った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よやわが十指は晶結し背にくりいむは瀧とながるるごとししきりに掌をもつて金屬の女を研ぎ胴體をもつてちひさなる十字を追へば樹木はいつさいに※轉し都は左にはげしく傾倒す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
