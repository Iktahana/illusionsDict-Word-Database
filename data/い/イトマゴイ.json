    "definitions": [
      {
        "index": 1,
        "gloss": "leave-taking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は長年の友人に暇乞いをするため、一軒一軒訪ねて回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "留学を前に、お世話になった先生のもとへ暇乞いに伺った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「また会う日まで。」と、彼女は涙を見せずに暇乞いの言葉を述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "その帰る前日に某名士の処へお暇乞いに行った。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女が暇乞いをして立つ時、父は物優しくファニーの無礼をことわって、いちばん美しい薔薇を返してもらった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　　＊　　　　　　　＊　永久にこの家から暇乞いをすべき日が来た。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「道で寄って暇乞いをする、ぜひ高岡を通るのだから」「じゃ町はずれまで送りましょう。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　安行と市郎は暇乞いして、吉岡の家を出た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは、この煩いでは、とても助からん思って、今、娘の処へ暇乞いに往って、帰っておると、お武家さんが見つけて、斬りに来たから、一所懸命になって逃げて来た。",
              "citation": {
                "source": "鬼火を追う武士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代に京都の罪人が遠島を申し渡されると、本人の親類が牢屋敷へ呼び出されて、そこで暇乞いをすることを許された。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても不思議なのは、その日の夕方にお兼が自分の町内にすがたを現わして、おなおさんその他の稽古朋輩に暇乞いのような詞を残して行ったことである。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の用件も片付いて、わたしも七月の初めには再び門司の支店へ帰ることになったので、先生のところへ暇乞いにゆくと、あいにくに今夜も先生は留守であった。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで考えると、よそながら暇乞いに来たらしい。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月めの終わりに、悟浄はもはやあきらめて、暇乞いに師のもとへ行った。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて新家元へ相伝の大任を終った翁が、藩公長知侯にお暇乞いに伺ったところ、御｜垢付の御召物を頂戴したという。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と死ぬ約束をして奉公先からそれとなく暇乞いに来た娘が帰るさに、「身体を大切にしておくれ」　と云われて、「アイヨ」　と笑った眼つき口もと。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時近くまで未練がましく待って、それでももし帰って来なかったりしたら、いよいよ引っ込みがつかなくなると思ったので、十一時になったのをキッカケに、体よく美沢の母に暇乞いして、帰途についた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど兼ての決心なり、明くれば友人の懇ろに引き止むるをも聴かず、暇乞いして大阪に向かいぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、主人の由兵衛に科はないわけで、ひとまず自分の家へ下げてやりました」「下手人はやはり万力ですね」「万力は野州鹿沼在の者で、それから江戸を立ちのいて、故郷の叔父や兄に暇乞いをした上で、蓮行寺という菩提寺に参詣し、家代々の墓の前で切腹しました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十七日の朝、長十郎は衣服を改めて母の前に出て、はじめて殉死のことを明かして暇乞いをした。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっ母さんに言うて、女子たちに暇乞いをさしょうか」こう言って権兵衛が席を起った。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれほどの用事を帯びて来て、それを二人の娘の母親に話さずにも帰られぬと思って、直談判をして失敗した顛末を、川添のご新造にざっと言っておいて、ギヤマンのコップに注いで出された白酒を飲んで、暇乞いをした。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け方にかけて月の出るころであったから、それまでの時間に源氏は入道の宮へお暇乞いに伺候した。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身もまた馬からおりて加茂の社を遥拝してお暇乞いを神にした。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は東宮へもお暇乞いの御｜挨拶をした。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "お暇乞いに殿様の所へおいでになりましたのを、私はちらとお見かけしましたが、何をお尋ねすることもできないじまいになったのですよ。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥も通わぬ八丈が島へ本土の人が渡ると、天女の後胤てふ美女争うて迎え入れ、同棲｜慇懃し、その家の亭主は御婿入り忝なや、所においての面目たり、帰国までゆるゆるおわしませと快く暇乞いして他の在所へ行って年月を送ると（『北条五代記』五）。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "混雑の際に邪魔をするのも悪いと思って、二人は早々に暇乞いをした。",
              "citation": {
                "source": "火薬庫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は一泊しろとしきりに勧められたのであるが、あしたは他の一行と共に浅草辺を見物する約束になっているので、今夜のうちに馬喰町の宿へ帰らなければならないと云って、四人は暇乞いをして出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたがた今日は早く帰る方がいいと思って、彼は早々に暇乞いをしてここを出た。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "暇乞いをして寺を出るころには雨が降って来た。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごちそうがすむと、藤太はいとまごいをして帰りかけました。",
              "citation": {
                "source": "田原藤太",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にいとまごいに行ったのは、松平伊豆守のお屋敷であった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
