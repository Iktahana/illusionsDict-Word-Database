        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "親の介護のため、彼は会社に長期の暇乞いを申し出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "体調が優れず、彼は上司に明日の暇乞いを願い出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "プロジェクトの多忙さを理由に、彼の暇乞いの申請は却下された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
