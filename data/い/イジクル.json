[
  {
    "uuid": "3ab5a708-bcfd-5e35-b8b0-e515be9a9a4f",
    "entry": "弄くる",
    "reading": {
      "primary": "いじくる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
