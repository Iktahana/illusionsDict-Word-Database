[
  {
    "uuid": "18cd6a0b-c06b-55a1-b2c1-b7827df04045",
    "entry": "殷々",
    "reading": {
      "primary": "いんいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "roaring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大空は名残なく晴れて朝日｜麗かに輝き、光る物には反射を与え、色あるものには光を添えて雑踏の光景をさらに殷々しくしていた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送ると小さくなって、一座の大山の背後へかくれたと思うと、油旱の焼けるような空に、その山の巓から、すくすくと雲が出た、滝の音も静まるばかり殷々として雷の響。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲火閃々、砲聲殷々。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓の音が殷々と轟く。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一人になって火鉢に手をかざしながら、その殷々の音を聞いていると、妙にひしひしと寂しさが身に迫った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯急ぎに急がれて、こゝに心なき主從よりも、御機嫌ようと門に立つて、一曳ひけば降る雪に、母衣の形も早や隱れて、殷々として沈み行く客を見送る宿のものが、却つて心細い限りであつた。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送ると小さくなつて、一｜坐の大山の背後へかくれたと思ふと、油旱の焼けるやうな空に、其の山の巓から、すく／＼と雲が出た、瀧の音も静まるばかり殷々として雷の響。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殷々として雷が響く。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殷々と響く初午の太鼓。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も遠く殷々たる砲声が聞える。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殷々たる――と云うのは都会の雷鳴で――まるで、身体の中で、ひびき渡るような金属的な乾いた雷鳴が、ビリビリと、四辺の空気を震動させた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "閃光を放ちながら雷鳴が殷々として遠く聞こえはじめた。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもやがて下の方で撃ち出した大砲の殷々たる響きを聞くと何となく心が騒いだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その砲軍の一つが、不意に紅の舌を出したかと見る間に、朝の静かな天地を砲声が殷々とどよもして、五、六発の榴弾が、不意に味方の頭上に破裂したのである。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "独房の四つの壁はムキ出しのコンクリートなので、それが殷々とこもって響き渡った。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　の号令で、爆音一発、火蓋を切つて朝霧の中に殷々と鳴り渡る。",
              "citation": {
                "source": "鵞鳥の家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールの上に狂奔乱舞する車輪の殷々たる響が耳底を流れてゆく――それだけのことの感覚で、乗客たちは自分が生きているということを辛うじて認識した。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "殷々たる砲声が、前方の海面に轟きはじめた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の鐘が殷々と鳴る。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時ならぬ時刻に大手御門の鐘楼の鐘がにはかに殷々と鳴りはじめ、それに連れて、あちこちの半鐘が一斉に乱打され出した。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンマルコの鐘の音の美しさも、旅情を慰める助けとはならず、私には賽の河原の歌となって、悲しげに殷々と響くのである。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "号砲が殷々と続くたびに方向を転じて上空高く上って散って行く。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして間を置いては梵鐘が殷々と沈みとどろいて、生のうつり易いことを、この瞬刻のいのちを撞き出しているかのようであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十六年より二十七年に至る間に成つた思軒の書には、猶「関何人にして頼氏喪中の事を経紀する殷々此の如くなるぞ」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云う内にも外の天気は、まだ晴れ間も見えないばかりか、雷は今にも落ちかかるかと思うほど、殷々と頭上に轟き渡って、その度に瞳を焼くような電光が、しっきりなく蓆屋根の下へも閃いて来ます。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて殷々と雷が鳴った。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にして乘客の喧騷となり、車窓を閉ぢる響となり、遂に一聲の汽笛となりて、轟々殷々、家飛び林動き、野走り山移り、瞬刻にして今市驛に着す。",
              "citation": {
                "source": "日光山の奧",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンサム死して既に半世紀、余威｜殷々、今に至って漸く熾んである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "空もいんいん、地もいんいん、肢體に青き血ながれ、するどくしたたり、電光したたり、身肉ちぎれやぶれむとす、いま裸形を恥ぢず、十字架のうへ、齒がみをなしてわれいのる。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『いいん、いんいん、いんいん……』エミ子は文太郎君の胸に顔を埋めて、思いのたけ泣いてしまいました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
