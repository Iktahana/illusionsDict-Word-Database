          "literary": [
            {
              "text": "獨逸語のヴイルトシヤフトリツヘ、アインハイト（Wirtschaftliche Einheit）、英語のエコノミツク、ユニツト（Economic Unit）、即ち『經濟上の單位』を能く有効にしやうと云ふのが目的である。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸語のヴィルトシャフトリッヘ、アインハイト（Wirtschaftliche Einheit）、英語のエコノミック、ユニット（Economic Unit）、即ち「経済上の単位」を能く有効にしようというのが目的である。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            }
          ]
        }
