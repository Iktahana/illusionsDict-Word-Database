[
  {
    "uuid": "e9e3e386-ede3-590a-8c25-4c82a055162a",
    "entry": "石倉",
    "reading": {
      "primary": "いしぐら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
