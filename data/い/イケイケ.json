          "literary": [
            {
              "text": "」「ううん、ただその活動はね、お客へ向って戦争へ行け行けって、やたらに進軍ラッパを吹いたり太鼓鳴らしたりしているの。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、捉つて了つて、其処の場図で迯るには迯られず、阿母さんは得たり賢しなんでせう、一処に行け行けと聒く言ふし、那奴は何でも来いと云つて放さない。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "行け行け、街に行け。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "行け行け……といったような気持ちで押し寄せた人々の大多数は、自動車や何かに乗らない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の友人たちが、行け行け、行け行けと、とうとう押し出してしまったのだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母様の処へ行け行けと云つてはその一番可愛い佐保子の頭をお打になる音を私にお聞かせになりました。",
              "citation": {
                "source": "遺書",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の朝、土人たちはみんな集つて、さあ行け行けといつて、わたしたちを連れだしました。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び上がった弁天松代は、桔梗様を軽々と抱き上げたが、「表門から行こう、さあ行け行け！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行け行け行け、かまわない。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が行け行けと催促するからさ」「ハハハありゃ御者でも亭主でもないんだとさ。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――失望の色は顔を鉛色に染む）ただ行け行け！",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしも、こんなやさかい、来んとよかろう云うたんやけど、行け行け云うたので出て来たんや。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行け行け男児日本男児　校長先生が唄った。",
              "citation": {
                "source": "平泉紀行",
                "author": "──専攻科第一類歴史部──",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ行け行け早く行け！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ行け行け、早く行け！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、行け行け！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お落とし申せ、行け行け行け！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行け行けと申したら、早く行け」　お高は、若松屋惣七をよく知っているので、は、はい、といそいで答えて、ほほえみをうかべながら、逃げるように座をたった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ、あつちへ行け行けで、餘り抱いたこともなかつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆が実枝に、松江い行け行けいうせに行くんで。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで学院の隣に別な小さな門があって、そこに平屋建ての、西班牙風な瀟洒な住宅があったが、学院の校舎とは庭つづきで行け行けになっていた。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頼むよ、大内君」「片山、行け行け！",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く敵の顔が見たいという憎しみ、一体誰だろうという好奇心、小説的な冒険の誘惑、色々な心持が、彼女を行け行けとそそのかした。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『一人死ねば、一人うまれる、それで結局いけいけだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
