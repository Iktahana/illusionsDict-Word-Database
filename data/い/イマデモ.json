    },
    "definitions": [
      {
        "index": 1,
        "gloss": "even now",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母が作ってくれた甘い卵焼きの味を、今でも鮮明に覚えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "転校してしまった彼からもらった手紙は、今でも机の引き出しの奥に大切にしまってある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「もう何年も前の映画だけど、ラストシーンのセリフは今でもそらんじることができるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たつたそれつぽつちのものが無暗に異様に思ひ出されて、その後それはどうなつたか、今でも物置小屋の隅でも探せば抛り込んであるのではないか、さしあたり今度帰省した時には、母にでも訊いてみようと、突嗟には思つたりする、――が、なに、それほど殊勝でもなんでもない。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという監督の作品だか、一切わからないけれども、あの作品の監督には、今でもお礼を言いたい気持がある。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして今でも、「さう、なくちや――なくちやならぬ」は、時に自身に向つて云はれてる場合があつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも折には矢も楯も堪らない程訓辞の必要を感じたが、そしてまた実際腹案を立てゝ登校したこともあつたが、教員室に覗いて教師達から威勢の好い挨拶をされるともうその勇気はなくなつてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今でも生徒の校長を悪く思つてるらしい口吻を聞付けた時には、「人間といふものは外だけをみて分るものぢやない、君達でも仮りに継母を持つてゐるとしたら学校に来てゐても思ふやうに勉強が出来まい」と何時もその言葉を反覆した。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その水の音は、今でもハツキリ覚えてゐる。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄もそれを言つた時の耕二の顔は今でも思ひ出せる程嬉しかつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今でも、時に尚思ひ出したやうに詩を書いてる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今でもなお、その同じ垣根の外で、昔ながらに自分を待っている恋人があり、誰れかがいるような気がするという意味である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校時代のことを考えると、今でも寒々とした悪感が走るほどである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闇阪の街燈には今でもやもりが居るが、元のような空想はもう起らぬ、小さな細長い黒影は平和な灯影に眠っているように思われるのである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は虫抑えの薬を取り出して呑ませてくれたがあの時の自分の心は今でも説明は出来ぬ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内容はすっかり忘れてしまったが、それを読んだときに身に沁みた平和で美しいフランスの田舎の雰囲気だけが今でもそっくり心に残っているようである。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今でもこの曲を聞くと、蒲団の外に出して書物をささえた私の指先に、しみじみしみ込むようであった春寒をも思い出すのである。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし自分が今でもこの匂いの実感を持合わさなかったとしたら、江戸時代の文学美術その他のあらゆる江戸文化を正常に認識することは六かしいのではないかという気もする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき先生自身がひどく吃驚した顔を今でもはっきり想い出すことが出来る。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の話した色々の話の中で今でも覚えているのは、外科手術に対して臆病な人や剛胆な人の実例の話である。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹を貰ってからのことを色々空中に画いてはエクスタシーに耽ったものと見えて、今でもなんだか本当に一度鷹を飼ったことがあるような気持がすることがある、もちろん事実は鷹などかつて飼った経験はないのである。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "えびは今でもいるが「子供の私」はもうそこにはいないからである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの「子供の私」は今でも「おとなの私」の中のどこかに隠れている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今でも盆踊りというとその夜を思い出すが、不思議な錯覚から、その時踊っていた妖精のような人影の中に、死んだその人の影がいっしょに踊っていたのだというような気がしてしかたがない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来軍人と云うものはすべてあんなものかと云うような単純な考えが頭に沁みて今でも消えぬ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の中学の時の修身の先生が、今でもその師範の倫理の先生をしてゐて、其処の、学校の役宅にゐる。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分……今では損はれてはゐるものの　　今でもやさしい心があつて、こんな晩ではそれが徐かに呟きだすのを、　　感謝にみちて聴きいるのです、感謝にみちて聴きいるのです。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一評者が「一時は紀行文は前人の未だ踏まない深山幽谷の奇景を、紹介するのを職とするような傾向であった、いや今でも、そういう好奇心で、紀行を書いている人もあるようだが、これはつまらぬことだろう」と言って、明らかに私に当たっている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん今でも未開時代そのままの模範的な迷信が到るところに行われて、それが俗にいわゆる知識階級のある一部まで蔓延している事は事実であるが、それとは少し趣を異にした事柄で、科学的に験証され得る可能性を具えた命題までが、一からげにして掃き捨てられたという恐れはないものだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも四十二の暮から自分で病気に罹って今でもまだ全快しない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのバケツの色彩が妙に眼について今でも想出される。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の布切れがやつぱり今でも引つかゝつて居るかも知れない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もどしたものを母親が小さな玩具のバケツへ始末していた、そのバケツの色彩が妙に眼について今でも想い出される。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
