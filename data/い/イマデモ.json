[
  {
    "uuid": "58022c1a-cc2b-5345-99e4-80907225b5bb",
    "entry": "今でも",
    "reading": {
      "primary": "いまでも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
