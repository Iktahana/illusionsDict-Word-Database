    "definitions": [
      {
        "index": 1,
        "gloss": "Ibaraki (prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏の休暇は、家族で茨城（いばらき）の海へドライブに行く予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "茨城（いばらき）のメロンは甘くて美味しいと評判なので、お土産に買っていこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は生まれも育ちも茨城（いばらき）だと言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしこの結婚も甘美とは行かず、半年もたたぬうちに彼の前生活について、そっちこちで悪い噂が耳に入り、そのうち放浪時代から付き絡っていた、茨城生まれの情婦が現われたりして、彼女が十年働いて溜めた貯金も、あらかたその手切れに引き取されてしまった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖以来茨城の結城郡に居を移した地方の豪族として、多数の小作人を使用する長塚君は、彼等の獣類に近き、恐るべく困憊を極めた生活状態を、一から十迄誠実に此「土」の中に収め尽したのである。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "米は茨城県の水戸の生れで、水泳の心得があるところから、投身すると見せかけてそのまま沖の方へ泳いで往った。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒜間江は今の茨城郡の涸沼である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "攝州の住吉だの、茨城、埼玉の某地だのの如きは、十二指腸蟲の巣窟で、そこの蔬菜井水を飮食すれば、危險至極で、其の附近には同患者の多いのは爭ふ可からざることである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "茨城だつたか千葉だつたか乃至は又群馬の方だつたか何しろ東京から餘り遠くない縣の何とか郡何とか村小學校内某といふ人から歌が來た。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、茨城の方の田舎とやらに病院を建てた人が、もっともらしい御容子を取柄に副院長にという話がありましたそうで、早速｜家中それへ引越すことになりますと、お米さんでございます。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年七月十五日發行、茨城縣立下妻中學校雜誌　爲櫻　第十七號所載）",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九三（明治二十六）年　四月、茨城県立水戸中学校に入学。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖以來茨城の結城郡に居を移した地方の豪族として、多數の小作人を使用する長塚君は、彼等の獸類に近き、恐るべく困憊を極めた生活状態を、一から十迄誠實に此「土」の中に收め盡したのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の住吉だの、茨城、埼玉の某地などは十二指腸虫の巣窟で、そこの野菜や井水を飲食すると危険至極で、その附近に同患者の多いことは争えないことである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩摩なまり、東北なまり、茨城弁など、数多の看守が立ちかわり入れかわり、同じようなことを幾度となく聞きただしては手帳につけて行く。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は又茨城にいる娘の夫が、これから何んとか面倒を見てくれるそうだから安心してやったらいゝと云った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利の福井は遠いし、佐野のあら町は不便だし、ここらから若者が出かけるには、茨城県の古河か中田かに行くよりほかしかたがない。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の地方（茨城県の北隅）ではこの虫が飛ぶと、軈て初雪の降るしらせだと云つてをります。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "茨城、千葉、栃木、群馬、の近県は勿論のこと、九州、越後、奥州、までのして歩いたよ。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茨城県は遊廓がなかつたと思ふんだが。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警報は出ないが、しかし油断はならないぜ」　　　暁の空襲警報　茨城県｜湊町の鮪船が四｜艘、故郷の港を出て海上五百キロの沖に、夜明を待っていた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前五時十五分、北緯三十六度東経百四十三度ノ海上ニアル茨城県湊町在籍ノ鮪船第一｜大徳丸ハ有力ナルＳ国軍用機ノ大編隊ヲ発見ス、高度約二千メートル、進路ハ西南西。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は茨城縣第○中學の助教諭、兩親と小妹とをば、昨年の暮任地に呼び寄せて、餘裕もない代り、別に窮迫もせぬ家庭を作つた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度衰亡史は云はずもの事、まだ一册の著述さへなく、茨城縣の片田舍で月給四十圓の歴史科中等教員たる不甲斐なきギボンは、此時、此歴史的一大巨人の前におのづから頭の低るるを覺えた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は茨城県第○中学の助教諭、両親と小妹とをば、昨年の暮任地に呼び寄せて、余裕もない代り、別に窮迫もせぬ家庭を作つた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度衰亡史は云はずもの事、まだ一冊の著述さへなく、茨城県の片田舎で月給四十円の歴史科中等教員たる不甲斐なきギボンは、此時、此歴史的一大巨人の前におのづから頭の低るるを覚えた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶一杯11・７（夕）　茨城の北相馬郡｜桑原村といふ土地に伝右衛門といふ爺さんが居た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体茨城の人には、人間では水戸烈公より外に偉い人はなく、山では筑波山の外に山らしい山は無いと思つてゐるのが多いが、伝右衛門もその一人で、仕合せと文字を知らなかつたから、烈公の方は絶念めて、閑さへあると筑波山へばかり登つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸目の前に散ついてゐる連中を数へ立ててみても藤田組の阪仲輔氏、茨城県代議士の鈴木錠蔵氏、第百銀行の本庄重俊氏、大阪電灯の日高｜驥三｜郎氏、大阪アルカリの上領純一氏、日本車輛製造の原田勘七郎氏……といつたやうに、卒業証書の有無なぞもう気に懸けないでもいゝやうな顔触ばかりになつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十二年に茨城県の国生という村の相当の家に生れた長塚節は水戸中学を卒業しないうちに病弱で退学し『新小説』などに和歌を投稿しはじめた。",
              "citation": {
                "source": "「土」と当時の写実文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の俳人で「いばらき」の記者をして居た藤田順吉氏、この人は非常に俳句が好きであつた。",
              "citation": {
                "source": "小川芋銭先生と私",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "この次の汽車ですから、君等をお送りして行かう」　時間が来たので、いばらき新聞社を出た。",
              "citation": {
                "source": "小川芋銭先生と私",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
