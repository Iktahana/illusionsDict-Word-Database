        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "美術館で見た抽象画は、見る者に言いようのない感動を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は絶望の淵にいて、言いようのない孤独感に苛まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めて訪れた秘境の景色は、まさに言いようのない美しさだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その料理は複雑な味が絡み合い、言いようのない美味しさだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験に合格した時の言いようのない安堵感は、今でも忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦争で故郷を失った人々の心には、言いようのない悲しみが渦巻いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の成長を目の当たりにする喜びは、言いようのないものがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "黒表紙には綾があって、艶があって、真黒な胡蝶の天鵝絨の羽のように美しく……一枚開くと、きらきらと字が光って、細流のように動いて、何がなしに、言いようのない強い薫が芬として、目と口に浸込んで、中に描いた器械の図などは、ずッしり鉄の楯のように洋燈の前に顕れ出でて、絵の硝子が燐と光った。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私はとめどなくげらげら笑いながら、そのまま「いでゆ」から出てしまったのであるが、宿へ帰って、少しずつ酔のさめるにつれ、先刻の私の間抜けとも阿呆らしいともなんとも言いようのない狂態に対する羞恥と悔恨の念で消えもいりたい思いをした。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然明い所へ出ると、少女の両眼には涙が一ぱい含んでいて、その顔色は物凄いほど蒼白かったが、一は月の光を浴びたからでも有りましょう、何しろ僕はこれを見ると同時に一種の寒気を覚えて恐いとも哀しいとも言いようのない思が胸に塞えてちょうど、鉛の塊が胸を圧しつけるように感じました。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思いはしたものの、言いようのない物足らなさが胸の奥底に濃く澱むのをどうすることもできなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二三度、四五度、繰返すうちに、指にも、手にも、果は指環の緑碧紅黄の珠玉の数にも、言いようのない悪臭が蒸れ掛るように思われたので。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の中に柳があったら、お月様の影の中へ、身を投げて死にたいような、……何んとも言いようのない心持になったのですえ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "言いようのない憂鬱が、しばしば絶望のどん底から感じられた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも言いようのない、悲しい心細い思いがしましたな。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒とも可哀想とも悲惨とも、何とも言いようのないつらい気持で、彼の痴語を聞きながら、私は何度も眼蓋の熱くなるのを意識した。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえ、そこどころじゃあない、私は野宿をしましてね、変だとも、おかしいとも、何とも言いようのない、ほほほ、男の何を飾った処へ、のたれ込んだ事がありますわ。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそれは何とも言いようのない、うつくしい女でした。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、哀れ、とよりほか言いようのない気持であった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、歓びでもなく苦しみでもなく、それは、それとより言いようのないものである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は椅子に全身を曲げて丸めて座っており、その姿勢が言いようのない印象を与えるのだった。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとも言いようのない不快な感じが胸に湧きあがり、じっとりとした冷たさで心臓をぞっとさせた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいまここで、たといそれができたにしても、自分の近年のなんとも言いようのない不幸と、許しがたい罪悪との記録を書きしるそうとはしまい。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "――朝になって、その哀れな男は、そのボートが、毎日行きつけている場所に――おそらく、勤務のために行かねばならぬ場所に――拾い上げて繋いであるのを見つけて、言いようのない恐怖に打たれる。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "がしだいしだいに――ごくゆっくりと――言いようのない嫌悪の情をもってその猫を見るようになり、悪疫の息吹から逃げるように、その忌むべき存在から無言のままで逃げ出すようになった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "命婦は故｜大納言家に着いて車が門から中へ引き入れられた刹那からもう言いようのない寂しさが味わわれた。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄之丞としては見くびられたとも貶しめられたとも、言いようのない侮蔑を蒙ったように感じた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来の仕事も生活もどうなってゆくかわからないような彼は、この冴えに冴えた秋の夜の底にひたりながら、言いようのない孤独に攻めつけられてしまった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何とも言いようのない屈辱を感じたが、それでも毛布をすてはしなかった。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつに意外ともなんとも言いようのないことを、ずばりと名人がいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが退屈男だけに、そのふわりふわりの膝栗毛が、何ともかとも言いようのない膝栗毛でした。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この嬉しさ、この肩身の広さは、やがて何とも言いようのない拷問に変わっていった。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の足音が、奥の間へ消えた時、玄石の顔には、何とも言いようのない表情が浮かんだ。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "で思わずその方向へ視線を送ると、正面の二階席の一番前列に、あの人が何とも言いようのない顔をして、両眼を釘付にされたようにして舞台の妾をにらんでいるのです。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、二人切りでこの離れ島に居るのが、何ともいいようのないくらい、なやましく、嬉しく、淋しくなって来たからでした。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の下では何ともいいようのない優しい水音がする。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの競漕の最中に、しばしば襲って来るあの辛いとも楽しいともいいようのない極限感が、たちまち彼女の心身を占めて、彼女を痺らす。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
