        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "井戸端で近所の奥さんたちが立ち話をしているのが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔は井戸端が村の情報交換の場だったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕涼みに井戸端に出て、涼しい風にあたった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夜中にふと眼がさめると台所の土間の井戸端で虫の声が恐ろしく高く響いているが、傍には母も父も居ない。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃のわが家を想い出してみると、暗いランプに照らされた煤けた台所で寒竹の皮を剥いている寒そうな母の姿や、茶の間で糸車を廻わしている白髪の祖母の袖無羽織の姿が浮び、そうして井戸端から高らかに響いて来る身に沁むような蟋蟀の声を聞く想いがするのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、起きて、ふたりで顏を洗ひに井戸端へ出て、そこでもう藝術論がはじまり、一時間ちかく井戸端をぐるぐるめぐり歩いて最近の感想を述べ合ひました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と子供を叱るやうな口調で言ひ、「そんな工合ひに家の中で、じつと爐傍に坐つてゐる人と、井戸端へ出て洗濯してゐる人と、どつちが寒いか知つてゐますか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の井戸端は習慣になつてゐるから。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝長屋　井戸端でお内儀さん二三人の立ち話し。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端のお内儀が囁き合った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次、エヘッと意味深の笑い残して内へ入るとカメラがスーと流れて、　井戸端です。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして下宿へ帰ると井戸端へ行って水ごりをとった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤吉は逃げ廻るはずみに井戸端で足をすべらせて、井戸側へよろけかかったかと思うと、さかさまに転げ込んでしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは山の宿の小間物屋の女房で、かれは誰も知らない間に、裏の井戸端で啖い殺されていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、じいさんは井戸端で足を洗ってきて云った。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端の氷は朝から、そのまま解けずにかたまっていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉が降り留っている井戸端の漆喰へ、洗面のとき吐く痰は、黄緑色からにぶい血の色を出すようになり、時にそれは驚くほど鮮かな紅に冴えた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭の当日は朝からよく晴れていて私が顔を洗いに井戸端へ出たら、佐吉さんの妹さんは頭の手拭いを取って、おめでとうございます、と私に挨拶いたしました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「井戸端で足を洗っています。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端へ出て顔を洗い、それから園子のおむつの洗濯にとりかかっていたら、お隣りの奥さんも出て来られた。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もその海水浴のときに「玉ラムネ」という生れて始めてのものを飲んで新しい感覚の世界を経験したのはよかったが、井戸端の水甕に冷やしてあるラムネを取りに行って宵闇の板流しに足をすべらし泥溝に片脚を踏込んだという恥曝しの記憶がある。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日慧鶴は井戸端で肌着を洗濯して居た。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠来い簑着て来い行燈の油に火を持って来い……………………　仲間の子供たちが声を揃えて喚き出したので、お涌も井戸端から離れた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、此はさすがに、井戸端で名のり懸けるわけには行かない。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、此はさすがに、井戸端で、名のり懸けるわけには行かない、さりとて用人の若御新造、さして深窓のと云ふではないから、隨分臺所に、庭前では朝に、夕に、其の下がひの褄の媚かしいのさへ、ちら／＼見られる。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日目に、井戸端で、例の身體を洗つて居る處へ、ニヤーと出て來た。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端で水を浴びたり、合長屋の障子を、ト唾で破いて、その穴から舌を出したり、路地の木戸を石※でこつこつやったり、柱を釘で疵をつけたり、階子を担いで駆出すやら、地蹈鞴を蹈んで唱歌を唄うやら、物真似は真先に覚えて来る、喧嘩の対手は泣かせて帰る。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "菖蒲、杜若は此處ばかりではない、前日――前々日一見した、平泉にも、松島にも、村里の小川、家々の、背戸、井戸端、野中の池、水ある處には、大方此のゆかりの姿のないのはなかつた。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ溝川にも、井戸端にも、傾いた軒、崩れた壁の小家にさえ、大抵皆、菖蒲、杜若を植えていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "路次の井戸端にまつられた石地蔵に、ある時何に腹立ってか、小便をひっかけた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど入笠山あたりのハイキングから帰って来たらしい、加世子の従兄と登山仲間の友人とが、裏の井戸端で体をふいているところだったが、加世子が見つけて、縁端へ出て言葉を交している工合が、どうもそうらしいので、均平も何か照れくさい感じでそのまま女中の案内で二階の加世子の部屋へ通った。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
