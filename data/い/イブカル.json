      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to wonder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "突然の訪問者に、彼は訝りながらドアを開けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「どうしてここに？」と、彼女は訝った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その不可解な状況に、私はただ訝るしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "疑い訝る者、引留める者も有ったには相違無い、一族｜朋友に非難する者も有ったには相違無い。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同一江海の朝と夕と相異なるが如きは、怪み訝るを要せぬことである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙の氣の昇降伸屈盤旋交錯によつて孕育生長せられて居るのが、一切庶物の状なのであるから、怪むところも訝るところも無いが、草木を觀ると如何にも面白い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この腹癒せには、何か復讐をしてやらなければ気が済まないと、連れの八重子の訝るのも関わずに、ぷん／＼腹を立てながら、もう約束の時間にも間もないので、八重子を連れて男の子たちが指定したＭ――店へ入り、クリスマスの為めに樅の木に装飾の美しい二階の食堂へ上って待受けました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞いた人は芸人の癖にと訝るかも知れない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、女の壁はそのような無窮無限の壁なのに何でわたしがおまえ一人を目指すのかとおまえは訝るかも知れない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は生面の客あるを見ても、絶て怪み訝ることなく、我に榻を與へて坐せしめ、我に盞を與へて飮ましめ、肴せんとて鹽肉團をさへ截りてくれたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "穗は何を騷ぐのかと訝るやうに少し俯目に見おろして居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ江海の朝と夕とが相異なることは怪しみ訝る必要もないことである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙の気の昇降・屈伸・旋回・交錯によって、養育生長させられているのが一切庶物の状態なのであるから、怪しむところも訝るところもないが、草木を観ると如何にも面白い。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他は番町の方の鰐淵と申す、地面や家作などの売買を致してをります者の手代で、間とか申しました」「はあ、それでは違ふか知らん」　宮は聞えよがしに独語ちて、その違へるを訝るやうに擬しつつ又｜其方を打目戍れり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がこの女から奇妙な取扱を受けながら、それを拒絶する力がもう無くなつてゐるのを、纔かに訝るばかりであつた。",
              "citation": {
                "source": "雲雀病院",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの病人の不時の出社を訝るよりも、先づ其の屋外の光線で見た衰弱の甚だしさに驚いた。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は寧ろ私の問ひを訝るやうに答ヘた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "と訝る折しも、何を思ったか洋装の少女はつと僕に近づいて、腕を捉えた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、さっと蒼白くなった顔の中で、二つの光の失せた眼を瞠り、訝るように、傍に立っている、天につかえそうな背高い戦士を見上げた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の冷澹なのを、やや訝るような心持になった。",
              "citation": {
                "source": "独身",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "新公は半ば嘲るやうに、又半ば訝るやうに、彼女の顔を眺めたなり、やつと短銃の先を下げた。",
              "citation": {
                "source": "お富の貞操",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と訝るらしい首の曲げ方で答えた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　牧野はそろそろ訝るよりも、不安になって来たらしかった。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十年代の詩界を顧みる人は、その若々しかるべき光景を豫想しつゝ、そこに煩悶と厭世の狹霧の立ち籠めてゐるのを見て、必ず一度はこれを訝ることであらう。",
              "citation": {
                "source": "創始期の詩壇",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　別所のことを云い出されても、李は訝る気色もなく、初めから分ってたもののような応対だった。",
              "citation": {
                "source": "浅間噴火口",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それがどちらとも判断がつかないうちに、私はすっかり驚いて、ただ眼を丸くして訝るより他にしようがなかった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は訝るといふよりも、むしろ、けはしく私を睨んでゐた。",
              "citation": {
                "source": "暗い青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁敵に事欠く場所ではないのであるから、太平はその特別の友情を一応訝るのであつたが、庄吉は太平の外の人々には目で挨拶を交すだけの友達すらも作らなかつた。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは太平がキミ子に思ひを寄せてゐるのを知つてゐた意味であらうと思はれたが、太平はそれを訝るよりも、実際にさうでしかないやうな激情に憑かれた。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲の善いにも悪いにも、このお松をほかにしては、友達らしい友達を持たぬ自分の身を顧みて、お松の言うことを訝るもののようでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややあって多摩川を発見して、あれは利根か知らんと訝る者もありますけれど、少しく頭を冷やかにして地理を案ずれば、その区別は苦にするほどのことではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でしょう――とお松は、それを訝るより先に、自分の胸が轟きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ変化なるものは万有の大法大則なれば、わが邦にして昔時の面目を一変したりとて、さまで訝るべきことにはあらざれども、その変化のあまりに快活にしてかつその方向の意外なる針路に向かって奔りたるの一点に関しては、何人といえども一驚を喫せざる者はあらざるべし。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
