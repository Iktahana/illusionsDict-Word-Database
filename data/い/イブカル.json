[
  {
    "uuid": "41a1c98a-696d-53a8-83c6-ec46434d4f39",
    "entry": "訝る",
    "reading": {
      "primary": "いぶかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
