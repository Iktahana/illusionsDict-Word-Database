          ],
          "literary": [
            {
              "text": "」「こんなところに、勝手に便所を建てたりして第一風景を損じて見ッともないじゃないか！",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ではまったく見られない堀ばたの一風景であった。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ではまったく見られない堀端の一風景であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏になるとあっぱっぱと云うのが流行りますが一風景です。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも亦明治聖代の一風景である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧朝鮮の日本人コロニイを背景とした「秋水嶺」は、現代日本の「青春」の一風景が素直な眼で捉へられ、健やかな感覚で舞台にくりひろげられた注目すべき力作であつた。",
              "citation": {
                "source": "内村直也の戯曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川賞一風景　今期の芥川賞選考委員会に、二つの放送局から録音の申込みがあったそうだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "窯場としても、村全体が美しい一風景をなしている点で他では見られない所です。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、兼子氏のような哲学に何か意味があるとすれば、それは一種の人間学と国粋哲学との結びつきを、相当ハッキリと体現して、現代のファッショ化したブルジョア哲学の漫画的一風景を点出した点にあるのである。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかにも奥山は、公園第二区となった観音裏に門並の楊弓店、のんきな連中が入り浸ってドンカチリと的の音、これも時代の一風景。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地方は藺の産地で、水田に植えられている様も、土地の一風景であります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
