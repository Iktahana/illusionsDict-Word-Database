    "definitions": [
      {
        "index": 1,
        "gloss": "to pass the time talking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
