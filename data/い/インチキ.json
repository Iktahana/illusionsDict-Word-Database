        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "インチキ新聞の記者になったり、暴力団の走り使いになったり、とにかく、ダメな男に出来る仕事の全部をやったと言っても決して言い過ぎではないかと存じます。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は学芸新聞を創刊してインチキ病院や、インチキ興行をイジメてやるかな……それとも全然｜河岸を換えて最新式の安アパートでも初めながら、原稿生活を続けてやろうかナ……なぞと……。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御禁制の袁許御祈祷のインチキ歌じゃ」「困るなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そげな仕事の下請けしよんなさるとアンタの首へ私が縄かけにゃならん」「インチキにかかる相手が疫病神なら仔細なかろうモン」「ナニ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "心は、インチキがお嫌い……と言う訳かな」「ワハハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも東京が日本第一の生存競争場である位の事は万々心得て上京した積りであったが、このアンバイで見るとその生存競争があんまり高潮し過ぎて、人間離れ、神様離れした物凄いインチキ競争の世界にまで進化して来ているようである。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの青空や、太陽や、行く雲までもがキネオラマみたいなインチキかも知れない。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "インチキが暴露たまま成功したのだから……。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しインチキだと思召すなら、念のために役場へ行って、戸籍の謄本をお取りください。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもその叔父というのは、よっぽどタチの悪い人間で、若いうちから放蕩に身を持ち崩したあげく、インチキ賭博の名人になって、親類や友達から見離されていたが、私が三つか四つの年に親父が喘息にかかって弱り込むと間もなく、上手に詫を入れて出入りをするようになった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも製作技術の智慧からではあるが、丸太を組み、割竹を編み、紙を貼り、色を傅けて、インチキ大仏のその眼の孔から安房上総まで見ゆるほどなのを江戸に作ったことがある。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなの、インチキというんじゃないかしら。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、インチキに挑戦して行く破れかぶれの賭のスリルだろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、続けて張っている内に結局はあり金を全部とられて了い、むろんインチキだった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対にインチキと違うよ、一見胸がときめいてなどと中腰になって、何かをわざと怖れるようなそわそわした態度で早口に喋り立て、仁が寄って来ると、先ず金を出すのがサクラの順平だ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん今日の言葉でいえばインチキの代物が多いのだが、だまされると知りつつ覗きに行く者がある。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、いくらインチキにしても種が尽きて来る。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨はとどこおりなく由兵衛の手に渡って、十三日からいよいよ奥山の観世物小屋に晒されることになったが、これはインチキでなく、確かに真物だ。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは野州庚申山で生捕りましたる山猫でござい位のことにして置けば無事だったのだが、そこが例のインチキで、弟の幸吉が飛んだ商売気を出した。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは友蔵らもさすがに心得ているから、抜目なく例のインチキ手段を講じた。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "由兵衛も同商売であるから、インチキ仲間の秘密は承知している。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてはイヨイヨインチキホテルだな。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中でインチキの小判と気が付いて引返やいて来よったら叶わん。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この故にコペルニクスの探偵趣味は生命がけの地動説を発表して聖書のインチキを曝露し、羅馬法王を狼狽、震駭させた。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "話術でスリルを作るのはインチキ話術ではないか。",
              "citation": {
                "source": "探偵小説漫想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
