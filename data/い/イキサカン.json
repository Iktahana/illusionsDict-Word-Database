        "examples": {
          "standard": [
            {
              "text": "試合終盤、両チームは意気盛んに最後の攻防を繰り広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいプロジェクトの始動にあたり、若手チームは意気盛んなアイデアを次々と提案した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祭りのフィナーレでは、地元の団体が意気盛んなパフォーマンスを披露し、会場を沸かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "環境問題への関心が高まる中、若者たちは意気盛んなデモ行進で社会に訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "厳しい状況にもかかわらず、彼は意気盛んに目標達成に向けて努力を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「よし、この仕事、意気盛んに片付けよう！」とチームリーダーは声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は長年取り組んできた研究に、今も意気盛んに情熱を注いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "同じく源空の門下に出て、後の浄土宗から分立し、源空最初の意気盛んな頃の説をどこまでも主張したのは、真宗の開祖善信聖人親鸞であった。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
