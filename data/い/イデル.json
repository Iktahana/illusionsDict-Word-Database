          ],
          "literary": [
            {
              "text": "されば今晩かなしげに、かうして沈んでゐる僕が、輝き出でる時もある。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを語り出でるためには時間と意志とが必要である。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今晩かなしげに、かうして沈んでいる僕が、輝き出でる時もある。",
              "citation": {
                "source": "酒場にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」が、冗談ぢやない、僕は僕が輝けるやうに生きてゐた。",
              "citation": {
                "source": "酒場にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とはなしに陸さんの門前の方へ廻り何とか云う人の門につきあたり左の方を注視したけれども先生の庭の方へ出でる道はない　仕方はないから又もとへ戻って先生の前へ来た。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際、文章ほど複雜多岐多樣の相貌形態を持つてゐるものはないが、これは作者なり筆者なりの人格或は氣質が自然に現れ出でるからに外ならない。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ町内に赤痢患者が出で、同じ市内に黒死病患者が出でるのも、我が不幸なるは明白である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金沢」といふ寄席の隣の、何とかいふ小さいしる粉屋でしる粉をのんで、その家を立ち出でると、三味線の音は手に取るやうに聞えて居た。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙信は勝っても負けても必ず川を越えて、川中島に出でるであろう。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "間髪をいれず社長のあとを二階へ追うて行って、辞職を申出でる必要があるか、どうか、咄嗟のうちに考えていたからである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び出でる間際にも、『奈々子は泣いたかツと問うたら、長女の聲で未だ泣かないと聞えた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その看護婦に附文する男が五指を出でると聞いた時、雁江は耳まで赤面してしまった。",
              "citation": {
                "source": "滑走",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず当面の歌舞伎座がいかなる策戦に出でるかということが、最も世間の注意をひく問題であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は咲いてゐないが、自分が花が見たいと思ふと、その直後にこの野原に美しく花が咲き出でると告げる。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれは此の家の中から洩れ出でる話声だった。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "成功した其時の嬉しさも思出でるが、併し多くは其時一處に行つた友の、死んだのや、遠ざかつたのや、いろ／＼それを懷出して、時々變な感情に打たれもする。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "權現臺の懷古",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会に出でると実際の事実が理想のようにないために失望して失敗するものが多い。",
              "citation": {
                "source": "女子教育に就て",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし男子の非道に反抗してこういう逆襲の態度に出でる事は暴を以て相酬いるので、本本互に謙遜し、互に尊敬し協和して男女各自の天分を全くすべき真理に悖ておりますから、一方を服従させようというのでなく、服従するなら互に真理の前に服従し得る立派な人格を養って後に結婚するのが大切でしょう。",
              "citation": {
                "source": "離婚について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私娼がもし監督の上に不便であるなら、すべて酌婦の名義で届｜出でる手続きを取らせてもよい。",
              "citation": {
                "source": "私娼の撲滅について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済、政治、その他一切の社会現象、人間の知識の凡てを、文学者が自らのものとした時、甫めて十九世紀に全盛を見、以後次第に衰微した文学が再び勢よく発芽し、花咲き出でるであろう。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "その深い憂鬱の海から華かな大きな花が咲き出でる。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえの良心がおまえを叫ばさせずにはおかないまでおまえの唇に迫るまで、おまえはへりくだり虚くして待つがいい、そのときこそおまえは権威ある人として語り出でることができるであろう。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのものは彼らにおいて生命であり力であるがゆえに、時にはそれらのものは自分自身を否定して巨大なる光輝となって輝き出でる。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考によれば、真の個性はそのとき少しも蔽われない姿において輝き出でるのである。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも渡さずば、その時こそはその友人を証人として訴え出でるのだ」と言う。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の御主のダイアナも月の冠をかむって御出でるから美くしいのだ、まばゆい車にのっていらっしゃるから立派なのだ。",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その穴の中から、潜水服のようなものを着た怪人物が姿をあらわし、爆弾から立ち出でると、のっそりと戦友の屍を踏まえて、突っ立った。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ見て御出でるのかなもし。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母が、父に小言でも言はれてふさいでる時私がそれを慰めようと思つて父の酷過ぎることを言ふと母は何時も私にさう言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
