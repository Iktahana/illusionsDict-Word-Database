    "definitions": [
      {
        "index": 1,
        "gloss": "different in appearance but essentially the same in content",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
