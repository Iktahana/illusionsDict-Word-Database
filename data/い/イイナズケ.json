        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "江戸時代、身分違いの許嫁との結婚は、現代では考えられないほど困難であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は幼い頃から、家同士の取り決めにより許嫁がおり、その相手との結婚が運命づけられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その小説では、主人公が許嫁の女性を救うために危険な冒険に挑む物語が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "両家の親族が集まる中、彼は初めて自分の許嫁に挨拶をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、あの人、私の許嫁なんですよ」と、彼女は少し恥ずかしそうに微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「許嫁さんには、もうお会いになったのですか？」と、周囲の大人たちが興味深そうに尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それはいちばん声のいい砲艦で、烏の大尉の許嫁でした。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大尉は呟やきながら、許嫁のいる杜の方にあたまを曲げました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたから、また許嫁といっしょに、演習ができるのです。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までの貴方様のお許嫁、蔵元屋のお熊さんと生写しで御座いましょうが」　半三郎の真青な顔が、見る見る火のように赤くなった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "許嫁でも、夫婦でも、情婦でも、私、まけるわ、サの字だから。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　年紀は少し……許嫁か、何か、身に替へて思ふ人でも、入院して居て、療治が屆かなかつた所から、無理とは知つても、世間には愚癡から起る、人怨み。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――親と親との許嫁でも、十年近く雙方不沙汰と成ると、一寸樣子が分り兼る。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいちばん声のいゝ砲艦で、烏の大尉の許嫁でした。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大尉は呟やきながら、許嫁のゐる杜の方にあたまを曲げました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたから、また許嫁といつしよに、演習ができるのです。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚破と、母屋より許嫁の兄ぶんの駈けつくるに、讀みさしたる書伏せもあへず抱きて立てる、栞の萩も濡縁に枝を浪打ちて、早や徒渉すべからず、あり合はす盥の中に扶けのせつゝ、盪して逃るゝ。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方には能くある習、角川の市郎と冬子とは所謂許嫁の間柄で、市郎が医師を開業すると同時に、めでたく祝言という内相談になっている。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "心斎橋筋の雑閙のなかでひともあろうに許嫁に小銭を借りるなんて、これが私の夫になる人のすることなのか、と地団駄踏みながら家に帰り、破約するのは今だと家の人にそのことを話したが、父は、へえ？",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もどると、伊都子は、「今、あなたが火を借りた男、私の許嫁よ」　と、言った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "許嫁気取り、しょってるわ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父や許嫁が一緒だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉はもう一度頭を下げようとしたが、丁度その時、伊都子の許嫁がキッと信吉の方を睨みつけた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "許嫁の視線は信吉の胸をチクリと刺して新たな悔恨があった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今朝、伯父や許嫁と一緒に東京を発って行った筈の伊都子が、今時分どうして自分を訪ねて来たのだろう――と、考える暇もなく、伊都子はいきなり両手を拡げて、信吉の胸にしがみついて来た。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんないやな男と結婚しなくちゃならないのかと、思って、許嫁の顔を見ていると、余計あなたに会いたくなったの。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "許嫁、すっかり旦那気取りなの。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやな許嫁に処女を捧げるよりは……」　と、昨日伊都子は信吉に身を任せた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "許嫁気取りの男への反撥心と、好奇心がさせた火遊びに過ぎない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "許嫁なんか怒ったって、構わないけど、伯父さんを怒らせてしまったんだもの。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学生の豹一は自分には許嫁があるのだと言い触らした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ私たちは――私と松岡とは、田舎にいた時分、許嫁だったのです。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、晃一の嫁の幸子は幼い時分から晃一の許嫁として、兄弟と一緒に育てられた身なのだが、未だ女学校にいる頃、高等学校の学生だった旻と恋に落ちて、駈け落ち迄したことがあった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が許嫁の死の床に侍して、その臨終に立会った時、傍らに、彼の許嫁の妹が身を慄わせ、声をあげて泣きむせぶのを聴きつつ、彼は心から許嫁の死を悲しみながらも、許嫁の妹の涕泣に発声法上の欠陥のある事に気づいて、その涕泣に迫力を添えるには適度の訓練を必要とするのではなかろうか。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じつを言うと、ぼくには、人間に飼われている、いいなずけがいてね、彼女が御殿の中を自由に歩きまわることができるもんだから、なにもかも、ぼくに話してくれたんだよ」　カラスのいいなずけが、カラスであることは、言うまでもありません。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、飼われている、ぼくのいいなずけの話によると、その子は、御殿の門をくぐって、銀色の服を着た番兵を見ても、階段をのぼって、金ピカのお役人にであっても、びくともしなかったってことだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
