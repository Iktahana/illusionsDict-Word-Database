        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仮りに相手は文学的個性があるので、自然、文学の話をするやうになるのである場合も、その相手が嫌になる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、相手に個性があればある程嫌になる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐の時、ヘルンはいつも二三本の日本酒を盃で傾けながら、甚だ上機嫌に朗かだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人がそれを読んできかすと、ヘルンはすっかり上機嫌になってしまい、『いかに面白い。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、彼もさすがにてれくさそうにして眼を激しくしばたたかせながら、そうして、おしまいにはほとんど不機嫌になってしまって語って聞かせたこんなふうの手柄話を、あんまり信じる気になれないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが外国人だから嫌な表情にみえないんだが、日本人だつたらどんなに嫌に見えるだらう。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを政夫さん隔てるの嫌になったろうのと云うんだもの、私はほんとにつまらない……」　民子は泣き出しそうな顔つきで僕の顔をじいッと視ている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴ン方、御飯よ……」　「あ、今行くよ」　七五郎、不気嫌に家へ入る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり日中だけの営業で、日が暮れたら店を片付けて住居に帰る）　三次の奴が境内の茶店に腰をかけて嫌に嬉し相にしている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次ほとほと嫌になった。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後から抱きつく奴――（Ｆ・Ｏ）　＝（Ｆ・Ｉ）五郎蔵の家の一室　五郎蔵が嫌にニタニタ笑って居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は不機嫌に怒って、ぷりぷりしていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊長は、不機嫌に、二人に怒声をあびせかけた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　栗本の声は不機嫌にとげ立っていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう云つてしまつた時、彼はその聲が非常に不機嫌に重々しく響いたと思つた。",
              "citation": {
                "source": "奎吉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行へ着いた時分には自分もかなり不機嫌になってしまっていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は急に不機嫌になった。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "全戸皆がこんな掘立小屋で、何時まで経つても或ひは藁葺だとか瓦葺だとか、家らしい家にならないし、全く嫌になつて終つたんですな。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に神經質で、如何かすると恐ろしく不機嫌になり勝ちな八歳の行夫は、私を見付けると「パパ」と大きな聲を出して、普段通りその日出遇つた珍談を聞かさうとするやうだつたが、私を見るといきなり少し詰るやうな顏付きをして、「パパは今日東京に歸るの」と云つた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この流儀で人生に処すると、世の中や人間のあらばかり見え、だんだん浮世が嫌になり、自分独り孤独を楽しむようになって、人交際が出来にくくなります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この曲なら胃の機嫌に悪影響はない。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くめ子は何となく心に浸み込むものがあるような晩なのを嫌に思い、努めて気が軽くなるようにファッション雑誌や映画会社の宣伝雑誌の頁を繰っていた。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小汚い六畳の部屋で、せいせい云つて寝てゐる険相な顔付を考へると、何にもかも嫌になつてしまふ。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽部君がねえ、そんなことをやったかねえ、こいつは愉快だ、と上機嫌に笑うばかりで、てんで私の話なんか受けつけようとしなかった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかしいな」　鶴雄の声はますます不機嫌になった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "罎のようだったから、訳がわからず、変な顔をしていると、男は上機嫌に、「石油だ（す）。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞はまことにむつかしい、自から省みて疚しくない境地へはなか／＼達せない、三輪空寂はその理想だけれど、せめて乞食根性を脱したい、今日の行乞相は悪くなかつたけれど、第六感が無意識にはたらくので嫌になる。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それでね、その癖、何のために戦争をするんだか、正義のためにとは云うんだけど、何が正義なんだかちっとも判らないし、第一敵が何処の国やら皆目見当がつかないんだから嫌になっちゃうんだよ」「そいつは、愉快だね。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之空氣がじめ／＼して嫌に生温いといふものだから、大概の者は氣が腐る。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "自躰心に錘がくツついてゐるか、言にしろ態度にしろ、嫌に沈むでハキ／＼せぬ。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
