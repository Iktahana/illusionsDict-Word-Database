    "definitions": [
      {
        "index": 1,
        "gloss": "dolphin (or other small toothed whales, incl. porpoises, belugas, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その窓の外には海豚のかたちももう見えなくなって川は二つにわかれました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生ぬるい水中へぎゅーんと五体がただ一つの勢力となって突入し、全｜皮膚の全感覚が、重くて自由で、柔軟で、緻密な液体に愛撫され始めると何もかも忘れ去って、小初は「海豚の歓び」を歓び始める。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで海豚は眼を細めている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女達が私に身を委せるとき、彼女達の感受性から海豚の粘々した動物性をうける。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり彼女も海豚なのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "が二人の間には、膝から下を切断し、おまけに腹膜炎で海豚のように腹がふくれている患者が担架で運んで来られ、看護卒がそれを橇へ移すのに声を喧嘩腰にしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海豚だなんてあたしはじめてだわ。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓の外には海豚のかたちももう見えなくなって川は二またにわかれました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、おかしな魚だわ、なんでしょうあれ」「海豚です」カムパネルラがそっちを見ながら答えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓の外には海豚のかたちももう見えなくなつて川は二つにわかれました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月　遠近の山の影、森の色、軒に沈み、棟に浮きて、稚子の船小溝を飛ぶ時、海豚は群れて沖を渡る、凄きは鰻掻く灯ぞかし。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿縁に因つて佛法を信じ、靈地を巡拜すると聞く、あの海豚の一群が野山の霧を泳いで順々に朦朧と列を整へて、ふかりふかりと浮いつ沈んつ音なく頭を進めるのに似て、稻塚の藁の形は一つ一つ其の頂いた幻の大な笠の趣がある。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "階子の下から上つて来るらしく、海豚が躍るやうな影法師は狐で。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷見鯖の塩味、放生津鱈の善悪、糸魚川の流れ塩梅、五智の如来へ海豚が参詣を致しまする様子、その鳴声、もそっと遠くは、越後の八百八後家の因縁でも、信濃川の橋の間数でも、何でも存じておりますから、はははは。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんでもない奴等、若い者に爺婆交りで、泊の三衛門が百万遍を、どうでござりましょう、この湯治場へ持込みやがって、今に聞いていらっしゃい隣宿で始めますから、けたいが悪いじゃごわせんか、この節あ毎晩だ、五智で海豚が鳴いたって、あんな不景気な声は出しますまい。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮みづく国つ神、海豚の眼見よな、遠眼、鋭眼、慧しな、羽ぶり羽ぶりおもしろ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮みづく國つ神、海豚の眼見よな、遠眼、鋭眼、慧しな、羽ぶり羽ぶりおもしろ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであくる朝早く、天皇をおつれ申して海岸へ出て見ますと、みんな鼻の先に傷をうけた、それはそれはたいそうな海豚が、浜じゅうへいっぱいうち上げられておりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じヤルート環礁の内のＡ島へ小さなポンポン蒸汽で渡つた時、海豚の群に取圍まれて面白かつたが、少々危いやうな氣もした。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、おどけた海豚共が調子に乘つてはしやぎ※り、小艇の底を潛つては右に左に現れ、うつかりすると船が持上りさうに思はれたからである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じヤルート環礁の内のＡ島へ小さなポンポン蒸汽で渡った時、海豚の群に取囲まれて面白かったが、少々危いような気もした。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、おどけた海豚どもが調子に乗ってはしゃぎ廻り、小艇の底を潜っては右に左に現れ、うっかりすると船が持上りそうに思われたからである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空には、あたかもこの海の沖を通って、有磯海から親不知の浜を、五智の如来へ詣ずるという、泳ぐのに半身を波の上に顕して、列を造って行くとか聞く、海豚の群が、毒気を吐掛けたような入道雲の低いのが、むくむくと推並んで、動くともなしに、見ていると、地が揺れるように、ぬッと動く。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿縁に因って仏法を信じ、霊地を巡拝すると聞く、あの海豚の一群が野山の霧を泳いで順々に朦朧と列を整えて、ふかりふかりと浮いつ沈んつ音なく頭を進めるのに似て、稲塚の藁の形は一つ一つその頂いた幻の大な笠の趣がある。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "海豚が陸へ上った恰好です。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は見ていたが――妙なもので、ここで鯨を売ればといっても、山車に載せて裃で曳きもしまいし、あの、おいらんと渾名のある海豚を売ればといって、身を切って客に抱かせもしないであろうが、飯蛸なぞもそうである……栄螺、黄螺、生の馬刀貝などというと、張出した軒並を引込んで、異に薄暗い軒下の穴から、こう覗く。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人か、海驢か、海豚かと、月の光りで海のうえを透かしてみると、どうもそれは人の形であるらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇常識を破らなければいけないと頑固に信じているからである。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ佐野次郎が電車にはね飛ばされて死んだのを知っているか」「知っている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、知っているから、発表するのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
