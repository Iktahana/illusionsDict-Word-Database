        "examples": {
          "standard": [
            {
              "text": "百獣の王たるライオンは、その姿を見るだけで威風凛々としたオーラを放っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "演説する指導者の姿は、まさに威風凛々としており、聴衆は皆、息をのんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古城は丘の上にそびえ立ち、その堂々たる佇まいは威風凛々としていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝説の騎士が剣を掲げた時、その姿は威風凛々として、敵は戦意を喪失した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "風采端然、威風凛々、言ふ迄もない、本艦の艦長である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "りゅうとした身裝をしたこの紳士の、威風凛々たる面構えは、わいわい囃し立てていた野次馬どもにも、大いに威壓的な效果を生んだ。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
