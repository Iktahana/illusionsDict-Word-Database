          "literary": [
            {
              "text": "雨の夜、ハミルトンが自宅で自分の８ミリを映写してみせる場面が再現され、ハミルトンの撮った８ミリが五十フィートぜんぶ、インサートされていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "８ミリ・フィルムのインサートのあと、ビル・ハミルトンがアランに会う以前へと、時間はフラッシュ・バックした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンディエーゴでのアランとダフネの出会いが語られ、ダフネが撮影したアランの波乗りのフィルムのすべてが、インサートされた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
