    "definitions": [
      {
        "index": 1,
        "gloss": "solitary Japanese cedar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山頂には、風雪に耐え抜いた一本杉が、静かに佇んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祭りの場所はこの一本杉の根元で、毎年多くの人が集まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遠くからでも見える、ひときわ高くそびえる一本杉は、この土地のシンボルだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "追っかけると、また逃げだしたが、足をゆるめると、また足をゆるめて顧眄ったが、そのうちに一本杉の方面へ姿を消して往った。",
              "citation": {
                "source": "虎杖採り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本杉は昔から、狐が出ると云われているところであった。",
              "citation": {
                "source": "虎杖採り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "摩利支天の祠に詣ずるに先立ちて、その太さ三拱にも余りぬべき一本杉の前を過ぐる時、ふと今の世にも「丑の時詣」なるものありて、怨ある男を咒う嫉妬深き婦人等の、此処に詣で来て、この杉に釘を打つよし、人に聞きしを懐出でたり。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は万々｜然ることのあるべからざる理をもて説諭すれども、渠は常に戦々兢々として楽まざりしを、密かに持余せしが、今｜眼前一本杉の五寸釘を見るに及びて予は思半ばに過ぎたり。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見る間に婦人は一本杉の下に立寄りたり。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本杉に至れば、金筆頭岩のみを見る。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "屏風岩の右手には、一本杉も見え、金※の一角も見え、上州の平原も見ゆ。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘脈、金洞の東面に延び、金※の筆頭岩に接し、そこに一本杉の峠を起せり。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが中の嶽の一本杉と云うので、われわれは既に第二の金洞山に踏み入っていたのです。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから第三の金※山は真正面に見えるのだそうですが、この時に霧はいよいよ深くなって来て、正面の山どころか、自分が今立っている所の一本杉の大樹さえも、半分から上は消えるように隠れてしまって、枝をひろげた梢は雲に駕る妖怪のように、不思議な形をしてただ朦朧と宙に泛かんでいるばかりです。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（下）　一本杉の下には金洞舎という家があります。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "くだりの路も途中からはもと来た路と一つになって、私たちはふたたび一本杉の金洞舎の前に出たのです。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも僕は根よく追っかけて、とうとう一本杉の茶屋の前まで来たが、赤座の姿はどうしても見付からないので、僕の不安はいよいよ大きくなった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべの一本杉の茶屋まで行きつく間、我れわれは木立ちの奥まで隈なく探してあるいたが、どこにも彼の姿は見付からなかった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夕ぐれ、山の上の一本杉でかなかな蝉が鳴くと、その鋭い声は岡を越え、野を越えて、遠く一里下の人里にまで聞えるといひます。",
              "citation": {
                "source": "茶立虫",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃寺に一夜をあかした時、庭前の一本杉の下でカッポレを躍るものがあったらこのカッポレは非常に物凄かろう。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "野中の一本杉の私は、せめてこんな楽しみでもなければやりきれない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅はいゝ、野中の一本杉の私は、せめてこんな楽みでもなければやりきれない。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まいてあの羊飼のわらんべなどは、夕日が山かげに沈まうず時は、必村はづれの一本杉にたかだかとよぢのぼつて、下につどうた羊のむれも忘れたやうに、「れぷろぼす」恋しや、山を越えてどち行つたと、かなしげな声で呼びつづけた。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると今度は「じゃ益さん、野中の一本杉をやって御覧よ」と誰かが云い出す。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ野中の一本杉の所まで参りますと……」　益さんはそれでもにやにやして応じない。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はとうとう益さんの野中の一本杉というものを聴かずにしまった。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕立を野中に避けて、頼と思う一本杉をありがたしと梢を見れば稲妻がさす。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、其木が一本松・一本杉と言ふ様に注意を惹き易い場合はとにかく、さもないと折角標山を定めた為に、雷避けが雷招きになつて、思はぬ辺りに神の降臨を見ることになると困るから、茲に神にとつてはよりしろ、人間から言へばをぎしろの必要は起るのである。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにいるか知っているなら、おしえてくれたまえ」「茨木なら、妙義山の一本杉の近くの金洞舎ってところにいるわ」「へんなことを聞くようだけど、どうして茨木なんか、知ってるんだい」「それはそうだろうじゃ、ありませんの。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　一本杉の金洞舎はすぐわかったが、茨木はこの月のはじめに、白雲山の奥ノ院に移ったということで、妙義町までひきかえして、社のうしろの登り口から、鶯鳴の滝のほうへぶらぶらと上って行った。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "野中の一本杉のような丹下左膳、親も妻子もない彼に、ああして忽然として現われ、親をもとめる可憐な心から、仮りにも自分を父と呼ぶチョビ安は、いつのまにか、まるで実の子のような気がして、ならないのでした。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は農家の一少年として生まれ、だれに頼ることなく、野中の一本杉として生きてきた。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは妻と二本杉というところだが、二人は一体なのだからやはり一本杉といわせてもらおう。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれからもこの一本杉は伸びなければならぬ。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
