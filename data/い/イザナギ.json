[
  {
    "uuid": "7cccb838-2003-5c10-b896-6be34fe36a99",
    "entry": "伊邪那岐",
    "reading": {
      "primary": "いざなぎ",
      "alternatives": [
        "いざなき",
        "イザナギ"
      ],
      "is_heteronym": false
