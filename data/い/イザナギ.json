    "definitions": [
      {
        "index": 1,
        "gloss": "Izanagi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "伊邪那岐命は、伊邪那美命と共に国生み神話の中心的な役割を担った創造神です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本神話において、伊邪那岐は黄泉の国で変わり果てた妻の姿を見て逃げ帰ったとされています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "穢れを清めるために禊を行った伊邪那岐の体から、天照大御神をはじめとする三貴子が生まれました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古事記には、伊邪那岐が十拳剣で火之迦具土神を斬り殺したという記述が見られます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伊邪那岐と伊邪那美の神話は、日本の創世神話や死生観の根源として深く研究されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "筑紫の日向の橘の小門の阿波岐原で禊祓を行った伊邪那岐は、多くの神々を生み出しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "僕は、――たとえば、伊邪那岐の尊となって――死人のにおいがする薄暗い地獄の勝手口まで、女を追っているような気がして、家に帰った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊邪那岐命、伊邪那美命と天の御柱をめぐりてみあひませしときに、伊邪那美命まづ、あなにやし愛男をとのりたまひて、くみどに興してうみたまへる御子のふさはしからざりしも、たゞごとにはあらざりけり。",
              "citation": {
                "source": "日月喩",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ獨り空に殘りし霞かな　女體山の上には、伊邪那美命を祭り、男體山の上には伊邪那岐命を祭る。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古史成文』は、凡ての源泉徴証を、比較綜合して、記して曰く、爾に神伊邪那岐、伊邪那美命、妹妖二柱嫁き給いて、国の八十国、島の八十島を生み竟え、八百万の神を生給い、亦た悉く万物を生給う。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然して後に、伊邪那岐命詔く、吾生めりし国は、唯朝霧のみ、薫り満てる哉と詔いて、吹き撥わせる御気に成坐せる神の名は、志那都比古神、次に志那都比売神、亦た志那斗弁神と申す。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾に、伊邪那岐命｜詔給わく、愛しき我が那邇妹の命や、子の一木に易えつるかもと詔給いて、御枕方に匍匐い、御足方に匍匐いて、哭給う。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊邪那岐命｜御佩かせる十拳剱を抜きて、其子迦具土神の御頸を斬り給う。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち殿騰戸より出で向えます時に、伊邪那岐命語らい給わく、愛しき我が那邇妹の命、吾と汝と作れりし国、未だ作り竟えずあれば、還りまさねと詔給りき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に伊邪那岐命見｜畏みて、逃げ返り坐す時に、其妹伊邪那美命、吾に辱見せ給いつと申し給いて、やがて泉津醜女を遣わして、追わしめき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾に伊邪那岐命詔給わく、愛しき我が那邇妹の命、汝しかし給わば、吾はや一日に千五百産屋立てなと詔給いき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古事記』に曰く、是に伊邪那岐命、見かしこみて逃げ返ります時に、其｜妹伊邪那美命、吾に辱見せ給いつと申給いて、即ち予母都志許売を遣して追わしめき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾に伊邪那岐命｜黒御鬘を取りて、投げ棄て給いしかば、乃ち蒲の子生りき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しその鬼が島征伐の一条は、伊邪那岐神の桃を投げて、黄泉軍を撃返せしと共に、支那古代の桃に関する信仰に基くものなり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の騒ぎには、通船会社の船長が三人謝罪の為にやって来て、問題は屡々国体観念に及ぶし、遂には哀れにも、「伊邪那岐、伊邪那美」両｜尊までが引合いに出されると云う結果を見るに至った。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎと、甲賀三郎と。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎ・いざなみと、近江の国と。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎの命の据ゑられた千引きの岩も、底の国への道を中絶えにすることが出来なかつた。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎの命の鎮りますひのわかみや（日少宮）は、実在の近江の地から、逆に天上の地を捏ちあげたので、書紀頃の幼稚な神学者の合理癖の手が見える様である。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、天照大神などを始め、とてつもない程沢山の神々の親神であるいざなぎのみこと・いざなみのみことの最初にお生みになつたのが、此淡島神で、次が有名な蛭子神であつた。",
              "citation": {
                "source": "雛祭りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎの禊ぎに先だって、よもつひら坂に現れて「白す言」あった菊理媛（日本紀一書）は、みぬま類の神ではないか。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎの尊ばかりの行動として伝えたため、この神は陰の者になったのであろう。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎの命が、あれほどに困らされた伝えのあるのも、祖先の久しい戦争生活から来た印象である。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎの命檍原で祓への為にすでる間に、神々は、すで水の霊力で生れたことになる。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本紀を見ると、いざなぎ・いざなみの二神が、天御柱をみたてゝ、八尋殿を造られたとある。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なもので、柱さへ立てば、家が建つたと同じに見立てたので、いざなぎ・いざなみ二神の章の、天御柱をみたてたと言ふのも、此意味である。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚する為に、家を建てるのは、いざなぎ・いざなみ二神の故事によつて、柱を廻るのに、傚うたのである。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎ・いざなみ二神が、神々をお産みになつた後、大八島をお産みになつた、と言ふことは、信仰だからいゝのだ、とだけでは済まされないので、説明するのに、ちよつと困る話である。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかまのはらにかむづまります、すめらかむつかむろぎかむろみのみこともちて、すめみおやかむいざなぎのみこと、つくしのひむかのたちばなのをどのあはぎはらに、みそぎほらひたまふときに……　八百万の神たちを念じておいて、それから次に、塩を撒きながら、「心身清浄の祓」を唱えました。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄泉の国に愛妻を見棄てゝ、遁れ帰られたいざなぎの命は、後から追ひすがる黄泉醜女をはらふ為に、桃の実を三つとりちぎつて、待ち受けて、投げつけた。",
              "citation": {
                "source": "桃の伝説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那側の材料は別として、いざなぎの命の話が、桃に対する信仰の起原の説明にはなつて居ない。",
              "citation": {
                "source": "桃の伝説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
