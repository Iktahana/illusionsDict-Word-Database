[
  {
    "uuid": "15903b99-01ca-5aaf-b039-e81f6ad8998e",
    "entry": "犬死に",
    "reading": {
      "primary": "いぬじに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
