      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wincing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上司の厳しい叱責に、若手社員は皆、畏縮してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然の雷鳴に、幼い子供は身を畏縮させて母親にしがみついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経験豊富なベテラン棋士を前に、新人の彼は畏縮してしまい、本来の力を出せなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の放つ威圧感に、周囲の人間は自然と畏縮する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「そんなに畏縮することはない。君の意見も聞かせてくれ。」と先輩は優しく声をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "市場の冷え込みに、企業は投資を畏縮させる傾向にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "圧倒的な存在感を放つ強敵を前に、選手たちは一瞬畏縮したように見えたが、すぐに気を取り直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何しろ冷ツこくなつた人間ばかり扱ツてゐる故か、人間が因業に一酷に出來てゐて、一度｜此うと謂出したら、首がして突ツ立ツてゐるのであるから、學生等は、畏縮といふよりは些か辟易の體で逡巡してゐる。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の汚い骨も、こんな小綺麗な墓地の片隅に埋められたら、死後の救いがあるかも知れないと、ひそかに甘い空想をした日も無いではなかったが、今はもう、気持が畏縮してしまって、そんな空想など雲散霧消した。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表情はますます私を畏縮させたが、續いて彼が何かを云はうとした時、反對に彼の詞を遮つて私は訊ねた。",
              "citation": {
                "source": "霧の夜に",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としめやかに朱唇が動く、と花が囁くやうなのに、恍惚して我を忘れる雪枝より、飛騨の国の住人以つての外畏縮に及んで、「南無三宝、あやまり果てた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの派手な参詣ぶりに畏縮して明石の船が浪速のほうへ行ってしまったことも惟光が告げた。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの返事は男子すらも畏縮させたに違いなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お勢と諍論ッて家を出た――叔父が聞いたら、さぞ心持を悪くするだろうなア……」と歩きながら徐々畏縮だした。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを要するに、お勢の病は外から来たばかりではなく、内からも発したので、文三に感染れて少し畏縮た血気が今外界の刺激を受けて一時に暴れだし、理性の口をも閉じ、認識の眼を眩ませて、おそろしい力を以て、さまざまの醜態に奮見するので有ろう。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学士の姿を見て此の室の住者は、全く畏縮して余の背後へ小さく隠れた。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八一年三月一日、全く予告なく突発した事情の下に帝位に即かせられることになった酒飲みのアレキサンドル三世は、有名なポヴェドノスツェフと共に極端な反動的政治をはじめ、そのために従来ナロードニキの社会的支柱であったブルジョア自由主義者は甚しく畏縮して来た。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ政論派の起こるは偶然に起こるものにあらず、必ず時弊に応じて起こるを常とす、当時なお封建の余勢を承け三百年太平の後に当たり、人心散乱公同の思想なく、民風卑屈自立の気象なし、全国はただ依頼心と畏縮心とをもって充満せられたり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸がキューッと締め付けられ、ハッ、ハッ、ハッ、ハッと喘ぎはするがそれは畏縮した喘ぎである。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術はために進んだとしても、科学と政治思想はために畏縮した。",
              "citation": {
                "source": "東西相触れて",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭でこそかれを強圧するものがあり、畏縮させるものがあったとはいえ、一たび外に出れば、そこには自由な小天地がかれをここちよく迎えてくれた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の強大に畏縮し、圓滑を主として、曲げて彼の意に順從する時は、輕侮を招き、好親却て破れ、終に彼の制を受るに至らん。",
              "citation": {
                "source": "遺訓",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には下層の新平民に克くある愚鈍な目付を為乍ら是方を振返るもあり、中には畏縮た、兢々とした様子して盗むやうに客を眺めるもある。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカモ大筋ニ臨ムニ※テ私情ニ拘ハリ公義ヲ失フニ非ラザレバ則畏縮退避シテ活ヲ草間ニ窃ムモノ往往ニシテアリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評家の妄評は彼を畏縮させずに彼を膨脹させた。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はむしろ先生の態度に畏縮して、先へ進む気が起らなかったのである。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔が――実はその顔で全く畏縮してしまった。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際自分が眼を上げて、囲炉裏のぐるりに胡坐をかいて並んだ連中を見渡した時には、遠慮に畏縮が手伝って、七分方でき上った笑いを急に崩したと云う自覚は無論なかった。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は恐ろしい空の中で、黒い電光が擦れ合って、互に黒い針に似たものを隙間なく出しながら、この暗さを大きな音の中に維持しているのだと想像し、かつその想像の前に畏縮した。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "素子の苦痛は伸子を畏縮させた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を真直に保ち、手足が規則正しく動くにつれて、等しい歩調で、ちょうど車の上で動かされている人形のように歩く姿は、この四周の畏縮しつくしている万物の中に、いかほど厳からしく見えたことだろう？",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のような次第であるから、大地震に出會つたなら、最初の二三十秒間、場合によつては一分間位は、その位置環境によつては畏縮せざるを得ないこともあらう。",
              "citation": {
                "source": "地震の話",
                "author": "今村明恒",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論崩壞の虞れなき家屋の内にゐるとか、或は廣場など安全な場所に居合せたなら畏縮する程のこともないであらう。",
              "citation": {
                "source": "地震の話",
                "author": "今村明恒",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで私は何時でも尊大にかまへられると、畏縮してしまふのが癖だつた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "常識ある万人の心が、その母と子とを気の毒と思う場合、その人が処罰の対象となったということで、人民はその人が気の毒だし、災難をうけた方が罪になるとは、さてこわいと、畏縮して、女子供の外出がへると思いつかれでもしたのだろうか。",
              "citation": {
                "source": "石を投ぐるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正造は東京に在ってそれを知ったが、沿岸の運動者がために畏縮することを慮って心を痛めた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "長所を伸ばす教育が弱い人間、普通よりも劣る人間には一番大切ですダメな人間、ダメなやつと云はれればなおさらいしゅくして伸びなくひがみます。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
