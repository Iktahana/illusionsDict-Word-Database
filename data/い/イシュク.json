[
  {
    "uuid": "e4267445-dbfa-578c-887a-c8d8eb5314cd",
    "entry": "畏縮",
    "reading": {
      "primary": "いしゅく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
