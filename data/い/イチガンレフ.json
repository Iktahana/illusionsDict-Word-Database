        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末の撮影旅行に向けて、彼は最新の一眼レフカメラを物色していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "結婚式では、被写体の表情を逃さず捉えるために、プロカメラマンは高性能な一眼レフを複数台用意する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現地特派員は、事件現場の緊迫した様子を記録するため、信頼性の高い一眼レフカメラを携えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいモデルの一眼レフは、暗所性能が飛躍的に向上し、夜景撮影の可能性を広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、この風景、一眼レフで撮ったらもっと綺麗だったろうなぁ。」と友人はため息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "野鳥観察愛好家は、遠くの野鳥の姿を鮮明に捉えるため、望遠レンズを備えた一眼レフを使用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スマートフォンの普及で手軽に写真が撮れるようになったが、本格的な表現を求めるなら、やはり一眼レフの描写力には一日の長がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一眼レフのカメラとフィルム、それに飲食物もだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の寝室に使っている予備の寝室へいき、テーブルの上に出してあった一眼レフにフィルムを装填した。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウクレレのかたわらに片膝をついた僕は、一眼レフのファインダーごしに、真上からウクレレを見下ろした。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような状態を、三脚につけた一眼レフのセルフ・タイマーで撮ればいい。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "望遠レンズをつけた一眼レフ・カメラを三脚に取り付け、チューブ波に焦点を合わせた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストラップで右手に下げていた一眼レフを、首にかけなおした。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私もそう思うわ」　歩み寄って手をのばした恵子に、彼は一眼レフを渡した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一眼レフを彼に渡し、恵子はガラス戸を開いた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルには一眼レフが置いてあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷がさまざまな角度で額を支え、彼女が一眼レフのファインダーごしに絵を見た。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その写真を僕は一眼レフのファインダー視野でいろんなふうにトリミングしながら、複写遊びをした。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「写真を撮るんだ」　小川が、縁側の前に一眼レフを三脚に取りつけていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
