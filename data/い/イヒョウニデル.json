[
  {
    "uuid": "2e6aab65-1664-5f4e-a6d3-bd22a4136d7e",
    "entry": "意表に出る",
    "reading": {
      "primary": "いひょうにでる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-一段"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to take (someone) by surprise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "敵は我々の意表に出て、側面から攻撃してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の質問は、いつも私の意表に出るものばかりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の突然の離婚発表は、友人たちの意表に出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "内川は人の意表に出る男だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の蓋あけに出くわしたその男の相手に、何か意表に出る行動がしたくてたまらなくなったのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "意表に出るその働きは水際立って効を奏した。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命といつてみたり機会といつてみたり、偶然といつてみたり、およそ意表に出る「時」の持つ魅力――不安でも、好奇でも、驚異でもあるものが、人間生活の中にこと新らしく思はれて来たりする。",
              "citation": {
                "source": "時",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の前でちょっと生意気な素振りをする者があると、彼はいつも相手の意表に出る乱暴を加えてタタキ伏せた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ日本人の、しかも女を派遣して、意表に出る策略を執ったならば却って安全かも知れぬという説が多数を制しましたために、コンドル首領も不承不承に承知したものと考えられます。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等……紫のハンカチを相印とする、Ｊ・Ｉ・Ｃの中の美人の一団は、二年｜前から私一人を目標にして、人の意表に出る素晴しい方法で私を片付けるべく、念入りな計画を立てて来たのだ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生自身の最も好まれる、人の意表に出る興味が躍然として現れてゐる。",
              "citation": {
                "source": "貝殼追放",
                "author": "泉鏡花先生と里見※さん",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、どうかして一番諸子の意表に出る進歩がして見たく、それには古人の句集を読むのが好からうと思ひ、其頃諸子仲間で猿蓑を貴んで居ることを知つて居たから、内々之を研究した。",
              "citation": {
                "source": "鳴雪句集",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其叙景の歌とても、宴遊の即景に祝言を託する様なものか、人の意表に出る様な誇張や、言ひ廻しで、興趣の嵐を起して、当座の人の心を捲き込んで行くと言ふ風なものであつた。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう謂つた書き方にあふと、読者は正直に、自分の小説よりも、作者の小説の意表に出る点を感じるのではないか。",
              "citation": {
                "source": "山の音を聴きながら",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代の知性は冷やかに死後の再会というようなことを否定するであろうが、この世界をこのアクチュアルな世界すなわち娑婆世界のみに限るのは絶対の根拠はなく、それがどのような仕組みに構成されているかということは恐らく人知の意表に出るようなことがありはしないか。",
              "citation": {
                "source": "人生における離合について",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌物語においては、如何にも真実らしく感じる所から、自然悲劇的な内容を持つものが多くなつて行くが、諺物語においては、次第に周知の伝承を避け、而も意表に出るを努める所から、嘘話としての効果をねらふ様になり、喜劇的な不安な結末を作る方に傾くのである。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほかにも泰文には人の意表に出るような奇怪な振舞が多かった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とわたくしは重ねて否定したが、しかし人生には意表に出る事件がないとも限らぬから、わたくしは帚葉山人が言った謎のような言葉を、そのまま茲に識して置くのである。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご懇意のはずでございますよ」　若い武士の山県紋也にとっては女のいうことが何から何まで意表に出るように思われた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにも人の意表に出るような行動が多かった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品は、仁清の仁清たる作風の基調をなす美の端厳な燃焼そのものからは少しかけはなれた性質のものではあるが、そこにまた仁清特有の人の意表に出る実意の一分相が看て取れるではないか。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらにとっては、大河は、最初の朝の板木一件以来、いわば、いい意味での一種の変人であり、何かしら人の意表に出るような親切をやって喜ぶ性質の人であった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで無論読者の意表に出るくらゐな構想の奔放はあつてほしいものだ。",
              "citation": {
                "source": "探偵小説小論",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し頭が痛い」「何だか嫂が、今日は君が休むそうだから留守を君に頼んでくれと云っておいたぜ」「そうか」清三はちょっと微笑して見せた、心の中では康子の人の意表に出る態度がはっきり分かった。",
              "citation": {
                "source": "須磨寺附近",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこのようにして、その考えが解きほぐされその体も常態に復して、そこで始めて試み、捉え、そして相手の意表に出ることもできるにいたって、始めて、さっぱりと、このわずらいから癒された。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一彼らがその中の何ごとかをかぎつけると、立ちどころにその考えを変えてしまい、彼らの意表に出るのを面白がった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば和泉式部のごときは伝説かも知れないが、いつでも人の意表に出るような応酬をしていたように言われている。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞くときは、いつも何か人の意表に出るような事業をきっとやっている。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
