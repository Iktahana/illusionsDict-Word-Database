        "examples": {
          "standard": [
            {
              "text": "公正証書遺言とするため、彼は公証役場へ遺言証書を持参した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遺言証書は、亡くなった父の遺品の中から弁護士によって発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "故人の明確な意思が、その遺言証書には細部にわたって記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "筆跡鑑定の結果、遺言証書の有効性が争われることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "将来のためにも、専門家と相談して遺言証書を作成することをお勧めします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遺言証書がなかったため、遺産分割協議は難航した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遺言証書は、紛失や改ざんを防ぐため、厳重に保管されるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
