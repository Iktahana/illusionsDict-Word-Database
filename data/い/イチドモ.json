[
  {
    "uuid": "8d11d9dc-8be7-5f51-b3dc-6e999b91a5d1",
    "entry": "一度も",
    "reading": {
      "primary": "いちども",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
