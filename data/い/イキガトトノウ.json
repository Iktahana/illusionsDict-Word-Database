        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "マラソンを完走し、ようやく息が整ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "階段を駆け上がった後、数分間立ち止まって息を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "驚きのニュースを聞いて動揺したが、深呼吸をしてなんとか息を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンテーションの直前、深々と息を吸い込み、気持ちを落ち着けて息を整える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "激しい議論の後、一旦休憩を挟んで各自が息を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "頂上に着くと、彼女はしばらく立ち止まり、高山病で乱れた息を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合終了のホイッスルが鳴り、選手たちは肩で息をしながらも、徐々に息が整っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
