        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "閉鎖的な村にも、都会の新しい文化の息吹が感じられるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "春の訪れとともに、植物たちが一斉に生命の息吹を吹き返す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプロジェクトには、若い世代の斬新な息吹が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "廃墟だった工場跡地に、新たな商業施設の息吹が生まれつつある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
