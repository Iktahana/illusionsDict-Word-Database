[
  {
    "uuid": "500cc7ee-ee5e-5a63-b02c-d67faa34adb9",
    "entry": "息吹",
    "reading": {
      "primary": "いぶき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
