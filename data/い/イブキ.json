      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "breath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒い朝、彼の口から白い息吹が漏れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深呼吸すると、新鮮な空気の息吹が肺を満たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤ちゃんの弱い息吹を感じ、命の尊さを思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "故に、芸術とは、興味が、笑ひといふ自然的作品よりも、作品といふ人力の息吹きのかゝつたものを作り出すためには、興味そのものの内部に、生活人よりも格段と広い世界を有さねばならぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いかにも、「廷臣とし、軍人とし、政治家として夙に盛名ある」ラロシフコー公爵その人の息吹が感ぜられる尊嚴盛大の文章である。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんだ空は息吹がかかったように、サッと曇って、今までどこにいたろうと思われる霧がかかる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は思慮分別も融けるような男の息吹きを身体に感じた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩手山巓外輪山の夜明け方、　　　　息吹きも白み競ひ立ち、三十三の石神に、　　　　　米を注ぎて奔り行く。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、聖霊の息吹きを受けて、つめたい花びらをいちまい胸の中に宿したような気持ち。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のツホウホー、人魂が息吹をするとかいふ聲に、藍暗、紫色を帶して、のりすれ、のりほせのないのは木菟で。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、この傘を大開きに開く、鼻を嘯き、息吹きを放ち、毒を嘯いて、「取て噛もう、取て噛もう。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃及のカタコンブから掘出した死蝋であるのか、西蔵の洞窟から運び出した乾酪の屍体であるのか、永くいのちの息吹きを絶った一つの物質である。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそは桂子自身の生命が、更に桂子の生命を支へ上げんとする健気な力、そして永遠に新しき息吹である。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはあなた方は作家の手からでなく、作家の口から出て来る息吹きのこもった言葉をきくであろう。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、この美しい晶玉になって、照らしよくなった骨も、それ自体、氷よりも冷たく鉄よりも硬くなっているのに、いのちの息吹き返さすその香油が何物であるか何処にあるのか、私の中なる母は、いま一生懸命考えているところです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、白紙に戻って、はじめて虚無の強さよりの「可能性の文学」の創造が可能になり、小説本来の面白さというものが近代の息吹をもって日本の文壇に生れるのではあるまいか。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややありて、息吹のゆめもやはらかに、盲ひし空をうちあふぎ、管かたぶけて吹きいづる石鹸の玉の泡のいろひとつびとつに円らかに紅みてのぼる、これやかの若くいみじき血のにほひ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ過ぎて、神ながら身は新らし、ここ過ぎて、我が息吹蘇らむ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼アイヌ、眉毛かがやき、白き髯胸にかき垂り、厳かしきアツシシ、マキリ持ち、研ぎ、あぐらゐ、真夜なす眼の窩のアイヌ、今は善し、オンコ削ると息長に息吹き沈み、恍れ、遊び、心足らふと、そのオンコ、たらりたらりと削りけるかも。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづもれよ、昼間嵐、現ながら、ほのぼのと雲は立ち、神と人｜息吹きかよふ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづもれよ、晝間嵐、現ながら、ほのぼのと雲は立ち、神と人｜息吹きかよふ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼アイヌ、眉毛かがやき、白き髯胸にかき垂り、厳かしきアツシシ、マキリ持ち、研ぎ、あぐらゐ、夜なす眼の窩のアイヌ、今は善し、オンコ削ると、息長に息吹き沈み、恍れ遊び、心足らふと、そのオンコ、たらりたらりと削りけるかも。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "利彦氏の顔は見る見る汗と涙にまみれて、肩は大浪を打ち、息は嵐のように息吹き初める。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそう」　というソノ息吹きの臭いこと。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日死んだバークリも私と同じ中隊の軍曹で、そして連隊の華、ああ、唇に息吹き持つなかでもいちばんの美女、それがナンシィ・ディヴォイ、軍旗軍曹の娘なのだ。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズと私は砂が多く広い道を歩きながら、新鮮な朝の空気を吸い込み、小鳥の音楽や春の息吹を楽しむ。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "がしだいしだいに――ごくゆっくりと――言いようのない嫌悪の情をもってその猫を見るようになり、悪疫の息吹から逃げるように、その忌むべき存在から無言のままで逃げ出すようになった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の感じていることのまあ全部ではないとしてもその大部分は、この部屋の陰気な家具――吹きつのってくる嵐の息吹に吹きあおられて、ときどき壁の上をゆらゆらと揺れ、寝台の飾りのあたりで不安そうにさらさらと音をたてている、黒ずんだぼろぼろの壁掛け――の人を迷わすような影響によるものだと無理に信じようとした。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし完全に穴を抜けきるその日まで、私は〈もう一人の私〉の息吹をはっきりと感じとることがありませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "古今東西人｜毎にかかる癖ありや否やを知らねど、牛が道中で他の牛の小便に逢わば必ず嗅いで後鼻息吹き、猫犬が自分の糞尿を尋ねて垂れ加え、また諺に紀州人の伴小便などもいわば天禀人にも獣畜類似の癖あるのが本当か。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、恨みある春の夜のよはのあらしに熱情の焔な消しそ、木がくれにのがれて急ぐ佐保姫が旅路を詛ふ蠱術の息吹とはかん火ぞ、これは。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日小野の　　　　逍遙に、ふるき小笛を　　　　拾ひきて、息吹きこめて　　　　なぐさむに、ふと吾胸の　　　　ゆるぎつる。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――蛇のとぐろを香匐ひぬ、苦熱の息吹。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
