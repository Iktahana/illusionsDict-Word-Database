        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さらに入れ込むうちに、首まで泥まみれになっている日本語処理のクソッタレ仕事をマシンに預けられるのではないかと期待し始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターに入れ込めば入れ込むほど、タイプライターを真似た現在のマシンの在り方が骨身に染み付いて、これ以外の可能性が見えなくなるということだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "伽話にある「舌切雀」の葛籠にいかなるものが潜在してあるかは、もらう人の与かるところでないようなものの、その根本を質せばもらう人が入れ込むのである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国人は袖口へハンケチを丸めて入れ込む風あり。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで幾つかの例において、牛痘を経過した人たちの腕に人痘試料を入れ込む前に、試料の状態について私の行った注意を述べた。",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            }
          ]
        }
