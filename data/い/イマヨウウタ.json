        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "平安時代の宴では、舞と共に今様歌が披露された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、古文書に残された今様歌を忠実に再現して歌い上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このCDには、現代の楽器で演奏された、美しい今様歌が収録されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史ドラマで、登場人物が切なく歌う今様歌が印象的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「駒の渡りの瓜作り、瓜を人にとられじと、守る夜あまたになりぬれば、瓜を枕につい寝たり」という今様歌がある、瓜を枕に野天の瓜畑で寝た風流はまことに羨ましい。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりリレーするんでしょう」　雅楽部の子供の合唱隊がおチビさんのハルモニュウムにひきずられながら金切声で今様歌をうたいだす。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで地上ではまだ今様歌がつづいている。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
