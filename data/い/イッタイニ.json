[
  {
    "uuid": "fa18a031-1b09-51f4-a45c-b81dc4393776",
    "entry": "一体に",
    "reading": {
      "primary": "いったいに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
