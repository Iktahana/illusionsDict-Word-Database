        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "知らぬ人が見たら祝いの酒宴とも見えるだろう。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の初節句、結婚の披露、還暦の祝い、そういう機会はすべて村のバッカスにささげられる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈凌ぎに飲食することは、前祝いのようで都合が悪かった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで常陸風土記によると一応はこうも事祝いでやった、「人民集賀、飲食富豊、代々無絶、日々弥栄、千秋万歳、遊楽不窮」と。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝庄屋の家の内部　祝いの酒宴である。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が慇懃に彼女に、　――お祝いしますよ、アダ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺の還暦の「お祝い」のことで帰っていてもそうなのである。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スパイは、僕等の結婚や、お祝いごとまでも妨害するのだ。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよという時にゃあ、俺だって馴染み甲斐に魚っ子の一尾も持ってお祝いに行こうと思っているんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "用材出しを手伝ったお祝いのしるしに、おみき（酒）を振る舞うのは一つの習慣だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、おめでとう、と私も不自然でなくお祝いの言葉を返す事が出来ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう百年ほど経って日本が紀元二千七百年の美しいお祝いをしている頃に、私の此の日記帳が、どこかの土蔵の隅から発見せられて、百年前の大事な日に、わが日本の主婦が、こんな生活をしていたという事がわかったら、すこしは歴史の参考になるかも知れない。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に何か祝いごとがあると、父は、十里はなれたＡという小都会から、四、五人の芸者を呼ぶ。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか、父の勲章祝いのときであった。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米寿の祝いに赤い胴着を着せられた老翁の姿を思い出した。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ成るとも判らぬこのやくざな仕事の首途を祝い、君とふたりでつつましく乾杯しよう。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農揚げといって、この秋のとり入れと、お米ごしらえがすっかり終わったお祝いに、どこの百姓家でもそうするのです。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちの花見酒で酔い潰れ、こっちのお祝い酒で奢り潰されてなあ」「太平楽なにも程がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタと差しで祝い酒を飲もうてや」「そりゃあ済まん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "国中の人間はこのお布告を見ると大騒ぎをして、お祝いの支度を始めました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犬は狸のようなつまらない汚い犬でしたが、いよいよお祝いの当日になりますと、金襴の着物を着て王様のお椅子に着いて、大勢の家来や人民にお目見得をさせる事になりました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして王宮にお伴をして、今一度この若い美しい王様のためにお祝いをしました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とてもにこにこして私のところへお礼に来たその少年に、合格のお祝いを言いながら私は、少年の受験当時の様子を詳しく尋ねました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族一同が心々の祝いものを贈る場合とします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはおのおの身分資力に応じて差別があるところに、祝いの真心が表れるので、差別あるこそ主人夫妻には平等な祝意が家族一同より感じられるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「坂の下祝いましょ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "拍子を取って、手を拍って、「坂の下祝いましょ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「山の峡は繁昌じゃ、」「洲の股もめでたいな、」「坂の下祝いましょ、」「地蔵菩薩祭れ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学へ入ると言う、その祝いだ、と云って、私を村田屋へ連出したのは、姉の旦那だ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから今夜はそのお祝いで親類はみな呼ばれました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
