        "examples": {
          "standard": [
            {
              "text": "来週の結婚式の準備で、新郎新婦の衣装合わせが行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "演劇の稽古の合間に、本番で着用する衣装合わせが行われ、役者たちの士気が高まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "成人式の前撮り撮影に向けて、美容室で振袖の衣装合わせを済ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "次のファッションショーのコンセプトに合わせ、スタイリストとモデルが綿密な衣装合わせを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもの七五三で、家族全員の和装の衣装合わせに時間がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社の創立記念パーティーのため、社員が各自、フォーマルな衣装合わせに余念がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "フォトウェディングの打ち合わせでは、撮影場所と時期に合わせてドレスの衣装合わせも同時に進められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
