          ],
          "literary": [
            {
              "text": "コンペイトウは露西亜語の名前だけれど、俺よりずっと不味いぞ。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "△行乞してゐると、村の餓鬼君がホイトウホイトウといふ、いつぞや敬治居に泊つたとき、坊ちやんが、「おぢさんはホイトウかの」といつて私達を微苦笑させたが、ホイトウはおもしろいな！",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、まっかなケイトウが、両側にずらりと並んで、おじぎをするよ。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは、見るもかわいらしいアラセイトウとカーネーションです。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイヘン　シヅカナ　ムラデ　イヌノ　ナキゴヱモ　キコエズ、イエイエノ　マドハ　ミナ　カタク　トザサレ、ガイトウニハ　ヒガ　トモツテ　ヰマセンデシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　ポストノ　ウシロニ　タツテ　ヰタ　ガイトウガ　カラ　カラト　ワラツテ、「ポストノ　カゲナラ、ポストノ　ウシロニ　コロガツテ　ヰル　ソノ　ブカツカウナノガ　サウヨ」ト　イヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アレハ　コノ　ワシノ　カゲサ」ト　ガイトウガ　イヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ガイトウノ　カゲナラ、ガイトウノ　ウシロニ　アル　ソノ　ヒヨロヒヨロシタノガ　サウダヨ」ト　ケイキキユウハ　イヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スズメト　ポストト　ガイトウハ、ケイキキユウト　マルイ　カゲヲ　ミクラベテ　ウラヤマシガリマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イトウで皆とわかれる時にも、じゃんじゃん飲んだよ。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はイトウ屋へ行つて先づ玩具の砂時計を購つてから酒場へ走つた。",
              "citation": {
                "source": "真夏の夜の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コンヤハンドレペイジチヨウジユウバクゲキキ五ダイトウチヤクシタ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "樽野は鴎丸の漁屋で、雨の日には夫々天に向つて舌を鳴らしながら酒宴を催しに集つて来る老若の、七郎丸、大々丸、鱗丸、三郎兵衛丸、潮吹丸、づくにゆう丸、鯖子丸、般若丸、サイトウ丸、源太郎兵衛丸などといふ連中と相知つたが、その酒宴の騒々しいことと云つたら素晴しい！",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ヤイトウの思出　母よ恋し八月十一日　晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通人の聴覚とベイトウベンの聴覚とを同一視するわけにはいかないのである。",
              "citation": {
                "source": "錯覚した小宇宙",
                "author": "――Our faith comes in moments;",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日あたりから、朝鮮人が来ると云う噂が立ち、センセンキョーキョー、地震のとき、春江ちゃんの行って居たサイトウさんのところでは、奥さんが死なれその良人、子供二人、姉妹たち、皆一緒に居る。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月廿日　曇、行程四里、正明市、かぎや（三〇・中）いや／＼歩いて、いや／＼ホイトウ、仙崎町三時間、正明市二時間、飯、米、煙、そしてそれだけ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "古市、人丸といふやうな村の街を行乞する、ホイトウはつらいね、といつたところで、さみしいねえひとり旅は。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日がグラモンの峰つづきに沈んで、ヴェイトウの街の灯がキラキラ光り初めるまで、船つきの太い杭に腰を下ろして、何を思うともなく、ぼんやりしていた、夕暮はさすがに寒い。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――カイトウオウトワボクセヨ、ホムラ」　電文は、「怪塔王と和睦せよ、帆村」というのであります。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・ツネコ・サイトウの陪食を仰せつかつてゐるんだから……。",
              "citation": {
                "source": "驟雨（一幕）",
