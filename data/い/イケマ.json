          "literary": [
            {
              "text": "『本を見る、いけません。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあなたの話、あなたの言葉、あなたの考でなければいけません』と常にいった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ家に本を読むばかり、いけません』と言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私死にますとも、泣く、決していけません。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どうも、このごろのジャーナリズムは、いけませんね。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつき経ち、ふたつき経って、そろそろ百日目がちかくなって来ても、私たちはだまって見ていなければいけません。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、何くわぬ顔してそれを読まなければいけません。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お笑いになっては、いけません。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に何も話題が無くていけません。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方に見せなければいけません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大隅君の上京を報告して、「どうも、あいつは、いけません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦笑なさっては、いけません。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく、何も送つて寄こしてはいけません」と書いてあつたので、私は實に不吉なものを感じて、ぎよつとしましたが、その葉書の隅に小さく「to see you 遠からず一緒に呑めます」と書かれてありました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は素早くそれを顏に塗らうとしたので兎は驚き、そんな事でこの藥の正體が暴露してはかなはぬと、狸の手を遮り、「あ、それはいけません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいま、葛原しげる氏の原稿を拜讀して、そんなに、嚴しいお叱りも無いので、狡猾の小文士は思はず、にやりと笑ひ、ありがたしと膝を崩さうとした、とたんに、いけませんでした。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梗概だけを述べますと、いやに理窟つぽくなつていけませんが、周樹人の仙臺に於ける日本人とのなつかしく美しい交遊に作者の主力を注ぐつもりであります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦笑なさつては、いけません。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌くる日は穂高岳に上るつもりで、朝｜夙く起きた、宿の女が「飯が出来やしたから、囲炉裏の傍でやって下せえ、いけましねえか」と、畏る畏る閾越しに伺いに来る、いいとも、と返辞して大囲炉裏の前に、蝋燭を立て、猟士や宿の人たちと、車座になって飯を済ます、準備も整って出かけると、雨になった。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、如何に、挙措を解放するにしても、常に或程度の収攬を、おのずから自分の上に忘れてはいけません。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかあさん、感情家だけではいけませんよ。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行っちゃいけませんよ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭助は太く疲れて禮服ぬぎも敢へず横に成るを、あれ貴郎お召物だけはお替へ遊ばせ、夫れではいけませぬと羽織をぬがせて、帶をも奧さま手づから解きて、糸織のなへたるにふらんねるを重ねし寐間着の小袖めさせかへ、いざ御就蓐と手をとりて助ければ、何其樣に醉ふては居ないと仰しやつて、滄浪ながら寐間へと入給ふ。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからは政の読書の邪魔などしてはいけません。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談言ってはいけません。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、病勢は変りなく、熱はなくなりましたが下痢は酷くおもゆとミルクでアゴ伸びるばかり（お粥をちょいと食うともういけません、情けない腹になりやがったものです）けれど懸命に頑張って居りますから此の手紙がそちらへ着く頃には（それが一ヶ月もかかるのでしたら）退院して本隊を追ッ掛けている筈です。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事をいっちゃあいけません。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）わたくしの申す詞は明瞭でないかも知れませんが、それは御勘弁あそばさなくてはいけません。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お動きなすつてはいけません。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
