[
  {
    "uuid": "d35aee1d-e79d-56be-9151-99c3a9b58222",
    "entry": "頂ける",
    "reading": {
      "primary": "いただける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
