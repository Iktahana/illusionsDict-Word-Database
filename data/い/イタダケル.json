            }
          ],
          "literary": [
            {
              "text": "判って頂ける言葉に苦しみます。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私という一人の人間が、真に感じたり想ったりしたことは、同じ人間である世のみな様に語って真実同感して頂けることと信じます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高きもの、第一義のものに対して、はっきりした目標を定めさして頂ける。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろそういう感情を沈澱させてその上に澄む生命の上水を汲まして頂ける美しさなのだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "懺悔をいたせば、悪い夢とあきらめて、思い直して頂けることもあろうかと思ったですが、いかにも取返しのつかんお身体にしたのじゃった、恥入ります。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは、何一つ世のためになるやうなことは出来なかつた、ほんとの能無しぢやから、この山の中に、こつそり暮させて頂けるさへ、有難いことと思つてをりますぢや。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから大概のことはみなさんから大目に見て頂けるらしい気がしますのよ。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは前陳の、予感があったという、それだけでも、うなずいて頂けると思います。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は参上して申述べ度きところでありますが、貴兄も一家の主人で子供ではなし、手紙で申してもききわけて頂けると信じ手紙で申します。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思うと、なんだか懐かしいような気がいたしまして、御飯もうまく頂けるのでございます。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしも、こんなことが許して頂けるんでしたら……私の月々頂くものを、半年分ほどまとめて、拝借できないでしょうか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が一杯でご飯頂けるかしら……」「随分歩いたから、ともかく落着きましょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、よろしければ屋敷内を案内して頂けるとありがたいのですが、カニンガムさん。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直のところ、この手紙は単に現状の概略をお伝えし、この件にご関心を持って頂けるか確認するためのものです。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "受けて頂けるなら、どうかランベリはチーズマン屋敷のファーガソンまでご電報を。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしらもどじょうにして頂けるかと思うと、豪儀に風流でござんす」　行く程にやがて南部の郷を出離れました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、女なら女同志、この苦しいことが分って頂けると思って、ようやく奥様にお会い出来て、お話しました。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のやうな狐でも生れ變つたやうになれば、斯うして社の番人をさせて頂けるのです。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月号に短歌をどつさり頂けることになつてゐます。",
              "citation": {
                "source": "編輯室より（一九一五年一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いうちに静かな処で一度会を開きたいとおもつてゐますが集まつて頂けるでせうかお茶でも飲んでしんみりと皆でお話したいと思ひます。",
              "citation": {
                "source": "編輯室より（一九一五年四月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "□この頃は頼まれないからなどゝ原稿をお書き下さらない向きもあるさうですが、私は原稿と云ふものは人にたのまれたからといつて書けるものでもないし頼まれないからいゝものが書けないつてこともないものだと思つてゐますのでどなたにかぎらず自信のあるいゝものが頂けるのをだまつて待つてゐるのです。",
              "citation": {
                "source": "編輯室より（一九一五年四月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "□哥津ちやんから何か頂ける筈でしたが今月は駄目でした来月号には屹度おかき下さるさうです。",
              "citation": {
                "source": "編輯室より（一九一四年一一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "だってこれでもう四日もはっていますけど、まだ頂ける葉が尽きはいたしませんものね。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな仕上げたら十四五圓頂けるでせう。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなえらい方に目をかけて頂けるなんて」　そして、真っ赤になってうろうろしている寿女の顔を、とんきょな眼つきで覗き込んだりした。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鳥の刺繍も、あたくし頂けるものとばかり思っていましたけれど、あれは、ほんとうによい記念になりましたのに……」　暗に、自分の所有に帰したい心を言ったのだけれど、師匠はききつけぬ容子で、やがて、言葉尠なに辞し去った。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "売って頂けるのなら、買いますがね。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「餘瀝　近事片々」（「正直ノオト」「春晝」「市井喧爭」「酒ぎらひ」「困惑の辯」「知らない人」「心の王者」「鬱屈禍」）　以上の五篇の創作にて、私のこれまで歩いて來た經過の、だいたいは、推察していただける事と思ふ。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「本郷ですの」「じゃ、三原橋まで着せていただけるわけですね。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あたしも、花輪で飾っていただけるの？",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
