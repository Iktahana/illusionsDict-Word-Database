        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "茨城県（いばらきけん）で生産される米は、品質が高いことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "台風の影響で、茨城県（いばらきけん）では一部地域に避難指示が出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末に、茨城県（いばらきけん）の偕楽園へ梅を見に行く計画を立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "米は茨城県の水戸の生れで、水泳の心得があるところから、投身すると見せかけてそのまま沖の方へ泳いで往った。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九三（明治二十六）年　四月、茨城県立水戸中学校に入学。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利の福井は遠いし、佐野のあら町は不便だし、ここらから若者が出かけるには、茨城県の古河か中田かに行くよりほかしかたがない。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の地方（茨城県の北隅）ではこの虫が飛ぶと、軈て初雪の降るしらせだと云つてをります。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "茨城県は遊廓がなかつたと思ふんだが。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警報は出ないが、しかし油断はならないぜ」　　　暁の空襲警報　茨城県｜湊町の鮪船が四｜艘、故郷の港を出て海上五百キロの沖に、夜明を待っていた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前五時十五分、北緯三十六度東経百四十三度ノ海上ニアル茨城県湊町在籍ノ鮪船第一｜大徳丸ハ有力ナルＳ国軍用機ノ大編隊ヲ発見ス、高度約二千メートル、進路ハ西南西。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は茨城県第○中学の助教諭、両親と小妹とをば、昨年の暮任地に呼び寄せて、余裕もない代り、別に窮迫もせぬ家庭を作つた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度衰亡史は云はずもの事、まだ一冊の著述さへなく、茨城県の片田舎で月給四十円の歴史科中等教員たる不甲斐なきギボンは、此時、此歴史的一大巨人の前におのづから頭の低るるを覚えた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸目の前に散ついてゐる連中を数へ立ててみても藤田組の阪仲輔氏、茨城県代議士の鈴木錠蔵氏、第百銀行の本庄重俊氏、大阪電灯の日高｜驥三｜郎氏、大阪アルカリの上領純一氏、日本車輛製造の原田勘七郎氏……といつたやうに、卒業証書の有無なぞもう気に懸けないでもいゝやうな顔触ばかりになつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十二年に茨城県の国生という村の相当の家に生れた長塚節は水戸中学を卒業しないうちに病弱で退学し『新小説』などに和歌を投稿しはじめた。",
              "citation": {
                "source": "「土」と当時の写実文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほかに茨城県｜稲田出生の小林三郎、これはまだ本の初めでありますから名前だけ記して置きます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "●昭和二十年八月二十三日　広島県佐伯郡八幡村田尾方より　茨城県高萩町南町深谷方　永井善次郎（佐々木基一）宛　ゴオルキイの幼年時代を読みかけて面白くなつたところで、その本も灰になりました。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "●昭和二十五年三月頃　武蔵野市吉祥寺二四〇六川崎方より　茨城県多賀郡大津町西町大津館内　永井善次郎宛　二三日寒さが烈しくて震へ上つてゐましたが今日は漸く春らしい天気にもどりました。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯原町は茨城県海岸の勝地である）",
              "citation": {
                "source": "おさんだいしよさま",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "「諸君、私は昨日、妻を実家の茨城県に帰して了つた。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は佐賀人でこれまでは茨城県令をしていて、水戸人とは気風が会っていたから、この度の転任と共に茨城県人を数人連れて来て、課長や重なる県官の椅子は段々とそれらに与えた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、髯を生やした男が、「一寸ごめん下さい」と言って出した名刺をみると、茨城県巡査という肩書があった。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近では、茨城県下の農家へ追いやられるとかの話があって、それを苦にしての自殺覚悟だったらしい。",
              "citation": {
                "source": "ものの影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿島の神は、現在茨城県鹿島郡鹿島町に鎮座する官幣大社鹿島神宮で、祭神は武甕槌命にまします。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たしかに、御婦人を、茨城県磯崎まで、送りとどけて参ります」「どうか、頼んだぞ」「それじゃ、サヨナラ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛国者よ頑張れ　千葉県を横断して、茨城県に通ずる幅の広い県道を、風を截って驀進する一台の幌自動車があった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茨城県磯崎に『狼』の巣を見付け出したのは、何といっても驚嘆すべきお手柄だ」草津大尉は、前方を注視しながら、独言のように云った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに一家は茨城県太田へ移ったという話だが、この太田は日立よりやや北方、海岸ではないが海に近く、あまり安全とは申されない。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年の初夏に東京へ戻つてきて、つづいて茨城県利根川べりの取手といふ町に住み、寒気に悲鳴をあげて小田原へ移り、留守中に家が洪水に流されて、再び東京へ住むやうになり、冬がきて、泥水にぬれたドテラを小田原のガランドウといふ友人のもとに残してきたのを取りに行つた。",
              "citation": {
                "source": "ぐうたら戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この方角です」　その方角というのは千葉県の香取神宮のそばをとおり、茨城県にはいって霞浦と北浦との中間をぬけ、水戸の東にあたる大洗海岸をつきぬけて、さらに日立鉱山から勿来関の方へつらなっていた。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私は兄妹を伴い巣離れの鮒を狙い、水之趣味社の人々と行を共にして、千葉県と茨城県にまたがる水郷地方へ釣遊を試みたことがある。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒烈、指の先が落ちさるような正月のある日、茨城県稲藪郡平田の新利根川へ寒鮒釣りに伴ったが、それでも海釣りよりも淡水で、糸と浮木の揺曳をながめる方が楽しめるという。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
