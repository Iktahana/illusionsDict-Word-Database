[
  {
    "uuid": "a1afd2d0-486c-5671-b73e-5cd8b8028967",
    "entry": "医学校",
    "reading": {
      "primary": "いがっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
