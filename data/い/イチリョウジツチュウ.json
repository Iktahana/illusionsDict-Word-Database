[
  {
    "uuid": "ae37e583-68d7-5f6b-89aa-7d6963094608",
    "entry": "一両日中",
    "reading": {
      "primary": "いちりょうじつちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "within the next couple of days",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一両日中に必要書類をすべて揃えておいてください。明後日の朝には取りに伺います」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サーバーのメンテナンス作業は順調に進んでおり、一両日中には完了する見込みとなっております。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一両日中にそちらから明確な返事がなければ、残念ながらこの縁談は白紙に戻させてもらうよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また出ますと云うたら宿は何処かと聞いたから一両日中に谷中の禅寺へ籠る事を話して暇を告げて門へ出た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムお気に入りの銀子が、手洗いの湯やタオルを盆に載せて持って行くと、ちょうど診察が済んだあとで、一両日中に入院でもするような話であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月号を今｜編輯していますので、一両日中に頂けますと何よりです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもしあなたが、滞在しておられるなら、一両日中にはあなたと一緒に出かけることが出来ると思いますが、――とにかく、この紙は置いて行って下さい。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご逗留なら、一両日中にはご同行しようかと思いましたが――では、この紙はあずからせてください。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一両日中は二人とも荷ほどきしたり、私物をうまく置こうと悩んだりしながら時間をとられたが、終えると徐々に腰も落ち着いてきて、新しい環境に慣れ始めていった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ではぼくは一両日中にその真鍮箱と紙との成り行きをご報告に参ります。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィルソンさん、一両日中には意見をお知らせしましょう。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄様も一両日中に手紙を差しあげるとか申して居りますが、何分御存じのとほり筆無精ですから当てにはなりません。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、一両日中にＲを案内して軍港見学の許可を乞ひ、鳥海、摩耶、愛宕その他を拝観する念願だつた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさうと、住居不定のまゝ今迄幾度かの召喚にも応ぜられなかつたゝめにいよいよ一両日中に解決しないと、汚名が決定するといふ瀬戸際に及んだので、彼は召喚状をふところにしてやはり母の許を訪れるより他はなかつた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の魔の海はここ一両日中の洋上である。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、一両日中に利用しようと心に決めている。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもう三月も暮れ、四月に入って学校の授業も一両日中には始まろうという日でした。",
              "citation": {
                "source": "三角形の恐怖",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、一両日中に、改めて、会合するとして、今日はこれまで――途中、気をつけて」　と、名越が立上ると共に、人々が、一斉に立って、身支度をした。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "調所の件で、延び延びになったが、一両日中には立たれよう。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽蔑と冷嘲の微笑を浮べて黙って彼の新生活の計画というものを聴いていたが、結局、「それでは仕度をさせて一両日中に遣ることにしましょう」と言うほかなかった。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親もモー一両日中に出て参ります。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「布哇の日系米人、騒がず」「墨西哥の首都附近に、叛軍迫る、一両日中に、クーデター起るものと予測さる」「英、仏両国は中立を宣言す」「注目すべきレニングラードの反政府運動」「中華民国も一と先ず中立宣言か」「上海に市街戦起る、○○師団、先ず火蓋を切る。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、この家の中からは、禁止品が山のように現れていますし、倉田組の倉庫はまだ開かれませんが、すでに封印されて、一両日中には白日のもとにさらされますよ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方どものうち申し合わせ、または鬮引き等にて元締、勘定、書記の三役を取りきめ、帳付け以下の儀は右三役にて相選み、人名一両日中に申し出づべきこと。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回磯五になりかわり、当若松屋が御督促申しあげ候以上、もはや猶予のお申し出には応じ難く、一両日中に即金二百五十両お払いくだされたく、伏して願い上げ申し候。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、いつぞやの染めのこともあるし、私は一両日中に発足して、ちょっと京表のほうへ行って来ようと思うが――」　いっているところへ、お駒ちゃんが帰って来たとみえて、店のほうできいきいいう声が聞こえた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴田　――ホントに、実に相済まんが、一両日中には本を売払って、いくらかでも持参するようにするから、今日のところは、ひとつ、お光さん――（くやしそうにお光を睨んで立っていたせい子が、プイと上手の扉から外へ出て行く）お光　駄目ですよ先生。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧版のサラが見つかりましたから一両日中にお送りいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで一両日中｜更に各位の十分御満足が頂ける豪華版で、慰問の夕を催すことに致しました。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一両日中に何分の解決があるはずだから安心されたい」樺山は危く内容の一端をもらしそうにして口をつぐんだ。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、中年の巡査部長から、「ひょっとしたら、一両日中に、あなたに請人になって貰って、大貫五郎を下げ渡すことになるかも知れませんから、連絡場所をはっきりして置いて下さい」　といわれた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "調査して一両日中に結果をお知らせします。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
