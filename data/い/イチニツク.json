    "definitions": [
      {
        "index": 1,
        "gloss": "to take one's place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "陸上選手たちがスタートラインに位置につくと、競技場の空気が一瞬で張り詰めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "指揮者の合図で、オーケストラのメンバーはそれぞれ楽器を手に位置についた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新入社員たちは、研修初日、緊張した面持ちでそれぞれのデスクに位置についた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警備員は、VIPの到着に備え、会場の各要所に位置についた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「さあ、みんな、並んで位置について！」先生の声に、子供たちは一斉に動き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発表会の準備が整い、いよいよプレゼンターがマイクの前に位置につく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観測隊は、極寒の環境下で、夜明け前に指定された観測地点に位置についた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "手術開始の合図とともに、執刀医と看護師たちはそれぞれの持ち場に位置についた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしそれも間もなく気持が馴れたらしく、文吉は毎朝いそ／＼として自分の位置につくようになりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代といふものは奇妙なもので、決してその時代の最大最高とは限らない人物が、時の流行の思潮によつて最大最高の位置につく。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディレッタントとかアマチュアというものは良い目があっても身を挺する信念も情熱も本当の自信もないのだから駄目で、芸術界に限らず、政界でも財界でも、真実その道、わが道に殉ずる情熱のないディレッタントや学者が責任ある位置につくことは最も不幸なことだと痛感した。",
              "citation": {
                "source": "日映の思い出",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はいつの間にかきちんと袴を着けてゐて、屍体が位置につくと、看護婦に命じて自分の上半身を起させた。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある人は他の人よりも多くの稟賦を恵まれ、そのより多くの力をもって指導者の位置につくことができる。",
              "citation": {
                "source": "世界の変革と芸術",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして皆なが各々元の位置につくや、競技が始まりました。",
              "citation": {
                "source": "愛ちやんの夢物語",
                "author": "ALICE'S ADVENTURES IN WONDERLAND.",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々は無論、現在に於て生活している、そこで現在は吾々の歴史的時間でどのような位置につくか。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの新しく編成された対立に際して、一方のものが他方のものに対して、もはや単に文化的にでもなく又道徳的にでもなく正に政治的・法律的・に統制を与える、という位置につくのである。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代というものは奇妙なもので、決してその時代の最大最高とは限らない人物が、時の流行の思潮によって最大最高の位置につく。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "権勢の位置につくかどうかは天命によって決する。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファラデーは「そんな責任の重い位置につくことを勧めてくれるな。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていゝ位置につくことになりました。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "箕作教授は、これは封建制度のある点が如何に莫迦げているかを示すいい例であり、同時に、これ等の人々が屡々、諦めと卑下とを以て奴僕の位置につく、辛抱強い態度を示し、また金を貰ったり借りたりするよりは、働いた方がいいと思っていることを、よく現しているといった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸将はおのおの揃いの服の家臣たちをつれて定めの位置につく。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは位置につくと、それを青眼にとって屹とこちらを見た。",
              "citation": {
                "source": "薯粥",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三之丞はおのれの位置につくと、おもむろに右肌を脱ぎ三ところ籐の弓をとって矢をつがえながら見やった。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金五郎は、責任ある位置につくことを堅く固辞したけれども、満場の推挙で、副組合長の役に据えられた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七　マリユスが与えし五フランの用途　マリユスは今や例の観測台の位置につくべき時だと思った。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、復讐の成るあかつきまで、仮に、一同のあるじの位置につくことを、曲げても、ご承諾ねがいまする」　すでにこのことは、梁党の下部から中堅にいたるまでの者が、当然のように、心で推していたことであり、ついに宋江も否みかねて、「――では、暫定的に、仮の首席として」　ということで、承認した。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ、検使以下、すべて、各※の位置につく。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
