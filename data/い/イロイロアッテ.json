[
  {
    "uuid": "477cdff8-e5e1-50ee-a10d-12720ce70b0e",
    "entry": "色々あって",
    "reading": {
      "primary": "いろいろあって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
