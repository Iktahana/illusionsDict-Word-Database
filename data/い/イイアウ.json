[
  {
    "uuid": "72f381e4-c80a-5085-a87b-f317a407144c",
    "entry": "言い合う",
    "reading": {
      "primary": "いいあう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
