    "definitions": [
      {
        "index": 1,
        "gloss": "escape",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "有毒ガスが貯蔵タンクから逸出し、住民に避難指示が出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工場から有害物質が逸出し、周辺環境への影響が懸念されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "機密情報が外部に逸出しないよう、データ管理は厳重に行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは技巧が跳躍して科学的真の圏外に逸出するためである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの所論はルクレチウスの哲学的の立場からすれば最も重要な役目を務めるものであろうが、今の私の立場から見るとあまりに現在の科学の領域を逸出した問題である事はやむを得ない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して「熱と空気の粒子」がほんのわずか逸出すると死んでしまう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後代の浮世絵の失敗の原因はこの領域を無理解に逸出した事にありはしないだろうか。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし此人は此の如き思想を有すると同時に、基督教の圈外に逸出して、破戒無慙の人として教界の齒せざる所となつた。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し苟も我が国土に脚を托するものにして誰れか能く国民性の圏外に逸出するものあらんや。",
              "citation": {
                "source": "国民性と文学",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "内に誠を藏し、血と涙とを湛へて、包むに奇才と博識とを以てし、或は磊落に、或は飄逸に、或は奇拔に、或は嚴正に、或は滑稽に、卓然として名利の※より逸出せる博士の人格は、今の世、絶えて其比を見ず。",
              "citation": {
                "source": "小日向臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは皆噴出の際に過大の速度を得たために、中心体の引力の余り利かなくなるほど遠い範囲に逸出してしまう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "中心体の外側の物質の大部分は、放出された微粒の速度のために、また一方高速度な分子の逸出のために空間に向かって飛散する、同時にこの旋転する円板は宇宙空間から輻射を受け取るために絶えず拡大される。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方では太陽から寒冷な星雲への輻射のためにこの量は不断に増加しているが、他方ではまた星雲ガス中で最大速度を有する分子がこのガス団塊から逸出し、そうしてそれがもっと密度の大きい物質集団の上に集積するために、不断に減少するのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんは、袖子のために人形までも自分で見立て、同じ丸善の二｜階にあった独逸出来の人形の中でも自分の気に入ったようなものを求めて、それを袖子にあてがった。",
              "citation": {
                "source": "伸び支度",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」此「而」の字の中の縦線二条が右辺に逸出してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか云ふ独逸出来の本に、化け物の画ばかり集めたのがある。",
              "citation": {
                "source": "支那の画",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻川博士がどんなふうにしてそれにかみつかれたのか、博士が発見されたときにはすでに瀕死の状態で、ただとりとめのない呪いの言葉をとぎれとぎれにうなっていただけで、よくわからないのだが、とにかく、当の毒蜘蛛は逸出していなかったので私はほっと安心した。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮殿の屋根が天日の陰となつて、神秘な人の威力の逸出を防ぐことなのでした。",
              "citation": {
                "source": "真間・蘆屋の昔がたり",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其たまの緒に限らず、霊物の逸出を禦ぐ為に結び下げて置くものを、ひもと言ふ。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう言ふ訣で、旅行者の歌には、妻の魂の逸出せぬ様にとの考へで、此ひもを問題にするものが多かつたのだ。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはひ詞は、霊魂の逸出を防いで安定させる詞である。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして其、不随意或は長い逸出などの、本人の為の凶事を意味する游離の場合に限つて、光りを放つものと見た様だ。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際かういふ小説の愛讀者は、木々さんの持説のやうに、推理が文學から逸出しても、問題にしない癖がついてゐる。",
              "citation": {
                "source": "人間惡の創造",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小坊主も暗黙の間の同情心が発揮されたと見えるが、白い紙でこしらえた社交関税は、すげなくお角親方の手から拒絶して、押しつけるその手先をかいくぐるようにして、早くも先に立って、お庭先の舞台の方へ逸出してしまいましたから、さすがの親方も、すっかりテラされてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程、父の厳しい性格を考へる度に、自分は反つて反対な方へ逸出して行つて、自由自在に泣いたり笑つたりしたいやうな、其様な思想を持つやうに成つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲンゲは元来支那の原産植物で、それが昔に我邦に渡来し今日では緑肥として一般に田面に播種せられているが、またそれからその種子が逸出して半野生の状態となっている処もある。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して反抗を続け、間隙を求めて逸出を図るの事は、また彼らにとって自己生存上の当然の要求であらねばならぬ。",
              "citation": {
                "source": "エタに対する圧迫の沿革",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的さえ正しければ、方便は問う所にあらずとの「ジェスイト」派の慣用手段は、不謹慎に不謹慎を増し、遂にはその目的すら教化の外に逸出し、漸く識者の厭う所となる。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしこれは少しく比較の埒外に逸出した言葉であるとしても、中ノ岳の南方に発源する栃木沢の上部の如きは、細いながらも二十余町の雪渓が続いているのを見た。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "周密なる観察から得た材料を綜合して見ると鼠賊の逸出するのには三つの行路がある。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これよりさきアインシュタインは光電池が、煌々と照らされて電子を逸出する作用を論じ、光量子は微粒子の如く、エネルギーである以上はその運動量も同時に考察せなければならぬ。",
              "citation": {
                "source": "物理學革新の一つの尖端",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸出する電子のエネルギーは物質より出るに必要なる仕事を、光量子から引き去つたものと均しと論じたが、この論鋒は正しく、又エッキス線に關するコムプトン（米人）效果に適用されて、光量子が恰も微粒子の如き行動を執れば自ら解決することゝなつた。",
              "citation": {
                "source": "物理學革新の一つの尖端",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの想念は、私から生ずるか、もしくは物象から逸出するや否や、必ず、あまりに強烈になる。",
              "citation": {
                "source": "芸術家の告白祈祷",
                "author": "ボードレール",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
