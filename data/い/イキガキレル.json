          ],
          "literary": [
            {
              "text": "肺の大さははじめもあとも同じですから、丁度同じころに息が切れるのです。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は息が切れるやうに喘いだ。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小県さん、私……息が切れる。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……水は、実は途中で、三度ぐらい飲んでいましたから、東海会社社長の顔を見ると斉しく、息が切れる、茶を一杯、といって、それから焼芋、蕎麦、大福の謎を掛けた。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "智慧の息が切れるわ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は息が切れるかと思ふほど、石畳に体を打ちつけたが、やがて起きあがつた。",
              "citation": {
                "source": "閾",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ年のせいだろう、少し歩くと息が切れるのだよ。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　するとさっきから退屈そうな顔をして、一同の顔を眺めていた民雄が、下からぐいぐい俊助の手をひっぱって、「辰子さんはね、あすこの梯子段を上っても、息が切れるんだとさ。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "節廻しの長い所を唱うと、息が切れる。",
              "citation": {
                "source": "仙人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ時彼は、ぐうつと胸一杯に空気を吸ひ込んで、もう息が切れる、という間髪に鋭くハッハッと叫んで一度に息を抜くことにしてゐた。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の暮れ方に、山上から瞰下ろした、牛小屋の下を過ぎて、どこまでも氷河に沿うて、南へ南へと登ってゆくと、急ではあるが、別に苦しい道ではないが、十二キロに余るリュックサックが、背負い慣れない肩をひいて、登りになると随分息が切れる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの右にはクラリモンドが飛ぶように馬を走らせ、わたしたちにおくれまいとして息が切れるほどに努力しているのを見ました。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の伏見屋まで坂を登るぐらいに、息が切れる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗が出る、息が切れる、心臓はドキンドキンと鳴る。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして梯子段を上り下りするだけで、息が切れるやうになつた。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯子段を上つても息が切れるほどに弱つたのは、もう二三ヶ月前のことであつた。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "血液の流動性が減ったために起きた肺循環の障碍は息が切れる悲惨な感じの原因である。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "こら、こら、息が切れるぞ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、あの翌る日、その金をそつくり人樣にお渡しする約束が御座いました」　お嘉代は少し息が切れる樣子でしたが、それでも思ひの外元氣に續けます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "縞の財布",
                "note": "青空文庫"
              }
            },
            {
              "text": "學問と智惠はあるか知らないが、年よりはうんとふけて、毎日のお談義さへ息が切れる。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、あの翌る日、その金をそっくり人様にお渡しする約束がございました」　お嘉代は少し息が切れる様子でしたが、それでも思いのほか元気につづけます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "縞の財布",
                "note": "青空文庫"
              }
            },
            {
              "text": "」トッドは息が切れるような声だった。",
              "citation": {
                "source": "歌う白骨",
                "author": "THE ECHO OF A MUTINY",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった、四十四や五で、歩いても息が切れるほど老衰するものだろうか？",
              "citation": {
                "source": "加護",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンリ・サンドはあの大きな体では息が切れるかと思うほどの勢いでまた立ちあがると、だしぬけに大へん怒つてその男に「何をしてるんだ、すぐ出て行け」と言いつけた。",
              "citation": {
                "source": "ピンの先き",
                "author": "THE POINT OF A PIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうやってゆく根気がつづくか、息が切れるかというところが、かね合いのようである。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院の梯子段を昇れば息が切れる。",
              "citation": {
                "source": "笑",
                "author": "アルチバシェッフ・ミハイル・ペトローヴィチ　Artsybashev Mikhail Petrovich",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は天下唯一人志賀直哉に立ち向ふ時だけは全く息が切れる。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ支度して、「新婚太閤記」だ、どうも気乗りせず、それにあばれ廻るので息が切れる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "くた／＼になり、息が切れる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人のホシはついてることだし」「けれど、こう何度も、鼻ッ先を掠めながら捕り逃がしているようではな」「こっちも息が切れるが、逃げる野郎の方だって懸命にちがいねえ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
