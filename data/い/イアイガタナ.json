        "examples": {
          "standard": [
            {
              "text": "居合道の稽古では、安全のため真剣ではなく居合刀を使用します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は新しい居合刀を手に入れ、早速抜刀術の練習に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この居合刀は、軽量でバランスが良く、初心者にも扱いやすいと評判です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "道場の壁には、手入れの行き届いた数本の居合刀が整然と飾られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もっと重心を意識して、居合刀を振ってみてください」と師範が指導した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外からの居合道愛好家が、日本製の高品質な居合刀を求めて専門店を訪れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "居合刀を選ぶ際は、自分の体格や技量に合った長さや重さを考慮することが重要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "又藩中に居て武芸をせねば人でないように風が悪いから、中村庄兵衛と云う居合の先生に就て少し稽古したから、その後、洋学修業に出ては、国に居るときのように荒い仕事をしないから、始終居合刀を所持して、大阪の藩の倉屋敷に居るとき、又緒方の塾でも、折節はドタバタ遣て居ました。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            }
          ]
        }
