[
  {
    "uuid": "5853fcfb-a5b0-5086-898d-4d63633eea7f",
    "entry": "石屋",
    "reading": {
      "primary": "いしや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
