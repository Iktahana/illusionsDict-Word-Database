    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stone dealer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お墓を建てることになり、評判の良い石屋を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "亡くなった祖父のために、石屋に立派な墓石を注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の伝統的な建築には、地元の石屋が加工した石材が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い石蔵の修復を依頼するため、専門の石屋に相談した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭に置く大きな庭石を探しに、郊外の石屋まで足を運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "石屋で手に入れた飛石を使って、趣のあるアプローチを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの石屋は、石工の技術も兼ね備えていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この石はもう手に入らないよ」と、ベテランの石屋が首を振った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "みづから塗れる伯林青の、　　むらをさびしく苦笑ひ、胡桃覆へる石屋根に、　　　　いまぞねむれと入り行きぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "淋い、森とした中に手拍子が揃って、コツコツコツコツと、鉄槌の音のするのは、この小屋に並んだ、一棟、同一材木｜納屋の中で、三個の石屋が、石を鑿るのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から夏休みにの、お邸中が浜の別荘へ来てじゃに就いて、その先生様も見えられたが、この川添の小橋の際のの、蘆の中へ立てさっしゃる事になって、今日はや奥さまがの、この切通しの崖を越えて、二つ目の浜の石屋が方へ行かれたげじゃ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ目の浜の石屋が方へ、暮方仏像をあつらえに往った帰りを、厭な、不気味な、忌わしい、婆のあらもの屋の前が通りたくなさに、ちょうど満潮を漕げたから、海松布の流れる岩の上を、船で帰って来たせいであろう。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろの小松原の中から、のそのそと人が来たのに、ぎょっとしたが、それは石屋の親方で。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、また石屋の親方が、水に彳んだ姿が怪しい。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石屋の親方が自分を背負って、世話をしてくれたのも、銑さんが船を漕いだのも、浪も、鴎も夢ではなくって、やっぱり今のが夢であろう。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ目の浜の石屋に頼まれての、今度建立さっしゃるという、地蔵様の石を削るわ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "淋い、森とした中に手拍子が揃つて、コツ／＼コツ／＼と、鐵槌の音のするのは、この小屋に並んだ、一棟、同一材木納屋の中で、三｜個の石屋が、石を鑿るのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――知合の墓地近くの花屋から、とに角、監督だけにと云って、ほか仕事で忙しい石屋の親方を一人頼みました。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この石屋が皆の意気込を買ってくれて、さし図どころか自分で深切に手を添えてくれた時、皆で抱まわしに、隣の墓から、先生の墓所の前へ廻し込んで、一段、段石を上げるのに、石碑が欠けちゃあ不可い、と言うと、素早い石屋が、構わねえで、バシリと半分にへし折って、敷いてかった塔婆が一本、じき隣のではありません。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――やがて近江屋へ帰って、敷石を奥へ入ると、酒の空樽、漬もの桶などがはみ出した、物置の戸口に、石屋が居て、コトコトと石を切る音が、先刻期待した小鳥の骨を敲くのと同一であった。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、小春が送ろうと言ったが、さっきの今で、治兵衛坊主に対しても穏でない、と留めて、人目があるから、石屋が石を切った処、と心づもりの納屋の前を通る時、袂を振切る。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　Ｈ――氏は非常に乗り気になって、直ぐ宝石屋迄一緒に行ってくれた。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝石屋の店を出ると、うなだれがちな私を引き立てるように、晴々とした調子で彼は云った。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは松島と目と鼻の間の駒込に、古くから大きな店を構えている石屋で、二月か三月に一度くらい、船で観音｜参詣に来て、そのたびに人目につかぬ裏道にある鰻屋などで彼女を呼び、帰りには小遣をおいて行った。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "小菊の姿にどこか哀れふかいところがあるので、石屋は色恋の沙汰を離れた気持で、附き合っているのだったが、それだけに小菊に人情も出て来るのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　松島は怪訝な顔をしたが、またあの石屋にでも誘い出されたのではないかと、しばらく忘れていた石屋のことを何となく思い出したりしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄の書齋が薄暗いのは、仙石屋敷の高臺から續く傾斜地――そこは泰養寺の山と云はれてゐる――の檜の木の大木や、枝のはびこつた松や、大きな椿や、江戸自慢といふ太い櫻やの影が追ひかぶさつてゐる上に、十數年を經た樹木がまた室近く繁り込んでゐる爲めばかりではない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは仙石屋敷と八幡山との間に挾まれ、細長い而かも鬱陶しい谷のやうなところだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウチの寺へ石塔を建てて、その細工賃を一年ばかり石屋へ引っかけて、拙僧に迷惑をかけとる奴じゃ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝石屋の前を通ると、はいって見ろと無埋にすすめる。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは又｜蔦蘿の壁にまとひ屋根にまとへる、小さなる石屋を見たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい林中に留まるも石屋裏にある間は虎これを害せず、水牛帰って後石を取り捨つ（リヴァースの『トダ人族篇』二六七頁）。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "すがめで屋根のけいしやみて、こらいい家だ、いい家だ。",
              "citation": {
                "source": "よい家",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はこのごろ毎夜狂犬いでて年若き娘をのみ噛むちょううわさをききたまいしやと、妹はなれなれしくわれに問えり、問いの不思議なると問えるさまの唐突なるとにわれはあきれて微笑みぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十蔵はわれを寿きて杯を飲み干しつ、片目一人、この船に加わりいることをかねて知りたまいしやと問う。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　清作はもちろん弁解のことばなどはありませんでしたし、面倒臭くなつたら喧嘩してやらうとおもつて、いきなり空を向いて咽喉いつぱい、「赤いしやつぽのカンカラカンのカアン。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "画かきは、赤いしやつぽもゆらゆら燃えて見え、まつすぐに立つて手帳をもち鉛筆をなめました。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うこんしやつぽのカンカラカンのカアン　あかいしやつぽのカンカラカンのカアン。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
