          "literary": [
            {
              "text": "大蛇のような鼾を掻く。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼾を掻く程も眠っていらっしゃって、大丈夫かな」　ちびりちびり三公は、二升徳利のどじょう殺しを舐め舐め大満悦でした。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫は常に鼾を掻く癖があるのだが、今日のは特別に物凄い鼾で、いつものと違うように思う。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから大蛇といっしょにベットに寝ていたんだよ、大蛇め僕の手枕をして、いびきをかくのだもの驚いてしまった。",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（寝そべっていびきをかく）セイウチ　こちらも一休み。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "平さんはときどき寝返りをうつが、いびきをかくようなこともめったにない。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
