[
  {
    "uuid": "e4878f6d-ab65-55a9-aa1e-005148ae3b20",
    "entry": "一宗",
    "reading": {
      "primary": "いっしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
