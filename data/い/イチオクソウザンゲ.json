          "literary": [
            {
              "text": "標語の好きな政府は、二三日すると「一億総懺悔」という標語を、発表した。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一億総懺悔」という言葉は、何か国民を強制する言葉のように聞こえた。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私は「国賊にして国辱」なる多くの人人が「一億総懺悔」という標語のかげにかくれて、やに下っている光景を想像して、不愉快になった。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
