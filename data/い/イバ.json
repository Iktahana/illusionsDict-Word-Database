        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "瞑想することで、意馬のような騒がしい感情が静まっていくのを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の意馬は常に走り回り、一つのことに集中することが極めて難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "意馬に振り回されず、冷静な判断を心がけたいと日々努力している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんな事を言っていると、いかにも私は我慢してキザに木石を装っている男か、或いは、イムポテンツか、或いは、実は意馬心猿なりと雖も如何せんもてず、振られどおしの男のように思うひともあるかも知れぬが、私は決してイムポテンツでもないし、また、そんな、振られどおしの哀れな男でも無いつもりでいる。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よせやい、見っともねえぞ、意馬心猿。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よせやい、見つともねえぞ、意馬心猿。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我意馬を奔らしめて、その往くところに任するときは、我はかの友だちに立ち後るゝ憂なかりしなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ意馬心猿とでもいうべき、全くあさましい有様だったのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "景気の好いお経だらう……心猿跳るを罷めず、意馬馳するを休まず――五欲の樹に遊び、暫くも住せず……あゝ。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若しそうなればもう叔母の許を受けたも同前……チョッ寧そ打附けに……」ト思ッた事は屡々有ッたが、「イヤイヤ滅多な事を言出して取着かれぬ返答をされては」ト思い直してジット意馬の絆を引緊め、藻に住む虫の我から苦んでいた……これからが肝腎｜要、回を改めて伺いましょう。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰を屈めての辛苦艱難も世を逃れての自由気儘も固より同じ煩悩の意馬心猿と知らぬが仏の御力を杖にたのみていろ／＼と病の足もと覚束なく草鞋の緒も結びあへでいそぎ都を立ちいでぬ。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "きらわれものの女白浪、それもお前というお人を一度見てからは、意馬心猿とやらが浅間しく乗り移った、さかりのついた雌犬同然さ――それで、悪いかえ？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "意馬心猿の境地ではおのずから裏切られてしまう性質のものであるから、つまり彼は剣聖の境に達したのである。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "意馬心猿追えども去らず、あわわわわわ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにもあでやかな眺めに、門之丞はしばし、その血管内に荒れ狂う意馬心猿もうちわすれ、呆々然として見｜惚れたのでした。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや香よりも匂いのたかい女脂の薫がふんふんと如海和尚の打振る鈴杵もあやふやにし、法壇はただ意馬心猿の狂いを曼陀羅にしたような図になってしまった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心にも住む意馬心猿は、彼を、寧子の家のほうへ駆りたてていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "意馬心猿――という相である。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが滑稽だとみえないばかりに、花の言葉はみなしやらくさい。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま斧鉞を加へられたと思ふ個所も、決して原作の詩情を失はないばかりか、却つて原作よりも善くなつて居る。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "死なないばかりか、少し太った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の実業家らしいのですが、財産やら地位やらを一言も広告しないばかりか、名誉の家だって事さえ素振りにあらわさず、つつましく涼しく笑って暮しているのですからね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人が辛いばかりではない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想的に美しいばかりでなく目に美しい物が我々には何れだけ必要だか分らないと思つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれら魂が稀薄なために、夢が浅いので歯切れが好いばかりだ。",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ更衣野路の人はつかに白し絶頂の城たのもしき若葉かな鮒鮓や彦根の城に雲かかる愁ひつつ岡に登れば花いばら甲斐ヶ嶺や穂蓼の上を塩車　俳句というものを全く知らず、いわんや枯淡とか、洒脱とか、風流とかいう特殊な俳句心境を全く理解しない人。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした所は、単に温泉町そのものの気分が田舎めいて陰気くさいばかりでなく、周囲の自然そのものからして、妙に百姓じみて感じが重苦しい。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは生れて三十何年間、色が黒いばつかりに、女にいちども、もてやしなかつたんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石楠花は依然多いが、それに次いでは、高根いばらが多く、丈高い茎に大形の紅色の花を着けたのが、消炭の火のように、かえって暗い感じをさせる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし蠅を取りつくすことはほとんど不可能に近いばかりでなく、これを絶滅すると同時に、蛆もこの世界から姿を消す、するとそこらの物陰にいろいろの蛋白質が腐敗して、いろいろのばいきんを繁殖させ、そのばいきんはめぐりめぐって、やはりどこかで人間に仇をするかもしれない。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪郭の美しいばかりではない、この氷片中に縦横に細い溝が規則正しく通って様々の紋理を見せている。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが出来ないばかりに、私は涙ぐんで蹲りながらおまえの歌を詠む。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘠せてオーバアコートを着てわらじを穿いた男が青光りのさるとりいばらの中にまっすぐに立ってゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
