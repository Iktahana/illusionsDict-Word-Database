    "definitions": [
      {
        "index": 1,
        "gloss": "haste",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "本日の会議資料のうち、急ぎの案件のみ先行して確認をお願いします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「申し訳ありませんが、これは急ぎの注文でして、今日中に仕上げていただけますでしょうか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠方の親族から急ぎの連絡があり、急遽（きゅうきょ）実家へ向かうことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この件は急ぎなので、後ほど改めて詳細をご報告させていただきます。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "被災地への急ぎの物資輸送のため、政府は自衛隊の派遣を決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "出発時刻が迫っており、旅行の最終準備は急ぎで進められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "駅構内にお忘れ物がございます。お急ぎのお客様は駅係員までお申し出ください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "御覧なさい天才は彼の自叙伝を急ぎさうなものに恋愛伝の方を先に書きました",
              "citation": {
                "source": "（天才が一度恋をすると）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓導宮沢賢治早くもひとり雪をけりはるかの吹雪をはせ行くは木鼠捕りの悦治なり三人ひとしくはせたちて多吉ぞわらひ軋るとき寅は溜りに倒れゐし赤き毛布にくるまりて風くるごとに足小刻むは十にたらざる児らなれや吹雪きたればあとなる児急ぎて前にすがりつゝ一列遠くうすれ行く",
              "citation": {
                "source": "訓導",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校庭宮沢賢治さ霧する白き木柵幹彫れる桐のいくもと剥げそめし白きペンキの木柵に人人は倚りそのペンキあるいは剥げあるものは庭をのぞめり一鐘のラッパが鳴りて急ぎ行く港先生白堊城秋のガラスはひらごとにうつろなりけり",
              "citation": {
                "source": "校庭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、この仕事を大急ぎで片づけてしまいますから、それまで鳥渡、待っていて下さいね。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると小僧も大急ぎで、その方に頭を突きだして笑つた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ナストウリ、モノサシトハサミ、カガミガアリマス、イケニフネ……」大急ぎでそれだけ読んだが、そこで息が切れた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラムボオは或一物に驚ろくとすると、彼は急ぎ過ぎたので、そして知能が十分だつたので、その驚きをソフィズム流に片附けた。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて傘持たぬ一同、たとえ張子ならずとも風邪など引いては面白からねば大急ぎにて雷門前まで駈け付く。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彩色と云っても絵具は雌黄に藍墨に代赭くらいよりしかなかったが、いつか伯父が東京博覧会の土産に水彩絵具を買って来てくれた時は、嬉しくて幾晩も枕元へ置いて寝て、目が覚めるや否や大急ぎで蓋をあけて、しばしば絵具を検査した。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あの時の相手が龜と子供でなく、まあ、たとへば荒くれた漁師が病氣の乞食をいぢめてゐたのだつたら、あなたは五文はおろか、一文だつて出さず、いや、ただ顏をしかめて急ぎ足で通り過ぎたに違ひないんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ともつともらしい顏で言ひ、「どれ、それではおれも刈つた柴を大急ぎで集めて、下山としようか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」牝狐は赤面して、大急ぎで巣の方へ走つた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方のバックには構内の倉庫の屋根が黒く聳えて、近景に積んだ米俵には西日が黄金のやうに輝いて居り、左の方の澄み通つた秋空に赤や紫や色々の煙が渦卷き昇つて居るのが餘りに美しかつたから、いきなり繪具箱を柵の上に置いてＷＣの壁にもたせかけ大急ぎのスケッチをしようとした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大急ぎで此の瞬間の光彩を攫まうとして藻掻いて居る私には、とてもそんな人達にかまつて居るだけの餘裕はなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなくジョバンニは〔〕黒い丘の方へ急ぎました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うから二人の役人が大急ぎで路をやって来るのです。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束の時間よりも少し早かったので、遠慮のない間柄であるから主人は「ちょっとお待ち下さい」といわせて急ぎの手紙を書き終えてから下へ降りた。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし何か自分の悪事が見付かって罰せられそうになると、大急ぎでその毒を仰いで自決をしようとする。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぎません退院迄にも一度お便りしますからそれはお読みになってからで結構ですからお送り願います。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "実ァ儂は急ぎの用事が御座いますので、これで失礼致します。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が、「旦那Ｔ「神信心って奴もやって見るとまんざら悪かァ御座んせんね」　と言って「急ぎやすから御免なせえ」と其の儘スタスタと去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次は勝坊の頭を撫でて、Ｔ「いい子だから早く帰んな」　と言い捨てて急ぎ足に去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　急ぎ足にすたすたと橋の袂にまで来た時、一人の浪人者とどんと突き当ってはずみを喰らって三次すってんどうと倒れた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近の通り　屋根の上からひらりと跳び下りた三次、その儘立ち去ろうとしてバッタリ急ぎ足にやって来たてっきり鉄と出合わした。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次、急ぎ彼女の許へ駈け寄って縄を解く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "若侍も「それでは致し方厶らぬ」と、進藤と別れ一同急ぎ足に走る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急速なるＦ・Ｏ）　＝（Ｆ・Ｉ）道――　急ぎ足に歩いて居る日下部典六の一行。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぎ足の典六等の一行。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝五郎蔵の家の表　大吉と半次格子戸をガラリと開くと、　バラバラと五六人の通行人急ぎ、　走り去る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
