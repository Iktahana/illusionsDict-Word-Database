    "definitions": [
      {
        "index": 1,
        "gloss": "to come",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「ああ居らっしゃるとも、難有い、ありがたい……」「その本堂に。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたもたまには洛邑にでも出てお気晴らしをなさっていらっしゃいませ、こんな田舎で長いこと毎日独で考え込んでばかり居らっしゃるのはお体の為によくありませんでしょう」　田氏はまた燭の火に一層近づいて髪の銀｜簪がすこし揺れるくらいの調子でつけ加えた。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ママが身の痩せる程私の飛行家になるのを恐れて居らっしゃるのに。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあなた何処に居らっしゃるの。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたの御婚約の方は、どちらに居らっしゃるのですか？",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女も、今、そちらの静かな闇の中で、斯様な悲しみに打れて居らっしゃるのですか。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女が、そんな方と一緒に居らっしゃる筈はないと思っても、矢張り、何だか心配で。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えて居らっしゃるのは。",
              "citation": {
                "source": "一九二三年冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙは神経質故、昨夜よく眠れなかった由……「Ｙさん、きっと眠がって居らっしゃるよ今頃――」　読みかけて居た本など、いきなりバタリと伏せ「眠い！",
              "citation": {
                "source": "木蔭の椽",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天職と云って居るのは人間であるから若しや神様の思って居らっしゃる天職とはかけはなれた事を天職だと云ってやしないか。",
              "citation": {
                "source": "妙な子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……お兄さまお兄さまお兄さまお兄さまお兄さま……お隣りのお部屋に居らっしゃるお兄様……あたしです。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上は非常に不安だと見えて涙ぐんだ様にして居らっしゃる。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さまが一人でぽつねんとして居らっしゃるのを見たら可愛そうになってしまった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井さんがどうしても復讐をすると云って居ると云うので母上が心配して居らっしゃる。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃妙に金の問題にきたなくなって居らっしゃる。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銭を自分の支配下のものとして居る自分は、ああ支配者としてせくせくして居らっしゃる様子はいやだと思えて仕方がない。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はそういうのを、感情的に肯定し、或意味から母の愛を誇って居らっしゃる。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方は、御自分の過去に誇りを持って居らっしゃる、然し、私はそうでない。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人を呼んで云うと云って居らっしゃるそうだが、二人で行くとなお面倒になるので、却ってよいと思い一人で国男さんと行く。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだ、雨の降る日に茶色のたまらなく私のすきな壺を借りて来ようと思って行った時に「今どこに居らっしゃるんでしょう」ってきいたら、「神戸に行ってるんです。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃道ぶしんで歩きにくく、わざとする様にまかれた砂石の道を人の居ないのを幸に足の先の方で走ってくぐりをあけるとすぐうたをうたう様な声をあげて、「居らっしゃる？",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにいくら御姉妹が御有りだと云って彼の姉様なんかはまるで何なかたで却って妹様ばかり御苦労なさって居らっしゃるんでございますからねー、空は晴れてもまだ雪の消えなくて空と土面との境はうす紅とうす紫にかすんで、残った雪の銀のようにかがやく月に奥床しいかざりの女車に召して御出になったのでございます。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな美くしい御顔であんな強いお心を持って居らっしゃるとはほんとうに」と悪口を云って居ると、「そんなに悪く云うものではない、その強い所が彼の人の何よりも尊いところだと私はよろこんで居る。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ木の香の新らしい縁に柳の五重を着て長い美くしい髪をふるわせながら橘の香の中につかって居らっしゃる女君の姿は絵よりも尚多いものであった。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴女は知って居らっしゃるでしょう、恋しい人の門に立てる錦木の千束にあまっても女の心が動かない時には男はいつでも苦しい悲しい思をのがれるためにまだ末長い命をちぢめると云うことを。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女は私が貴女の二親のないので馬鹿にした恋を仕掛けて居ると思って居らっしゃるんではないの、そうじゃあないの。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後を見送った女達は、「今日はまア何と云う好い元気で居らっしゃるんでしょう、いつもこんなでいらっしゃるといいんですけれ共ネー」「ほんとうにですよ、今度いらっしゃって又｜無情くされていらっしゃると又どんなにお歎きになるかそれを思うと私はたとえ様もないほど悲しいんです」と乳母などは云って居た。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもそれでも私は忘られなくて、忘られなくて、しょうこりもなく又来たんです、こりのないいくじのない男だと貴女は思って居らっしゃるでしょう、けれ共、恋する男の因果ですもの」　女君の手はとまって目は油断ないようにかがやいて居る。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴女はまただまって居らっしゃる、だれがその美くしい唇を封じた様にしました、誰が貴方、何故そんなに無情なくなさるの。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが眠っていらっしゃる間に。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
