        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は鏡に映る一糸まとわぬ自分に、ため息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "美術館には、古代の彫刻家が制作した一糸まとわぬ人物像が展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夢の中で、私は見知らぬ街を一糸まとわぬ姿でさまよっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "気違いは、裸になるというが、妙なもので、私も、女房や女中の奸計を怒って狂いたつと、一糸まとわぬ裸体になっていた。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにゼネストとまぎらわしい穏かならぬ言葉であるが、一糸まとわぬストリップの意味なのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストッキングだけはいているが、モモから上は一糸まとわぬ裸体のようである。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件の発見に先立って、あやか夫人は洋館の居室以外のどこへでも、血に汚れた衣服を隠すことができたでしょうし、あるいはズロース一枚で内海さんを殺しに行かれたかも知れない、あるいは全然、一糸まとわぬ裸体でおでかけであったかも知れません。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはいたましい断末魔の苦悶をそのままに、人間界の花が、美しい倭文子の一糸まとわぬ裸体姿が無慙にもとじこめられていたのだ。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなとき、一糸まとわぬ彼の肉体を熟視すると、それはまことに貧弱なものだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
