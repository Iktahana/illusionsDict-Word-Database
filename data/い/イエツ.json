        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長引いた国際会議が妥結した際、参加各国の大使たちは互いの怡悦を分かち合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の研究が実を結び、ノーベル賞受賞の報に接した教授は、静かな怡悦に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年待ち望まれていた古典絵画の修復が完了し、関係者は怡悦の表情を浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の悲願であった平和条約の調印に際し、両国の代表団は怡悦した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "友人A：「ついに目標を達成できたね！」\n友人B：「ああ、まさに怡悦の極みだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年追い求めていた芸術的境地に達し、画家は内なる怡悦に静かに身を委ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "災害からの復興が進み、住民たちの顔に喜びが戻ってきた様子は、地域全体に怡悦をもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "人は感情の爲に動くものであるから、滿足怡悦すれば、再び復新衣を造り與へんとするに至るべきも、聊かなりとも悦ばしからず感ずるに於ては、再び新衣を造り與へんとするに際しても、或は時遲く、或は物｜粗なるに至るべき勢が幾分かある。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に果實が生ずれば、必らずや之を味はふ人をして幸福を感ぜしむるので有つて、主人自ら之を味はふにせよ、主人の親近朋友が之を味はふにせよ、又は主人に賣卻せられて、或他の人が之を味はふにせよ、何人かが造物主の人間に贈るところの福惠を享受して、滿足｜怡悦の情を湛ふるに相違無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又其の靈光神威に勵まされたことは、御伽談の魔力ある寶物を掌裏にした人が、一切の困苦や厄難を物の數ともせざるが如く、如何に二人に無限の希望と怡悦と勇氣とを與へて、四圍の慘苦の光景に堪へ、一身の氣分を緊張せしめた事で有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "千手が濱で艇を出て、アングリング・エンド・カウンツリー・クラブの養魚場を見たが、舟から上つて平地の林の中へ入つて行く感じは眞に平和な仙郷へでも入るやうで、甚だ人に怡悦の情を味はしめた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、初め我が人をして聳聽せしむべく、怡悦せしむべき句ぞとおもひしものは、今は人々の一顧にだに價せざらんとす。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かポツジヨが軽快なる辯と怡悦の色とを見て、その厭世の客たるを知り得ん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "父母又は其位に當る人々が、嫁を寢牀の中央に直立せしめ、外面嚴格、内心怡悦の壻がいと鹿爪らしく嫁の覆面を除く。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然が閉じたる魂には拒み、開いたる魂にはささげ与え惜しまない、あの無数の怡悦を考えつつ、英知の上の長者たる彼は、金銭の上の長者たる人々をあわれむようになる。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく華やいだ、むしろ孤独｜怡悦の神の、――隠微な擬態だつたやうだ）孤独よ、これは宥せ。",
              "citation": {
                "source": "雪",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえついにやつも、へまをやった――ごくごく瑣細なもつれだが――致命的なものであったがゆえに、相手に肉薄できる。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえつい先刻。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
