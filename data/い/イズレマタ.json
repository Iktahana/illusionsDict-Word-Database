[
  {
    "uuid": "b8ff5ab6-67ac-530b-92ca-e38f57cbab54",
    "entry": "何れまた",
    "reading": {
      "primary": "いずれまた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
