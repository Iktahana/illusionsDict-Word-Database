    },
    "definitions": [
      {
        "index": 1,
        "gloss": "some other time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「本日は貴重なお時間をいただきありがとうございました。何れまた日を改めて、じっくりとご相談させていただけますと幸いです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日は短い時間でしたが、何れまたゆっくり飲みに行きましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今回のプロジェクトの反省点については、何れまた時期を見て検討会を開くことにしましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「何れまた機会がございましたら、ぜひ私どもの展示会にも足をお運びください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「その話は、何れまた機が熟したときにお話しすることにいたしましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「何れまたどこかでお会いできることを楽しみにしております。どうかお元気で」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その話の上で、何れまたお力をお借りしなければならないことになると思ひますが、その時には何卒宜敷お願ひ申します。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校に残ッておられる方々にもお話するはずであッたが、何しろ五分ばかりのつもりのところが、大分長くなッたから、何れまた学校に残ッておるお方は長寿をなさるだろうし、私は尚更長寿をするつもりだから、またいつか上ッてつまらぬ演説をする事もありましょう。",
              "citation": {
                "source": "人格の養成",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れまたといふことで、一年すぎ、忘れてゐた頃、また話がもちあがつた。",
              "citation": {
                "source": "「由利旗江」を書いた頃の思出",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れまた、同道の機会を作りませう。",
              "citation": {
                "source": "旅の苦労",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何れまた三人で話をしましょう。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お帰りを待っていたんですけれど、あまりお遅いから、何れまた会社の方へ伺いますと云って、つい先刻帰ったばかりなんです。",
              "citation": {
                "source": "過渡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は一寸急ぐから、何れまた逢おう。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では何れまた、」と刑事は云った、「皆さんのお留守の時に伺っても宜しいです。",
              "citation": {
                "source": "白血球",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れまた更めて御挨拶に……。",
              "citation": {
                "source": "職業（教訓劇）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傷口が、今度癒りかける時分に、何れまた、誰かゞあばかずには置かないのだ。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　　何れまたこの話は、この次の機会に……。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れまた、お目にかゝれるやうに祈つてゐます。",
              "citation": {
                "source": "頼母しき求縁（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢや、何れまた……。",
              "citation": {
                "source": "取引にあらず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れまた招待しなほすよ」　呼ばれる方へ心を惹かれながら、後ずさりをするやうにして、安藤はしきりに頭をさげる。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "姐さん、いずれまたお礼に来るぜ」　幾らか包んだものを女中にやって、半七は茗荷屋の門を出ると、松吉もあとから付いて来てささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、も一度笠を出して面を伏せて、「いずれまた……」「ではさようなら。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら、いずれまた」　もう一度松本に挨拶し、それからそこのお内儀に、「えらいおやかまっさんでした。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、いずれまた参ります。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれまた、ゆっくり、などと書いて、ふと、なあんだ誰もお前を相手にしちゃいないんだ、と思って、がっかりした。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その挨拶を受けらるる時の奥方が、端然として針仕事の、気高い、奥床しい、懐い姿を見るにつけても、お蔦に思較べて、いよいよ後暗さに、あとねだりをなさらないなら、久しぶりですから一銚子、と莞爾して仰せある、優しい顔が、眩いように後退して、いずれまた、と逃出すがごとく帰りしなに、お客は誰？",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いずれまた……」　陽子は階段を降りて行きながら何かしらもう一度このアパートへやって来ることがありそうな気持に、ふっとゆすぶられていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月以来絶えて口にしなかった肉の味に舌鼓を打ちながら、Ｈ氏と私とが「いずれまた秋頃までには帰って来るよ」（本当に、二人ともその予定だったのだ）と言うと、マリヤンが笑いながら言うのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いずれまた借りますから」と、失わないうちに、私はその公判記録を天辰の主人に返しに行くと、「そうですか、やっぱり戦争だと書けませんか。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから最後に彼は、もう仕事もなくなったから、いずれまた何か出てくるまで、ブラブラしていようじゃないかね、と云いながら、応接間の方に引き上げて行った。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが終わると、もう仕事も手を離れたから、いずれまた何かが出てくるまで安楽に過ごそう、と言いながら、我々を応接間の方へ導いた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先どういうふうにして二人が一緒になるかの相談はいずれまた逢っての上にしましょう。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いずれまたのちほど、おじゃまでござった」　長居は無用とばかり静かに立ち上がると、名人は止めるひまもないうちにもう表のやみの中へ吸われていきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれまた、そのうちに。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれまた参りましょう。",
              "citation": {
                "source": "初夢",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれまた機会があったら……。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
