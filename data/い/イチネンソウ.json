          "literary": [
            {
              "text": "上古より旧く我邦に作られている重要植物の一でクワ科に属する一年草である。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の中央には楕円形の花壇があり、渋い一年草を植えてあり、中間色の小さい花が咲いている。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
