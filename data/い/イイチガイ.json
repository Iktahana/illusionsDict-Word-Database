          "literary": [
            {
              "text": "伊村君は言い違いしたのだ。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木山自身の、言い違いと思い違いに過ぎなかった。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今世紀の中頃になって、何人かの歴史物語作家が、文献や手記の微細な陰影をとらえ、陳述の「言い違い」や無意識な発言を追究し、この事件の真相に近いところへ肉迫した。",
              "citation": {
                "source": "海難記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
