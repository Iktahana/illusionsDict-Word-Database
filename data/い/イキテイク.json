[
  {
    "uuid": "df0b8be5-45c5-5bbf-8840-26773a2b31a2",
    "entry": "生きていく",
    "reading": {
      "primary": "いきていく",
      "alternatives": [
        "いきてゆく"
      ],
      "is_heteronym": true
    },
    "grammar": {
