      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to subsist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "物価の高騰で、どうにかして食費を切り詰めながら生きていくのが精一杯だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は大きな夢を追っていたが、今はただ、家族のために健康に生きていくことを最優先に考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地方の漁師たちは、高齢化と漁獲量の減少に苦しみながらも、伝統を守り生きていく術を探っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "厳しい環境下でも、その植物は独自のメカニズムで水分を蓄え、たくましく生きていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人生に困難はつきものだが、前向きな気持ちで、一日一日を懸命に生きていくしかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "A:「最近、仕事が大変でさ。」\nB:「そうか。「なんとか、うまく生きていかんとね。」」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "低賃金労働者は、最低限の生活を維持するために、複数のアルバイトを掛け持ちして生きていくしかない状況に置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「ええ、一日一日、生きていくことが、とっても楽しいわ！",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一日一日、生きていくことが、とっても楽しいわ！",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくて、話に聞く仙人のようにただ霞を吸って生きていくだけだったら、ああ、厭だ、厭だ。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなたちが、せちがらい世の中で、表面はすずしい顔をしながら、きたないことを平気でして生きていくのは、この少年たちが、ぬれぎぬをものいわぬ石太郎にきせて知らん顔しているのと、なにか、にかよっている。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それは強くない、心のどこかで、こういう種類のことが、人の生きていくためには、肯定されるのだと、春吉君には思えるのであった。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしを、生きていくのに苦労のないように、監獄へ入れて……監獄へ入れて……」　鶴代はそう叫ぶように言いながら、そこの地面へくずおれてまたひどく泣きだした。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女にはもう生きていく力がなくなっていた。",
              "citation": {
                "source": "身投げ救助業",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく今後も募っていくだろう現象の混乱とインフレの挟撃のなかにあって、分裂症にかからないで生きていくには、どうすればいいのか。",
              "citation": {
                "source": "悪夢",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅いといわれるのは「例えば船山馨という人たちが書いているものですよ、どういう風に生きていくかということではなくて、何か別の世界、非常に観念のあそびみたいなものを書いてゆく」「しかし勤労者が小説を書く場合には、どういう風に生きていったらいいかということからともかく出発している。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "純潔というものもいわゆる「無垢」なるものだけが純潔なのではなくて、すべての不正とすべての間違いと、すべての汚れの中から、人間が自分の社会認識の力と人間性の油でそれらの汚れを弾きとばしながら生きていく、そこに純潔性があると思う。",
              "citation": {
                "source": "社会生活の純潔性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあとの御遺族のことなどを申し上げるのは失礼ですが、自分が生きていくのに努力してでも御遺言をまちがいなく遂行したい心に今はなっています。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした人物にとって、生きていくことは一種の格闘にならざるをえないようです。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働は生きていくために必要な金銭を得るための手段ではなく、それ自体が目的だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの生命がけでその日その日を生きていく炭坑の坑夫のようなつきつめた、あの痛烈な、むき出しな、あんな生き方が自分にもできるのなら、こんなめそめそした上品ぶった狭いケチな生き方よりどのくらい気が利いているかしれない。",
              "citation": {
                "source": "出奔",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論各自の程度によって求むる種類と分量というようなものは異っていくだろうが、とにかくそんなものなしには一日も生きていくことはできないのだ。",
              "citation": {
                "source": "出奔",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして約束を守って、しっかり生きていくの。",
              "citation": {
                "source": "潮風",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それをいかに演劇の世界に生かすべきか、または、この世界を知ったものが、いかに演劇の中で「生きていく」べきかを思い悩んでいる。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪物は話をつづけた、――「生きていくうえに必要な同情を交してわたしといっしょに暮らしていける女性を、あんたに造ってもらわなくてはいけないのです。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "末世の衆生善根の志少く、仏の御弟子も歌ったり踊ったりせねば、生きていくだけの衣食は得られなかったものと思われる。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしはただ、夫とも子供とも別れて、かうしてひとりで生きて行くために、ともかく、生きていく力がほしいの。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのこと唯ひとつが、およそ圓朝にとっては生きていく上の喜び愉しみ苦しみ悲しみあらゆるものではあったのだった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "この思いのなかには、肉親にたいするあこがれと愛情がこもっていて、生きていくうえの一貫した深いよろこびを感じさせてくれる。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなったからには、覚悟をきめ、みなで力を合せて生きていく道を才覚しようではないか。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ張合いができ、生きていくことがたのしくなったが、そうまでした介抱の甲斐もなく、八月に長六が、九月に甚兵衛が、「かたじけなかった」と、虫のような声で、三人に礼をいって死んだ。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの敵も、あしたは味方……その人心機微の間に処してゆくところにこそ、人の世に生きていく無限のおもしろみがあるのでございましょう。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "効用とは、人間の欲望を充足させる、そのものが持つ性能をいうのだが、私のこんなヌードでも、ヌードの効用があるなら、結婚と名づけるあやふやな座業をあてにせずに、パンパンにでもストリッパァにでもなって、ひとの世話にならずに生きていく自信がある。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが生酔いというものなのか、気持の張りがなくなって、生きていくことのむずかしさが、つくづくと身にしみる。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの知らない片隅で、ひっそりと生きていくことを理想にしている、貧しい平凡な娘をとり巻いて、このひとたちが、なんのために、いきりたったり、腹をたてたりしているのかわからない。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
