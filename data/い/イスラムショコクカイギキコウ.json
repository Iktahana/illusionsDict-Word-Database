        "examples": {
          "standard": [
            {
              "text": "1969年に開催された首脳会議を契機として、イスラム諸国会議機構が設立された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "イスラム諸国会議機構は、パレスチナ問題の解決に向けて加盟国の連帯を呼びかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "2011年の外相会議において、イスラム諸国会議機構は現在のイスラム協力機構へと名称を変更した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "国連に次ぐ加盟国数を誇ったイスラム諸国会議機構は、国際社会において独自の地位を築いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "イスラム諸国会議機構の事務局は、サウジアラビアのジッダに置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
