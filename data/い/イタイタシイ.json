    "definitions": [
      {
        "index": 1,
        "gloss": "pitiful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供が必死に複雑な紐を結ぼうとして、自分自身を絡めてしまった様子は、見ているこちらが思わず顔をしかめるほど痛々しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新のウェブサイトを読み込もうとする古いフィーチャーフォンの姿は、どこか痛々しく、時代の流れを感じさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はギターの腕前を披露しようとしたが、コードはずれ、リズムも狂い、その痛々しい演奏に会場は静まり返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "友人が、流行遅れのキャラクターグッズを「きっと喜ぶよ！」と満面の笑みでくれた。その痛々しいまでの熱意に、私は返す言葉もなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "窮地に立たされた大臣が、必死に支持を訴える姿は、国民から見れば痛々しいばかりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あ、危なかったね、もう少しで転ぶところだったよ。」と、彼はその痛々しいほどぎこちない動きに、思わず笑いをこらえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "場の空気を読まずに古いジョークを連発する彼の姿は、周囲から見れば痛々しく、同情を禁じ得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "悲壮な、痛々しい、骨の鳴るような人生が、一本の枯木を通して、蕭条たる自然の背後に拡がって行く。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東地震や北伊豆地震のときに崩れ損じたらしい創痕が到る処の山腹に今でもまだ生ま生ましく残っていて何となく痛々しい。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悔恨は鞭のやうに痛々しい。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地の悪い、痛々しい塵の戯れではある。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実さんが舞台上に発散する妖気のあらわれは、そうした心境の奥の奥からほのめき出る痛々しい感じを多分に含んでいるのだ。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒焼けというのだろうか、きめの荒そうな皮膚が紫がかっていて、顔全体にむくみが来て、鋭い光を放ってかがやく眼だけれども、その白眼は見るも痛々しいほど充血していた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　袖を落して悄るる手に、鉄の欄干は痛々しい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "落した裳も、屈めた褄も、痛々しいまで亂れたのである。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛々しいばかりに、清楚であった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子という娘の身のまわりに漂っている何か痛々しい、暗い、寂しい翳への、一種のノスタルジアに似た気持が、「もしかしたら、もうあの娘に二度と会えないのではないか」　という意味での、取りかえしのつかぬ想いに、小沢をうろたえさせたのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かエアーポケットのような感じでありそれがふと痛々しい感じのような気がするのは、結局自分が冴子にとって最初に接吻を与えたという罪にも似た意識のせいだろうか。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えれば考える程へんな娘だ――）　井深君は娘のその痛々しい有様を何とも云えない心持で眺めたのであった。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若先生は……あなたはなぜこの鼓を持って高林家へお帰りにならないのですか」　若先生の眉の間に何ともいえぬ痛々しい色が漂った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肋骨から背中へかけて痛々しい鞭の瘢痕が薄赤く又薄黒く引き散らされていた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、痛々しいという感じは、特に私ひとりだけに強く響いたものかも知れない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけは、この先生は、その講義に於いてずいぶんご自分の言葉使いに気をくばっておいでの様子で、私もまた自分の言葉の田舎訛りにはかねがね苦労させられているので、他人のそんな気持には敏感に同情できて、そのせいもあって、特に痛々しいなどと感じたのかも知れなかった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い眉を集め、さらでだに血色のよくない顏を痛々しい許り暗くして、人の顏を見る事を何よりも恐れてゐるやうな容子を見ると、神經が研ぎすました西洋剃刀の刄のやうに鋭くなつてゐて、皿と皿のカチリと觸れる音でさへ、電光のやうに全身に響くらしい。",
              "citation": {
                "source": "新しい歌の味ひ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "年紀の頃は十九か二十歳、色は透通る程白く、鼻筋の通りました、窶れても下脹な、見るからに風の障るさえ痛々しい、葛の葉のうらみがちなるその風情。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て過去に痛々しいこともありましたし将来に棘立つことも待受けているようです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この三四日、目星ばかり気にし続けて居た京子の偏執が、今朝もまだ、眉や顎に痛々しい隈を曳いている。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水垢で赤く※びついていて、おまけに眼鼻立ははっきり判別出来ぬほどすり切れていて胸のあたりなど痛々しい。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつては豊満な脂肪で柔かった肩も今は痛々しいくらい痩せて、寺田は気の遠くなるほど悲しかったが、一代ももう寺田に肩を噛まれながら昔の喜びはなく、痛い痛いと泣く声にも情痴の響きはなかった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "充血して痛々しいくらいである。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいが、しかしやつれ果てて、痛々しい位、蒼白い横顔だった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷垣の恐縮はそれに一種の愛矯も含まれていたが、この老番頭の恐縮は痛々しいほどに真面目なものであった。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴が鮒などよりも薄い位で、細い肋骨の列が外から見え、時々咽喉の邊をふくらませるのも何か寒さうで痛々しい。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから探偵小説は人類が唯物文化から唯心文化へ転向して行く過渡時代の、痛々しい内省心理の産物ではないか。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この故に探偵小説は人類の思想傾向が、囚われる唯心文化から囚われざる唯物文化に進化し、更に又、囚われたる唯物文化から、囚われざる唯心文化へ反転して行く過渡時代の痛々しい内省心理の産物でなければならぬ。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に、谷は、四月の末か、五月頃の柔々しい呼吸で充ちていて、大きな声を出すのすら、いたいたしいようだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の僕はそこまでは考えなかったけれど、親しく目に染みた民子のいたいたしい姿は幾年経っても昨日の事のように眼に浮んでいるのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
