          "literary": [
            {
              "text": "いい加減にしなさい」　黒川は、見るに見かね、トラ十をしかりつけた。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとをからかふのも、いい加減にしなさい」「よし、両者の意見が一致したんだから、もう遠慮はいらないわ。",
              "citation": {
                "source": "悪態の心理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかげんにしなさい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんにしなさい」「まあ、虫のいい！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、たくさんだわ、ばかなまねはいいかげんにしなさいよ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかしおまえは僕のことを熊といったぞ」「あれはお兄様のことじゃありません」「うそをつけ」「照常、いいかげんにしなさい。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
