          ],
          "literary": [
            {
              "text": "さればまことに豚の心もちをわかるには、豚になって見るより致し方ない。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "反感をもたれても、致し方ない。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "只謹んで神意を伺い奉るよりほか致し方ないのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "用件を早く言ってくれ給え」「はあ、その点数のことなんですが」「点数のことは致し方ないよ、どうにもならないよ」「なりませんか？",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもまあ寿命なら致し方ないのでございますが、当人がいよいよ息を引き取ります時、廻らない舌で何か申しましたそうで……」云いかけて、利兵衛はまた躊躇した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵器の進歩によってフランス革命を来たしたことにしなければ、学者には都合が悪いらしいのですが、都合が悪くても現実は致し方ないのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもへんな話だが、アフガニスタンにしろズズアイランドにしろ、仮にも王さまの御用とあらば致し方ない。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　羽左もミスタア・ウザエモンじゃあどうもめりはりが合わなくて申訳ないが、これもこの場合まことに致し方ないというものは、橘家さんや大師匠ではこの赤毛の「おとこしゅ」に一そう通じっこないんだから――。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが時々急にこの地で致し方ない程の郷愁にかられると、大概は神田の朝鮮食堂にでも行って元気な学生達の顔を嬉しそうに眺めたり、朝鮮歌謡の夕だとか野談や踊りの催しなどをさがしては出掛ける。",
              "citation": {
                "source": "故郷を想う",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "この次の時代を極端に怖れるというならば、生まれてくる赤ん坊をことごとく抹殺するよりほか致し方ないでしょう。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、既往のものは致し方ないにしても、新しい犠牲者だけは何とかして防ぎ止めたいと思ったからなんだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは多賀之丞の三婦女房のおつぎなどが、堂々として見えても致し方ない。",
              "citation": {
                "source": "見ものは合邦辻",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "内容が古くさいのは何とも致し方ないが、これとても、一種の皮肉として通用しないとも限らない。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○望月、口論の果の出来事で致し方ない、とか何とか云って居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、これ一人御願いします」　私の考えでは、夫人と娘と同舟させ、私と葵原君とは同じ舟に乗って一日を遊び暮らそうとする予定であったが、健康を害していると言えば致し方ない。",
              "citation": {
                "source": "葵原夫人の鯛釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手数がどうも容易のものではないが、それは致し方ない、と駒井が、そのことを思い及ぼすと、どうもあの不所存者のことが気になる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "自工法は無理な競爭、殊に外國車の如き基礎も充分固まつた實力のある會社のダンピングを防ぐ意味に於て有効ではあるが、正當なる競爭に於ては矢張り自らの力に頼る外致し方ない。",
              "citation": {
                "source": "國産自動車と價格の問題",
                "author": "――自動車製造工業の一大難關――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこに色々な悲喜劇が演ぜられることも致し方ない。",
              "citation": {
                "source": "飜訳遅疑の説",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれも致し方ないことなのであろう。",
              "citation": {
                "source": "農業物理学夜話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気温は致し方ないとしても、水温の方はある程度まで制御可能である。",
              "citation": {
                "source": "農業物理学夜話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画で現象の説明をするとなると、どうしても線画が多くなるのは致し方ない。",
              "citation": {
                "source": "科学映画の一考察",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸溜水をチチハルからこの奥地まで運んで、それを凍らせて氷を作り、その氷で零点を決めるという程度の手数がかかるのは致し方ない。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして皆相当に繁昌しているようには見えたが、それは共喰い的な繁昌であることは致し方ないとして、それ以上に何となく消耗的な影が、店のどこかに見えるような気がして仕方がなかった。",
              "citation": {
                "source": "満洲通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清々しさの研究を、清々しい気分で遂行出来るのはよほどの天才のことであって、現在の科学はとかく渋面を作りながら研究することになっているのだから、この場合もその例に洩れぬのも致し方ないことであろう。",
              "citation": {
                "source": "清々しさの研究の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が通ずるようになれば、魚がだんだん逃げてゆくのは致し方ないことであろう。",
              "citation": {
                "source": "大謀網",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく北国の夏の夜明けの夢をみるのならば、もう少し縹渺とした夢か、桁のはずれた夢を見たいものであるが、もって生れた本性は致し方ないようである。",
              "citation": {
                "source": "八月三日の夢",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれば出来るに決っていることをやるのを研究と称することになっていた我国の習慣では、それも致し方ないことであった。",
              "citation": {
                "source": "原子爆弾雑話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも『参同契』には、隠微の奇書とされても致し方ない点もある。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻や弟の難儀なぞ、致し方ないと諦めるばかりだ」「そうか。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼つきの卑し気なのは致し方ないとしても、それを除くとほぼ皇帝に似ている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
