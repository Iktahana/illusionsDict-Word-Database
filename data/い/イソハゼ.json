    "definitions": [
      {
        "index": 1,
        "gloss": "Eviota abax (species of pygmy goby)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
