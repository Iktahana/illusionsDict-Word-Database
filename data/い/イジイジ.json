        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あのね…」と、子供はイジイジと母親の袖を引っ張った。「（あの、もう一冊、本を読んでもいい？）」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そんなにイジイジしてないで、はっきり自分の意見を言えばいいんだよ」と友人は励ました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「君の報告は、もう少し自信を持って、イジイジせずに話してほしいのですが」と上司は促した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国際会議での発言を求められた際、彼はイジイジと喉を鳴らし、なかなか本題に入れなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい服を買おうか迷っていたが、最終的にイジイジと決断できず、元の商品棚に戻した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、初対面の人と話すとき、いつもイジイジと視線を合わせようとしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、若竹が、あちこちの空に、かぼそく、ういういしい緑色の芽をのばしている初夏のひるで、松林では松蝉が、ジイジイジイイと鳴いていました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真をすぐに送ってください」　まもなくジイジイジイと、写真を焼きつけるための信号が入ってきた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇長はじめ通信係の一同は、ジイジイジイと廻るドラムの上を、またたきもせず、見つめている。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
