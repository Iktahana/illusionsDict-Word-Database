        "examples": {
          "standard": [
            {
              "text": "ギャンブル依存症者の増加が、深刻な社会問題となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "依存症者の社会復帰を支援するためのプログラムが、地域で新たに開始された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "精神科医は、依存症者の個々の状況に合わせた治療計画を立てる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、自助グループで同じ悩みを抱える依存症者たちと出会い、支え合うことの重要性を実感した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あぁ、もうダメだ。自分はただの依存症者なんだ」と、彼は絶望的な表情で呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "薬物依存症者の更生施設では、職業訓練も提供されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "依存症者の家族が抱える負担も、社会全体で理解し、支援していくことが求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
