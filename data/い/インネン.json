[
  {
    "uuid": "ca3d4ad7-2267-59c3-a8e2-9a4513238afb",
    "entry": "因縁",
    "reading": {
      "primary": "いんねん",
      "alternatives": [
        "いんえん"
      ],
      "is_heteronym": false
    },
    "grammar": {
