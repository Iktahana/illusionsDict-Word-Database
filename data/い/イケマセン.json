            }
          ],
          "literary": [
            {
              "text": "どんな鳥でもとてもあそこまでは行けません。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くしないと明るいうちに家に行けません。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉藤平太は分教場の玄関から教員室へ入らうとしましたがどうしても行けませんでした。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃあもう……そんな風に先へ先へと手を廻して計画をたてて行かなくちゃ、帝国主義の政府はやって行けません。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんも、刎起きて、突立ったにゃ突立ちましたが、腰がふらついて歩行けませんので、大黒柱につかまって、おしッこをするように震えています。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "果してわたくしはそこまでは行けませんでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ」　と、それにうなずいたのが、丁度、公園で待っているということへの返辞にもとれて、君枝は狼狽したが、しかし、「いいえ、行けません。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「五円じゃ行けませんよ！",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧は一しょに附いて来た女中に、「籠はわたしが持っているから、あの血を掃除しなくちゃ行けませんぜ、畳にも落ちましたからね」と、高慢らしく忠告した。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぢやア、ね、かうしましよう――」義雄が別なことを云ひかけた時、千代子の草履の音がばたばたとして來て、「あなた、諭鶴が行けませんから、叱つて下さい」とおめきながら、障子をばたりと明けた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し、僕のおツ母さんにでもしやべつたら行けませんよ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那さんと相撲を取つたら行けません」と、醫者のらしい口調を意地惡さうに眞似て、「人を馬鹿にしてる！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、いったん、それがおわると、それなり、水の上のあわになって、おたがいむつまじくして来たひとたちのなかに、お墓ひとつのこしては行けません。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "横腹を抱えて、しょんぼりと家へ帰るのに、送って来た友だちと別れてから、町はずれで、卵塔場の破垣の竹を拾って、松並木を――少年でも、こうなると、杖に縋らないと歩行けません。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう叔母の所には行けませんからね、あすこには行きたくありませんから……あのね、透矢町のね、双鶴館……つがいの鶴……そう、おわかりになって？",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は戦争のお金を出さなくてもいゝようにならなければ、みんなにいじめられますから、どうしても学校には行けません。",
              "citation": {
                "source": "級長の願い",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうこれからは百姓になるか、闇屋になるかしなくては、どつちみち生きては行けませんぞ」　以前は敏腕な社員だつたが、今は百姓になつてゐる後藤は、皆を前にして熱心に説くのであつた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕を冷かしては行けません」「冷かしなんぞはしない」大石は睫毛をも動かさずに、ゆったり胡坐をかいている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも僕はpassifで行けません」「誰だってあらゆる方面にactifにagressifに遣るわけには行かないよ」　給仕がスウプを持って来た。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも僕は passif で行けません」「誰だってあらゆる方面に actif に agressif に遣るわけには行かないよ」　給仕がスウプを持って来た。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても仲間について行けません。",
              "citation": {
                "source": "母の話",
                "author": "アナトール・フランス",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬はなかなか夏のように早く行けません。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日一〇七四メートルには登りましたが、濃霧のため迷って、金糞へは行けませんでした。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人に一人ぢやとても行けませんからと云つて止められたので、それは思ひ止まつたらしかつた。",
              "citation": {
                "source": "初秋の淺間",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くは行けませんが、それでもお寺の門にいま一足でとゞくところになりました。",
              "citation": {
                "source": "豆小僧の冒険",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう行けませんぜ、ここんところは――岸にあがりましょう」　川面の方にいくらか傾いたドロ柳が、雨のあたらぬ木肌を白っぽく見せていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "友右衛門は、そんな風に、本然の姿から云へば立役・実悪と言つた風なものが向くと思ふのですが、口が邪魔をして、そこへ行けません。",
              "citation": {
                "source": "実悪役者を望む",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然んな気の弱い事をいつちやア行けません、お加減が悪ければ、明日は御大役の事ですから早く牛の角文字にでも見せたら宜しうございませう…。",
              "citation": {
                "source": "牛車",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本を見る、いけません。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあなたの話、あなたの言葉、あなたの考でなければいけません』と常にいった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
