[
  {
    "uuid": "1b366b40-5b8e-5f70-a79a-eb2643a2e99b",
    "entry": "医術",
    "reading": {
      "primary": "いじゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
