    },
    "definitions": [
      {
        "index": 1,
        "gloss": "medicine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の医術は神業の域に達しており、多くの難病患者を救ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代文明における医術は、現代の科学では解明できない神秘に満ちている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域では、伝統的な医術が今なお人々の健康を支えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新の遺伝子治療は、従来の医術の常識を覆す可能性を秘めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「彼の医術にかかれば、どんな重い病も治る」と、村人は口々に語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "軍医たちは、劣悪な環境下で最大限の医術を尽くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "西洋の医術と東洋の医術を融合させる研究が進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "医術というものは結局こういう造化の天然の医術の幇助者の役目を勤めるものであるらしい。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで医術がもっともっと進歩すると、精神のけがでもこれら天然の妙機を人工的に幇助することによって楽に治療できるようになるかもしれない。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯科医術のまだ幼稚な明治十年代のことであるからずいぶん乱暴な荒療治であったことと想像される。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の科学の初まりは神様の存在を否定し、人間をその良心から解放するのが目的で、同時に一切の化学の初まりは錬金術であり、一切の医術の初まりは堕胎術と毒薬の研究でしかなかったのである。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまだ癌とか癩病とかコレラとかは相変らず医術の力の外であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて三人は三人とも、実に医術もよくできて、また仁心も相当あつて、たしかにもはや名医の類であつたのだが、まだいゝ機会がなかつたために別に位もなかつたし、遠くへ名前も聞えなかつた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯ういう山村に生れても、家が富裕であるお庇に、十年以前から東京に遊学して、医術を専門に研究し、開業試験にも首尾好く合格して、今年の春から郷里に帰った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎の父は之を憂いて、倅には充分に医術を修業させ、将来は郷里で医師を開業させる心組であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に、卵巣切開手術や隆鼻手術のような高級な医術に自発的に参加するのには、余程の医学的知識と勇気、英断を要するものだという持論が彼女を慰めた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年で習つて、折角はやりかけた医術も、過労のため押し切れなく成り、それで儲けて建てた、かなり立派な家も人手に渡し、田舎へ引込んだ年であつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年間つぶさに修学した秋成は、安永四年再び大阪へ戻つていよいよ医術開業。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして額に手を組んで誰にいふともなく、「僕の子供の育つ時分には、医術が発達して、結核なんかはたいして体の毒にはならんだらうな……」　Ｑ――芸館借入れの不調や、小布施の事件で、桂子が無気力虚脱に過ぎてゐた一年の間に、桂子の信用や名声は高められ、Ｑ――芸館からむしろ懇望の形で桂子の大会は迎へられた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校では、生理の課目は無かったが、木版刷の「全体新論」や「化学衛生論」を読んでみて、支那の医術は、意識的もしくは無意識的な騙りに過ぎない、という事をいよいよ明確に知らされた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の新しい学問への志願は、初めから医術とつながっていたとも言える。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、西洋の医術を学び取るために、蘭語の勉強を始めた者も多かった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど、日本に於ても、更に進歩した医術が他のどんな科学よりもさきに、民衆に依って渇望されていたのだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我旅行は医術修行の為なれば、格別の事なり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は医術が猶幼かったとは云え、それでも相応に手の尽しかたは有った。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、間もなく医術開業試験の規則が出来て、もうお情け免状を相続することはできなくなりましたが……、其の時すぐ養子をすると、まだ一代は其の恩典に浴することはできましたが、私の家にはちょっとした財産がありまして、其の日に困ると云うほどでもありませんでしたから、親類も其のままにしてありました。",
              "citation": {
                "source": "薬指の曲り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "己れの取る所を奉信するは善し、己れの取る所を以て、他の取る所を妄排す、是を思想界の藪医術と言はずして何ぞや。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れ藪医術とは外科の医術を言ふなり、而して其の外科たるは、人間の病原を探りて後に其治術を講究するにあらずして、外部に表はれたる病象の一部分を見て、直に膏薬を塗するに留まるなり。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "咄、藪医術はいかほどに進歩するとも、人世に於て何の功益するところあらんや。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "信仰個条彼れ自身は、藪医術にあらず、繩墨彼自身は藪医術にあらず、唯心論も亦た然り、唯物論も亦た然り、然れども個の信仰個条を擁し、個の繩墨を擁し、個の善悪論を擁し、個の唯心論を擁し、個の唯物論を擁し、之を以て宇宙を法規する唯一の真理と迷信する輩の手に於て、藪医術の本源は存するなり。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば医学博士を掴まえて医術の講釈をこころみ、禅宗坊主を向うに廻わして禅学の弊害を説教する。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも、医術を修めました以上は、そんな風に役立てたいものだと思っておりました。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「併し、被告は、神の力を信ずるという迷信から遠ざけて、医術を信じさせようとするような行為に出たことは、一度として無いではないか？",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
