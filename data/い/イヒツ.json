    },
    "definitions": [
      {
        "index": 1,
        "gloss": "writing left by the deceased",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "亡き祖父の遺筆から、彼の若き日の情熱が伝わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "画家の遺筆展には、未発表のデッサンも展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その詩集には、彼の最期の遺筆が収められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の高厳荘重なるミルトンまでも一度は此轍を履んとし、嶢※豪逸なるカーライルさへ死後に遺筆を梓するに至りて、合歓｜団欒ならざりし醜を発見せられぬ。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯱か何かに成って敵の軍艦を喰ってやるぞ、といった意味の和歌が、確か、遺筆として与えられたはずだったことを彼は思出し、家中捜し廻って、ようやくそれを見付け出した。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事庵の遺筆など見せられて感に堪へず、われも一句を認めて遺子木公に示す。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ近日｜暇を得まして、御高教を煩わしたく、かたがた御機嫌伺いに上るでございましょう」「此の方よりも今日の、此の御無礼をば詑びがてら、大先生の御遺筆なぞ拝見いたしに、参邸のお許しを得とう厶る」「よろこんでお待ちいたしまする。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、遠く慶長享保年代からの御年貢｜皆済目録があり、代々持ち伝えても破損と散乱との憂いがあるから、後の子孫のために一巻の軸とすると書き添えた先祖の遺筆も出て来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、奥の方の壁に、父の遺筆が紙表具の軸に成って掛っている。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "実が満洲へ旅立つ時、預って置いた父の遺筆を取出した。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ二百五十年前の嘉永三年（1850）に上梓せられた『桃洞遺筆』第二輯に三度栗の記事があって次の通り書いてある。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の『桃洞遺筆』に引用されている『本朝食鑑』（小野必大の著、元禄十年1697出版）巻之四の文を仮名交りに書いてみれば、「上野州下野州ニ山栗アリ極メテ小ニシテ一年ニ三度、栗ヲ収ム故ニ三度栗ト号ス其味ヒ佳ナラズト為サズ此｜類ノ山栗ハ諸州ニ在レドモ亦極メテ小キナリ是レ古ヘノ※栗乎」である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔明の遺筆たるはいうまでもない。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『武家義理物語』の三の一に「すこしの鞘とがめなどいひつのり、無用の喧嘩を取むすび、或は相手を切りふせ、首尾よく立のくを、侍の本意のやうに沙汰せしが、是ひとつと道ならず。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草より出でゝ草に入るとは武蔵野の往時の月をいひけん、今は八百八町に家相望めば、東京の月は真に家の棟より出でゝ家の棟に入るともいふべけれど、また水の東京のいと大なるを思へば、水より出でゝ水に入るともいひつべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれ秋の夕なんど天の一方に富士を見る時は、まことにこの渡の風景一刻千金ともいひつべく、画人等の動もすればこの渡を画題とするも無理ならずと思はる。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろづ温順にして、君子の体を具へて小なるものともいひつべきさまなる、取り出でゝ賞むべきものにもあらぬやうなれど、なか／＼に好まし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ、」　と唯吉は、恰もいひつけられたやうに、敷居に掛けた手の上へ、横ざまに耳を着けたが、可厭な、と云ふは何の聲か、其は聞かない方が望ましかつた。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馳せ出でつつ、その落ちたる梭を取って押戴き、社頭に恭礼し、けいひつを掛く）しい、……しい……しい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』といひつゝ、染々と吾等兩人の姿を打瞻め『此處は印度洋もズツト南方に偏した無人島で、一番に近いマダカツスル群島へも一千哩以上、亞細亞大陸や、歐羅巴洲までは、幾千幾百哩あるか分らぬ程で、到底尋常では人の來るべき島ではありませんが。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やまねこは巻たばこを投げすてて、大いそぎで馬車別当にいひつけました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪夢に襲はれて寝言をいひつゞけたことが私自身によく解つてゐる、これはとても不愉快だつた。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの百姓男は、村長からいひつかつて、坊さんを探しに今朝はやくから、この街道に出て来てゐたのでした。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんちきしよ、こんちきしよ、と久助君は口の中でいひつづけた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお祖母さんにいひつけた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ぱいひつかけなきや、力が出ねえ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かへさんとてめえの父つあんにいひつけるぞ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉助にいひつけるぞォ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の上に立って、うつくしい村をながめては、歌にうたい、牧場にいって、やさしいひつじのむれをながめては、詩をかくのがつねでした。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵海、（仮設し置く）風呂は門前の弥平爺にいひつけての、明日から毎日立てさせろ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お別れといたしまして、其處らの茶店をあけさせて、茶碗酒をぎうとあふり、其の勢で、暗雲に、とんぼを切つて轉げるまでも、今日の内に麓まで歸ります、とこれから雪の伏家を叩くと、老人夫婦が出迎へて、富藏に仔細を聞くと、お可哀相のいひつゞけ。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四囲の人々、皆驚き恐れ『人殺ぢや、人殺ぢや』などいひつつ逃れ去る。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といひつつ海野は一歩を進めて、更に看護員を一睨せり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
