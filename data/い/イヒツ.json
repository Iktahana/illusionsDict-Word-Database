[
  {
    "uuid": "8f1047a8-602b-594e-958a-e5ac63ab273c",
    "entry": "遺筆",
    "reading": {
      "primary": "いひつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
