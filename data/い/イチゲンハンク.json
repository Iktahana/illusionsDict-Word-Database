[
  {
    "uuid": "d0229c36-5b14-5516-b87e-6b873b3f3bb1",
    "entry": "一言半句",
    "reading": {
      "primary": "いちげんはんく",
      "alternatives": [
        "いちごんはんく"
      ],
      "is_heteronym": false
    },
    "grammar": {
