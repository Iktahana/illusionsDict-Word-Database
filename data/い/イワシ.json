    "definitions": [
      {
        "index": 1,
        "gloss": "pilchard (esp. Japanese pilchard, Sardinops melanostictus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さらば我、皿持ちゆかん、鰯の頭を賜びさせ給へ！",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯の頭を三つ貰つたつて、それが何にもならないことは決つてゐるが、呉れる奴の方はこつちを嗤つて呉れるだらう。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りこつちでは、例へば白い西洋皿の上に、鰯の頭が三つ、コロコロと這入るところを、よつくとみて、どうせ対手は嗤つてゐるのだから一寸、ホンの一寸した目礼くらゐで自分の所に帰つてゆけば、却々シツクリした気持だつて味はへるやうなもんぢやないか。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の光今朝や鰯の頭より　正月元旦の句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京のいろは骨牌では、イが「犬も歩けば棒にあたる」であるが、大阪の方では「鰯の頭も信心から」で、絵札には魚の骨から金色の後光がさし、人々のそれを拝んでいる様が描いてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いた家無し猫は、開け放った戸棚に這入って乾し鰯を食っていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "養鶏をしている者、養豚をしている者、鰯網をやっている者もある。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金廻りの良かった時には、鰯網に手を出したこともある。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八歳か九歳の時から鰯網の手伝いに行った。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が学校が引けると小舟に乗りこんでやって行って、「マイラセ」という小籠に一っぱいか半ばい位いの鰯を貰って来るのだ。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯網が出ない時には、牛飼いをやった。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五六になった頃、鰯網は、五六カ月働いて、やっと三四十円しか取れなかったので、父はそれをやめて、醤油屋の労働をすることになった。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、鰯網の「アミヒキ」もやった。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダシがらの鰯もやった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は鰯のようなヒョロヒョロの星やめだかのような黒い隕石はみんなパクパク呑んでしまうんだ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は鰯のようなひょろひょろの魚やめだかの様なめくらの魚はみんなパクパク呑んでしまうんだ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯の天窓も信心から、それでも命数の尽きぬ輩は本復するから、外に竹庵養仙木斎の居ない土地、相応に繁盛した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "城趾のあたり中空で鳶が鳴く、と丁ど今が春の鰯を焼く匂がする。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、織さん、この二、三日は浜で鰯がとれますよ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と独りで極めて、もじつく女房を台所へ追立てながら、「織さん、鰯のぬただ、こりゃ御存じの通り、他国にはない味です。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "座にその鰯の臭気のない内、言わねばならぬ事がある……「あの、平さん。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "へへへへへ、鰯を焼きな、気は心よ、な、鰯をよ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、鰯の催促をしたようで。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわしぐも　鰯雲といふは、鰯などの群るゝ如く点々｜相連りて空に瀰るものを云ふなり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "童児などは、此雲を指さして、鰯の取るゝ兆なりといふもまたをかし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたは、わしが今日限り抵当ながれにならなくてはならないわしの土地についてはよく承知なんだ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「芝浦の漁人も網を打忘れ月には厭ふいわし雲かな」といへる狂歌、天明頃の人の咏にあり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は私の顔を天眼鏡で覗いて見たり、筮竹をがちゃがちゃいわして見たり、まるで人相見と八卦見と一しょにやっていましたが、やがてのことに、『イヤ御心配なさるな、この児さんは末はきっと出世なさるる、よほどよい人相だ。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ入れて頂きましょうかな」　と言って、表障子をがたがたいわして入って来た。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　矢來邊の夜は、たゞ遠くまで、榎町の牛乳屋の納屋に、トーン／＼と牛の跫音のするのが響いて、今にも――いわしこう――酒井家の裏門あたりで――眞夜中には――鰯こう――と三聲呼んで、形も影も見えないと云ふ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
