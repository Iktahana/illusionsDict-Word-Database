  {
    "uuid": "12c7ed0c-6140-5794-a0f2-4ee0c121e846",
    "entry": "伊蘭",
    "reading": {
      "primary": "いらん",
      "alternatives": [
        "イラン"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "castor oil plant (Ricinus communis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「言ふ事すべて氣にいらん。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれのくびから上だけが、おいらん草のやうにふるへてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」杜氏は人のいゝ笑いを浮べて、「親方は別に説明してやることはいらんと怒りよったが、なんでも、地子のことでごた／＼しとるらしいぜ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴らをほめたりなんかするこたア、そりゃ、決していらんこったよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いらんことを喋っちゃいかん！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、田地を買うて呉れたって、いらん。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぼ田を買うたっていらんこっちゃ！",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "図に乗ってまくし立てるようだが、登楼して、おいらんと二人でぐっすり眠って、そうして朝まで、「ひょんな事」も「妙な縁」も何も無く、もちろんそれゆえ「恋愛」も何も起らず、「おや、お帰り？",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらんの中でも、あれは少し位の高いほうだったのかも知れません、ちょっと威厳さえ持っていました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして婆に言いつけて、私の連れの職工とその相手のおいらんをも私たちの部屋へ呼んで来させ、落ちついてお茶をいれ、また部屋の隅の茶箪笥から、お皿に一ぱい盛った精進揚げを取り出し私たちにすすめました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎょっとして、あわてて精進揚げを呑みくだし、うむ、と首肯くと、その女は、連れの職工のおいらんのほうを向いて小声で、育ちの悪い男は、ものを食べさせてみるとよくわかるんだよ、ちょっちょっと舌打ちをしながら食べるんだよ、と全くなんの表情も無く、お天気の事でも言っているみたいに澄まして言うのでございます。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性のうちで、最もしいたげられ、悲惨な暮しをしていると言われているあのおいらんでさえ、私にとっては、実におそろしい、雷神以外のものではなかったのでした。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頸摺れに、突着け、突掛け、「やあ、おいらんの道中々々！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うが空屋で両隣は畠だ、聾の婆が留守をしとる、ちっとも気遣はいらんのじゃ、万事｜私が心得た。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……此奴おいらんでいやあがる。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親合點の母親承知で、向島へ花見の歸りが夜櫻見物と成つて、おいらんが、初會惚れ、と云ふ寸法に成るのであるが、耕地二十石の百姓の次男では然うは行かない。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又その女中が「けいらん五、」と或時言つた。",
              "citation": {
                "source": "廓そだち",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、きいちやん、けいらんツて玉子の事だね。",
              "citation": {
                "source": "廓そだち",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜若を一年植たが、あの紫のおいらんは、素人手の明り取ぐらゐな處では次の年は咲かうとしない。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらんは成佛しました。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「防空壕やったら、あんた、誰に気兼遠慮もいらんし、夜空襲がはいっても、身体｜動かす世話はいらんし、燈火管制もいらんし、ほんま気楽で宜しあっせ」　そして、わては最後までこの大阪に踏み止って頑張りまんねんと、他アやんは言い、「メリ助が怖うてシャツは着られまっかいな。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんた所が焼けたので、雑誌が手にはいらんようになったよ」　すると三ちゃんは、滅相もないという口つきを見せて、「何言うたはりまんねん。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、いらん」　食堂だと思ったが、夜はカフェに変るのだろうか、いや、朝っぱらからもうカフェじみているわいと思いながら、小沢はぶっ切ら棒に断ったが、ふと思い出して、「――それより、にぎりを持って来てくれ」　十五円のライスカレー一皿では、腹が一杯にならなかったのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「言ふ事すべて気にいらん。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町へはいると一軒々々、「今日は菜はいらんかのう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいらんという道具を二三品、抽き出して台俎板の向う側へ黙って抛り出した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらんよ」と受付の男は、うるさそうにはねつけました。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「墨いかが」　「墨も筆もいらん。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
