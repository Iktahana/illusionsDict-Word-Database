    "definitions": [
      {
        "index": 1,
        "gloss": "grain (of rock)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "熟練の職人は、石目を見て石を割る方向を瞬時に見極める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この硯は石目が非常に細かく、墨が滑らかに摺れるのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「見てください、この大理石の石目はまるで流れる雲のようですね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "壁面に貼る石材の石目を美しく揃えるには、高度な施工技術を要する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "石目に沿ってタガネを打ち込むと、硬い岩石も面白いように真っ二つに割れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近のキッチンパネルは、本物の石目と見紛うほど精巧なプリントが施されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "墓石を選ぶ際は、石目の細かさや色の均一さが耐久性の目安とされることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――ところでですわね、股立を取った趣は、羽にうつ石目｜一鏨も、残りなく出来上って、あとへ、銘を入れるばかり、二年の大仕事の仕上りで、職人も一同、羽織、袴で並んだ処、その鶏の目に、瞳を一点打つとなって、手が出ません、手が出ないんですとさ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶々その一を讀めば、石目細工の家と題したり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁又｜歩牀には石目もて方圓種々の飾文を作る。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鷲掴みに茶碗を片手にひっ掴んだかと思うと、いきなりそれを庭石目がけて叩きつけた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、懐剣一本で斬り返されて、どじを踏んでしまったので見ると、一松斎さんが、この男に、奥義を譲らなかったのも、流石目があるというもんだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰金堂で、種々骨折つて呉れたが、思はしい色がないので、石目にして造つて見た事などが有つた。",
              "citation": {
                "source": "装釘に就て",
                "author": "『春』と『家』及び其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕭条と石に日の入る枯野かな蕪村こがらしや畠の小石目に見ゆる同木枯や小石のこける板ひさし同　石が寂しい姿と色とを持っているから人間は好きになれるのだが、反対のものであったら誰も石好きにならないであろう。",
              "citation": {
                "source": "庭をつくる人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体大谷石の特色は、石目が荒く脆いが、それだけに仕事が早い。",
              "citation": {
                "source": "野州の石屋根",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つめたいしめった空気がしんとみんなのからだにせまったとき子供らは歓呼の声をあげました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いもかけぬ重い苦痛と疑惑とが、若い心を老いしめると思うほどに押し寄せてきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあれを染めるには何でも黒いしめった土をつかうというはなしもぼんやりおぼえています。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工芸学校の先生は「黒いしめった土を使うこと」と手帳へ書いてポケットにしまいました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春らしいしめった白い雲が丘の山からぼおっと出てくろもじのにほひが風にふうっと漂って来た。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖｜其の挙止端整なるを喜びて、皇孫に謂って曰く、此荘士、当に其才を老いしめて以て汝を輔けしめんと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　境も歯の根をくいしめて、「しっかりしろ、可恐しくはない、可恐しくはない。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と引かれて、カチカチと、何か、歯をくいしめて堪えたが、突込む筆の朱が刎ねて、勢で、ぱっと胸毛に懸ると、火を曳くように毛が動いた。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（へい、その鍵をおなくしなすった……そいつはお困りで、）　と錠前の寸法を当りながら、こう見ますとね、新聞のまだ残った処に、青錆にさびた金具の口でくいしめた革鞄の中から、紫の袖が一枚。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と歯をくいしめてすすり泣きつ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度び三度び呟き返し、身に味わいしめてから、わたくしはこれが何で人が憧憬するほどの境涯であろうと不審ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄、高坂弾正、飯富兵部、馬場民部、真田幸隆等に一万二千を率いしめて、妻女山の背面を襲わしめ、謙信が巣から飛び出す処を打とうと云うのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝｜茲に於て、遼陽の一部将｜祖承訓に兵三千を率いしめて義州に南下し、朝鮮の部将｜史儒以下の二千の兵と合して、七月十六日平壌を攻撃させた。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の報を得た賊軍側は大いに駭き、細川｜顕氏に軍を率いしめ、八月十九日に大阪天王寺を出発せしめて居るが、彼は泉州に於ける優勢な楠勢にはとても敵せぬと、京都に報告して居る。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たいしめっぽい風が枝葉に音をさして吹いてきた。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "定吉は兎欠脣を食いしめながら、紋作を憎さげに睨んで出て行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　この年は正月から照りつづいて江戸近国は旱魃に苦しんだと伝えられているが、白河から北にはその影響もなくて、五月の末には梅雨らしいしめり勝ちの暗い天気が毎日つづいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はハッとした、ひろげられた味瓜畑は、その娘さんの白い両手はいつの間にか男の茶色にたくましい指と変り、だん／″＼と娘さんをそこの夜露のいつぱいしめつた草原に夢のやうにしめつけてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "内庭にはまた水門から堀がつづいて、船頭たちはどこへ姿を消したか、ぬしのないしめなわ舟がなぞのごとくに見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際｜餌をやるときには、きっと誰かが扉をあけるにちがいないが、一年三百六十五日の間には何十とある猛獣の檻の扉を一つぐらいしめ忘れることはありそうなことだ。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ村の利助が丁度に通りかかって、犬どもを追っ払ってしまったんですが、その時の尼さんの顔はまるで人相が変わって、目を据えて、歯を食いしめて……。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の居るのをまるで知らない様に落ついた眼つきで話したい事を話して居る娘の様子を見て居ると重い重いしめられる様なわけのわからない悲しさが仙二の胸に湧き出して来た。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
