          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遠くの空で、一筋の稲妻が夜の闇を切り裂いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ピカッと稲妻が光った直後、ゴロゴロと雷の音が響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の脳裏に、解決の糸口となるアイデアが稲妻のようにひらめいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「うわっ、稲妻だ！」「雷が近いのかな、怖いね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "生涯の出来事や光景が、稲妻のように一時に脳裏に閃いたと思うとそれは消えて、身を囲る闇は深さも奥行も知れぬ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室へ戻って、友人にハガキを書いていると、富士の雲が引いて取ったように幕を明け、銀磨きの万年雪が、巨獣の斑紋のように二筋三筋キラリと光って、夏の富士にして始めて見るところの、威嚇的な紫色が、抜打に稲妻でもひらめかしそうに、うつぼつと眉に迫って来る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒るときは、山腹にかみなり稲妻を起し満山は暗くなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が何やら判らないで、一度稲妻のように掠れ合った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手の渚には、波がやさしい稲妻のやうに燃えて寄せ、右手の崖には、いちめん銀や貝殻でこさえたやうなすすきの穂がゆれたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから電車のポールの尖端から出る気味の悪い火花も、日本アルプスを照らす崇厳な稲妻の曾孫くらいのものに過ぎない。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう云った時にアインシュタインの顔が稲妻のようにちょっとひきつったので、何か皮肉が出るなと思っていると、果して「自然が脳味噌のない『性』を創造したという事も存外無いとは限らない」と云った。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚子の句に「一角に稲妻光る星月夜」とある。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻のぴかりとする時間は一秒の百万分一という短時間で、これに照らして見れば砲丸でも止まって見える。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻が光る度に稲が千石ずつ実るという云い伝えがあるが、どういう処から割り出したものであろう。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃海外では農芸に電気を応用する事がようやく盛んになろうとしているから、稲妻の伝説と何か故事つけが出来そうである。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀が稲妻のように舞踊靴の部屋に這入ってくると、彼は米良にボロジン一味が再び南昌から漢口に潜入したことを告げ、彼は嶮しい眼を閉じるとボロジンの南昌入によって新たな時局の転廻となるか、恐らくは最期の瓦解となる二つの道を告げるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花曇り」「かすみ」「稲妻」などでも、それと寸分違わぬ現象が日本以外のいずれの国に見られるかも疑問である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばドイツの「ウェッターロイヒテン」は稲妻と物理的にはほとんど同じ現象であってもそれは決して稲田の闇を走らない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども窓の外では、いっぱいに咲いた白百合が、十本ばかり息もつけない嵐の中に、その稲妻の八分一秒を、まるでかがやいてじっと立っていたのです。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗が来たと思う間もなく、また稲妻が向うのぎざぎざの雲から、北斎の山下白雨のように赤く這って来て、触れない光の手をもって、百合を擦めて過ぎました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手の渚には、波がやさしい稲妻のように燃えて寄せ、右手の崖には、いちめん銀や貝殻でこさえたようなすすきの穂がゆれたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この時水色の烈しい光の外套を着た稲妻が、向うからギラッとひらめいて飛んで来ました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして二人は一緒に稲妻のマントにつかまりました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻がぎらぎらっと光ったと思うともういつかさっきの泉のそばに立って居りました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と稲妻が申しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻はもう見えません。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう状態が続いているうちに突然天の一方から稲妻のような光がひらめいて瞬間に眼前のものの正体が見える。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もしルクレチウスが現代の科学者にとって有効に役立ちうるとすれば、それはまさにこの稲妻の役目をつとめうる点である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻のように飛び上って頭の上の電灯のスイッチをひねった。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供に関するすべての事が稲妻のひらめくように私の頭の中に照らし出された。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻でもすればさらにおもしろい。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「漢楚軍談」「三国志」「真田三代記」の愛読者であったところの明治二十年ごろの田舎の子供にこのライネケフックスのおとぎ話はけだし天啓の稲妻であった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていなずまのようにつづけざまに丘を四つ越えました。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石と石とをぶっつけ合せていなずまを起す。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
