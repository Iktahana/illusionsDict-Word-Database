          ],
          "literary": [
            {
              "text": "僕は科学者だから、何時だって冷静に計画を立てることが出来る。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時だって、貴方のおっしゃることは、真面目で聴いているではありませんか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに何時だって蟹が取れるとも限ったものでもないんだ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年Ｋ　何時だってかまうもんか。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう何時かしら」「何時だっていい。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何時だって……。",
              "citation": {
                "source": "潮風",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう九時でしょう」「何時だってかまわない……」　私はこう言って羽織と足袋を脱ぎ、袴をつけて、杉の樹間の暗い高い石段を下り、そこから隣り合っている老師のお寺の石段を、慄える膝頭を踏ん張り、合掌の姿勢で登って行ったのであった。",
              "citation": {
                "source": "父の出郷",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時だってそれよ、あなたは。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時だって日曜日じゃないか。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けい　あら、子供は何時だって咲やと一緒にねるんだから、そいって下さればいいのに。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒夫には何時だって構わなかった。",
              "citation": {
                "source": "同胞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は大層｜温順しいのねえ」「何時だって温順しいじゃないか」　彼は同じ食卓に就いて居る一人の年増の貴婦人を凝乎と瞶めて居た。",
              "citation": {
                "source": "乗合自動車",
                "author": "川田功",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者とは言え、あぶれ者の長庵のことだから、九寸五分ぐらいは何時だって呑んでいる。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「絶交しようと思えば何時だって出来るさ」「しかし今まで付合っただけが損になるじゃありませんか」「そりゃ何の関係もない御前から見ればそうさ。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きみは晩には水にかえってゆくが、かえって往くことを何時だってわすれたことがないね。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「慍るも慍らないも、ないわよ、何のために今どきうろうろ出ていらっしゃるの、あたいのいる間、いくらいらっしったって、何時だって会わせて上げるもんですか。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もあそこに何時だって坐って見るかくごはある。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、金魚の問屋のお爺ちゃんの家にゆけば、何時だってあるのよ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何時だって現われると、すぐ逃げ出してしまうくせに、何のために現われるのよ、そんなのもう古いわよ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何時だって同じさ。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれが読まれて話題になる頃には、何時だって大体もうその状態はぬけているのに。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの心構えは何時だってあるのですよ」「自由意志で学校に出ないと言うのだろう」と天願氏が言った。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは何時だって、自分のことだけしか考えていらっしゃらないくせに」「おれが？",
              "citation": {
                "source": "河鹿",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時とわずかな費用とさえかければ、一人でならば何時だってこういう事はできる。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつだってばかじゃねえからな」　呉清輝は、腹からおかしく、快よいもののようにヒヒヒと笑った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕は、いつだって、忘れたことなんかないよ。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『幸ちゃんとこのようにですか、だってあれは株ですものう、水車がそういつだってできるもんならたれだってやりますわ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、神さまは、いつだって、ぼくをたすけてくださるんです」「ふん、そうか。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはおれのもんだし、それに、あいつだって、おれを乗せて行くぐらいできるさ！",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はたじろいだが、しかし、気を取り直し、「うん、飲ませてくれるなら、いつだって飲むがね。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
