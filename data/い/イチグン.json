[
  {
    "uuid": "4406a9b4-e1ff-5ad2-80c6-0e3fb7dbbd16",
    "entry": "一群",
    "reading": {
      "primary": "いちぐん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
