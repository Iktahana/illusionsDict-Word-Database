    },
    "definitions": [
      {
        "index": 1,
        "gloss": "group",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "午後の公園で、ハトの一群が地面をついばんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "災害現場には、支援物資を運ぶボランティアの一群が到着した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "放課後、駅前広場には友人たちと待ち合わせる学生の一群が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夜空を見上げると、淡く輝く星の一群が星座を形作っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、あそこにいるのは、みんな同じ服を着た人たちの一群だね。何かのイベントかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "サバンナの平原を、シマウマの一群がゆっくりと水を求めて横断していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "学会の会場では、新しい研究成果について熱心に議論する専門家の一群がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "アンチテエゼの成立が、その成立の見透しが、甚だややこしく、あいまいになって来て、自己のかねて隠し持ったる唯物論的弁証法の切れ味も、なんだか心細くなり、狼狽して右往左往している一群の知識人のためにも、この全体主義哲学は、その世界観、その認識論を、ためらわず活溌に展開させなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも知られぬ或る日、或る一隅に於ける諸君の美しい行為は、かならず一群の作者たちに依って、あやまたず、のこりくまなく、子々孫々に語り伝えられるであろう。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、達沢が教頭席に腰を下した儘、前方のゴタゴタした一群れ――それは何か分らぬ――に向つて、その太い腕を得意気に振廻してゐる光景のみが、彼の目に見えてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥萩原朔太郎夕ぐれてほの痒くなる指のさき坂をくだれば一群の鳥は高きをすぎ行けり。",
              "citation": {
                "source": "鳥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に手に紅葉の枝をさげた女学生の一群が目につく。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、いま月下の宴に打興じてゐるこの一群の赤く巨大の生き物は、鬼と呼ぶよりは、隱者または仙人と呼稱するはうが妥當のやうなしろものなのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたちまち、その天蓋から一群の魚がむらむらとわかれて、おのおの銀鱗を光らせて滿天に雪の降り亂れるやうに舞ひ遊ぶ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひは、この子は、父に連れられて近所の井の頭動物園に行つた時、檻の中を絶えずチヨコチヨコ歩きまはつてゐる狸の一群を眺め、愛すべき動物であると思ひ込み、それゆゑ、このカチカチ山の物語に於いても、理由の如何を問はず、狸に贔屓してゐたのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのご両人は、あまりに老大家であって、「一群」からは、かけ離れていた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群の人たちは、遅塚麗水、大町桂月、江見水蔭、田山花袋、久保天随、坪谷水哉などであるが、花袋が紀行文家と言われた時分は、自然派文学勃興以前のことで、文章に感傷癖はあったが、淡泊清新、ことに武蔵野あたりの原野や雑木林の寂しさを、淡彩的に点描するのに巧みであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また白衣の道者の一群に、森の出口でゆき遇う。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群の星は前述のリーラ星座より発して四方に展開しつつあるがごとく、他の一群は北天カメロパルダリス星座の辺より馳せ出るようである。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何某講と染め抜いた揃いの手拭を冠った、盛装に草鞋ばきという珍しい出で立ちの婦人の賑やかに陽気な一群と同乗した。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小雨の降る薄暮の街に灯がともり始め、白い水面を一群のかもめが巴を描いて飛び交わしている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラテン系の mons, monte, montagne, mountain 等は明白な一群を形成していて上記とは縁が遠く見える。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の円頂閣 cupola はラテンの cupa（樽）から来たそうであるが、現在の流義では同一群に属する。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日庭に角砂糖をいくつか出しておいたら、やがて一群の蜜蜂がこれにとまってしきりに骨折っていたが、堅くて喰い欠く事が出来ぬと見えて一時飛び去ってしもうた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は町のなかで次のやうな一群を見た。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋は大理石像の一群に囲まれて、ロダンさんは秘書のマハセル・チレル公爵夫人と、何かお仕事をしていらっしゃいましたが、その公爵夫人が部屋からお去りになるとロダンさんは壮年のような若々しさを以て、妾の小さい肉体を、あの頑健な腕で抱えて、喜悦をお伝えになったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日本が過去の栄華から、幻燈に似た流行を耽溺するプチ・ブルジョワの一群と、実生活から畸型的に形成されたブルジョワ末期の社会に発生したプロレタリア精神の出現を、繁雑な社会主義理論闘争から逃れて、私を信仰する一人の女性の涙とともに東京駅を離れて品川の砲台、横目で計算していた。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたとえマラバーの六個の円筒の下でカルカラの一群によって白骨になろうとも、私は未来の有効な地図に向って突進します。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群の退院者が丘を下って谷あいの街へ小さくなって行くと、またあとから別の群が病院の門をくゞりぬけて来た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田はその昔、ある大名の下屋敷の池であったのを埋めたのでしょう、まわりは築山らしいのがいくつか凸起しているので、雁にはよき隠れ場であるので、そのころ毎晩のように一群れの雁がおりたものです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "有機系とはなんの交渉もないものが繁殖し始めるとその有機系の調和が破壊され、その活力が阻害され結局死滅する、それと同時にその死滅を促成した反逆者の一群も死滅することは当然である。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も今日の世界の状態食やゝ足り亦は足らず、もし偏狭なる人間一群ありて動物は可〔哀さう〕なれば食すべからずと云はゞこれ人類の食糧の四分の一を奪取せんと企つるものに非や。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」特曹は、訓練所出の一群を指さした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群の負傷者にまじってトラックに揺られ病院に来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群の鶏も、数匹の白兎も、ダリヤの根方で舌を出している赤犬に至るまで。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "wide expanse (of flowers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "丘陵を埋め尽くす一群の野花は、風にそよぎながら息をのむような色彩の海を創り出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初夏、ラベンダー畑は一群の紫色に染まり、遠くからもその香りが漂ってくるようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "広大な大地に、一群のチューリップが咲き誇り、まるで自然が描いた巨大な絵画のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ニュースで見た、一面に広がる一群のコスモス畑は圧巻だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "朝露に濡れた一群の朝顔が、庭一面に可憐な青い花を咲かせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "砂漠のオアシス周辺では、季節になると一群の珍しい花々が、限られた大地を彩る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
