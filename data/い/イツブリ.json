          ],
          "literary": [
            {
              "text": "また鵜やかいつぶりの卵などはほとんど両端の丸みが同じで楕円形をしている。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑けさよ、三宝寺池、潜き鳥、かいつぶりのよく響きて、ともすれば連れ走る、頭のみぞ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠の内からかいつぶりがひょいと浮き上る。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいつぶりはふいと沈む。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖には遠く一二点、かいつぶりの姿が浮んでいた。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして蘆と藺との茂る濠を見おろして、かすかな夕日の光にぬらされながら、かいつぶり鳴く水に寂しい白壁の影を落している、あの天主閣の高い屋根がわらがいつまでも、地に落ちないように祈りたいと思う。",
              "citation": {
                "source": "松江印象記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳰鳥（かいつぶり）は水に潜くので、葛飾のかずへの枕詞とした。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともその話は沙汰止みになったようで、安心したのであるが、とにかく一度は閣議の席上での論議にまで上ったのであるから、本気の話としたら、またいつぶり返すかも知れないので、まだ安心は出来ない。",
              "citation": {
                "source": "兎の耳",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいつぶりのいる沼のそばで育った十二歳の少女には、他人の手は、心やすくも親しげにも、そうやすやすと握れるものではなかった。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいつぶり三好達治かいつぶり　かいつぶり　そうれ頭に火がついた私たちの歌に應へて　かいつぶりは水に沈むそれは旱魃の夏だつた　ただそれだけのことだつたかいつぶり　かいつぶり　かいつぶりのゐない日もあつた",
              "citation": {
                "source": "かいつぶり",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいつぶりが二匹遠くの方に水尾をひいて泳いでゐるのが眼に入つた。",
              "citation": {
                "source": "古江",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれがかいつぶりという鳥なんだな」と新八は呟いた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
