[
  {
    "uuid": "e4451c54-7f63-5d41-b98b-fa931255a305",
    "entry": "行ったり来たり",
    "reading": {
      "primary": "いったりきたり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
