[
  {
    "uuid": "3b4a0d3c-c405-5ae0-9c75-1b14dd08b051",
    "entry": "言い表す",
    "reading": {
      "primary": "いいあらわす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
