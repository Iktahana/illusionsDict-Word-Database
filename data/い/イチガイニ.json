[
  {
    "uuid": "a1f67cc4-c6c7-5128-a4e7-a56f888775d7",
    "entry": "一概に",
    "reading": {
      "primary": "いちがいに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
