        "examples": {
          "standard": [
            {
              "text": "密閉された空間での火気使用は一酸化炭素中毒の危険があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎年冬になると、暖房器具の使用による一酸化炭素中毒のニュースが増える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はガレージでエンジンをかけっぱなしにしていて、一酸化炭素中毒になりかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "死体解剖の結果一酸化炭素中毒による死であることが判明して、当局は前後の事情から、過失によるガス中毒と決定したという事だった。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色合の佳い屍体を視たら、先ずチャン化合物中毒か、一酸化炭素中毒を考えろと、法医学は教えて居ます。",
              "citation": {
                "source": "越後獅子",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "エミール・ゾラは一酸化炭素中毒によって悲劇的に死亡した。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
