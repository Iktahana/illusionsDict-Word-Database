          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ゴッホの絵画に描かれているような、天に伸びる糸杉の並木道を歩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "トスカーナ地方の丘陵には、点々と糸杉が立ち並ぶ風景が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "風が吹くたびに、庭に植えられた糸杉がさわさわと音を立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夕日に照らされて、長い影を落とす糸杉が幻想的な雰囲気を醸し出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "糸杉の巻きあがった葉も見える。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向側の鏡が、九枚も上手に継いであって、店が丁度二倍の広さに見えるやうになって居り、糸杉やこめ栂の植木鉢がぞろっとならび、親方はもちろん理髪アーティストで、外にもアーティストが六人もゐるんですからね、殊に技術の点になると、実に念入りなもんでした。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向側の鏡が、九枚も上手に継いであって、店が丁度二倍の広さに見えるようになって居り、糸杉やこめ栂の植木鉢がぞろっとならび、親方らしい隅のところで指図をしている人のほかに職人がみなで六人もいたのです。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木会社の貸物らしい大きな糸杉の植木を飾った入口の仏蘭西扉の前に十人位の者が立って中を覗き込んでいた。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロメオが露台の上によじのぼって、まことの愛の接吻が天使の思いのように天へとのぼって行ったとき、まるい月は黒い糸杉のあいだに半ばかくれて、澄みきった空に浮んでいたこともあるのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "りっぱな玉座の間には、ただ裸の壁が残っているだけで、黒い糸杉がむかし玉座のあったところをその長い影でさし示しています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはすばらしく大きな糸杉で、幹の周囲が百二十六｜呎、樹齢はごく内輪に見積っても、まず六千年は請合だと言われている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆ラムプの細い燈心には人の眼を竪にしたやうな形の愛らしい焔がともつてゐて、その薄い光りが窓の前に伸びた無花果と糸杉の葉を柔らかく照し出して居た。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の先には柳と糸杉が技を張つて、麦袋をつなぎ合せたカーテンを降すと昼間でもランプが必要だつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "賤しい男の蒔いた種からどんな立派なサアンガンの糸杉が生えたか、見せて遣ろう」　反対に、何ともいえない懐しさと憧れとが、天地の間に、自分という生命を与えた父に対して、感じられることもある。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸杉の葉かげのうつる歩廊の甃を、再び広間の方に歩きながら、やがて、ルスタムが云った。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして糸杉の蔭に無数の墓がぴつしり並んでゐるのを想像することが出来るだらう。",
              "citation": {
                "source": "不可説",
                "author": "UNERKLARLICHT!",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い糸杉の木、倒れてゐる柱形の墓石、僕に手を握らせて微笑んでゐる若い女の顔。",
              "citation": {
                "source": "不可説",
                "author": "UNERKLARLICHT!",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕はジユリエツトの姿、薔薇の谷の小さいトルコの珈琲店、糸杉の木、スクタリの柱形の墓石、ベゼスチンの刀剣商を思ひ浮べるのだ。",
              "citation": {
                "source": "不可説",
                "author": "UNERKLARLICHT!",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔らかい糸杉の蔭に野うばらの花が咲いていた。",
              "citation": {
                "source": "夢と人生",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルク色に立ちこめた雨の中から、組み合った糸杉の群りすすんで来るような朝の雨だ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄ばんだ糸杉の下枝が濡れた屋根を包んでいる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちこもった霧雨の中から糸杉、槙の葉、栗の枝が影絵のように浮き出ている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしゴオグの糸杉や太陽はもう一度僕を誘惑するのである。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯が済むと、静三は家の玄関から暗い露路を通って、そこの店へ裏口から乗込んで行くのだが、糸杉の植わった暗い石畳が何か神秘な感覚につつまれていて、その纔かな距離を歩く間にも、夜の劇の期待に心は弾むようだった。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、本館は水松の刈込垣で繞らされ、壁廓の四周には、様々の動物の形や頭文字を籬状に刈り込んだ、※や糸杉の象徴樹が並んでいた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルボナウト以後の占星学では、一番手前の糸杉と無花果とが、土星と木星の所管とされているし、向う側の中央にある合歓樹は、火星の表徴になっているのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある物は糸杉の間に、太陽の見える風景だった。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "青あをと燃え輝いた糸杉もやはりゴツホの生まれぬ前には存在しなかつたのに違ひない。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば一本の糸杉は微風よりも常人を動かさないかも知れない。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども天才に燃えてゐたゴツホはその一本の糸杉にも凄まじい生命を感じたのである。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、意次の背後の方に、少し離れて佇んで、警護するように九十郎がいたが、その九十郎を狙うように、漁夫と熊坂とが九十郎の背後の、糸杉の蔭から現われて、こっちへ徐々に近寄って来た。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗くて、よくわかりませんでしたが、奥の方にはイタリー特有の糸杉の立木があつて、そこに何かの胸像らしいものが真白に浮き出てゐました。",
              "citation": {
                "source": "フランスに於けるシェイクスピア",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸杉に覆はれた麓の小径を降りて行きませう。",
              "citation": {
                "source": "けむり（ラヂオ物語）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはまた葉の茂つた糸杉が並木を作つてゐて、その隙間から、ホテルの門が見えます。",
              "citation": {
                "source": "けむり（ラヂオ物語）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
