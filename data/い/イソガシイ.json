[
  {
    "uuid": "52905daf-f47b-5547-a7df-996924847b94",
    "entry": "忙しい",
    "reading": {
      "primary": "いそがしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
