    },
    "definitions": [
      {
        "index": 1,
        "gloss": "busy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "年末は配送業者が一年で最も忙しい時期だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は重要な会議の準備で忙しく、電話にも出られない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "育児と仕事の両立で、毎日が目まぐるしく忙しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「ご多忙の折、大変恐縮ですが、ご確認のほどよろしくお願いいたします。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "都会の生活は刺激的だが、時としてその忙しさに心がすり減る思いがする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "レストランの厨房では、大勢の料理人が忙しく立ち働いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "週末は子供のサッカーの試合や習い事の送迎で、平日に輪をかけて忙しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "――こうした刈入時の田舎の自然と、収穫に忙しい労働の人生とが、屋根の上に飛びあがった一羽の鶏の主観の影に、茫洋として意味深く展開されているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋裸足で痛痛しい、胸が開張けて、雪の肌が白百合の匂ひ、島田の根が外れて忙しい呼吸である。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙しい世間は竹村君には用はない。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この忙しいのにどんなに世話を焼かすか知れぬと頭ごなし。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど二学期の試験のすぐ前であったが、忙しい中から同郷の友達等が入り代り見舞に来てくれ、みんな足しない身銭を切って菓子だの果物だのと持って来ては、医員に叱られるような大きな声で愉快な話をして慰めてくれた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島では」と、折から忙しい中を講演に来てくれたＫ君が、笑ひながら、臍の話を批評した。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺たちゃ、明日から忙しいから、汽車ん中で寝て行き度えんだよ」「どこへ行くんだい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少女達がいろいろなサンドウイッチを手頃な荷にして、ギャルソン達の忙しいサーヴィスの間を、邪魔にならぬように詰った客の間を、売歩く。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の忙しいときや、面倒なときに、家のものは飯を握り飯にしたり、または紙に載せて店先から与えようとした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は大学を出ると美術工芸学校やその他二三の勤め先が出来た上、類の少ない学問筋なので何やかや世間から相談をかけられることも多く、忙しいまま、東海道行きは、間もなく中絶してしまった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日帰りを延して久し振りにどっか近くの東海道でも歩いてみようじゃないか」　私は、はじめ何をこの忙しい中に主人が言うのかと問題にしないつもりでいたが、考えてみると、もうこの先、いつの日に、いつまた来られる旅かと思うと、主人の言葉に動かされて来た。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず現代の応用科学の産み出した文化は天地間のエネルギーを駆使して多くの唸り声や吼声を製造するに忙しい。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほど極端でないまでも、実際科学者としては日進月歩の新知識を修得するだけでもかなりに忙しいので、歴史的の詮索までに手の届かぬのは普通の事である。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ忙しい彼には沢山色々のものを読む暇がないのであろう。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は只石川君の所謂（忙しい生活の間に心に浮んでは消えて行く刹那々々の感じを愛惜する云々）といふやうな意味で作られたものが最善の歌とは思へないだけである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙しいため十分｜纏める暇もありませぬし、時間も足りなくて急いだものですから、不徹底な所があったろうと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度忙しい時であったから家族を見せに遣った。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）わたくしの方では、きのうの事は幕明の音楽で、忙しい調子の中へ、あらゆるモチイヴを叩き込んだものに過ぎないので、これからが本当の曲になると云いたいのですが、あなたには、何んと云ってもそう考えて下さる事が出来ないのですね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも妾は眼のまわるように忙しいのよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷役に忙しい樺太や釧路通ひの汽船や、白いペンキの醜く剥げ落ちた帆船の中には、舷の低い捕鯨船の疲れたやうな姿が横はつてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護卒は、たゞ忙しそうに、忙しいのが癪に障るらしく、ふくれッ面をして無慈悲にがたがたやっていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだ、昼間があまり忙しいので、夜なべに蕎麦をこなしたのだと母は話している。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の知人の実業家で年じゅう忙しい人がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙しい忙しいで時候が今どんなだかそんなことを考えたりする余裕はないということであった。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は恐ろしく多面的な忙しい頭脳をもっていた人である。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って科学者は自分の研究以外の事で常に忙しい想いをするように余儀なくされる。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう考える以上は、場合によっては自分の大事な研究時間をずいぶん思い切って割いても世間の要求に応じるために忙しい想いをし、従ってそれだけの心のエネルギーを余計に消磨させなければならない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために人のよく知る通り恐ろしく忙しいからだになってしまった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校で毎日のやうに物理學や數學をどしどし詰め込まれるのに忙しい私の頭からは、おふみと云ふ女の名も次第に煙のやうに消えてしまつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君だって、いそがしいからだである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
