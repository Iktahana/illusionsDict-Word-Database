    "definitions": [
      {
        "index": 1,
        "gloss": "just as one was told",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「プロの料理人が勧める店と言うだけあって、素材の使い方が実に見事だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『一生もの』と謳うだけあって、この鞄は十年経っても型崩れひとつしていない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「スポーツ万能と言うだけあって、彼は初めてのボルダリングでも難所を軽々と登り切った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「毎日欠かさず練習していると言うだけあって、彼女の演奏には迷いがなく、音に厚みがある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「看板メニューと言うだけあって、この店のオムレツは驚くほどふわふわで口の中で溶けてしまう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「厳しい指導で有名と言うだけあって、その教室の生徒たちは皆、背筋が伸びていて礼儀正しい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「百戦錬磨の交渉人と言うだけあって、彼の話し方には相手を納得させる不思議な説得力がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人に欺されて、田地家屋までとられてしまったというだけあって、善良な性質の男に違いない。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでの話やけど、その柳吉つぁんというのは吃音でな、吃音にわるい人間は居らんというだけあって、人間は良え人間やけど、なんし、ぼんぼんやぜな、蝶子も余計苦労や」　種吉はしみじみと言い、もうはいって来た時の見幕などどこにも見当らず、「――これというのも、みな芸者になったばっかしや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲罰のためというだけあって、仙台刑務所での作業は辛かった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈サマー・イン・ザ・シティ〉というだけあって、暑苦しい音だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時にひどく放蕩をしたというだけあって華族の出に似合わず、世馴れていて、中々愛想がよく、人を外らさないが、野村にはそれがひどく狡猾に見えて不愉快だった。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "綽名を牛丸というだけあって彼の職業は牛飼いであった。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、どうやら、海底要塞の、ごく底の方らしく、臨時というだけあって、まるで倉庫であった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の山道ですよ」　バスが運転中止というだけあって、大変な悪路であった。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩ノ家というだけあって、庭いちめん、汀石の控えにまで萩を植えてある。",
              "citation": {
                "source": "ユモレスク",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "森林の伐採が始まれば、いつも木伐りの方を働くというだけあって、小屋掛けが好きで手慣れていた。",
              "citation": {
                "source": "鹿の印象",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭につづく十二人の舟子は、破船を見捨て、十町も沖から島に泳ぎ着いたというだけあって、いずれも倔強な連中ばかりであった。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎十郎は、うへえ、と顎をひいて、「お庭番というだけあって、なかなか思い切ったことをする。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「面目次第もござりませぬ、いやはや掏摸をはたらこうというだけあって、なんと身軽なやつで」「掏摸？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛瀑障りというのか、池のむこうの小滝を、楓の真木が一本、斜めに切るように滝壺のほうへ枝をのべ、萩ノ家というだけあって、庭いちめんにうっとうしいほど萩を植えこんでいる。",
              "citation": {
                "source": "野萩",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸好みの道楽者の福之助を、好きで配偶にしたというだけあって、この女にはなんとなく、気の知れない仇っぽさと、浮気らしいところの匂うのは、はじめて応対する平次にまで、焦立たしい媚を感じさせるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "凧の糸目",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のうちに、腕を切り落す外はあるまいと思うが、いかがでしょうな」　こう言われると、又次郎はすっかり蒼くなりましたが、父の又左衛門は武士の出というだけあって思いの外驚きません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "南蛮秘法箋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家は家号を「ねずみ屋」というだけあって、平素は白昼でも鼠が家の中を走り廻り、客のそばをも恐れる色もなく跳び歩いていたのに、地震の前日には、夜の更けるにつれて、鼠の数が減ったということである（加藤庸一、大地震の実況）。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九の厄というにしては初々しく、喜三郎が命まで投げ出そうというだけあって、お皆のような文法的な美人ではありませんが、いじらしく、優しく、潤いと光沢があって、なんとなく人好きのする娘でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "女の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はははは、二番の贋金使いの弥兵衛たらいう奴は、さすがに贋金でも使ってみようというだけあって話せる奴だわい、お寒いに御苦労さまでございますなんかと言って、袂の裾をふんわりと重くさせる奴さ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　教来石兵助のいまの家は、当主で二十何代目というだけあって、おそろしく古い建物だった。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「耳と目によるコロムビア音楽史」というだけあって、解説書に半分の重要さを持たせたものであるが、選曲はいずれも聴くに堪えるもので、楽しく味わう古典としては、この要領のよさに敬服せざるを得ない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど昔リヨンで踊り子をしていた時分に、伯爵に見｜初められたというだけあって、水々しい眸、魅力的な潤みを帯びた睫毛、どこか雌豹を偲ばせる嫋やかな脚！",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "千本というだけあって浜伝いは見霞む限り松原だ。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに小野氏の『啓蒙』などは、啓蒙というだけあっていつも心安く、物を尋ねに近よって行かれる。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
