          ],
          "literary": [
            {
              "text": "このような状況下では、全帝国における惰気倦怠の掃き溜め、このロンドンに私が居着くのは当然のことだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも着て寝た寝間着をたゝむにも、どことなく町中とちがつた朝の気分に、何だか自分が当分しつとりと居着くところへ来たやうな心持がするのは、かうした、いろんな人のごた／＼ゐない、たゞの家だからだらうか。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "目見得も済んで、翌日から私の家に居着くこととなった。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "享保十五年の正月、この島に居着くようになってから、十一年目ではじめて沖を行く帆影を見た。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かあの当時、二十年の後に自分が関西に居着くやうになることを予想しようぞ。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰文のほうは、いちどは素直に勅を受けたものの、もともとこんな潮くさいところに居着く気はない。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二五八九、二、二、午後七時）在浦安町（茫屋にて）　予は浦安町に居着くことになった。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱すぎるとか寒すぎるとか、高すぎるとか低すぎるとか息苦しいとかまあそういった場所であり、エクストリームスポーツの開催もちょっと、というような場所に居着く。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たとい半年ほどでもええ、暫く向うに居着く迄でも、こいさんが附いて行ったげる、云うたらその気になりはるかも知れん。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや呉の国へどうして居着くものですか。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "で結局僕は僕の心の虫をいつくしむんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつくしむよりほかどうしやうもあるもんか。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆつくりいつくしめば、いつくしんだだけ人様に対して反動を廻すとかなんとか、さういふ自他のけぢめを掻き毟つたやうな行為は少くなるんだし、自分としてもコクのある気分でゐられるんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひよつとしたら、仕事したなんて人は、自分の虫をいつくしみ了せた所から出発したのかもしれない。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を思いつくのは私の宿命です。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空が曇ったのか日が上野の山へかくれたか畳の夕日が消えてしまいつくつくほうしの声が沈んだようになった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中國の人をいやしめず、また、決して輕薄におだてる事もなく、所謂潔白の獨立親和の態度で、若い周樹人を正しくいつくしんで書くつもりであります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いつくままを書きました。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には、いつくしみのなかに味ひとつまみの小言もいれなくては完全な慈悲とはならないでしょう。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこが、あんまり急いで行くもんだから、小さな子どもらは、追いつくために、まるで半分｜馳けた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷風は『歓楽』の中で、「其の土地では一口に姐さんで通るかと思ふ年頃の渋いつくりの女」に出逢って、その女が十年前に自分と死のうと約束した小菊という芸者であったことを述べている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷風の「渋いつくりの女」は、甘味から「いき」を経て渋味に行ったに相違ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の学生時代の想い出のようなものでもいいからといわれるので、たださしあたり思いつくままを書くことにする。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音はかくも無性な激しい怒りとまといつく怖れのもつれあがるのをぶち切ったのだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "断然殺してしまわねば死ぬまでまといつくような蛇にも思われる。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこの夏期は夜番と云いつくろって父娘二人水泳場へ寝泊りである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく黙っていたが、跳ね返す警句を思いつく気力もなく、「兄弟分でもなんでもない、全く一つのものだ」　と低い声音に渾身の力を籠めて言った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "預金はとっくの昔に使いつくし、田畑は殆ど借金の抵当に入っていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつくらい他人のキタないところをいつもかつもさぐっている奴は少ないであろう。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この問題の解決に、われわれは、現在の幾人かの作家が闘争の現実に馳け足で追いつくことによって文学を推し進めようとするようなそんなケチなところに重点を置いてはならない。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
