      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "still having slim chances of victory",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "将棋の終盤、絶妙な合駒によって自玉は辛うじて生き体となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「この局面、苦しいながらもまだ生き体ですね」と大盤解説の棋士が冷静に分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "リーグ戦での連勝により、自力優勝の可能性を残す生き体の状態で最終節を迎える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "相手の猛攻を凌ぎきり、反撃の糸口を見出すための生き体を維持することに専念した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "創業以来の赤字続きではあるが、革新的な新技術の特許取得により、企業としての生き体を繋ぎ止めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "予選敗退の危機に直面していたが、他会場の結果次第で生き体となる望みが繋がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そうして、その天国とかいうところへのぼっていきたいわ」「そんなことを考えちゃいけないよ」と、おばあさまが言いました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、ぼくは、外の広い世の中へ、出ていきたいんです！",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは、子供のところへおりていきたいのだね」という声が、すぐそばでしました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校へもいきたいんだって。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし坊をよくいじめた酒屋の三ちゃんがいてもいいのってきいたらね、三ちゃんがいても、学校へいきたいって。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ下りていきたい。",
              "citation": {
                "source": "星の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "持っていきたい荷物は何もかも、信用できる配達人に頼んで今夜のうちに宛名なしでヴィクトリア駅まで急送させること。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリアへいきたい――」　いや、うわおいぐつがさっそくしるしをみせてくれたことは有りがたいことでした。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかはやくむこうへいきたいなあ。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだんに、だんだんに、どうぞして人間のなかまにはいっていきたいと、ねがうようになりました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもういちど、ひろい世界へ、カイちゃんをさがしに出ていきたいのです。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なんだかわからないが、ただいきたい。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "内容が濃いうえに、かなり注のいりそうな『書物の出現』は、書き込みで真っ赤にしながら読んでいきたい類の本でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "法制問題小委員会の中山信弘主査からは、今後「もし必要が生じましたら当然議論の対象になる」との、吉川晃著作権課長（当時）からは「今後、検討課題とするかどうか、議論をしていきたい」との回答があった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちじるしき境遇の相違は、とうていくまなくあい解することはできないにしても、なるべくは解し得るだけ多くあい解して、親友の関係を保っていきたい。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌が出てからは、人々は感情のあふれてくるままに、こうした人間の愛し合う世界を千年も続けて見ていきたい気を起こしたが、二条の院を出て四日目の朝になった源氏は、今日はぜひ帰らねばならぬと急いだ。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はいま日本に叙事詩が生れなければならない現実的な環境と必然性とを考へ当分この長詩の形式を追求していきたい考へです。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだいったとおり、二年四人に、一年四人、これだけしか決まっていない」「おれ、新しい寮にいきたいな」　と、服部がまた足を投げだし、「壁」によりかかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あと、何時間寝られるかな」「二時ちょっとまえだから、五時間だな」「高志、新しい寮にいきたい？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナーニおれの筆法からいけば、『夜間の突撃には喊声を上げず』だからおれは喊声を上げると、こうアマノジャクにいきたいのさ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高一はすぐにもとんでいきたいきもちでしたが、そんなことをすれば、またいっしょにつかまると思って、がまんしました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、私どもが、自分達の生活を少しでも民主的にして、文学も人間らしい文学を作っていきたいと思っております時に、昨日や今日の新聞は私たちに何を感じさせたでしょうか。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か世話してくれって、いつも訊いてるからね、貴方はどうかと思って」「ほう、そいつは有難いね、へえ、そうかい、おろくさん、そんなにお嫁にいきたいのかい」　ろくは、そう云われるのばかりを待って、先刻から坐っているようであった。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は中の君を心苦しく思召しながらも、新しい人に興味を次々お持ちになる御性質なのであるから、先方に喜ばれるほどに美しく装っていきたいお心から、薫香を多くたきしめてお出かけになった姿は、寸分の隙もないお若い貴人でおありになった。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "煩わしい気持ちに中の君はなるのであったが、どうにかしてこの人の恋をやめさせ、安らかにまじわっていきたいと思う心があるため、女房へも知らせぬようにさりげなくしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、営業は願い下げといきたいのに加え、売り込みを図るもの自体も難物である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校まで柔道や剣道をやっており、警察でも続けていきたいというスポーツマン。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々情報処理事業グループとしても、今後はこの分野を考えていきたいと思っているのですがいかがでしょうか」　情報処理担当役員の石井善昭がそう問いかけた相手が、大内淳義であることは出席者の誰にも明らかだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに新しいマシンでは、中心となる本体に加えてさまざまな周辺機器を用意していきたいという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに西は、二二歳の青年が社長を務め、ベーシックを売り物にアメリカで急成長しているマイクロソフト社と新しい会社を起こし、今後はソフトウエアの分野にも進出していきたいということだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
