[
  {
    "uuid": "4ff5604c-e0a5-5d00-ab22-e8b4d491f260",
    "entry": "生き体",
    "reading": {
      "primary": "いきたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
