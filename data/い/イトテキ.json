[
  {
    "uuid": "527efe56-65f5-5cf9-96ee-db8e4b26d331",
    "entry": "意図的",
    "reading": {
      "primary": "いとてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
