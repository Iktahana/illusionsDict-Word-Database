        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出船入り船帆影も繁き石の巻からそのお城下までへは、陸前浜街道を一本道に原ノ町口へ抜けて丁度十三里――まさかと思ったのに、およそ退屈男程気まぐれな風来坊も稀でした。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩竈の町は遠い昔から色の港で、出船入り船を迎うる女郎山の古い名が今も残っている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで秀吉は、行長の艦隊に命じて湖水に入り船から城を攻撃させたのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "寫すのは弟がやつてくれることにして、二人で行つてみると、いりふねばしのまん中でもう途方にくれてしまつた。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
