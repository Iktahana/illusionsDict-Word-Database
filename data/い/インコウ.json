[
  {
    "uuid": "362ef03b-955d-5564-8f23-8f38c6c0ba1b",
    "entry": "印行",
    "reading": {
      "primary": "いんこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "printing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで現にあの印行本にも余計な事は一切書き添えなかった。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあの印行本二冊のどこにもファウストの作者ウォルフガング・ギョオテの名が出ていぬと云う事実である。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて太田さんの事を言ったから、ついでに話してしまうが、太田さんは印行本の扉の枠とペエジの頭にある摸様とをかいて下すった。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一切経の印行を思ひ立つた坊主でございます。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白い印行が出來ますよ。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎の著した書で、存命中に印行せられたのは、ただ『護痘要法』一部のみである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし可笑しい事には、外題に慶安としてあるものは、後に寛文中に作ったもので、真に慶安中に作ったものは、内容を改めずに、後の年号を附して印行したものである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その四十四　日本の古医書は『続群書類従』に収めてある和気広世の『薬経太素』、丹波康頼の『康頼本草』、釈蓮基の『長生療養方』、次に多紀家で校刻した深根輔仁の『本草和名』、丹波｜雅忠の『医略抄』、宝永中に印行せられた具平親王の『弘決外典抄』の数種を存するに過ぎない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫子の書は既に印行せられたことがある。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは後明治七年に森｜枳園が蘭軒遺藁一巻として印行したものの原本である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍書刊行會は曾て抽齋の奧書のある喜三二が隨筆を印行したが、大正五年五月に至つて、又｜飛蝶の劇界珍話と云ふものを收刻した。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "米國のエドワルド、エス、モールス氏が、明治十二｜年に於て、初めて此所に遺跡を發見し、然うして大發掘を試みられた記事は『理科會粹』の第一｜帙として、東京大學法理文學部から印行せられてある。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "大森貝塚の發掘",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの侯伯には、食前方丈侍妾數百人をはぶきて、文教の助けとある浩瀚の書を印行せしもありき、今の世にはありがたかり。",
              "citation": {
                "source": "ことばのうみのおくがき",
                "author": "大槻文彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一千部限り印行、十八箇月内に完結の予定、と云ふ規定であつた。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ゆき子が、仏印行きの決心を固めたのも、かうした不倫から自分を抜けきりたい気持ちで、事がきまるまでは、伊庭夫婦にも、静岡の母にも、姉弟にも打ちあけなかつたのだ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ、仏印行きが本当にきまつてから、ゆき子は肉親にも知らせ、伊庭夫婦にも打ちあけた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に申述べた通り、唐時代から佛典は隨分盛に印刷されて居りますが、次の五代時代からは、佛典の外に儒書が印行される。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三世紀の半頃に、李奎報といふものが作つた『詳定禮文』の跋によると、當時鑄字を用ゐて、この書物を二十八部印行したことが記載してあります。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この書を印行するに際し、我等は先づ満鉄の諸君と、各地に於て歓待して下さつた人人との深大なる恩情に対して、心からの永久的な感謝を棒げる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "跋　本書の第三版を印行するに当って、我輩は本書第一版以下を閲読して懇切なる批評と指教とを与えられたる友人各位、就中男爵菊池大麓博士、織田萬博士および船山曄智君の好意に対して深厚なる謝意を表せねばならぬ。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十一年印行の時も、原本のまゝ出したに違ひない。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "耶蘇降生千八百八十三年米国聖書会社明治十六年日本横浜印行。",
              "citation": {
                "source": "接吻",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "波上宮の入口に近い護國寺には、かのペルリの時こゝに居つて英國の旗をあげ、基督教の傳道に從事し、遂に琉球語の聖書を印行した、ベツテルハイムの記念碑がある。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時はあだかも江戸開板の新聞紙が初めて印行されるというころに当たる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "凌霜子所藏の弘化年間印行の地圖を見るにワダツミと假名振りてあり。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説來訪者初板五千部印行すと云。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "依って印行の次第を記し以て序に代ふ。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶長四年（一五九九）の『孔子家語』、『六韜三略』の印行を初めとして、その後連年、『貞観政要』の刊行、古書の蒐集、駿府の文庫創設、江戸城内の文庫創設、金沢文庫の書籍の保存などに努めた。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "William Caxton 印行本、第四巻。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両腕は背にまわされ、多分しめていた兵児帯で後手に緊縛されているのだろう、その端がいんこう部に二まわりばかり堅くくくられている。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
