        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭師は、枯山水の庭に自然な風合いの石積みを施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方では、段々畑の境界に石積みがよく見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "増水に備え、川岸の護岸工事には頑丈な石積みが採用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "崩落した斜面を安定させるため、熟練の職人が石積みで補強した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古城の石積みは、数世紀にわたる風雪に耐え、今もその雄大さを保っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い村道脇の石積みが一部崩れ、通行の妨げとなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "石積みの技術は、石の形状や大きさを見極める熟練の眼が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "賽河原の石積みみたいなことを一生續けるつもりなのか。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "賽の河原の石積みとなった悪夢の互換ベーシック開発　Ｎ88―ＢＡＳＩＣやＮ―ＢＡＳＩＣと互換性をとるためには、中間コードとファイルフォーマットの仕様を知ることは絶対に欠かせなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが増設ボード化とＥＰＲＯＭという二重の保険をかけて古山が取り組んだ賽の河原の石積みのゴールは、この時点でもまだ先が見えなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが賽の神に石を手向けた名残か、どうか知らねど、蔵王山の賽の河原の石積みは、正しく御仏に縁を結ばうとするのであらう。",
              "citation": {
                "source": "石を積む",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚木とりに東の入江へ行くと、百石積みの船が一艘、浜に漂い着いていた。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たい何の爲に此處まで出向いて來るのか、酒を飮む奴の意地の穢さも命を賭けての彷徨であるといふのか、または何かを誤魔化さうとするためだか、私は間もなく痛い肚をかかへて防空壕といふものの石積みを始めた。",
              "citation": {
                "source": "巷の子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "やらねばならない石を動かす所作で、私の胃潰瘍はぷすぷす穴があきはじめたが、藥でおさへ、毎日根氣好く石積みをやつた。",
              "citation": {
                "source": "巷の子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　大川筋の船、大きいのは五百石、千石積みから、小さいのは釣舟、猪牙舟にいたるまで、虱潰しに調べあげられた結果、抜け荷を積んだ船が一｜艘発見されました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二町先に、陸地近く泊っているのは、灯も何にもない、二三百石積みの船です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "断わっても聞かれず、月はありながら提灯を持った僕に、別酒一樽を持たせて大平山神社の社を、左へ取って、石積みの鳥居を潜る時分、酔いが廻って主膳は陶然たる心持になりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二百石積みばかりでしょうか、かなり大きな船が二｜艘これはずっと沖にいるんです」　と休之助は云った。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物言わぬ石積みの大寺院に入って、オルガンの音を聞けば、心地いいもんだよ」「あなたが音楽で癒されるようには見えませんが」「見えんのは事実だ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく杯を与えて、「この船は、何石積みか」　と、質問した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この船は一体、何石積みか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この船は、七百八十石積みで、三本｜帆檣。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ、周馬のみならず、その時二百石積みの船がもろに傾いて、海水をすくうかと思われたほど、激しい震動を食ったのであった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
