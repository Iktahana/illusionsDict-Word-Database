          "literary": [
            {
              "text": "」　イントロダクションのところをもういちどききなおすと、ワラは、高志と慶一のほうにむきなおった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそ堂々たるイントロダクションではないか。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンポの緩やかな長いイントロダクション、続いて湖水の表のような冷静な第一楽章、アンダンテ、しかして作者はこの章と第二楽章との間に少くとも十二日間という休符を挿入するつもりだつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ツィゴイネルワイゼン』も弾いた、『ロンド・デ・ルタン』も弾いた、『イントロダクションとタランテラ』も弾いた。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気以前の心細い吹込みであり、かつピアノの伴奏で、その上一面に吹き込むために、小さいイントロダクションをカットしているが、その宏大な表現力と、火のような情熱に打たれない人はあるまい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々木　邦イントロダクション　私達の母校明治学園は字音、「飯が食えん」　に通じる。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
