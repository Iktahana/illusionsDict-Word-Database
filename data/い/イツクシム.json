          ],
          "literary": [
            {
              "text": "希望を持てないものが、どうして追憶を慈しむことができよう。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年には童がこの兎馬を愛ずるにも増して愛で慈しむたくましき犬あればにや。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は、だんだん老紳士に対する好感が増して行き、慈しむような眼ざしで青年の姿を眺めていると、老紳士は、暗黙の中にそれを感謝するらしく、「だが、よく、むす子さんを一人で置いて来られましたな。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きくなったな」　さも懐かしみ慈しむように顔を交る／″＼右左にやゝ傾けながら始めて見る娘ででもあるようにわたくしの顔を覗き見るのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、わたしはいつの間にかそれを透しておまえに寂しいものと、寂しいものを慈しむ厚いあたたかいもののあるのを感じて、だん／＼離れ難くなって来た。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "粋は仁に邇し、即ち魔境に他を慈しむ者。",
              "citation": {
                "source": "粋を論じて「伽羅枕」に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と娘を抱き寄せ、ごわごわした大きな手で、慈しむように娘の栗毛をなでた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の暑さは海辺の別荘へ、冬の寒さは暖かな山の温泉へ、何不自由なく過ごせる華やかな今の身の上――それに今の母は強いて綾子を欲しいと願つた程なのであつたから、それこそ玉のやうに大切に、吾子のやうに慈しむでゐるのであつた。",
              "citation": {
                "source": "秋雨の絶間",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その呪言は、〈我諸竜王を慈しむ、天上および世間、わが慈心を以て、諸｜恚毒を滅し得、我｜智慧を以て取り、これを用いこの毒を殺す、味毒無味毒、滅され地に入りて去る〉、仏曰く、この呪もて自ら護る者は、毒蛇に傷殺されずと。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私のそばに愛し慈しむものの共にあることを悦びます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹さんを、私はあわれに、いとしくおもい、仏の眼のうるおいと赦しとをもって、優しく、慈しむ気でいます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その有難い感じが、自分の生を一層愛し慈しむ感情が、死ぬべき者をも救うかもしれない。",
              "citation": {
                "source": "病室の幻影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と織江は驚き、かつは不安を感じたらしく、「いいえ妾もあなたとご一緒に……」「それが行けないのでございますよ」「織江殿」と貝十郎は、慈しむような声でいった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの善と悪とに感じる力を人間の心に宿る最も尊きものと認め、そしてこの素質をさながら美しき宝石の如くに愛で慈しむ。",
              "citation": {
                "source": "善くならうとする祈り",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの善と悪とに感じる力を人間の心に宿る最も尊きものと認め、そしてこの素質をさながら美しき宝石のごとくにめで慈しむ。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この友人に従へば、田巻安里は文学そのものを愛する以上に、「文学を愛すること」を愛し、引いて文学を愛する自分自身を慈しむのあまり、文学の本体を見失はうとしてゐるといふのである。",
              "citation": {
                "source": "田巻安里のコーヒー",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのヤス子の名をかたり、ヤス子の慈しむ少女をさらって暴行する、ヤス子は怒り、蔑み、私を捨てゝ去るであろう。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その稚さは、革命家にとっても、むしろ慈しむべきであろう。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は然し血のつながりを慈しむのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は、ただ現在の生をのみ慈しむ涙ぐましい心を懐いて、袷の肌にも寒いほどの夜更けに、火種さえない下宿の四疊半へ、ぼんやり帰っていった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりぼっちの男やもめが、深く慈しむ一人娘を、遙か遠く離れたデボンシャーという外国へ嫁がせるというのは、両親の気持ちがいかばかりか、察しがつこうというもの。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はあの妹が早く母に死に別れたのを不憫に思い、及ばずながら母に代って慈しむようにして来たのに、母の法事の時になって家から追い出すなどと云うことが出来るものでない。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛がった昔の女を今は娘のように慈しむあたたかさが、私たちにも自然の安堵と温情をわきたたせた。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "極楽トンボ」なかば叱るように、なかば慈しむ口調で、ハリーは僕を迎えてくれた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最高のようだね」　爺さんが慈しむような目つきで言った。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "で結局僕は僕の心の虫をいつくしむんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつくしむよりほかどうしやうもあるもんか。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は弱きをいつくしむ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黒檜」一巻、秘して寧ろ密かに我といつくしむべく、梓に上して些か我が真実の謬られむことをおそる。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院に来て、妻や子をいつくしむまことの我にかへりけるかな。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
