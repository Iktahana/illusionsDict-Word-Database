    "definitions": [
      {
        "index": 1,
        "gloss": "... and northward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この地図は、北緯40度線以北の地域を示している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼らの故郷は、この山脈以北に広がる広大な平原だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "沿岸警備隊は、国境線以北の海域をパトロールしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この村は、古くから交易路の要衝として、その以北への物流を支えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "槍ヶ岳以北は、見えなかったが、木曾駒ヶ岳は、雪の荒縞を着ながらも、その膚の碧は、透き通るように柔らかだ、恵那山もその脈の南に当って、雄大に聳えている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最も標本的に現われているのは、越中薬師岳（二九二六米突）、信州黒部の五郎岳（二八四〇米突）などで、一体に槍ヶ岳から以北、即ち立山山脈、または後立山山脈に頗る多い。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台以北は始めての旅だから、例により陸地測量部二十万分の一の地図を拡げて車窓から沿路の山水の詳細な見学をする。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷点に相当する等温線が大陸をほぼ東西に横断してその以北は雪、以南は雨が降っている、その雨と雪の境界に沿うて帯状をなした区域が凍雨や雨氷に見舞われている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この零度等温線とほぼ並行して風の境界線があり、その以北は北がかった風、以南では南風が吹いている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は靉河右岸に沿い九連城以北に工事を継続しつつあり、二十八日も時々砲撃しつつあり、二十六日｜九里島対岸においてたおれたる敵の馬匹九十五頭、ほかに生馬六頭を得たり――「どうです、鴨緑江大捷の前触れだ、うれしかったねえ、あの時分は。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京湾は甚だ広けれども品川以北中川以西即ち東京の前面の海上は大抵上に説けるが如し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "又た所謂たゞの博徒の種類で侠客と称するには足らぬか知らぬが、十年も前には女の親分さへ山形にあつた位で、福島以北にも可なりの博徒はあつたらしいが、何を云つても関東が一番盛んであつた。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも伊吹以北の峰つづきには、やはり千メートル以上の最高点がいくつかあるから、富士のような孤立した感じはないに相違ない。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸奥とは、もと白河、勿来の二関以北の総称であつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中里から以北は、全く私の生れてはじめて見る土地だ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　中岩より以北の道路は水をはなれるので景色は平凡になる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし鬼怒川の兩岸は、中岩以北も相當に太古よりの秋霖春漲に洗ひ出されて巖壁を露はしてゐることだらう、隨つて細かに川筋を見たら美しいところもあるだらうと思はれる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は羅馬以北の景を看て、その概ね皆陰鬱なるに驚きぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今東半球の赤道以北よりすら、甞て南米に漂著せる人の絶無ならざるを證する爲に、予の日記の一節を略ぼ原文の儘寫し出す事次の如し。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方の密室は赤道以北の住民には見る能わざる星を総称したものであろう。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反しインド以北では大いに持囃して福神毘沙門と敬仰さる。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒンズー教仏教ともにこの神を北方の守護神とし、支那には古く子は北方でその獣は鼠としたるに融合して、インド以北の国で始めて鼠をクベラすなわち毘沙門の使い物としたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岡俊明等このインド以北の支那学説とインド本土の経説の混淆地で作られた大乗諸経に見ゆるからとて、支那の十二支はインドから伝うなどいうも、インドに本五行の十二支のという事も、鼠を北方の獣とする事も、毘沙門の使とする事もない（『人類学雑誌』三四巻八号、拙文「四神と十二獣について」参看）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "北欧州やアジアのヒマラヤ以北に住み北欧のものは長十五インチ尾三インチ、常の鼠より大きい。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日關東以北の人が、活用言のヒとヘとをよく誤り、石をエシと發音するなど其遺習である。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は見ン事鐵嶺以北に退却した。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "貫通車の三等室、東京以北の總有國々の訛を語る人々を、ぎつしりと詰めた中に、二人は相並んで、布袋の樣な腹をした忠太と向合つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は見ン事鉄嶺以北に退却した。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "貫通車の三等室、東京以北の諸有国々の訛を語る人々を、ぎつしりと詰めた中に、二人は相並んで、布袋の様な腹をした忠太と向合つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（六月十六日）　名古屋を境界線としてこれより以東以北の地は毎朝飯をたいて味噌汁をこしらへる。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが京城は黄金通りを境界線として、その以北が純然たる朝鮮人街である。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二　物見岩八戸は、もと南部支藩のありたる處、人口二萬、盛岡以北、陸奧東部唯一の大都會也。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "始皇帝は天下一統の後ち、蒙恬を將として兵三十萬を率ゐて匈奴を征伐せしめて、悉く之を黄河以北に驅逐した。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "白粉で塗り隱した荒んだ肌、左の頬に拵へたわざとらしいほくろ、眉墨で縁取つた疲れたやうな眼の光、受け口のまつ赤な唇、まづい顏ではあつたが、相當の教育も受けたらしく、愛想交りにも日本の事を色色問ひ尋ねたりする女だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
