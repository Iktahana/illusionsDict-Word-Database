        "examples": {
          "standard": [
            {
              "text": "プロジェクトを成功させるには、メンバー間の密な意思疎通が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国際会議の場で、各国の代表は平和的解決に向けた意思疎通を重ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "思春期の子供とは、些細なことでも意思疎通を図ることが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヒューマンインターフェースの進化は、機械と人間の意思疎通をより自然なものに変えつつある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事故発生直後、現場と本部の意思疎通が一時的に途絶え、混乱が生じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "患者とその家族に対する丁寧な意思疎通が、治療への納得感を高める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "教師と生徒、保護者との間の円滑な意思疎通が、健全な学校生活を支える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "異文化交流では、言葉の壁を越えた意思疎通の努力が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "似たもの同士はそんな意思疎通が確かにできるからだ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
