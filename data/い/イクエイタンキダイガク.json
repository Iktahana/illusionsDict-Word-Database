        "examples": {
          "standard": [
            {
              "text": "育英短期大学は、地域社会のニーズに応えるため、新たな専門コースの設置を発表しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「来年、育英短期大学のオープンキャンパスに行ってみようと思ってるんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "育英短期大学の保育学科では、実践的なカリキュラムを通じて、即戦力となる保育士を育成しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域経済の活性化に貢献した卒業生を多数輩出している育英短期大学は、地域との連携をさらに深めています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "娘が育英短期大学への進学を決めたので、学費や奨学金について詳しく調べています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "育英短期大学の学園祭が、地域住民も参加できる催しとして開催され、多くの来場者で賑わいました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "教育学の研究者たちは、育英短期大学の教育メソッドが、学習者の主体性をどのように引き出すかに注目しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
