[
  {
    "uuid": "e588484c-9a4b-5c3c-a3d1-a5d52b447b18",
    "entry": "今はこれまで",
    "reading": {
      "primary": "いまはこれまで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
