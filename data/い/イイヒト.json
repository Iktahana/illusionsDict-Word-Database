          ],
          "literary": [
            {
              "text": "「おどさ」は、いい人でした。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實にＫ氏は、いい人だ、できた人だ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんないい人が、どうして死んだのだらう、と追悼記の一ばん前の頁をひらいて見ると、そこに、學院長Ｋ・Ｍといふ人の弔詞が在ります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「氣取らなけれあ、いい人なんだが。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は優しい、いい人でしたわ。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、用心のいい人は毒瓦斯に充ちた工場で平気で働き、不用心な人は大地で躓いてすべって頭を割るのであろう。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青空」も考へて見れば隨分いい人達を持つてゐた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫はそれを涼しいもののように眼を細めて恍惚と眺め入っていたが、突然野太い男のバスの声になって「そりゃ、貝原さんはいい人さ、小初先生と僕のことだって大目に見ての上で世話する気かも知れませんさ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その少し前に芥川龍之介さんの宅で初めてお眼にかかつて想像とはまるで違つた實に氣持のいい人｜柄に感じ入つたものだつたが、球突の相手としてあんな氣持のいい印象を留めてゐる人は先づ珍しい。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人は頭のいい人種である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　いわゆる頭脳のいい人はどうも研究家や思索家にはなれないらしい。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯のいい人は、おそらく、この卑近な幸福を自覚する僥倖を持たないに相違ない。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔自分達が若かった頃のクリスチャンのように妙に聖者らしい気取りが見えなくて感じのいい人達のようである。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふみが、Ｔ「あたしのいい人、今現れてもう消えちゃったわ」　と言って、Ｔ「仏さまもまんざら嘘はつかないものね」　太郎左衛門一寸出鼻をくじかれた態。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人も生れ落ちるとこの山で育ったので、何にも存じません代り、気のいい人でちっともお心置はないのでござんす。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる頭のいい人は、言わば足の早い旅人のようなものである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人は、言わば富士のすそ野まで来て、そこから頂上をながめただけで、それで富士の全体をのみ込んで東京へ引き返すという心配がある。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人は見通しがきくだけに、あらゆる道筋の前途の難関が見渡される。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の悪い人は、頭のいい人が考えて、はじめからだめにきまっているような試みを、一生懸命につづけている。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人には恋ができない。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人は批評家に適するが行為の人にはなりにくい。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人には他人の仕事のあらが目につきやすい。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人で人の仕事のあらはわかるが自分の仕事のあらは見えないという程度の人がある。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合にも頭のいい人は人間の頭の力を買いかぶって天然の無際限な奥行きを忘却するのである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかの若い生物学者や地質学者やみんなまじめで上品で気持ちのいい人たちであった。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は優しく、にぎやかな、いい人ですが、叔父さんの事になると、時々、父と言い争いを致します。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とお友達だった芹川さんは、女学校を出て三年目に、もういい人を見つけてお嫁に行ってしまいました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は、四十ちかい叔母さんで、顔が黒く、痩せていて、それでも優しそうな感じのいい人であった。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいいひとは、たいてい、こんな表情をしてゐるものです。",
              "citation": {
                "source": "黒石の人たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「子供の足でこれだけ、おとなの足でこれだけ」と、何も言わなくてもいいひとり言を大きな声で言うので困ってしまう。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
