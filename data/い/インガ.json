[
  {
    "uuid": "37bf0b98-a480-554d-894a-ccd61ed62683",
    "entry": "印画",
    "reading": {
      "primary": "いんが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(photographic) print",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "火が、ぴしぴし、音を立てて、盛に燃え出すと、樺の立木の葉が、鮮やかに、油紙の屋根に印して、劃然とした印画が炙り出される。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁を思わせるうす紅色で、雨気を含んだ虚空に、浸み透るように、暈して描かれた自分たちの印画は、この大なる空間を跨いで、谷間へと消え落ちた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の事を特に強い印象として焼き付けるだけの「光線」があったであろう、その光線はとうの昔に消えて、一枚の印画だけが永久に残っているのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうものの並んでいる間に散点してまた実に昔のままの日本を代表する塩煎餅屋や袋物屋や芸者屋の立派に生存しているのもやはり印画記録の価値が充分にある。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンズが肉体に化した木崎の写真は、印画紙からニヒリズムの体臭が漂うくらい、個性が強く、彼のねらう構図にはつねに夜が感じられて、ふとデカダンめいたが、今夜の陽子と茉莉の写真も「夜のポーズ」という彼の好みのテエマにふさわしかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、写真といえば写真器械によって撮影され現像されたもの、ハイカラにいえば印画のことだろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでなら、絵は紙やキャンバスの上、写真は印画紙、動画はフィルムやビデオテープ、音はレコードやＣＤと、それぞれ専用の〈器〉におさめられていた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字一字印画紙に文字を撮影していく写植オペレーターの都合を考えて、そんなときは、変化する字詰めに合わせて区切りを入れた原稿用紙に文章を書き写したりしました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字一字文字を選び、指定の字詰めに合わせて仕上げた印画紙を台紙に張り込み、訂正の求めに応じて手作業で文字の張り替えを進めます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラフなブロマイト印画紙のような肌は、もう近在から出る地卵とそっくりであった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "……恰度、あの写真の現像をする時にですね……私は、あれが道楽なんですが……赤い電気の下で、現像に夢中になっていると、不意に、直ぐ自分の横へ確かに置いた筈の赤い紙に包んだ印画紙が、どこかへ消えてしまって、すっかり面喰ってしまうことがよくありますね。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで三ちゃんは、水洗をいい加減にして急に乾かすと、それを印画紙にやきつけた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローランドの嬌笑は印画のやうに眼蓋の裏にあざやかだつたが、国元の妻子のことを思ふと、特に斯んな晩は凝つと怺へなければならぬとさとつて、手紙を書きつゞけた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこれ優等児製造はかくの如き文化性から生み出されるかという印象を与える雰囲気、画面の所謂芸術写真風な印画美であるが、私たち数人の観衆はこの文化映画として紹介されているもののつめたさに対して何か人間としてのむしゃくしゃが胸底に湧くのを禁じ得なかった。",
              "citation": {
                "source": "映画の語る現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこがカチリと印画になって納められているのである。",
              "citation": {
                "source": "昨今の話題を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぶしかった日光の反射は彼自身の印画を若過ぎるほど若く見せて、それが自分の旅人姿とも一寸受取れなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "頁から頁へと一つの印画から一つの印画へとそこに描こうとされた生活の各断面が十分の量感をもって展開されていて、そこからたちのぼって来る生活の息づきに、心持よく顔をふかれるような感じをうけた。",
              "citation": {
                "source": "ヴォルフの世界",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし印画に映つたのは大きい※といふ羅馬数字だつた。",
              "citation": {
                "source": "横須賀小景",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "同博士が自分の頭蓋骨と名付くる「天然色、浮出し、発声映画撮影機の暗箱」に取付けている二つの眼球のレンズと、左右の耳朶のマイクロフォンに、如何なる順序で、そうした事件の推移が印画されて来たかという事を、その順序通りに廻転して行くフィルムに就て説明して参ります。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手には写真の印画紙らしいものを二三枚もっているが、いま水から上げたばかりと見えて水滴がぽたぽた床のうえに落ちた。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにある」湯河原中佐が、クルクルと捲いてある細長い印画紙を机の上に、展げて見せた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者居村の風物を撮影したる印画数葉を插みて、趣を助く。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者は田舎を愛すれども、都会を捨つる能わず、心窃に都会と田舎の間に架する橋梁の其板の一枚たらん事を期すされば本書は信仰と趣味、理想と煩悩の間に徘徊※徨せる著者が懴悔の一片とも見るべく、又多感多情の著者なるレンズを透かして印象せられたる田園生活の印画とも見るを得べし。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンズの見るもの、すなわちそれは物理的屈折光線が印画面上にもたらす化学的変化であり、その集積がすなわちレンズの平面的構成の過程である。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらと視線が流れたばかりにすぎないはずが、まるで眼の中へ焼きこまれたと思はなければならないやうな強烈な印画で、××××××××××××××視野いつぱいにひろがり、部屋いつぱいの大きさにふくらみあがり、安川の顔へめがけてわッとおしつけてくるやうだつた。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その衰えた精神によつて特殊な加工を施され、現実以上の悪相と悪意を宿した股間の印画もいやなのである。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにのいんがに、このやうな、気づよいをとこが、まま、わしや、いとし。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり暢気でもがいんがな。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――闘牛は今はじまろうとして、全すぺいんがここに集って待っている。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞策がこれに報いんがために、『医心方』一巻を贈ったというのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
