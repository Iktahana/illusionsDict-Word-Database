        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "事故で片目を失い、彼は一隻眼となったが、日常生活には支障がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海賊の船長は、眼帯の下に一隻眼を光らせて遠くの船影を捉えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鳥は獲物を狙う時、動かないよう一隻眼でじっと見つめる習性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
