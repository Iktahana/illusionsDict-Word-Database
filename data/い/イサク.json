    "definitions": [
      {
        "index": 1,
        "gloss": "posthumous works",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "先日亡くなった画家の遺作展が、東京国立近代美術館で開催されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "生前、未発表だった楽曲群が、彼の遺作としてこの度リリースされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この小説は、作家が亡くなる直前に完成させた遺作であり、彼の集大成とも言える作品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "故郷の公民館では、彫刻家が遺した遺作を展示し、その功績を伝えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ええ、この遺作を観て、彼の晩年の苦悩が伝わってくるようです」と、鑑賞者は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の遺作からは、現代社会への静かな問いかけが感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "監督の遺作となったドキュメンタリー映画は、多くの賞を受賞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "床中で握りつめながら死んだといふ傷ましい形見の遺作であつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の数葉は氏の遺作集から恩地君が選抜した。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人情紙風船」が山中貞雄の遺作ではチトサビシイ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "親しかった人々は追悼会や遺作展覧会を開いてくれ、またいろいろの余儀ない故障のために親戚のものだれ一人片付けに行く事のできなかった遺物の処理までも遺憾なく果たしてくれた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死後私は遺作の數々を讀まして貰つて、生前會つておくべき人に會はずにしまつたといふ憾みを覺えることが深い。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつおまえさんあれを一手に引き受けて遺作展覧会をやる気はありませんか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて私は、書簡もなければ日記もない、詩十篇ぐらいに訳詩十篇ぐらいの、いい遺作集を愛読したことがある。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というのは亡兄の遺作（へんな仏像）に亡兄みずから附したる名前であって、その青色の二尺くらいの高さの仏像は、いま私の部屋の隅に置いて在るが、亡兄、二十七歳、最後の作品である。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の三造には、伯父の遺作を図書館に寄贈するのを躊躇する心理的理由が、もはや余りにも滑稽な羞恥としか映らない。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松田優作の遺作となった「ブラック・レイン」を撮ったリドリー・スコットは、都市を支配する足し算と引き算の大原則をよく理解した監督だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "片多徳郎遺作展　春台展での片多徳郎遺作展は僕を感動させた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一言、春台展では片多徳郎、丹野次男、平田千秋の三人遺作展をやつてゐるが、それも非常に良いことである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "この感は遺作を列べてゐる三岸好太郎の諸作にも同様のことが言へる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "三岸好太郎　この室には三岸の遺作が列んでゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年前までは椿岳の旧廬たる梵雲庵の画房の戸棚の隅には椿岳の遺作が薦縄搦げとなっていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、椿岳の最も勝れた蒐集が烏有に帰したといっても遺作はマダ散在している。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺作としては大きさ二尺位の文殊の像がありましたけれども、学校の火事の時焼失しました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "西町時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は立たなければなりませんでした　丁度その時、上野の竹の台では洋画家の日本画の展覧会と青木繁氏の遺作展覧会がやつてゐました。",
              "citation": {
                "source": "書簡　木村荘太宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "楳嶺先生の一周忌でしたか三周忌でしたか、御苑内で遺作と一緒に弟子孫弟子の作品を並べたことがありまして、そこに出された栖鳳先生の六曲一双「蕭條」は、水墨で枯柳が描かれたものでいいものでした。",
              "citation": {
                "source": "昔のことなど",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京での帝展見物のついでに、物故作家の遺作展を見てまいりましたが、婦女風俗としての絵は殆どなかったと思います。",
              "citation": {
                "source": "虹と感興",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "納められた中の和歌は数こそ尠かったがどれもみな高次郎氏の遺作ばかりだった。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日　狩野芳崖遺作「悲母観音」を見る。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "心理学の月謝のことと、公開講義のこと、芳崖翁の遺作のことについて御話をして来る。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユウゴオを記念する小博物館として大抵の遺作、遺品、故人の著作に挿んだ絵の下絵、著作の広告に用ひた絵、其他故人に関係ある雑多の物が陳列されて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二月二十七日）芝居の後　ユウゴオの百十回の誕生日（二月廿六日）の晩、文豪の遺作「楽める王」がコメデイ・フランセエズで演ぜられ、ムネ・シユリイのサン・ンの茶坊主ツリブレ、フヌウのフランソア一世と云ふ、仏蘭西現代の劇壇で全く申分の無い役割であつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが為にその這ふ影の、軽やかに優しからまし」といふ文豪の遺作が刻してあつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は「自分の弟子で若くて歿した日本人を知つて居るか」と問はれたので、僕等は生前に交際しなかつたが其遺作を屡観た事を告げると、翁は「彼は自分の許へ度度来たのでは無かつたが、彼は善く自分の製作を観て自分の芸術の精神を領解した。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオリスの遺作は、作品としては“Le Centaure”と“La Bacchante”の二篇の散文詩が目立つてゐる他は、斷片的なもののみで、むしろ日記や手紙に獨自なるものがある。",
              "citation": {
                "source": "モオリス・ド・ゲランと姉ユウジェニイ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の用件というのは、――最近、私の恩師であるＡ氏の遺作展覧会が催されるので、夫人の所有にかかわるところの氏の晩年の作品の一つを是非とも出品して貰おうがためであった。",
              "citation": {
                "source": "窓",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼童思慕詩篇肖像あいつはいつも歪んだ顔をして、窓のそばに突つ立つてゐる、白いさくらが咲く頃になると、あいつはまた地面の底から、むぐらもちのやうに這ひ出してくる、ぢつと足音をぬすみながら、あいつが窓にしのびこんだところで、おれは早取写真にうつした。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
