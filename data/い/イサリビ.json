          "literary": [
            {
              "text": "果して漁り火だった。",
              "citation": {
                "source": "村芝居",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その中にたった一点、沖の漁り火のように赤く小さく瞬くものがある。",
              "citation": {
                "source": "母を恋うる記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月明の海上にチラチラと漁り火のように見えだしたのも烏賊採り舟ではありません――、あれは関所のお船手と、早川番所につめている大久保加賀守小田原の人数です。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
