[
  {
    "uuid": "09218a77-f8fc-5966-8197-19f8535f84c9",
    "entry": "生きて帰る",
    "reading": {
      "primary": "いきてかえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
