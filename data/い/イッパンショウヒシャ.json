        "examples": {
          "standard": [
            {
              "text": "メーカーは一般消費者からのフィードバックを重視している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その商品は一般消費者向けに価格設定されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一般消費者のニーズを把握することが、新商品開発の鍵だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誤解を招く広告は、一般消費者の信頼を損なう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第一のルートは、一般消費者をターゲットとして、マルチメディア機能を持たせたマッキントッシュを開発していく道だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、私は生産者の責任よりも消費者の責任を高調し、一般消費者の責任よりも特に富者の責任を力説したのである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロックンロール産業は、アーティストにとってもまた一般消費者にとっても、資本主義下での詐欺的利益追求行為の典型となることができる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
