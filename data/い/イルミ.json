        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "博覧会のイルミネーションを観て昔の行灯時代の事を想えば、今更のように灯火の進歩に驚かれる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は毎日のやうに池の端の會場へ行き、夜になればイルミネーシヨンの輝やく不忍池畔で、龍宮の形をした場外の酒場へ飮みに行つた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "至る所のイルミネーシヨン。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根の根の細かな繊毛のその岐れの殆ど有るか無きかの毛の尖のイルミネエション、それがセンチメンタリズムの極致とすれば、その毛の尖端にかじりついて泣く男、それは病気の朔太郎である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トララ　トララ　トララ　トララ　緑色のイルミネェション、青い眼鏡に穴をあけながら、水の上を進んで行く。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夜間の遊覧飛行イルミネェーションで作られたファンタジツクな科学の尻尾、――妻にたいする愛を結びつけて、……。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの広告のイルミネーションが、せわしなくまたたきをするたびに色がぱっぱっと変わる、そのように私の頭の中でもいろいろの考えがまたたくように明滅した。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがちょうどたとえば仕掛け花火か広告塔のイルミネーションでも見るような気がしてならないのである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "店をイルミネーションで飾るでもなし、英字新聞の大陸版へ広告を出すでもなし、表の構えは普通に塗った木目の板で囲い、ただ内側だけ気持よくこしらえてしとやかに客を待つといった風だ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜目には黄と黒の横縞に感じられる四階建ての店で素手に指環だけ一つ残したような小さい入口の上に foyot の屋号と二筋三筋のイルミナシヨンの細描きがあっさり浮き出ている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると、町じゅうにイルミネーションがつきました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "色とりどりの美しいイルミネエションの中に陽気な広告の楽隊が鳴り響いていた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「絵葉書に針でもってぷつぷつ穴をあけて、ランプの光に透かしてみると、その絵葉書の洋館や森や軍艦に、きれいなイルミネエションがついて、――あれを思い出さない？",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒猫がゆく、屋根の廂の日光のイルミネエシヨン。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』男が丘の上へ登りきつて了ふと、今まで目にも見えなかつた沖の小舟が、黒胡麻のやうにチラ／＼、チラ／＼、遥かに一列綴られてゆく、千も万も、幽かに幽かに、――生活むきが立たねば、夜も遅くまで、泣いて烏賊つる、その舟の火の、やゝありて、イルミネエシヨン。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "靄に点くイルミネーシヨン、高架線、すれちがふ省線電車、ああ、スパーク、師走月、風も吹く、風も吹くなり。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三回の訪問は五月のなかばの日曜日で、わたしは午後七時ごろに上野行きの電車を降りると、博覧会は夜間開場をおこなっているので、広小路付近はイルミネーションや花瓦斯で昼のように明るかった。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤、青、緑、いろいろの電球をズックの天井の下につるし並べてイルミネーションをやる。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫木蓮は若葉のにぎやかなイルミネーションの中からはでな花を咲かせる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫木蓮は若葉の賑かなイルミネーションの中から派手な花を咲かせる。",
              "citation": {
                "source": "木蓮",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物全体をイルミネーションで包み、飾窓には、これから顔を見せにくるはずのシネマスターの大きな写真が何枚も貼り出されてあった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の夜には燃えるように見える池のむこうの活動写真のイルミネーションは、月の光にぼやけて見えた。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにして月はイルミネーションとして君を飾る君の沿岸に咲く野花のなんとことごとく君の為めの花輪であらう、すべてを冷静に眺めてきたヴォルガよ、沈着な河、ヴォルガよ、君はいま歴史を貫く国を貫ぬいてゐる、正義の河と言へるだらう。",
              "citation": {
                "source": "小熊秀雄全集-5",
                "author": "詩集（４）小熊秀雄詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草は今では活動写真館が軒を並べてイルミネーションを輝かし、地震で全滅しても忽ち復興し、十二階が崩壊しても階下に巣喰った白首は依然隠顕出没して災後の新らしい都会の最も低級な享楽を提供している。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関ホールからの光と、トゥリーのイルミネイションだけが、サロンを照らす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内外各所の活動写真館は続いてイルミネーションを付けた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新世界の夜を飾るイルミネーションを、彼女達はベツレヘムの星と仰いだ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時、金、生活、享楽――即ち物資文明の産物たる東京のバラック、イルミネーション、エレベーター、店頭装飾、そのようなものの間を駈けめぐる電車、自転車、荷車、汽車、オートバイの響は砂煙を上げ、天地に轟きつつ、まだ気の弱い、生れ立ての職業婦人たちの神経を戦かした。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
