        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのサッカー選手は、劣勢の場面でも臆することなくボールを奪いに行く勇み肌だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は度重なる失敗にもめげず、新たな事業に果敢に挑戦し続ける勇み肌として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "戦国時代の武将としては、後退を知らぬ勇み肌の武将が、しばしば敵陣深くまで切り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫だって！僕が先頭で行くから、みんなついてきて！」と、彼はいつも勇み肌なところを見せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その政治家は、改革断行のために反対勢力に真っ向から立ち向かう勇み肌の姿勢を貫いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は危険な状況でも冷静さを失わないタイプではなく、どちらかというと勇み肌で、後先考えずに突っ走る傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "唯だ日本の侠客、少くとも勇み肌の人間に対し、「水滸伝」が陰に陽に感化を与へた、其の勢力の莫大なことを看過する訳には往かぬ。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言の方ではえてして、あの類の勇み肌が勝つことに筋が仕組まれておりまするが、啖呵では勝ちましても、本身の刄先が飛び出したとなりますると、筋書通りに参りますまいかと思いまする」「いや、そうでない。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "初松魚　鎌倉を活きて出でけん初松魚の魚河岸についたとあれば、棒手ふりまでが気勢いにきおって、勇み肌の胸もはだけたまま、向鉢巻の景気よく、宙を飛んで市中を呼び歩く。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来が裸一貫の力ずくでやる勝負の見物に、屋根も天井もいったものかは、青空を頭に戴いて小屋も土俵も場所場所に新しくものしてこそ、六根清浄、先祖の宿禰にも背かぬというもの、こうなっては行く行く相撲は江戸ッ児の見るものでなくなるかも知れないと、そんじょそこらの勇み肌が中ッ腹でいるそうな。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいがい彼等は饒舌家で、道楽者で、勇み肌で、堂々たる恰幅をしている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "世がくだるにしたがつて、それが表面化し、勇み肌といへば、職業的な任侠の徒や、見得を大切にする根性になりさがつたが、大根はいまいつたやうなところにあつたのだ。",
              "citation": {
                "source": "初かつを",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、鐵火とは、卷き舌で、齒ぎれのよい肌合を差していつたものだが、氣のあらい勇み肌のなかでも、鐵火といはれるのは、どうしたことかすこし下品さをふくんでゐる。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのべらんめえと来たら、勇み肌の坊つちやんだから愛嬌がありますよ」「増給がいやだの辞表が出したいのつて、ありやどうしても神経に異状があるに相違ない」おれは窓をあけて、二階から飛び下りて、思ふ様打ちのめして遣らうと思つたが、やつとの事で辛防した。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい」「おい」「来たぜ」「とう／＼来た」「是で漸く安心した」「野だの畜生、おれの事を勇み肌の坊っちやんだと抜かしやがつた」「邪魔物と云ふのは、おれの事だぜ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのべらんめえと来たら、勇み肌の坊っちゃんだから愛嬌がありますよ」「増給がいやだの辞表を出したいのって、ありゃどうしても神経に異状があるに相違ない」おれは窓をあけて、二階から飛び下りて、思う様｜打ちのめしてやろうと思ったが、やっとの事で辛防した。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい」「おい」「来たぜ」「とうとう来た」「これでようやく安心した」「野だの畜生、おれの事を勇み肌の坊っちゃんだと抜かしやがった」「邪魔物と云うのは、おれの事だぜ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリイ・シェイケビッチ夫人のプルウストに就いてのクロッキによりますと、病弱の彼も然し却々の勇み肌で、あるとき夫人をさらふやうにしてシロといふ料理店へ連れ込みました。",
              "citation": {
                "source": "かげろふ談義",
                "author": "――菱山修三へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "察するに、プルウストの御婦人とのお近づきぶりは、君にちよつと勇み肌をつけたすと、ほぼ同じ恰好になるらしいですね。",
              "citation": {
                "source": "かげろふ談義",
                "author": "――菱山修三へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "常連の一人に相馬といふ友禅の板場職人がゐて、山本宣治の葬式の先頭に赤旗を担いだ男で、勇み肌の正義感から時々逆上的な喧嘩をしたが、凡そ憎めない男がゐた。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇み肌の妙信は、当の安川や村山よりも義憤に燃えて、京二郎に決闘を提議したのも彼であつた。",
              "citation": {
                "source": "決闘",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんばらなくちゃアいけないのだぞ、人間はな」　ちょッと勇み肌めいたところがタヨリなくはありましたが、それはまたちょッと神々しいものでもあったのです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大竜は小心ヨクヨクたるところもあるが、オッチョコチョイの勇み肌もあって、小さいのや女の子におだてられても気をよくしてのぼせあがる性分だった。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犬小屋には小さくて臆病だが自宅の前でだけはメッポー勇み肌のテリヤの雑種が住んでいたから、思いがけない闖入者に慌てふためいて、お奈良さまの足にかみついたのである。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だましてやるには手ごろの勇み肌のニューフェースなのである。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、持つてゐる力をどれだけ出してゐるかと云ふと、大山は十分に出しきつて、ほとんど余すところなく、升田は勇み肌でポカも打つ。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊ちやん」を無学にしたやうな、正義派で、勇み肌の快人物だが、この碁会所の創設から肩を入れること並々でなく、宣伝のために京都中を駈まわつたものだ。",
              "citation": {
                "source": "囲碁修業",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "高野さんは勇み肌だが、人徳があるので事が荒立たない。",
              "citation": {
                "source": "囲碁修業",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しもともと他巳吉は他人のことに自ら進んで一肌ぬぐといふやうな勇み肌の親切気は、まつたく持合せがなかつたのである。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病故の勇み肌も同じことで、日本犬以上にケンカをしたがる。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この調子では今にトマトの寿司、コンビーフの寿司、サンドイッチの寿司、トンカツの寿司など、創意創作がむやみやたらと現われ、江戸前を誇った勇み肌の寿司屋など跡を絶たねばならなくなるだろう。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「覚えていやがれ、そんな事をすりゃあ手前んとこの屋根にペンペングサを生やしてやるゾ」と勇み肌の江戸ッ子はよく文身体の尻を捲って啖呵を切ったもんだけれど、実は屋根の上には余りペンペングサは生えないものである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで支度は出来たものと思込んで土間へ下りると、「おっと待った」と、初さんがまた勇み肌の声を掛けた。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつはどんな風をしているのです」　勇み肌の職人体の男が、役者を弥次る様な声で怒鳴った。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
