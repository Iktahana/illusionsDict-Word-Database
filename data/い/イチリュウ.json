[
  {
    "uuid": "b7860128-9a34-5a34-ae1c-27da1b94f21e",
    "entry": "一流",
    "reading": {
      "primary": "いちりゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
