          ],
          "literary": [
            {
              "text": "そんな奇麗な手のお手紙を貰つた女の人が、此の世の中に幾人あるのか知ら？",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この忌々しい病気の為に、過去に僕は幾人かの友人を無くしてしまい、愛する人を意外の敵に回してしまった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなバスケットや信玄袋の中から取り出した殘りものゝ鹽煎餅やサンドウイッチを片付けて居た生徒達の一人が、さういふものゝ包紙を細かく引き裂いては窓から飛ばせ始めると、風下の窓から手を出して其れを取らうとするものが幾人も出て來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾人の神人や人間が、この女神に恋をしたことであるだろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは数週前いきなり掲示場にはりつけられた〔〕われらはわれらの信ぜざることをなさず　といった風の宣言めいたものの〔〕十幾人かの聯名のその最后に記された富沢であった。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学位を取った日から勉強をやめてしまうような現金な学者が幾人かはあるとしても、それは大局の上から見ればそう重大な問題ではないであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう主張は実は単なる言詞としては決して新しいものではないだろうが、日本画家で実際にこの点に努力し実行しつつある人が幾人あるという事が問題である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう点だけでも自分の見るところでは津田君と同じような人が他に幾人求め得られるか疑わしい。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公｜爵、男｜爵、老政客、天文學｜博士、實業家など、藝苑では一時｜的に中村時｜藏や千｜葉早智子なども住んでゐたし、シロタやトドロヰッチ夫人のピアノ彈奏を立ち聽きした事もあるし、所謂見｜越の松｜風の淑女も幾人か住むといふやうな物｜靜かな屋｜敷町でもある。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾人かの修道士は時時靜かに廊下を往き來した。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪なくして、薄暗い牢獄に投じられた者が幾人あることか！",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――このうちから幾人かはシベリアに残されるんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁蒲団も毛布も幾人かの血や膿や汗で汚されていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等と一緒に兵タイに取られ、入営の小豆飯を食い、二年兵になるのを待ち、それから帰休の日を待った者が、今は、幾人骨になっているか知れない。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この問題の解決に、われわれは、現在の幾人かの作家が闘争の現実に馳け足で追いつくことによって文学を推し進めようとするようなそんなケチなところに重点を置いてはならない。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "己がモデルだと自称する人が幾人も出て来たりする。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "如才はあるめえが、御符売りが幾人いて、それがどんな奴だか、よく洗って来なけりゃあいけねえぜ」「ようがす、受け合いました」　ひょろ高い男のうしろ姿が山下の方へ遠くなるのを見送って、半七は神田の家に帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、今までに幾人も通ったが、北の方からきこえて来るその足音がどうも待っているものであるらしく直覚されたので、半七は咳きの合図をすると、塀の横手からもその返事があった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わっしもそこが大切だと思って近所の者によく訊いてみたり、お由という女中が外へ出るところを捉まえて、それとなく探りを入れて見たんですが、まったく誰も出這入りをするらしい様子がないんです」「夜になって祈祷をたのむ奴が幾人ぐらい来る」「それがこの一と月ほどは一人も来ねえそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の文學が、でたらめとか、誇張とか、ばかな解釋をなさらず、私が窮極の正確を念じていつも苦しく生きてゐるといふ事をご存じの讀者は幾人あつたらうか。",
              "citation": {
                "source": "『富嶽百景』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、一年半ばかりのうちに彼は、ロシア人を殺し、ついにはまた自分も殺された幾人かの同年兵を目撃していた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、幾人あるかしれないだろう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾人か、幾十人かが最も猛烈な黄燐の毒を受けて、下顎を腐らしてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千倍という顕微鏡は、数も少くまたこれを調節することができる人も幾人もないそうです。",
              "citation": {
                "source": "手紙　三",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、ジュール・ラフォルグの詩にあるように哀れなるかな、イカルスが幾人も来ては落っこちる。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れなるかな、イカルスが幾人も来ては落っこちる。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前述のような理由で音声の音色が変わる事と、反射面に段階のあるために音が引き延ばされまた幾人もの声になって聞こえる事と、この二つの要素がちゃんとつかまれていたからである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の幼時に愛した木版の東海道五十三次道中｜双六では、ここが振りだしになっていて、幾人ものやっこのそれぞれ長い槍を持ってこの橋のうえを歩いている画が、のどかにかかれてあった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全部、やめるつもり、……」大男の文士は口をゆがめて苦笑し、「それは結構だが、いったい、お前には、女が幾人あるんだい？",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ世界十幾億万人の中、平気な人でないものが幾人ありましょうか、詩人、哲学者、科学者、宗教家、学者でも、政治家でも、大概は皆な平気で理窟を言ったり、悟り顔をしたり、泣いたりしているのです。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
