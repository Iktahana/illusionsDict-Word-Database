    "definitions": [
      {
        "index": 1,
        "gloss": "dwarf",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "草むらからひょっこり現れたその小人は、まるでお伽話の一寸法師のような愛らしさだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、そんな一寸法師みたいな小さな道具で、この大きな壁を直すつもりか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は同級生の中で一番背が低いが、知恵と勇気は一寸法師に負けないほど備わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それで、事によるとこれらの一寸法師はわれわれの一秒をあたかもわれらの十秒ほどに感ずるかもしれず、そうだとすれば彼らはわれわれのいわゆる十年生きても実際百年生きたと同じように感じるかもしれない。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸法師が尨大なメガフォーンをさしあげてどなっているような感じがある。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやしのなかにふる霧は、　蟻のお手玉、三角帽子の、一寸法師のちいさなけまり」　霧がトントンはね踊りました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……蓬々と延びた髪の毛……無性ヒゲ……ボロボロの浴衣……結び目をブラ下げた縄の帯……瘠せ枯れた腕……灰色のホコリにまみれた素跣足……そんなものの黒い影が、一寸法師のように、眩しい地面に這いついていた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大丈夫、大丈夫、」　と民弥はまたわずかに笑を含みつつ、「仲の町越しに、こちらの二階から見えるんだから、丈が……そうさ、人にして二尺ばかり、一寸法師ッか無いけれど、何、普通で、離れているから小さいんだろう。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「踊る一寸法師」では、その材料のステキサと、ノロノロと推移するリズムの詩的？",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の世界を離れた高山に思いがけなく一寸法師の夫婦が子供を一人養っているのを発見して撮影している。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるところでその頃江戸川氏が『東京朝日』に連載していた「一寸法師」の話が毎晩あるグループの話題に出て、興味をもって事件の成り行きを注視していたそうだ。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「一寸法師」は読まなかったから、その結末がどんな風であったかは知らぬ。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし「一寸法師」の結末が「陰獣」の結末と同巧異曲のものであったとしたら、読者が「怒り出した」という気持ちはわかる。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "『一寸法師』などはその所産だが、必ずしも、『一寸法師』を書くためにではなく、そうした情景が彼には気に入るらしい。",
              "citation": {
                "source": "江戸川乱歩",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "『心理試験』の中におさめられたもの以後では、私は、「屋根裏の散歩者」「一人二役」「踊る一寸法師」などを読んだに過ぎない。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一人二役」や「踊る一寸法師」などは、着想においては、それほど奇抜ではなく、誰でも思いつける程度のものであるが、それをあれだけ念入りに、巧みに、書きこなす手腕は、大抵の人には期待できないことである。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、「踊る一寸法師」のような、凝った、丹念にみがきをいれた作品に対しても、これきりかというような軽い不満をさえ感じはじめるのである。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸法師　元の至元年間の或る夜である。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、わたくしが昨夜泥酔して帰ったことは宿の主人も知っていますし、第一わたくしは一寸法師といっても好いほどに背が低い上に、髯などはちっとも生やしていないで、人相書とは全く違っているものですから、官兵は碌々に取調べもしないで立ち去ってしまったのです。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "「闇に蠢く」「湖畔亭事件」この二長篇は実の所、全部通読して居りませんので、ここでは寸感をはぶくとし「火星の運河」「踊る一寸法師」「お勢登場」「鏡地獄」等は皆通読致しました。",
              "citation": {
                "source": "探偵文壇鳥瞰",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と富江は笑つて、『誰がまた、那※一寸法師さんを一人前の人｜待遇にするもんですか。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに「一寸法師」に於て本格小説の手腕を鮮かに見せた氏は、きっと、次から次へと、大作を発表して、私を喜ばせてくれることを信じてやまない。",
              "citation": {
                "source": "江戸川氏と私",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れは利己的な、一寸法師の「我」が探求する事なのではないのだ、と想う。",
              "citation": {
                "source": "断想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭でつかちの一寸法師見たいなやつでね、夫がフロツクに緋天鳶絨のチヨツキと云ふ拵へなんだから、ふるつてゐたよ。",
              "citation": {
                "source": "南瓜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦もあきらめて、その子に一寸法師と名前をつけました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸法師は五つになっても、やはり背がのびません。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十を越しても、やはり一寸法師でした。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸法師が往来を歩いていると、近所の子供たちが集まってきて、「やあ、ちびが歩いている。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸法師はだまって、にこにこしていました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　一寸法師は十六になりました。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日｜一寸法師は、おとうさんとおかあさんの前へ出て、「どうかわたくしにお暇を下さい。",
              "citation": {
                "source": "一寸法師",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
