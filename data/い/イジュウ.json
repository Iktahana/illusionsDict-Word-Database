    "definitions": [
      {
        "index": 1,
        "gloss": "migration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "都市部から地方への移住を支援する制度が、人口減少に悩む多くの自治体で導入されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は長年の夢だった海外移住を実現するため、現地の言語習得と資金調達に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦後の混乱期、多くの日本人が新天地での成功を夢見て南米の広大な土地へと移住した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テレワークの普及を機に、都心を離れて自然豊かな環境への移住を真剣に検討する世帯が急増した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「定年後は夫婦で暖かい島に移住して、のんびりと趣味の釣りを楽しみながら暮らしたいね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深刻な干ばつに見舞われた地域の住民たちは、生き延びるために隣国への移住を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父の代にこの開拓地へ移住してきて以来、我が家は三代にわたってこの土地を耕し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "何事も、一切の係累を捨ててしまつて、遠く南米の天地に移住したいと語つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが作楽井をして小田原から横浜市に移住した長男の家にかかるよりも熱田住みの次男の家へかからしめた理由なのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "体験としての存在様態が模様に客観化される例としては、ドイツ民族の有する一種の内的不安が不規則的な模様の形を取って、既に民族移住時代から見られ、更にゴシックおよびバロックの装飾にも顕著な形で現われている事実がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし中等学校を卒業しないうちに学校生活が一時中断するようになったというのは、彼の家族一同がイタリアへ移住する事になったのである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の諸国にあるこの種の部落的タブーは、おそらく風俗習慣を異にした外国の移住民や帰化人やを、先祖の氏神にもつ者の子孫であろう。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "移住する彼の家　（本庄陸男氏）　讀み憎い作品だ。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "題材はある小作人の一家が先祖代々耕して來た土地を住み切れず、カラフトへ移住してゆく顛末を書いたのであるが、その晦澁を讀みこなせば描寫は甚だ通一遍で、眞に農民の生活のなかから書かれたものとしては首肯し難いものがある。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "移住者という題なのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "不毛の地に最初の草の種が芽を出すと、それが昆虫を呼び、昆虫が鳥を呼び、その鳥の糞粒が新しい植物の種子を輸入する、そこにいろいろの獣類が移住を始めて次第に一つの「社会」が現出する。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によると、昔のある時代に繁茂していた植物のコロニーが、ある年の大噴火で死滅し、その上に一メートルほどの降砂が堆積した後に、再び植物の移住定着が始まり、その後は無事で今日に到ったのではないかという気がする。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は、土地も、家も、家畜も売り払って、東三省へ移住した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの者が移住した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その移住の途中で、行軍する暴兵に掴まって、僅かの路銀を取りあげられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろくな元資も持たず七年前に富山から移住してきた男だったが、水田にかけては経験もあるし、人間もばかではないようだったから、……その……何んとかいったなあもう一人の養子は……何んとかいった、それにわしが推薦したのがもとになったんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しあすこの土地に人為上にもっと自由が許されていたならば、北海道の移住民は日本人という在来の典型に或る新しい寄与をしていたかも知れない。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは外国へ移住して行く農夫の一家でした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれまで一年三箇月間、津軽の生家で暮し、ことしの十一月の中旬に妻子を引き連れてまた東京に移住して来たのであるが、来て見ると、ほとんどまるで二三週間の小旅行から帰って来たみたいの気持がした。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等のあわただしい移住は、それは何も僕たちに関係した事では無いかも知れないけれども、しかし、君のその「ノオ」の手紙が、僕と君が上野公園で別盃をくみかわしたあの日の前後に着いたとしたら、この菊屋一家の移住は、それから四、五日後に行われた事になる。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬えば移住民が船に乗って故郷の港を出る時、急に他郷がこわくなって、これから知らぬ新しい境へ引き摩られて行くよりは、寧ろ此海の沈黙の中へ身を投げようかと思うようなものである。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春になったら房州南方に移住して、漁師の生活など見ながら保養するのも一得ではないかと思います。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした悲しい移住者は、思ひきりよく故郷と縁を絶つては來たものの、一足都會の土を踏むともう直ぐその古びた、然しながら安らかであつた親讓りの家を思ひ出さずにはゐられない。",
              "citation": {
                "source": "田園の思慕",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて更にその子、即ち悲しき移住者の第三代目になると、状態は餘程違つて來る。",
              "citation": {
                "source": "田園の思慕",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私も亦「悲しき移住者」の一人である。",
              "citation": {
                "source": "田園の思慕",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處には、金澤の人多人數、移住したるゆゑ、故郷にて、（加州金澤の新堅町の云々）と云ふのが、次第になまりて（かしや、かなざものしんたてまつる。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して翌年の二月、小笠原島に更に私が移住する迄の間、殆ど四ヶ月あまりの日月を、その寺の寂しい書院で静かな虔ましい生活をしてゐたのである。",
              "citation": {
                "source": "雲母集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、町には急に或大工場が出来て、何千人という職工たちが移住して来ました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　せかいじゅうのくにぐにから、旅行者が皇帝のみやこにやってきました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "せかいじゅうをちょっととびまわった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いじゅうたんをしき詰めた階段の上を皆が恐る恐る踏んだ。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はたといじゅうぶんでなくとも、ある程度まではゆうべの行動について弁明を試みておかなければなるまいと思った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幽霊の移転",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
