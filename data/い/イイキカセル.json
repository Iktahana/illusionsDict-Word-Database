[
  {
    "uuid": "5be9d3a0-854f-51c8-8ed6-d3bb84dcec9e",
    "entry": "言い聞かせる",
    "reading": {
      "primary": "いいきかせる",
      "alternatives": [],
      "is_heteronym": false
    },
