          ],
          "literary": [
            {
              "text": "而も猶、一寸立つて便所に行かうとすると、途中で曲つてゐる梯子段を踏み過つて、私は四五段も辷り落ち、肘をしたたか磨り剥いたのだが、驚いてとんで来た医者に、抱き取られながらも、いい気味だいい気味だ、死んだ弟を忘れてゐたから罰が当つたのだと、急にまた千万無量な思ひをするのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちからもこっちからもねずみがみんな集まって来て、「どうもいい気味だね。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ときかれて、赧くなったことが、心外になったくらい、いい気味だと思った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪も割ってもらわなくちゃこまるし、糠味噌もよく掻きまわして、井戸は遠いからいい気味だ、毎朝｜手桶に五はいくんで来て台所の水甕に、あいたたた、馬鹿な亭主を持ったばかりに、あたしは十年寿命をちぢめた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気味だ」といったような意味から、卑怯な嘲罵を翁の生涯に対して送ったのではあるまいか。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだい、あんなお内儀と、石田を取ってやるのがいい気味であり、そしてもう石田を細君の手に渡したくなかった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "をはじめ烏老の不義を憎んでいる者は、いい気味だと思っていると、三日目になって甦った。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪らねえ、いい気味だ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかで唯ひとり、路傍の柳のかげに立って、六三郎の駕籠をじっと睨んで、「畜生……いい気味だ。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はいい気味で、もう一つ八っちゃんの頬ぺたをなぐりつけておいて、八っちゃんの足許にころげている碁石を大急ぎでひったくってやった。",
              "citation": {
                "source": "碁石を呑んだ八っちゃん",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いい気味だったわ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "女一　いい気味だわ。",
              "citation": {
                "source": "世評（一幕二場）",
                "author": "A morality",
                "note": "青空文庫"
              }
            },
            {
              "text": "女悲しげに歌いながら、石に打たれていたが、それが一つ眉間に当るとくずれるように倒れてしまう）男達　ざまを見ろ、いい気味だ。",
              "citation": {
                "source": "世評（一幕二場）",
                "author": "A morality",
                "note": "青空文庫"
              }
            },
            {
              "text": "婿は、玉ころがし屋の悪はどうなりました」「きのどくながら、ご番所で舌をかみ切りましたぜ」「いい気味でござんす！",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまあ見やがれ、いい気味だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さわっちゃいやよ、さわっちゃいやよ……ホ、ホ、ホ、ホ、いい気味だ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気味いい気味、ざまア見やがれ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッハハハ、いい気味だなあ」　トットと先へ走って行く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どこの国にお前女房にしてやるったって、いきなりそんな……だが土方の奴」　いしは、いい気味そうに笑い出した。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しいい気味だ、うちへ来ない罰よ」「今晩から来てよ、あの婆さんなかなか要領がいい。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東條たちにたいしていい気味だとおもうのはまちがっている。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、いい気味だとおもってすむ程度のなまやさしい犠牲を人民ははらったのではなかった。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "残暑の酷しい折とて快い限りであつた、それをいい気味だ、人のいふことを信じない罰だと戯れたのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "降参、降参、本統に降参だ」「きっとですか」「きっとだ、きっとだ」「いい気味だ。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにいい気味ったらありゃしない。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても逃れる所はないんですものね、蒼い顔をして悄然としているのを見ると、あたしはほんとにいい気味だったわ。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「へー」と云ったきりぼんやりして居るうち垣の外のにわとりはいいきみだと云うように「コケッコー」と云って一寸ふりかえってさっさとかえってしまった。",
              "citation": {
                "source": "三年前",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チェッ、ざまみろ、いいきみだ」　女房はプンプン怒つてゐるが、マダムはたぶん部屋の中で笑ひころげてゐるだらう。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、いざとなると、たれも知らん顔をして、よりつこうともしないどころか、これまでお金のあるのを鼻にかけて、こうまんにふるまっていたものが、そんなざまになって、いいきみだといってわらいました。",
              "citation": {
                "source": "ラ・ベルとラ・ベート（美し姫と怪獣）",
                "author": "ヴィルヌーヴ夫人　Madame de Villeneuve",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チェッ、ざまみろ、いいきみだ」　女房はプンプン怒っているが、マダムはたぶん部屋の中で笑いころげているだろう。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
