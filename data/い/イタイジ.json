          ],
          "literary": [
            {
              "text": "「いたいじゃありませんか、奥さん」「なんだって、通り道なんかに、寝ているのさ！",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こうするんだ」「いたいじゃアないか？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを表に出さないでも、せめて心の中でだれの菩提のためにと思いたいじゃないか」　と源氏が言った。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が、好き好んでやってるわけじゃあるまいし、出来るものなら、さっさと足を洗いたいじゃないか」　それは、ひとりお悦ばかりでなく、その日が来ることは、一味にも再生を意味するのだった。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三根夫が撮影録音してきたフィルムによって、天蓋の堅牢さが、想像していたいじょうにすごいものであることがわかったのだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳がいたいじゃないか」　太刀川時夫は、夢心地でつぶやいた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いくら思うまいとしても、白と黒の三びきの小犬が、重なり合って、彼の顔を見たとき、尾をぴちぴちと振って、助けてくれといわぬばかりに鳴いたいじらしい姿を、男は、いつまでも目から取ることができませんでした。",
              "citation": {
                "source": "犬と古洋傘",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の耳にも入って、なにしろ店の者の評判が大きいから、聞いたいじょう捨ててもおけない。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "海へ帰る女",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて死ぬ時ぐらい身ぎれいにしていたいじゃないの？",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
