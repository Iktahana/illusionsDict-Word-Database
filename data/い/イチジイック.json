[
  {
    "uuid": "364d1aa5-dd2d-5ed6-a94a-86cfe72bf06c",
    "entry": "一字一句",
    "reading": {
      "primary": "いちじいっく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
