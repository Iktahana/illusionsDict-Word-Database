    "definitions": [
      {
        "index": 1,
        "gloss": "distinguished service",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "戦地での彼の多大な勲は、国民の記憶に長く刻まれるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "永年の研究が実を結び、その勲に対して最高の栄誉が贈られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "創業以来、会社の発展に尽くした彼の勲は計り知れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まさに彼の勲が、このプロジェクトを成功に導いたんだ」と上司は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "文化財保護における地道な活動が勲として認められ、叙勲の運びとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は祖国のためにその勲を捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その研究者の勲は、現代医学の進歩に大きく貢献した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その頃始めて国の聯隊が出来て、兵隊や将校の姿が物珍しく、剣や勲章の目につくうちは好かったが、だんだん厭な事が子供の目に見えて来た。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勲績のある上長として、盛名のある君子として、礼を尽した態度であった。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前の勲功によって歿後勲一等に叙し瑞宝章を授けられた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勲功によって貴族に列せられようという内意があったが辞退したので、爵位はその夫人に授けられ、夫人からその一人息子の John James Strutt（一七九六―一八七三）に伝えられた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大切りにナポレオンがその将士を招集して勲章を授ける式場の光景はさすがにレビューの名に恥じない美しいものであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は案内された部屋に、レジオン・ド・ヌウルの勲一等の赤い略章をつけた肥大した肉体の恰好の好い一人の老人を見出すのでした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛のため、ニコロの愛欲の満腹のためには、私は未来の歓楽もビイクトリア勲章の憧れさえも、放擲する考えだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "スラビナの勲章哀れにも売られてしまって、彼等三人の外国人が支那へ兵隊に買われて行かねばならぬ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャックソンの胸で孔子廟が勲章の役目をしていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良が電流に乗ってリー・シー・ツワンの部屋に這入ると、彼は寝台のなかで外出着をつけて胸には瀝青を鍍金した勲章をぶらさげていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は教会の門前で柩車を出迎えた後霊柩に付き添って故人の勲章を捧持するという役目を言いつかった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒天鵞絨のクションのまん中に美しい小さな勲章をのせたのをひもで肩からつり下げそれを胸の前に両手でささげながら白日の下を門から会堂までわずかな距離を歩いた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等は、勲章を貰うために、どこまでも俺等をこき使って殺してしまうんだ！",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五「今度こそ、俺れゃ金鵄勲章だぞ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今持っている旭日章のほかに、彼は年金のついている金鵄勲章を貰うことになる。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから勲功によって中佐に抜てきされる。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それは表沙汰にして罰すると、自分の折角の勲功がふいになってしまうのだった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長の時になると、もう信長は臣下の手柄勲功を高慢税額に引直して、いわゆる骨董を有難く頂戴させている。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽柴筑前守なぞも戦をして手柄を立てる、その勲功の報酬の一部として茶器を頂戴している。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり五万両なら五万両に相当する勲功を立てた時に、五万両の代りに茶器を戴いているのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、勲功によって授爵される場面で、尊貴の膝下にひざまずいて引き下がって来てから、老妻に、「どうも少しひざまずき方が間違ったようだよ」と耳語しながら、二人でふいと笑いだすところがある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか、父の勲章祝いのときであった。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえの部下の叙勲はおまえにまかせる。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、まん中のは、大将の軍服で、小さいながら勲章も六つばかり提げています。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土耳古人たちは、みんなまっ赤なターバンと帯とをかけ、殊に地学博士はあちこちからの勲章やメタルを、その漆黒の上着にかけましたので全くまばゆい位でした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）バナナン大将の行進歌合唱「いさおかがやく　バナナン軍マルトン原に　　たむろせど荒さびし山河の　すべもなく饑餓の　陣営　　日にわたり夜をもこむれば　つわもののダムダム弾や　　葡萄弾毒瓦斯タンクは　恐れねどうえとつかれを　いかにせん。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお必ず不二の山しらたえやきよらとも、あわれ浄し不二の山しらたえやしらたえや、むべも可建てしいさおし。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、長いさおを縦横に振って波頭めがけて糸を投げ込んだ一人の男が、見事に大物をつりあげるのを見た。",
              "citation": {
                "source": "近況",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "コラムのいさおしであった。",
              "citation": {
                "source": "魚と蠅の祝日",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのさおでは、思うように釣りができないから、もっといいさおが欲しいものです。",
              "citation": {
                "source": "一本の釣りざお",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
