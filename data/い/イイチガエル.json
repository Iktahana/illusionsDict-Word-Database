        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "緊張のあまり、司会者が新郎の名前を言い違えてしまい、会場に微妙な空気が流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、すみません。言い違えました。会議は明日ではなく、明後日です」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "内容を正確に伝えようと焦るほど、肝心な部分を言い違えてしまうものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は昔から、弟の名前と私の名前をよく言い違える癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ニュース番組でキャスターが統計数字を言い違え、番組の最後に訂正と謝罪を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "言葉の意味を混同して、「確信犯」と「常習犯」を言い違えている人が見受けられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
