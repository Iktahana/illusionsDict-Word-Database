    },
    "definitions": [
      {
        "index": 1,
        "gloss": "at will",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "熟練の操縦士は、巨大な機体をあたかも自分の手足であるかのように意のままに操った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "独裁者は権力を振りかざし、国民の生活を意のままにコントロールしようとしたが、民衆の怒りは限界に達していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「人生が全て意のままになるなんて思わない方がいい、予期せぬ困難があるからこそ面白いんだ」と父は笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もう一つの予言はどうなるか分らないが、ともかくも今まで片側だけしか見る事の出来なかった世界は、これを掌上に置いて意のままに任意の側から観る事が出来るようになった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今にわかに人為的にこれを破壊し棄却しようとしてもそう急速には意のままにならないであろうと考えられる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの臆病なる小さな心臓は老人の意のままに高く低く鼓動した。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて障子のかげから無邪気な笑顔を現わしたときには、相手のからだは意のままになる状態に在るであろう。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる修業を求めてもこの山を意のままにして見度い。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、「御意のままになし給え。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句は、楽焼や墨流しに似ているところがあって、人意のままにならぬところがあるものだ。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子は曾に席をすすめさして、温かみのある言葉で何かとおたずねになったが、やや暫くして、曾に三｜品以下の官は、意のままに任免することをお許しになり、宰相の着ける蟒衣と玉帯に添えて名馬をくだされた。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私が第一の段階と名づけたものの印象がもし意のままに思い起されないものとしても、長いあいだたったのちに、それらの印象が自然にやってきて、どこからやってきたのかと怪しむようなことはあるまいか？",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者はぜんぜん彼らの意のままになったにちがいないよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者が前者を創造し、それを意のままに支配し、修正しうることもまた、疑う余地のないことである。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "「意のままに」と私は言う。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作は今おとよさんにどうされたって、おとよさんの意のままになるよりほか少しでも逆らうべき力がないようになってしまった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が作った車、お前に奉仕した車が、終に、車までがおまえの意のままにはならなくなってしまうんだ。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子路はもとより東夷のような・蒼梧の人のような拙いことをするような人ではないが、昔の学問を修めないで意のままに事を行えば、心は善であるが行いが非となる事を、喩えを以って先生が諭されたのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるのに、今の人は英雄豪傑の敵陣突破のように、勇猛果敢にどんな書でも読過して了として、句読訓詁などは立派な男がする事ではないという了見で、粗雑な態度を自省することなく、自分の意のままに解釈し、批評し、論難したりして、大きな間違いに墜ち入り常軌を逸する。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるのに、小学を足蹴りするように、粗雑・大胆・軽率傾向の人は、自分の浅い了見で由字を解釈して頼字とし、可からずを解釈して宜しからずとし、「意のままに政治を行うことを可とする」とこの章を解釈し、そして之を大いに非難するような、無益な議論を数々耳にする。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中でも暁でも源氏の意のままに従って歩いた男が、今夜に限ってそばにおらず、呼びにやってもすぐの間に合わず、時間のおくれたことを源氏は憎みながらも寝室へ呼んだ。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "十また十二歩離れた壁を跳び越え、騎手の意のままに諸方に廻り駈け、見物人の称讃を求むるようだ――熊楠いう、『千一夜譚』第四七夜に、女子九フィートの溝を跳び越ゆるを追う王子の馬跳び越え能わぬ事あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして読者の注意を作者の意のままにひっぱりまわして、最後の数行に至るまで、読者に真相を見抜かせないだけの装置が必要である。",
              "citation": {
                "source": "作家としての小酒井博士",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "胆力衆に秀で、剣また並ぶ者なく、退屈することまた人に抜きん出て、どれもこれも人並み以上でないものはないが、釣ばかりはいかな早乙女主水之介も御意のままにならぬと見えて、手の届きそうなところにひらひらと泳いでいるのが見えながら、たやすく魚の方で対手になってくれないのです。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが地球全土は、われら地球人類もひっくるめて、彼らの意のままに従わなければならないのだ」「ああ、何という恐しいことでしょう。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方も堀田原へ移れば家もこれまでよりは手広になるし、通う道程も四分の一位になって都合もよいので、師匠の意のままに堀田原へ全部移転したのであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "堀田原へ引っ越した頃のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその学校中で最も乱暴者であつたので、生徒は僕の意のままになつた。",
              "citation": {
                "source": "自慢山ほど",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "陛下は、昔つれない仕打ちあそばした女の妨害などございませんから、御意のままになさいませ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる物質にも常住の形はなく、何物も互いに意のままにならざりき。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事は実に無造作に、自由に、すべて意のままに造られてあるように見えた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして犬と一緒になって主人の意のままに働いている。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃はまた写真電送機というものが成効に近づいて写真画図のごときものを一瞬間に遠距離に送る事さえ思いのままになろうという事である。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し心とからだの安息を与えて、思いのままに彼の欲する仕事に没頭させた方が、かえって本当にこの稀有な偉人を尊重する所以でもあり、同時に世界人類の真の利益を図る所以にもなりはしまいか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
