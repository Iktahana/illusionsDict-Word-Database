[
  {
    "uuid": "ddb6a9c0-3ee5-5c3b-9a0d-37c3e316b064",
    "entry": "一言居士",
    "reading": {
      "primary": "いちげんこじ",
      "alternatives": [
        "いちごんこじ"
      ],
      "is_heteronym": false
    },
    "grammar": {
