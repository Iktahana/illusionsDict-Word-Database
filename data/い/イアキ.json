    "definitions": [
      {
        "index": 1,
        "gloss": "burglary (while occupants are present)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜、住宅街で居空きが複数件発生し、警察が住民に注意を呼びかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ちょっとコンビニまで」と、ほんの数分の外出でも居空きの被害に遭う可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "近年、巧妙な手口を使った居空きが増加傾向にあり、戸締りの徹底が重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "居空き犯は、物音を立てずに侵入するため、気づかれにくいのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもが昼寝をしている間に、一階で居空きに遭ったという話を聞いてゾッとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長期旅行はもちろん、ゴミ出しのような短時間の外出でも居空き対策は怠るべきではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、それはもう悲しみの涙ではなくて、永久に魂に喰い入る、淋しい淋しいあきらめの涙である。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このかなしいあきらめを、フロオベエルは知らなかつたしモオパスサンは知つてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このかなしいあきらめを、フロオベエルは知らなかったしモオパスサンは知っていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの心には死に捕へられた人の上にのみ臨む物凄いあきらめが首を擡げかけた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹いつぱい水を飲んで来てから寝る　放浪のさびしいあきらめである。",
              "citation": {
                "source": "水〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは恋人を思いあきらめるがごとき大発心にて、どうか思いあきらめて下さるよう切望いたします。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには細川に早く思いあきらめさしたい積りで。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの農家の横手には可なり広いあき地があって、そこに大きい物置小屋がある。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前川氏とたった一度一しょに、シネマを見れば、美沢に見つけられて、美沢が美和子と一しょに遊ぶ口実にもなれば、美沢が自分を思いあきらめる最後のとどめになるなんて、何という馬鹿馬鹿しいことだろうと苦笑したいくらいだったが、しかし、それを美沢に会って弁解する必要も感じなかった……。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その城に向こうたこちらの岸に広いあき地があった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、そんなにかしこいあきんどでしたが――そのうち、このあきんども死にました。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーテンが水底のやうに白んで来ると、私は頼りないあきらめの吐息を衝いて五体がたゞ煙りのやうにふわ／＼としてゐるのを感ずるだけだつた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　小さいあき子さんと一つ寝床に寝てゐるおくみは、板戸の隙間が仄かに白んで来た明方など、一人このやうなことを考へて、早くから目を開いてゐたりした。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のその目篇がちときびしすぎてな、江戸の女共を喰いあきたせいでおじゃるのか、それともまた田舎育ちの土女共が味変り致してよいためでおじゃるのか、どちらがどうやら存ぜぬことじゃが、所労保養のお暇を願ったとやらにて、ぶらりとこの月初めに知行所へお帰り召さったのじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一人が十一人、人妻までも捕りあげて屋敷の広間に監禁した上、なおそれでも喰いあきぬと見えて、この次は何兵衛の娘、その次は何太郎の家内と、御領内残らずの女共の中から縹緻よしばかりをえりすぐって、次から次へと目星をつけているゆえ、領民共とて、人の子じゃ、腹立てるのは当り前でおじゃりますわい。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面は五百二十坪とかあるそうで、裏手の方は畑になっておりましたが、それでもまだまだ広いあき地がありました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の小唄の殆んどすべても、やはり、なげやりな人間のはかないあきらめと、ロマンチツクな意氣張りから戀のいきさつもこだはりも思ひ捨てゝ再び思ひ出すまいとしてゐる心持がどの唄にも見られる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうも思わしいあきないもなしに、彼はいつもより早く帰った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎造はもう自分の生命のことなどは思いあきらめた。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "露路の入口は狭いが、奥には可なりに広いあき地があって、ここら特有の紙漉場なども見えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母の業やれは悲しいあきらめであつたが、私の業だなは寂しい自覚である。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイは、食いあき飲みあき懶怠にあきた上流社会の美しく装った男女が、馬車の中で、花園でする恋愛に一つの社会的腐敗の悪臭をかぎ出している。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半星形に立ちならんだ建物と建物との間の、かなり広いあき地に石炭殻を一面にしきつめた、草一本生えていない殺風景な庭だ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のいたその家のあとは、いまだに、まだ家もできずに広いあき地になっている。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱いあきらめや、浅はかな見越しをすて真実の世界をつなぐ花の環の一環として、平和を守る世界正義の下へ日本の勤労階級の正義をも結び合わしてゆかなければならない。",
              "citation": {
                "source": "正義の花の環",
                "author": "――一九四八年のメーデー――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
