    "definitions": [
      {
        "index": 1,
        "gloss": "home telephone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最近は家族全員がスマートフォンを持っているため、家電が鳴るのは決まって営業電話か間違い電話だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、お父さん？ 今、家電の方に電話してるんだけど」と、携帯の電波が届きにくい場所から自宅へ連絡を入れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "契約書類の連絡先欄に携帯番号を記入したが、念のため家電の番号も書き添えておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「もしもし、おばあちゃん？」と、受話器を握りしめた孫が慣れない手つきで家電に応対している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "災害時の予備回線として維持してきた家電だが、利用頻度の低下から解約を検討している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつては気になる異性の家に電話する際、家族の誰が出ないかドキドキしながら家電にかけたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一人暮らしを始めるにあたって、わざわざ家電を引く必要はないだろうと考え、固定電話の契約は見送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "名乗りを上げるのは、突然「家電をやるぞ」とわめきだしたアップルだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アップルが家電って、例のリンゴ・マークのついた扇風機や冷蔵庫でも作るの」という疑問には、次項の言い訳で答える。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも家電への参入宣言があり、この戦略に沿ってアップルはカラーの液晶ディスプレイに高い技術を持つシャープとの提携に踏み切った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルが開発中のものをちらりと見せる代わり、家電とコンピューターの融合という新しい波の到来を印象づける記事を、どかっと書いてくれとなったらしい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ家電への参入という大枠は、当然だと思う。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカリー自身が語っているとおり、アップルがやらなかったとしても家電とコンピューターの融合商品は誰かがやる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのビジネスの好調を受けて、井深御大は大衆市場向けの家電新製品開発に堂々乗り出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "東芝でさまざまな家電製品の開発に携わってきた山田正吾さん語り下ろしの「家電今昔物語」によれば、電気釜への初のチャレンジは、一九一五年頃、京都電灯によって行なわれたという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけで、ソニーがしょっぱなで大ずっこけをかました電気炊飯器の来し方を探っていくと、電灯会社が電球の省エネ化という危機をきっかけに家電の開拓に取り組み、電力会社へと変貌をとげていくダイナミックな産業構造の変化と結びついたおかまの真実が見えてくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし電灯産業の誕生期、その延長上に家電産業の勃興と軌を一にした電力産業のダイナミックな展開を見ることや、怪しげな銀座ルネッサンス商会の延長上にソニーのオーディオ・ビジュアル全面展開を予想することは、どんな誇大妄想狂にも不可能だったのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊一九九二年の一月になって、アップルが家電市場に参入すると言い出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラスベガスで開かれた家電製品の展示会、コンシューマー・エレクトロニクス・ショーでのことだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この催しの基調講演で、ジョン・スカリー会長は「アップルの将来は家電市場にある」と宣言した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカリーによれば、アップルは今後二筋の道から家電市場に食い込んでいくという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに家電製品の中で賢くして意味のあると思われるものを、マッキントッシュの開いた人との対話の流儀に沿って電脳化しようとする腹だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルは複数の大手家電メーカーと協力して、今後ＰＤＡの開発を進めていくという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "家電ははなから、他人の領分と踏んできた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがほうっておいても、家電はマイクロコンピューターを飲み込んで電脳化されていく。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "となると陰に隠れてはいても、コンピューターと人との対話が家電上でも生じてくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彼らとしては、膨大な市場規模を持つ家電が電脳化されていくのを、指をくわえて眺めているのも業腹だろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "家電製品自体は作らないまでも、電脳家電が人に向ける顔のところは任せろと言い出すのは当然だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルはＰＤＡという名前の言い出しっぺになったが、マイクロソフトも同じような観点から家電への進出を狙っている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがパーソナルコンピューター屋が家電屋に化けるのは、ほんの手始めでしかない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この流れをさらに一歩進めば、コンピューターらしいコンピューターと電脳家電との連係をどうやって付けるかが、すぐに課題として浮かび上がってくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあとりあえずマッキントッシュとその真似っこであるＷｉｎｄｏｗｓの使いこなしの流儀をコンパクトにまとめて、電脳家電のお面に使うのが早いのではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルやマイクロソフトの家電への参入に納得するのは、オレがそう考えているからだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「電脳家電のインターフェイスがそろって、おまえはそんなにうれしいか」って。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがかつての自動車や家電製品、半導体で起こったと同様の悲劇が、ここでもまた繰り返されようとしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
