          ],
          "literary": [
            {
              "text": "春になったら房州南方に移住して、漁師の生活など見ながら保養するのも一得ではないかと思います。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一得一失こそ、ものの成長に追随するさだめではなかったか。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草花いぢりも夏の一得であらう。",
              "citation": {
                "source": "樹木とその葉",
                "author": "夏を愛する言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "由って思案の末課目が十あるうち作文と講義は得手物で満点と極まっており、総点数の五分一得れば落第せぬ定め故、他の八課の答えは直ちに白紙を差し出し件の二課は速くやって退け十分安心して遊び廻った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにや、一得は、必ず一失を伴ふ。",
              "citation": {
                "source": "碓氷峠",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "物にはすべて一得、一失有りつてね。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一得、一失は有るが、要するに此の二つの外に無いね。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵からぐつすり寝たので早く眼が覚めて、夜の明けるのが待ち遠しかつた、これも老人の一得一失だらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の畑に芋が落ちてゐたので、拾つて来て芋粥をこしらへる、貰ひ水徃復の一得ともいへよう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも一得一失はあるべけれど、大体の上よりはわれらは『万葉集』崇拝の方に賛成するなり。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の下女下男を宜しからずと思わば、既往数年の事を想起し、其数年の間に如何なる男女が果して最上にして自分の意に適したるや、其者は誰々と指を屈したらば、おの／＼一得一失にして、十分の者は甚だ少なかる可し。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日においても官学校の生徒と私学校の生徒とを比較すれば、その学芸の進歩、一得一失、未だ優劣を決すべからず。",
              "citation": {
                "source": "学者安心論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは我に一得あるも彼に二得あるときは、我はその一得に安んずるの理なし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "風俗の美にして取締りの行き届きたるも学校の一得と言うべしといえども、その得は学校たるもののもっとも賤しむべき部分の得なれば、毫もこれを誇るに足らず。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは散歩の一得であると思う。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間武帝の如き一二豪傑の君主が出て、北狄征伐を行うたけれど、要するに九失一得、功は勞に酬ひずといふ有樣であつた。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もせずに寝ているよりも、気が紛れて幾分は身体のタシになるような一得はあるかも知れない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬は、それがために、あぐね果てて空しく門前を行きつ戻りつしているが、無人境の一得には、いくら行きつ戻りつしたからとて、べつだん怪しげな目を向ける人もない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "めいめい好きな方をやればいい、一得一失。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一得あれば一失を生ずる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから大雨は、一失一得を伴い得の方が大きかったかも知れない。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まって下さい」　美青年の一得であった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来本朝にその怪談が少いのは、貧乏な国の一得さ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處になると、理想家は一得一失で、失敗しても左ほど世間から憎まれない。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処になると、理想家は一得一失で、失敗しても左ほど世間から憎まれない。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の早いのも確かに一得。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんざん考えあぐんだ末生易しい兵法ではいけないと見て、お艶の影を認め次第｜飛礫の雨を降らせるようにと番頭小僧へ厳命を下しておいたが、その結果は、小石の集まる真ん中でお艶をして唯一得意の「お茶漬さらさら」をやらせるに止まり、顕の見えないことおびただしかった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも兄さんのような聡明な人に、一種の思わくから黙って見せるという技巧を弄したら、すぐ観破されるにきまっていますから、私の鈍いのも時には一得になったのでしょう。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんた、隠さんと正直にいっとくれなはれや」政江の小さな三角型の眼が陰険に光った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直にいっとくれなはれや、というのは政江の十八番だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
