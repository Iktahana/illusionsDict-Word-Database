            }
          ],
          "literary": [
            {
              "text": "之れ室生君家庭の一徳なり。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノッポの一徳でもあろうが、とにかく視力はすぐれているらしい。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノッポの一徳――豹吉の大股では、梅田新道より中之島公園まで、五分もかからなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人一倍背が高く、つまりノッポの一徳で、見通しの利く方なのだが、沢山の傘に邪魔されて、容易にＳの姿が見つけられなかった。",
              "citation": {
                "source": "面会",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄の一徳か、動作も敏捷で、声も必要以上にきんきんと高く、だから客たちは、ほう綺麗だなと思っても、うっかり冗談を言いかける隙がなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと臆病な丹造は、支店長の顔を見るなりぶるぶるふるえていたが、鼻血を見るが早いか、あっと叫んで、小柄の一徳、相手の股をくぐるようにして、跣足のまま逃げてしまい、二日居所をくらましていた……。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "また秀吉三楽に向って曰く、「御身は智仁勇の三徳ある、良将なり、されど小身なり、我一徳もなし、しかし天下を取るが得手なり」と。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智の部下六七人が、真田兄弟の働き心にくしと見て迫るのを、兵部丞にっこり笑って、「滋井の末葉｜海野小太郎幸氏が後裔真田一徳斎が二男兵部丞昌綱討ち取って功名にせよ」と名乗るや三騎を左右に斬って棄てた。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲留仙　水はいいよ、水のいいのは、山の中にいる者の一徳だ。",
              "citation": {
                "source": "涼亭",
                "author": "――序に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄の一徳か、動作も敏捷で、声も必要以上にきんきんと高く、だから客たちは冗談を言いかける隙がなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようよう窓の明るみそめる夜明方の浴槽にたんだ独りひっそりと浸りながら、聞くともなくそれの鳴く音に耳を澄ますのはまた渓間の温泉の一徳であろう。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐解の賀の済だ頃より、父親の望みで小学校へ通い、母親の好みで清元の稽古、生得て才溌の一徳には生覚えながら飲込みも早く、学問、遊芸、両ながら出来のよいように思われるから、母親は眼も口も一ツにして大驩び、尋ねぬ人にまで風聴する娘自慢の手前｜味噌、切りに涎を垂らしていた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、反省謹慎、一億一心一徳の心がまへ。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝の一徳で、他の一切の諸惡を帳消し難くない。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人にして嫉妬しないと云ふ一徳があれば、外にどんな缺點があつても結構であると云ふやうに、支那人は婦人に對して不妬と云ふことを非常な美徳と認めて居ります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "つきあひ下手の三田でも、珍しいといふのが一徳で、會場では存外もてた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝが茶の湯の一徳といふものだ。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の湯の一徳は屁理窟かも知れないが、自在奔放な生活をみんな自我流に組みたてゝゐる秀吉に比べると、なるほど俺は窮屈だ、と悟るところがあつた。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに多くの門弟を引き連れて来て峻嶮を平らげ、山道を開き、各国に信徒を募ったり、講中を組織したりして、この山のために心血をささげた普寛、神山、一徳の行者らの石碑銅像には手も触れてない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "平素書斎の塵を掃はざるもこの一徳あり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "円朝、円生、円遊、円右、馬車の円太郎、ヘラヘラ万橘、金潮、新潮の落語、手品が、西洋手品天下一品の帰天斎正一に女テジナの蝶之助、水芸の中村一徳、鶴枝の生人形、そこへ新内が銀朝ときてます。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "同一の隱蔽、同一の誇張、同一の無恥、同一の詐欺が、僞善として憎まれずに滑稽として笑はれるに過ぎないのは、馬鹿の一徳である。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてずうずうしいのも世渡りの上じゃ一徳だぐらいに考えているんです」「まさか」「いえ、そうです。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "北原ミユキは、そういう彼女の気持を実によくのみこんで、それとなく、かばいだてをしたり、時によると、軍服をはがれた夫一徳の立場に不思議な同情と理解とを示したりするのである。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡すかぎり黒々と焦げ散つた「街」の残骸を夕やみがおゝう頃、あの日、夫の一徳は軍刀のつかをいつものように左手で握つて、さもそれは予期したことだといわぬばかりの悠々たる足どりで帰つて来た。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　康子の夫、井出一徳は、正規の道を踏んだ陸軍技術将校で、砲兵科の秀才として部内では早くから嘱望され、専門の弾道学は世界的とまで言われていたが、彼は研究室に閉ぢこもつてばかりいなかつた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に解体を終り、ガランとしたこの工しようの一室で、井出一徳元大佐は、妻康子の到着を待ちうけていたのである。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、はしをおいた康子をみて、一徳はたずねる。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんた、隠さんと正直にいっとくれなはれや」政江の小さな三角型の眼が陰険に光った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直にいっとくれなはれや、というのは政江の十八番だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
