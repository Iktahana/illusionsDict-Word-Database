[
  {
    "uuid": "f9d3a38b-b942-570f-8174-1efbbf10ef3d",
    "entry": "一種異様",
    "reading": {
      "primary": "いっしゅいよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
