      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eccentric",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "森の奥に足を踏み入れると、そこには一種異様な雰囲気が漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の服装はいつも一種異様で、街を歩いていると人々の注目を集める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その古い洋館は、昼間でも一種異様な静けさに包まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども彼の「本校」といふ言葉の中には、「私立」といふことを非常に特殊扱ひしてゐる響があつたために、ズツト此の学校に勉めて来てゐる教師達には、一種異様に聞えたのである、訓辞はたゞ訝しさを与へたばかりであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを一種異様な感動を持って眺めていた。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深窓の美姫、紅閨の艶姐、綾羅錦繍の袂を揃えて、一種異様の勧工場、六六館の婦人慈善会は冬枯に時ならぬ梅桜桃李の花を咲かせて、暗香堂に馥郁たり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "咄嗟にお丹乞食は、一種異様の光を帯びたる眼をもて屹と見送り、「あの邸さ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、其の湿んだ眼は一種異様に輝いていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どうしたわけか、その下腹が、奇妙な恰好にムックリと膨らんでいるために、親爺の曲りくねった足と並んで、一種異様な対照を作っているのであった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ起った今度の事件なので、草川巡査は最初からチョット一つタタキノメされたような感じで、一種異様な興奮――緊張味を感じているのであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章に一種異様の調子が出て来て、私はこのまま順風を一ぱい帆にはらんで疾駆する。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩中にはいると、一種異様なにおいが鼻をつき、ヘどが出そうになる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩中にはいると、一種異様なにおいが鼻をつき、へどが出そうになる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その戸棚を開けると、緑礬、硝石、甘草、肉桂、薄荷、どくだみの葉、中には売薬の版木等がしんみりと交錯がつた一種異様の臭を放つ。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種異様の悪臭が私の鼻をも衝いた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだって円錐の立方積なんぞを計算し出したのだ」と、僕は石原に言ったが、それと同時に僕の目は坂の中程に立って、こっちを見ている女の姿を認めて、僕の心は一種異様な激動を感じた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思う時、さらに一種異様の声が叔父の耳にひびいた。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一人の声は一種異様なる鋭き声なりき。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが遠いような、近いような、地の底からでも聞えるような、一種異様のひびきを伝えるので、大抵の者はしまいには鳥肌になって、敵にうしろを見せることになるのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳の伝統を破った飄逸な画を鑑賞するものは先ずこの旧棲を訪うて、画房や前栽に漾う一種異様な蕭散の気分に浸らなければその画を身読する事は出来ないが、今ではバラックの仮住居で、故人を偲ぶ旧観の片影をだも認められない。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし熊本では見ることのできない意味で新しいので、むしろ一種異様の感がある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその困難を極めた、一種異様な責任は本日の午後に、思いもかけぬ未知の人物から、私の双肩に投げかけられたものであります。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の中で私が抱き続けて来た一種異様な鬼胎観念は、やはり意外千万な意味で物の美事に的中していたのであった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そんな風な話を平気で進めながら、次第次第に昂奮して、雄弁になって来る彼女の表情をジイット凝視ているうちに、彼女の眼付きの中に一種異様な美しい光が、次第次第に輝き現われて来るのを発見した。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な髯を生やして、黒い紗巾をかぶって、一種異様の獣にまたがっているのである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "その連中が門内を覗きこんで、一種異様な臭気を持った煙の霽れゆく間から本堂のあたりと覚しき跡に眼を移したものは、思わず、「吁ッ」と叫んで、顔をそむけた。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに僕は、一種異様な妖気が屋内にたれこめているのを感じないわけにいかなかった。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱い主観の情と冷めたい客観の批判とが絡り合せた糸のように固く結び着けられて、一種異様の心の状態を呈した。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここはどこであろう」　千枝松は驚異の眼をみはって唯ぼんやりと眺めていると、一種異様の音楽がどこからか響いて来た。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま迄、兎や犬や羊の心臓を切り出すことに馴れて居た僕も、たとい死体であるとはいえ、その女の蝋のように冷たく且白い皮膚に手を触れてメスをあてた時は、一種異様の戦慄が、指先の神経から全身の神経に伝播した。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
