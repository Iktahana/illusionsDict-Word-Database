    "definitions": [
      {
        "index": 1,
        "gloss": "malicious",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「そんな意地悪を言って友達を困らせるのはやめなさい」と、母親は息子を厳しくたしなめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "記者会見では、新閣僚の知識の隙を突くような、あえて答えにくい意地悪な質問が相次いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は根は優しいのだが、好きな人を前にすると照れ隠しでつい意地悪な態度を取ってしまう癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「せっかくの遠足なのに朝から雨が降り出すなんて、お空の神様も意地悪だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職場の先輩から執拗な意地悪や嫌がらせを受けていた彼女は、ついに退職を決意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "意地悪な見方をすれば、今回の彼の寄付も売名行為の一つと言えなくはないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼い頃、近所の意地悪な犬に追いかけられた経験が、今でも彼のトラウマになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それ故ある人々は、ヘルンがもし悪妻をめとり、意地悪の姑等と同居したら、彼の神国日本観は、おそらく顛倒した結果になったろうと言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（偶々批評が盛んなやうでも、少し意地悪く云つてみるならばそれは評定根性である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな訳だから、学校でも軍人希望の者などとはどうしても肌が合わぬ、そう云う連中から弱虫党と目指されて、行軍や演習の時など、ずいぶん意地悪くいじめられたものだ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸から咽喉へかけて意地悪い痩せこけて骨張った手が捏ねくり廻しているようだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお金でいまに太郎の美くしいお嫁に着物を買つてやるのです…………太郎はどこからかきつと美くしいお嫁さんを連れて来ませう…………そのお嫁さんは、ひよつとするときつい意地悪るかもしれません。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲が意地悪く光って、低くたれています。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車に乗ると大抵満員――それが日本特有の満員で、意地悪く押されもまれて、その上に足を踏みつけられ、おまけに踏んだ人から「間抜けめ、気を付けろい」などと罵られて黙っていなければならなかった。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『武道伝来記』には、ある武士が人魚を射とめたというのを意地悪の男がそれを偽りだという。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母も意地悪く何とも言わない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地悪の嫂が何を言うても、母が民子を愛することは少しも変らないけれど、二つも年の多い民子を僕の嫁にすることはどうしてもいけぬと云うことになったらしく、それには嫂もいろいろ言うて、嫁にしないとすれば、二人の仲はなるたけ裂く様な工夫をせねばならぬ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静が、　「兄さん、意地悪ねえ」　「お前が、あんまり綺麗になってるもんだから、すっかり見違えて居たんだよ」　「知らない」　石松笑う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さん意地悪したから教えない事よ」　「手紙あるだろう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上等兵の表情には、これまで、病院で世話になったことのないあかの他人であるような意地悪く冷酷なところがあった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、皮肉に意地悪く云った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所だか海軍省だかの煉瓦を背景にした、まだ短夜の眠りのさめ切らぬような柳の梢に強い画趣の誘惑を感じたので、よほど思い切って画架を立てようかと思っていると、もうそこらを歩いている人が意地悪く此方へ足を向け始めるような気がする。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも歌女寿は意地悪く稽古を休ませなかったので、彼女は殆ど半死半生のおぼつかない足もとで稽古台の上に毎日立ちつづけていた、お仲も肚の仲ではらはらしていたが、大師匠の怖い目に睨まれて、彼女はどうすることも出来なかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "デボチンは、皮肉げに、意地悪げに、空にうそぶいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝子は婉曲に意地悪されているのだな。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たってお前が其処を退かないというのなら、それも仕方はないがネ、そんな意地悪にしなくても好いだろう、根が遊びだからネ。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとまず中止としてカンバスを室のすみへ立てかけて遠方からながめて見ると顔じゅう妙に引きつりゆがんで、始めに感じのよかった目も恐ろしく険相な意地悪そうな光を放ってにらんでいるので、どうもそのままにしてあすまで置くのは堪えられないような気がした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人とすれちがう時などには特に意地悪くわざわざガリガリと強い音を出す。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは以前あの人たちに何か悪い事でもして来たのでしょうか、どうして私たちにこんなに意地悪をするのです。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは、あんな、意地悪くポチの姿を見つめるようなことはしないので、ポチも自身の醜さを忘れて、いそいそ私についてきた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまはまた違うようになりましたが、その頃は、私のたわいも無い綴方が、雑誌に二度も続けて掲載せられて、お友達には意地悪くされるし、受持の先生には特殊な扱いをされて重苦しく、本当に綴方がいやになって、それからは柏木の叔父さんから、どんなに巧くおだてられても、決して投書しようとはしませんでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "内にいると、そのおかみさんとめしたき女にいじめられるし、たまたま休みの日など外へ遊びに出ても、外にはまた、別種の手剛い意地悪の夜叉がいるのでございました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながら画かきはまた急に意地悪い顔つきになって、斜めに上の方から軽べつしたように清作を見おろしました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い木霊はそこで一寸意地悪く笑って青ぞらの下の栗の木の梢を仰いで黄金色のやどり木に云いました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜか口が横の方に引きつってゐて意地悪さうに見えます。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくいじわるなんかしないように気をつけないといけないぞ」　ホモイはつかれてねむくなりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとすぐ目の前をいじわるの狐が風のように走って行きます。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
