    "definitions": [
      {
        "index": 1,
        "gloss": "have a good day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "（子供が学校に行く時に）「気をつけてね、行ってら！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "（同僚が外出する時に）「じゃあ、行ってら！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "（友人が遊びに出る時に）「楽しんできてね、行ってらー！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「いま海へ行ってらあ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だっておっ母さんも行ってらっしゃるしそれに神さまが仰っしゃるんだわ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃では、ともよは湊を思い出す度に「先生は、何処かへ越して、また何処かの鮨屋へ行ってらっしゃるのだろう――鮨屋は何処にでもあるんだもの――」　と漠然と考えるに過ぎなくなった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはべつの方だわ」「するとあすこにいま笛を吹いているんだろうか」「いま海へ行ってらあ」「いけないわよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちへ行ってらっしゃい。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行ってらっしゃいまし。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はわたくしの家へ来て、少し長｜逗留になると、母は窮屈がって、釣にでも行ってらしてはと勧めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいとも、ゆっくり行ってらっしゃい」　道子はわれ知らず顔をほころばした。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「行ってらっしゃい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、やっぱりゴルフに行ってらしたの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり下りると、「へい、行ってらっしゃいまし。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも博文館に入ってから一年ほど経った或時、近頃は忙がしくて紅葉さんの許ばかりへ行ってられないで諸方へ顔を出すので、紅葉さんの御機嫌が悪くて困ると愚痴を覆した事があった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根行一「御機嫌よく行ってらっしゃいませ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体何処へ行ってらしたのです」「イヤなにちょっと、その……」「いくらお隠しになっても駄目ですのよ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車をおりるとすぐ彼は私とあべこべの方へ行ってらした。",
              "citation": {
                "source": "心配",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉五郎どのが見えましたらば、宜しくお伝えください」「行ってらっしゃい」と、留吉も丁寧に会釈した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行ってらっしゃいよ。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "……兄さん、庄原と言ったら、家のお父さんが子供のころ、勉強に行ってらした所でしょう？",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「リョーニャ、月曜日に行けたらエーゴル・マクシモヴィッチのところへ行ってらっしゃいよ、ね？",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「叔父さんのところへ来るかい」「いや」　油井が、みのえの方は見ず、「じゃ、奥さん行ってらっしゃい、私、みのえさんを家まで送って行きますから」と云った。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして紀久子が、「行ってらっしゃいまし」と声をかけると、父はそれへ頷きもせずステッキの握りへ片肘をのせて心もち前屈みに向う側の窓へ顔をむけたなりで行ってしまった。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった二分間……」「じゃ、行ってらっしゃい。",
              "citation": {
                "source": "碧眼",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝湯にはいって、講釈の寄席へ昼寝をしにゆくのを毎日の仕事にしていたが、あんまり口やかましいので、佃島の庭の梅が咲いたからお訪ねなさい、桜がよいでしょうから行ってらっしゃいと、私の父の閑居に体よく追払われては来た。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "また細君のみと子夫人が、背中の上の方に閂のかかった薄鼠色の看守服の良人を門口まで送って出て、「行ってらっしゃい。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "行ってらっしゃい」　と高くつづけさまに云って手を振り、主人の見えなくなるまで電柱の傍に立ちつくしている姿も、これも雨が降っても雪が降っても毎朝変らなかった。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、私はもう十幾年間、「行ってらっしゃい。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "行ってらっしゃい」　とこう呼ぶ加藤家の元気の良い声をどれほど聞かされたことかしれぬ。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『うまいことをいってらア』と江藤はつぶやいた。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さあ、はいってらっしゃい』と、おばさんは言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにを寝言いってらっしゃるの。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
