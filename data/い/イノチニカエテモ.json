        "examples": {
          "standard": [
            {
              "text": "「この子たちの未来は、私の命に代えても守ってみせる」と彼女は強く心に誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国宝級の機密情報が入ったディスクを、スパイは命に代えても持ち帰る覚悟だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "たとえ命に代えても、無実の罪を着せられた親友の名誉を回復したかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「拙僧の命に代えても、奥様とお子様達は、おかくまい申します」　住職はこう云って六人の者を慰めていた。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余「ハイ聞きました」穴川「命に代えても行い度いと云う程の密旨ですから一通りの事では有りません。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞操ぐらいで殺されるなんてそんな勘定の合わないソロバンがあるものかとおっしゃるなら、まことにその通り、命に代えても貞操をまもれなどゝ無理難題を言い得るものではない。",
              "citation": {
                "source": "貞操の幅と限界",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに権堂の身になれば、命に代えても、あの大トランクは離されないのです。",
              "citation": {
                "source": "悪人の娘",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら十三名は、各※すがたを変えて、敵地の伊丹城中に潜伏し、たとえいかなる臥薪嘗胆の苦難をしのぶとも、八幡大菩薩、産土の神も照覧あれ、臣等の一命に代えても、かならず官兵衛様の身を救い出してみせる」　と、天地神明にその一心をちかい結んだものなのである。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "命に代えてもやらいでか」第六章　併せ馬　ハリーフィールデンは眠れぬ夜を過ごし、有り難いことに朝食時間となった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
