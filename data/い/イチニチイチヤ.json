      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "all day and night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "降り続いた激しい大雨により、一日一夜にして川の水位が避難判断水位を超えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "連絡船は一日一夜の航海を経て、ようやく朝霧の中に浮かぶ離島の港に入港した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一日一夜、一睡もせずに看病してくれた彼には、感謝してもしきれない」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は一日一夜を費やして、山積していた未処理の膨大なデータをすべて分析し終えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "村の古い慣習として、冬至の日には一日一夜、囲炉裏の火を絶やしてはならないという教えがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "締め切り直前の編集部では、一日一夜、怒号と激しいタイピング音が止むことはなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一日一夜の宿を貸していただきたい」と、道に迷った旅人は古寺の門を叩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "即ち「邪宗門」「思ひ出」「東京景物詩」「白金の獨樂」であるが、この中、最後の「白金の獨樂」は、作者自ら言ふ如く一日一夜の急作であつて、いかにインスピレーシヨンの激潮に乘つたとはいへ、藝術として重厚のものとは思へない。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　亨一が東京へ行つた一日一夜を通してすず子の考へたことは、之れとは全く反対の趣意であつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　亨一が東京へ行つた一日一夜を通してすず子の考へたことは、之れとは全く反對の趣意であつた。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "定として、他は一切音をさせてはならない、と一所にな、一日一夜に三度ずつは必ず鳴らさねばならないんだ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、冷飯の残りを食べたゞけで、水を飲んで読書した、しづかな、おちついた一日一夜だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒も煙草もない一日一夜でした。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはそれを述べるのに便利なため、三日三夜を一日一夜ずつに分けて述べてみましょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思慮はたゞ一つところを馳せ※るに似て、一日一夜は過ぎぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれ等は別れて来た幹線――一直線に傍眼も触らずに一日一夜やつて来た幹線の方を名残惜しさうに振返つた。",
              "citation": {
                "source": "浴室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこれが主水之介に、あまり類のない旗本退屈男と言うような異名を生じさせたそもそもの原因ですが、実に彼のこうして吉原五町街をぶらぶらとあてもなくさ迷いつづける事は、きのうや今日に始まったのではなく、殆んど三年来の一日一夜も欠かしたことのない日課なのでした。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅木大臣は昨日濃紅姫を送り出すと直ぐに門を固く鎖して、二人の小供の死骸を石神の部屋に移して、そこで公爵夫人と一所に一日一夜の間泣き明かしましたが、一方濃紅姫の事も気にかかって心配で堪りませぬ。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、愉快で、そして憂欝で、妙な一日一夜だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口の句会へ行く、椹野川づたひに歩いて行つた、春景色、そして私は沈欝であつた、いつ訪ねても周二居はしづかであたゝかである、湯田温泉も私のかたくなにむすぼれた身心をほぐしてくれた、おいしい夕飯をいたゞいて、若い人々と話して、終列車で戻つた、まことによい一日一夜であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしく、また一日一夜が過ぎた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も来なかつた、郵便も来なかつた、孤独と沈黙との一日一夜だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことによい一日一夜であつた、Ｋさんにあつくお礼を申上げる。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "螻子居の厄介になる、昼酒、晩酌、読書、雑談、散歩、螻子君と共に一日一夜たのしく暮らした。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十二日　雨、滞在休養、ゆつたりと一日一夜を味はつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠々として一日一夜を楽しんだ、洗濯、歓談、読書、静思、そして夜は俳句会へ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞相はよかつた、所得もわるくなかつた、埴生一時間、厚狭二時間、それだけの行乞で食べて飲んで寝て、ノンキに一日一夜生かさせていたゞいたのだから、ありがたいよりも、もつたいなかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月廿三日明けて飲み、暮れて別れた、とにかく忘れることのできない一日一夜だつた、めでたくもありめでたくもなし、喝。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・たどりきてからたちのはな・からたちの咲いてゐる始業の鐘の鳴る・何もかも過去となつてしまつた菜の花ざかり　今日がはじまるサイレンか・ゆふべは豚のうめくさへ・右からも左からも蛙ぴよんぴよん　四月廿五日曇、間もなく雨となつた、そして一日一夜降り通した。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでございましたら、ただ今承りましたことは結構なことでございまして、一日一夜でも道におはいりになっただけのことは報いられるでしょうが、しかしもうまったくお亡くなりになったのでございましたら、死後のお髪の形を変えますだけのことがあの世の光にはならないでしょう。",
              "citation": {
                "source": "源氏物語",
                "author": "御法",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ送ります」と書いてやると、一週間ほどしてから、矢張り苦しさうな筆蹟で、「折角の御意、差し當り何も欲しいものはなけれども、流星光底長蛇を逸してはと、一日一夜考へ通した末、鮒の雀燒きを所望いたす。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一日一夜の後に、どこともわからない海岸に吹き付けられて難破してしまった。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛引は日夜の臨機応変にして、政略上にもっとも大切なる部分なれば、政治家の常に怠るべからざる事なれども、学問は一日一夜の学問に非ず、容易に変易すべからざるなり。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞享元年に二万三千五百句を一日一夜のうちによんだ。",
              "citation": {
                "source": "明治十年前後",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ候へど、この日は浪やや高く、殊に昨日より今日まで一日一夜の静止の後に候へば、客人達は船酔ひがちに食事も進まぬ様に候ひき。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
