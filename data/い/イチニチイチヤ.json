[
  {
    "uuid": "f86b84f4-8a8e-5b08-8e54-35971a53ea43",
    "entry": "一日一夜",
    "reading": {
      "primary": "いちにちいちや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
