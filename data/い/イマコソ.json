        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "迷っている暇はない、今こそ行動を起こす時だ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の夢を叶えるために、今こそ挑戦する決意を固めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さあ、みんな！今こそ、我々の力を結集してこの難局を乗り越えよう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この歴史的な瞬間に立ち会えるのは光栄だ。今こそ、記憶に刻むべき時だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "15　今こそ、自分は芥川君の自殺について、一つの判然たる推論を下すことができるのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は、今こそ、シルレルを讀まなければなるまい。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに泰子、今こそはしづかに一緒に、をりませう。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに泰子、今こそはおまへの髪毛なよぶころ花は香炉に打薫じ、羊の歌羊の歌　　安原喜弘に※　祈り死の時には私が仰向かんことを！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶頂の火口は、今こそ休火山ではあるが、烈々と美を噴く熔炉になっている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは、うちの家族のことを芸術の挺身隊と言ったが、今こそ首肯する。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ俺は、あの桜の樹の下で酒宴をひらいてゐる村人たちと同じ権利で、花見の酒が呑めさうな気がする。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは愛とか、知識とか、喜びとかいつたやうなものであり、それは今こそ、ほんの少し暗くなつて、落ちつかなささうにしてゐますが、誰かがちよつと注意をして、その面倒を見てさへやれば、すぐにまた元のやうに明るくなる光のやうなものなのです。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ妾の愛はあなたと共にあるのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩井は、今こそ、いくらか小金をためて虫をも殺さぬ顔をしている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ俺は、あの桜の樹の下で酒宴をひらいている村人たちと同じ権利で、花見の酒が呑めそうな気がする。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜多八、さあ、其の氣で歩ばつしと、今こそ着流で駒下駄なれ、以前は、つかさやをかけたお太刀一本一寸極め、振分の荷物、割合羽、函嶺の夜路をした、内神田の叔父的、名を彌次郎兵衞といふ小田原通、アイお茶代を置いたよ、とヅイと出るのに、旅は早立とあつて午前六時に搖起された眠い目でついて行く。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われにもあらでまたとは見るに忍びぬを、いかでわれかかるべき、必ず心の迷えるならむ、今こそ、今こそとわななきながら見直したる、肩をとらえて声ふるわし、「お、お、千里。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者買いしたって、学校から罰せられることもなかったし、私は、今こそと思った。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ地殻ののろのろのぼりや風や空気のおかげで、おれたちと肩をならべてゐるが、元来おれたちとはまるで生れ付きがちがふんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、今こそあなたにも明します。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ地殻ののろのろのぼりや風や空気のおかげで、おれたちと肩をならべているが、元来おれたちとはまるで生れ付きがちがうんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今こそ本当の事を申し上げます。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ答えまいらすべし、ただ一｜言。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ思い出でぬ、今の少女の顔のよく肖たりというはわが治子なるを。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は窮みなき空高くながめ、胸さくるばかりの悲哀をおさえて、ひそめし声に力を入れ、『必ず手紙を送りたまえ、今こそわが望みは君が心なれ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠の中なる何某は出づるにも出でられず、命せに背かば御咎めあらむと、まじ／＼として煙草を吸へば、幼君左右を顧み給ひ、「今こそ豫て申置たる二人前の料理持て參れ」と命ぜらる。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそこんな処へ来てゐるが、前は、それはもう、硝子でこさへた立派な家の中に居たんだ。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ鶴雄は、あえかに抱いていた鈴子への恋情が――いや、その恋情だけが、自分の青春のすべてであるように、思われるのだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今こそ芸術家というものを知りました。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのピストルは少し前に、不吉な猫を殺す手段として、用意して買った物であったが、今こそ始めて、これを役立てる決行の機会が来たのである。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに泰子、いまこそは暮るる籬や群青の空もしづかに流るころ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまこそわたれわたり鳥、いまこそわたれわたり鳥。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "復讐心が強いそうだからなあ、犬は」　いまこそ絶好の機会であると思っていた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまこそ私は、いつか叔父さんに教えられたように、私の見た事、感じた事をありのままに書いて神様にお詫びしたいとも思うのですが、私には、その勇気がありません。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
