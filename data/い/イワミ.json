    "definitions": [
      {
        "index": 1,
        "gloss": "Iwami (former province located in the west of present-day Shimane Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "延宝四年六月には石見、同五年三月には陸中の南部に地震と海嘯があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は石見國鹿足郡津和野町に生れたものだ。",
              "citation": {
                "source": "私が十四五歳の時",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚助心得て長浜に来り、勝豊の家老徳永石見守、与力山路将監、木下半右衛門等を口説いた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋ぞろえ　　　　　　　　五「さあ、おい、起きないか起きないか、石見橋はもう越した、不動様の前あたりだよ、直に八幡様だ。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「石見橋なら石見橋、蓬莱橋なら蓬莱橋、蛤町の河岸なら蛤河岸さ、八幡前、不動前、これが富岡門前の裏になります。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年は明和五年で伊織の弟宮重はまだ七五郎と言つてゐたが、主家の其時の當主松平石見守｜乘穩が大番頭になつたので、自分も同時に大番組に入つた。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊織が妻を娶つてから四年立つて、明和八年に松平石見守が二條在番の事になつた。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時は代人｜差立と云ふことが出來たので、伊織が七五郎の代人として石見守に附いて上京することになつた。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は私とは同じ石見人であるが、私は津和野に生れたから亀井家領内の人、君は所謂天領の人である。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "家臣小笠原備前、河喜多｜石見等は門を閉ぢて防戰し、遂に火を放つて切腹した。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "祠前の小池の中に牛石ありて、牛の形をなすと云へど、水多くして石見えず。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "石見も三瓶に登つて、そこからすつと下りて、断魚渓に行つて見たい。",
              "citation": {
                "source": "行つて見たいところ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年の男は矢張主人で、石見の浜田のものださうだが、此処に来てからもう十年になるといふことであつた。",
              "citation": {
                "source": "海をわたる",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「化石見つけちゃったのよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの大久保｜石見守長安の罪に連坐したのであるともいい、または大坂方に内通の疑いがあったためであるともいい、あるいは本多佐渡守｜父子の讒言によるともいう。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二　男は石見弥次右衛門という四国の武士であった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御貴殿は石見弥次右衛門殿でござるか。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は九州へ渡り、中国をさまよい、京大坂をながれ渡って、わが身の生計を求めるうちに、病気にかかるやら、盗難に逢うやら、それからそれへと不運が引きつづいて、石見弥次右衛門という一廉の侍がとうとう乞食の群れに落ち果ててしまったのである。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "石見弥次右衛門は小屋の前に死んでいたのである。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛は石見弥次右衛門から譲られたものである。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にして考えると、かの石見弥次右衛門の因縁話も嘘ではなかったらしい。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜兵衛と生前親しくしていた藩中の誰かれがその遺族らと相談の上で、二つに裂けたかの笛をつぎあわせて、さきに石見弥次右衛門が自殺したと思われる場所にうずめ、標の石をたてて笛塚の二字を刻ませた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何卒平生の心事御了解被成下大納言様御手筋を以乍恐朝廷へ御取成寛大の御汰沙｜只管奉歎願誠恐誠惶　謹言酒井孫八郎吉村又右衛門沢｜采女三輪権右衛門大関五兵衛服部｜石見松平｜帯刀成瀬｜隼人正様　次いで、同月十八日、官軍の先鋒が鈴鹿を越えたという報をきくと、同文の嘆願書を隣藩亀山藩へ送った。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は米子から岡山へ出る道を取つて、すこしぐらゐ無理でもまだ鐵道の連絡してゐないと聞く山道を越えようかと考へたり、それとも、最初の豫定通り、遠く石見の國の果まで行つて、山陽線を※つて歸らうかとも考へたりして、そのいづれもが容易でなささうなのに迷つた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方山の話の末に、これから私達が向はうとする石見地方のことが出た。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　杵築より石見益田まで　杵築に着いた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて五時間ばかりもかゝつて、石見の益田まで乘つて行つた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "石見にある雪舟の遺蹟も傳へてない。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の天開樓に送つた後、石見に來てその最後の老熟期に達したといはれてゐる。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわみ銀山しかじかの鼠取りといわれるもので、夫婦はどうやら助かるもようだが、末子のいちは死に、登がいってみたときは、他の三児も重態であった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
