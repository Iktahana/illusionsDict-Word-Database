    "definitions": [
      {
        "index": 1,
        "gloss": "to find it hard to say",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "現時点では判断材料が乏しく、その件が事実かどうかは何とも言いかねます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "直接お伝えするにはあまりに忍びなく、どうしても言いかねていたのです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "部下の手前、私の口からはこれ以上の苦言は言いかねるのが本音です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "具体的な発売時期については、諸般の事情により現段階では言いかねます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は何か言いたげな様子でこちらを見ていたが、結局最後まで言いかねたまま立ち去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "いくら親しい間柄とはいえ、高額な借金の申し入れとなると流石に言いかねるものがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たった一晩のことではあるし、病院へ泊るか、泊らないか、まだわからないさきから、関係もない人に、迷惑をかけるのはわがまますぎて、しいてとは言いかねるが、――むろん野々宮はこう流暢には頼まなかったが、相手の三四郎が、そう流暢に頼まれる必要のない男だから、すぐ承知してしまった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物を破壊しないで人間はセン滅するから原子爆弾よりも有効であるなどと人間ならば言いかねる言葉を日本の新聞は書いております。",
              "citation": {
                "source": "世界は平和を欲す",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは……いつの幾日であったか、しかとは言いかねるが、ペトローヴィッチがついに外套を届けに来た日は、恐らくアカーキイ・アカーキエウィッチの生涯においていやが上にもおごそかな日であったに違いない。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈欝な秋の日に乗客はほんの数えるばかり、出札の河合は徒然に東向きの淡暗い電信取扱口から覗いては、例の子守女を相手に聞きぐるしい、恥かしいことを語りおうていたが、果てはさすがに口へ出しては言いかねるものと見えて、小さい紙片に片仮名ばかりで何やら怪しいことを書きつけては渡してやる。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、神話だから、そのとりいれの方法が正確ではないし、所詮はボーバクたる神話なのだから、似ているがハッキリとそれがオレの国の誰それ様だとも言いかねるものが多いのです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとても――とても大きくて――いやしかし、つまるところ、僕はそれがどんなに途方もなく大きかったかを言いかねる位です。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら現今はと見渡しますと、実は私からは口はばったくて言いかねる所ですが、真になさけない有様です。",
              "citation": {
                "source": "近作鉢の会に一言",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで、私がどんなに困っているかということが、あなたにもよくお分かりになったろうと思いますが、いったいなんであの幽霊が出るのでしょうか」　私は彼に対して、自分はまだ十分に理解したとは言いかねると答えると、彼はその眼を爐の火に落として、時どきに私の方をみかえりながら、沈みがちに言った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "信号手",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やゝ言いかねる様子であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを強っても言いかねるが、梁山泊一｜期の浮沈です。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく高まった地価というものは、いわば社会が生み出してくれたもので、私の功績でないばかりでなく、諸君の功績だともいいかねる性質のものです。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化のある時期には、若い人が精神においても若いといいかねるような悲劇が生じる。",
              "citation": {
                "source": "山の彼方は",
                "author": "――常識とはどういうものだろう――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりやまあ僕だつて判然としたことはいいかねる。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれとてもいかに讃めたくも、日本の商業道徳を西洋のそれに優るとはいいかねる。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一々それを述べないが、そういう研究を経ず、それらの問題に一々明かな解釈を施さずして、甲骨文字を遠い上代のものとするのは、学術的の取扱いかたとして周到な用意があったとはいいかねる。",
              "citation": {
                "source": "日本に於ける支那学の使命",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、学者の態度によっては、その世間一般に及ぼす影響において、かの固陋な放恣な主張の宣伝せられたのと、似たようなことが起らぬとはいいかねるかも知れぬ。",
              "citation": {
                "source": "日本歴史の研究に於ける科学的態度",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやはや全く、どうにもいい趣味とはいいかねる代物だね」　突然いとこは手をのばし、彼の胸ぐらをつかみ、頭を玉突き台へ押しつけて、「よこすんだ、手紙を」と顔をいとこの顔にくっつけるようにして、小声で言った。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は近重物安博士や現南禅寺師家柴山全慶師らの研究によるから、誤伝とはいいかねる、どうも他の行状を見ても、こんな剽窃はやりかねない人間であったと思える。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロケットも、人工頭脳も、原子力発電も、科学によってつくられたものであって、科学そのものとは、いいかねる。",
              "citation": {
                "source": "犬がなくとガラスがこわれるか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、今さらここで、新之助をあげるともいいかねることは、そのご、おじさんが、ほんとに一度も、新之助をくれと云わないからです。",
              "citation": {
                "source": "柿の木のある家",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし軍功にもつながるものだ」「義貞は武人、軍は論じますが、商論はぞんじません」「元々、道誉は純な武将とはいいかねる。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
