        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「部長、お見えですか？」「いえ、今ほど外出されましたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あれ、地震かな？いや、気のせいか。でも今ほど少し揺れたような…。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "お客様からお電話です。今ほど着信がありました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
