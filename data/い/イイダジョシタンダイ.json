        "examples": {
          "standard": [
            {
              "text": "飯田女子短大は、長野県飯田市に位置するカトリック系の私立短期大学である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は飯田女子短大の幼児教育学科に進み、保育士への道を歩み始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今年の飯田女子短大の学園祭、一般公開もあるみたいだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飯田女子短大は、南信州における女子教育と地域文化の振興に大きな役割を果たしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地元の高校を卒業後、自宅から通学しやすい飯田女子短大への進学を選択した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飯田女子短大のキャンパスは緑豊かな高台にあり、落ち着いた環境で専門知識を学ぶことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
