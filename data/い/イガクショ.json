    "definitions": [
      {
        "index": 1,
        "gloss": "medical book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試験が近いから、この医学書を徹夜で読破するつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この症例は稀だから、専門の医学書で確認してみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新の医学書は一冊数万円もするから、学生には大変だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "図書館の医学書コーナーで、ずっと探していた古い文献を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の研究は、19世紀の貴重な医学書に書かれた記述からヒントを得たらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医学部に入学する甥に、最新の解剖学の医学書を贈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのドイツ語の医学書を日本語に翻訳するプロジェクトが始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "九　栗栖は隅に椅子卓子などを置いてある八畳の日本｜室で、ドイツ語の医学書を読んでいたが、銀子の牡丹がふらふらと入って来るのを見ると、見られては悪いものか何ぞのように、ぴたりと閉じた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏の日、二つ井戸へ医学書の古本を漁りに行つた帰り、道頓堀を歩いてゐると喫茶店の勘定場で金を払つてゐる修一を見つけた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速出掛けたが、二人は留守で、管理人や隣室の人にきいてみると、月給は雪江の分と合はせて九十五円はいるのだが、そのうち二十円は雪江の親元へ送金するほか、研究費とむやみやたらに買ふ医学書の本代に相当要るので、部屋代と交通費を引くといくらも残らず、予想以上にひどい暮しらしかつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日僕はちょっと医学書を覗いてみたが、脳へ来るのには五年や十年は掛るらしいんだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "折りたたみのできる寝台、医学書ばかり詰まった木製の本棚、寝台のわきに肘掛椅子が一つ、壁に寄せて粗末な椅子が一つ、円卓が一つ、それから大きい金庫、これらが目にとまる主立ったものである。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身の病症は主な点では医学書にしるされているものとべつに違っていなかった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろの医学書に手をふれないようになった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "黴くさい医学書が山のように積みあげられ、そしてわけのわからぬ錆ついた手術具や医療器械やが、所もせまくもちこまれている医学生吹矢の室は、もともと奇々怪々なる風景を呈していたが、いまこの珍客「生ける腸」を迎えて、いよいよ怪奇的装飾は整った。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「支那の古い法医学書に『洗冤録』というのがあります。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは本富士署あたりの警戒のために未遂に終ったが、当時の医学書生というものの中には本質までじゃらじゃらでない者のいたことを証明しているのである。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学書生のやる学問は常に肉体に関することだから、どうしても全体の風貌が覚官的になって来るとおもうが、長谷川翁の晩年は仏学｜即ち仏教経典の方に凝ったなどはなかなか面白いことでもあり、西洋学の東漸中、医学がその先駆をなした点からでも、医学書生の何処かに西洋的なところがあったのかも知れない。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "著流しのじゃらじゃらと、吉原遊里の出入などということも、看方によっては西洋的な分子の変型であるかも知れないから、文化史家がもし細かく本質に立入って調べるような場合に、当時の医学書生の生活というものは興味ある対象ではなかろうかとおもうのである。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも医学書の文章は同情がない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はいつもいっしょに往診したり、医学書を勉強したり、三味線をひいて歌ったり、川へあゆをとりに行ったり、山登りをしたり、乗馬の手入れをしたりしていた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、寝たきりの重病ではなかったため、院内を回っては米軍医の診察治療ぶりを見学したり、いまだ一般には輸入されてない新刊の米国医学書を見せてもらう内、自然と米国医学に親しむようになり、医者としての再勉強をはじめるようになったからである。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性への忠言、産児制限、効用並害悪、良人と妻の便覧、妻の知識、以上五冊の有益なる医学書を最も有効にして無害なる産児制限具の図解カタログとともに無代進呈す。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる「開国」の前にヨーロッパの医学書が出版されたことは興味深い。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世の家庭医学書である有名なサレルノ養生訓は次のように言っている。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に訳されたのはガレノスの医学書のあるもの、および化学の著書であり、これは化学についてのアラビアの知識の基礎になった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベイコンは幾つかの医学書を書いているが大部分は草稿として残っている。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、初期の医学書の著者67人の182版のうちで、23人は13世紀と14世紀で、30人は15世紀、8冊はアラビア語で書かれており、何冊かはサレルノ学派のもので、6冊だけが古典時代のものであった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作者の現実と人間の進歩の関係を見ることに於ての誤りは皮膚だけかえるところにあると批評されているが、皮膚を代えるのは生理的現象であるとして丸善の小僧氏は医学書の間に入れてある。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "金原書店その他の医学書は一つもなし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "療養新道は、医学書の部分をみんな見ましたが、こちらにはありません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学書にある神経図に似た梢が俄にゆらゆらと動いた。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は日がな医学書を開いて、薬品やなんかのことを読んでいた。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何冊かの医学書を書き、頭痛から治るのに電気を使った。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代の医学書著述者と違って、以前の著者たちからコピーした種々の方法を記録する方法を採用せず、彼の教科書は体系的であった。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
