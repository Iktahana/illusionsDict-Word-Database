  {
    "uuid": "b478fd08-73f5-5de4-a18f-047d5ab9f9ba",
    "entry": "一腹",
    "reading": {
      "primary": "いっぷく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
