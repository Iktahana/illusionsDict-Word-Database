    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being born of the same mother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの兄弟猫は顔つきがよく似ているから、きっと同じ一腹から生まれたのだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この犬舎の子犬たちは皆、同じ一腹の兄弟なので、とても仲が良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "牧場では、同じ一腹から生まれた仔馬たちが元気に駆け回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼らは互いにライバルではあるが、同じ師の下で学んだ一腹の弟子たちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "眠っている間は、煙草を吸うわけにゆかないですからねえ」「いや私は、第一腹がへるので、眼が覚めますわい。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しらふじゃあ、第一腹がすわりませんや。",
              "citation": {
                "source": "老年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は自分自身で、流れて行つてゐる――さすらふといふ風な形で、中でも一番均等に行つてゐるのは、允恭天皇の皇子の木梨軽皇子、それからその妹の軽大郎皇女、この二方が、一腹一生の兄妹なのに夫婦の契をしたといふことが、神意によつて現れて、それで皇女が伊予国に流された。",
              "citation": {
                "source": "真間・蘆屋の昔がたり",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一腹が減って、目がまわりそうだ」「あれっ、強いといばった人が、もはやそんなに弱音をふくんじゃ、やっぱり弱虫の方だね。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵は一腹に五、六百万粒ほど入っているといわれる。",
              "citation": {
                "source": "鯰",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一腹が耗って蒲団も帽子も上衣もないのだ。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「三十六人というと一腹じゃありますまい」「幾腹でも構わない」「すると……」「何だい？",
              "citation": {
                "source": "人生正会員",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これじゃあ、全く物足りないし、第一腹が張らない。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもおかしい事には一腹に三人の四人も、怖ろしい子を生むというのである。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通は勝手な瓦の隙間などに巣を掛け、それがまた並んでいるのを見究め難いが、私が自分の寝る室の窓の前に、柱のような木を一本｜栽え、それに巣箱を引掛けて三回ほど雛を孵させて見たところでは、子雀の時代にいつもこの巣箱の附近へ、集まって来る者がちょうど一腹の数ほどあった。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは椿の根元でいっぷくすって行ってしまいました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んでいっぷくせい」　右へ二人、左へ三人、行く手を塞いだ四五人に、あっさり揚心流当て身の拳あてて片づけながら道を開いておくと、「女つづけッ」　にったり打ち笑みながら、さッと駈け出しました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから江戸へは二里八丁、京へ百三十三里十四丁ということになっている、先は長いから、まあいっぷくやって行こう」と、あるお茶屋へ休みました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌の川虫をとっていっぷくやる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "男Ａ　朝起きて、いっぷく吸わねえと、どうも、眼がさめねえ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、いっぷく、お吸けなすって」　煙草盆を、そこへ出しておいて、下剃は、流し元で、青砥をすえて、ごしごしと、剃刀を磨ぎはじめた。",
              "citation": {
                "source": "治郎吉格子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "終航の船が繋がれる、さあ急がしい、留さんは褌ひとつになって船の上を駈け廻る、あっちへ走るかと思うとこっちへ、箒を投出す、バケツの水がはねる、煙草いっぷくの暇もないのだ。",
              "citation": {
                "source": "留さんとその女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花崗道円は浮かない顔つきで、ひどく念いりに手指を拭き、それから莨盆をひきよせて、いっぷくつけた。",
              "citation": {
                "source": "月の松山",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すると、期間は、どのくらいですか」　道円は「さよう」と云って、庭のほうへ眼をやり、それから煙管を詰め替えて、またいっぷく吸いつけた。",
              "citation": {
                "source": "月の松山",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしのお友達ですの」おせんはとりなすように小さな声で云った、「――お針にいっていたじぶんの仲良しなんです、ゆうべひどく酔って来て苦しそうだったもんですから」　松造は黙って莨をいっぷくした。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計を見て、桂は、茶をいっぷく喫んでいたが、「こらっ、誰か来い」「はっ」　隊士が、首を出した。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぷくあがって、此方で、手なりとお焙りなされませ」二「ありがとう」　言葉だけで、ちょっと会釈したまま、武蔵は依然と、背を向けていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、しごとにかかるまえに、いっぷくしましょう。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　博士は、わけのわからないことをいって、「まず、いっぷく。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井の茶店でいっぷくして、浜並木へ一同がかかった時である。",
              "citation": {
                "source": "死んだ千鳥",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
