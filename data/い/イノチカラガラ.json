        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "for dear life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、燃え盛る建物から命からがら逃げ出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "嵐の中、小舟は命からがら港にたどり着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「危なかった！命からがら助かったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "猛獣から逃れるため、彼は命からがら森の奥へと駆け込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ＫＳ倶楽部の土間は、命からがら、身をもって逃がれて来た人々で埋まっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、さすがのフウケーボー大博士も命からがらにげだした。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃこそ出たぞ、と驚き慌て、得右衛門も待ち合えず、命からがら遁帰りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの貴下が命からがらで御遁げ遊ばす処が一番｜愉快い。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "およしなさいっていうのもきかないで、お友達の狐が、或る家の家鴨を盗もうとしたので、お百姓に見つかって、さんざ追いまくられて、命からがら逃げたことでした。",
              "citation": {
                "source": "手袋を買いに",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お爺さん、これお爺さん、何をそんなに魘されてるのだよ」　すると老人の声で、「ああ怕かった、乃公が街を歩いてると、何をかんちがいしやがったのか、二人の仕事師が、だしぬけに鳶口を持って追っかけて来たのだから、命からがら逃げて来たのだよ」　と云った。",
              "citation": {
                "source": "遁げて往く人魂",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしく、命からがらであった。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』ヴェル氏、仰天して、ころげるようにして廊下へ飛び出し、命からがら逃げかえったそうで、僕は、どうも、人のざんげを聞くことが得手じゃないのです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨魚タマカイに追われて生命からがら独木舟に逃げ上ることもある。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "家財はもちろん型なしで、塵一っ葉残りませんけれど、それでも家の者五人は命からがら逃げまわって、まあみんな無事でした。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは命からがら船へ帰りました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "避難列車で命からがら逃げて来たと聞いて、両親は、えらい苦労したなとしきりに同情した。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその中にまじつて、こはれ掛つた椅子にもたれて、アスピリンで微熱を下げながら、自分の運命のやうに窮地に陥ちた王将が、命からがら逃げ出すのを、しよんぼり悲しんでゐたのだつた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱十本を一両に売って、しかも買い手が命からがら逃げてゆくなどということは、ここらでも前代未聞の椿事と噂された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　日本のあと、フィリピンにまわった四人は、大統領の招待を断わったとかで、空港で群衆に投石され、命からがら脱出するはめになった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って見たら危うくなぐられそうになって、命からがら……。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の有様などを詳さに述べたところで、結局私達が奴等に手とり脚どりされて、ぐるぐる回る水車の川下に放り込まれてしまつたゞけのことで、そんな自分の姿を偉がりやの私としては思ふだに自尊心に関はりますので止めますが、私達は命からがら向方岸へ泳ぎついたのでした。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしらも傍杖の怪我せぬうちと、命からがら逃げて来たのじゃ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "久作が椿事に遭って生命からがら帰って来たのを感ちがいした喜助は、初一念を貫いて、あれから直ぐ後で、鉄路の露となって消えてしまった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山卯の若い衆が大宅太郎を気どって出かけると、蝦蟆の妖術よりも恐ろしいのに出逢って、命からがら逃げて帰るという始末。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "出しには出しても、出した荷は山と積まれたまま焼けてしまうのですから、誰も彼も生命からがら、ただ身一つになって、風呂敷包み一つも持たず逃げ出したもの……実に悲惨なことでありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "浅草の大火のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗男は、命からがら、この殺人境からのがれ出た。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、馬は置き捨てにして、命からがら池の端の辺まで逃げました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは、生まれた西国の地方で、一揆の暴徒に襲撃されてその家と蔵とを打ち壊わされたので、命からがら逃げ出してきた。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷もつに火がつくので水をかける、そのあまりをかい出すもの、舟をこぐもの分業で命からがらにげ出したのだ。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事だったのは二匹のはえだけで、これはジャムだらけになって死んでしまった母親のからだをしゃぶりに、さっさと飛んで行きましたし、一ぽうとかげは命からがら、尾をちょん切られたままで逃げ出しました。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、京都のどんどん焼きとも言い、また鉄炮焼きとも言って有名な蛤御門の変で、隣の家へ落ちた大砲の弾から火事を起こし、その質蔵も類焼し、一家は生命からがら伏見の親類へ避難したのでした。",
              "citation": {
                "source": "あのころ",
                "author": "――幼ものがたり――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あぶなく癩患になるところよ」「命からがらって云う奴さな」年下の方は汗を拭いた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月九日の下町の空襲の時、淺草の松葉町で、すつてんてんに燒いてしまつて、文字通り命からがら、二人は知人を頼つてこの信州のＳ町にやつて來た。",
              "citation": {
                "source": "雪の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いきなり、によも何も放り出して、いのちからがら逃げ出した。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
