[
  {
    "uuid": "91470c53-7c65-55de-a473-3577754a4175",
    "entry": "命からがら",
    "reading": {
      "primary": "いのちからがら",
      "alternatives": [
        "いのちがらがら"
      ],
      "is_heteronym": true
    },
    "grammar": {
