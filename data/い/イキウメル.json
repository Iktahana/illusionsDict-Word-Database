        "examples": {
          "standard": [
            {
              "text": "古代の処刑法には、罪人を生き埋めにするという残虐なものがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "山岳地帯での土砂崩れにより、数名の登山者が生き埋めになるという痛ましい事故が報じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "映画では、主人公が秘密を知りすぎたため、組織によって生き埋めにされそうになる緊迫したシーンが描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "戦国時代の合戦後、敗北した武将の家臣たちが、主君と共に生き埋めにされる殉死の風習も一部で見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、あの事件は単なる事故ではなく、意図的に誰かを生き埋めにするための計画だったとは…」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
