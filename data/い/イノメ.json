    "definitions": [
      {
        "index": 1,
        "gloss": "heart symbol (to ward off evil spirits)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い神社の門を見上げると、魔除けの意味を持つ猪目の形をした透かし彫りが施されており、その可愛らしいハート形に目を奪われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "刀の鍔に刻まれた猪目は、猪が突進するように勇猛果敢に戦う武士の精神を表している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統的な建築意匠である猪目をモチーフにした現代風のアクセサリーが、お土産物屋で人気を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかるに、この傷は猪目透二字切となっております。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "丹頂の鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鶴御成が明日に切迫いたし、上様御覧のみぎり、『瑞陽』が衰弱いたしおるため、おのが悪事を見あらわされんことを恐れ、水蛭の歯形によく似たる、猪目透二字切の手突矢にて突きころし、水蛭の咬み傷によって死したる如くによそおったものに相違ございません」　いならぶ床几から、どっと嘆賞の声が起る。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "丹頂の鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の小島の東屋に、三十ぐらいのめがねをかけた品のいい細君が、海軍服の男の子と小さい女の子を遊ばせている。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "直接に、あの茶碗一ぱいのめしのことを指して言っているのだ。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなうなぎをつかんだといって、両方の手の指で、てんびんぼうほどの太さをして見せるので、ほんとうかと思っていってみると、筆ぐらいのめそきんが、井戸ばたの黒いかめの底にしずんでいるというふうである。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日においてこそは、社会組織の不完全なるがゆえに、かようなるくだらぬことが人間の手仕事となりおれども、将来の進歩せる社会においては、たいていのめんどうなることはみな器械の働きとなり、人間はただこの器械を用いて僅少の骨折りをなすにすぎざることとなるべし。",
              "citation": {
                "source": "婦人の天職",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては女出入りが原因だなと、ただちにだいたいのめぼしがついたものでしたから、すばやく片手を伸ばすと、奪いとるようにして取り上げながら、鋭く若者にいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この原稿を君がベロナールを飲む前に送つて置くぜ、ありがたう、これで、特種料で一ぱいのめるわけだ」　白足袋の指導者は、それから二通の遺書を書いた。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのおの思い思いのめかし道具を持参して、早や流しには三五人の裸美人が陣取ッていた。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "男には出来ない」「じゃ、わたしには出来ることなのね」と静子は酔いのめぐった、生理的な昂奮を抑え切れないで大きな声を出した。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど蚊のようにやせた体を倒れるかと思うくらいのめらせながら。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハム二百瓦二・四〇の中、六十哥が税、九十哥が原価であとのあまりでそうして食いのめるか？",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを唄い終ってからはめいめい得意の唄を声をかぎりに唄いのめし、手拍子かけ声が外の山々に反響するかと思われるばかりだ。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱い砂の上には這いのめって、甲羅を乾しているものもあった。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お米　蔵前ふうの根の高いのめし髷。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "金鳳釵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたいのめうしあたいのめうしはちっぽけだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたいのめうしは、ちっぽけだ、めうしのふくらはぎはちっぽけだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたいのめうしはちっぽけだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はおれがめずらしくはやおきをして、といってもかれこれひるちかかったが、朝昼けんたいのめしをくっている時だった、みしりみしりと階段の音がして留守番のばあやが、「ムッシュウ・じゅあん、お客さんですよ」　といい、よちよち一枚の名刺を眼のまえにさしだした。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたら、そいつはきみに面と向かって、笑いのめすくらいが落ちだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなふうに思うようすが、互いのめまぜのなかにあらわなくらい出ていた。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みつかりそうになったんで預けたに違いない、……世間ばなしというのもまんざら嘘じゃあないんだな」　早鐘を撞くような動悸だった、おちつこうとしても、跡を跟けられてはいないかという怖れで、ついのめるような足早になっていた。",
              "citation": {
                "source": "金五十両",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「めしはね、あんまり噛むとうまくないんだ、二、三度ぐらい噛んでね、ぐっとのみ込むときに、半搗きぐらいのめし粒が喉をこすっておりるときの、匂いと味がね、たまらないんだ」そして、実際どのくらいたまらないかを表現しようとするかのように、下顎を前方へせり出させ、それからまた云った。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（a）ちょうど我々の舞踏会において、舞踏を教えるのを商売としている卑しい身分の人たちが、わが貴族たちの上品な態度を真似ることができないもんだから、あぶなっかしいとんぼ返りや、その他いろいろと軽業師まがいのめずらしい運動なんかをして、認めてもらおうと努めているのと同じことである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は地上または海上において交えた沢山の苦戦、彼と運命を共にした五十万の人の血と命、彼の企図のために使い果された二カ国の力と富とを、きわめておかしく、きわめて気のきいた言葉で、わらいのめしているではないか。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
