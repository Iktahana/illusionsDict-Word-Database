          ],
          "literary": [
            {
              "text": "（扇を笏に）それ、山伏と言っぱ山伏なり。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お腰元と言っぱ美人なり。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋路と言っぱ闇夜なり。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日一日をいっぱいに生きている」　それ以後、私は馬場へ肉親のように馴れて甘えて、生れてはじめて友だちを得たような気さえしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きの高い四つの窓から、東京の空の光がいっぱいに流れ込む。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "に朱罫、十八行二十四字）いっぱいに画いた附近の略地図である。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規常用の唐紙に朱罫を劃した二十四字十八行詰の原稿紙いっぱいにかいたものである。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室へ入ろうとするといつの間にか商人｜体の男二人その連れらしき娘一人室へいっぱいになって『風俗画報』か何か見ているので、また甲板をあちこち。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏やかな日光が広い園にいっぱいになって、花も緑もない地盤はさながら眠ったようである。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るまに左の手のひらにいっぱいになる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンケチにいっぱい拾って包んでだいじそうに縛っているから、もうよすかと思うと、今度は「あなたのハンケチも貸してちょうだい」と言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいつかジョバンニの眼のなかには涙がいっぱいになりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどこでなくカムパネルラは、その雑誌を読むと、すぐお父さんの書〔斎〕から巨きな本をもってきて、ぎんがといふところをひろげ、まっ黒な頁いっぱいに白い点々のある美しい写真を二人でいつまでも見たのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして教室中はしばらく机の蓋をあけたりしめたり本を重ねたりする音がいっぱいでしたがまもなくみんなはきちんと立って礼をすると教室を出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時がうってしばらくたったころ、ジョバンニは拾った活字をいっぱいに入れた平たい箱をもういちど手にもった紙きれと引き合せてから、さっきの卓子の人へ持って来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠いものは小さく、近いものは大きく、遠いものは橙や黄いろではっきりし、近いものは青白く少しかすんで、或ひは三角形、或ひは四辺形、あるひは電や鎖の形、さまざまにならんで、野原いっぱい光ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カムパネルラが、さう云ってしまふかしまはないうち、次のりんだうの花が、いっぱいに光って過ぎて行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人たちはしづかに席に戻り、二人も胸いっぱいのかなしみに似た新らしい気持ちを、何気なくちがった語で、そっと談し合ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上の方を見ると、すすきのいっぱいに生えてゐる崖の下に、白い岩が、まるで運動場のやうに平らに川に沿って出てゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云った途端、がらんとした桔梗いろの空から、さっき見たやうな鷺が、まるで雪の降るやうに、ぎゃあぎゃあ叫びながら、いっぱいに舞ひおりて来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　窓の外の、まるで花火でいっぱいのやうな、あまの川のまん中に、黒い大きな建物が四棟ばかり立って、その一つの平屋根の上に、眼もさめるやうな、青宝玉と黄玉の大きな二つのすきとほった球が、輪になってしづかにくるくるとまはってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこならもうほんたうに明るくて匂がよくて立派な人たちでいっぱいです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつにそのすきとほった奇麗な風は、ばらの匂でいっぱいでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川下の向ふ岸に青く茂った大きな林が見え、その枝には熟してまっ赤に光る円い実がいっぱい、その林のまん中に高い高い三角標が立って、森の中からはオーケストラベルやジロフォンにまぢって何とも云へずきれいな音いろが、とけるやうに浸みるやうに風につれて流れて来るのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく河原の青じろいあかりの上に、黒い鳥がたくさんたくさんいっぱいに列になってとまってぢっと川の微光を受けてゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ジョバンニの眼はまた泪でいっぱいになり天の川もまるで遠くへ行ったやうにぼんやり白く見えるだけでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然たうもろこしがなくなって巨きな黒い野原がいっぱいにひらけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の中はもう半分以上も空いてしまひ俄かにがらんとしてさびしくなり風がいっぱいに吹き込みました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニが胸いっぱい新らしい力が湧くやうにふうと息をしながら云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして誰にも聞えないやうに窓の外へからだを乗り出して力いっぱいはげしく胸をうって叫びそれからもう咽喉いっぱい泣きだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
