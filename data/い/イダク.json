[
  {
    "uuid": "a52aaeaa-d7ee-5a2e-b655-17bbb39e3970",
    "entry": "抱く",
    "reading": {
      "primary": "いだく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to hold in one's arms (e.g. a baby)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "母親は、生まれたばかりの赤ん坊を腕に抱き、その小さな寝顔を慈しむように見つめていた。",
              "citation": {
                "source": "幻辭AI",
                "作者": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "父親は、初めて歩いた息子を誇らしげに腕に抱いた。",
              "citation": {
                "source": "幻辭AI",
                "作者": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう大丈夫だからね」と、少女は膝に顔をうずめる弟を優しく抱きしめた。",
              "citation": {
                "source": "幻辭AI",
                "作者": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、慣れない様子で震える子猫を、服の中にそっと抱き入れた。",
              "citation": {
                "source": "幻辭AI",
                "作者": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "被災地では、親とはぐれた子供たちが、ボランティアの手で温かく抱かれていた。",
              "citation": {
                "source": "幻辭AI",
                "作者": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "久しぶりに再会した恩師を、彼は感極まって強く抱いた。",
              "citation": {
                "source": "幻辭AI",
                "作者": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、幼い頃から大切にしていたテディベアを、眠る前にそっと腕に抱いた。",
              "citation": {
                "source": "幻辭AI",
                "作者": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ところでＢの方が不平を抱く時は、悲劇なのだが、Ａの不平は悲劇でもない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もそれを抱く以前とその作品の実質に於て亳も変りはしなかつた。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の言葉に依れば、彼のケエスそれ自体が現代のサンボルだ、中はうそ寒くからっぽであるというんだが、そんなときには私は、この男はいったいヴァイオリンを一度でも手にしたことがあるのだろうかという変な疑いをさえ抱くのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜を記念しようという、なんの意味もない決心を笑いながら固めて、二人、浅草へ呑みに出かけることになったのであるが、その夜、私はいっそく飛びに馬場へ離れがたない親狎の念を抱くにいたった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて彼等の間では彼等が世間に向つて抱くその野望からの当然の産物として出て来なければならなかつたのは、仲間同志に於ては、その仲間の誰でもを褒めたとも譏つたとも理由の分らない噂――まあまあ噂――さうつまり噂なんだ、それを作り出さんことに閑暇がない。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の教育者たちは、子供等がその夢を見て居る時に、頭から馬鹿者と呼んで嘲笑し、且つそんな非現實的な空想を、實際に抱くことを禁壓した。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規は世の中をうまく渡って行く芸術家や学者に対する反感を抱くと同時に、また自分に親しい芸術家や学者が世の中をうまく渡る事が出来なくて不遇に苦しんでいるのを歯痒く思っていたかのように私には感ぜられる。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も下りたとして、私はその埃りの道に困るだけのことになるかも知れない、――回想的な気持でなんかなしに暮すことこそ、濃い回想を抱くことにもなるのであらうから、なまなか昔ゐた所をも一度なんと思つて下車することは多分愚劣であらうが、下車するであらう……。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、焙り出されかけた家の子供等は、「水」と云ふものに、原始アラビア人が覚えた程も、驚異と礼讚の念を抱くやうになつたのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山の岳神となったわが娘福慈神の性格が果してこの山の如くならば、自分がこの娘に対して抱く考えも気持もまるで見当外れである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度僕のこの敬意は、我々詩人が時に小説家に對して抱く所の、或る種の畏敬と同じ性質の者であつた。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（両手を拡げて未来を掻き抱く如き振をなす。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "長靴を抱くようにして急いで脱って、少しびっこを引きながら、そのまっ暗なちらばった家にはね上って行きました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に卑しいことだと心に否定しながらもその欲望に身を委せてしまふ時、人はこの奎吉の樣な感じを抱くのであらうか。",
              "citation": {
                "source": "奎吉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗悪に対してひどい反感を抱くのは私の久しい間の癖でした。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と仔細は語らずただ思い入ってそう言うたが、実は以前から様子でも知れる、金釵玉簪をかざし、蝶衣を纏うて、珠履を穿たば、正に驪山に入って、相抱くべき豊肥妖艶の人が、その男に対する取廻しの優しさ、隔なさ、深切さに、人事ながら嬉しくて、思わず涙が流れたのじゃ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈も夢を照らすやうな、朦朧とした、車室の床に、其の赤く立ち、颯と青く伏つて、湯気をふいて、ひら／＼と燃えるのを凝然と視て居ると、何うも、停車場で銭で買つた饂飩を温め抱くのだとは思はれない。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」博士たすけよ、と呼ばむとする時、何と、……頸寄り、頬重り、脚抱くと視るや、尾を閃めかして接吻をした。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　色を五百機の碧緑に織つて、濡色の艶透通る薄日の影は――裡に何を棲ますべき――大なる琅※の柱を映し、抱くべく繞るべき翡翠の帳の壁を描く。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ立去りぎわに名残惜しくてや、両手もて輪をつくり、抱くように胸のあたりまで火の上にかざしつ、眼しばだたきてありしが、いざとばかり腰うちのばし、二足三足ゆかんとして立ちかえれり、燃えのこりたる木の端々を掻集めて火に加えつ、勢いよく燃え上がるを見て心地よげにうち笑みぬ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで戦争の中頃からは一面に塹壕を掘って辛抱くらべを始めました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶碗にかかるほど、襯衣の袖の膨らかなので、掻抱く体に茶碗を持って。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "廉平は雲を抱くがごとく上から望んで、見えるか、見えぬか、慌しく領き答えて、直ちに丘の上に踵を回らし、栄螺の形に切崩した、処々足がかりの段のある坂を縫って、ぐるぐると駈けて下り、裾を伝うて、衝と高く、ト一飛低く、草を踏み、岩を渡って、およそ十四五分時を経て、ここぞ、と思う山の根の、波に曝された岩の上。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "濡れしおたれた黒髪に、玉のつらなる雫をかくれば、南無三浪に攫わるる、と背を抱くのに身を恁せて、観念した顔の、気高きまでに莞爾として、「ああ、こうやって一思いに。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　で、ちょっと紙袋を袖で抱く。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　その若い妓は、可愛い人形を抱くように、胸へ折った片袖で、面を蔽う姿して、「堪忍して下さいな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にね、――潰島田に水色の手柄を掛けた――年数が経って、簪も抜けたり、その鬢の毛も凄いような、白い顔に解れたが――一重桜の枝を持って、袖で抱くようにした京人形、私たち妹も、物心覚えてから、姉に肖ている、姉さんだ姉さんだと云い云いしたのが、寂しくその蜜柑箱に立っていた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その緋の絞の胸に抱く蔽の白紙、小枕の濃い浅黄。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また自然の野山に黙って咲く草木の花のように、ありとあらゆる美しい事、善い事が併立して行かれないからと言って、そのためにこの世をはかなんで遁世の志をいだくというわけでもない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "階級が一ツちがっていても、いいだくだくと、命令を聞かなければならないのが軍人だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to have (a thought or feeling)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は将来への大きな希望を抱いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若者は皆、それぞれに壮大な夢を抱いて故郷を後にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の説明には、どうにも拭いきれない疑問を抱いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "度重なる嘘で、彼女に強い不信感を抱くようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めて会った時から、彼には特別な好意を抱いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このままではいけないと、多くの人々が現状に強い危機感を抱いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
