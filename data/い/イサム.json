[
  {
    "uuid": "f5fdb038-1dae-5fa2-8f55-89d35089f24f",
    "entry": "勇む",
    "reading": {
      "primary": "いさむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be in high spirits",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "決勝戦を前に、選手たちは「いざ出陣」とばかりに意気勇んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祭囃子が遠くから聞こえてくると、地元の若衆たちは勇み立って神輿の準備を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しいプロジェクトのリーダーに抜擢された彼は、勇んで企画案の作成に取り掛かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "待ちに待った遠足の朝、子供たちは大きなリュックを背負い、勇んで家を飛び出していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今度こそ手柄を立ててみせる」と勇んで会議に臨んだが、提案はあっけなく却下された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "恩師に昇進の吉報を届けようと、彼は勇んで母校の校門をくぐった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "茶色の枯れたような冬の芽の中に既にいま頃から繚乱たる花が用意されているのだと思うと心が勇む気がする。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　箱根、伊豆の方面へ旅行する者は國府津まで來ると最早目的地の傍まで着ゐた氣がして心も勇むのが常であるが、自分等二人は全然そんな樣子もなかつた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "織次は偶と幻に見た、夜店の頃の銀河の上の婦を思って、先刻とぼとぼと地獄へ追遣られた大勢の姉様は、まさに救われてその通り天にのぼる、と心が勇む。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と慶造が勇むに引代え、若山は打悄れて、ありしその人とは思われず。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は思ひ返して見て、闇の中で独りでに心の勇むのを感じた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の聲を聞くと、急に氣が勇むで來て、愉快で耐らない。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "『駒の朝勇み』といふ俗諺が有るが、駒の未だ馬と成らざる者は、甚だしく逸り勇むもので、朝は好んで馳奔※躍するけれども、夕に及んでは萎頓して復其の勇無きが常である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "獸も朝に於て勇むのは、駒のみでは無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "狗も牛も皆勇むのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟲は卻つて暮夜に勇むのが多いが、朝より晝にかけて勇むものは亦甚だ多い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く行く情人の足を蹈み止まらすもの、猛く勇む雄士の心を弱くするもの、情｜差ひ歓薄らぎたる間柄を緊め固うするもの、涙の外には求めがたし。",
              "citation": {
                "source": "山庵雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆の祭は盛んであるほど郷土の意気が勇む。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "早熱早冷の大に誡しむべきは寧ろ戦呼に勇む今の時に非ずして、却りて戦後国民の覚悟の上にあるべくと存候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮なるかなや、故国の運命を担うて勇む胡天の君が意気。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駒の朝勇み」という諺が有るが、駒が未だ馬と成らない内は、甚だしく逸り勇むもので、朝は好んで駆け回るが夕に及んでは、ヘトヘトになり朝の元気が無いのが常である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "全盤を見渡して良い手良い手と心掛けて勇むのは張る気の働きである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "獣も朝に勇むのは馬だけではない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬も牛もみな勇むのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫は却って暮夜に勇むのが多いが、朝から昼にかけて勇むものもまた甚だ多い。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍らに臥せる長男を呼び起せば、手を拍つて喜び勇む。",
              "citation": {
                "source": "沖の小島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "）これぞ敗けいくさの前兆と、味方は愁い……敵は勇む。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐさまご入来願わしくとあるんだから、早いところおいでなさいましよ」　素足に雪駄、巻き羽織のしのび姿で、いななき勇む伝六を従えながら、それなるご用主の内藤家へ行きついてみると、しかるにこれがなんともふつごうなことに、名人の看破したとおりなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ三つ四ついつしかに、敵の數の、やうやく多くなりけらし、こなたは未だ家あらず、敵の陣は落ちなく布きてこたびこそはと勇むつはもの。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、家は彼下だ……と思う時、始めて故郷を離れることの心細さが身に染みて、悄然としたが、悄然とする側から、妙に又気が勇む。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "エオスはアストレオスと契りて、制し難き雄心に勇む風の神を生みぬ。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は里の子供等を集めて、昔の剛者の物語など面白く言ひ聞かせ、喜び勇む無邪氣なる者の樣を見て呵々と打笑ふ樣、二十三の瀧口、何日の間に習ひ覺えしか、さながら老翁の孫女を弄ぶが如し。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす寒き二旬にわたる曇り日のやうやう晴れて初夏の陽の光やや強まるなべに、重き※袍ぬぎすてて厚き毛糸のシャツもぬぎ痩せし身の重荷おろしてちぢこめゐたる首伸ばし手足伸ばせば、船ゆ港を望むごとふるさと見ゆる心地して心は勇む。",
              "citation": {
                "source": "枕上浮雲",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「からすかんざえもんは　くろいあたまをくうらりくらり、　とんびとうざえもんは　あぶら一｜升でとうろりとろり、　そのくらやみはふくろうの　いさみにいさむもののふが　みみずをつかむときなるぞ　ねとりを襲うときなるぞ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「からすかんざゑもんは　くろいあたまをくうらりくらり、　とんびとうざゑもんは　あぶら一升でとうろりとろり、　そのくらやみはふくろふの　いさみにいさむものゝふが　みゝずをつかむときなるぞ　ねとりを襲ふときなるぞ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた達がはやく大きくなると、此の國にさむいさむい風が吹いたり、雪がふつたりしないうちに遠い遠い故郷のお家へかえるのよ。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
