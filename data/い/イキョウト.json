[
  {
    "uuid": "866a8f12-5caa-5a36-aa08-2e239aaeca10",
    "entry": "異教徒",
    "reading": {
      "primary": "いきょうと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
