        "examples": {
          "standard": [
            {
              "text": "次の戌の年には、何か新しいことに挑戦してみようと考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戌の年に生まれた人は、真面目で義理堅い性格が多いと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわあ、年男だ！ 次の戌の年が来るまでにもっと成長しなきゃ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "明治四十三年の庚戌の年に出来た会……ウン。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に大正壬戌の年、黄花未だ発せざる重陽なり。",
              "citation": {
                "source": "恒藤恭氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたくしは大正｜壬戌の年の夏森先生を喪ってから、毎年の忌辰にその墓を拝すべく弘福寺の墳苑に赴くので、一年に一回向島の堤を過らぬことはない。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋に生まる　私は戌の年で今年七十九歳になるのですが、至って壮健で老人メクことが非常に嫌いですので、従って自分を翁だとか、叟だとか、または老だとか称したことは一度もありません。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古事記』によるに、仲哀天皇の崩年は壬戌の年で、多分晋の恵帝泰安元年の壬戌のことと察せられる。",
              "citation": {
                "source": "石上神宮の神宝七枝刀",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに由って観れば幽林が脚気を病んでその男典を伴い丹羽村の万松亭に還ったのは寛政二年庚戌の年でその齢六十五の時である。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十九　嘉永三年｜庚戌の年枕山は門人｜溝口桂巌に編輯の労を執らしめて『同人集』初編二巻を刊刻した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして御手許に召置かれることになったものの中には、成化｜戊戌の年の述作にかかる『和唐詩』四冊、功徳院所蔵の『日本紀』の珍本および『園太暦』等がある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壬戌の年六月十一日崩りたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてタラシナカツ彦の天皇の御年は五十二歳、壬戌の年の六月十一日にお隱れになりました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、綱吉の若年の名は、右馬頭といっていたし、館林侯から出て、将軍家を継いだ天和二年も、戌の年だった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
