          "standard": [],
          "literary": [
            {
              "text": "そして九千七百円のアシスト製品のインパクトの大きさの背後にあるものもまた、「誰に何を提供するのか」との問いに切り返す見切りの鋭さである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "またインパクトのある商品を集め続けられるのか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはインパクト・ローンではない。",
              "citation": {
                "source": "革命を待つ心",
                "author": "――今の實業家、昔の實業家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロックンロールが持っていたトータルなインパクトを、ティーンエージャーたちは受けとめ、受けとめている証拠を、逆に自分の体をつかって表現してみせた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の二十世紀の精神はその音楽と舞踏の持つ想像力とインパクトを受け止めきれなかったのだ。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
