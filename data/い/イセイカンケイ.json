    "definitions": [
      {
        "index": 1,
        "gloss": "relationships with the opposite sex",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
