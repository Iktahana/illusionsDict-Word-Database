        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年は私の戌年なので、何か新しいことに挑戦したい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は戌年生まれで、温厚な性格だと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "次の戌年には、どんな犬のキャラクターが人気になるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "して、こなたの母御は当年何歳で、なんの年の御出生でござるかな」「母は六十で、戌年の生まれでございます」と、半七は答えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "某が相果て候今日は、万治元｜戊戌年十二月二日に候えば、さる正保二｜乙酉十二月二日に御逝去遊ばされ候松向寺殿の十三回忌に相当致しおり候事に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "万治元｜戊戌年十二月二日興津弥五右衛門｜華押　　　　　皆々様　この擬書は翁草に拠って作ったのであるが、その外は手近にある徳川実記（紀）と野史とを参考したに過ぎない。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は戌年の人に限って突くのだという説もあったが、かの延寿太夫は酉年の生まれで戌年ではなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも無理はないわ、私は戌年の生れだもの。",
              "citation": {
                "source": "犬神",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいことには、よほど後藤君もあの不動が欲しかったか、ちょっと私へたのむのに細工をしたことが後で分って笑いましたが、実は後藤君は酉年ではなくて、戌年であったのでした。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "不動の像が縁になったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八歳之時父（錦橋父）正明病死仕候」と云ひ、「池田杏仙正明、寛保二戌年正月十六日病死」と云ふのが一つである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五代将軍綱吉は、聡明の人ではあったけれど、愛子を喪った悲嘆の余りにわかに迷信深くなり、売僧の言葉を真に受けて、非常識に畜類を憐れむようになり、自身｜戌年というところから取り分け犬を大事に掛けた。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父のものは、俳諧連歌か何かを記入したものであつたが、父のものには、『品々万書留帳』といふ、明治七｜甲戌年二月吉日に拵へたものである。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、万石以上の面々ならびに交代寄合、参覲の年割り御猶予成し下され候旨、去々｜戌年仰せ出され候ところ、深き思し召しもあらせられ候につき、向後は前々お定めの割合に相心得、参覲交代これあるべき旨、仰せ出さる。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "田所君の報告によれば、文化六年那賀郡黒地村の棟附帳に、一、壱家　　万之助　歳五拾三　此者曾祖父源次郎義享保之戌年棟附御帖に間人と相附候得共、此度百姓被付上候様被仰付候　とある。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧徳島藩での、「郷士格以下｜身居調査書」というものに、他国より年来罷越居候流浪人、吟味の上村方故障無之分は、居懸百姓又は見懸人に相｜居、医者又は賤しからざる渡世仕来候者は、郡付亦は郷付浪人等に申付候様、享和二戌年御内達に有之。",
              "citation": {
                "source": "来り人の地位と職業",
                "author": "平民申付候事",
                "note": "青空文庫"
              }
            },
            {
              "text": "北御町奉行所御掛ニテ去ル戌年十二月十七日御呼出相成ル。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "明和戌年秋八｜月、そよ吹きわたるゆうべの風に、静かに揺れる尾花の波路。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、まだごく小さかった義姉が戌年なので、狗の絵を入れたらなどといったこともあって、かわいそうでならなかった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "母桂昌院が戌年生まれだとかいうので全国に手配をして犬の戸籍をつくった。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍綱吉が、戌年生れだったからである。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、戌年の犬公方も、戌年の柳沢吉保も、面当てを喰ったようなもので、どんなに怒ったかもしれますまい。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戌年生れの、将軍綱吉が、隆光や、桂昌院の献言をいれて、世の人間たちへ発令した、畜生保護令――いわゆる“生類おんあわれみ”と称する稀代な法律の厳行である。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――要するに、時の将軍家が、戌年生れだったのが、時の人民全部の、不幸なる生涯を約束してしまったわけだ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『申し上げまする』　綱吉も戌年生れなら、柳沢出羽守も、戌年だった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし内匠頭が犬だったら、戌年生れの将軍や吉保は、憐愍のなみだを流してやむまいにと、へんな気もちがしてならなかった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
