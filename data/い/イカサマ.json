        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「いかさま、お説の通りでございます。私の配慮が足りておりませんでした」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いかさま、これこそが天下に聞こえた名刀に相違ございません」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いかさま、そのお言葉を信じて、此度は命をお預けいたしましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いかさま、先刻の無礼、伏してお詫び申し上げます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いかさまにも、あのお方の物腰には、ただならぬ品格が漂っております」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いかさま、その勝負、私が証人として最期まで見届けましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
