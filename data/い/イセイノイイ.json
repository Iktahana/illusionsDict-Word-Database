[
  {
    "uuid": "b143735a-30f9-51da-a7db-c35e33504cc9",
    "entry": "威勢のいい",
    "reading": {
      "primary": "いせいのいい",
      "alternatives": [
        "いせいのよい"
      ],
      "is_heteronym": true
    },
    "grammar": {
