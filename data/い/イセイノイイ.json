    },
    "definitions": [
      {
        "index": 1,
        "gloss": "high-spirited",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「威勢のいい」演説で、候補者は聴衆の心を掴み、支持者たちの熱気を一気に高めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はベテラン営業マンとして、どんな難局でも「威勢のいい」調子を崩さず、相手を説得していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初めての全国大会に臨む若きアスリートは、不安を滲ませるどころか、「威勢のいい」気迫で周囲の期待を集めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祭りの会場は、「威勢のいい」掛け声と響き渡る太鼓の音で、熱気に包まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議で彼女は、既存の枠にとらわれない「威勢のいい」提案を行い、新しい方向性を示唆した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その政治評論家は、ニュース番組で「威勢のいい」言葉を使い、社会問題に対する鋭い分析を展開した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "もちろん仰向けに寝ていて描いたのだと思うがなかなか威勢のいい地図で、また頭のいい地図である。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四ページは消防隊の繰り出す威勢のいいシーン。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢のいい、」「あれだね。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理場の前には、もう揃った折詰の弁当が堆く、戸を圧して並んだが、そこへ幹事が通りかかるのを見ると、蔭から、腰掛を立って、印半纏の威勢のいいのが顔を出して、「白尾さん。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "印半纏の威勢のいいのでなく、田船を漕ぐお百姓らしい、もっさりとした布子のなりだけれども、船大工かも知れない、カーンカーンと打つ鎚が、一面の湖の北の天なる、雪の山の頂に響いて、その間々に、「これは三保の松原に、伯良と申す漁夫にて候。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつやは頗る威勢のいい女、少し酔っている。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "口では何のかのと威勢のいい事を言っていながら、やっぱり、周さんと別れるのが、誰よりも淋しかったのだろう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「申すまでもない、威勢のいい若い声だ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "撃劍の竹刀の撃合ふやうな音と、威勢のいい掛聲とが入り交つて、如何にも爽やかな感じである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "撃剣の竹刀の撃合うような音と、威勢のいい掛声とが入り交って、如何にも爽やかな感じである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢のいい獅子鼻なぞを持っている人は、自分の鼻に対してもじっとしておられない場合が無いとも限らない。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、どこをあてどもなしに走って、やっと気が注いたところで、そこに板屋根の小窓から威勢のいい燈の見えている家があった。",
              "citation": {
                "source": "馬の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや全く実に威勢のいい文句ばかり並べられたがね、遂に彼からは手の甲で一撃見舞って来てしまったんだが、僕は不覚にもそれはしっかり受けそこなってしまった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "普段は威勢のいい快活な老兵なのだが、うちに秘めたる激烈な凶暴性や執念深さを見せるようなこともあった。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりは老人で、皺々の険しい顔にどんよりした目、もうひとりは威勢のいい若者で、晴れやかにこやかな顔に派手な服は、我々を呼んだ出来事に比べると妙な感じがした。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤は恐ろしい威勢のいい犬であった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢のいい赤は其から幾年間を太十の手に愛育された。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢のいい赤は依然として太十にじゃれついて居た。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢のいい四手駕籠が次郎左衛門を追い越して飛んで行った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ今が花の三月となっても、毎日の雨に邪魔されていたらしかったが、きょうは俄か天気で世間も俄かに春めいたので、日が暮れると表には駕籠屋の威勢のいい掛け声がつづけてきこえた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちらの威勢のいいだんなが、やにわとおかしなことをおっしゃってどなりつけましたゆえ、つい腹がたったのでございます。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "印半纒を着た威勢のいい若い衆の二、三人が詰めていて、糸目を付けるやら鳴弓を張るやら、朝から晩まで休みなしに忙がしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の役人が車を五六台並べて通って行った時には、先生も生徒もみんな授業をよそにして、その威勢のいいのにみとれていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叔父は芸者に賛同を求めると、芸者は威勢のいい語気に合槌を打ちながら、「でも、こちらは随分沈んでらっしゃるのね、どうなさったのかしら。",
              "citation": {
                "source": "馬頭観世音",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚芳のおとなしい物腰に対して、この爺さんの方は威勢のいい商人であった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢のいい魚河岸の若い衆が、なんで突然日本橋から身を投げたのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "網をつみこんだ親舟、それをとりまく小舟は威勢のいいかけ声と共にたちまち岸をはなれて行く。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "広場では、いせいのいい子供たちが、ときどき、自分たちのそりを、お百姓の車に結びつけては、ずいぶん遠くまで、いっしょに走っていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきのいいいわしだアい」　ごんは、その、いせいのいい声のする方へ走っていきました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて、いせいのいい音を立てることでしょう。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
