        "examples": {
          "standard": [
            {
              "text": "港湾管理者によって、長期間放置された遺棄貨物のオークションが開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "賃貸契約終了後、元テナントが残した遺棄貨物の撤去費用が請求された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この倉庫にある遺棄貨物について、所有権は誰にあるのでしょうか？」と弁護士に相談した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "税関では、通関手続きが完了しないまま放置された遺棄貨物を適切に管理・処分する体制を整えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "解体される工場の跡地から、過去の事業活動で生じたとみられる遺棄貨物が多数発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさかこんなところに遺棄貨物が捨てられているとは、環境汚染が心配ですね」と地元住民が語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
