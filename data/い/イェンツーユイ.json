    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese high fin banded shark (Myxocyprinus asiaticus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
