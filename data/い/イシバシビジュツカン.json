        "examples": {
          "standard": [
            {
              "text": "石橋美術館では、夏期特別展として、印象派絵画の数々が展示される予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "来週末、久留米の石橋美術館へ友人たちと出かける計画を立てています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域の現代アートに触れたいなら、石橋美術館のコレクションは外せません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "九州旅行の際には、太宰府天満宮だけでなく、石橋美術館への立ち寄りもおすすめです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "先日、石橋美術館で開催された現代美術展で、刺激的な作品群に出会いました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今度の連休、どこか行きたいところある？」と聞かれ、「うーん、そうだなぁ、石橋美術館なんてどうかな？」と答えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
