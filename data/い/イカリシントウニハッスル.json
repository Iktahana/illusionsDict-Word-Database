        "examples": {
          "standard": [
            {
              "text": "政治家の汚職が発覚し、国民の怒り心頭に発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の友人に裏切られ、彼は怒り心頭に発し、激しく詰め寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が理不尽な扱いを受けたと聞き、母親は怒り心頭に発して学校に乗り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトの失敗の原因が内部告発によって明らかになり、社長は怒り心頭に発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "約束を何度も破られ、ついに彼の怒り心頭に発し、関係を絶つことを決意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大切な書類が何の断りもなく捨てられたと知り、彼は怒り心頭に発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "度重なる納期遅延と品質の低さに、顧客は怒り心頭に発し、契約解除を申し出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしは容易なことでは喧嘩を始めない代り、一たび怒り心頭に発するときは、それこそ容易にはおさまらない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
