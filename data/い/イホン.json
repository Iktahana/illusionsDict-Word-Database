        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "図書館の奥深くで見つけたその本は、まるで異本かと思うほど奇妙な装丁だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「これ、もしかして異本？ 内容が全然頭に入ってこないんだけど」と友人は首を傾げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い屋敷で見つかったその日誌は、現実離れした出来事が記されており、まるで異本のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、読んだ本が突然ページ順を無視して現れ、異本だと怯えた経験がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
