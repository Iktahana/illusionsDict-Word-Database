    "definitions": [
      {
        "index": 1,
        "gloss": "variant edition (of a book)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この古典文学の校訂版は、複数の異本を比較検討して作成された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "研究者は、失われた原稿の異本を探して、世界中の図書館を巡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古書店の片隅で、珍しい異本を見つけた時の興奮は忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "同じ作品でも、異本によって登場人物のセリフが微妙に異なることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "内容の本筋は古事記に依拠し、日本書紀とその異本とを参酌した。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "建久四｜癸丑年に十九なら安元元｜乙未年すなわち未歳生まれで寅歳でない、『東鑑』は偽りなしだから『異本曾我物語』は啌で寅歳生まれで虎と名づけたでなく寅時にでも生まれたのだろ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕の草紙に、かにひ（異本にがむひ）の花とあるはこれらしいが、色は濃からねど藤の花にいとよくにて、春秋と二度さくいとをかしとは眼皮と違ふ。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "宋本御覽が三國志を引て靈帝光和中の句を殘せるは、當時の異本或はかく作りし者ありけん。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに持つて生れた好古癖にまかせて、折角考証に考証を重ねて、在来のままの経籍とは違つたところのある異本を公にして、学界に寄与しようとすると、世間の人達は碌すつぽそれを読みもしないで、「あれは偽書ださうだよ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化十三年、伯父錦橋の歿する年に至つて、京水は料らずも系図の一異本を観た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのほかにも異本がない訳ではない。",
              "citation": {
                "source": "るしへる",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は以下にこの異本第三段を紹介して、聊巴の前に姿を現した、日本の Diabolus を一瞥しようと思う。",
              "citation": {
                "source": "るしへる",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女を評定所の給仕として差出したことについて「異本洞房語園」に次の如く記している。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで鎌倉時代以来の絵詞にはいろ／＼異本が出来たのである。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、一般には、絵詞は固定性が薄く、従つて、異本が多いのである。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は曾我物語の異本のことで、最人望の深かつたものであつた。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "翼あるによりて鳥といふ四三―四五【福その】parea beato per iscripto 消えざる福その姿にあらはる異本。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "地、二七・一一二以下にボンコンテの父につきて聖フランチェスコと鬼と爭へることいづ、すべてこの種類の物語中古の傳説に多かりきといふ、ミカエル（ミケーレ）と鬼とモーゼの屍を爭へりとの記事すでに聖書の中（ユダ、九）にあるをおもへ【天に屬する】異本。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "海は地中海二二―二四【わが歌をもて】異本、わが歌まで【ウリッセ】オデュセウス。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテミスはゼウスとレトの間に生れし獵の處女神なり【とゞまり】異本、走り【エリーチェ】カリスト。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し異説多し〔革紐を纏ふ者〕ドミニクス派の僧（この派の僧は革紐を帶とす）即ちわれトマス異本、「非難」。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる大詩人にも良き材料を供給するほど三四―三六〔今〕異本、今の字なし〔その疾き火〕雲の火即ち電光三七―三九〔ヨスエ〕ヨシュア。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "異本、「汝等の視力」（人智）五五―五七我等の智いかに力むともその自然の性としてこれが源なる神意を知るをえず、否知るに近しとさへいふをえず〔己に見ゆるもの〕われらの智に映ずるところ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹入るゝ息によりて笛が美音を發する如く、神の愛聖なる思ひを動かして諸靈に歌をうたはしむ異本、〔火衣〕一六―一八〔第六の光〕木星。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯帝紀が、種々の異本に通じた名であつて、一種類の史書の異名でないことだけは、明らかである。",
              "citation": {
                "source": "日本書と日本紀と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、更に推測を加へれば、日本書の帝紀が早く成つて、其が伝写を経て、様々の異本を生じて居たものとも考へられる。",
              "citation": {
                "source": "日本書と日本紀と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に古く尺素往来の所謂｜大舎人の鵲鉾は実は異本にある笠鷺鉾の誤りであらうと言ふ事は、武蔵総社の田植ゑに出た傘鉾にだしとして鷺の飾りの附けられてゐるのを見ても明らかである。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌（二首略する）人麻呂の歌としての伝説を信じても、是歌が、なほ、民間に流布したものと信じることは、他の人麻呂集の歌が、民謡として行はれた、と見えるのから推しても、また、「異本の歌」や「一云」とある、異伝を考へても、是歌の謡ひ広められたあとを見ることが出来る。",
              "citation": {
                "source": "短歌様式の発生に絡んだある疑念",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "書かれた根本を語る中に、色々な入れ語を交へて来たのが、又書きとられて根本の異本が出来て来る。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "向は色々の本を校正した經驗から、異本の出るごとに誤りを直さねばならぬといふので、初めは竹簡に書き、刊改を待つことにしたのである。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "錢曾の讀書敏求記――異本書目の祖　この珍本收藏の最初の解題が讀書敏求記である。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "相慶之の写本以外の異本があるなら、見たいな。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "異本『伯耆巻』にも、「奥州津軽の住人安東又太郎季長云々、此の安東と云は義時が代に夷島の抑へとして、安藤が二男を津軽に置ける彼等が末葉なり」ともいっている。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペクトルの色がそれぞれに美しいほんとうの色であるように、やはりそれぞれ正しい道なり原理なりが併立しうるように思われる。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
