[
  {
    "uuid": "ce13cdc2-f401-57a9-bb26-d252f38fd631",
    "entry": "石火矢",
    "reading": {
      "primary": "いしびや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
