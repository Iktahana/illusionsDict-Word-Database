    "definitions": [
      {
        "index": 1,
        "gloss": "to appear uncomfortable (with)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――女はクセのない男つて嫌がるものよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと云ってまた無理やりに嫌がる煎薬を口を割って押し込めば利く薬でももどしてしまい、まずい総菜を強いるのでは結局胃を悪くし食慾を無くしてしまうのがおちである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾が薄気味悪がって逃げ出そうとすると、急に妾を抱えて嫌がるのもきかないで妾に接吻しました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろこれは一種の病気であると認めて、近江屋でも嫌がる本人を連れ出して、二、三人の医者に診てもらったのであるが、どこの医者にも確かな診断をくだすことは出来ないで、おそらく年ごろの娘にあり勝の気鬱病であろうかなどというに過ぎなかった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしすぐに娘を連れて行くといっても、きっと嫌がるに相違ないと思ったので、夫婦だけがまずその行者をたずねて、彼の意見を一応きいて来ることにした。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昨夜、おばさん三味線を持って東京へ帰り（私に唄をうたわせ発声運動の目的で来たが私が避暑地の人達に聞かれるのを嫌がるので、）主人今朝大阪より此処へ戻る。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌がる、追っかける。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「済まないがね、蝶子さん、しばらく家へ来ていて、お母さんの面倒を見てあげて呉れないかね」　いま急に人手を入れて見たところで、看護婦などは嫌がるお母さんのことだから、馴染のない人間なら一層辛がりなさるだろう、「やはり、あんたが世話してあげるのが一ばんだ」と嘉六は申しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田島は前からイベットと知り合いだとこの女に云った処で仕方もなしきりが無いので嫌がる女を引きたててホテルの玄関から夕暗のなかに出して遣った。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横堀は蝨をわかせていそうだし、起せば家人が嫌がる前に横堀が恐縮するだろう。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "松島の死んだのを隠していて国家のためになるのなら、それは黙っておりますとも」「なにしろ、それを聴きますと他の職工たちが嫌がるもんですから、まあ、士気が鈍るというようなわけで、それで、なるべくはあなたに、どこかここから遠いところへ引っ越していただきたいとも思うんです。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後者の点だが、とりわけ日の暮れた後、ひとりにされるのを嫌がるという形で現れる。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人の嫌がることをなせ　これがマウント・ホリヨーク・セミナリーの立った土台石であります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人の嫌がることをなし、他の人の嫌がるところへ行くという精神であります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏は嫌がるから辛いので、辛いから不幸を感じるのだ。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋いものや苦いものは嫌がる人が多いには違い無い。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし嫌がるべしと定まった訳でも無い。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし甘藷など食うのは、嫌がる人になれば随分恐ろしい刑罰ぐらいに思うものもある。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年時代少年時代より壮老に及んで、自己の最大喫緊事件たる食物に於ける嫌がる嫌がらぬと好く好かぬとの変化遷移に驚かぬものは無かろう。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌がる嫌がらぬというは主観的である。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧を嫌がり、その嫌がるところの貧に附纏われ勝なところから、貧即不幸と感ずるのもこの理によるのである。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏を嫌がる強迫観念の強烈なのに囚われたものだけが生命に別状を起すのである。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の興業にも、他の都市から嫌がる俳優を連れてきて主役に据ゑて舞台に立たした、今度の主役もまた背景に押しつぶされなければいゝがと俳優達が心配しだした、さりとて殺伐であつても劇団に道具方がゐなくては、芝居にならないので道具方を追払ふわけにもいかず困つてしまつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかるところにあっては蛇の姿を嫌がるどころにあらず、諸邦でこれを家の祖霊、耕地の護神とせるは尤千万と悟った。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛は太く短くまっ黒で、おどおどした両の小さい眼を被いかくすほどもじゃもじゃ繁茂していやがる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛を描いて眼鼻をくっつけ、そうして知らんふりをしていやがる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたたちは、人生の切實の姿を見せつけられるのを、とても、いやがるからね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、いやに明けっ放しでいやがる。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、おどれがうま／＼と腹をおこしていやがる。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「癪に障るからなあ、――一寸ましな娘はみんなモグラの奴が引っかけて行っちまいやがるんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
