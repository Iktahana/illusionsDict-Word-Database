        "examples": {
          "standard": [
            {
              "text": "プロジェクトの成功のために、私も*一翼*を担いたいと思っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域のお祭りの準備に、ボランティアとして*一翼*を担った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その歴史的な出来事において、彼は重要な*一翼*を担った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
