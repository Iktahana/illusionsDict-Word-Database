    "definitions": [
      {
        "index": 1,
        "gloss": "one wing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鳥は*一翼*を広げて空を飛ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "飛行機の*一翼*が損傷したため、修理が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その古い建物は、左右対称に*一翼*ずつ増築された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "忽ち隻翼は又｜聳ち起り、竹を割く如き聲と共に、一翼はひたと水に着き、一翼は劇しく水を鞭ち沫を飛ばすと見る間に、鳥も魚も沈みて痕なくなりぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "双方、彼等を取替へて、御坊は羽黒へ帰りついでに、其の武士を釣つて行く、拙道は一翼、京へ伸して、其の屑屋を連れ参つて、大仏前の餅を食はさうよ――御坊の厚意は無にせまい。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仕事の一翼と自称する大袈裟な身振りの文学には、軽蔑を以て接していた。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一翼としての知的方面も、如何なる形で協力すべきかは、今後の興味ぶかい問題であらう。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "が私はとにかく笠原のおかげで日常の活動がうまく出来ているのだから、その意味では彼女と雖も仕事の重要な一翼をもっていることになる。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "本戦闘はフリードリヒ大王が三万五千の寡兵をもって六万四千の墺軍を撃破せる大王会戦中の傑作であって、兵力を一翼に集結し一挙に決戦を強要せる好範例である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで社会問題をあまり扱わなかったＮ・Ｒ・Ｆさえ時事問題をあつかわざるを得ない情勢におされ、広汎な反ファシズム文化運動の一翼につらなったのであった。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行動のヒューマニズム」も、その一翼にしたがわざるを得なかった更に巨大な更に行動的な、現実の社会的・文化的行動が起されていたという歴史の進みゆく歩どりの複雑さをこそ学ぶべきなのであった。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化の相関的一翼として文学においてもこの現象は今日あきらかに現れている。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家同盟婦人委員会が、プロレタリア文学における婦人の広汎な積極的な活動は真に階級的な文化闘争の一翼として、どれほど重大な意味をもつものであるか、各支部はこの分野の活動を直ちにとりあげるべきであることをいち早く各支部に徹底させることを遅らした。",
              "citation": {
                "source": "国際無産婦人デーに際して",
                "author": "――作家同盟各支部に婦人委員会をつくれ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "反宗教運動は、プロレタリア文化運動の一翼として、当然起ってくる活動です。",
              "citation": {
                "source": "反宗教運動とは？",
                "author": "――質問に答えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "階級闘争の一翼としての芸術活動の正当な任務を理解するために絶えず自己批判し、また「文戦」と論争をくりかえした。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "全プロレタリア解放運動の戦線強化につれて、その文化的一翼であるプロレタリア芸術運動は、今日もう実質的に国際化しているということである。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正年代には婦人参政権運動の一群の進歩的な婦人たちと並んで、労農党の一翼として、婦人同盟という進歩的な婦人の団体があった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもファシズムとの闘いへのはっきりした一翼です。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文筆家の覚醒の一翼として、翻訳家の現実問題がおこって来ている。",
              "citation": {
                "source": "文化生産者としての自覚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその闘いは、現代において二十世紀はじまりのヨーロッパにおいてのように、個人の偶然もっている条件――才能と環境――だけに頼らず、科学技術者として勤労人民の全戦列の一翼にむすびついて前進しなければならないという時代に入っています。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その軍勢は裾の薄氷のような白い塩田の方から進んで来て、黄褐色の大軍のざわめきとなり、泡だちあがって城を包囲し、外廓の一翼のあの峯を占め取ると、そこへ日本で初めて使う大砲の筒口を据えつけた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分はいま自分の家の一翼を建てさせてゐます。",
              "citation": {
                "source": "春日遲々",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "このダンサー時代に秦啓源は彼女を見出し、大西路の自分の住宅の一翼に住ませた。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、空襲のために罹災して、大きな家屋の一翼に住んでいる。",
              "citation": {
                "source": "聖女人像",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ都市の治安維持、進んでは行政、経済その他一般の平和工作が、現下の情勢では、まだ軍事的機関の一翼に連つて進められることは勿論であるから、あまり立ち入つたことは書けぬと思ふ。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらに付し、高度国防国家体制の必要がとなへられ、いはゆる文化の部門がその一翼として動員されることになつた理由は、国の力が、まだ、そこにもあるといふことの証拠であります。",
              "citation": {
                "source": "国防と文化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地方文化運動といふものの一翼に此の観光事業といふものを結び着けて戴きたい。",
              "citation": {
                "source": "観光事業と文化問題",
                "author": "――日本観光連盟第六回総会に於ける講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "全日本の文化機構の整備強化は、国家としての一元的文化政策の樹立と、民間文化団体の綜合的組織とが、両々相俟つて達成せらるべきであるが、既に展開の途上にある翼賛運動の一翼として、各地に擡頭しつゝある新文化団体は、正にこの方向にむかつて発足したものと私どもは確信し、また期待してゐるのである。",
              "citation": {
                "source": "戦時下に於る文化運動の意義",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて翼賛会としましては、この自主的に盛上つた力を十分生かし、且つ翼賛運動の一翼としてその効果を十分挙げられるやう、凡ゆる機会を捉へて連絡努力してきました。",
              "citation": {
                "source": "生活力の強化",
                "author": "――北陸地方文化協議会講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此児童劇、学校劇と云ふものは、勿論興行的にやられて居るものではありませんけれども、日本の文化運動の一翼としてその存在は無視することは出来ませぬ。",
              "citation": {
                "source": "日本演劇の特質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学座の芸能祭参加について岸田國士　文学座はその傾向と能力との許す範囲において、この挙国的行事の一翼に加はることになつた。",
              "citation": {
                "source": "文学座の芸能祭参加について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらに対し、高度国防国家体制の必要がとなへられ、いはゆる文化の部門がその一翼として動員されることになつた理由は、国の力が、まだ、そこにもあるといふことの証拠であります。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "まま子だったということが、だいいちよくないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
