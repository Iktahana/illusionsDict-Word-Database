        "examples": {
          "standard": [
            {
              "text": "あの廃墟に足を踏み入れるのは、畏怖嫌厭の念に襲われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ホラー映画のクライマックスシーンは、畏怖嫌厭の感情を掻き立てるものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "未知の深海生物の姿は、畏怖嫌厭を同時に抱かせる、異様なものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "且つ又、自分が姿を現せば、必ず君に畏怖嫌厭の情を起させるに決つてゐるからだ。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ又、自分が姿を現せば、必ず君に畏怖嫌厭の情を起させるに決っているからだ。",
              "citation": {
                "source": "山月記",
