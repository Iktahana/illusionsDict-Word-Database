    "definitions": [
      {
        "index": 1,
        "gloss": "distorted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この石は形が歪んでいて、まっすぐ立たない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の顔には、苦痛で歪んだ表情が浮かんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歪んだ正義感から、彼は過激な行動に走った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "仕方が無いから、Ｎさんが、それからおつしやつた、氣持のいい言葉を、歪曲すること無く、そのまま次に書き記す。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が薬師岳で観察した所に依ると、凡べてのカアル皆然りとは言われないが、カアルの初期は、雪が横一文字に堆くなっているに過ぎないが、その両端の垂下力が遅く、中央が速いためか、第二期には三日月形に歪み、更に拡大して勾玉形になって来ている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "歪んだポーズである。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞しい忍耐を以て、この歪んだポーズに堪え、根気よく真に魅力ある理想を探って行き度い。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "地殻の歪みが漸次蓄積して不安定の状態に達せる時、適当なる第二次原因例えば気圧の変化のごときものが働けば地震を誘発する事は疑いなきもののごとし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に一方において地殻の歪みを測知し、また一方においては主要なる第二次原因を知悉するを得れば地震の予報は可能なるらしく思わる。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下の歪みの程度を測知する事はある程度までは可能なるべく、また主なる第二次原因を知る事も可能なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかくも歪みが増すに従って現象の発生を期待する公算の増加するは勿論にて、従って歪みがある程度に達するまでは現象は起らずと安心すべき根拠を与うべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "破壊がただ一回に終らず、数回の段階的変化によるとすれば、これらの推移中に歪みの変化は複雑に起り、場合によりては毎回地震の強度は微弱なる事もあるべく、また時にはその中に強震を生ずる事もあるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合には第一にこれらの分布を知り、またすべての弱点に対する歪みの限界値を知り、同時にすべての弱点における歪みの刻々の現状を知るを要す。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にはエーテルと称する仮想物質の弾性波と考えられ、マクスウェルに到ってはこれをエーテル中の電磁的｜歪みの波状｜伝播と考えられるに到った。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば地殻の一部分にしかじかの圧力なり歪力なりが集積したために起ったものであるという判断である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち地殻のその特別の局部に、そのような特別の歪力を起すに到ったのは何故かという事である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の若者が団扇太鼓のようなものを叩いて相手の競争者の男の悪口を唄にして唄いながら思い切り顔を歪めて愚弄の表情をする、そうして唄の拍子に合わせて首を突出しては自分の額を相手の顔にぶっつける。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、これでもかこれでもかと眼新しい趣向を凝らして人性の自然を極度に歪曲したものばかり見せられている際に、たまたまこういう人間らしい平凡な情味をもった童話的なものに出会うと清々しい救われたような気持がするから妙である。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこに、彼の作品の恐ろしい「歪力」が感じられる。",
              "citation": {
                "source": "本質的な文學者",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物は不安に歪んで、病気のように瘠せ細って来た。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、そろそろ歩きはじめた、みんなそつとしてくれ、そつとしてくれ、おれは心配で心配でたまらない、たとへどんなことがあつても、おれの歪んだ足つきだけは見ないでおくれ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはけさきやべつの皿を喰べすぎました、そのうへこの窓硝子は非常に粗製です、それがわたくしの顔をこんなに甚だしく歪んで見せる理由です。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼童思慕詩篇肖像あいつはいつも歪んだ顔をして、窓のそばに突つ立つてゐる、白いさくらが咲く頃になると、あいつはまた地面の底から、むぐらもちのやうに這ひ出してくる、ぢつと足音をぬすみながら、あいつが窓にしのびこんだところで、おれは早取写真にうつした。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "居眠りなんぞをすると花輪が歪むからな。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな風にしたら、彼等の絶望した心を引き立たせ、彼等の歪んだ意志を――事件の行きがかり上、ほんの一時的な假りの性格をとつてゐたところの、が現在は、殆どその使ひ方も知らぬ異樣な力として彼等自身のうちに持ち扱つてゐるところの、その意志を調節してやれるでせう？",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来たときの疎髯を貯えた父の立派な顔が都会の紅塵に摩擦された興奮と、疲れとで、異様に歪んで見えた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い絨氈の上を鏡のない人間が歪んだシルクハット、胸は悲しい葬だ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛、痛つ‥‥‥』と、その時お前は顏を歪めて、敷布の上にのけぞりながら身もがきした。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十年間に、文学運動の上では、言文一致の提唱とその勝利があったが、そしてそれは、より直接的に社会生活を反映し得る手段を整えたものと云い得るのだが、作品に於ては、現実は歪曲され、愛国主義は鼓吹された。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一兵卒」はこれに比すると、量は十分の一にも足らないが、現実は遙かに歪められず自由に掴まれている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、「将軍」に最も正しく現実が伝えられているか否かは、検討の余地のある問題であるが、こゝには、すくなくとも故意の歪曲と隠蔽はない。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯横町は右下半に曲線を描いて子規庵は長さ一センチくらいのいびつな長方形でしるされてある。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その線路の右端の下方、すなわち紙の右下隅に鶯横町の彎曲した道があって、その片側にいびつな長方形のかいてあるのがすなわち子規庵の所在を示すらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
