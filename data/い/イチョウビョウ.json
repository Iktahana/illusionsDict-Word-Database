    "definitions": [
      {
        "index": 1,
        "gloss": "gastrointestinal disorder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ストレスが原因で、友人は長年、胃腸病に悩まされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "食あたりがひどく、彼は胃腸病の専門医を受診した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この薬は、軽度の胃腸病の症状緩和に効果があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "幸吉は、三年程前から、長い胃腸病を根治する為に、妻のお邦と、十二になる正太郎という長男と、九歳の裕次と元から家に使って居た二人の小間使を連れて、東京の山の手の或大きな病院の近くに出養生に行って居るのである。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇の団体に関係した事もある、工場を経営した事もある、胃腸病の薬を発明した事もある、また、新体詩というものを試みた事だってある。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かと云へば、医師の診断は、死因が胃腸病にあつて、負傷にはなかつたが、その医師の留守に、養子の医学士が診断した時には負傷が原因で神経系統を害した、と明言したのであつた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃腸病によく利くといふので友だちに勸められ、私は其處に一月近く滯在してゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "火山をめぐる温泉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は私の此処に来たのはひどい気紛れからで、胃腸病には日本一だというその山奥の白骨温泉に一箇月間滞在の予定で遥々駿河の沼津からやって来て居り、その帰りを長野市に廻って其処で我等の社中の短歌会を開く事になっていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に海城の宿舎にいたときにも、胃腸病の患者に眼薬の精※水をやって、あとでそれに気がついて、大いに狼狽して取戻したことがある。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると、女は長い事胃腸病で困つてゐたが、ある夜の夢に若い男が来てお腹を撫つて呉れた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある胃腸病院へ診察を求めに行ったころは、そこの院長もまだはっきりした診断を下しかねていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "□らいてう氏はしばらく胃腸病でやすんでゐらつしやいましたが此の頃は余程いゝやうです。",
              "citation": {
                "source": "編輯室より（一九一五年五月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの湯は胃腸病に効験いちじるしいさうなが、それを浴びるよりも飲むのださうな、田舎からの入湯客は一日に五升も六升も飲むさうな、土着の人々も茶の代用としてがぶ／＼飲むらしい、私もよく飲んだが、もしこれが酒だつたら！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝九時キャフェーとパンを喰って、一時が昼飯で、晩が七時と、キチンと巴里全体が定っているのでまるで胃腸病院へでも入った様なもんだ。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は乳を無暗に哺ませ過ぎて胃腸病を多くする。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に眼病や胃腸病の多いのは幼兒の養育法を過つて居るからである。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは乳を無暗に哺ませ過ぎて胃腸病を多くする。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に眼病や胃腸病の多いのは幼児の養育法を過っているからである。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二日に胃腸病院の神保孝太郎博士の診察を受けたこと。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "楠緒さんが死んだという報知の来たのは、たしか私が胃腸病院にいる頃であった。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "前は七号で神経痛だつたが、今度は胃腸病だ。",
              "citation": {
                "source": "続重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃腸病なぞばかばかしいと思つていい加減にあしらつてゐたのがいけなかつたのだ。",
              "citation": {
                "source": "続重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし胃腸病である自分はいささか閉口した。",
              "citation": {
                "source": "続重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山君、モー行こう」と暇を告げて立上る、大原は最早平日の如き元気にて床を離れ室を出でて玄関まで送り来り「中川君よろしく」中川「よろしくとは」大原「お登和さんにさ」中川も小山も「アハハ」○胃腸病の食品としては最初の内刺身粥パン半熟玉子等を良しとす。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に暑い時分の病気は大概胃腸病に原因しないものはありません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそれは胃腸病その他二、三の慢性病に限るけれどもその病院の主意は大概な病気を食物と運動方法で治療するというのだ。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど、××産婦人科とか、××胃腸病院とか、××耳鼻医院とか、一々名を挙げるのに煩わしいほど、数多の病院が、建てこんでいた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在日本の湯治場のちょッとぬるい湯の温泉は、たいがい胃腸病と神経病にきく、というような極く有りふれた効能が書いてある。",
              "citation": {
                "source": "人生三つの愉しみ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月一日（土）　島中君が南胃腸病院に入院中である。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石氏が修善寺で発病した時、同地にこれを見舞いその後胃腸病院に入院している時に一度これを見舞い、尚おその南町の邸宅を一両度訪問した以外殆ど無沙汰をし続けにしてしまった。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○明治四十三年十一月二十一日（麹町区内幸町胃腸病院ヨリ）（封書）　拝啓　その後は御無沙汰に打過候。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長の墓の前に供えられる花が、幾度か枯れ、幾度か代って、萩、桔梗、女郎花から白菊と黄菊に秋を進んで来た一カ月｜余の後、余はまたその一カ月余の間に盛返し得るほどの血潮を皮下に盛得て、再び院長の建てたこの胃腸病院に帰って来た。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄耳君が驚ろいて森成さんに坂元君を添えてわざわざ修善寺まで寄こしてくれたのは、この報知が長距離電話で胃腸病院へ伝って、そこからまた直に社へ通じたからである。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
