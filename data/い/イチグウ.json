[
  {
    "uuid": "c85bd21f-d13f-5356-b400-b4c9b45280cc",
    "entry": "一遇",
    "reading": {
      "primary": "いちぐう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
