  {
    "uuid": "9e1ddb3f-d31e-59a7-a42d-1f9be004e173",
    "entry": "一隅",
    "reading": {
      "primary": "いちぐう",
      "alternatives": [
        "ひとすみ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "corner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い寺院の、普段は人の目に触れない一隅から、貴重な仏像が発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は長年、古文書解読という学術界の一隅を静かに守り続けてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "静かな湖畔の一隅で、彼は一人、物思いにふけっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このプロジェクトにおいて、彼女は目立たない一隅の担当だったが、その貢献は計り知れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ねえ、この部屋のどこか、一番落ち着く一隅ってある？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "賑やかな商店街の一隅に、古くから続く小さな定食屋がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "映画館の一隅に坐っている数刻だけは、全く世間と離れている。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも知られぬ或る日、或る一隅に於ける諸君の美しい行為は、かならず一群の作者たちに依って、あやまたず、のこりくまなく、子々孫々に語り伝えられるであろう。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして中庭の一隅には、昔ながらの柚の花が咲いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万象の死んでる沈黙の中で、暗い台所の一隅に、こうした鮓がならされているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく駆け来る列車の一隅に座を構えて煙草取り出せばベルの音｜忙しく合図の呼子。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の山懷の一隅には非常時の嵐が未だ屆いて居ないのか、妙にのんびりした閑寂の別天地である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは真犯人の旧騎士吉田を今の新聞記者吉田に仕立ててそれをこの法廷の記者席の一隅に、しかも見物人にちょうどその目標となるべき左の顋下の大きな痣を向けるように坐らせておく必要があるのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロレンツのごとき優れた老大家は疾くからこの問題に手を附けて、色々な矛盾の痛みを局部的の手術で治療しようとして骨折っている間に、この若い無名の学者はスイスの特許局の一隅にかくれて、もっともっと根本的な大手術を考えていた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれかが席の一隅から野次を飛ばした。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦畑の一隅にてまつ正直の心をもつて、わたくしどもは話がしたい、信仰からきたるものは、すべて幽霊のかたちで視える、かつてわたくしが視たところのものを、はつきりと汝にもきかせたい、およそこの類のものは、さかんに装束せる、光れる、おほいなるかくしどころをもつた神の半身であつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は扉をひらいて部屋の一隅に立つてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十八日の夕方、妻クララに宛てて、「誰れももう疑へませぬ、私は巴里に居るのです、いま私の住まつてゐるこの一隅がどんなに物靜かであつても。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが谷地の池水を距ててＡ―丘の後へ入りかける夕陽を眺めているときででもあると（湊の生れた家もこの辺の地勢に似た都会の一隅にあった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼は私を部屋の一隅に引張ってきて熱心に私の納得の行くように話しつづけるのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガロンはロシア人共産党員とともに上海に入ると、直に大馬路の一隅で露支共産会合が開かれ、赤衛軍の決死隊が組織され、党員徽章が配付されると労農領事館には青天白日旗とソビエット・ロシアの聯邦旗が交錯して掲げられた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また僕は、卓子の一隅で蛙を食べている知合の旅女優、彼女は僕を見そめると、やってきて僕に囁いた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの卓子の一隅にはパラマント・オン・パレードで男前を見せたかのマツイ翠声がお可笑な顔をしてスープをすすっていた。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、つつましやかな氣持で甲板の一隅にぢつと佇みながら、今まで心の中に持つてゐた、人間的なあらゆる醜さ、濁り、曇り、卑しさ、暗さを跡方もなくふきぬぐはれてしまつたやうな、美しく澄み落ち着いた自分になつてゐた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその一隅にある傾斜の急な階段を手探りに登つて、登りついた二階の廊下の扉を開くと電燈のぱつとした、十疊ほどの長い廣間だ。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間から丘にかけて一帯に耕地が固くなって荒れるがまゝにされている中に、その一隅の麦畑は青々と自分の出来ばえを誇っているようだった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "会堂内で葬式のプログラムの進行中に、突然堂の一隅から鋭いソプラノの独唱の声が飛び出したので、こういう儀式に立ち会った経験をもたない自分はかなりびっくりした。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教授は自分の主裁している研究所の一隅に彼のための椅子を設けてくれた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについて思い出すのは十余年前の夏｜大島三原火山を調べるために、あの火口原の一隅に数日間のテント生活をした事がある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ量的にあまりに抽象的な、ややもすれば知識の干物の貯蔵所となる恐れのある学界の一隅に、時々は永遠に若い母なる自然の息を通わせることの必要を今さららしく強調するためにこんな蕪辞を連ねたに過ぎないのである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの現象の多くのものは、現在の物理的科学の領域では、その中でのきわめて辺鄙な片田舎の一隅に押しやられて、ほとんど顧みる人もないような種類のものであるが、それだけにまた、将来どうして重要な研究題目とならないとも限らないという可能性を伏蔵しているものである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象台の測器検定室の一隅には聖母像を祭ってあって、それにあかあかとお燈明が上がっていた。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "買いに行った店にはゴムのかかとのが無かったのでそのかわりに、かかとの一隅に小さな三角形の鉄片を打ちつけたのをなんの気なしに買って来た。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばまた、銀座松屋の南入り口をはいるといつでも感じられるある不思議なにおいは、どういうものか先年アンナ・パヴロワの舞踊を見に行ったその一夕の帝劇の観客席の一隅に自分の追想を誘うのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで聞いた事だが、その弘前の或る有力者のお妾で、まあ、当時は一流のねえさんであったようである）そうして、私のあたっている炬燵の上に置いた瞬間、既に私はそのお膳の一隅に雀焼きを発見し、や、寒雀！",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
