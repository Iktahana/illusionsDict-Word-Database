        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試合は最終イニングで両チームが点を取り合い、白熱した展開となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今のイニング、完全に流れが変わったね！」と監督が叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "九回の裏、このイニングで同点に追いつかなければ敗退が決まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "シャイニング、ブライト、イン、ア、キャビン。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "イン、ザ、ウィンドウ、イッツ、シャイニング、フォア、ミイ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いジャージーのトレイニング・パンツをはいてきたのに、その上から蚊に刺されたらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワンピースでなければいけないというなら、それでもかまわないが、なにかべつの色、たとえば、トレイニング・ウェアに合わせて、オレンジ色とかにしないと、つじつまが合わないではないか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しいトレイニングの後で嘔きたくなる時のような疲れを感じて、窓の外の太陽の光が妙に黄臭くて、起き上ろうとすると眼がクラクラして堪りませんので、生まれて初めて終日、床に就いておりましたが、あれは多分、烈しい神経の打撃からだったのでしょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺は断然、今後臆病になるトレイニングにとりかゝるぞ。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やがて、左うした嫉妬と絶望のどん底へ突き落される前提としてのトレイニングぢや。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "円い五六人坐れる卓子、高くなく下った家庭的なダイニングルーム・ランプ。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイニング夫人の「皇太子の教育」と題される文章が「皇太子殿下の御教育」と日本化された翻訳で『文芸春秋』に発表されている。",
              "citation": {
                "source": "ジャーナリズムの航路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイニング夫人の筆致にも抑えられたおどろきがある。",
              "citation": {
                "source": "ジャーナリズムの航路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないから、下宿の老婆を煽てて家じゅうから買物の空箱やら、クリイニングから洋服を入れてくるボウル紙の箱や何かをありったけ徴収し、それへ手当り次第に放り込んだのを糸で縛ってタキシへ投げ入れ、狂気のように疾駆させて、ほんとに間一髪のところで船へ聯絡する汽車の出発に間に合ったのだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、よく見ると、最近入念にクリイニングした形跡が、読まれるのである。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、その日の昼は、もうあなたと遊べなくなった淋しさと、口惜しさから、殆ど飯も食べずに、トレイニング・パンツに着更え、誰もいないＢ甲板をうろついていると、ひょッくりあなたと小さい中村｜嬢に逢いました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、その日の昼は、もうあなたと遊べなくなった淋しさと、口惜しさから、殆ど飯も食べずに、トレイニング・パンツに着更え、誰もいないＢ甲板をうろついていると、ひょッくりあなたと小さい中村嬢に逢いました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは間に合せの、ごまかしの、「点取り主義」の新劇舞台に馴らされた眼には、至極もつともなことで、文学座の現在行ひつゝあるトレイニング、基本練習にはさぞかし興味がもてまいと察せられるのです。",
              "citation": {
                "source": "文学座第二回試演に際して",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時に散会、ソレカラ下のクラブ、ダイニングルームで、暫く居て、羽織をシューバ〔毛皮外套〕の上からかぶって二時頃かえる。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このダイニングルーム、地下室、ひどくなったピアノをがんがんならして、若い作家が、若い品よくない女と、三鞭酒をのみ、浮かれ、さわいで居た。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○この講演会ピリニャーク一派の広告に、自分達つかわれたような形故不快であったので、クラブ、ダイニングルームのさわぎも気に入らず、モヤ第一にくどくくどく、自分に当って怒った。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗顔用タオル、赤いグリイス塗料、黒のライニング・ステック、楽屋用ワセリン一壜、白粉。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、精神のはたらきが極端に不均衡にならないために、健康で、溌剌とした感受性の土台になる、精神全体の絶え間なきトレイニングを勧告しているわけです。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "このトレイニングこそ、俳優の表情に、最も奥深い生命の輝きを与え、最も価値ある人間的魅力を添えるものだと信じます。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　精神のトレイニングになによりも効果のある方法について、僕の考えを述べる前に、君にひとつ質問をします。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分もう、僕の今迄の話しかたで、「教養」という言葉を、「精神のトレイニング」にすりかえたのだということぐらい察せられたでしょう。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "中等科の一年生としての一般教育は普通どおりに受けられ、その上ヴァイニング夫人の英語をはじめ、いろいろな人の進講をお受けになるので、相当重い御負担のようである。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　秋川の名をいうと、ボーイ長は、とたんに謹んだようすになって、「ダイニングで、食事をなすっていらっしゃいます」「おひとり？",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからテドオ、私、あなたに手をかして、あなたの先生の、色の生白いタヴァイニング氏の事を告げ口（それともいぢめたと云つてもいゝわ）したことがありましたつけ――ほら、何時も、私たちが、憂鬱な人と呼んでゐた、あの人さ。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "バイニング夫人が、英語をお教えしたりして、西洋のクラシック音楽についても、一応の興味をお持ちになっていたのであろう。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼に対してその後かわらぬ真情を持ちつづけたブロイニングの家庭である。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "善良な優しい「ロールヒェン」――エレオノーレ・フォン・ブロイニングは彼より二歳｜年下であった。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
