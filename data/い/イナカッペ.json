        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「いやあ、おらみたいな田舎っぺには、東京の駅は迷路みてえでさっぱり分かんねえ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "都会の学校に転校した初日、訛りをからかわれて「田舎っぺ」と呼ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は自分のことを「ただの田舎っぺですよ」と謙遜するが、実は鋭い洞察力を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "自分の鈍重な田舎っぺいを、明確に、思い知ったのは、つい最近の事なのですからね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎っぺいの取巻きがたくさんいる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も田舎っぺいですよ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」どんな意味で使ったにせよ、私には、田舎っぺいという言葉は耳に快くなかった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生におけるこの味いかた、この田舎っぺえさが藤村にあっては骨子をなしている。",
              "citation": {
                "source": "「夜明け前」についての私信",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――田舎っぺえは御免だよ」「英語が話せたり、ピアノが弾けなくちゃいけないのね、そんなら……」「ピアノなんかどうだっていいさ」　ぱらぱらと夥しい令嬢の写真版つきの雑誌を翻したが、英輔はふと真面目に傍に縫子のいることなど念頭にない自然さで考え深く呟いた。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美容師の方たちにおこられそうだけれど、日本の西洋流の化粧は田舎っぺだと思います。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と云って、お前はどうかと云われたら、私は大田舎っぺだと逃げておきます。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしその田舎っぺは西洋流でないだけです）　利口な女のひとの何気ない化粧と何気ない趣味の着物にあうと、浸み透るものを感じます。",
              "citation": {
                "source": "着物雑考",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事大的の田舎っぺー。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあんだ、田舎っぺの女中か。",
              "citation": {
                "source": "子供どうし",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田舎っぺのくせに、生意気だな。",
              "citation": {
                "source": "子供どうし",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺を田舎っぺだと思ってあなどっても、俺のまなこは、こんなにでっかい目っこだわ』　これは、笑い話だけれど、父さんには、その人の困ったり怒ったりする様子がよくわかるのだ」　父は、そして、アハハと笑った。",
              "citation": {
                "source": "おもしろい話",
                "author": "畔柳二美",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏で「ロンドンは田舎っぺえのロンドンになった」ので公園の鉄柵は塗かえ中だ。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかがいなかっぺいのけんつくぐれえに尾っぽを巻いて、江戸八百八町の名折れじゃござんせんか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると主人は、「いなかっぺはぐずでしょうがねえなあ。",
              "citation": {
                "source": "水菓子屋の要吉",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホイソラ、ホイソラ』いなかっぺえいなかっぺいのおたずねだ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京にいたとき、田舎から転校して来た生徒があると、「いなかっぺえ」といって、やっぱりみんなでからかったり、意地悪をしたりしたものだ。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
