[
  {
    "uuid": "3257ab88-3b16-5b7c-9fd7-ad362bea7b6f",
    "entry": "居残る",
    "reading": {
      "primary": "いのこる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
