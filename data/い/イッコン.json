          ],
          "literary": [
            {
              "text": "いや化の皮の顕われぬうちに、いま一献きこしめそう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もございませんがいさゝか歓迎のしるしまで一献さしあげたいと存じます。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りがかりには挨拶をしましたが、仔細あって、しばらく、ここへ参るまいと存ずるので、会釈に一献進ぜました。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫様にお祝儀を申上げ、われらとても心祝いに、この鯉魚を肴に、祝うて一献、心ばかりの粗酒を差上げとう存じまする。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "捻平この話を、打消すように咳して、「さ、一献参ろう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、御先達、お山伏は、女たちとここで一献お汲みがよいよ。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を持て酒を……サア平馬殿｜一献重ねられい。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事にお届が相済んで祝着この上もない……まず一献……」　贋せ侍斬りに就いて大目附へ出頭した紋服姿の石月平馬と、地味な木綿縞に町の低い役袴を穿いた三五屋、佐五郎老人が、帰り道に招かれて夕食の饗応を受けていた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一献頂戴の口ではいかがですか、そこで、件の、いが餅は？",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まま一献まいれ。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、嘘でない信に一献差すから、その積で受けてもらはう」「はあ、是非戴かして下さいまし」「ああ、もうこれには無い」「無ければ嘘なので御座いませう」「未だ半打の上有るから、あれを皆注いで了はう」「可うございますね」　貫一が老婢を喚ぶ時、お静は逸早く起ち行けり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一献掬まさずにはおかぬぞ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついてはおわび旁々、おちかづきのしるしに、粗酒一｜献さしあげたく候間、拙邸までおこし下さらば腰本治右衛門、ありがたきしあわせと存じ奉りあげ候」　粗酒一献とあるのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君から来信、一献傾けたいから用意して置いてくれとの事、さつそく在中の五十銭銀貨二枚を持つて街へ出かける、酒、魚、御馳走を拵らへる、三時頃から六時頃まで、めでたきさかもり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――春三君の芳志万謝、Ｓ屋で一献！",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつしよに出かけて一献酌んで別れた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主主義の方向が、民主主義文学者に明確に把握されていたならば、そして、新鮮な決意があるならば、ファシズムに抵抗を感じている文学者たちの会合として、一献は不用のものであった。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "参右衛門はどこで手に入れたものだか珍らしく私に一献酒を注いでくれた。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "就ては酒を一献酌もうではないかと云うから、私が之に答えて、「始めてお目に掛て自分の事を云うようであるが、私は元来の酒客、然かも大酒だ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一献酌もうとは有難い、是非お供致したい、早速お供致したい。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まず、一献」「いや、その儀は、取調べ確定の上にて」　と、三五郎は、強硬な口調でいった。",
              "citation": {
                "source": "大岡越前の独立",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はなくとも先づ一献過せ。",
              "citation": {
                "source": "竜宮の犬",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿へ帰って一献｜酌もうではありませぬか。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて帆をあげ勇ましく船出することも出来るでございましょう、取りあえず本席はそれを祝って、一献さしあげたく――」「ありがたいことでございます」と彼らは頭を低げた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一献――炊事の方？",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "男衆が、雪之丞に、「今夜、さじきにお見えになっている土部さまから、はねてから、柳ばしの川長で、一献さし上げたいというおはなしだそうですが――」「え！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何は無くとも、先ず一献、斯う云う所だが然うは云わねえ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の父の宗吉と私は、その晩、八幡様には行かないで、家で一献酌むことにしていた。",
              "citation": {
                "source": "田園の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎいっこん、ぎいっこん、――と、波に逆らいながら漕いでゆく櫓の音だけがかすかに聞えてきた。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
