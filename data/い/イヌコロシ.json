        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔話には、犬殺しとして村人から恐れられる猟師が登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は地域で有名な犬殺しだったが、実は人知れず野良犬の保護活動をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その町では、身勝手な犬殺しが横行し、住民を不安にさせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あるいは一時間｜乃至半時間の後には、残酷な犬殺しの獲物となってその皮を剥がれてしまうかも知れない。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "カアは、野良犬みたいに見えるから、いつ犬殺しにやられるか、わからない。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬殺しが歩るき、巫女が酒倉に見えるのもこの時である。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、来た来た、犬殺しの馬車が来た。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは犬殺しで帯へ挿した棍棒を今抜こうとする瞬間であった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "人なつこい犬は投げられた煎餅に尾を振りながら犬殺しの足もとに近づいて居たのである。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬殺しは太十の姿を見て一足すさった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殺すのよ」　犬殺しは太いそうして低い声で応じた。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見やがれ殺しはぐりあるもんか」　犬殺しは毒ついて行ってしまった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒繩で括った麻の空袋を肩から引っ懸けた犬殺しの後姿が見えなくなってから太十は番小屋へもどった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは犬殺しが何処かで赤犬の肉を註文されて狙いをつけたのだから屹度殺してやるとそこらで放言して行ったということを知らせる為めであった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際其頃は犬殺しの徘徊すべき時節ではなかった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ犬殺しの手にかけるなら自分でやっちまった方がいいと思って……」　太十は口をしがめた。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃ、おっつあん赤か、どうしたんでえまあ」　太十は犬殺しの噺をした。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは赤が死んだ日に例の犬殺しが隣の村で赤犬を殺して其飼主と村民の為に夥しくさいなまれて、再び此地に足踏みせぬという誓約のもとに放たれたということを聞いたからである。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は相の悪い犬殺しが釣した蓆の間から覗くように思われて戦慄した。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬殺しの棒は先を少し太くし、必ずこの木を用ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーコン卿の『シルヴァ・シルワルム』に、犬が犬殺しを識るは普通に知れ渡った事で、狂犬荒るる時｜微かに卑人を派して犬を殺さしむるに、かつて犬殺しを見た事もなき犬ども集り来て吠え奔ると。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
