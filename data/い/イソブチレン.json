        "examples": {
          "standard": [
            {
              "text": "イソブチレンは、合成ゴムやブチルゴムの主要な原料として、自動車タイヤや医療用ゴム手袋の製造に広く利用されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "石油化学プラントでは、ナフサ分解によって得られるイソブチレンを原料に、様々な化学製品が生産されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イソブチレンの重合反応は、特定の触媒を用いることで精密に制御され、機能性ポリマーの開発に繋がっています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "高性能プラスチックの原料として、イソブチレンを基盤とした特殊ポリマーの研究開発が活発に行われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「イソブチレンを扱う際は、静電気の発生に十分注意し、換気を徹底してください。」という注意喚起が、化学工場でなされました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "炭素数4の分岐アルケンであるイソブチレンは、その特異な構造から多様な化学反応を起こすことが知られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イソブチレンは、ガソリンのオクタン価向上剤としても使用されることがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
