[
  {
    "uuid": "2f4a786f-5c99-5ae3-9a60-0ca5d7c498e9",
    "entry": "言いかける",
    "reading": {
      "primary": "いいかける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
