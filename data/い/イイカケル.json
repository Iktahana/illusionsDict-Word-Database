    "definitions": [
      {
        "index": 1,
        "gloss": "to start to say",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "隣の田中さんに、新しい自転車について何か言いかけようとしたが、ちょうど電話がかかってきてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は彼女に「あの、すみません、少しお願いが…」と言いかけたところで、彼女に遮られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "記者が大臣に、最近の政策変更について質問を言いかけた瞬間、会場がざわついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "専門家は、その現象のメカニズムを説明し始めたが、途中で言葉を言いかけたまま、資料に目を落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「えーっと、それはね…」と彼は言いかけたが、すぐに「いや、やっぱりいいや」と首を振った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "母は、私の将来について何か心配そうな顔で言いかけたが、結局何も言わずにため息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「でも、基本的人権というのは、……」　と、誰かが言いかけると、「え？",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の主人にお知らせしようと思い、あなた、と言いかけると直ぐに、「知ってるよ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃア母上さんが……」と言いかけるのを自分は手を振って打消し、「黙っておいで、黙っておいで」と自分は四囲を見廻して「これから新町まで行って来る」「だって貴所……」「否や、母上さんに会って取返えして来る。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『出直そうよ、ぐずぐずしてるとまた鉄道往生と間違えられるから、』と行きかける、『人をばかばかしい、』と娘はまだ何か言いかけると内から母親があくび声で、『お菊もう寝るから外をお閉め。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "註文を引受けてきた出前持は、多少間の悪い面持で「お気の毒さまですが、もう看板だったので」　と言いかけるのを、年長の出前持はぐっと睨めて顎で指図をする。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小田さんを訪ねて来て、よかった」　と、思いながら、両手をついて、「――はじめまして、あたくし」　と、言いかけると、小田はいきなり、「判ってます。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いきなり、「明日……」　昼食を食べにホテルへ来ませんかと、信吉が言いかけると、しかし冴子は、「衣裳をつけて来ますから……」　と、もう立ち上っていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お蔦さんの事よ、」　と言いかける、口の莟が動いたと思うと、睫毛が濃くなって、ほろりとして、振返ると、まだそこに、看護婦が立っているので、慌てて袂を取って、揉込むように顔を隠すと、美しい眉のはずれから、振が飜って、朱鷺色の絽の長襦袢の袖が落ちる。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蝶ちゃんはいゝなあ、物を考えなくて――」　わたくしはその言葉が不服だったので、「そう見えて、こりゃまた、なんて浅墓な人なの」　と言いかけるのを、池上は押えるようにして、「いや、そりゃ考えるだろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日もアバタ面のお武家様が山賊退治に行くといって出掛けられましたが、今に下ってみえない所をみると……」　女中がそう言いかけると、もしと楓はせきこんで、「もしやそのお侍、信州訛りでは……？",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがし確かに一太刀浴びせ申したが、残念にも風をくらって……」　逃げてしまったと言いかけると、奉行はカラカラと笑い出した。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄の一徳か、動作も敏捷で、声も必要以上にきんきんと高く、だから客たちは、ほう綺麗だなと思っても、うっかり冗談を言いかける隙がなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄の一徳か、動作も敏捷で、声も必要以上にきんきんと高く、だから客たちは冗談を言いかける隙がなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことでお詫び……」と、豹一が言いかけるのを、終いまで言わさず、「構へん。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十銭芸者の話……」とマダムが言いかけると、「ほう？",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この重箱の蒔絵もやっぱり、）　と言いかける、と、目配せをした目が衝と動いた。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　と、言いかけると、清く頬のやせた客僧が、掌を上げて、またニコリとしながら、頭を一つ、つるりと撫でた。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもそう思いながら実行ができないだけですよ」　袖を放させて出ようとするのを、典侍はまたもう一度追って来て「橋柱」（思ひながらに中や絶えなん）と言いかける所作までも、お召かえが済んだ帝が襖子からのぞいておしまいになった。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこうして顔を突きあわせて、親しく物を言いかけるのは実に四年目であった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母さん、あのねえ……」などと言いかけるかと思うと消えて了う。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして浅井が何か言いかけると、「ハア、ハア。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "女御の所には洗練された女房たちがそろっているはずで、こうした露骨な戯れを言いかける人はないわけであると思って、考えてみるとそれは噂に聞いた令嬢であった。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い人に共通した浮わついたことも言わず、落ち着いたふうを見せていることで、二人の姫君付きの女房は皆物足らぬように思って、いどみかかるふうな冗談もよく言いかけるのだった。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は男の真似はよした方がいい」「だって、今は女だって男の方のすることを……」　と、一枝がいいかけると、照井は、「しかし、あんたは働いてない」「しかし、あんたは働いてない」　白崎は例によってすぐ照井の口真似をした。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と亀田先生がいいかけると、主人らしい人が、「へッ、あなたがあの御有名な亀田鵬斎先生！",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、小太郎が綴方の字を間違えて、それで南條先生が……」と、準之助氏のいいかけるのを、夫人は頷きながら、引き取って、「小太郎が、貴君に何か申し上げましたの？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、女将は急にまじめに返って倉地に向かい、「こちらはきょうの報正新報を……」　といいかけるのを、葉子はすばやく目でさえぎった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道理でさっき私がこの事をいいかけるとあの方が目で留めたんですよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、天野氏、貴殿は成田殿御息女とは、すでに御｜結納が……」と、小泉がいいかけると、新一郎は憤然として、「天下大変の場合、左様な私情に拘っておられましょうや。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "静也は籐椅子に腰を下し、手巾で汗をふいてから、「時に……」　と、いいかけると、彼女はそれを遮って言った。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to speak to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "道で偶然会った友人に、「やあ、久しぶり！」と言いかけたが、相手はすでに遠くにいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "裁判官が「異議あり」と叫ぼうと言いかけた瞬間、被告人が突然立ち上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新製品発表会の壇上で、開発責任者は聴衆に向かって「皆様、本日はお忙しい中」と言いかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "駅員さんに切符の買い方を尋ねようと言いかけたが、ちょうど窓口が空いたので、そちらへ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "隣の席に座った人に、気になっていた展覧会の話題について、そっと言いかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "記者会見で、大臣は国民へのメッセージを丁寧に言いかけたが、質問攻めに合い、最後まで述べられなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
