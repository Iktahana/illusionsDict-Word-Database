[
  {
    "uuid": "ccc70ae5-ddc4-5585-b562-ae72f04facdb",
    "entry": "イタリア人",
    "reading": {
      "primary": "イタリアじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
