      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Italian (person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "著名なイタリア人建築家が、新しいプロジェクトについて議論するために来日した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "友人が、イタリア人シェフが営む本格的なイタリア料理店を推薦してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その論文は、ルネサンス美術を専門とするイタリア人歴史学者の詳細な分析に基づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "街角で道に迷っていたイタリア人観光客に、地図を指し示してあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの、すみません。イタリア人の方が書いた本を探しているのですが…」と、店員に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国際会議の席で、イタリア人代表団が新たな経済協力の提案を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "近所の公園で、イタリア人らしき家族が楽しそうにピクニックをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "欧州のどこかの寄席で或るイタリア人の手先で作り出す影法師を見たことがある。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃よく話の種になったイタリア人がある。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田の居た二階の縁側に立って見ると、裏の塀越しにイタリア人の家の庭から縁側が見下ろされる。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を尋ねたり、墓を訪うたり、美しい夢ばかり見ていたあの頃の自分には、このイタリア人は暗い黄泉の闇に荒金を掘っている亡者か何かのように思われた。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アクセントのおかしいイタリア人の声が次第に高くなる。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は黒田も地方へ行ってしまってイタリア人の話をする機会も絶えた。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを我慢して相手にしないでいたら、最後の捨て言葉に「日本人はもっとゼントルマンかと思った」と言うから、私も「イタリア人はもっとゼントルマンかと思った」と答えて、それきり永久に別れてしまった。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い異郷から帰って来たイタリア人らは、いそいそと甲板を歩き回って行く手のかなたこなたを指ざしながら、あれがソレント、あすこがカステラマレと口々に叫んでいる。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い国にさすらいのイタリア人が、この歌を聞くときっと涙を流すという。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片言の英語で赤帽相手に齷齪していたイタリア人の高位司祭がいたので、数分ばかり手間取ったが、手荷物輸送をパリ行きで手配してあると伝える手助けをした。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人は彼異様に鋭き声を発せし人をイタリア人ならんと思へり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人はイタリア人にて、ロシア人と対話せしことなしと云ふ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア人だとか、イギリス人だとか、スパニア人だとか、フランス人だとか云ふが、要するにその申立をした人が自国の人でなくて、外国の人だと思つたのだ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア人の談話を聞いたことのないイタリア人はロシア語だらうと云ふ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭い声というのは、この証人はイタリア人の声だと思っている。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉は聞きとれなかったが、音の抑揚で、言ったのはイタリア人だと確信する。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この証人はイタリア人で、ロシア人と話したことはない。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども鋭いほうの声に関しては、その特異な点は、――彼らの意見が異なっていたということではなくて――イタリア人と、イギリス人と、スペイン人と、オランダ人と、フランス人とがそれを説明しようとしているのに、めいめいがみんなそれを外国人の声だと言っていることなのだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア人はロシア人の声と信じているが、『ロシア人と話したことはない』のだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、もう一人のフランス人は、前のフランス人と違って、その声をイタリア人の声だと思いこんでいるが、その国語を知らないので、スペイン人と同様に『音の抑揚で確信』しているのだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが邦で、拇指を食指と中指の間に挟み出し人に示すは、汝好色なりという意という事だが、イタリア人などにそれを見せると、火のごとくなって怒る。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後｜河鍋暁斎がキヨソネとかいうイタリア人に、絵画と写真との区別心得を示した物を読んだ中にも、実例を出して、似た事を説きあったと憶える。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンリ・エチエンの『アポロジ・プー・レロドト』十章に、十六世紀のイタリア人、殊に貴族間に不倫の行多きを攻めた末ポンタヌスの書から畜類に羞恥の念ある二例を引く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア人ジォヴァンニ・バッチスタ・バシレの『イル・ペンタメロネ』の四巻一譚に、ミネカニエロ翁雄鶏を飼う。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その頃イタリア人から成る「黒手組」の裁判が行われて、新聞紙を賑わしていた時であって、彼の許へは一日何通となく脅迫状が舞い込んだのであった。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの脅迫状はいずれも、拙い文章で書かれてあったが、文章の構造から、差出人はイタリア人であることが、想像された。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の犯罪によって捜索の範囲をイタリア人たちの方へ拡げねばならなくなったが、果してそれがイタリアの犯罪者の仕業であろうか。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォーカーの家に出入したものの中に、イタリア人はなかった。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはあたしを見ると、好きだ好きだと仰言るし、イタリア人はイタリア人で、あたしを放してくれないし、まア、何んでもいいわ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
