[
  {
    "uuid": "7b284dcc-6ec0-55ce-b1ba-52606e3eee76",
    "entry": "一上一下",
    "reading": {
      "primary": "いちじょういちげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
