    "definitions": [
      {
        "index": 1,
        "gloss": "(spare) time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最近仕事が立て込んでいて、ゆっくり本を読む暇もない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「ごめん、今日はちょっと暇がなくて、また今度にしてもらえる？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ようやく一息つける暇ができたので、庭の草むしりをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "猫は日向で丸くなり、一日をのんびりと過ごす暇を謳歌している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "その蕩揺といふことがない以上、生活の余暇の芸術ではあり得ても、芸術生活となることは出来ない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さうだとすると、これはまたしても芸術の中に生活を見出すことのない、「生活の余暇の芸術」であると思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつまり是等の一呼吸詩歌が十分に人一人の仕事となる性質のものでなくて、生活の余暇に出来る――といつて語弊があるならば、生活に随伴的に出来るものとして意義のあるものだといふことを証示する、一つの事ではあるまいか？",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、新短歌が今後益々作られることに、異存のあるわけもないが、新短歌が「生活の余暇的なもの」といふ私の考へにして間違ひがないならば、新短歌が民族詩歌の発展に寄与する所は少ないであらう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも貧乏暇なしでね」とＢは云ふ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、人がもし無限に面白かつたら笑ふ暇はない。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母の来るのはいやに遅いが、どうせ近所へのお暇乞ひがまた長いのであらう。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者の暇々には日に何べんとなくやつて来て、そしてはあんたを抱いたものだ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンが学校に行ってる間、夫人は暇を盗んで熱心に読書をし、手の及ぶ限り、日本の古い伝説や怪談の本を漁りよんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の暇あなた本よむです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく暑中休暇にはいり、東京から二百里はなれた本州の北端の山の中にある私の生家にかえって、一日一日、庭の栗の木のしたで籐椅子にねそべり、煙草を七十本ずつ吸ってぼんやりくらしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑中休暇がすんであたふたと上京したら、馬場の海賊熱はいよいよあがっていて、やがて私にもそのまま感染し、ふたり寄ると触ると Le Pirate についての、はなやかな空想を、いやいや、具体的なプランについて語り合ったのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の読本の、正行が御暇乞の所、「今｜一度天顔を拝し奉りて」といふのがヒントをなした。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の背後の、ブランコのある所を見たいと思つて建物の横を廻りかけたが、何しろ休暇中だし、朝の五時半であつたし、小使の女房か女学部の舎監であつたか知らないが、炊事場の小窓から一寸顔をのぞけて、ケゲンさうにこちらを見たから、諦めてコソコソと引返した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は休暇中の自分の予定が、まだ三分の一も出来てゐないことでヂリヂリしてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はこの休暇中旅行だつてしたことはないのですもの図書館位行きますよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて彼等の間では彼等が世間に向つて抱くその野望からの当然の産物として出て来なければならなかつたのは、仲間同志に於ては、その仲間の誰でもを褒めたとも譏つたとも理由の分らない噂――まあまあ噂――さうつまり噂なんだ、それを作り出さんことに閑暇がない。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "落第や其の他の事情で土地の学校を出て他所に転校を余儀なくされた彼は、わざわざ、もう暑中休暇も終るといへば、また立つて行くのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういつたつて、今我々には「集団」の声は余りに耳近く響き、各人各様の閑暇なぞ、却々以てあるべくもない。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入の夢や小豆の煮えるうち　藪入で休暇をもらった小僧が、田舎の実家へ帰り、久しぶりで両親に逢ったのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日だけの休暇を楽しむ、可憐な奉公人の子供は、何の夢を見ていることやら、と言う意味である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また出ますと云うたら宿は何処かと聞いたから一両日中に谷中の禅寺へ籠る事を話して暇を告げて門へ出た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少しゆっくり考えてかく暇があったらもう少し面白い昔話が思い出せるかもしれないが、原稿｜〆切という日曜日の朝のしかも出かけ前に書くのであるから遺憾ながらこれだけである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹を引取って後も、郷里との交渉やら亡き人の後始末やらに忙殺されて、過ぎた苦痛を味わう事は勿論、妹や姪の行末などの事もゆるゆる考える程の暇はなかった。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり農家の暇な時季を選んだものだろう。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "各自の望みを追うに暇のない世人は、たまに彼の萎びた掌に一片の銅貨を落す人はあっても、おそらくはそれはただ自分の心の中の慈善箱に投げ入れるに過ぎぬであろう。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校時代に夏期休暇で帰省する頃にはもういつも盛りを過ぎていた。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この突然の暇乞ひもまた、無言の微笑でもつて許された。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣道場の入口から、時々水を飲みに、剣道用の繻絆姿で現れるのは生徒だが、それは選手だから暑中休暇も帰省しないで道場にゐるといふわけである。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "――けれどもその考へもセンチメントの私の考へに過ぎないとまた反対にも取つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
