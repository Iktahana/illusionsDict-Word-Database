    "definitions": [
      {
        "index": 1,
        "gloss": "critical (touch and go) situation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
