    "definitions": [
      {
        "index": 1,
        "gloss": "the husband of one's younger sister",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "無病息災を売物のようにしていた妹婿の吉田が思いがけない重患に罹って病院にはいる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹婿は日曜などにはよく家内連れで方々へ遊びに出た。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの氷店へはいって休んだ時には、森の中にあふるる人影がちらついて、赤い灯や青い旗を吹く風も涼しく、妹婿がいつもの地味な浴衣をくつろげ姪にからかいながらラムネの玉を抜いていた姿がありあり浮ぶ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来ての話に、無心したところ、妹婿が出て応待したが、訳のわからぬ頑固者の上に、いずれはこの家の財産は養子の自分のものと思ってか随分けちんぼと来ていて、結局鐚一文も出さなかった――と、柳吉はしきりに興奮した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別れておっても、去り状はやってないから、やっぱり夫婦、舅殿の讐も打たし、妹婿の讐も打たす」　直助はお袖を云いくるめた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "職人風情を妹婿に持つたとて、姉の見得にも手柄にもなるまい。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モウ、これからは何もかもアンタの思い通りにしなさい」　それから混雑の中を押し分け押し分け妹婿や、養子達に一々、この事を報告してまわった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾エ氏は父を安右衞門と云つて、孝高の妹婿である。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、はじめは王様の妹婿さまを。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川島の妹婿たる佐々木照山も蒙古から帰りたての蛮骨稜々として北京に傲睨していた大元気から小説家二葉亭が学堂提調に任ぜられたと聞いて太く激昂し、虎髯逆立って川島公館に怒鳴り込んだ。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "職人風情を妹婿に持ったとて、姉の見得にも手柄にもなるまい。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事のものとは、外でもない、妹婿の杉浦非水氏である。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひろは今でも辰之助の妹婿の山根に心が残っていたけれど、お絹に言わせると、金には切れ放れはよかったし、選びもおもしろい山根ではあったけれど、別れぎわが少し潔くない点があったので、その手前としても、おひろはのめのめ商売なぞしているのは厭だった。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今此文に由つて、蘭軒の養孫棠軒と霞亭の養子悔堂の妹婿との交際が証せられるのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は姫路に妹婿｜土方伴六｜正旗を訪ひ、鳥取に顕忠寺中の兄田中悌庵が墓を展したのださうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）これは香以の妹婿に当たる細木伊兵衛のつくつたものである。",
              "citation": {
                "source": "身のまはり",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の妹婿で、ミジューエフってんだよ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "チチコフの半蓋馬車は、ノズドゥリョフと妹婿が乗った半蓋馬車と並んで駈けて行ったから、途々ずっと彼等三人は自由に談話を交わすことが出来た。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、妹婿が聞き咎めた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、妹婿が応酬した。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹婿も、さすがに賭まではしなかった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその話にも妹婿は疑いをさし挟むことを忘れなかった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、妹婿が訊いた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そうは言ったが、妹婿はやはり腑に落ちないらしく、首を振った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹婿はちょっと見て、ただ首を振っただけであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は右に左に、チチコフと妹婿とへ、どちらのコップへもしきりに酒を注いだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼はノズドゥリョフがどうかして話に夢中になったり妹婿のコップへ酒を注いだりしている隙に、急いで自分のコップの酒を皿へこぼしてしまった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "チチコフも、妹婿のいる前では、例の重要な問題をノズドゥリョフに切り出す気にはどうしてもなれなかった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹婿とはいい条、局外者には違いなく、然もこの問題は、こっそり二人だけでしんみりと語りあう必要があったからだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
