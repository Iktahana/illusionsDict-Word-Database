[
  {
    "uuid": "6ed9208f-444b-5219-aab7-f64f18407928",
    "entry": "如何ばかり",
    "reading": {
      "primary": "いかばかり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
