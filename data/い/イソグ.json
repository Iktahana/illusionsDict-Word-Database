[
  {
    "uuid": "1c5eb6fe-567f-5cd4-bd0f-dd2922ebd7ee",
    "entry": "急ぐ",
    "reading": {
      "primary": "いそぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
