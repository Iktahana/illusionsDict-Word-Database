    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to hurry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「もう時間がない。急いで支度しないと間に合わないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この書類は締め切りが明日なので、急いで仕上げなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は雨に降られそうになり、家路を急いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「そんなに急がなくても大丈夫だよ。ゆっくりでいいからね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顧客からの問い合わせに、彼は急いで返信を作成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "朝の通勤ラッシュ時は、皆一様に足早に駅へ急ぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "救急車は患者を乗せ、サイレンを鳴らして病院へ急いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実はたゞ行りさへすれば好いのに、その効果を知ることを急ぐことから起るのだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は荒寥とした枯木の中を、葱さげて家路に急ぐ人の姿は、さうした冬の季節の中で、ふしぎに物侘しく、孤独にふるへる生の果敢なさを感じさせ、何かしら或る暖かい、焚火の燃える家郷への、魂のノスタルヂアを追懐させる。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の八時すこしまへで、學校に急ぐ中學生の列が、黒くぞろぞろ、つづいてゐた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山の上で、朝から夕立に遇っては堪まらないと、多年山登りの経験から気がついて、呆れ顔の導者を促して路を急ぐ、岩角を上ったり、下ったり、偃松や黄花石楠花の間を転がるようにして走ったが、その間に幻影は消え消えながら、三度出た、しかし心配ほどもなく、霧は奇麗に拭われて、雨にはならなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、彼とても特別に急ぐような、見っともない事はしない。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉は、翁が福慈神に近付くとき胸に叫んだと同じ言葉ではあるが、翁はただ呟いただけで山に急ぐこころは無かった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいてなお急ぐこころは湧き出でない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、もう知らん顔で三要は座を立ち法堂へ急ぐ様子でした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は作楽井とその息子の時代と、私の父と私たちと私たちの息子の時代のことを考えながら急ぐ心もなく桑名に向っていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもジョバンニは、いつかまた深く首を垂れて、そこらのにぎやかさとはまるでちがったことを考へながら、牛乳屋の方へ〔急ぐのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酉さまへ諸共にと言ひしを道引違へて我が家の方へと美登利の急ぐに、お前一｜處には來て呉れないのか、何故其方へ歸つて仕舞ふ、餘りだぜと例の如く甘へてかゝるを振切るやうに物言はず行けば、何の故とも知らねども正太は呆れて追ひすがり袖を止めては怪しがるに、美登利顏のみ打赤めて、何でも無い、と言ふ聲理由あり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな山の中で休むより、畑へ往ってから休もうというので、今度は民子を先に僕が後になって急ぐ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酉さまへ諸共にと言ひしを道引違へて我が家の方へと美登利の急ぐに、お前一處には來て呉れないのか、何故其方へ歸つて仕舞ふ、餘りだぜと例の如く甘へてかゝるを振切るやうに物言はず行けば、何の故とも知らねども正太は呆れて追ひすがり袖を止めては怪しがるに、美登利顏のみ打赤めて、何でも無い、と言ふ聲｜理由あり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説といふものはだらだらして、くだらないことを細々と書き立てるので、讀むからに退屈であり、僕のやうな結論を急ぐ性急者には、てんでのつけから讀む氣がしない文學である。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半さん急ぐのか」　「なーに急ぐと云ったってどうせ大した用じゃねえんだよ」　半五郎、源兵衛の傍へ腰を掛けて、　「併し、お前が国へ帰って堅気になって居ると聞いたが、まさか此処にいるたァ夢にも思わなかったよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "七五郎、　「暫く居るンだろう」　「今夜帰るつもりだ」　お静、　「まあ、今夜帰るの」　「ウン」　「馬鹿に急ぐんだな、おい、ゆっくりして行けよ、久し振りに来たンじゃねえか」　「せめて二三日遊んで行ったらどう？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次、Ｔ「昨夜、芝居が　果ててから　帰りを急ぐ仲蔵　の駕籠を……」（此のタイトル次の画面にＯ・Ｌして）　＝深夜の街　帰りを急ぐ駕籠一丁。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝街　山左、左膳にお小夜と半次それに長七と君江が急ぐ。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の方面からは、　武蔵の舟が急ぐ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方の舟が荒波蹴立てて急ぐ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば自分はそのエルサレムへ急ぐ巡礼だった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午過妻とともに本郷の喜福寺へ急ぐ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の脇につきつきりの編輯者は印刷を急ぐためにその原稿を一枚一枚はぎ取るやうに持つて行つた。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅で、列車からプラットフォームへ降りて、あわたゞしく出口に急ぐ下車客にまじって、気おくれしながら歩いていると、どこからやって来たのか、若々しく着飾った、まだ娘のように見えないでもない女が、清三の手を握らんばかりに何か話しかけていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この荷物は急ぐんだぞ。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この荷物は急ぐんだぞ。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りは登りよりかずっと勾配が緩やかで、山の尾や谷間の枯れ草の間を蛇のようにうねっている路をたどって急ぐと、村に近づくにつれて枯れ草を着けた馬をいくつか逐いこした。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そう、あの局の帰りに来ると宜んだけど、家に急ぐ用が有ったもんだから……」　といい乍ら二人は中に入った。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しほだる花や水の音や、家路をいそぐ人々や。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "先をいそぐ身は今更引っ返して詮議もならないので、彼女は娘をそのままにして先方へ行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
