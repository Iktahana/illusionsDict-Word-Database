          ],
          "literary": [
            {
              "text": "貧乏していると、へんに片意地になるもので、どんな親しい人からでも、お金の世話になりたくないものです。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとッつさんのは言い出すとすぐ片意地になるから困る」「なに……なにが片意地なもんか。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、Ｋさんが牛肉と酒と蚊取線香とを持つて来て飲まうといふ、飲む、食べる、歩く、唄ふ、そして帰る、Ｋさんは酔ふとなか／＼片意地になる、ＳからＭへまはつたゞけでやつと連れて戻つた、大出来／＼、樹明君をよんだのに来なかつたのは残念／＼。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "怨み憤るに先立ちて先見の明なかりしおのれが檮昧を愧づべきに、未練に未練を重ねて離行く女の後を追ひ、是が非にも己が実意の底を見せて改心させんと片意地になるが如きは以ての外の不量見なり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方も意地になる。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の方も意地になる。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことされちゃ、あたしは意地になるだけだわ、いいえ、あたしにうしろ昏いとこあるからじゃない、意地でなら、一緒に死んであげてよ、あたしが潔白なことあなたに見せるためなら、だけど、あたし、それじゃあなたの他人になって死ぬのね、といった。",
              "citation": {
                "source": "リラの手紙",
                "author": "豊田三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親には親の考へがなうてはすまんけえ、いろ／＼と気をもんどるのに、われや何故わしがものを云ふと直ぐ意地になるぢやらう。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちで何かいうと、なお意地になるんだから」「ええ、わざわざ陰陽不和を醸すように仕向けるのね」　お延が叔母とこんな批評を取り換わせている間、叔父はにこにこして二人を眺めていたが、やがて会話の途切れるのを待って、徐ろに宣告を下した。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドノバンの呼吸は微弱である、もし肺に影響するとだいじになる。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
