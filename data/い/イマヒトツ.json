        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この映画、映像は綺麗なんだけど、ストーリーが今ひとつだったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の提案は悪くないんだけど、どうも斬新さに欠けて今ひとつなんだよなあ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "新しいパソコンを買ったはいいものの、期待していたより速度が今ひとつでがっかりした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "今日の体調はどう？」「うーん、悪くはないけど、今ひとつすっきりしない感じ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
