[
  {
    "uuid": "f54fe02f-5dd8-57d2-b32f-b7cd4032bdfc",
    "entry": "今ひとつ",
    "reading": {
      "primary": "いまひとつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
