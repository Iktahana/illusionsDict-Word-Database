    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one more",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "料理は完璧に見えたが、シェフは満足せず、今ひとつスパイスを足した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の議論には説得力があったが、決定的な証拠が今ひとつ足りなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ゴールまであと少し。今ひとつ、最後の力を振り絞れ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし人生に今ひとつの希望がある。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとうたにことの飽かねば今ひとつ、「とくと思ふ船なやますは我がために水のこゝろのあさきなりけり（るべしイ）」。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "（今ひとつの手紙を読む）妻よ、お前の苦しみは察するにあまりある。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に至るもカルパシヤの、峯に駒をば打ち立てて、不思議の騎士は底もなき、奈落の淵に亡霊が、あまた一つの屍を、噛みくだく有様と、今ひとつなる屍が、地中にありて次ぎ次ぎと、成長しつつ堪へ難き、苦痛に我れと我が骨を、噛みつつ大地をどよめかす、その有様を見まもるなり。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "意欲そのものの善悪、いかに意欲するかでなく何を意欲するかの実質内容につき道徳的判断を下したいのはまたわれわれの今ひとつのやみ難き要請である。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた快楽を追うことの今ひとつの害毒は浪費である。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ひとつは相手に死なれた場合だ。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ひとつ格別のものに、北陸ではたらばがにの洗い、東京ではしゃこの洗いがある。",
              "citation": {
                "source": "洗いづくりの美味さ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その付近に今ひとつ、向日町という上産地がある。",
              "citation": {
                "source": "筍の美味さは第一席",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今ひとつの大事な秘訣は、料理する者の心得として、腹を空らしておいてつくることです。",
              "citation": {
                "source": "料理する心",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれだけでは、ただ交際を嫌われるというだけで、そうひどく賤しまれるはずはない訳でありますが、いわゆるエタにとって今ひとつの大きな災難は、彼らの生活に不足がなかったということです。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "音も動きも無い世界　ところでこの微速度撮影のほかに、今ひとつ菅谷君が、その威力を発揮すべき場面がある。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇興行だけの収入で人件費その他全部の費用をまかなって自立している劇団は、今ひとつもないといっても言いすぎではない。",
              "citation": {
                "source": "抵抗のよりどころ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから今ひとつ申し上げたいことがございます。",
              "citation": {
                "source": "玉章",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、題名にするには今ひとつです。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念ながらボストンの地理に不案内なので、語り手とピックマンがどう歩いたのか今ひとつ判りませんでした。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に出た部分を考え合わせると多分ロフトの天井が尖った形をしているという意味でしょうが、「水平のロフト」との位置関係が今ひとつわかりません。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔の構造（特に壁面内部の）がはっきりしないため、この the open floor が何を指すか今ひとつはっきりしません。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "fairy bird は「妖精の鳥」だと今ひとつしっくりこないので、「美しい鳥」としてあります。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "」まもなく彼女が良い方の卵を持ってきたので私は卵二つの朝食を再開したが、食欲は今ひとつになってしまった。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今ひとつ縁談があるのだが……」　そういうことで暫く保留になった。",
              "citation": {
                "source": "日本婦道記",
                "author": "墨丸",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ひとつのほうは揚げ毬といって、空に向かって、二つまたは三つの手毬を投げあげて、手に受けてはまた揚げるという動作をくり返すあそびで、このほうは毬の高低によって、歌の節を長くも短かくもするのがまたおもしろく、これならば弾まぬ手毬でも遊ぶことができた。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは灰繩千束を献上せよ、今ひとつは「打たぬ太鼓の鳴る太鼓」を持ってこい。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを以前のままになお持ちつづけてこられたのは、一つは改革のそうたやすくないためと、今ひとつは我邦に発達した、ユイという団結のおかげであった。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまひとつ、これも妖怪の作った歌であるが、事情は、つまびらかでない。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大魔神』は、ミニチュアがいまひとつだが、まあまあのできだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この最後の疑問を突込む前に、僕は、いまひとつ、新しい発見を紹介しよう」と、それから喬介は明かに興奮を浮べた語調で、「この鉄蓋の上を見給え。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはいまひとつの想像がある。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、御覧に入れましたところで、お笑ひを蒙りますのは必定で……」「達つて所望いたす、すぐに持参いたすやうに」忠興は前にある小壺の列に、ちらと眼をくれながら、「この上凡作をいまひとつ加へたところで、おれが所領の大きさを知る上には、少しも差支へないのぢや」　小壺は佐渡の屋敷からすぐに取り寄せられました。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまひとつの足跡は爪先のほうだけしかついておらぬけど、確かに戻っております。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
