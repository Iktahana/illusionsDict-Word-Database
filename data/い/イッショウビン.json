    "definitions": [
      {
        "index": 1,
        "gloss": "one-shō bottle (approx. 1.8 litres)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お正月に親戚が集まるから、地元の銘酒を一升瓶で二本ほど買っておこう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「祖父は毎晩、一升瓶からトクトクと徳利に酒を注ぐ時間を何よりも楽しみにしていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「宴会の片付けをしていたら、空になった一升瓶が部屋の隅にゴロゴロと転がっていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "北山さんは、一升瓶を持參してゐたので、私は、北山さんのころぶ度に、ひやりとしました。",
              "citation": {
                "source": "黒石の人たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九本の一升瓶をずらりと一列に並べて、よくよく分量を見較べ、同じ高さずつ分け合うのである。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に握り飯が大形の、切溜めという深く四角い塗った器につめてある傍に、濁酒のはいった素焼の一升瓶が添えてあった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れて、樹明君と同道して岐陽さんを訪ねる、さつそく酒になる、久芳校長も浅川国手もやつてこられて、一升瓶が何本か倒れた、下物はお手のもので凝つたものばかり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君が、お酒の「五ん合」くらいはいっている一升瓶を持って来た。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、秋田に於いて、常連が二十人ちかく、秋田のおかみは、来る客、来る客の目の前に、秋田産の美酒一升瓶一本ずつ、ぴたりぴたりと据えてくれた。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が一升瓶一本ずつを擁して、それぞれ手酌で、大きいコップでぐいぐいと飲むのである。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手に一升瓶、すでに半分飲んで、残りの半分を持参という形。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを祝する意味に於いて、だ、（一升瓶とさかなを両手にぶらさげ部屋にはいり、部屋の上手の襖をあけ）おうい、おうい。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（野中）（にやにや笑いながら一升瓶を持ったまま奥田の机の傍に坐り）どうも、ねえ、漁師まちの先生をしていながら、さかなが食えねえとは、あまりにみじめすぎるよ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人、小さい食卓をはさんであぐらを掻き、野中は、二つの茶呑茶碗に一升瓶の酒をつぐ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と言いながら一升瓶を目の高さまで持ち上げ、電燈の光にすかして見て）無色透明なるサントリイウイスキイ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一升瓶を持ち上げる）（奥田）（それを制して）いや、僕のはまだここに一ぱいあります。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとといの晩と、きのうと、二日つづけて酒を呑んで、けさは仕事しなければならぬので早く起きて、台所へ顔を洗いに行き、ふと見ると、一升瓶が四本からになっている。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色く薄濁りした液体が一ぱいつまって在る一升瓶は、どうにも不潔な、卑猥な感じさえして、恥ずかしく、眼ざわりでならぬのである。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所の隅に、その一升瓶があるばっかりに、この狭い家全体が、どろりと濁って、甘酸っぱい、へんな匂いさえ感じられ、なんだか、うしろ暗い思いなのである。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けふ配給がありましてな、近所に、飲まないところもかなりありますから、そんなのを集めて、」と言つて、集めるやうな手つきをして、それから一升瓶をたくさんかかへるやうに腕をひろげて、「さつき内の者が、こんなに一ぱい持つてまゐりました。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "年老った婢は一升瓶子と湯呑茶碗を持って往った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "底にぽっちり葡萄酒の入っている醤油の一升瓶がじかに傍の畳へ置いてある。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い玄関の三畳で、後向きに、一升瓶の中へ米を入れて、鉄の棒ですこんすこんと米つきをしてゐる日本髪の娘がゐた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は、ひとり多分、社長から貰ったに違いない一升瓶を抱え、本郷から自動車をとばし銀座に出た。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は持ってきた一升瓶を飲み、女給たちは店のビールを飲む。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れたわけではないが、牛乳の一升瓶をぶらさげてる、その瓶容れの藁編みの紐が、掌にくい入って痛かった。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心のため、橋の欄干から少し離して、地面に立てて置いといた牛乳の一升瓶が、馬に蹴られたのであろう、二つに割れて、地面に白く牛乳が流れている。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は馬から降りて、満足そうに牛乳の一升瓶を見せたが、わたしには渡さなかった。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升瓶を下げて歩くことなんか、大したことではない。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の午後二時頃、小野田さんはやって来た、馬には乗らず、黒い背広服に派手な博多織のネクタイをしめ、牛乳の一升瓶を手にさげていた。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれと彼女は、電熱器のそばに一升瓶をひきつけ、飲みながら夜明けを待った。",
              "citation": {
                "source": "朝やけ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "青々軒は一升瓶を持ちだしてきて茶碗酒をすゝめ、長火鉢でお好み焼を焼きながら義太夫を唸つてゐたが、太平は見合せた目と目のことを思ひつゞけて落附かなかつた。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は立ち上って、一升瓶を提げてきて、コップに注いで飲んだ。",
              "citation": {
                "source": "夢幻泡影",
                "author": "外村繁",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
