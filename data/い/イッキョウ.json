          ],
          "literary": [
            {
              "text": "いやな仲間もまた一興じゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそういう見方から西鶴の探偵趣味とその方法を観察するのも一興であろう。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス語の冬 hiver はラテンの hibernum であろうがこれを「冷える」と比べてみるのも一興である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、さらさらひらひら、と続けるのも一興だ。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝かれにさっそく、この事を告げて、彼をして狼狽させてやるのも一興である。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者が一興業が済んで舞台から身を引いた時は、もうハムレットでもなく、大石良雄でもなくただの人間です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理｜方が摺鉢俎板を引くりかえしたとは違うでの、催ものの楽屋はまた一興じゃよ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は米國軍艦、我は帝國軍艦、水雷砲火ならぬ陸上の運動をもつて互に挑み鬪ふも亦た一興であらうと思ふ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　大通りは一筋だが、道に迷うのも一興で、そこともなく、裏小路へ紛れ込んで、低い土塀から瓜、茄子の畠の覗かれる、荒れ寂れた邸町を一人で通って、まるっきり人に行合わず。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四有三居訪問、番人に誰何されたり、押売と間違へられたりした、それも旅の一興、いや、私にはふさはしい出来事だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな仲間もまた一興ぢやないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう夜もまた一興だ。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大みそかをよそにして雪見酒も一興かと存じ、ごぶさたのお詫びも兼ね、今夕お招き致しましたところ、さっそくおいで下さって、うれしく思います。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒れたものでありますが、いや、茶釜から尻尾でも出ましょうなら、また一興でござる。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れの日の事は好くは知らないが、かうした静かな夕暮時に競馬の練習を見物してゐるのも、また一興といふほどの心地なのだつた。",
              "citation": {
                "source": "娘とドリアン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、それからワトソン君、――もし君が、破れた窓から入る隙間風に我慢が出来るなら、せめて三十分も僕の書斎に上って、一服やってくれたら、また何か一興を供することが出来ると思うんだがね」　昔馴染の室は、そのミクロフト・ホームズの管理と、ハドソン夫人の行き届いた注意で、全く昔ながらの儘であった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "可懐いその姿を見るのも、またこの旅の一興に算えたのであったから――それを思出して窺ったが……今日は見えぬ。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それも旅の一興。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　大通りは一筋だが、道に迷ふのも一興で、其処ともなく、裏小路へ紛れ込んで、低い土塀から瓜、茄子の畠の覗かれる、荒れ寂れた邸町を一人で通つて、まるつ切人に行合はず。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　若しさうならば、そしてそれが解つたならば、また一興と私は思つたので或時、Ｒの体操を私の背後で眺めてゐる満里子に質問すると「いゝえ。",
              "citation": {
                "source": "満里子のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋に戻つて眠りにつく前に、この白々と酔つた泰平なるあたまで、水族館の奥でも眺めたら、また一興といふものであらう――などと陽気の加減か、わたしはうつらうつらと青葉の径をよろこびながら、車を駆つて油壺の浜辺までのしたわけであつた。",
              "citation": {
                "source": "書斎を棄てゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分なら大丈夫じや」「今晩雨になるのも又一興だよ、ねえ、甘糟」　黒餅に立沢瀉の黒紬の羽織着たるがかく言ひて示すところあるが如き微笑を洩せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘糟の答ふるに先ちて、背広の風早は若きに似合はぬ皺嗄声を振搾りて、「甘糟は一興で、君は望むところなのだらう」「馬鹿言へ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖畔の路はわづか十五六町なれど、宿の舟あれば、乘りて湖心に出でて、眺望を縱まゝにするも亦一興と、舟を頼みおきしに、朝起き出づれば、『老人は舟を漕ぐことを知らず』とて斷り來たる。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄一切黙って引込んでいたのが、その雨漏に濡れながら急に唄い出した声の意外にも澄んで清らかであったも一興であった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それも一興として、あるいは多少の参考として、読んでくれる人も無いではあるまい。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸瓜の実が尻ぬけをしたあとを、何心なく覗き込み、細かい繊維の網から出来上った長い長い空洞が、おりからの秋天の如く無一物なのに驚いて、声を放って哄笑するのも、時にとっての一興である。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　襟に西田屋と染めぬいた隣りの客引きを鷹揚にさし招くと、これもまた一興というように打ち笑みながら呼びかけました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "充分に用意いたせよ」　事起らばそれまた一興、不審の雲深ければさらに一興、いっそ退屈払いになってよかろうぞと言わぬばかりに、のっしのっしと通って行くと、不敵な鷹揚さを示して命じました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
