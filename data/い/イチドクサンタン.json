    "definitions": [
      {
        "index": 1,
        "gloss": "a reading leaves one with ceaseless sighs of admiration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの作家の初期の短編集は、何度読んでも一読三嘆の感動を覚える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新発見された古文書に記された思想は、現代人にとっても一読三嘆に値するものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の書いた最終報告書は、その分析の鋭さと表現の巧みさで、まさに一読三嘆ものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その歌集を初めて手にした時、ページのどこを開いても一読三嘆の詩句に出会った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "師の遺した書簡は、簡潔ながらも深い教えに満ちており、弟子たちは皆一読三嘆した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "論考全体に漲る著者の情熱と洞察には、ただ一読三嘆するばかりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "当時これ等の名篇は創作探偵小説界に於ける空谷の跫音として、何人も一読三嘆したものだが、Ｏ君の伝える所によると、作者は相当の年配いやむしろ老人だということだった。",
              "citation": {
                "source": "キビキビした青年紳士",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
