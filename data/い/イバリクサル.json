        "examples": {
          "standard": [
            {
              "text": "彼は少し地位が上がった途端、昔の仲間に対して威張りくさるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「あいつ、また部長の前だけでいい顔して威張りくさって」「まったくだ、見てられないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "実力もないのに威張りくさる人ほど、見ていて滑稽なものはない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "べつに、君が英語の試験を受けるわけぢやあるめえ」「わしや、威張りくさる人間は、きらひぢやけん………」　彼は、こゝで、まさに本音を吐いた。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり、巡査が威張りくさるもんじゃけ、つい、いつもの癖が出てしもうたが、……どうも、後口が悪いなあ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいこの神保先生は、幕府の役人がいばりくさるのを、ふだんから心憎く思っている。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
