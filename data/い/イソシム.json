[
  {
    "uuid": "e46424eb-56de-5132-ac2b-85b21d945ec4",
    "entry": "勤しむ",
    "reading": {
      "primary": "いそしむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to work hard at",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は来たるべき展覧会に向けて、創作活動に勤しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その学者は生涯、古代文明の研究に勤しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "祖父は退職後、晴耕雨読の日々を送り、畑仕事に勤しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女はコンクールでの優勝を目指し、来る日も来る日もヴァイオリンの練習に勤しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "職人たちは親方のもとで、伝統工芸の技術を後世に伝えようと日夜修行に勤しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「彼は家族を養うため、休日も返上して仕事に勤しんでいるそうだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "冬に備え、蟻たちはせっせと巣に食料を運び込む作業に勤しむ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "こう互いに慰め合いながら、各自の奉仕に勤しむのであった――教団を出ようと決心した庄三郎の心持ちが、この信徒達の態度を見ると、また変らざるを得なかった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の九十日間は雲水達はどこかの寺の道場に宿りを求め静に座禅工夫にいそしむのであった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の造るのは靴の甲の方で、女の手に及ばない底づけは父の分担であり、この奇妙な父子の職人は、励まし合って仕事にいそしむのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで菩薩となり仏となったものは化他の業にいそしむことになるのが自然の法で、それが即ち菩薩なり仏なりなのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひまもなくいそしむ人の。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その目は、ときおり、芸道にいそしむ者のみが持つ、燃えるような、きらめくような、異様な光とともに、吸い寄せられでもするかのごとく、青焼き人形にふりそそがれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れやかに鳴く鳥は日くれを思ひ、蜥蜴は美くしくふりかへり、時計の針は薄らあかりをいそしむ…………捉へがたき過ぎし日の歡樂よ、哀愁よ、すべてみな、かはたれにうつしゆく薄青きシネマのまたたき、いそがしき不可思議のそのフィルム。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "顳※に即効紙をはって、夜更けまで賃仕事にいそしむ母親の繰り言を聞くと、いかなる犠牲も堪えなければならぬといつも思う。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオの国民歌謡は、男は国の守りとして外へ出てゆき、家を守り家業にいそしむこそ女であるもののつとめであるとくりかえし歌っている。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は想像する――あの窓からこの広場の鳩と子供のむれを見おろしながら、覚束ない指さきで細工物にいそしむ、やっと生きているような老人たち。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳と美との雰囲気の中に学びの道にいそしむのは何という幸福であったろう！",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は自分の運命を受け取り、ゆるさるる幸福を享け楽しんで死を待ちつつ仕事にいそしむことができるようになりました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言つても、背に笞してひたすら学業にいそしむことを怠りはしなかつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、この遠くへだたったハンガリヤの地で、独学で難事な日本語の勉強にいそしむためには、彼のように、こうして来る日本の旅客を捉え、案内役を引き受ける以外に方法はないであろうと察せられる。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の少女いそしむは古き世からの習ひなり。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神々の御ちかひによつて、まそけく日々にいそしむおほみたからの意と解する方が適切であらう。",
              "citation": {
                "source": "用言の発展",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、案内されて廻縁からはいって来た客人――年頃は主じとあまり違わぬ三十何歳、細い髷をすずしく結って、伊達好みの茶壁の着付、袴はわざと穿かずに、無紋紺地の短か羽織を軽く羽織って、もとより親しい仲と見え、閾ぎわに立ったまま、絵筆にいそしむ主じに話しかけるのでした。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄内川には鮎が群れ、郊外の早苗田では乙女達が、※秧の業にいそしむようになった。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が其共同生活の為に一糸乱れず自治的労働にいそしむ様は、実に涙ぐましい程立派なものである。",
              "citation": {
                "source": "吾等の使命",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民としての青年の道は、それぞれ職あるものは職に励み、学窓にあるものは学業にいそしむことにありとはいへ、たゞそれだけのことなら、今更めて云ふ必要はないのである。",
              "citation": {
                "source": "青年へ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この含蓄ある、鋭い、しかも極めて綜合性に富んだ言葉の内容は、いふまでもなく「苦しみ」と「好み」との渾一融合であつて「道にいそしむことによつて覚悟をつくる」日本人独得の直観力を示したものである。",
              "citation": {
                "source": "「矜り」と「嗜み」",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たしなむ」といふ動詞から来たものに違ひありませんが、「たしなむ」といふ言葉の意味は、元来「好く」「好む」といふ意味のほかに、「苦しむ、なやむ」といふ意味があり、それが重つて、「修業する」「わざを学ぶ」「道にいそしむ」「磨き飾る」といふやうな意味に用ひられて来てゐます。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月初旬雪が降る候になると、そろそろ脂肪を持ちはじめ、一月から二月には春機が発動して、羽根の色にも筋肉の容にも生気が漲って三月、四月には雌雄相交わり、五月には産卵して育児にいそしむ。",
              "citation": {
                "source": "季節の味",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで花々しさを誇った青銀色の鱗の底から、そろそろ淡い紅の艶が、刷毛で刷いたように浮かび出し、もう肥育が止まり、これからは性の使命にいそしむばかりであるという姿になる。",
              "citation": {
                "source": "香魚と水質",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も内心いつそひと思ひに文子さんと結婚しやうかと思ふ心はあつたのですが、それはつまり、ひと思ひに清水の舞台から飛び降りる気持といふあの自殺的な自棄気味だけのことなのですね」「仕事にいそしむ者は高められた心でなければなるまいが、然しお前の毎日毎時間が寺院の中に住むやうな心ではゐられまい。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉が不便なところから足を封じられて、彼は自然書斎に閉じこもり、次から次へと創作にいそしむ機会をもったと言われております。",
              "citation": {
                "source": "イプセン百年祭講演",
                "author": "久保栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段高い学府に籍を置いたという厳粛な感じに支配せられて燈下に膝を折って下読みにいそしむ事も多く、同時にまた松山の狭い天地を出て初めて大きな都に出たという満足の下にその千年前の旧都を飽きもせずに彷徨き廻る日も多かった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
