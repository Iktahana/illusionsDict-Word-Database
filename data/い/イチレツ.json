    "definitions": [
      {
        "index": 1,
        "gloss": "(a) row",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちは先生の指示で、きれいに一列に並んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "商店街の福引には、朝から一列に人が並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この公園の桜の木は、入り口からずっと一列に植えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "疾走れるものを見るなかれ、いまともがらは一列に、手に手に銀の鈴ふりて、雪ふる空に鳥を薫じ、涙ぐましき夕餐とはなる。",
              "citation": {
                "source": "巡禮紀行",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔卑屈の友らをいきどほろしく〕宮沢賢治卑屈の友らをいきどほろしく粘土地二片をはしりてよぎり崖にて青草黄金なるを知りのぼりてかれ草黄なるをふめば白雪きららに落ち来るものか一列赤赤ならべるひのきふたゝび卑屈の友らをおもひたかぶるおもひは雲にもまじへかの粘土地なるかの官庁に灰鋳鉄のいかりを投げよ",
              "citation": {
                "source": "〔卑屈の友らをいきどほろしく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓導宮沢賢治早くもひとり雪をけりはるかの吹雪をはせ行くは木鼠捕りの悦治なり三人ひとしくはせたちて多吉ぞわらひ軋るとき寅は溜りに倒れゐし赤き毛布にくるまりて風くるごとに足小刻むは十にたらざる児らなれや吹雪きたればあとなる児急ぎて前にすがりつゝ一列遠くうすれ行く",
              "citation": {
                "source": "訓導",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩の翻訳の不可能は、この一列によつても解るのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同座敷の片側へ一列にならんで順々拝が始まる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから新入生一人一人に総長が握手をするというので、一列に並んで順々に繰出して行った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下に一列のスチームヒーター。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃、寒月の冴えた夜などに友達の家から帰って来る途中で川沿いの道の真中をすかして見ると土の表面にちょうど飛石を並べたようにかすかに白っぽい色をした斑点が規則正しく一列に並んでいる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小さな列車の窓は一列小さく赤く見え、その中にはたくさんの旅人が、苹果を剥いたり、わらったり、いろいろな風にしてゐると考へますと、ジョバンニは、もう何とも云へずかなしくなって、また眼をそらに挙げました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかへ行く街道らしく小さな電燈の一列についた通りがありました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳列品の中に獅子舞の獅子の面が二点あったが、その面に附いている水色に白く水玉を染出した布片に多分｜鬣を表わすためであろう、麻糸の束が一列に縫いつけてある。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは無言でぼんやり時間を過ごすうちに、一列の雁が二人を促すかの様に空近く鳴いて通る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一列に並べた食卓の真中に二条のレールを据え付け、この上を御馳走を満載した可愛らしい電車が徐々と進行する。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見置時計のような形をしているが、その前面の円盤には羅針盤と同じように方角を誌し、その周囲には小さい豆電灯が一列に輪をなして並んでいる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ベンチの第一列に腰を掛けてゐたのが、此時立ち上がつて、さも感動したらしく鼻をかんでゐる男がある。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚の上には小さき、柄の長き和蘭陀パイプを斜に一列に置きあり。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "山下界隈の怪しい酒場で酔泥れた一列の黒奴の火夫達が、最新流行歌をうたって和服の蠱惑の街に傾いた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けると、天界ホテルの海辺に面したダンス・ホールで、マリを先頭にして十三人の娼婦が一列に並んで健康のための体操をはじめたが、何故かお六ひとりその列に見えなかった。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから一列に輸入品の帽子が並べられて、その後で職業女の赤い唇がひらいたりしぼんだりした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重硝子の窓を通して、空の橇が馭者だけを乗せて、丘の道を一列につゞいて下るのが見えた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は畑、左は堤の上を一列に老松並ぶ真直の道をなかば来たりし時、行先をゆくものあり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　劇場などで座席を選ぶ場合に、一列の椅子のどちらか一方の端の席がいいという人がある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一列に散らばっていた兵士達は遠くから小屋をめがけて集って来た。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは一列になって出て行った。",
              "citation": {
                "source": "チチハルまで",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩頸列西は箱ヶと毒ヶ森、　　　　　　　椀コ、南昌、東根の、古き岩頸の一列に、　　　　　　　氷霧あえかのまひるかな。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波がちょうど減いたとこでしたから磨かれたきれいな石は一列にならんでいました。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小さな列車の窓は一列小さく赤く見え、その中にはたくさんの旅人が、苹果を剥いたり、わらったり、いろいろな風にしていると考えますと、ジョバンニは、もう何とも云えずかなしくなって、また眼をそらに挙げました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき向ふから一列の馬が鈴をチリンチリンと鳴らしてやって参りました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはいかに赤きずぼんに毛皮など、　　春木ながしの人のいちれつ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドッテテドッテテ、ドッテテド　二本うで木の工兵隊　六本うで木の竜騎兵　ドッテテドッテテ、ドッテテド　いちれつ一万五千人　はりがねかたくむすびたり」　どういうわけか、二本のはしらがうで木を組んで、びっこを引いていっしょにやってきました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
