    "definitions": [
      {
        "index": 1,
        "gloss": "one pair (set) of clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は面接のために、一番良いスーツを一張用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "娘の成人祝いに、美しい振袖を一張あつらえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "舞台俳優はその役のために、時代物の衣装を一張新調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それで学校に式のある時など、他の教師は皆礼服で列席するのに、ヘルンは一張羅の背広で押し通していた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その性根で用意した祭の踊に行く時の一張羅を二人はひっぱって来た。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の中ではランプが今｜一張ついた、これが八幡神社の入口である。",
              "citation": {
                "source": "八幡の森",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛のあんなに細い弱い糸の網で大きな蝉が捕られることから考えると、蚊帳一張りほどもない網で一台の飛行機が捕えられそうにも思われるが、実際はどうだか、ちょっと試験してみたいような気がするのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の秋のお祭りに、太鼓を舁いだり、幟をさしたり、一張羅の着物を着てマチへ出る村の人々は、何等か興味をそゝって話の種になったものだが、東京の街で見るものは彼等にとって全く縁遠いものだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどももちろん平太には一張羅の着てゐる麻服があるばかり他に入れるやうなものは何もありませんでしたから親方に頼んで板の上に引いた要らない絵図を三十枚ばかり貰ってぎっしりそれに詰めました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、慌ててら、慌ててら、それに一張羅だ、堪ったもんじゃあねえ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　錦の帯を解いた様な、媚めかしい草の上、雨のあとの薄霞、山の裾に靉靆く中に一張の紫大きさ月輪の如く、はた菫の花束に似たるあり。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、こゝに、低い草畝の内側に、露とともに次第に消え行く、提灯の中に、ほの白く幽に見えて、一張の天幕があつた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面藤の花に、蝶々まで同じ絵を彩った一張の紙幕を、船板塀の木戸口に渡して掛けた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "星も隠れた、真暗、」　と仰向けに、空を視る、と仕掛けがあったか、頭の上のその板塀｜越、幕の内か潜らして、両方を竹で張った、真黒な布の一張、筵の上へ、ふわりと投げて颯と拡げた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびはえらい御不幸なと挨拶をした婆さんに抱いていた豹一を預けると、お君は一張羅の小浜縮緬の羽織も脱がずバタ／＼とはたきをかけ始めた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宿――豊後屋といふ――はやつぱりよかつた、同宿者のおしやべりには閉口したけれど、一室一燈一張のよろしさだつた、便所のきたないのはぜひもない。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時、田部の藤本屋といふ安宿に泊つた、よい意味で、また、わるい意味で、安宿の代表的なものであつた、この宿でも一室一燈一張の主人であることができた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "一張羅を無くしては仕様がないじゃあないか、エ、後ですぐ困るじゃ無いか。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かは知らず、人の氣分が張つてのみも居らず、弛んでのみも居らず、一張一弛して、そして張つた後は弛み、弛みたる後は張りて、循環すること譬へば猶晝夜の如く、朝夕の如く、相互に終始して行くことは誰しも知つて居ることである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一張一弛して、そして次第に或は生長し或は老衰するのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋燭の俄に太くもなり細くもなるでは無く、護謨球の中の空氣の俄に或は増し或は減ずるのでは無いが、一張一弛は慥に其處に存在し、一張一弛其處に存在すれば、其の結果は明らかに差異を生ずる。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に朝顏の花の如く一張一弛して即ち休んで了ふもので無いところの花、たとへば木芙蓉の花の如きに就て諦觀する時は、朝の何時より晝の何時までに至るまでは其の氣張り、それより後に至つては其の氣弛みて、また次の日に至つて如何に且つ張り且つ弛むかといふことを仔細に知り得る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に聴衆が増し、彼等の表情が、自分の物語の一弛一張につれて、あるいは安堵の・あるいは恐怖の・偽ならぬ色を浮べるのを見るにつけ、この面白さは抑えきれぬものとなった。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に聽衆が増し、彼等の表情が、自分の物語の一弛一張につれて、或ひは安堵の・或ひは恐怖の・僞ならぬ色を浮べるのを見るにつけ、此の面白さは抑へ切れぬものとなつた。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔭に隠れて見えねえけれど、そこに一張天幕があります。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……組合の気脉が通って、待合の女房も、抱主が一張羅を着飾らせた、損を知って、そんなに手荒にするのであろう、ああ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葭簀張ながら二坪ばかり囲を取った茶店が一張。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「春着に辛うじて算段した、苦生の一張羅さ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのから元気を見るにつけても、年下の息子を悩ませ、且つその友達を苦らせる、（一張羅だと聞けばかなしも。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このたびはえらい御不幸な……」　と挨拶した婆さんに抱いていた子供を預けると、お君は一張羅の小浜縮緬の羽織も脱がず、ぱたぱたとそこらじゅうはたきをかけはじめた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その後月に二回はかならずやってくるお君に、村田は平気でおれず、ある夜、新聞紙に包んだセルの反物を持って路次へやってきて、「思いきって一張羅イをはりこみましてん。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰翳は彼が肋に明暗す一張一弛、カンテラの青み吸ひつつ、縞蛇の喘ぐが如し。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、どんぶり持って豆腐いっちょう買いに行くのが、一ばんつらかった。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
