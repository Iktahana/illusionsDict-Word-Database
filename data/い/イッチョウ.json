        "examples": {
          "standard": [
            {
              "text": "ここから一丁ほど歩いた先に、古い道祖神が立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "昔の地図を見ると、このあたりは道幅が一丁もなかったようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「その角を曲がって一丁も行かないうちに、お目当ての茶屋が見えるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
