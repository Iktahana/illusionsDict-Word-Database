        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冷酷な犯人は、何の躊躇もなく人々の命を絶った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ハンターは、食料を得るために野生の鹿の命を絶った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その独裁者は、反対する者たちの命を次々と絶っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
