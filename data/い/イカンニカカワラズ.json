[
  {
    "uuid": "7ba0ea1d-8485-5c19-86d0-598b0f3e93e4",
    "entry": "如何に関わらず",
    "reading": {
      "primary": "いかんにかかわらず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
