[
  {
    "uuid": "3b95d9ce-5b17-5897-b3bd-f5f64dd4686f",
    "entry": "虎杖",
    "reading": {
      "primary": "いたどり",
      "alternatives": [
        "イタドリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
