          ],
          "literary": [
            {
              "text": "長い、空しい幾夜かの野營の後の、寢臺。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "また東京らしくない、しめり氣を帶びた可厭な蒸暑さで、息苦しくして、寢られぬ晩が幾夜も續いた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもよく幾夜も僕の夢遊病症につき合つて下さいましたね。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の鼻眼鏡をこつそりいぢくつて、ぽきつとその硝子を割つてしまつたときには、幾夜もつづけて寢苦しい思ひをした。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾夜も寝苦しい思いをした。",
              "citation": {
                "source": "川端康成へ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "借さぬものを無理借りする訳には行かぬので、氏郷の軍は奥州の厳冬の時に当って風雪の露営を幾夜も敢てした困難は察するに余りある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして、背戸に泣く虫の音もいたく衰へた秋の夜長、親子三人枕を並べはしたが、思ひ／＼の悲愁に満ちた不眠の幾夜、分けても釜貞にとつては辛い苦しい悪夢の夜が続くのであつた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉・茎を白く抜くのであるから、幾夜かを費した。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてあな幾夜か経にし。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "花過ぎて、啼くや、幾夜さ、ほととぎす、　　薄墨の鳥。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜の風秋はほのかに寝ざめして、あはれと思ふ幾夜さぞ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆ど錬金道士のやうな苦しみが、幾日幾夜続いたか、而も私の得たものは何であるか。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶ち絶ちて幾日をか経し、饑ゑ饑ゑて幾夜をか経し、この我や生きて貧しく、生きんすべせんすべだにもなきものを、米の玉、しら玉あはれ。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "直に城中こぞつて、徹宵額をあつめて議を廻らすのであつたが、幾夜々々続けても、天狗の羽ばたきにのみ想ひを馳せてゐた夢想家達には、決して具体の案が浮ばなかつた。",
              "citation": {
                "source": "東中野にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が幾夜も踊つて不用に歸した時には、それが彼等の歩いた路の傍に埃に塗れながら到る處に抛棄せられて散亂して居るのを見るのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮殿の中は冬のやうに静かに、憂ひのみのうちに幾夜／＼を更して居るのです。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "静子と過すべき晩は、これからの長い結婚生活に、幾夜だってある。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽き／＼するほど幾夜だってある。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが余り幾夜も続くので、私も、はア、終には気の毒になつて、重右だツて、人間だア。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は晴れて水のような月夜が幾夜か続いた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "静子と過すべき晩は、これからの長い結婚生活に、幾夜だつてある。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽き／＼するほど幾夜だつてある。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十幾夜の月が出かかつたのであらう。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊びに倦みつかれたような浅井には、幾夜ぶりかで寝る、広々した自分の寝室の臥床に手足を伸ばすのが心持よかった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "百八　秘密な会合をお島に見出されたその女は、その時から頭脳に変調を来して、幾夜かのあいだお島たちの店頭へ立って、呶鳴ったり泣いたりした。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に幾夜泣きあかしたか知れない。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "この結婚は当時新聞が、百合子はアメリカにごろついていた洗濯屋と夫婦になったなどと書いたりしたことがあり、両親は勿論賛成せず、特に母はそのために眠られない幾夜かを過したのであった。",
              "citation": {
                "source": "母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしおいぼれがいやだなんて云ったらぶんなぐっても連れていくよ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、松吉についていくより、しかたがありませんでした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たらいは、動いていくようには思えませんでした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
