    },
    "definitions": [
      {
        "index": 1,
        "gloss": "perusal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "現代のビジネスパーソンなら、この古典的名著はぜひ一読しておきたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "提出された企画書に一読したが、実現可能性の面でいくつか課題が残る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "契約上のトラブルを避けるため、署名前に重要事項説明書を必ず一読してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その手紙を一読した彼女は、何も言わずに静かに机の上にそれを置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議の冒頭、司会者は参加者全員に配布資料の一読を求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "難解な論文だが、冒頭の要旨を一読するだけで筆者の論旨は概ね理解できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の遺稿を一読するだに、当時の創作活動における苦悩が痛いほど伝わってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし何よりも先ず事実の方から確かめてかかる事が肝心であるから、万一読者の中でそういう現象を目撃した方があったらその観察についての示教を願いたいと思う次第である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの天象について特に興味を感ぜられる読者には岡田博士著『雨』について詳細の説明や興味ある実例を一読される事をお勧めしたい。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しもこねかえしがないから一読純粋な清浄な感情が味われる。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の両様とも悉しく其の姿を記さゞれども、一読の際、われらが目には、東遊記に写したると同じ状に見えて最と床し。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ある物理学者の集会の席上で私はこの書の内容の梗概を紹介して、多くの若い学者たちに一読を勧めたこともあった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方において私は若い科学の学生にこの書の一読をすすめてもよいと思うものである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上ただ手に触れるに任せて一読しただけのものを並べたに過ぎない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君がもしこの書を一読すれば、すくなくとも翌日からして、詩の批判を正当にすることができるであろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの手紙を御一読なさったら、黙って破り棄てて下さい。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御一読後は、ただちに破棄して下さい。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一読者の立場として、たとえばチエホフの読者として、彼の書簡集から何ひとつ発見しなかった。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに受賞者の作品を一読するに及び、告白すれば、私、ひそかに安堵した。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の書いた文章が、全く読まれないか、あるいはざっと一読の光栄に浴して、そうして、「なんだいこれは」と顔をしかめられるのをハッキリ自覚しながら、それでも一字一字まじめに考え考えして文章を書かなければならぬというのは、つらい話である。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一読して、名文だと思った。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その報告書は内務省に現存して、浅野｜正恭翁も一読したと云って、筆者は浅野翁からそれを聞かされた。",
              "citation": {
                "source": "レンズに現われた女の姿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品を読んだ事は無かったが、詩人の加納君が、或る会合の席上でかなりの情熱を以て君の作品をほめて、自分にも一読をすすめた事がありました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿は、そのままするすると編輯者の机上に送り込まれ、それを素早く一読した編輯者を、だいいちばんに失望させ、とにかく印刷所へ送られる。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『道化の華』早速一読｜甚だおもしろく存じ候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下、必ず一読せられよ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此処で一読するが宜しからん」と、魔王は云った。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつらで洒落なんぞ、第一読者に対して無礼だよ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファウストの場合では佐佐木信綱さんが好意を以て一読して下さることになった。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "元どおりに直して、さて一読してみて、彼はやっと落ちつく。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の御褒美の中に「平日の心掛｜宜敷」「暮し向万事質素」「門弟引立方深切」云々という事実は筆者等が翁の晩年に於ても親しく実見したところで、後に掲ぐる翁の逸話を一読されたならば思い半に過ぐるであろう。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人も一読すべきだと思ふ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワトソン君、これは君も一読しといていいものだろうと思うんだよ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「念を押すが、ワトソン、一読の価値ありだ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「テレグラフ紙とクロニクル紙の記事は一読を。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この両様とも悉しくその姿を記さざれども、一読の際、われらが目には、東遊記に写したると同じ状に見えていと床し。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "稿の成ると共に直ちにこれを東京に郵送して先生の校閲を願ったが、先生は一読して直ちに僕が当時の心状を看破せられた。",
              "citation": {
                "source": "おばけずきのいわれ少々と処女作",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
