[
  {
    "uuid": "1196834e-06e0-5746-a155-e58e93cf2883",
    "entry": "一読",
    "reading": {
      "primary": "いちどく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
