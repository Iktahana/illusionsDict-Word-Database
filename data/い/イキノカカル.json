          "literary": [
            {
              "text": "どじを踏むと、八丁堀の息のかかる、御朱引内で、十手は持たせねえぞ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "力尽きようとしたとき、瀕死の耳に、「あなた」　女の声が、息のかかる近さで聞えた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お早ようございます」　挨拶すると、金五郎は、友田と息のかかる近さに寄った。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
