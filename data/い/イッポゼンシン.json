    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(a) step forward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新薬の臨床試験で良好なデータが得られ、がん治療において大きな一歩前進となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ずっと無視されていた彼からようやく返信が来て、関係修復に向けて一歩前進した気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "企画書の骨組みが固まっただけでも、昨日の白紙の状態から比べれば確かな一歩前進だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "われ、事に於いて後悔せず、との菊池氏の金看板の楯の弱さにも、ふと気づいて、地上の王者へ、無言で一杯のミルクささげてやって呉れる決意ついたら、それが、また、君のからだの一歩前進なること疑う勿れ。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの作家に不明瞭なものゝ解決を『二人の裸婦』のやうな明瞭さに到達し解決しないで『無題』から一歩前進してほしい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、これはジャーナリズムの文学に対する一歩前進であり、その支配権の確立の証左である。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、この作者のみならず、恐らく一般探偵小説の一歩前進を期待してやまない。",
              "citation": {
                "source": "『心理試験』を読む",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥を知れッ」　まァまァと分団長が中に入ったが、鉄造はそれをふり払いまた一歩前進した。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度毎に一歩前進したとの感を深くした。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月号『プロレタリア文学』に鈴木清がこの問題について「一歩前進か二歩退却か」という論文を書いている。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それはいつも、何かのかたちで婦人の生活が社会的に一歩前進する事情に面したときである。",
              "citation": {
                "source": "「女らしさ」とは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見ささいなこの実力こそ私たちが大きい苦痛と犠牲を払って進んできた一歩前進の最もたしかな収穫であると思う。",
              "citation": {
                "source": "明日をつくる力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者は、芥川龍之介の敗北の究明とともに、小市民的土壌を自身の生活に否定し、「過渡期の道標」では一歩前進した。",
              "citation": {
                "source": "巖の花",
                "author": "――宮本顕治の文芸評論について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "全集の普及は、わたしたちすべての人民が、歴史における運命を一歩前進させるための足がかりとして小林多喜二の生涯と文学とを、あらゆる角度から多面的に摂取するための何よりの機会である。",
              "citation": {
                "source": "小林多喜二の今日における意義",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女にとって、失敗はさらに一歩前進するための教訓でしかない。",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人としてさえ恥を知らないジェスチュアによって東條の人気を挽回することで、その努力の一歩前進させることを期待したファシズム勢力があることこそ、わたしたちの警戒しなければならない最大の危険である。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦争は、近代資本主義の一歩前進として日本の社会生活全般を震撼させた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような多忙をきわめた理論闘争と組織更えの間に、プロレタリア文芸の理論は一歩一歩前進し、一九二八年雑誌『前衛』による蔵原惟人の論文「生活組織としての芸術と無産階級」で、はじめてプロレタリア文学の創作方法の問題がプロレタリア・リアリズムの提唱としてあらわれた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家たちは、自分たちの生きている意義として、今日、真率な情熱で、自分がかつてとり逃した覚えがあるならば、その人生的モメントをふたたび捉えなおし、抑圧されてきた人民の苦き諸経験の一つとしてしっかり社会の歴史の上につかみ、そのことで生活と文学との一歩前進した再出発を可能としなければならない。",
              "citation": {
                "source": "歌声よ、おこれ",
                "author": "――新日本文学会の由来――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わからなければモウ一つ質問する」　軍医大佐は一歩前進して自分の背後を指した。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や人間は動物から一歩前進しなければならぬ。",
              "citation": {
                "source": "覚え書",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "会合毎に、一歩一歩前進してるからね。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとでもいうがいい」頭目四馬は軽くうけ流すと、一歩前進した。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイロは大きくうなずくと、目を皿のようにして、ガスコのほうへ一歩前進した。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説が仮に一歩前進したとすれば、戯曲はすくなくとも三歩や五歩は前に出てゐるのである。",
              "citation": {
                "source": "新劇の黎明",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "コミンフォルムの日本共産党批判はその方向への一歩前進を暗示しているし、それに対して右翼も益々組織され尖鋭化する形勢にあるようだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "野坂中尉と中西伍長",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚しい特別扱いですが、それでも一歩前進して、とにかく、ヒダにカントク者らしき者をきめ、ヒダの支配者たる形式に一歩ちかづいたものと見られましょう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけ渡したら一歩前進し、全く未開の境地の開拓に当たるべきである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが三四年に『唯物論と経験批判論』の二十五周年記念に、ヨッフェやヴァヴィロフのような著名な物理学者が哲学者と共同で講演をやり、自然科学の方法論としてのレーニン哲学の意義を認め、哲学者の側でも自然科学的テーマを取り上げたことは、この方面における一歩前進を意味するものである。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き終った長篇小説は、それとして伸子の人生を一歩前進させた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、人が自分の身を清くしようと思って一歩前進して来たら、その清くしようとする気持を汲んでやればいいので、過去のことをいつまでも気にする必要はないのだ。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの心をむち打って一歩前進せしめないではおかないきびしさがある。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説でも、今どうやら一歩前進の過程にあるらしく、努力のコツとでもいうか、そういうものが会得されかかった感じです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
