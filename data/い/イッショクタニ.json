[
  {
    "uuid": "7f66d6ed-16e5-5961-8556-1faacd76f551",
    "entry": "一緒くたに",
    "reading": {
      "primary": "いっしょくたに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
