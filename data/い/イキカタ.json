[
  {
    "uuid": "503ca2bb-9747-5420-a184-4845211004f5",
    "entry": "行き方",
    "reading": {
      "primary": "いきかた",
      "alternatives": [
        "ゆきかた"
      ],
      "is_heteronym": false
    },
    "grammar": {
