[
  {
    "uuid": "b8b10e24-2f2c-5a41-ab26-2446f8d51ae3",
    "entry": "至らぬ",
    "reading": {
      "primary": "いたらぬ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
