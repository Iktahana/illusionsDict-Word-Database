        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝早くから、庭の柿の木に家雀が群がって実をついばんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電線にずらりと並んだ家雀たちが、一斉に飛び立つと空が黒くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園のベンチでパンを食べていると、足元に家雀が近寄ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、軒先に巣を作る家雀の様子を毎日飽きずに観察していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "都会の喧騒の中でも、家雀のさえずりは変わらず聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あら、可愛い！」と、窓辺に止まった家雀に母が声をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "雀の家雀のお家はどこでせう雀に聞いてもかくしてる子雀　だまして聞きませう学校のうしろの篠籔はわたしのお家と云ひました。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "一五　お茶をつくる家雀が父さんのお家へ覗きに來ました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その後、家雀の群を友達にさせてからこのウソの声がすっかり荒されてしまって、しまいにはチャア、チャアとばかり鳴くようになった。",
              "citation": {
                "source": "木彫ウソを作った時",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さ、あんたも食べぬか」　彼女に付きまとっていた家雀は、兼好の膝や机の上に移って、彼が食べこぼす麦粉を拾って啄むことで夢中になり、彼は一喫の茶のうちに、ふと、彼女の俯し目がちな面に、今日はまた凄艶なべつな美を見つけ出していた。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
