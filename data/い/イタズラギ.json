        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ハイハイを始めたばかりの息子に、伸縮性のある悪戯着を着せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "泥遊びで汚れることを見越して、丈夫な生地の悪戯着を用意しておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あら、その悪戯着、クマさんの耳がついていてとってもお似合いね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "活発に動き回る幼児にとって、上下がつながった悪戯着は着崩れの心配がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出産のお祝いとして、肌触りの良いオーガニックコットンの悪戯着を贈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「さあ、お外でたくさん遊べるように、今のうちにこの悪戯着に着替えましょう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "膝のところが擦り切れた悪戯着を見て、子供の成長の早さをしみじみと実感する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
