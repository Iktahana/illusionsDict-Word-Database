[
  {
    "uuid": "4b62c826-8d4a-50e9-a270-2b72cdd545b1",
    "entry": "石山",
    "reading": {
      "primary": "いしやま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
