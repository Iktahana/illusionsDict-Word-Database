    "definitions": [
      {
        "index": 1,
        "gloss": "back of the house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちは、家の裏庭で元気に遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「おい、泥棒だ！」と叫ぶと、男は慌てて家の裏手へ逃げていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家の裏には小さな畑があり、季節の野菜を育てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風で飛ばされた洗濯物が、いつの間にか家の裏側に落ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜中、家の裏から聞き慣れない音がして、思わず身構えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "敷地調査の結果、家の裏の地盤が一部緩んでいることが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "台風の後、家の裏の物置が壊れてしまい、修理が必要になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わが家の裏まで来て立止った。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここからは家の裏横手の露路を見通すことが出来る。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある家の裏には芭蕉の葉が垂れている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また自分たちの家の裏の丘上の別荘にいた人は爆音を聞き、そのあとで岩のくずれ落ちるような物すごい物音がしばらく持続して鳴り響くのを聞いたそうである。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐吉さんの家の裏に、時々｜糶市が立ちますが、私もいちど見に行って、つい目をそむけてしまいました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おわかりになりまして……今夜の十二時半……わたくしの家の裏門……」　という未亡人自身の声がした。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の裏戸が明いて早起きのおかみさんが掃除を始める、その箒の音がこれに和する。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、足許のさだかでない、凹凸の小逕を傳うて家の裏の方に行つて見る。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚三の笛とは、いつの頃からか、かやには余程遠い昔と思われる頃から、かやの家の裏門から続く広い耕地を越えた、南の方の村落から、毎夜聞えて来る横笛の音なのである。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　破廂　泰助は昼来て要害を見知りたれば、その足にて直ぐと赤城家の裏手に行き、垣の破目を潜りて庭に入りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　矢來邊の夜は、たゞ遠くまで、榎町の牛乳屋の納屋に、トーン／＼と牛の跫音のするのが響いて、今にも――いわしこう――酒井家の裏門あたりで――眞夜中には――鰯こう――と三聲呼んで、形も影も見えないと云ふ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、家の裏の竹藪に蚊帳を釣つて難を避けたのださうである――）　――前のを續ける。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの家の裏庭から北に見渡される戸山が原には、春らしい青い色はちっとも見えなかった。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び友達のない私は、家の裏の木に登って、遠くの雲の中に聳え重なっている街を見ていた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木職人の風をした私は高林家の裏庭にジッと跼んで時刻が来るのを待った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお母様は毎夜毎夜出て行つて隣の家の裏畠から桑を千切つて来ては蠶に遣りました、他所の物を盗むといふことは悪い事には違ひありませぬがお玉の可愛さが胸一パイになつて居るお母様の身に取つては善い事も悪い事も考へる隙がありませんでした。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中に蠶はずん／＼大きくなつて最早二三日ばかりすると繭をかけると云ふ一番大切な時になりました、お母様はいつもの通り金持ちの家の裏の畠に桑を盗みに行きますと其の夜は美しい月の夜で今まで毎晩葉を千切られた桑の樹が皆枝ばかりになつて白い光りの下にズラリと並んで居りました。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、それから後、殆んど毎日のように電話をかけて来る彼女の命令のまにまに、店を仕舞うとすぐに身じまいをして、隣家の裏口から抜け出して、そこいらで待ち合わせている彼女と肩を並べながら夜の街々を散歩するようになった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの一年は家の裏手にあたる国分寺跡の松林の中で修行をした。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした農家の裏山には、小高い冬枯れの墓丘があつて、彼等の家族の長い歴史が、あまたの白骨と共に眠つてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吉、杉作の家の裏手には、二抱へもある肉桂の大木がありました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の家の裏の畑で、紙鳶を一緒にあげたらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたけへ入って芋をほりちらしたり、菜種がらの、ほしてあるのへ火をつけたり、百姓家の裏手につるしてあるとんがらしをむしりとって、いったり、いろんなことをしました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　十日ほどたって、ごんが、弥助というお百姓の家の裏を通りかかりますと、そこの、いちじくの木のかげで、弥助の家内が、おはぐろをつけていました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、兵十の家の裏口から、家の中へいわしを投げこんで、穴へ向ってかけもどりました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでごんは家の裏口から、こっそり中へはいりました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家の裏庭は百草園と呼ばれて、雑草の生い繁った非常に広大な庭で、自分の幼少の頃の楽園であったが、そこへ行けば、蟋蟀の穴がいくつでも見つかり、自分は同じ穴に二匹｜棲んでいる蟋蟀を勝手に所謂「原配」ときめて、二匹一緒に糸でしばって、生きているのをそのまま薬鑵の熱湯に投げ込めばそれでよかった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の片側は立派な丈の高い塀つづき、それに沿うて小溝が廻されている、大家の裏側通りである。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、アッシェンプッテルはあっというまに、いえのうらにわにきえてしまいました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
