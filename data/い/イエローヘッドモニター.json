    "definitions": [
      {
        "index": 1,
        "gloss": "yellow-head monitor (Varanus melinus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
