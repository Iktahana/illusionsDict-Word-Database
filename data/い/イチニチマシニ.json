        "examples": {
          "standard": [
            {
              "text": "この街は、「一日増しに」活気を取り戻しているように感じるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の好奇心って、「一日増しに」広がっていくから、見ていて飽きないわ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいシステムは、「一日増しに」改善されて、使いやすくなってきたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地球温暖化の影響で、異常気象が「一日増しに」深刻になっているとニュースで見たわ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "練習の成果で、彼女の演奏は「一日増しに」魅力的になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父の病状は、「一日増しに」回復に向かっているようで、本当に安心したよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はね、与えられた仕事を「一日増しに」こなせるようになってきているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "月末に近づいたせいか、この頃は帰る人が一日増しに多くなった。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹の疑いは一日増しに根強くなって、もうこの頃ではどうしてもそうなければならないと思われるようになってきた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半二　（よんどころなく筆を措く）二月ももう末になりましたから一日増しに春めいて來るやうです。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが段々一日増しに軽くなって行った。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでの藍色がだんだんに褪せ、一日増しに伸びてゆく昼の長さとは正反対に、温度はじりじりと下ってゆく。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "錐のような髯が、両｜頬を包んで、灰色がかった皮膚から、一日増しに弾力が失われていくのだ。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、そのことを言って望遠鏡から目をはなすと、博士は、「これから、一日増しに、大きく見えて来るじゃろう。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、これから一日増しに寒くなって、日が短かくなりやす。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お糸といふのは此間行方不明になつた姉のお清と共に、日本橋の二人小町と言はれた美人ですが、自分の身に降りかゝる恐ろしい危難を豫知したものか、近頃は一日増しに憂鬱になつて行きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "振袖源太",
                "note": "青空文庫"
              }
            },
            {
              "text": "お糸というのはこの間行方不明になった姉のお清とともに、日本橋の二人小町と言われた美人ですが、自分の身に降りかかる恐ろしい危難を予知したものか、近頃は一日増しに憂鬱になって行きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "振袖源太",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、一日増しに与八というものが、伊太夫の生活に無くてならないものになりつつゆくのを、伊太夫自身も如何ともし難いらしいが、与八に於ては、特にそういった意味で、伊太夫から選ばれているともなんとも思ってはいません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣いてばかりいやがる」「だって……だって……一日増しにおまえさんが、私に冷たくなって行くんだもの」「へえ、いつおれが、おめえに熱かったことがある？",
              "citation": {
                "source": "治郎吉格子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、渭水の水が一日増しに涸れて来た。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
