          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "わぁ、見て！あの鳥、信じられない速さで飛んでいく！と子供が言った。ほんの一瞬間だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史的な瞬間、彼女はマイクの前で一瞬間、言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "感動のあまり、彼は言葉を詰まらせた。その一瞬間が、彼の感謝の気持ちを雄弁に物語っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ほんの一瞬間であつたけれども、自分は理由なしに慄然とした。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」實に或る一瞬間、自分はさう思つて觀念した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓硝子に映つた自然の外景を、その一瞬間の姿のままで、永久に印畫しておきたいといふ夢想から、今日の飛行機や、蓄音器や、電話や、寫眞機やが發明された。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まどろむこと一瞬間、焚火も全く消えた、一個の逞ましい木像と、一個の冷たい大理石像と、小舎の中に横わる、一は依然として動かないのに、一は蠢めいて待つものあり。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺なんざあ、三十年も銅や岩ばっかり噛って来たが、それでも歯が一本も欠けねえ」「岩は、俺たちの米のおまんまだ」　と云う程、慣れ切った仕事であったのに、それでもその一瞬間は、たとい夏であっても体のどこかに、寒さに似たものを感じるのであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心はスパークのやうに、一瞬間青白い光を放ち、熱を持つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃はまた写真電送機というものが成効に近づいて写真画図のごときものを一瞬間に遠距離に送る事さえ思いのままになろうという事である。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来数知れぬ刑死者の中にもおそらくは万一の助命の急使を夢想してこの激烈な楽しみの一瞬間を味わった人が少なくないであろう。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬間の中に、すっかり印象が変ってしまった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩は一瞬間に於ける霊智の産物である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一瞬間令嬢を凝視し、突然その膝に身を投げかけ、両手を肩に掛け、抱き付きて叫ぶように。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（両手の間に画家の頭を挟みて抑え、目と目を見合せ、一瞬間極めて真面目になりいて、さて詞ゆるく、極めて悲し気に。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一瞬間、それらの物音が途絶えてひつそりとすると、私の頭上の何處かで、窓を開けるらしい音がするのでした。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新しい動作は、その男を非常に落着かせたものか、彼は一瞬間全く輕快さうに歩いてゆきました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――無論、それはほんの一瞬間でした。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一瞬間、橋の欄干によりかかりながら、立つてゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "大火の場合などに、極度に緊張した一瞬間の生ずるやうなことが屡※ある。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬間、儚かった恋愛の泡が消えて、エモーションの波のなかに僕は、繊細な事件のために魑魅子にあたえた心理的な新らしい恋愛の鋳型を見るのであった。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　部屋にかえると私は壁の黄色いボタンを執拗に押えつけて印度女の乱暴さをのろうように苛酷に一瞬間を指の先に約束する。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一瞬間、こんなことを感じた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬間私は、私が幼い時經驗した無念さや恐怖を、やはりそんなに迫害されてゐる私の姿を憶ひ浮べた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬間前の鋭い心構えが悲しいものに思い返せるのであった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕をこまぬいて頭を垂れ、ぼんやり佇んでいようものなら、――一瞬間でも、懐疑と倦怠に身を任せようものなら、――たちまち玄翁で頭をぐゎんとやられて、周囲の殺気は一時に押し寄せ、笠井さんのからだは、みるみる蜂の巣になるだろう。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、一瞬間だけの気持かも知れない。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬間で、私はこんなに無残に落ちてしまった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の町とロンドンの町とを一瞬間に取り換えることもできる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はあなた方の仕事をする番が来た」と言いながら、悪魔のように殺気立った群衆に取り囲まれて保安裁判所に引かれていく……　仏国革命に現われでる代表的人物の中でことに気に入ったマラーの最後のありさまは、これだけ込み入った光景をただ一瞬間に集めて、ともすれば西山の頭にまざまざと浮びでた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ天の星の如く定った軌道というべきものもないから、何処で会おうかもしれない、ただほんの一瞬間の出来事と云って可い。",
              "citation": {
                "source": "一寸怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その眼と眉の間に一種形容の出来ぬ凄味を帯ていて、所謂る殺気を含んでいると云うのであろう、その凄い怖い眼でジロリと睨まれた一瞬間の怖さ恐しさ、私は思わず気が遠くなって、寝台の上に顔を押付けた。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あたしだって、一瞬間の何千倍も生きて、楽しく、しあわせに、くらしますわ。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
