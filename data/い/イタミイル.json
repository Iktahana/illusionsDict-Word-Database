    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be greatly obliged",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「遠方よりわざわざお越しいただき、誠に痛み入ります。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この度は一方ならぬご厚情を賜り、痛み入るばかりでございます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ご多忙の中、ここまでお骨折りいただき、全く痛み入る次第です。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "身に余る光栄とは存じますが、謹んでお受けいたします。痛み入ります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私の不手際にもかかわらず、寛大なるお言葉をいただき、痛み入ります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このような細やかなお気遣い、誠に痛み入るばかりでございます。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年のご愛顧に深く感謝申し上げます。痛み入ります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「これは御挨拶、痛み入る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の澄まない事がいくらある……「お言で痛み入る。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "只で頂いては痛み入るが頂戴するぞ」　ずいずいと近寄りながら、鐺で錠を手もなく叩きこわして、さッと蓋をはねのけました。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎度々々よく御気がついて痛み入る次第じゃ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし達の間はまだ何でもないし、第一水戸さんはご存じないのよ」「へえ、そうかね」とドレゴは大袈裟に愕いてみせて「わが可憐なるエミリー嬢が見掛けとはおよそ似つかぬ清純たる恋に悩んでおられるとは、さっぱり気がつかなかったね」「おおきにお世話よ、鈍感坊ちゃん」「これはお言葉、痛み入る。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士とは痛み入る叮嚀なお言葉だが、商売柄だけ誰を見ても紳士と云うのが口癖に成って居ると見える、婆は医学士の背後から「イエイエ、お待ちなさいよ、グリムを呼んで来て噛み殺させるから」と云い早や立ち去ろうとする様子だ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、その節快く御承諾下されたので、我々共は今日の参るのを指折り数えて待っておった次第で」「なんでござったかな、敵討なんどと、左様な大事件をお引受け致したか知らん」「御失念では痛み入る。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、御丁寧な御挨拶にて、痛み入る。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して其の丘のような横広い体躯を揺り起して、額をピタリ卓子につけて痛み入る程丁寧な挨拶。",
              "citation": {
                "source": "大野人",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船長どのに、左様お伝え願おうか」邦夷はそれを士官に云った、「身どもも今は開拓使の移民の一人――別段のご配慮はかえって痛み入るばかりじゃ」「でもございましょうが」「おぬし――」と邦夷は幾らかいらいらした声で阿賀妻を呼んだ、「行って断って来て貰わにゃなるまい」　士官はおどろいて二三歩うしろに退った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニ助けたと申し条、ただちょっと通りかかったまで、そのご挨拶では痛み入る」葉之助も傲然と云った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "可いんでせうね」と念を押して、何にも知らない下女を氣の毒がらしてゐる所へ、最前の仲働が出て來て、「何うぞ御通り下さい」と丁寧に頭を下げたので、今度は宗助の方が少し痛み入る樣になつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は痛み入る境を通り越して、遂に迷惑を感じ出した。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、本多は、『お言葉の通りの道理と存じ、まことに、痛み入る次第である。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく二人がお膳についた時に、大丸髷のお絹が、きちんと身じまい薄化粧にまで及んで、たいへんな澄まし方でお給仕に立つのが、あんまり現金で痛み入るくらいのものでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日も早く賢彌さんを相俣淵へ引き取って、岩魚を安心させてやりたいが、なんとかならぬものでしょうかといったところ、一言のもとにはねつけられた」「それはご親切に――厚くお礼を申しあげます」「お礼で痛み入る――ところで、嫁を貰い子供を儲けぬうちに賢彌を誘拐すれば、石坂家の系図はそこで絶えてしまう。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とそれを言へば、先方は猶々痛み入る様子。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "碩翁殿よりの紹介状、丁寧でかえって痛み入る。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではひとの病気処にては無之、御見舞状を受けて却って痛み入る次第に候。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、昔あれほど気に病んでいたお線香代のほかのお心付けも、もうこのごろでは師匠こんなに頂いてはと寺男が痛み入るほど莫大にやることができるようになっていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それでは痛み入る。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウウ荒木氏、松原氏、ママお気を悪くなされぬように……」「お言葉で痛み入る」荒木陽一郎は、まだ、左手に引きつけた一刀を離さずに、「それは、マア、屏風の置き違えにはきまっておるが、場合が場合じゃテ、臆病なようだが、ちょっとびっくり致した。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が正装をしているのに私はこんな服でと先生が最前云われた時、正装の二字を痛み入るばかりであったが、なるほど洗い立ての白いものが手と首に着いているのが正装なら、余の方が先生よりもよほど正装であった。",
              "citation": {
                "source": "ケーベル先生",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上よく観て、何でも気がついた事があるなら、そう云いなさいと、あたかも余を視察家扱にするんだからなおさら痛み入る。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいんでしょうね」と念を押して、何にも知らない下女を気の毒がらしているところへ、最前の仲働が出て来て、「どうぞ御通り下さい」と丁寧に頭を下げたので、今度は宗助の方が少し痛み入るようになった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
