[
  {
    "uuid": "631af3bd-8640-52e5-8631-2bf4a1f3143f",
    "entry": "痛み入る",
    "reading": {
      "primary": "いたみいる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
