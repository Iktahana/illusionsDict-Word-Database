[
  {
    "uuid": "cd378624-a4bf-5cf6-ae44-cd6bf001c449",
    "entry": "意力",
    "reading": {
      "primary": "いりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
