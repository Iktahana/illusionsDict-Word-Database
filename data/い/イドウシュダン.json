          "literary": [
            {
              "text": "現場への移動手段、事件の詳細なども依然として不明のままで、スタンガスンの消息もわかっていない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんのひと時であろうと、人の住まわぬこの地、悠久の死が支配する究極の地に移動手段なしでいるのは賢明ではないからだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
