          "literary": [
            {
              "text": "机は蚊母樹か何かで岩乗に出来てゐて、引出には真鍮の金物が打つてある。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或るとき伊澤氏で、蚊母樹で作つた櫛を澤山に病家から貰つたことがある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の休みを待って、心の引かれるまま、うぐいすのきた方角へ出かけてみました。",
              "citation": {
                "source": "春はよみがえる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
