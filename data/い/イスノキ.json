    "definitions": [
      {
        "index": 1,
        "gloss": "Distylium racemosum (evergreen tree of the winter-hazel genus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
