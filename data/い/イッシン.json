[
  {
    "uuid": "e3492079-fc42-51a8-bd5e-bb0c870f6077",
    "entry": "一審",
    "reading": {
      "primary": "いっしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
