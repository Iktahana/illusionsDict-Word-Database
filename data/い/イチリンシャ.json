        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "小学校のグラウンドで、子供たちが器用に一輪車を乗りこなして遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "娘への誕生日プレゼントに、サドルがピンク色の一輪車を買ってあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "サーカスのピエロが、背の高い一輪車に乗りながら見事なジャグリングを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "＊濁点付きの二倍の踊り字は「／″＼」-------------------------------------------------------一　五六台の一輪車が追手に帆をあげた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一本しかない一輪車の車軸は、巨大な麻袋の重みを一身に引き受けて苦るしげに咽びうめいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一輪車は菱形の帆をふくらましたまゝ貧民窟から、その兵営の土煉瓦のかげへかくれて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一輪車が咽ぶその反対の方向では、白楊の丸太を喰うマッチ工場の機械鋸が骨を削るようにいがり立てた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後方に一輪車が取り付けられ、そうして三つの輪の中央のサドルに腰をかけた人がペダルを踏んで推進する仕掛けになっている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペムペルがキャベジの太い根を截ってそれをはたけにころがすと、ネリは両手でそれをもって水いろに塗られた一輪車に入れるのだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またインドで曙光神アスヴィナウは、日神スリヤその妃サンニアと牡馬牝馬に化けて交わり生んだので三輪の驢車に乗り、日神自身は翡翠色の七頭の馬に一輪車を牽かせて乗ると類似して、ギリシアの日神ヘリオスは光と火を息する四の雪白馬が牽く車に乗る（第六図）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "合間合間に、小さい子供が一輪車に片脚をのせて転って行った。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした窖の中に、広漠たる平野を蔽いつくす耕作力がひそんでおり、一輪車で物を逓送する汽車以上の運輸力がひそんでおり、豚が仔を産み、鶏が孵化し、穀物の袋や酒の甕が蓄えられ、時とすると壁に貨幣が塗りこめられ、人の子が次々に生れてゆく。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車、馬車、力車、一輪車、電車、あらゆる種類の車と、あらゆる人種を交へた通行人とが絡繹としながら些の衝突も生じないのを見ると、神田の須田町や駿河台下でうろうろして電車に胆を冷すのはまだ余程呑気だと思ふ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また手押の一輪車は市街や村落の中で小貨物を運ぶのに用ひられる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに一輪車の通る度に、きいきい心棒を軋ませるのは、頭痛さえしかねない騒々しさである。",
              "citation": {
                "source": "長江游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑内から一輪車やトロッコを押して来る掘子等は、下帯一つの素裸になっていた。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は、「選鉱の一輪車押しをしていた寅吉でやさ」と答えた。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "街を歩いている支那の商人や、一輪車に乗って行く支那婦人の服装。",
              "citation": {
                "source": "十九の秋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八二項　車輪の怪痕　愛知県葉栗郡浅井村に数十年前、一輪車の怪と名づくるもの現れたことがある。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが現実に所有するのにいちばん近くまで往ったのは、わたしがホローエル農場を買おうとしたときで、わたしはわたしの種子を選り別け、またその農場をつづけ、もしくはできたものをはこび去るための一輪車をつくるための材料をあつめにかかった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、わたしは気前を見せて、その畠をわたしがそれに払ったとちょうど同値で彼に売りわたし、相手が金持ちでなかったから十ドルの贈り物をし、それでもまだ自分はくだんの十セントと種子と一輪車の材料とを手許にのこしたともいえる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしわたしは風景は手許にのこしておき、その後は毎年それが産んだものを一輪車なしではこび去った。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "女や子供、年寄が多く、片足で飛び飛び一輪車を廻して来る小児、まるで動物と思えないような小犬を、華奢な鎖で引つれて、ファーコートの間から、仄かな花の香りを暖い午後の空気に残して行く婦人。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜひ真相を突き止めてやる」　男が一輪車を押してゆっくり戻って来たので、直接話すために男爵が近づいて言った。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは名前がジェフリ、駐独英国大使の息子です」　男は一輪車と去り、残った二人の男は混乱するばかりだった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫車は近世支那から輸入した一輪車のことで、どんな幅の狭い田の中の路でもあるくから便利なものだが、我々はそのきいきいと細く軋る音を形容して、こんな変った名を付けていたのである。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
