        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "畑の畝の間に堆肥を運ぶには、この手押しの一輪車が一番小回りが利いて使いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "炎天下の建設現場で、砂利を山盛りに積んだ一輪車を何往復もして運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "長年使って錆びついた農作業用の一輪車を、ペンキで塗り直して修理した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
