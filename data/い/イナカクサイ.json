    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rustic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上京したての頃は、自分の服装がどこか田舎臭い気がして気後れしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の言葉遣いは少し田舎臭いが、それがかえって親しみやすさを感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この店の内装は、意図的に田舎臭い雰囲気を演出しているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "洗練された都会の生活に憧れる一方で、ふと自分の田舎臭さが嫌になることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてその仕事をまじめにしているともう考えることも考えることもみんなじみな、そうだ、じみというよりはやぼな所謂田舎臭いものに変ってしまう。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどうやら田舎臭い感じを与えて、かの女に失望の影をさしかけた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに何処何処のカフエーで落したから念の為に訊いて見て呉れといふので、私が行つて見ると田舎臭い白粉をごて／＼と塗つた四五人の女が、ゲラ／＼と笑つて、「まあ、落したんですつて……あんまり気前好く振り撒いたので気まりが悪いんでせう。",
              "citation": {
                "source": "老猾抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "華楊の作とは、斯うした田舎臭いものと、都会臭いものとの他に、もう一つ問題にしていゝ立場のものがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも郷里の人に両親から言伝た品物だとかで、例によって私が帰宅後に、病院に居残っていた彼女が受け取ったという話であったが、彼女が汗を流して提げて来た酒瓶と樽にはレッテルも何もなく、きわめて粗末な、田舎臭い熨斗紙が一枚ずつ貼り付けて在る切りであった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉助や妹達は、あんな田舎臭い女が姉だなんて云つて来られると震へあがるなどと軽蔑し、わたしの妻だけがひとり親しく交際してゐるだけだつた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は髪の毛の長い、色の白い、薄痘痕のある、背の高い男で、風采は何所となく田舎臭いところがあるが、其の柔和な眼色の中には何所となく人を引付ける不思議の力が籠つて居て、一見して、僕は少なからず気に入つた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "清方といふ人は江戸ツ子によくある酷い郷土自慢で、偶に病気にでも罹つて、箱根辺へ保養に出掛けなければならぬ折には、家族と水盃も仕兼ねない程の旅行嫌ひで、東京市内でも山の手は田舎臭いといつて、滅多に出掛けた事が無いさうだが、その日は築地だつたから、別れに水盃の必要もなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくとも、民衆には丸で無関心な、若しくはロメン・ロオランの云ったように、民衆を少しも軽蔑しないと云う事を却って軽蔑のたねにする、即ち其の膏汗で自分等の力を養ってくれた親の田舎臭いのを恥じる、成上り者共の多い文壇の事である。",
              "citation": {
                "source": "新しき世界の為めの新しき芸術",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は気味の悪いほど赤く縮れた髪をもった、巌畳な体格の女で、リモオジュから主婦の手伝いに巴里へ出て来たばかりの頃はいかにも田舎臭い娘であったが、その人がもう一度田舎の方へ帰って行く頃には見違えるほど巴里の風俗を学んで、働き好きな娘らしい手なぞにもさすがに若い女のさかりを思わせるものがあった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "難かしいことを云えば技術的に未だ未熟だし、田舎臭いところもありはするがトラムにはそう云う欠点を片端から克服して行くだけの唯物弁証法的な努力と正しいプロレタリア的素質がある。",
              "citation": {
                "source": "ソヴェト「劇場労働青年」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しその第三流的な田舎臭いところが僕には好きなんだ。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人通りは多いが田舎臭いところが町の隅々にころがって居る。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヤケツの上衣の長いのや裳の大きく拡がつたのなどは、昔長崎へ来た和蘭船の絵の女を見る様に古風である丈今日の目には田舎臭い。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯林の女は肥満した形が既に美でないのに、服装も姿態も仏蘭西の女を見た目には随分｜田舎臭いものである。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "割合に広い住居ではあったが、なにしろ田舎臭い処であった。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お雪さん、そんな田舎臭い束髪を……どれ、貸して見さっせ……私は豊世のを見て来たで、一つ東京風に結ってみて進げるに」　お房は大きな口を開きながら、家の中を歌って歩いた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い雨外套を着た職工風の男が一人、絣りの着流しに八字髭を生しながらその顔立はいかにも田舎臭い四十年配の男が一人、妾風の大丸髷に寄席芸人とも見える角袖コートの男が一人。",
              "citation": {
                "source": "寺じまの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い雨外套を着た職工風の男が一人、絣りの着流しに八字髯を生しながらその顔立はいかにも田舎臭い四十年配の男が一人、妾風の大丸髷に寄席芸人とも見える角袖コートの男が一人。",
              "citation": {
                "source": "寺じまの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "白っぽい浴衣に兵児帯をしめ、田舎臭い円顔に口髯を生した年は五十ばかり。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はしまいに父の無知から出る田舎臭いところに不快を感じ出した。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎臭いことが嫌いな私は、自然書生臭いことも嫌いだったので、よほど語るに足ると思う相手でない限り、めったに文学論や藝術論などを闘わすこともしなかった。",
              "citation": {
                "source": "客ぎらい",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎八は四十過ぎの中年者で、一座には腕ッこきの達者がそろい、江戸のお客には、少し田舎臭い芸ではあったにしても、二た月あまり飽きさせずにいたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池、芥川の両君とか、ことに久米君などは、同じような所を歩いていながら、今までの田山のやり方を野暮だとか何とかいったり、田舎臭いと罵ったりして、やって来たわけであった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは女房どものような田舎臭いものと違って、彼女が富裕なミウーソフ家で女中をしていたころ、モスクワから招聘された舞踊の師匠が踊りの振り付けをした同家の家庭劇場で、彼女もいっしょに踊ったその踊り方であった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時彼女はこの男の容貌が如何にも田舎紳士臭く、知的なところが少しもないのが気に入らなかったので、義兄の親切な斡旋があったにも拘らず、我が儘を云って断ってしまったのであったが、あれから十余年の歳月を経た今見ても、矢張この人は田舎臭い顔をしている。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
