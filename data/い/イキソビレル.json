        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "楽しみにしていたライブ、チケットが取れずに結局行きそびれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "特別展に行きたかったのですが、会期中に都合がつかず、残念ながら行きそびれてしまいました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、あの限定品のセール、仕事で忙しくて行きそびれた！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "郵便局に荷物を出しに行こうと思っていたのに、うっかり忘れて行きそびれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ずっと気になっていたあの島への旅行、飛行機の予約が取れず行きそびれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地元の大きなお祭りに参加するつもりだったが、急な雨で中止になり、多くの人が行きそびれて残念がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
