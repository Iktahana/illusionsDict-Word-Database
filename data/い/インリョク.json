[
  {
    "uuid": "8566d1ce-5fb5-5be4-90bc-ddae7a35f185",
    "entry": "引力",
    "reading": {
      "primary": "いんりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
