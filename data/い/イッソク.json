[
  {
    "uuid": "37b53186-1ba6-577d-aa9f-a5c75661e8c1",
    "entry": "一足",
    "reading": {
      "primary": "いっそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
