        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若くしてこの分野で逸足を発揮した彼には、将来が嘱望されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は幼い頃から絵画における逸足を示し、周囲を驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
