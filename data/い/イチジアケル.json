    "definitions": [
      {
        "index": 1,
        "gloss": "to leave a space (between words)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
