        "examples": {
          "standard": [
            {
              "text": "物価高騰が続けば、この給料では「とても」生きていかれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ああ、彼なしでは」生きていかれないと、彼女は涙ながらに訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代社会では、スマートフォンなしには「もはや」生きていかれないと感じる人も多いだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "好きな仕事がなければ、いくら給料が良くても「きっと」生きていかれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "都市部で生活するには、公共交通機関がなければ「到底」生きていかれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もし彼がいなかったら」私は一人では生きていかれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この分野の専門知識なしには、この業界では「もう」生きていかれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それでも今までの茶店を続けていけば、生きていかれないことはなかった。",
              "citation": {
                "source": "身投げ救助業",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はミーチャなしじゃ生きていかれないよ。",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりほかに僕の生きる道はないんだ」「あなたと別れては、私は生きていかれないわ」「生きてゆかれるだけの物を君にやる」「全財産でしょう？",
              "citation": {
                "source": "魔性の女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べねば生きていかれない人間なんですものね。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
