          "literary": [
            {
              "text": "それでも今までの茶店を続けていけば、生きていかれないことはなかった。",
              "citation": {
                "source": "身投げ救助業",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はミーチャなしじゃ生きていかれないよ。",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりほかに僕の生きる道はないんだ」「あなたと別れては、私は生きていかれないわ」「生きてゆかれるだけの物を君にやる」「全財産でしょう？",
              "citation": {
                "source": "魔性の女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べねば生きていかれない人間なんですものね。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
