  {
    "uuid": "1f611859-dced-5538-91f6-5c1931f4eba6",
    "entry": "磯祭",
    "reading": {
      "primary": "いそまつり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
