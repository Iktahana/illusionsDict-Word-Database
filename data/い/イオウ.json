[
  {
    "uuid": "48a30c6f-6ee7-5033-bf83-59b35959cfca",
    "entry": "以往",
    "reading": {
      "primary": "いおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "after",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "以往のデータに基づけば、この予測は妥当だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "以往の経験から、同様のミスを避けることができるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "以往の慣習にとらわれず、新しい視点で問題を解決する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域では、以往には見られなかった現象が頻発している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "以往の成功事例を参考にしつつ、独自の戦略を練る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は以往、幾度となく困難を乗り越えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "以往の議論を踏まえ、最終的な決定を下す運びとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十数年｜以往文壇と遠ざかってからは較や無関心になったが、『しがらみ草紙』や『めざまし草』で盛んに弁難論争した頃は、六号活字の一行二行の道聴塗説をさえも決して看過しないで堂々と論駁もするし弁明もした。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その裏面を窺ふと、或は願後身世世、勿復生天王家（劉宋の順帝）といひ、或は願自今以往、不復生帝王家（隋の恭帝）といひ、似而非なる禪讓の犧牲となつた君主の境遇、眞に憐むべきものがあつても、兔に角形式の上では、堯舜の先例その儘になつて居れば、それで支那人は承知するのである。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "無力なる君主は、或は願後身世世、勿復生天王家といひ（劉宋の順帝）、或は願自今以往、不復生帝王家といひ（隋の恭帝）、極端なる恐迫觀念に戰きつつ、危惧憂鬱なる一生を送る。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大師の作られた、「爲大使與福州觀察使書」の中に、建中（西暦七八〇―七八三）以往、入朝使船、直着揚蘇。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "其に先つて言はねばならぬことは、「祝詞」又は略して「祝」の字面を以て、のりとに宛てるのは、大体平安朝以後の慣例と見てよく、さうして、さう言ふ字面が用ゐられ、其用例から認容せられたのりとの内容は、やはり延喜式の祝詞から、百年前以往には溯れないだらうと言ふことである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "世田ヶ谷に出て、三軒茶屋以往は、最早東京の場末である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその所謂日の本の地も、内地文化の進展とともに、次第に東方に退却して、近世では北海道アイヌは得撫以往の北千島をチュプカと呼び、その住民なる千島アイヌをチュプカグルと云う。",
              "citation": {
                "source": "国号の由来",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世以往農工商の住所にあらず、梓神子・猿引・傀儡師・非人頭等住し、今南都の僻地なり。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "辭書の如きも、未だ多く徳川時代の著作の羈絆を脱せず、中古以往の語にのみ詳にして、現代の活きたる言語に粗なり。",
              "citation": {
                "source": "『辭林』緒言",
                "author": "金澤庄三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをもっと端的に「詞は古きをしたひ、心は新しきを求め、及ばぬ高き姿をねがひて、寛平以往の歌にならはば自づからよろしき事もなどか侍らざらむ」ともいっている。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "定家は『近代秀歌』の中に、「詞は古きをしたひ、心は新しきを求め、及ばぬ高き姿を願ひて、寛平以往の歌に習はば、自づから良しきこともなどか侍らざらむ」といっているが、為世の『和歌秘伝抄』には、この詞の中、特に「寛平以往」という点を全く黙殺している。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、為兼はまさにその「寛平以往」を足場として、『万葉集』に学ぶ立場の自由を導き入れているのである。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに駿河町の越後屋（そのころの三井呉服店、今の三越）をいおう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いていおうならば北斗南面して看るという唐ようの古語にでも表現を譲るより仕方はあるまい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、おまえが何といおうとも、私はこれからもおまえにああいう手紙を書き送る。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私自身も郵便を投函する必要のあるとき自動車の運転手に「郵便函があったら留めてくれ」といおうか「ポストがあったらストップしてくれ」といおうか、どっちがよくわかるだろうかと咄嗟に迷うことがある。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの場合で、クキがクッキーでグキットしたとはいいやすいが、アマノがアマゴとアナゴを間違えたといおうとするとうまく口が廻らないで多少の努力を要する。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじっかなこと云い出せないもの」　じりじりと照りつける陽の光と腹匍いになった塚の熱砂の熱さとが、小初の肉体を上下から挟んで、いおうようない苦痛の甘美に、小初を陥れる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父は少しも意に介せず、「これ、一生のうちにただ一度いおうと思って、今までおまえにもだれにもほのめかしたこともないが、ついでだから謂って聞かす。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それから道の程を経て、京橋辺の道具屋に行くと、偶然といおうか天の引合せといおうか、たしかに前の鐙と同じ鐙が片方あった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと着物を着て四角いおうちにはいっているんだぞ。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『いやじゃないが、今すぐと言うたところで叔母が承知するかせんかわからんじゃないか』『叔母さんがなんといおうとあなたがその気ならなんでもない、あなたさえウンと言えば私が明日にでも表向きの夫婦にして見せます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たいへんなの……」「たいへんなの、ぼくの部屋が火事になったよう」といおうとしたが、どうしても「大変なの」きりであとは声が出なかった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが私には一つの仕事があって、他の人はどういおうと、私としてはこの上なく楽しく思う仕事ですし、またその仕事から、とにかく親子四人が食っていくだけの収入は得られています。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は少し安心して、若者の肩に手をかけて何かいおうとすると、若者はうるさそうに私の手を払いのけて、水の寄せたり引いたりする所に坐りこんだまま、いやな顔をして胸のあたりを撫でまわしています。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして渡瀬さんに対する自分の考えをいおうとしているうちに、母は支度をすまして茶の間にはいってきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母さんはそのきっかけにおぬいさんに何かいおうとしたらしかったが、思い返したか、心｜許なげな眼つきでその後姿を目送しただけで何もいわなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いおうようない嫉妬が身を噛み上げて来て私は小頸だけぶるぶると慄わした。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "素質と言おうか、本能といおうか、ただただ不思議である。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "錐を引いたと同時に去って行く痛みの尾のいおうようない甘酸っぱいひりひりした感覚の中に、うっかり閃いて来る心象は橘屋の娘のことでなければ富士の白い姿であった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "before",
