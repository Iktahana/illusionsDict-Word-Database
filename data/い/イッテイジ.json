        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「彼はあんなに知識人を気取っているが、実は一丁字も解さない無学な男だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一丁字も読めないまま異国の地に放り出され、彼は途方に暮れてしまった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一丁字も書けなかった祖母が、ひらがなを覚えて最初に書いたのは私の名前だった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "處で、此女房が眼に一丁字の無いもので、泰然自若の意味が分らなくても、其言葉で如何にも泰然自若たる處が表れてゐなければいけない。",
              "citation": {
                "source": "文章の音律",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は眼に一丁字もない彼女が何をするのかと、訝んだ。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に一丁字のないこの猴の前にいるときほど、文字による教養の哀れさを感じさせられることはない。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁夫など一丁字なき者は海図など見るも分からず、不断山頂の木また神社の森のみを目標として航海す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし文字のあるものが、目に一丁字のない床屋の若いものに、智慧をつけて、嵩じたいたずらをしたのが害になったんだから、なお責任は重大です。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老耄せしにも由るべけれど、もとより目には一丁字もなし。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤は牙籌一方の人物で、眼に一丁字なく、かつて応挙の王昭君の幅を見て、「椿岳、これは八百屋お七か」と訊いたという奇抜な逸事を残したほどの無風流漢であった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "元藩士の役人の家に生れながらおちかは眼に一丁字なかつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」氷峰が氣を利かせたやうに返事を引き受けた、「小樽の松田などア、兄の方は道會議員でも目に一丁字なしの方で、兄弟とも分らず屋だから、どうせ駄目と見といてよからうが、まア、あせらずにゐ給へ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかれは文盲だ、眼に一丁字なく、耳に一章句を解せぬが、しかもよく大義名分を弁え、日露の役には区民に率先して五十円を献金し、某の侯爵に隣してその姓名を掲げられたが、実は侯爵よりも数日を先んじて報公の志をつくしたのであったそうな。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "父には誠意がなく、母には眼に一丁字もなかった。",
              "citation": {
                "source": "父",
                "author": "金子ふみ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに思え、古来｜一丁字を知らざる母が、よくその子を育して遂に天下の一大家となしたる者あるにあらずや。",
              "citation": {
                "source": "教育の事",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紹介状を貰ふときに東京で聞いた所によると、此宜道といふ坊さんは、大變性質の可い男で、今では修業も大分出來上がつてゐると云ふ話だつたが、會つて見ると、丸で一丁字もない小廝の樣に丁寧であつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼に一丁字なきものゝ為めに、パスカルの言も市役所の標語も何等異なる処はない。",
              "citation": {
                "source": "横槍一本",
                "author": "――外国文学の『味』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼に一丁字無き百姓婆さんも、こうしてそこらの博士さん達よりも本当の学者になつて居る。",
              "citation": {
                "source": "百姓日記",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "角力トリのある人々は目に一丁字もないかも知れぬが、彼らは、否、すぐれた力士は高度の文化人である。",
              "citation": {
                "source": "太宰治情死考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に一丁字もないことは問題ではない。",
              "citation": {
                "source": "太宰治情死考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業の性質上、目に一丁字もない文士はいないが、一丁字もないと同様、非常識であっても、芸道は、元来非常識なものなのである。",
              "citation": {
                "source": "太宰治情死考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人たちは、戦争中、弾圧、禁止を乱用したものだが、目に一丁字なき軍人がこれを行うのは、ともかく、文化国家と自称するものが、禁止の安易につくとは言語道断と云わねばならぬ。",
              "citation": {
                "source": "戦争論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に一丁字もない男女が予言を行って狂わぬことがあるものだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その九　覆面屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "紹介状を貰うときに東京で聞いたところによると、この宜道という坊さんは、大変｜性質のいい男で、今では修業もだいぶでき上がっていると云う話だったが、会って見ると、まるで一丁字もない小廝のように丁寧であった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに住する人民は目に一丁字を解せず、身に破褸を着け、垢臭人を襲わんとするも、はだしのもの少なく、裸体せるものにいたっては全くなし。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "生国は越後で眼に一丁字もない無学文盲でしたけれども、性来の利発もの、お世辞はないが実直でなかなかたのもしい女でした。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くはある時代のある片田舎の、ほとんど眼に一丁字もなき人々の製作であった。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴隷には黒奴もあれば白人もあり、白人の中には花のごとき窈窕たる美女もありながら、しかも彼らも彼女らも眼に一丁字なく、奴隷は祖先代々奴隷としての境遇に甘んじてその範囲を出ることは一歩たりとも許されないのです。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち目に一丁字なきこれ等の女性文人が、特に物識りとして尊ばれた根拠である。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "山名時氏などは目に一丁字もなかったという。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "高々船長ぐらいになって、三上さん見たいな人をいじめて、ご自分はまた、自動車か何かに乗った耄碌爺からわけもわからないことをいっていじめられたいの。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪口をいっていじめるって。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、あなたたちは、勉強ができないといっていじめたり、服がおかしいといって笑ったり、おとうさんが金持でないといったり、鼻のかっこうがわるいといってあざけったりする生意気な連中と、いっしょに学校にいかなくてもいいんですもの。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
