  {
    "uuid": "5fef0f27-30d4-57b1-9640-11b210671c2c",
    "entry": "板敷き",
    "reading": {
      "primary": "いたじき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
