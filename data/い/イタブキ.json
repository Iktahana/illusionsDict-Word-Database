          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その古い寺院の屋根は、杉の板を幾重にも重ねた板葺きの技法で造られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山間の集落には、今もなお板葺きの民家が点在し、昔ながらの景観を保っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文化財の修復にあたり、雨漏りがひどかった板葺きの屋根を全面的に葺き替えることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「板葺きの屋根は趣があるけれど、現代では維持管理が大変そうですね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "檜の薄い板を用いた板葺きは、その繊細な重なりが建物に独特の美しさを添える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "瓦葺きが普及する以前、庶民の住居の多くは板葺きや茅葺きが一般的であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "激しい風雨にさらされた板葺きの屋根は、年月とともに銀灰色へと味わい深く変化していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この宿屋もこの前の紀行には『これも廣重の繪などに見るべき造りの家である』と書いてある通り、曾木板葺きの古び果てた宿であつたが今は一枚ガラスの大戸を玄關に立てた立派な宿館に新築されてあつた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月に野分の風が強かった年以来廊などは倒れたままになり、下屋の板葺きの建物のほうはわずかに骨が残っているだけ、下男などのそこにとどまっている者はない。",
              "citation": {
                "source": "源氏物語",
                "author": "蓬生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれを見て非常に変な感じに打たれたのでありますが、せめて家丈けでも板葺きの家が見られるやうになりたいといつても小作人は自分が経済が発展しやうがないので迷惑がるのであります。",
              "citation": {
                "source": "農場開放顛末",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家根といえば瓦葺きか板葺きである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半は甍で半を板葺きの田舎町が。",
              "citation": {
                "source": "赤い鳥居",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "影は板葺きの屋根を這って、軒先に突き出ている大きい百日紅を足がかりに、するすると滑り落ちて来るらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古ぼけた小さな母家の前には、花を一杯につけた林檎の木が二本あり、家の後ろには、ななかまどと接骨木の木だけの、長の低い小さな庭があって、その叢みの奥に、柿板葺きの木造の小舎がかくれており、擦ガラス入りの小さな窓が一つ見えていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は度たび夢うつつの間に彼の両親の住んでいた信州の或山峡の村を、――殊に石を置いた板葺き屋根や蚕臭い桑ボヤを思い出した。",
              "citation": {
                "source": "玄鶴山房",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "門に立てる松や竹も田端青年団詰め所とか言う板葺きの小屋の側に寄せかけてあった。",
              "citation": {
                "source": "年末の一日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある板葺きの小屋のそばを通り過ぎるころ、平兵衛は路傍の桃の小枝を折り取って、その葉を笠の下に入れてかぶった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど屋根を板葺きにした板家と同様だから、それで板家カエデというのであるとして、今日いうハウチワカエデ（Acer japonicum Thunb.）の葉形が掲げてある。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は雨で、古い板葺き屋根を打つ雨の音が、かなり高く、そして間断なしに聞えていた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いはまた板葺き屋根の上に、どしんと物の落ちた響がして、驚いて出てみたら、気を失ってその児が横たわっていた、という話もある。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、板葺きの変化　これとは反対に、萱で葺く屋根のほうは、あまり平べったくしておくと雨の水がよく流れず、萱の茎のあいだに湿気をもって、やわらかくなり、また早くくさって、葺きかえをしなければならなくなるので、どこの地方に行っても、葺くのにさしつかえのないかぎりは、なるだけあの三角を尖らせようとしている。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてどちらもだんだんに変ってきたという中でも、板葺きのほうは少しずつ後へさがり、萱葺きはつい近ごろまで、数も多くなり、また技術も進んでいた、ということが言えるようである。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは板葺き一派の三角のゆるい扁たいもので、ささ板やこけら板で葺いたのから、檜はだ、杉皮の屋根まであり、現在さかんに建っている瓦葺きもその中にふくめてよい。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門の職工には、技術のすぐれた者が多く、鋏とか、槌とか、こて板とか、その他いろいろの道具の使い方をかんがえ出して、二尺三尺の厚さにはしを切りそろえ、あの美しい屋根の形をつくりだしたのは、空中の彫刻といってもよく、これとくらべあわせると、板葺きはむしろ単調に見える。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "萱野の萱がだんだんと足りなくなってきて、木材ももう少ないのだから、ふたたび板葺きにもどることもできず、瓦はまだそう容易には手にはいらぬという時代には、ふつうの日本人はいろいろと、ほかの材料をかわりに使う工夫をした。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事の用心に板葺きというのはおかしいが、その板の上には蠣の殻を多くのせて、火の子の燃えつくのを防がせることにしたのであった。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際に大通りの本町二丁目に、滝山弥次兵衛という金持があって、家を新築するのに町に面した屋根だけを瓦で葺き、棟から裏のほうは板葺きにした。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "板葺きの三角は平たいから、どんなに大きくてもそう棟が高くならない。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "上品のうちにも、どこかメフィストめいたぶきみさをたたえた不思議な老人だ。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
