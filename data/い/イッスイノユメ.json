          "literary": [
            {
              "text": "民子は一炊の夢も結ばず。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自から稱す、汽車の通ぜざりし頃は、車夫を業とし、東京まで二日半にて走りつき、得たる賃錢を紅樓に一擲して豪遊せしも、すでに一炊の夢に歸しぬ。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗木城の客分になった事も、ようやく雲助の足を洗って苗木城中浪人組のその一人に加わって天晴れ一働きと思った時坊主之助と名を宣る玄斎とかいう入道に惜しいところで遮られたのも今から思えば一炊の夢のほんの一｜時の栄華であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……かしこ過ぎて、ここ現実の園に戻り来れば、何事もみなはかなき一炊の夢だ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
