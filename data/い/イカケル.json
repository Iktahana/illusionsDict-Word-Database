          ],
          "literary": [
            {
              "text": "距離はちょうど射ごろの十二、三間、上からねらって射掛けるにはかっこうの高い鐘楼が見えるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に矢を射掛けるように、ひどく己を傷けおる。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いかけると、左右の頬に、子供のような笑窪が出来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子が追いかける草のなかを、ばったは二本の脚を伸ばし、日の光を羽根一ぱいに負いながら、何匹も飛び出した。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、基本的人権というのは、……」　と、誰かが言いかけると、「え？",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の主人にお知らせしようと思い、あなた、と言いかけると直ぐに、「知ってるよ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは……これで……お暇を……この御恩は死んでも……」「アラマア……」　眉香子は追いかけるように二、三歩進み出た。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃア母上さんが……」と言いかけるのを自分は手を振って打消し、「黙っておいで、黙っておいで」と自分は四囲を見廻して「これから新町まで行って来る」「だって貴所……」「否や、母上さんに会って取返えして来る。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『出直そうよ、ぐずぐずしてるとまた鉄道往生と間違えられるから、』と行きかける、『人をばかばかしい、』と娘はまだ何か言いかけると内から母親があくび声で、『お菊もう寝るから外をお閉め。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしていちばんあとから見えと因襲の靴を踏み脱ぎすてたヒロインが追いかける。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな連中は世間憚らず女にからかいかけるので白昼でも女の一人歩きはしなくなった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夫が学生たちに笑いかける。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（蓮月、客の讃辞を聞き流し、そろそろ品物をしまいかける。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "註文を引受けてきた出前持は、多少間の悪い面持で「お気の毒さまですが、もう看板だったので」　と言いかけるのを、年長の出前持はぐっと睨めて顎で指図をする。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、そりゃ……」　困ると、あとを追いかける余裕もなく、鶴雄は赧くなってぽかんと見送っていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小田さんを訪ねて来て、よかった」　と、思いながら、両手をついて、「――はじめまして、あたくし」　と、言いかけると、小田はいきなり、「判ってます。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いきなり、「明日……」　昼食を食べにホテルへ来ませんかと、信吉が言いかけると、しかし冴子は、「衣裳をつけて来ますから……」　と、もう立ち上っていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は男の真似はよした方がいい」「だって、今は女だって男の方のすることを……」　と、一枝がいいかけると、照井は、「しかし、あんたは働いてない」「しかし、あんたは働いてない」　白崎は例によってすぐ照井の口真似をした。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、女の子は、そのあとを追いかけるのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの後家めが、私に肩を揉ませるたんびに、変なことを云いかけるので御座います。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……あなたって人は……ほんとに仕様のない人ね」「……ウーン……どうせヤクザモノさ」「だけど……」「何だい……」　私は追いかけるようにこう云いながら心もち冷笑を含んで彼女を見上げた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は現実の彼岸に於て、絶えず生活の掲げる夢を求め、夢を追いかけることに熱情している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と亀田先生がいいかけると、主人らしい人が、「へッ、あなたがあの御有名な亀田鵬斎先生！",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「規矩男さんのお母さんは……」とかの女が云いかけると、「まあ僕の母のことは好いです」と抑えて、「あなたゴルキーの母という小説を読みましたか」「ええ、読んでよ」「あの母は感心というより可愛ゆいな」「ほんとう。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んでいる小さい屋台店が急いで店をしまいかけるのもあれば、どうしようかと判断し兼ねて居るのもある。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やはり、にこりともせず、僕の眼をまっすぐに見ながら問いかける。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "という文句を追いかけるように二人の耳へ送った。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お蔦さんの事よ、」　と言いかける、口の莟が動いたと思うと、睫毛が濃くなって、ほろりとして、振返ると、まだそこに、看護婦が立っているので、慌てて袂を取って、揉込むように顔を隠すと、美しい眉のはずれから、振が飜って、朱鷺色の絽の長襦袢の袖が落ちる。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の附近のバアのラジオは私を追いかけるようにして、いまは八時に五分まえである、台湾はいま夕立ち、日本ヨイトコの実況放送はこれでお仕舞いである、と教えた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蝶ちゃんはいゝなあ、物を考えなくて――」　わたくしはその言葉が不服だったので、「そう見えて、こりゃまた、なんて浅墓な人なの」　と言いかけるのを、池上は押えるようにして、「いや、そりゃ考えるだろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
