    "definitions": [
      {
        "index": 1,
        "gloss": "crawling on the ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い戦記物には、戦場で負傷し、足を失った兵士が地面を躄って味方の陣地へと向かう悲惨な情景が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "民話に登場する病気の老人は、神仏に祈りを捧げるため、遠くの社まで身体を躄らせて参拝したという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深手を負った狼は、最後の力を振り絞るようにして、血の跡を残しながら森の奥へと躄っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地滑りで道が寸断された山道を、人々は大きな荷物を抱えながら、文字通り地面を躄るようにして進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夫婦して小さな躄車のようなものに病人らしい老母を載せて引いて行く、病人が塵埃で真黒になった顔を俯向けている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様を信ずれば盲目が見え、唖が物を云い、躄が駆け出すのだ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが躄勝五郎の物語で有名な初花の滝さ」　少しわき道をして慶四郎は、千歳に滝を見せたりした。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へん、躄の人力挽、唖の演説家に雀盲の巡査、いずれも御採用にはならんから、そう思い給え。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "権現様の出開帳に、お寺の門によたれている、躄ほどにも思わねえか、平気で、私かいッて傍へ来るだ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "文作が足萎え和尚の寝ている方丈の雨戸をたたいた時には、もう夜が明けはなれていたが、和尚が躄りながら雨戸を開けて「何事か」と声をかけると、文作は「ウーン」と云うなり霜の降ったお庭へ引っくり返ってしまった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶世の美人だったが姉妹とも躄だった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はその中をひらひらと躄音もさせずに歩いた。",
              "citation": {
                "source": "月光の下",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、この泊のある財産家の持地でござりますので、仮の小屋掛で近在の者へ施し半分に遣っておりました処、さあ、盲目が開く、躄が立つ、子供が産れる、乳が出る、大した効能。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話によると、明治のずっと初めの比、四国を巡礼している足の悪い遍路が、車を杖で運んでその薬師まで来たが、薬師の霊験のあることを聞いて、そこへ車を停めて祈願を込めていると、数日の後に不思議に足が立ったので、躄車を置いたまま帰って往った。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其の前には、それから三四間程の間をおいて、一人の勢子らしい男が、側に銃をほうり出し、両手を後につき、足を前方に出したまま躄のような恰好で倒れて、眼だけ放心したように虎の方を見据えている。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから帰り途にその非人の処を通りかかりましたが、酔うたマギレの上機嫌で、『最前の味噌チリ喰うたか』　と尋ねてみますと老人の躄の非人が入口に這い出して来てペコペコ拝み上げました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎天を仰いで念ずると鳩が飛んで来て四郎の掌上に卵を産み、卵の中から天主の画像と聖書を出したとか、一人の狂女が来ったのに四郎｜肯くと忽ちに正気に還ったとか、またある時には、道場に来て四郎を罵る者があったが、其場に唖となり躄となった、などと云う。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "褌の掛がえを一条煮染めたような手拭、こいつで顱巻をさしたまま畳み込んだ看板、兀げちょろの重箱が一箇、薄汚え財布、ざッとこれで、身上のありッたけを台箱へ詰め込んだ空車をひいて、どうせ、絵に描いた相馬の化城古御所から、ばけ牛が曳いて出ようというぼろ車、日中は躄だって乗りやしません。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本邦の猴など山野にあれば皆伏行し、飼って教えねば立って行かず、猩々なども身を斜めにして躄り歩く。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼処の流行神様は、躄が歩きだした」「盲目の遍路の目が見えだした」　などと流行神様の噂が村の人の口から口に伝えられる。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、雷ぎらいの人間を雷見舞に遣ろうというのですから、躄を火事見舞に遣るようなもので、どうも無理な話です。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二部興行で、昼の部は忠信の道行、躄の仇討、鳥辺山心中、夜の部は信長記、浪華の春雨、双面という番組も大きく貼り出してある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二部興行で、昼の部は『忠信の道行』、『躄の仇討』、『鳥辺山心中』、夜の部は『信長記』、『浪花の春雨』、『双面』という番組も大きく貼り出してある。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "躄か腰拔けならば知らず、五體滿足の人間がたゞ安閑としてはゐられない時節だ。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様といふのは、ある鉱山師の女房で、その女は何処かで掘出して来たらしい大黒さんを座敷に祠り、そこに引籠つて、躄を立たせたり、一寸した頭痛持を癒したりしてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "口も利かずに黙って腰かけているお島は、ふと女坂を攀登って、石段の上の平地へ醜い姿を現す一人の天刑病らしい躄の乞食が目についたりした。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小娘の手から酔どれの襟首をひったくると、躄車みたいに往来に引き出して行って、そして二人を同時に鉋屑のように抛り出した。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主人は多少異色がある、子供が十人あつたと話す、話す彼は両足のない躄だ、気の毒なやうな可笑しいやうな、そして呑気な気持で彼をしみ／″＼眺めたことだつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "躄になりかかつたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホオヘンツオルレルン家の名相に同情するも、阿部家の躄儒に同情するも、固よりわたくしの自由である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」題の下に自註して躄痿の事を言ひ、遷任の事を言つてゐるが、既に引いてあるから省く。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦行をしてめぐっているうちに盲目の眼があいたり、いざりの脚が立ったり、業病がなおったりした者があると云われている。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるときいざりがめぐっていたのを、うしろから下駄で蹴とばした者があった。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると忽ちいざりの脚が立って、蹴とばした者の脚が立たなくなってへたばりこんでしまったという。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "cripple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
