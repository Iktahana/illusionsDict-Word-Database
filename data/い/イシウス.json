          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの製法で味噌を作るため、祖母は米麹と大豆を大きな石臼で挽いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この蕎麦屋では、風味を最大限に引き出すために、毎朝石臼で蕎麦の実を挽いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遺跡から出土した石臼は、当時の食料加工技術を知る上で貴重な資料となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は自家栽培のハーブを石臼で丁寧にすり潰し、オリジナルのハーブソルトを製造している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、このスパイス、石臼で挽くと全然香りが違うね！」と友人が驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "展示されている石臼は、江戸時代に使われていたもので、当時の人々の食生活を偲ばせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "米粉を作るために、家庭用の小型石臼を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "月もなく、日もなく、樹もなく、草もなく、路もない、雲に似て踏みごたえがあって、雪に似て冷からず、朧夜かと思えば暗く、東雲かと見れば陰々たる中に、煙草盆、枕、火鉢、炬燵櫓の形など左右、二列びに、不揃いに、沢庵の樽もあり、石臼もあり、俎板あり、灯のない行燈も三ツ四ツ、あたかも人のない道具市。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "進まれもせず、引返せば再び石臼だの、松の葉だの、屋根にも廂にも睨まれる、あの、此上もない厭な思をしなければならぬの歟と、それもならず。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の樣子を、間近に視ながら、毒のある目も見向けず、呪詛らしき咳もしないで、ずべりと窓に仰向いて、病の顏の、泥濘から上げた石臼ほどの重いのを、ぢつと支へて居る病人は奇特である。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あの、黄金白銀、米、粟の湧こぼれる、石臼の重量が響きますかい。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御褒美に遣わさるる石臼なれば可けれども＝＝この坊主を輪切りにして、スッポン煮を賞翫あれ、姫、お昼寝の御目覚ましに＝＝と記してあろうも計られぬ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と口も気もともに軽い、が、起居が石臼を引摺るように、どしどしする。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでお千代も石臼につらまって、一所にウツラウツラしいしい加勢をしていたが、そのうちに四時頃になって夕蔭がさして来ると、山芋をドッサリ荷いだ亭主の金作が、思いがけなく早く、裏口から帰って来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっくらな家の中を、人々は盲のように手でさぐりながら、水甕や、石臼や大黒柱をさぐりあてるのであった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "進まれもせず、引返せば再び石臼だの、松の葉だの、屋根にも廂にも睨まれる、あの、この上もない厭な思をしなければならぬの歟と、それもならず。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此集では各処に散らかつてゐるが、「茶の煙」の中の「鈴蘭」「沙羅の木」「冷たき微笑」「雪の翅ばたき」の中の「霰と雀」「石臼と杵」「現身」等である。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんはその実を隅の石臼の処へ持って往ってそれを入れて挽いた。",
              "citation": {
                "source": "蕎麦餅",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢の好い蒼白い光が燃えて、豆をひく石臼や豆腐釜などを照らした。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水から一坂上り口に、薪、漬もの桶、石臼なんどを投遣りにした物置の破納屋が、炭焼小屋に見えるまで、あたりは静に、人の往来はまるでない。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石臼に縋って、嫁菜の咲いたも可哀である。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　時に青空に霧をかけた釣鐘が、たちまち黒く頭上を蔽うて、破納屋の石臼も眼が窪み口が欠けて髑髏のように見え、曼珠沙華も鬼火に燃えて、四辺が真暗になったのは、眩く心地がしたからである。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おすがの家には土藏まであるがそれでも日常は石臼で挽いた麥を交ぜた飯をたべて居る。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つ又はくゞり戸開けてはひるとすぐに石臼へ手を貸した。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "石臼はぐる／＼と輕くめぐる。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「當てにもしねえ傭が出來ておれは此れだからうめえな」　と卵屋も相槌打つて勢よく然かもそろ／＼と石臼をめぐす。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "石臼は其儘幾つかごろ／＼とめぐして此れで蕎麥挽はやめた。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「篩ふなあしたでもえゝんでがすから」　とお袋は石臼臺の粉を桶へ移して筵を掛ける。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "船体の危険と、船体と共にする自分自身の危険と、そして、てきめんに自分の凍えんとする肉体に対する危険とは、火事が中風の婆さんに、石臼を屋外まで抱え出させたほどの目ざましい、超人間的な活動を、水夫たちに与えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌はやはり石臼をまはすと同様に上体を動かせてゐないと調子がつかぬと見えて、おかくは粉ひきの物腰でいつまでも歌つてゐるのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして子供が再び眼を醒しても相変らず石臼をひいて歌つてゐるのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球が始まつてからながいだが僕が見た地球は全く新しい、青年が老いてゆく――そんな馬鹿なことがあるものか若い人よ、わが友よ、薔薇よ石臼のやうな歯をもつた人よ、ばりばりと歯を鳴らせ。",
              "citation": {
                "source": "小熊秀雄全集-10",
                "author": "詩集（９）流民詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "英蘭とスコットランドの境部諸州の俗信に、パウリーヌダンターは古城砦鐘樓土牢等にある怪で、不斷亞麻を打ち石臼で麥をつく樣の音を出す。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうですね、八十貫は充分ありましょう……大きな石臼みたいですよ……そいつがジリジリ下まで降り切ってしまうと、また捲き上げるんです」「なるほど、最近捲き上げたのはいつですか？",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはお歯黒をつけるには必ず必要の五倍子の粉を売っていた店で、店の中央に石臼を据えて五倍子粉を磨っている陰陽の生人形が置いてあって人目を惹いたもの、これは近年まで確かあったと覚えている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "城内から大きな沢庵石――は、ちと可笑しいから、大きな石臼を見つけてきて、これを目の上よりも高くあげて、寝台に睡る妖婆の頭の上にドーンとうちつける。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
