        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この資料の*一覧*を見れば、全体像が把握できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "商品の*一覧*から、欲しいものを選んでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "設定項目の*一覧*が表示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "心慧思霊の非常の英物で、美術骨董にかけては先ず天才的の眼も手も有していた人であったが、或時｜金※から舟に乗り、江右に往く、道に毘陵を経て、唐太常に拝謁を請い、そして天下有名の彼の定鼎の一覧を需めた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからワイナハトマンが袋をかついで出て来ておどけて笑わせて、それで式が済みお客さんはみんな別室へはいって、ここへ陳列した子供への贈物を一覧するわけでした。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名刺を通じて古宝物の一覧を請うと、宝物は火災をおそれて倉庫に秘めてあるから容易に取出すことは出来ない。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝物一覧を断られたのもこれがためであると首肯かれた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「普通の茶会だったら、これから炭手前の拝見とか、香合一覧の事などがあって、それから、御馳走が出て、酒が出て、それから、――」「酒も出るのですか。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雑誌の、八月上旬号、九月下旬号、十月下旬号の三冊を、私は編輯者から恵送せられたのであるが、一覧するに、この雑誌の読者は、すべてこれから「文学というもの」を試みたいと心うごき始めたばかりの人の様子なのである。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて村丸贔屓の城主荒木は、このたびもまた笑って、よろしい、蝦夷一覧もよかろう、行っておいで、若い頃の長旅は一生の薬、と言って事もなげにその我儘の願いを聞き容れてやった。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つてＮ君は或る本をひらいて私に見せたが、そのペエジには次のやうな、津軽凶作の年表とでもいふべき不吉な一覧表が載つてゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心慧思霊の非常の英物で、美術骨董にかけては先づ天才的の眼も手も有して居た人であつたが、或時｜金※から舟に乗り、江右に往く、道に毘陵を経て、唐太常に拝謁を請ひ、そして天下有名の彼の定鼎の一覧を需めた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそれよりも、真珠の首飾見たようなものを、ちょっと、脇の下へずらして、乳首をかくした膚を、お望みの方は、文政｜壬辰新板、柳亭種彦作、歌川国貞｜画――奇妙頂礼地蔵の道行――を、ご一覧になるがいい。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こいつは仕入れ先の一覧だ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう、これがこの街にある仕入れ先の一覧だ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『けれど、職業別一覧があるんじゃあ？",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりやって月曜の一二時までに一覧をいただければ。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言うと、『では今度は、』と相手は言って、『家具商の一覧を作っていただきたい。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蓋の内側に張り紙があって、またもや大文字でＫＫＫ、その下に『手紙・控え・受取・一覧』とあります。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでわかったろう、この一覧と日記は南部の顔役の幾人かを結びつけるもので、これが見つかるまで夜もおちおち眠れない連中が大勢いるのだ。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「懐の遺留品について、もう一覧はありますね、警部。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　馬車が正面観覧席近くの特別区域に停まると同時に、出走表へ目をやると次の一覧が見えた。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一覧して遺すなきは、すなわちかつてこれあり。",
              "citation": {
                "source": "失うた帳面を記憶力で書き復した人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、処で、矢を貫いた都鳥を持つて、大島守｜登営に及び、将軍家一覧の上にて、如法、鎧櫃に納めた。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この作品を入力したいのだけれど、作者の著作権は切れているだろうか」という問い合わせも、繰り返し寄せられていたため、作業マニュアルに合わせて、「著作権の消滅した作家名一覧」と名付けたリストを用意した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際電話をかけるたびに「あそこの国番号は何番だ」とわめき散らす必要ももはやなく、静かにカントリー・コードの一覧表のウインドウを一つ開けば良いではないか、と考えたのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は初め怪しみ、遂には恐れて、こは狂人なるべし、狂人を紹介せる嘉悦氏もまた無礼ならずやと、心に七分の憤りを含みながら、なお忍びに忍びて狂人のせんようを見てありしに、客は忽ち慚愧の体にて容を改め、貴嬢願わくはこの書を一覧あれとの事に、何心なく披き見れば、思いもよらぬ結婚申し込みの書なりけり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、マア坊の小さい誇りをいたわるために、一覧しなければならぬ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『諸社一覧』八に『太神宮神異記』を引いて、豊太閤の時朝鮮人来朝せしに、食用のためとて太神宮にいくらもある鶏を取り寄せ籠に入れてあまた上せけるに、ほどなく皆返さる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の菜の当てッこをしたり、昼の菜の一覧表をつくったり、そんなことも消閑の一策になっている。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰山前に頽るるともビクともしない大西郷どんさえも評判に釣込まれてワザワザ見物に来て、大に感服して「万国一覧」という大字の扁額を揮ってくれた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイプ印刷のパンフレットには、各クラブの一覧、担当教師名、活動の内容が書かれている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
