      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "deadlock",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "OSにおいて、複数のプロセスが互いに排他ロックを保持し、他方の解放を待つことで発生する行き詰まりは、システム全体の応答を停止させることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "データベースのトランザクション処理では、行き詰まりを回避するためにタイムアウト設定やデッドロック検出機構が重要となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国際的な貿易交渉は、保護主義的な措置を巡る意見の対立から、打開の糸口が見えない行き詰まりに陥っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい研究開発テーマは、初期段階で予想外の技術的行き詰まりに直面し、プロジェクトの遅延が懸念されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人生の岐路に立ち、どの道を選ぶべきか決めかねて、深い行き詰まりを感じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長引く不況で、多くの企業が新たな事業展開の行き詰まりに悩まされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このままでは本当に行き詰まりだよ。何か良いアイデアはないの？」と彼は焦った様子で尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "で、性急な批評家の或る者は氏の芸術の硬化や、行き詰まりを云為してゐる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくもあるところまで進んで来て行き詰まりになっている考えに新しい光を投げ、新たな衝動を与える何物かを発見する事は決して珍しくはあるまいと思うのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアインシュタインやド・ブローリーがルクレチウスを読んだであろうとまでは思わないが、彼らの仕事に最初の衝動を与え幾度か行き詰まりがちの考えに常に新しい活路を与えたのは、私に言わせれば彼らの頭の中にいるルクレチウスのしわざである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろそういう研究を奨励することが学問の行き詰まりを防ぐ上に有効でありはしないか。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう時代において、それ自身だけに任せておくととかく立ち枯れになりやすい理論に生命の水をそそぎ、行き詰まりになりやすい抽象に新しい疎通孔をあけるには、やはりいろいろの実験が望ましい。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在世界じゅうの学者が争って研究しているような問題が、やがて行き詰まりになるであろうということは当然の事でもあり、また過去の歴史がことごとくこれを証明しているように思われる。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本当面の非常時、政治的不安や経済的行き詰まりにいよいよ恐慌を増して来ましたこの頃では、金融は全く逼塞してしまいましたので、日本の大多数の人々は、その命つなぎの金にさえ不自由する有様に立ち至っております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど商売が行き詰まり、母の手元は苦しかったが、それはその時々の食糧や小遣になる零細な金で、銀子は月々の親への仕送りで、いつも懐ろが寂しく、若林からもらう金も、大部分親に奉仕するのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまで広からぬ道は片割月の下近く、山畠の傍なる溜池のほとりに行き詰まりつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその国産品の氾濫も最早、行き詰まりかけているのではあるまいか。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆の読書趣味が行き詰まり初めたようである。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば象徴、写実、又は印象派、未来派、感覚派なぞいう、あらゆる芸術表現の行き方を、それと名は知らないままに色々と試みては行き詰まり、行き詰まっては又新しく試みる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に謡が美しく行き詰まりつつ消えて行く。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "デカダンの非道いのになると、腐りのまわった捨てものが一番いいなぞと云い出す位で、どこ迄行っても男性の良心は行き詰まりませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝展派の画家の行き詰まりと、最も進歩的でなければならない筈のプロレタリア・リアリズム画家の行き詰まりの状態に相似点のあることは、この種の客観主義者が多いからである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の道が行き詰まりになったら第二の道へ、――第二の抜け道がまたぷつりと絶えたら第三の裏道へ、それまではまず英気を養ってというように八丁堀へ帰って寝て待っていたが、どうしたことかその伝六の帰りが長引きました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう、そう思いますと一緒に、私の運命が眼の前で行き詰まりかけておりますことがアリアリとわかりました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですからその名前は申し上げられませぬ」「では貴方はその名をどうして御存じですか」　紅木公爵夫人がこう尋ねますと、青眼先生はグッと行き詰まりました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの競争もある程度まで行くと、行き詰まりになるのは止むを得ない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義がきまりきった所だけの利潤では行き詰まり、金利が下がって、金がダブついてくると、「文字通り」どんな事でもするし、どんな所へでも、死物狂いで血路を求め出してくる。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの傾向は、探偵小説の行き詰まり、早老を予感せしめる徴候の一つではないかと私は考える。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの位置で、斯う南を指して来たならば此処がもう陸の行き詰まりかと思つてゐたが、これでは未だ後七哩ちかくまでも走らなければ、南を指す陸の尽きるところへは達しない――そんな馬鹿なことを思つて、変に考へ込んだりしてしまつた。",
              "citation": {
                "source": "駆ける朝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新派はかえって行き詰まりの形になって来た。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しい数は記憶しておりませんが、大体の見当は鋼や油は年額数億トン、石炭に至っては数十億トンを必要とすることとなり、とても今のような地下資源を使ってやるところの文明の方式では、二十年後には完全に行き詰まります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "白色人種は、物質文化の行き詰まりを一面に於て唱えながらも、これを刷新せんとする彼らの案は、依然として寒帯文明の範疇を出ることができない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋文明は既に覇道に徹底して、みずから行き詰まりつつある。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしドイツ軍部もこの頃は国防の根本に対する熱情が充分でなく、ややもすれば行き詰まりの人事行政打開に重点を置いて軍拡を企図した形跡を見遁す事が出来ない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義のいきづまりが愈々増々顕著になって来たこの三四年来、物理学の危機が特別に喧伝されるということは、だから決して偶然ではない＊。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
