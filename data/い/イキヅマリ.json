[
  {
    "uuid": "0f418a41-036a-5b23-bd32-966cfe5a7b41",
    "entry": "行き詰まり",
    "reading": {
      "primary": "いきづまり",
      "alternatives": [
        "ゆきづまり"
      ],
      "is_heteronym": false
    },
    "grammar": {
