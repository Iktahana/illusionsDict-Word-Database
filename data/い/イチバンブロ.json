          ],
          "literary": [
            {
              "text": "……ちゃんと、こら、俺れゃ、一番風呂に失敬してやった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長岡散歩、入浴、一番風呂で気持がよかつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はまた湯屋で、ほんたうの一番風呂だつた、湯加減もよかつたので、たつたひとり、のび／＼と手足を伸ばした気持は何ともいへなかつた、殊にそこの噴井の水はうまかつた、腹いつぱい飲んだことである。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見ははからずも一番風呂の贅沢を独占する。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は運動がてら、氣晴らしにもなるし、毎日下町まで往復するのは何でもなかつたので、湯屋の戸の開く時刻を見計らつて、少しくらゐ戸口に彳んで待つてゐても、一番風呂に入るのを一日の樂みにしてゐたが、妻に取つては、湯屋通ひは厄介であつた。",
              "citation": {
                "source": "水不足",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
