        "examples": {
          "standard": [
            {
              "text": "顧客情報の不正利用は、重大な違法行為にあたる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業は従業員に対し、違法行為に関わらないよう徹底した研修を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの政治家は、選挙期間中に複数の違法行為を働いたとして告発された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――伯爵の違法行為がそんな大仰な一種の告発に値しないことをいったのではなく――民衆にむすびついた伯爵の勢力から見て、そのような告発が危険を招くことを説明したのだった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺ということは、未知の世界に対する一種神秘的な違法行為であり、ある程度まで魂の死を含み得るものであって、ジャン・ヴァルジャンにはなし得ないことだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、絶対に誰にも言わせません、未来の義父が違法行為で競馬場出入り禁止になったなんて」「違法行為だと、フィールデン君、狂ったな、説明しろ」「狂っていません。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥ずべき事ですが、そのような女性が悪党の違法行為によって選ばれたのです」「令夫人は誰にもおっしゃらないのですか。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
