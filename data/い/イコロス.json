          ],
          "literary": [
            {
              "text": "病犬を射殺するやや感傷的な場面がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きた犬を放つて馬の上から射殺す、この犬追物の遊技は、鳥右ヱ門の何より好きなもので、三日に一度は、必ず館の庭で、自分一人で練習をしました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "練習とはいつても生きた犬を射殺すので、三日に一匹づつどこかで犬を探し出して来なければなりませんでした。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "張はそれを見るとこれは己を外へ伴れ出して、射殺すではないかと思いました。",
              "citation": {
                "source": "人蔘の精",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえて日光をあびせてもてこの憐むべき貞婦を射殺すなかれ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "李如梅の如きは、金甲の倭を手ずから射殺すと云うから、日本軍の一隊長と渡合って之を倒しているわけである。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの情景では、士官達が短銃で農民を、面白半分に射殺するのです。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に名のらなかったら、おれは機関部第二分隊長の実力をもって、貴様を射殺する」　ピストルを握ったフランク分隊長の右手は、わなわなとふるえていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、今、この男を射殺すると、あとはどうなる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーマーの詩「オヂツセー」の中には、ユリツシーズがアイラスに矢毒を要求することが書かれてあり、希臘神話の中にもパリスが毒箭を放つてアキリーズを射殺すことが述べてある。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば倉庫は心臓で、これを破れば多数人の集合体である軍隊の破滅を来たすからである」と断定し、戦闘についても歩兵は唯射撃するのみ、射撃が万事を決する、精神上の事は最早大問題でないと称し、「現に子供がよく巨人を射殺することが出来る」と述べている。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどナニ貴方が正直にさえ仕て居れば、必ず射殺すと云う訳でもないから」余「では有体に云いますが、貴方に少し話が有るから、外の人に妨げられぬ様に此の室の戸を閉じなさい」余「鍵は何所にありますか」穴川「鍵は其の戸に附いた儘で有る筈です」成るほど錠前の穴へ填った儘である。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対説の大要は、鳩は平和と穏順の半神的象徴であるのに、それを冷たい血において射殺するのは狂気に近いというのである。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "場合によっては、射殺するも已むを得ない。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "退かないと射殺すぞ」　遠藤はピストルを挙げました。",
              "citation": {
                "source": "アグニの神",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "退かないと射殺すぞ。",
              "citation": {
                "source": "アグニの神",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して語られざる哲学にとっては、生活を改造しない知識、現実を支配しない理想は、音ばかりして決して射殺することができない弾丸が猟夫にとって無意味であると同様に無意味である。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十人の所番地を襲って、もちろん射殺するだけ。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これが又右の手には小銃を持ち、左の手にはピストルを持って一時に二人射殺すと言う、湖南でも評判の悪党だったんだがね。",
              "citation": {
                "source": "湖南の扇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その神の矢がどこへ飛び去っていつ何者を射殺すか、それは神霊のお心である。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがはいの、いうことをきかない者は、たちどころに射殺する。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "出さねば、一人一人、射殺すぞ、それ、者ども」　と側近の者達を顧みると、佐藤三郎、四郎兄弟、武蔵坊弁慶などの名だたる面々が、今にも弓を引きしぼるかのように、「ご命令じゃ、早くいたせ、背く者は、これで、いちいち射殺すぞ」　とにらみつけた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、答えられないで黙っていますと、実に女々しい不愉快きわまる、今後来るのはことわる、そう言ってニヤニヤして、テーブルの引出しからピストル取り出して、又来たら、これで射殺すると、僕にねらいを附けるような恰好をして、又笑いました。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰気な、外の人間の裡にある快活さや、率直さを一目で射殺すような正隆の眼を見ると、一人として、元の明快な気持を保っていることが出来なくなる。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はシシリヤ人が乗込んで来たら相手を夜中にナイフで刺殺すか、または垣の後から射殺するかして、どっちにしろ一言も音を出さぬように殺すに相違ないと信じておった。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手をわけなく片付けるほうがはるかに容易であるのに、さあ射殺するぞという様子ばかりをしてみせるのは、この上もなく馬鹿げたことだと知っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "動くと射殺するぞ※」　がんと喚きながら進出たのは、老紳士とみせた警視庁の高野刑事課長だった。",
              "citation": {
                "source": "亡霊ホテル",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆気に取られて暫くは口も利けなかった船長は、急に穴の入口へ近づくと、「出て来い、武器を捨てて出て来い、少しでも反抗すると射殺するぞ、早くしろ」　と喚きたてた。",
              "citation": {
                "source": "流血船西へ行く",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というて、それに不適な才能をむりに持って来ても、これは当人の天性をつかいころすことになるからな。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
