[
  {
    "uuid": "26d8096d-4a1b-5514-a4a2-c0047a7264ea",
    "entry": "隠語",
    "reading": {
      "primary": "いんご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
