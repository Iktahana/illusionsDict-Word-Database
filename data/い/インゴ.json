  {
    "uuid": "59622fbc-3419-5e92-a35f-a87394fa90f4",
    "entry": "淫語",
    "reading": {
      "primary": "いんご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
