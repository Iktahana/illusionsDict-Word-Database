    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indecent language",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は後に財宝と淫語とに関する言説において、悪しき例として建仁寺を引いている。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、最近ではすっかりいんごう親父のあしらいを覚えたＹ子は「ラップランドが冷え込むプログラミング日和になりましたね」と訳のわからないことを言うばかりで、取り合おうとはしない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は此方に来る前手紙で、今小田原のＫ病院に入院してゐるが、未だに実家への帰参が許されないで閉口してゐる、親父や阿母は何でもないんだが、兄貴の奴がとても頑張つてゐて始末に終へない、親父は君も承知の通りあゝいふ優しい人で、在れども無きが如き存在だが、いんごうなのは兄貴だ。",
              "citation": {
                "source": "スプリングコート",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩にもならず実に当惑して居た処に、同船中、下ノ関の商人風の男が出て来て、乃公が請合うと先ず発言して船頭に向い、「コレお前も爾う、いんごうな事を云うものじゃない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "（言いながら、五十フランを出して、おかみに渡す）ルノウ　いんごうなことを言ったようで、すみませんねえ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座のいんごうやへ橘夫妻も共に行き、いつものビフテキと気の抜けたライスカレーを食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時に道子同道、中泉眼科へ寄り、いんごう家へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の座談会の定食がわりに美味かったから、夜の五円のならいゝだらうと思ったのに、これが少量で全く満腹しないので、有志即ち僕・女房・橘の三人だけ、いんごう家へ、ビフテキとライスカレーを食ひ、橘のとこへ戻り、古風なる二十一といふ遊びを十時近く迄やり、甚だ当るので気持よかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲテ洋食をついでに拾ふと、これはゲテ中のブルジョワだが、　いんごうや――ビフテキと子供だましのライスカレー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で銀座へ出て、いんごうやのビフテキ、一っそうまい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪へ出発の日、十二時に家を出て、銀座のいんごうやへ、母上と食事、此処のビフテキもうまくなくなった、それに右の奥歯が痛くて困った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こらッ、そんな天秤棒など下ろさんか」「いんごうな兵隊さんだね。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
