    "definitions": [
      {
        "index": 1,
        "gloss": "half-sister (younger, different mother)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父の葬儀で初めて会った異母妹は、どこか私と似た面影を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "遺産相続の話し合いの席で、突然見知らぬ異母妹が名乗りを上げて親族は騒然となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "異母妹の結婚式に招待されたが、複雑な家庭環境もあって参列すべきか悩んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "異母妹のナターリイは、老人の死骸に打倒れて泣いた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お艶にはなお、これが伯母だとか義姉だとか異母妹だとか、他人を勝手に引張って来て勝手にそう思い込み、そう思い込むが最後、その通り肉身の気持になれる幾人かの女性がある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かというに九年も前の話だから……しかも十七ばかりに成る、妹のような娘から、唯一度の接吻を許されたのだから……　その娘は腹違いの妹の学校友達で、お新と言って、色の黒い理窟好な異母妹とは大の仲好だった。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑中休暇で娘達も家に居る頃で、毎日のようにお新は異母妹の許へ遊びに来た。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "異母妹とお新とは、互に堅く腕を組合せて、泡立ち流れる潮の中を歩いたことを思出した。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は娘達の髪はまだ赤かったが、でも異母妹から見ると、麦藁帽子を脱いだお新の方は余程黒かったことを思出した。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもお新は異母妹と一緒に、度々旅舎へ遊びに来たが、彼の方では遠くでばかり眺めていた。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人の側に、山本さんは遠慮勝に腰掛けて、往時お新や異母妹と一緒に菖蒲田の海岸を歩いた時の心地に返った。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろ子の最終の目的は、財産を自己一人の手に入れることと、異母妹さだ子らに対する烈しい嫉妬をはらすことである。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰つて来ると、私は、その時まだ十八だつた異母妹の弓子を連れて、毎日裏の山へ登つたり、川口にある貸ボートを借り切りにして海に降つたり、川をずつと上流の方まで漕いだりして遊びまはつてゐた。",
              "citation": {
                "source": "鬼神",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様子をみてゐると、忍の異母妹で弥生といふ十九の娘が草吉の住居に同居してゐるのであつたが、当太郎はその娘に気があるのだといふことが人々に判つた。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥生とよぶ十七才の異母妹を連れてゐた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵とは対い合いに、お民の隣には仙十郎の妻で半蔵が異母妹にあたるお喜佐も来て膳に着いていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉左衛門ももう杖なぞを手にして、新たに養子を迎えたお喜佐（半蔵の異母妹）の新宅を見回りに行くような人だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ来た新宅のお喜佐（おまんの実の娘、半蔵の異母妹）には宗太をつけて、これも家の下女たちと一緒にやることにした。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宅（下隣にある青山の分家、半蔵が異母妹お喜佐の旧居）も貸すことにしたね。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "異母妹は衣子と云った。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり三千子はあの晩、恋敵の異母妹といい争った末、激情のあまり、ついあんなことをしてしまった。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "義母や異母妹たちの気持もあります。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
