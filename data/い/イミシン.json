[
  {
    "uuid": "cdbb6923-6bce-51aa-bd8e-6c28055ab7ef",
    "entry": "意味深",
    "reading": {
      "primary": "いみしん",
      "alternatives": [
        "いみぶか"
      ],
      "is_heteronym": false
    },
    "grammar": {
