        "index": 1,
        "gloss": "chief for the day (PR event in which a celebrity heads a police, fire, etc. department for a day)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
