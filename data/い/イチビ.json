          "literary": [
            {
              "text": "市日丹藤に越ゆるみかげ尾根、　　うつろひかればいと近し。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎では鎮守の祭りや市日の売店があった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、かくなる上は今市日光間の四｜哩を汽車で行こうということになった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと月ほどあとの、ある日、丘の上に、忠犬の銅像ができあがったというので、村人たちは市日のように、いそいそと、丘の上にあつまっていきました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、市日や祭日にはいてるばかりでは、木ぐつもなかなか、すりへるものではありません。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "機織たちの市日が賑って女の眼につく縞柄が無雑作に車に投げ積まれています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "町は市日で、近在から出た百姓がぞろ／＼と通つた。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理屋に三味線の音が夜更けまで聞こえ、市日には呉服屋唐物屋の店に赤い蹴出しの娘をつれた百姓なども見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊夫君が震える手をもって、受け取った名刺は、歯科医　大村貞三　東京市日本橋区蠣殻町三丁目　右のごときものでありました。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私はそれを買いに市日ごとに市場に遣わされた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "市日の朝、私は、何か他の用事にかこつけて庭先の米倉へ這入った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月一と五の日はＡ町の市日で、近郷から種々の産物を売りに来たり買ひに来たりするので非常に賑かである。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平三の村からは毎日商人が生魚を売りに来て居るが、市日になると買物｜旁々塩魚を売りに来る人が随分多い。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日も丁度其市日にあたるので町は随分の人出であつた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老い萎えている町の呼吸が、この市日で、微かに保たれているようである。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五城目の市日」といえば、昔から、この近郷の人々が寄り集う慣わしであった。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶらやのお父さんもお父さんだが、お母さんの締まることったら、鶏さやる餌をな、市日の終ったあとさ籠こ持たせて拾わせにやるってさあ」「それで税金の方は誤魔化そうとしているし、町会さ当選した時だって、酒こ二升しか買わねえってな。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山姥が市日に来て大食をした話や、小袋に限りなく物を容れて帰つた伝説は、其から起つたと思ひます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下関の村は、月六斎の市日の一つに当る日で、賑うて居た。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山人・山姥が市日に来て、大食をした話し、無限に這入る小袋にものを詰めて行つたと言ふ伝説は、さうした、山人が里のものをたくさんに持ち還つた記憶があつて出来た話しだと思ひます。",
              "citation": {
                "source": "門松のはなし",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、年の暮れ、山の神が刈り上げ祭りに臨む日が、古式の市日であつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山人は、山の神人であり、山の巫女が山姥となつて、市日には、市に出て舞うた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山人の携へて来るものが、山づとと呼ばれて、市日に里人と交易せられた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、市日と、宮廷・豪家の祓へに臨む時だけは、山蘰を捲き、恐らく、からだ中も、山の草木で掩うてゐた事があるのだらう。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "市日に山姥の来て、大食をした話や、小袋に限りなく物を容れて帰つた伝説などがあるのは、鎮魂の夜の山づとと取り易へて、里の品物、食料などを多く持ち還つたからでせう。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、山人・山姥が里の市日に来て、無言で物を求めて去つた、と言ふ伝説の源でもある。",
              "citation": {
                "source": "山のことぶれ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝから二十二マイルばかり、馬でなら、半時間かゝる、隣りの町の市日に、私をつれて行って、ひとつ見世物にするがいゝ、と、彼は主人にすゝめたのです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は友達の意見にしたがって、私を箱に入れて、次の市日に隣りの町まで運んで行きました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "市日がすんで、私たちは家に戻りましたが、主人はこの次の市日にも、またこの見世物をやるという広告を出しました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様はいちいちびっくりして、目を丸くして聞いておいでになりました。",
              "citation": {
                "source": "姨捨山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
