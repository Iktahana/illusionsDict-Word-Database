    "definitions": [
      {
        "index": 1,
        "gloss": "Isaiah (book of the Bible)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "神学ゼミで、学生たちはイザヤ書第53章の「苦難のしもべ」について深く考察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "聖書学者による新たな研究は、イザヤ書における預言の解釈に一石を投じるものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "合唱団はヘンデルの「メサイア」を練習中だが、その歌詞の多くがイザヤ書から引用されていることを知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、困難な状況に直面したとき、イザヤ書の言葉に慰めを見出すことがよくあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術館の特別展では、古代写本の中にイザヤ書の一部が展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "教会の日曜礼拝で、牧師はイザヤ書の一節を引用し、希望のメッセージを語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学の文学の講義で、教授はイザヤ書が西洋文学に与えた影響について解説した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（イザヤ書三五章一―二節）　今日は少しこの世のことについてお話しいたそうと欲います。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "イザヤ書の如きは、その第五十三章の救主予言を以て光明の絶頂に達したのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにこれを以てイザヤ書は終らずして、六十六章まで続いている。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "(10) 以賽亞書：　イザヤ書。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "(9) 以賽亞書：　イザヤ書。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三七・一一・二五）　　　　　参考書のたぐい田中智学　大国聖日蓮聖人清水竜山　日蓮聖人の生涯山川智応　日蓮聖人伝十講有朋堂文庫　日蓮聖人文集室伏高信　立正安国論高山樗牛　日蓮とはいかなる人ぞ姉崎正治　法華経の行者日蓮倉田百三　祖国への愛と認識ニーチェ　ツァラツストラ如是説旧約聖書中のイザヤ書。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の部分はイザヤの言ではなく、その後二世紀を経てバビロン捕囚の国民的悲運を経験した時代に、或る名の伝わらない預言者の宣べた言であって、其後更に二世紀｜経ってイザヤ書が今日の形に編輯せられた時、その編輯者がイザヤ書預言の最終曲として此処に収載したものである。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イザヤ書の中にはイザヤの言は勿論であるが、彼よりも後代の無名の預言者の言も含まれて居り、又編輯者の信仰も籠って居る。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "このイザヤ書の最終曲は世界審判（三四の一―四）、エドムの刑罰（三四の五―一七）、並にイスラエルの復興（三五）の三部より成る。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "このイザヤ書第三十五章は荒野とうるおいなき地とはたのしみ、　沙漠はよろこびて咲き出でる。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "バビロン捕囚といふ悲運の中からかかる希望の声を挙げた人、又この詩を最終曲としてイザヤ書を編輯した人は、実に大きな信仰をもった人と思う。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時代にイザヤ書の編輯者が出て之を国民に送り、神の審判を学ぶべきことを教えたのである。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十六章―三十九章は大体列王紀略下並に歴代志略下の記事をばイザヤ預言の附録として掲げたものであるから、此の部分は省略することとして、イザヤ書講義は以上を以て終り、同時に帝大聖書研究会は今日を以て解散する。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イザヤ書の講義も今日でおしまい、同時に此の会もおしまいである。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めの数回は『科学と宗教』等学問的なる問題について講演したが、十一月以後ロマ書の講義をし、本学年はイザヤ書の講義をして来たのである。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し私はまだ本当に辞めた様な気持になれず、且つイザヤ書の講義は途中であるから、私が此処で聖書の講義を続けて行くことは、当然過ぎる程当然の気持がしていたのである。",
              "citation": {
                "source": "帝大聖書研究会終講の辞",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしイザヤ書第五十三章は、恥辱の死をとげるキリストを明白に預言している。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の「荒野に呼ばわる者の声す、『主の道を備えその道筋を直くせよ』」というのがイザヤ書四十章三節の言葉です。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルコはマラキ書の言とイザヤ書の言とを一緒にして、イザヤ書からの引用として掲げました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "イザヤ書に「わが扶くるわが僕わが心悦ぶわが選び人を見よ、我わが霊を彼に与えたり、かれ異邦人に道を示すべし」（四二の一）、また「見よわが僕知恵をもて行なわん」（五二の一三）、等とあるごとく、神に選び出されて神の言を託されし者は「僕」と呼ばれている。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "イエス御自身、譬話をもって語られることの理由を弟子たちに説明せられた中に、イザヤ書第六章九節十節を引いて「これ見るとき見ゆとも認めず、聴く時聞こゆとも悟らず、ひるがえりて赦さるることなからんためなり」と言われました（四の一二）。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　火をもて塩つけよ　イエス様は「ゲヘナの消えぬ火」の怖るべきことについて、イザヤ書第六十六章二十四節を引用して「彼処にてはその蛆つきず、火も消えぬなり」と語り給いましたが、その「火」という言に関連して、それ人はみな火をもて塩つけらるべし。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一一の一七）「もろもろの国人の祈りの家」というのは、イザヤ書五十六章からの引用です。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "イザヤ書十一章一節にエッサイ（ダビデの父）の株より一つの芽いで、その根より一つの枝生えて実を結ばん。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一四の四八、四九）　これはイザヤ書五十三章や、ゼカリヤ書十三章七節等を連想して言われたのでしょう。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし記録は明確でなく、幼児はイザヤ書のイスラエル人のように追い払われてしまった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
