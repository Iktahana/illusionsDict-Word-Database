    "definitions": [
      {
        "index": 1,
        "gloss": "country-bred",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は田舎育ちなので、満員電車と人混みはどうも苦手です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "山道を平気で駆け上がるなんて、さすが田舎育ちの健脚だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女の洗練されたマナーからは、田舎育ちだとは誰も想像できないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「田舎育ちだから、虫は全然平気だよ」と彼は笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "とにかくこの生まれて始めて味わったコーヒーの香味はすっかり田舎育ちの少年の私を心酔させてしまった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも鳥のことで賭をしているのだが、五ポンド賭けていい、僕の食べた鳥は、田舎育ちだ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな方が田舎育ちの娘などを眼中にお置きになるものですか」　と妻は言った。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "了意の『東海道名所記』に「大きなる赤犬かけ出てすきまなく吠えかかる云々、楽阿弥も魂を失うて俄に虎という字を書いて見すれども田舎育ちの犬なりければ読めざりけん、逃ぐる足許へ飛び付く」とある。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎育ちの者かかる美女に手を握られた嬉しさ心魂に徹し、屋敷へ帰っても片時も忘れず。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のその目篇がちときびしすぎてな、江戸の女共を喰いあきたせいでおじゃるのか、それともまた田舎育ちの土女共が味変り致してよいためでおじゃるのか、どちらがどうやら存ぜぬことじゃが、所労保養のお暇を願ったとやらにて、ぶらりとこの月初めに知行所へお帰り召さったのじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり心持のいい役ではありませんが、根が田舎育ちでございますから、わたくし共が考えるほどには蛇や蛙を怖がりもいたしません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ俺は、田舎育ちの野暮な人間である……」「…………」　何を云つてゐるのか、と周子は思つた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この田舎育ちの子供が独りでぽつぽつ帰って行く日にはおげんはお新と二人で村はずれまで見送った。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三も田舎育ちだけに、大きい景勝よりも、こうしたひそやかな自然に親しみを感じた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくせきの場合だから細君が虚栄心を折って、田舎育ちの山出し女とまで成り下がって、何年の間か苦心の末、身に釣り合わぬ借金を奇麗に返したのは立派な心がけで立派な行動であるからして、もしモーパッサン氏に一点の道義的同情があるならば、少くともこの細君の心行きを活かしてやらなければすまない訳でありましょう。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京下町に生れ、水商売もやつてきたお定さんであるから、山の手の人や田舎育ちの人とは違つてゐるのが当然だが、東京の下町では最もあたりまへな奇も変もない女のひとで、むしろ、あんまり平凡すぎる、さういふ感じである。",
              "citation": {
                "source": "阿部定さんの印象",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も持ち前の商才にたけてはいたが、田舎育ちのために、性格に反して大事をとり、手堅い商法からハミだす勇気を失っていた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、都会っ子ねえ、そうでしょう」　私は、私も田舎育ちであり、そこも又、白砂だったことを告げた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎育ちの一人娘で甘ったれて育ったせいで、彼女は終戦を迎えるまで歯をみがいたことがないのである。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎育ちの者が、知人もない中央の学校へ受験に行くというのを案じたのでしたが、すぐに独逸から返事が来て、不合格でも心配するなとあったので、気が楽になりました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長唄や常磐津が普通の家庭にまで入っていることは、田舎育ちの下婢にめずらしく思われたのである。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎育ちのおどり子はこの有様に全くおどろいてしまひました。",
              "citation": {
                "source": "おどり子の出世",
                "author": "槇村浩",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　田舎育ちの通人が都風の粋な情緒に特にあこがれを寄せるのは理のあるところで、花廼屋は大そうな為永春水ファン。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまだ三十前の、しかも日本でも田舎育ちの若い者が、突如として放り出されたのであるから、ずいぶん心細い思いをした。",
              "citation": {
                "source": "サラダの謎",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこから見ても田舎育ちの御婆さんであった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小原は、なるほど握手とはこんなふうにするものかと、田舎育ちの少女にも即座に納得がいくような心のこもった仕方で、一二度強く握ると、「よく来たねえ、たいへんだったろう。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は同族の藤原貴族を一丸として敵に廻すに至ったが、彼が己れの実兄や一族をおとしいれた陰謀といっても、決して手のこんだものではなく、むしろ無策でガムシャラで、ただもう威張りたい一方の頭の良くないお人よしの田舎育ちの大臣の策という泥くさ手段が多いのである。",
              "citation": {
                "source": "安吾史譚",
                "author": "道鏡童子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙水仙、花ワサビ、水竹蘭、延命竹などとも称される」　生れながらの田舎育ちなら、知っていたかも知れないが、ちょっと見ては、セリにそっくりである。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来が田舎育ちの無骨者なので、人づきあいが拙く、従って異性との交際などは一つもなく、まあそのために「君子」にさせられた形だったでもありましょうが、しかし表面が君子であるだけ、心の中はなかなか油断なく、往来を歩く時でも毎朝電車に乗る時でも、女に対しては絶えず注意を配っていました。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに留守役は料理茶屋などにも顔がきくので、田舎育ちの永井をひきまわし、遊びを仕込むのはたやすいことだ。",
              "citation": {
                "source": "古今集巻之五",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女たちはそれぞれ薙刀の使いかたぐらいは知っていたし、若尾が田舎育ちでありそんなにも若いので、軽蔑のしかたもかなり露骨であった。",
              "citation": {
                "source": "みずぐるま",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どうも伜めが、とんだご無礼をいたしましたが、このとおりな田舎育ちじゃ、ま、堪忍してやってくだされい」「いやご主人、こちらも悪かったのですよ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
