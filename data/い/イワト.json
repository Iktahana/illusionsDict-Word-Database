    "definitions": [
      {
        "index": 1,
        "gloss": "rock door (to a cave)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "記紀にはないが、天手力男命が、引き明けた岩戸を取って投げたのが、虚空はるかにけし飛んでそれが現在の戸隠山になったという話も、やはり火山爆発という現象を夢にも知らない人の国には到底成立しにくい説話である。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅順の要塞が陥落すると、日本の国内は、もったいないたとえだが、天の岩戸がひらいたように一段とまぶしいくらい明くなり、そのお正月の歌御会始の御製は、　　富士の根ににほふ朝日も霞むまで　　　　　としたつ空ののどかなるかな　まさに日本は、この時、確実に露西亜を打破ったのだといってよい。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまの岩戸を開けるような恰好して、うむと力こめたら、硝子戸はがらがらがら大きな音たてて一間以上も滑走し、男爵は力あまって醜く泳いだ。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦岩、蓬莱岩、岩戸不動滝、垂釣潭、宝船、重ね岩、宝塔｜等等等の名はまたあらずもがな、真の気魄はただに天崖より必逼する。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の岩戸の昔よりという意気組であります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く厩舎へ曳っ張っていって、脚へ重みがかからないように梁から吊って、そして岩戸をすぐ呼んで手当てをさせろ！",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "防戰の持場は赤間口、畝町、金出口、金出宿、宰府口、比惠の原、岩戸口、三瀬越、唐津口、生松原、船手と城内とに分けられた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神代巻」や『古事記』に、天照大神岩戸籠りの時、八百万の神、常世の長鳴鳥を聚め互いに長鳴せしめたと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根の主峯なる神山は、霧に封ぜられ、その支峰なる聖山、鍛冶屋山より岩戸山、日金山、弦卷山、玄嶽、小川澤山は順次南に連なりて、恰も屏風を立つるが如く、その裾に伊豆山、熱海、網代、伊東等の市街散在す。",
              "citation": {
                "source": "沖の小島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、天の岩戸扇石、一名辨慶七戻り、高天の原、紫雲石、天の岩戸胎内潜り、國割石、神樂石、大黒石、北斗石、寶珠石、大神石など是れなり。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあけさは岩戸のすきから世の中をのぞいて見るのよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十八年の秋、団十郎三回忌の追善興行が歌舞伎座に催されたときに、九女八も門下の一人としてその序幕の「岩戸のだんまり」に出演した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『知識』でも、『力』でも、『眞』でも、『徳』でも、『淨化』でも、『豫言』でも、いかなる神の力でも開かれなかつた天の岩戸が、『笑』の女神の力によつて開かれた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな『力』も、太陽が岩戸からやゝ姿をあらはしかけた時に、その手を執つて引き出すことにのみ役立つたことを語りたいのである。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い岩戸を押しひらいて、知らず識らずのうちに、大衆を高めることの出來るやうな、好い滑稽が溢れたものであつて欲しい。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照という女酋長が、出来上ることをたのしみにして織っていた機の上に弟でありまた良人であって乱暴もののスサノオが馬の生皮をぶっつけて、それを台なしにしてしまったのを怒って、天の岩戸――洞窟にかくれた話がつたえられている。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神の岩戸がくれは日蝕の物語だともいわれる。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをとりまいて見物している神々が笑いどよめいた声に誘われて、好奇心を動かされた女酋長がちょいと岩戸を隙かしたところを、手力男命が岩を取り除けて連れ出したという物語である。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天ノ岩戸の時以来の天真な、快活な、自然人らしい空気が神楽のなかに伝統しているのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十二日　けふも日本晴、まるで春、行程五里、海ぞひのうつくしい道だつた、加津佐町、太田屋（三〇・中）此町は予想しない場所だつた、町としても風景としてもよい、海岸一帯、岩戸山、等、等。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "中将は、「腹をたててあなたが天の岩戸の中へはいってしまえばそれが最もいいのですよ」　と言って立って行った。",
              "citation": {
                "source": "源氏物語",
                "author": "行幸",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五九（昭和三十四）年、日米安全保障条約をめぐって日本が大揺れに揺れる前の年、岩戸景気で企業が活気づく中で、東京大学理学部応用物理学科を卒業して古山良二は日本電気に入社した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十和田湖前より別路を取り、大黒天、天の岩戸、金の神、山の神、火の神、風の神などの巖窟を見て、西海の濱に出で、近く惠比須島を見て歸途に就き、織田氏の家に小憩して、黄昏の頃、宇樽部に歸りぬ。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本屋は少く、今では岩戸町の電車通りにある竹中一軒位のものだ。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今その当時の明進軒の息子（といってもすでに五十過ぎの親爺さんだが）は、岩戸町の電車通りに勇幸というお座敷天ぷら屋を出している。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまてらすおおみかみさまは裸で岩戸からのぞいておいでになる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸一貫のお酌は天の岩戸以来初めてだろう」「妾にもお盃を頂かして下さい」「オイ来た。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつたく、天照大神が天の岩戸に隱れ給うたときのやうに、まつたく蒼蠅なす、もろ／＼のまがつみが國内にみちたのでした。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つら／＼神典の文を案ずるに、大御神は素戔嗚尊の荒らき振舞を怒りて、天岩戸に隱れさせ給へり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（読む）「井戸を汲みながら女が、若い時は二度はないわと言つた――私はそれを少し離れた所に立つて聞いてゐた。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
