          ],
          "literary": [
            {
              "text": "夏なんだから、もう少しは居心地いいところでなくちゃ、体のためにわるいわ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "官僚主義は、反革命の最も居心地いい温床である。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このおうち、　いごこちいいから　きっと　ひとふゆ　ぐっすり　ねむれるわ。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            }
