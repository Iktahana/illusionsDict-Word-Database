        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このカフェ、BGMも落ち着いてて、なんだか居心地いいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引っ越したばかりだけど、もうすっかりこの部屋が居心地いい空間になったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの人の周りはいつも笑顔が絶えなくて、すごく居心地いいんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい部署は、みんな協力的でとても居心地がいいです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このソファ、座り心地もいいし、本当に居心地がいいから、ついうたた寝しちゃう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「初めて来た国だけど、思ったよりずっと居心地のいい街だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「チームのみんなといると、変に気を使う必要がなくて、本当に居心地がいい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夏なんだから、もう少しは居心地いいところでなくちゃ、体のためにわるいわ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "官僚主義は、反革命の最も居心地いい温床である。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このおうち、　いごこちいいから　きっと　ひとふゆ　ぐっすり　ねむれるわ。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
