[
  {
    "uuid": "569cc3e5-c344-5736-8414-b436c546aec9",
    "entry": "斑鳩",
    "reading": {
      "primary": "いかるが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
