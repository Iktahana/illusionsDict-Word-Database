        "examples": {
          "standard": [
            {
              "text": "「このチャンスを逃したら次はないぞ。やるなら今しかない！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ずっと欲しかった限定モデルが再入荷している。買うなら今しかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ごめん、話せるのは今しかないんだ。少しだけ時間いいかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "受験まで残り三ヶ月。本気で追い込みをかけるのは、もう今しかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これにアリスも、にげるのは今しかないとふんで、すぐさま動いてかけ足、やがてワンコのほえる声も遠くかすかになっていってね、そのうちこっちもへとへとで息切れ。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにアリスも、にげるのは今しかないとふんで、そこですぐさま動いてかけ足、そのうちこっちもへとへとで息切れ、やがてワンコのほえる声も遠くかすかになっていってね。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　めし使いはさきほどの言葉をくりかえすには今しかないと思ったのか、言い方を変えてね。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく二人で話し込んだあと、健一は今しかないと思い、ひとり二階にある伯母の部屋に忍び入った。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "お目にかかれる万に一つの機会は全く今しかない。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
