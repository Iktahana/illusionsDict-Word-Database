    "definitions": [
      {
        "index": 1,
        "gloss": "first place (in a race)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ゴール手前で猛スパートをかけ、ハナ差で二位を抑えて一着で入線した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一着でゴールした瞬間、彼は天を仰いで両拳を力強く突き上げ、喜びを爆発させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予選をダントツの一着で通過し、決勝でのメダル獲得に大きな期待がかかっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "クラブ員は海賊のユニフォオムを一着すること。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには颱風の事実を捕える観測網を出来るだけ広く密に張り渡すのが第一着の仕事である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一般に実際上の問題に物理学を応用しようとする時に、第一着手としてしなければならぬ事は問題自身の分析的研究である。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渾沌とした問題を処理する第一着手は先ず大きいところに眼を着けて要点を攫むにあるので、いわゆる第一次の近似である。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラウエ、菊池の実験といえども、まず第一着に本質的に何よりもだいじなことは「写真板の上にあのような点模様が現われる」ことであった。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと、旗取り競争第一着、駿足の少年にも似たる有頂天の姿には、いまだ愛くるしさも残りて在り、見物人も微笑、もしくは苦笑もて、ゆるしていたが、一夜、この子は、相手もあろに氷よりも冷い冷い三日月さまに惚れられて、あやしく狂い、「神も私も五十歩百歩、大差ござらぬ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服をきらいなのではなく、いや、きらいどころか、さぞ便利で軽快なものだろうと、いつもあこがれてさえいるのであるが、私には一着も無いから着ないのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩はすぐさまその石標の上に跳り上り、遠からん者は音にも聴け、近くば寄って眼にも見よ、吾こそは今日登山競走の第一着、冒険和尚｜字は春浪なりと呼わったが、音に聴く者も眼に見る者も側なる津川五郎子ばかり。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "未醒子の漫画では、吾輩群を抜いて一着のように描いてあるが、その実津川子と同着、シカモ吾輩は裸一貫、津川子には重い荷物のハンデキャップが付いている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一着は水中の津川五郎子で、一｜哩の時間十五分十二秒、二着は髯将軍、三着は羅漢将軍、四着は走れそうもない木川子が泳ぐようにして辿り着いたという事で、吾輩はビリの到着。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の第一着は差引きでゼロと相成った。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじく月賦……這個まつくろなのを一着して、のそ／＼と歩行く奴を、先生が嘲つて――月府玄蝉。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれども、その計劃の第一着手として、理想的な美少女を令夫人に迎えることを、あなたは全く忘れておられました。",
              "citation": {
                "source": "夫人探索",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラブ員は海賊のユニフオオムを一着すること。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には背広服が一着も無い。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出來ない迄も兎に角に氣を過泄する癖を除かんと企つる其の次には、事理の相應といふ事を心掛けるので、散る氣の習を改めんとする第一着手の處は、之を措いて他には無いのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "散る氣の習の既に付いて居る人には一寸｜斯樣いふやうに萬般の事を爲て行く事は出來難いものであるが、先づ些細の事からでも宜い、第一着手のところは何でも、爲す可きを爲し、爲す可からざるを爲さぬ、思ふ可きを思ひ、思ふ可からざるを思はぬと、決意決行するのに在る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "全氣全念を以て事に從ふのは、儒教に於ては『敬』といふのが即ち其で、全氣全念を保たんとするのが道家の『錬※』の第一着なのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一着々々に全氣で事を爲す習を付けるのが肝要である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、私の訪問客ではなく、つねに私のふしだらの、真実の唯一の忠告者であるのだが、その親友は、また、私よりも、ずっとひどい貧乏で、洋服一着あるにはあるけれど、たいていかれの手許にはない。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "『××さんは今日の第一着であした。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　脊の高い方は、それでも外套一着で、すっぽりと中折帽を被っている。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……というのは羽織袴です――弁持も私も、銀行は同一取引の資産家だから、出掛けに、捨利で一着に及んだ礼服を、返りがけに質屋の店さきで、腰を掛けながら引剥ぐと、江戸川べりの冬空に――いいかね――青山から、歩行で一度中の橋手前の銀行へ寄ったんだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那、其の夜の出と謂ふは、黄な縞の銘仙の袷に白縮緬の帶、下にフランネルの襯衣、これを長襦袢位に心得て居る人だから、けば／＼しく一着して、羽織は着ず、洋杖をついて、紺足袋、山高帽を頂いて居る、脊の高い人物。",
              "citation": {
                "source": "山の手小景",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大乗理想から見れば、肝腎の菩提心の一着だけは欠いているが、殊にこの著書の特色は、人間の愛慾に求道を終始連絡させているところである。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、誰も親なし子や言うて虐めたら、あけへんし」　その日から、君枝はだんだん明るい子になり、間もなく行われた運動会の尋二徒歩競争では、眼をむき、顎をあげて、ぱっと駈けだし、わてのお父ちゃんはマラソンの選手やった、曲り角の弾みでみるみる抜いて一着になった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それどころか、坂田は花田八段の第一手七六歩を受けた第一着手に、再び端の歩を一四歩と突いたのである。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "前号にも言ひし如く、維新の革命は前古未曾有の革命にして、精神の自由を公共的に振分けんとする革命にてあれば、此際に於て尤も多く時代に需めらるべきは、此目的に適ひたるものなるが故に、其第一着として三田翁は皇天の召に応じたるものなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、この時に響いた二三発の銃声こそはＡが私の運命を手玉に取り初めた、その皮切りの第一着手であったことも、トックにお察しが着いていることでしょう。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "追込線に入りて断然他馬を圧倒し、鼻頭を以て、一着す。",
              "citation": {
                "source": "我が馬券哲学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
