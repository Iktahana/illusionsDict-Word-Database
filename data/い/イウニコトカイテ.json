          ],
          "literary": [
            {
              "text": "言うに事欠いて、良い返事をしないと、私達をヘアデールパークから追い出すと言った」　父が不安そうな青白い顔を娘に向けて、かすれ声で訊いた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うに事欠いて、結婚は詐欺だ、一連の儀式は偽物だ。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うに事欠いて上流階級出身だと。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "署まで行ったんだが、言うに事欠いて、あの地区で有能な警官を配置するのは無理だと。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
