    "definitions": [
      {
        "index": 1,
        "gloss": "every single word and phrase",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "俳優は舞台の本番を控え、台本の一言一句を完璧に記憶した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "閣僚の会見内容が一言一句精査され、失言の有無が厳しく追及された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "契約書に署名する前に、不利な条項が含まれていないか一言一句を注意深く読み進める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの時、あなたが私にかけてくれた言葉を、今でも一言一句忘れてはいません」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "翻訳家は原作者の繊細な文体を再現するため、原文の一言一句を吟味して言葉を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裁判の記録には、証人の発言が一言一句違わず正確に記されなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "恩師の最後の講義を、学生たちは一言一句聞き漏らすまいと熱心にメモを取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "不憫の故にな」　ああ、一言一句そのまんま私は記憶して居ります。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者の言葉を一言一句聞きのがしてはならない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、君たちから僕のつまらぬ一言一句を信頼されるのを恐れていたのかも知れない。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに吾人は艇長の動機に、人間としての極度の誠実心を吹き込んで、其一言一句を真の影の如く読みながら、今の世にわが欺かれざるを難有く思ふのである。",
              "citation": {
                "source": "艇長の遺書と中佐の詩",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上、一言一句あやまちなし。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の一言一句がクラスの全體から力強く同感されてゐる快さに醉つてゐた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己喪失症とやらの私には、他人の口を借りなければ、われに就いて、一言一句も語れなかった。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして又、一言一句の末にまで容赦なき拘束を受けて、何事に限らず、その思ふ所をそのままに言ふことを許されない境遇にゐた彼等は、翁の大膽なる論文とその大膽を敢てし得る勢力とに對して、限りなき羨望の情を起さざるを得なかつたに違ひない。",
              "citation": {
                "source": "トルストイ翁論文",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダメス王の鼻は、王の顔面に築かれたピラミッドに過ぎませぬ」　この強い、そうして静かな議論は、その一言一句が悉く生と死――動と静の反語ばかりで成り立っている事を並いる神々に認めさせました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａの言葉が一言一句、真実に相違ない事を証明するに十分な、畑中昌夫と谷山秀麿の戸籍謄本や、新聞紙面の複写フィルムを、内ポケットから探し出したばかりでなく、メチャメチャに壊れたＡのカメラの中に、タッタ一枚無事に残っていた、私の妻子のグロ写真を現像する事にまで成功したではありませんか。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "話された内容を一言一句書き留めたというレストレードの手帳から直に確かめてある。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おかみさんは他人事だと思って、笑いながら話していましたが、わたくしはその一言一句を聞きはずすまいと、一生懸命に耳を引っ立てていました。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間もちょっと話した飯田町の大久保殿の二番娘……」　お菊は襖を押倒すほどに身を寄せかけて、その一言一句をも聞き落すまいと耳を澄ましていた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私には限らない、当時の貸本屋フワンは誰でもだったが）信乃が滸我へ発足する前晩｜浜路が忍んで来る一節や、荒芽山の音音の隠れ家に道節と荘介が邂逅する一条や、返璧の里に雛衣が去られた夫を怨ずる一章は一言一句を剰さず暗記した。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "談話するにさえ一言一句を考え考え腹の底から搾出し、口先きでお上手や胡麻化しをいう事が決して出来なかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は姉の言葉をでも、聴いているように、一言一句に、微笑しながら肯いた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの中の一言一句にも、私は沢山な背景なり前景なりを持つてゐる。",
              "citation": {
                "source": "或新年の小説評",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は姉の言葉をでも、聴いてゐるやうに、一言一句に、微笑しながら肯いた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の一言一句は、鋭くわたしの胸に突き刺さった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方は、わたしを取巻いて、わたしの一言一句を重んじて、わたしの足もとで死ぬ覚悟でいらっしゃる。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……彼はただ、わたしをちょいとからかおうと思っただけのことだろうが、その一言一句は猛烈な毒となって、わたしの血脈という血脈を走り回った。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一言一句が五十銭づつの値段でもするやうに、出し惜みをするらしく緩りした調子で、「なに高い事は無いさ、幾万円払つた骨董が宅の土蔵にしまひ込んであるとなると、外に沢山あるがらくた道具までが、そのお蔭で万更な物ぢや無からうといふので、自然｜値が出て来ようといふものぢやないか。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の人達の事とて、胃の腑の詰まつてゐる代りに、頭のなかは空缶のやうに空つぽだつたから、演説は一言一句その儘に入つて往つたが、几帳面な汽車の時間表は、首相の演説にも少しも容捨はしなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁動員課の男の式辞や、校長の訓示はいい加減に聞流していたが、やがて、立派な国民服姿の順一が登壇すると、正三は興味をもって、演説の一言一句をききとった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁動員課の男の式辞や、校長の訓示はいい加減に聞流してゐたが、やがて、立派な国民服姿の順一が登壇すると、正三は興味をもつて、演説の一言一句をききとつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "して、子爵自身に就いて云へば、この詩の方面に於ては、キーツ、テニソン、ブラウニングに精通し、特にウワアヅウワアスに至つては、早くからこれを愛誦し、その一言一句をも諳んじて、折に触れ事に接してこれを想ひ起し、回想記にも雑講にも随処にこれを引用してゐる。",
              "citation": {
                "source": "趣味としての読書",
                "author": "平田禿木",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨其六経を読み明めむとするには必ず其｜一言一句をも審に研究せざるべからず。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言一句を研究するには、文字の音義を詳にすること肝要なり。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖ろしさに躯ぢゆうをわなわな顫はせて、そのひとのいふ一言一句に身内の呻くやうな思ひをしながら。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
