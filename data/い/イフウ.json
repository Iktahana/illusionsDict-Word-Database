        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "恩師の「誠実であれ」という遺風を胸に、私は社会人になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この歴史書には、偉大な哲学者の遺風となる思索が、詳細に記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「常に感謝の気持ちを忘れるな」という父の遺風は、今でも私の指針だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
