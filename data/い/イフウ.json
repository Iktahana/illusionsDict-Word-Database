[
  {
    "uuid": "44be08b0-5969-5109-a28c-b26a20dc79ff",
    "entry": "威風",
    "reading": {
      "primary": "いふう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
