          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "シューベルトの「未完成交響曲」は、その抒情的なイ短調の旋律が聴く者の心に深く響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、イ短調が持つ独特の哀愁を表現するのが得意な作曲家だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このバイオリン協奏曲の第一楽章は、情熱的なイ短調で始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ピアニストは、イ短調で書かれた練習曲を滑らかに弾きこなした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この曲のイ短調への転調は、劇的な効果を生んでいるね。」と、友人は感嘆した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バッハのシャコンヌは、イ短調でありながら非常に壮大な広がりを感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のサントラでは、主人公の悲しい過去を描写するシーンでイ短調の楽曲が効果的に使われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「第二ソナタ＝イ短調」はコロムビアのシゲティーが当然良く、「第二パルティータ＝ニ短調」は同じくメニューイン（ビクターＪＤ七四〇―三）とハイフェッツ（同上ＪＤ一五九三―六）が対立する。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に「四台のピアノのための協奏曲＝イ短調」もあるがさしたるレコードではない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イギリス組曲」も六曲のうち第二番のイ短調のが、ランドフスカの演奏でバッハ協会の第五集に含まれているが、これなどは名盤にかぞえられるものだろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品一三二「四重奏曲イ短調」のカペエは幽婉、美妙の名演奏だ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ四重奏曲で「弦楽四重奏曲イ短調作品二九」のコーリッシュ四重奏団を挙げて良いと思う（コロムビアＪ八四一三―六）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェロのソナタには「イ短調（アルペジオ）」がある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピアノ協奏曲＝イ短調（作品五四）」はきわめて有名な曲であり、シューマンにとっては傑作の一つである。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チェロ協奏曲＝イ短調（作品一二九）」はヴァイオリン協奏曲と共にシューマンの弦楽器をマスターした名曲と言えるだろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弦楽四重奏曲」では第一番のイ短調（作品四一ノ一）を入れたカペエ弦楽四重奏団のコロムビア・レコード（Ｊ七六二九―三一）ひと組あれば沢山だ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「複協奏曲＝イ短調（作品一〇二）」はヴァイオリンとチェロのための協奏曲で、ブラームスの最後の傑作の一つだ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弦楽四重奏曲＝第二番イ短調（作品五一ノ二）」はレナーだけ（コロムビアＪ八〇二三―六）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前あんなにも無視され虐げられていたチャイコフスキーが、この人の思い出のために、美しくも悲しい名曲「偉大な芸術家の思い出に」と頭書した「ピアノ三重奏曲イ短調」を作ったことはあまりにも有名である。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三重奏曲、四重奏曲「ピアノ三重奏曲イ短調＝偉大な芸術家の思い出（作品五〇）」は、ニコラス・ルービンシュタインを弔った曲で、非常に親しみの深い、哀愁を湛えた優雅な曲だ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じヴィヴァルディのコンチェルト・グロッソは、後にバッハに影響した重要な作品であり、レコードされている数も少なくないが、そのうちですぐれたものは、メンゲルベルク指揮の「コンチェルト・グロッソ＝イ短調作品三ノ八」（テレフンケン二三六六〇―一）などではあるまいか。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヴァイオリン協奏曲第五番＝イ短調」はそのうちの一つ、コロムビアに、デュボアとブラッセル王立音楽院管弦団の入れたのがある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピアノ協奏曲＝イ短調（作品一六）」は物優しい良い曲だ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヴァイオリン協奏曲＝イ短調（作品八二）」をハイフェッツの演奏したのが技巧的に面白いだけのこと（ビクターＪＤ四二七―九）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはフィンランドの保護をうけて売出されたもので特色的な良いものであったが、「交響曲第四番＝イ短調」ストコフスキー指揮のビクター盤と共に廃盤になってしまった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドヴォルザークの『協奏曲＝イ短調』は近来一段円熟の境に入ったメニューインを語るレコードとしては、逸することの出来ない傑作である。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でチャイコフスキーの『三重奏曲＝イ短調』だけは推賞されてよかろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "組物はバッハの『協奏曲＝ホ長調』、ドヴォルザークの『協奏曲＝イ短調』、それにチャイコフスキーの『三重奏曲』を挙げられる。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二番の怪奇なイ短調の前奏曲では、もう息詰まらせていた。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードは、『ピアノ協奏曲＝イ短調』（シューマン）（コロムビアＪ八二七九―八二、傑作集一七八）　これが代表的なものであろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "代表作は、『ハンガリー幻想曲』（リスト）（ビクター九一一〇―一）『ピアノ協奏曲＝イ短調』（グリーク・作品一六）（ビクター九一五一―四、名曲集二四）　以上二曲であろうと思う。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このトリオは、ベートーヴェンの『ピアノ三重奏曲＝ニ長調（幽霊トリオ）（作品七〇の一）』（ビクターＪＤ八九八―九〇〇、名曲集六三四）とチャイコフスキーの『三重奏曲＝イ短調』（ＪＤ一一七八―八三、名曲集六七六）を入れている。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "カペエのベートーヴェンは、その全部が最上級の名演奏だが、わけても『四重奏曲第十五＝イ短調（作品一三二）』（コロムビアＪ七五六二―六、名曲集八八）をまず聴いて見るがいい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『四重奏曲＝イ短調（作品五一の三）』（Ｊ八〇二三―六、傑作集一五一）と『四重奏曲＝ハ短調（作品五一の一）』（Ｊ八一三六―九、傑作集一六七）だ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドン弦楽四重奏団　　古い因縁を持った団体で、コロムビアには以前沢山入っていたが、今ではベートーヴェンの『四重奏曲第十五＝イ短調（作品一三二）』（Ｊ八三四一―五、傑作集二〇〇）一つしかない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルトックの『四重奏曲＝イ短調』（ＪＤ六七八―八一、名曲集五九五）がある。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "リストの『合唱弥撒＝イ短調』、レヴィの指揮したパリ・フィルハーモニック合唱団の演奏で、器楽を伴わない合唱で、非常に興味の深いものだが、一般的なレコードではない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
