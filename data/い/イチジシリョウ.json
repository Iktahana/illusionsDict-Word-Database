        "examples": {
          "standard": [
            {
              "text": "歴史学者は、過去の出来事を正確に理解するために、日記や公的記録といった一次資料に依拠することが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この学術論文では、二次的解釈に留まらず、直接一次資料を参照することを強く推奨する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "報道機関は、未公開の内部文書や関係者への直接取材といった一次資料を駆使して、事件の真相を追究した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "科学研究における再現性の確保には、実験の生データや詳細な手順を記した一次資料の公開が不可欠である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家系図を作成する上で、戸籍謄本や古い家族写真などの一次資料は、信頼性の高い情報源となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "法廷では、契約書の原本や事件現場の記録といった一次資料が、客観的な証拠として重視される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "芸術批評では、作家の草稿や未発表の書簡を、その創作意図を解き明かすための重要な一次資料と見なす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "本人の直接証言や一次資料が公開されているのなら、要約や引用は避けてリンクする。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
