        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "結局、妻の理詰めの反論に言い負けて、リビングのソファで寝る羽目になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "開発チームの突きつける正論を前に、マネージャーは言い負けて、スケジュールの延長を認めざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の意見の方が正しい自信があったが、相手の迫力に言い負けてしまったのが悔しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テレビの討論会では、野党の執拗な追及に言い負け、大臣が立ち往生する場面もあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お姉ちゃんのバカ！」と叫んだものの、口達者な姉に言い負けて、弟はついに泣き出してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "取引先との条件交渉において、相手の強気な態度に完全に言い負けてしまい、不利な契約を結ぶことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "言いたいことは山ほどあったが、語彙力の差で言い負けてしまうのがいつものパターンだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
