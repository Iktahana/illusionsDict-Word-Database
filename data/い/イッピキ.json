    "definitions": [
      {
        "index": 1,
        "gloss": "one (small animal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お母さん、この子猫、一匹だけ残ってたんだ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭に一匹の野良猫が迷い込んできて、しばらく住み着いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供が描いた絵には、黄色い鳥が一匹、枝に止まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あれ、ハムスターが一匹、ゲージから出てるよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "僕は高森のことを想ふと、いつも一匹の美しい仔熊を聯想する。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、蟇蛙が一匹、ピクピク／＼しながら何時の間にか、庭の真中に匐ひ出してゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで蠅打を取つてピシヤリと一匹を打つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾よく一匹はそこに仰向きに転んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かう行けば好い――」　彼は一匹だけだと思つてゐたのだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所がもう一匹の奴がゐることを知つた時一寸、大変な災難が来たやうな気持になつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は東寺に先祖の一海和尚の墓に参って、室戸岬の荒涼で雄大な風景を眺めたり、昔この港の人柱になって切腹した義人の碑を読んだりしたが、残念ながら鯨は滞在中遂に一匹もとれなくて、ただ珍しい恰好をして五色に彩色された鯨漁船を手帳にスケッチしたりしただけであった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時刻にそこから十町も下流の河口を船で通りかかった人が、何かしら水面でぼちゃぼちゃ音がしていると思ってよく見ると、一匹の「えんこう」が、しきりにぐるぐる廻転運動をしているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と狸は、たちまち眼をかがやかして、「おれが三つの時、おふくろが鮒を一匹捕つて來ておれに食べさせてくれた事があつたけれども、あれはおいしい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性にはすべて、この無慈悲な兎が一匹住んでゐるし、男性には、あの善良な狸がいつも溺れかかつてあがいてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オリュンポスが馬を一匹くれるはずであったが、馬の代りに尻尾を一本くれた。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボロ洋服を着た小學生が三人、一匹の眞白な野羊を荒繩の手綱で曳いて驅け※つてゐたが、どう思つたか自分が寫眞をとつて居る傍へ來て帽子を取つてお辭儀をした。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の火事ならば大勢の人が集まっているであろうに、あたりには人影もなくただ野良犬が一匹そこいらにうろうろしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十恰好の女が一人大きな犬を一匹背中におぶって行く、風呂敷包一つ持っていない。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が三毛猫だけ連れてもう一匹の玉の方は置いて行こうと云ったら、子供等がどうしても連れて行くと云ってバスケットかなんかを用意していた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、このキャディのうちの一人がリンクの池で鮒を一匹つかまえて、ボールを洗う四角な水桶の中に入れておいて、一廻りした後に取りに来たらもう見えなかったそうである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内気でそして涙｜脆く、ある時羊が一匹｜群に離れて彷徨っているのを見て不便がって泣いたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話によると、Ｋ先生は教場の黒板へ粗末な富士山の絵を描いて、その麓に一匹の亀を這わせ、そうして富士の頂上の少し下の方に一羽の鶴をかきそえた。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかに日が暮れ出すや否や、犬どもは、一匹づつ、扉の隙間から出て行つた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその一匹などは臟腑ぐるみ死んだ胎兒を引つぱり出されたりした。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が更けてロダンさんは一匹の番犬を連れて、離れの二階の寝室に妾を案内していらして、犬と妾を部屋に置くと、母屋の方に下りていらっしゃいました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一匹もさげずに帰るのか、――俺れゃいやだ。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が下って来るまで、見渡す限り雪ばかりで、犬一匹、人、一人見えなかった山の上に、茶色のひげを持った露西亜人が、毛皮の外套を着、銃を持って、こちらを見下しているのであった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十貫の豚が一匹あればツブシに売って、一家が一カ月食って行く糧が出るのだ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹が跳ね、騒ぎだしたのにつれて、小屋中の豚が悉く、それぞれ呻き騒ぎだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにも、十個ばかりの柵が、がらあきでたゞ仔豚をかゝえた牝が一匹横たわっているばかりだった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士の死ぬ事を、チンコロが一匹死んだ程にも考えやしない。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か嗅覚類似の感官にでもよるのか、それとも、偶然工場に舞い込んだ一匹が思いもかけぬ甘納豆の鉱山をなめ知っておおぜいの仲間に知らせたのか、自分には判断の手掛かりがない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ、のら猫の連れていた子猫のうちの一匹がどうしたわけか家の中へはいり込んで来て、いくら追い出しても追い出してもまたはいって来て、人を恋しがって離れようとしない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまの上にはたいてい蠅が一匹ぐらいとまっていた。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
