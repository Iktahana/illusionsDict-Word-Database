        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "着物を作るために、反物（たんもの）を一匹仕入れてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この生地は一匹が二反分なので、コートなら十分作れます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古道具屋で、古い絹の反物（たんもの）を一匹見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
