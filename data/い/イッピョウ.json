  {
    "uuid": "a156df70-4cce-5a63-b55e-44bc256e44d2",
    "entry": "一瓢",
    "reading": {
      "primary": "いっぴょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one gourd",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その隠者は、水筒代わりに一瓢の干し瓢箪を腰に下げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "昔の旅人は、一瓢の水を頼りに長い道のりを歩いたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "川の水を汲み、彼は持っていた一瓢を潤した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "アルヒ　アサカラ　ヨイテンキヤマヘ　ユキマス　シバカリニ　このお爺さんの樂しみは、お天氣のよい日、腰に一瓢をさげて、劍山にのぼり、たきぎを拾ひ集める事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瓢に造化を藏し、三尺妖邪を斬り、逡巡の酒を造ることを解し、また能く頃刻の花を開かしむ。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルヒ　アサカラ　ヨイテンキヤマヘ　ユキマス　シバカリニ　このお爺さんの楽しみは、お天気のよい日、腰に一瓢をさげて、剣山にのぼり、たきぎを拾ひ集める事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "法蓮は変な事と一瓢を破り見れば中に粒大きく雪ほど白い精米五斗あり、他を剖いて見るに毎瓢同様なり。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "因って諸人に示し『法花経』に供え諸僧に食せしめ更にその一瓢を光勝に送る。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭溪二瓢を携へ來り、一瓢を余の手にわたす。",
              "citation": {
                "source": "白河の關",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯖一尾十五銭、胡瓜一瓢十銭、のんびり晩酌一本また一本、ありがたし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "で彼は或日一瓢をたずさえ、湖水の岸に添い乍ら小坂の観音の方へ彷徨って行った。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢山の瓢の中これが一番形も面白く俗ぬけがしてゐて、しかもひねくれすぎず、私の一番好きな瓢なのであるが、肥が足らぬのか木かげのせゐか一向ずば／＼と成長せず、ほんとの一瓢きりなのである。",
              "citation": {
                "source": "瓢作り",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人ともに手頃の荷物を振分けにして肩にひっかけ、別に道庵は首に紐をかけて、一瓢を右の手で持ちそえている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、とある酒店で、持参の瓢箪の中へいっぱい清酒を詰めさせた客人があるという手がかりがあって、それから問いただしてみると、それは多分｜件の一瓢を携えて寝覚の床へおいでになったのだろうとのことです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、方丈の毛氈の上へ坐り込んで、そこで寝覚の床の全景を見下ろしながら、早くも一瓢を開いたものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瓢を携へて山に登ると書いてもよかつたのだ。",
              "citation": {
                "source": "花より団子",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで少々得意になったので外国へ行っても金が少なくっても一箪の食｜一瓢の飲然と呑気に洒落にまた沈着に暮されると自負しつつあったのだ。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥さん、月並と云うのはね、まず年は二八か二九からぬと言わず語らず物思いの間に寝転んでいて、この日や天気晴朗とくると必ず一瓢を携えて墨堤に遊ぶ連中を云うんです」「そんな連中があるでしょうか」と細君は分らんものだから好加減な挨拶をする。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じ篇に、子曰く、賢なるかな回や、一箪の食、一瓢の飲、陋巷にあり。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがパッと評判になって、源内櫛を挿した娘に限って殺されるなんてえことになったら、わざわざ長崎から伽羅を引き、二階の座敷を木屑だらけにして櫛を梳かせ、何とかこいつを流行らせようというので、一瓢を橋｜渡にして、吉原丁字屋の雛鶴太夫に挿させたまでの苦心の段が水の泡。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ことによれば、ことによるぞ」　葺屋町へ入って行くと、向うから坊主頭を光らせながらやって来たのが、浅草茅町に住む一瓢という幇間。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "源内先生は、焦れったそうに足踏をしながら、「それはいい、……それはいいが、一瓢さん、ちとひょんなことになった。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "その掛合で、これから浜村屋の楽屋へ行くんだが、あなたもどうか一緒に行ってください」　一瓢は、何か思惑ありげに眼を光らせ、「浜村屋に、何かあったんですか」「まだ、そんなところまで行っていない。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "……先生、こりゃ妙なことになりました」　源内先生は、額をおさえて、「こりゃ、いかんな」　一瓢は、すかさず、「先生、そこで一句」　源内先生は、苦り切って、「とても、それどころじゃない。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、一瓢さん、あんたはどう思う。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら浜村屋が酔興でも、九つ十歳の娘などに色文をつけるわけはない」　一瓢は、妙な工合に唇を反らしながら、「それゃ何ともいえねえ。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄情もいい浮気もいいが、いい加減にしておかないと、いずれ悪い目を見るぜ」　源内先生は、分けて入って、「おい、一瓢さん、今そんなことを言い出したってしようがない。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺の消息は、一瓢がうすうす知っていて、帰りがけにわしにそんな風なことを囁いた。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瓢一を加へ百かつ千、千瓢向ふところ商敵なし、叱咤たちまち握る世界の權といひ度い。",
              "citation": {
                "source": "大阪といふところ",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南郷綾麿は町内の若い男女五六人と、その頃流行った「一瓢を携えて」亀井戸の臥龍梅を見、少し廻り道をして、五つ目の羅漢寺に詣で、蠑螺堂の回廊をキャッキャッと騒ぎながら登ったのは、最早夕景近くなってからでした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "観音様の頬",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾麿と香折の他には、十八九から二十歳を越したのが四五人、例の一瓢を空っぽにした元気で、威勢よく蠑螺堂の頂上に駈け登って、大ふざけにふざけながら、四方の景色を眺めて居ります。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "観音様の頬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一箪（たん）の食（し）、一瓢（ぴよう）の飲（いん）、陋巷（ろうこう）にあり、人はその憂に堪えず。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "small drink (esp. of alcohol)",
        "register": "standard",
        "nuance": null,
