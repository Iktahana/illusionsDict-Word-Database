[
  {
    "uuid": "15ec2eb3-615e-50cb-91be-4e03893faaec",
    "entry": "一俵",
    "reading": {
      "primary": "いっぴょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
