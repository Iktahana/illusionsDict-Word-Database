[
  {
    "uuid": "38775b1b-16d8-5a9e-bd55-63ae0281e293",
    "entry": "一語一語",
    "reading": {
      "primary": "いちごいちご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
