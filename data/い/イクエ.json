          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "幾重にも重なる積乱雲の層が、遠くの山並みを黒く覆い隠していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その小説は、登場人物の繊細な心理描写が幾重にも重なり合い、読者の心を深く揺さぶる感動的な物語である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の言葉には、表面的な意味だけでなく、幾重にも隠された複雑な意図が感じ取れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "クレープ生地は、薄く何枚も焼いて幾重にも重ねることで、しっとりとした独特の食感を生み出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、あの夕焼けの空は、幾重にも色が重なって、まるで絵画のようね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "研究所の厳重なセキュリティは、幾重もの認証システムと物理的な障壁によって、外部からの不正アクセスを徹底的に防いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "晴れた日には、遠くの山脈が幾重にも連なって見える、その雄大な眺めは訪れる者を圧倒する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "人垣は急に崩れて、大風に偃す野草の如く、芳の通路を拓けども、何分多人數であるから、幾重にも犇犇と垣あり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾重の雲の中から、名の知れない山の顔が……肩から肩へと、腮を載せて、私を冷やかに見ている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "西風に吹きつけられた水蒸気が、山の胴体を幾重にも巻いて、凝結しているのだと思う。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬の山と幾分か軽く視て、雪中の登山服装というほどの準備もしていなかったため、幾重の衣も徹されて、腹から股にかけ、薊で撫で廻されるような疼痛を感じ初めた、唇はピリッとして、亀裂するかと惑われ、その寒さにわなわなと骨髄から震動した。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "光ったり陰ったり、幾重にも畳む丘々の向うに、北上の野原が夢のように碧くまばゆく湛えています。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西部のパノフォラム・ロードに虹が浮いて、香港は動乱の巷を他所に見て、植民地兵の配列のなかで、幾重にも市街を取巻いた軍用道路の設置と、無線電信台に集中される軍国主義の機密と、今日の支那に関する利権が活動を始めた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は花火の筒と云えば、木筒に竹のたがを幾重となく鉢巻きしたのを使ったものだが、さすがに今ではもうそんなものは使わないと見える。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は畳に額をうずめて、恐れかしこんでわが子の罪を幾重にも詫びた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端氏に對してはその作品を汚したことを幾重にもお詫びしたい。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは幾重にも御諒察を願はしう存じます。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがそのはじめは不精密なる経験の試験的整理を幾重となく折り返し繰り返し重ねて、漸進的に進んで来たものである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようないろいろの騒がしい音はしばらくすると止まって、それが次の室に移り行くころには、足もとの壁に立っている蒸気暖房器の幾重にも折れ曲がった管の中をかすかにかすかにささやいて通る蒸気の音ばかりが快い暖まりを室内にみなぎらせる。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光ったり陰ったり、幾重にも畳む丘丘の向ふに、北上の野原が夢のやうに碧くまばゆく湛へてゐます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長は大きな黒猫で、少しもうろくしてはゐましたが、眼などは中に銅線が幾重も張つてあるかのやうに、じつに立派にできてゐました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く根も葉もない作り事を申上げまして、御心配をおかけ申しました段は、幾重にも御勘弁を……。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ溶媒中における溶質分子の拡散と比べてはなはだしく幾重にも複雑な方則に支配されるであろうし、拡散する「物」の安定度が少ないために、事がらがいっそう込み入って来るのであろう。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯く認め終りし書面をば幾重にも疊み込み、稻妻の首輪に堅く結び着けた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃く香しい、その幾重の花葩の裡に、幼児の姿は、二つながら吸われて消えた。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日尋春不見春　　杖藜踏破幾重雲帰来拭把梅花看　　春在枝頭已十分　その梅はもう盛りをすぎたけれど、あちらこちらにしろじろと立っている。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクリュウに捲き上げられ沸騰し飛散する騒騒の迸沫は、海水の黒の中で、鷲のように鮮やかに感ぜられ、ひろい澪は、大きい螺旋がはじけたように、幾重にも細かい柔軟の波線をひろげている。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農場の入口に、大きい石碑が立つてゐて、それには、昭和十年八月、朝香宮様の御成、同年九月、高松宮様の御成、同年十月、秩父宮様ならびに同妃宮様の御成、昭和十三年八月に秩父宮様ふたたび御成、といふ幾重もの光栄を謹んで記してゐるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると看護婦は滿々と水のやうなものを充たした中に、黒い護謨の管を幾重にも輪を卷いて浸してある容器を持つて來た。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや就きまして……令嬢に折入ってお願いの儀が有りまして、幾重にも御遠慮は申しながら、辛抱に堪えかねて罷出ました。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しごいて、引いて、幾重にも巻取るようにした指を、離すと、すっと解けて頬を離れる。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生御夫妻が可愛がって下さった頃の麗姫のかたみだと申し添えてお届けして欲しいと申して………」　遜は土間の隅に大きな包みを抱え、うずくまって居る従者を顧み幾重にもからめた包装を解かせた。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根連山から聖ヶ嶽へかけて濃い薄い霞が山襞ごとに幾重にも引きはへて、そのところどころから野焼の煙が白く真直にのぼつてゐる西の方の展望は、閑かで匂はしくて、それももう冬のものではない。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠山脈の歌上つ毛の加牟良の北に天そそる妙義荒船、遥ばろと眺めに出れば、この日暮ふりさけ見れば、いや遠し遠き山脈、いや高し高き山脈、いやが上に空に続きて、いや寒く襞を重ねて、幾重ね、幾｜畳り、末遂に雲居にぞ入る。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠山脈の歌　上つ毛の加牟良の北に天そそる妙義荒船、遥ばろと眺めに出れば、この日暮ふりさけ見れば、いや遠し、遠き山脈、いや高し高き山脈、いやが上に空に続きて、いや寒く襞を重ねて、幾重ね、幾｜畳り、末遂に雲居にぞ入る。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾重にも張廻わしてある厳重を極めた警戒網を次から次に大手を振って突破して、一直線に福岡県庁に自首して出た時には、全県下の警察が舌を捲いて震駭したという。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い樹の幹が押しあってならんでいて、まえをみると、まるで垣根がいくえにも結ばれているような気がしました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
