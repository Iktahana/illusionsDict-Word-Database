[
  {
    "uuid": "1d190824-1855-5a03-b743-4fa827db0257",
    "entry": "威服",
    "reading": {
      "primary": "いふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
