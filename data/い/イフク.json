        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "awing into submission",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大将の威風は兵士たちを威服させ、誰も逆らうことはできなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その強大な怪物は、その力で周囲の生き物をすべて威服させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カリスマ的なリーダーは、言葉ではなく、その存在感で人々を自然と威服させてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その責任上、永禄三年兵を関東平野に進め、関東の諸大名を威服し、永禄四年に北条｜氏康を小田原城に囲んで、その城濠｜蓮池のほとりで、馬から降り、城兵が鉄砲で狙い打つにも拘らず、悠々閑々として牀几に腰かけ、お茶を三杯まで飲んだ。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄に威服していた連中は、後嗣の勝頼頼むに足らずとして、家康に※を通ずるものが多い。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについての鄙見は他日に譲り差し当り述ぶるは、『淮南子』に〈景陽酒に淫し、髪を被りて婦人を御し、諸侯を威服す〉。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "稙宗は勇武絶倫の将であって、しばしば隣国と戦って大いに捷ち、将軍足利義稙より偏諱を賜うて稙宗と名乗り、奥州の探題となって東北を威服した人である。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に隱忍して時を待ち、其の勝れた才徳を以て自然に馬子をも威服せしめ、蘇我氏の權力をも壓へる樣にしたことは、日本紀を讀んだだけでも分明である。",
              "citation": {
                "source": "聖徳太子",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "補佐する高資に至っては――長崎高資に至っては、貪慾にして苛察の小人、賄賂を貪り訴訟を決し、私情をもって人事を行い、ひたすら威服を擅にす。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の位置は、風雲によって生れたのであるから、天下の全土を完全に威服させてしまうまでは、寸時も生々躍動の前進を怠ってはならない。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔明は、銀坑の蛮都に入ってから、これを治めて掠めず、これを威服せしめて殺戮せず、克くただ徳を布き、さらに軍をととのえて、王征を拡大して来た途にあった。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから自分の手先につかっている安蔵という奴に云いふくめて、二、三日まえからお亀の家の近所をうろついて、内の様子を窺わせているうちに、その屋敷からお蝶を一生奉公にかかえたいという掛け合いに来たことも判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧の中を飛ぶ術のまだできていないふくろうの、ばたばた遁げて行く音がしました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやり方を、家へ帰っても毎日、繰返すよう言いふくめました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧の中を飛び術のまだできてゐないふくろふの、ばたばた遁げて行く音がしました。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大きな平べったいふらふらした白いもので、どこが頭だか口だかわからず、口上言いがこっち側から棒でつっつくと、そこは引っこんで向うがふくれ、向うをつつくとこっちがふくれ、まん中を突くとまわりが一たいふくれました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "節の短い円く肥つた腕ではあるが、女らしいふくらみがないのであつた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、背中を抱いた手を胸の柔いふくらみの方へ廻して、ギュッと力を入れながら頬をくっつけて来た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら諦めなければいけないと自分の心に云いふくめてみたところで、所詮無駄だった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、美しいふくよかな音楽が、おかあさんのすぐそばで鳴ったかと思うと、今度は、ずっと遠くで、それからまた近くで、というふうに、たえず鳴りひびいていたからです。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "この王さまは、わしの力で、世界じゅうの国々をせいふくしてやろう、わしの名前を聞いただけで、あらゆる人間をふるえあがらせてやりたいものだ、と、こんなことばかり考えていました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの国をも、かたっぱしから、せいふくしていきました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、わしは、神さまをもせいふくしよう」　こう言うと、心のおごった、ばかな王さまは、空を飛んでいくことのできる、一そうの船を作らせました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは、神さまをせいふくするのだ」と、王さまは言いました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、せいふくした国々から、たくさんの兵隊をかりあつめました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、毀れてしまった操り人形のように、あわれにも精も根も尽き果てた様子で、明るい真昼間の日ざしの中で眠りこけている姉の寝姿を見ていると、自分もつい悲しくなるのだが、しかし私は姉をそんなに不幸にしてしまったとしても、それはあくまで自分の罪でないことを、自分の胸に幾度も云いふくめた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今日ばかりでなく、これから後いつまでもさういふくだらぬことはしてもらひたくないといふ心をあらはしてゐた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、口に出して言はれないやうな、われながらみつともない形で女のひとに逃げられたものであるから、私は少し評判になり、たうとう、佐野次郎といふくだらない名前までつけられた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、髭そうろうの大尽は、かの五人の手下に言いふくめて、金銀｜綾錦のたぐいの重宝をおびただしく持参させ、かの土塀の家に遣し、お姫様を是非とも貰い受けたしと頗る唐突ながら強硬の談判を開始させた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆は察して、売れ残りの芸者ひとりを呼んで、あれは素性の悪い大馬鹿の客だけれども、お金はまだいくらか持っているようだから、大晦日の少しは稼ぎになるだろう、せいぜいおだててやるんだね、と小声で言いふくめて、その不細工の芸者を客の座敷に突き出した。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬吉は田舎初段であったが、おたかに言いふくめられて、三度に一度儀助に負けてやった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だが向って右手の硝子窓には黄の赤い蘭科の花の鉢が一つ、大きな素木のテエブルの上に載せてあって、その怪しげな生物が、またこの大陸風のこの雨の日の外光を思いきり吸いふくれていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアは五代綱吉時代にカムチャツカを収めたが、つひに我が千島列島を侵し、女帝エカテリナは日本語の研究をやらせてゐたといふくらゐだから、北海道を手に入れようと窺つてゐたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
