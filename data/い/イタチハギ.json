    "definitions": [
      {
        "index": 1,
        "gloss": "false indigo (Amorpha fruticosa)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
