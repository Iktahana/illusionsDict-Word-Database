      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stone monument bearing an inscription (esp. memorial for future generations)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "戦争の犠牲者を追悼する「碑」が、公園の一角にひっそりと建てられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代の歴史を伝える「碑」には、当時の権力者の業績が刻まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "文豪の生誕地には、彼の代表作の一節が刻まれた「碑」が立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "震災の記憶を後世に伝えるため、被災地に新たな「碑」が建立された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発見の偉業を称える「碑」の除幕式には、多くの科学者が集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この『碑』は、村の歴史を物語る大切な証だ」と老人は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風雨に晒され、表面の文字が読みづらくなった「碑」を見つめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この崇高な山頂に、一つの新しい石碑が建つてる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして秋の落ちかかる日の光で、人々は石碑の文字を讀むであらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、ああだれが山頂の墓碑を見るか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我も死して碑に辺せむ枯尾花　金福寺に芭蕉の墓を訪うた時の句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマンの教室を出て右を見ると河向いにウィルヘルム一世記念碑のうしろの胸壁の裏側が見える。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある杉垣の内を覗けば立ち並ぶ墓碑｜苔黒き中にまだ生々しき土饅頭一つ、その前にぬかずきて合掌せるは二十前後の女三人と稚き女の子一人、いずれも身なり賤しからぬに白粉気なき耳の根色白し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は東寺に先祖の一海和尚の墓に参って、室戸岬の荒涼で雄大な風景を眺めたり、昔この港の人柱になって切腹した義人の碑を読んだりしたが、残念ながら鯨は滞在中遂に一匹もとれなくて、ただ珍しい恰好をして五色に彩色された鯨漁船を手帳にスケッチしたりしただけであった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらずこういう口碑は人の心を三韓征伐の昔に誘う。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞説らく多摩川に沿うた溝には、独歩の「忘れ得ぬ人々」の作にちなんで、独歩の碑が立っているとか、さらば近代における多摩川風景の祖道者として、花袋の碑は、そこに建てらるべきではなかろうか。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東地震のあとで鎌倉の被害を見て歩いたとき、光明寺の境内にある或る碑石が後向きに立っているのを変だと思って故田丸先生と「研究」していたら、居合わせた土地の老人が、それは一度倒れたのを人夫が引起して樹てるとき間違えて後向きにたてたのだと教えてくれた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかり「地震による碑石の廻転について」といったような論文の材料にでもして故事付けの数式をこね廻しでもすると、あとでとんだ恥をかくところであった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "災害記念碑を立てて永久的警告を残してはどうかという説もあるであろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその碑石が八重葎に埋もれた頃に、時分はよしと次の津浪がそろそろ準備されるであろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこそ例えば津浪を戒める碑を建てておいても相当な利き目があったのであるが、これから先の日本ではそれがどうであるか甚だ心細いような気がする。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある地方では明治二十九年の災害記念碑を建てたが、それが今では二つに折れて倒れたままになってころがっており、碑文などは全く読めないそうである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある地方では同様な碑を、山腹道路の傍で通行人の最もよく眼につく処に建てておいたが、その後新道が別に出来たために記念碑のある旧道は淋れてしまっているそうである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」この邊に天神さんの碑があった。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの石の龜が碑の下から顏を出してゐるやつだ。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから、北上川の岸からこの高原の方へ行く旅人は、高原に近づくに従って、だんだんあちこちに雷神の碑を見るようになります。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじみの西郷銅像と彰義隊の碑も現に自分の頭の上何十尺の土層の頂上にあると思うと妙な気がする。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は空に浮んだ雲を見ながら、この地方の山中に伝説している、古い口碑のことを考えていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "概して文化の程度が低く、原始民族のタブーと迷信に包まれているこの地方には、実際色々な伝説や口碑があり、今でもなお多数の人々は、真面目に信じているのである、現に私の宿の女中や、近所の村から湯治に来ている人たちは、一種の恐怖と嫌悪の感情とで、私に様々のことを話してくれた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの裏日本の伝説が口碑している特殊な部落。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線電信――六〇六――石碑――W.C　――じゃ、間違いっこなし、明朝、練兵場よ。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その村に生田春月の詩碑がある。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中でふとその詩碑のところへ行ってみる気になって海岸の道路を左へそれ、細道を曲り村の墓地のある丘へあがって行った。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地の下の小高いところに海に面して詩碑が建っている。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔古き勾当貞斎が〕古き勾当貞斎が、　　　　　　　いしぶみ低く垂れ覆ひ、雪の楓は暮れぞらに、　　　　　ひかり妖しく狎れにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにロクないしぶみさえない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお街道の岐道には、常夜燈といしぶみとが立っていた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
