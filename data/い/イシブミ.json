[
  {
    "uuid": "28de83df-3fb2-5158-a32f-2722e404d116",
    "entry": "碑",
    "reading": {
      "primary": "いしぶみ",
      "alternatives": [
        "ひ"
      ],
      "is_heteronym": true
    },
    "grammar": {
