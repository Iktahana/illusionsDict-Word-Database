    "definitions": [
      {
        "index": 1,
        "gloss": "caution",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お前の失敗は、慢心に対する戒めだと思え」と父に諭された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "過去の教訓を自分への戒めとして、手帳の最初のページに書き込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は二度と同じ過ちを繰り返さないよう、心の戒めを固くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "成功に浮かれている自分への戒めとして、あえて苦言を呈してくれる友人は貴重だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は学生に向っても、常に奢侈を戒めて質素を説き、生活を簡易化することの利得を説いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこれは、好色の戒めとでもいふものであらうか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこそ例えば津浪を戒める碑を建てておいても相当な利き目があったのであるが、これから先の日本ではそれがどうであるか甚だ心細いような気がする。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戒めとして永く大事にこの言葉の意味の自戒を保ち合って行こう。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康は「上を見な」「身の程を知れ」の「五字七字」を秘伝とまで考えたから、家臣の美服を戒め鹵簿の倹素を命じた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは一方にお万を戒めると共に、久次郎を追い遠ざける手段を講じた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父母は私によくそう云つて戒めた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるものとはともに遊ぶな、とわが友は常に戒めつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、船で巡るか、富山へ上らないぢやあ、松島の景色は論ずべからずと、ちやんと戒められて居るんだよ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は科学の学生がただいたずらにＬ軸の上にのみ進む事を戒めたく思うと同時に、また科学教育に従事する権威者があまりにＳＫ面の中にのみ学生を拘束して、Ｌ軸の方向に飛翔せんとする翼を盲目的に切断せざらん事を切望するものである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡父の戒めかも知れない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ私は女難の戒めをまるで忘れたのではありませんが、何を申すにも山里のことですから、若い者が二三人集まればすぐ娘の評判でございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが母の戒めがありますから、うかとは手も出しませんでしたが、決して心からその実、女を恐れていたのではなく、もしよい機会があったらきっと色の一ツぐらいできるはずになっていたのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリジナリティの無いと称せらるる国の昔話に人まねを戒める説話の多いのも興味のあることである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "連歌に始まり俳諧に定まった式目のいろいろの規則は和声学上の規則と類似したもので、陪音の調和問題から付け心の不即不離の要求が生じ、楽章としての運動の変化を求めるために打ち越しが顧慮され去り嫌い差合の法式が定められ、人情の句の継続が戒められる。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また作者自身の境界にない句を戒められたようである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の間に白帽白衣の警官が立ち交って、戒め顔に佩劔を撫で廻して居る。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度の聖者たちは実際｜故なく草を伐り花をふむことも戒めました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟うに博学多才なる深川夫人が慈善会を代表して、渠が暴行を戒めしに、屈服したりしものならんか。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子は再び出で来らず、膳を進らせんと入行きたる下婢のお松を戒めて、固く人の出入を禁じぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　三　蝦蟇法師がお通に意あるが如き素振を認めたる連中は、これをお通が召使の老媼に語りて、且つ戯れ、且つ戒めぬ。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは道元禅師が、使い残しの半杓の水を桶にかえして、水の尊いこと、物を粗末にしてはならないことを戒められたのである。",
              "citation": {
                "source": "水〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこがしっくり箝まっているとも思えないのであったが、田舎に残っている老母が、どこでも尻のおちつかない、物に飽きやすい彼の性質を苦にして漢学者の父の詩文のお弟子であったその先輩に頼んで、それとなし彼を戒めたので、均平も少し恥ずかしくなり、意地にもそこで辛抱しようと決心したのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、それがこの道の行儀作法ででもあるように、戒めるのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "情慾萩原朔太郎手に釘うて、足に釘うて、十字にはりつけ、邪淫のいましめ、齒がみをなして我こたふ。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雪とひのきの坂上に〕宮沢賢治雪とひのきの坂上に粗き板もてゴシックを辛く畳みて写真師の聖のねぐらを営みぬぼたと名づくる雪ふりていましめさけぶ橇のこらよきデュイエットうちふるひひかりて暮るゝガラス屋根",
              "citation": {
                "source": "〔雪とひのきの坂上に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余計なお饒舌や※言を云う時には口では云わずになるたけきつい顔して無言のいましめをしてやります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心の中の俗物根性をいましめただけの事なのである。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心相こころの師とはならんとも、　　こころを師とはなさざれと、いましめ古りしさながらに、　　たよりなきこそこゝろなれ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもあれ師はいましめて、　　点竄の術得よといふ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "prohibition",
