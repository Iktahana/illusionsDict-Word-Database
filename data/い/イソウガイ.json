[
  {
    "uuid": "bbd4919a-1f5a-5417-8d5c-614c0010bb94",
    "entry": "意想外",
    "reading": {
      "primary": "いそうがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
