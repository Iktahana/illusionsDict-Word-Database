    "definitions": [
      {
        "index": 1,
        "gloss": "each house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕暮れ時、家々に明かりが灯り始める光景は、どこか懐かしさを感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "配達員は手際よく、家々のポストにチラシを投げ込んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "坂道に沿って立ち並ぶ家々の窓からは、瀬戸内海の穏やかな海原が一望できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "正月を控え、家々の門口には立派な門松が飾られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "集中豪雨によって、低地にある家々の床下浸水が相次いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この古い街道筋には、江戸時代の面影を残す家々が今も大切に保存されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "湾も、港市――その家々も、たゞ一様にドス黒く見えてゐる。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまちには、よく似た路地が蜘蛛の巣のように四通八達していて、路地の両側の家々の、一尺に二尺くらいの小窓小窓でわかい女の顔が花やかに笑っているのであって、このまちへ一歩踏みこむと肩の重みがすっと抜け、ひとはおのれの一切の姿勢を忘却し、逃げ了せた罪人のように美しく落ちつきはらって一夜をすごす。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路に落ちる家々の軒の日影が、くつきり黒い。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の軒先に、魚の干物でも乾してあるのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭の日には、家々の軒に、あやめや、菖蒲や、百合などの草花を挿して置くので、それが雨に濡れて茂り、町中が忽ち青々たる草原のようになってしまう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の軒には干魚がかけて乾してあり、薄ら日和の日を、秋風が寂しく吹いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖簾をかけた質屋の店も、既に戸を閉めてしまったので、万象｜寂として声なく、冬の寂寞とした闇の中で、孤独の寒さにふるえながら、小さな家々が眠っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の軒先には、台所のガラクタ道具が並べてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも上根岸八十二番とか思うていたが家々の門札に気を付けて見て行くうち前田の邸と云うに行当ったので漱石師に聞いた事を思い出して裏へ廻ると小さな小路で角に鶯横町と札が打ってある。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに従う村じゅうの家々の代表者はみんな裃を着て、傘ほどに大きな菅笠のようなものをかぶっていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々は、賢き陪臣、ニコチンに、汚れたる歯を押匿す。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "界隈の昇華した名家々々の流れを相互に婚姻を交えている間に、家の人間に土より生い立てる本能の慾望を欠き、夢以外に食慾が持てない咀嚼力の精神になってしまったのも原因の一つであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んでいる邸宅風の家々はむかし鳴海絞りを売って儲けた家だと俥夫が言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると町〔の〕家々ではこんやの銀河の祭りにいちゐの葉の玉をつるしたりひのきの枝にあかりをつけたりいろいろ仕度をしてゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑煮の味というものが家々でみんな違っている。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々に依り、家々に依り、年齢に依り、階級に依り、土地により、悉く家庭の趣味は変って居る。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして家々の窓口からは、髭の生えた猫の顔が、額縁の中の絵のようにして、大きく浮き出して現れていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が其處から再び出て來たときには、家々は坂の上に煌めき、緑色の葡萄畑は暗く浪打ち、空は廣びろとして靜けさに充ちてゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はなほも暫らく、急勾配な屋根のある家々だの、その傍らに聳えてゐる御堂だのを眺めてゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言つても、新橋の上でうす緑色の馬車がどうだとか、或はあの赤いやうな色の滲じみ出し具合がどうだとか、或はまた眞珠に近い灰色をした家々の防火壁の上に貼られてある廣告がどうだとか、と一々取り上げて言ふことは出來ない。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の家々は、石のように雪の下に埋れていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の上の、雪に蔽われた家々には、灯がきらきら光っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巷の人は一人もこの僧を顧みない、家々の者はたれもこの琵琶に耳を傾けるふうも見せない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はこの子を連れて家々の門に立てば、貰い物多く、ここの人の慈悲深きは他国にて見ざりしほどなれば、子のために行末よしやと思いはかりけん、次の年の春、母は子を残していずれにか影を隠したり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "舷燈の光｜射す口をかなたこなたと転らすごとに、薄く積みし雪の上を末広がりし火影走りて雪は美しく閃めき、辻を囲める家々の暗き軒下を丸き火影飛びぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『徒然草』の「あやめふく頃」で思い出すのはベルリンに住んではじめての聖霊降臨祭の日に近所の家々の入口の軒に白樺の折枝を挿すのを見て、不思議なことだと思って二、三の人に聞いてみたが、どうした由来によるものか分らなかった。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを通り抜けて停車場の方へと裏町を歩いていると家々からラジオが聞こえ、それが今聞いた市役所の庭の合唱そのままである。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街では、毎晩、そこ、ここの家々が、武器を持った兵士等に襲われた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、各々、家々へ散らばった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村中の家々は、目ぼしい金目になるようなものを掠奪せられ、たたきつぶされていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
