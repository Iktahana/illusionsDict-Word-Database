    "definitions": [
      {
        "index": 1,
        "gloss": "you",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "汝、何故かくも嘆いているのだ？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "汝の抱える苦しみを、私に打ち明けよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「汝、この試練を乗り越えよ。必ずや、汝の力となろう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "勇者よ、汝は選ばれし者。この地を救うべく、旅に出るのだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "汝等祝福されてあるべきなり、其の他はすべて分解しければ。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ星に甘え、われ太陽に傲岸ならん時、汝等ぞ、讃ふべきわが従者！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のもと林の中に、たゆけくも　仰ざまに眼をつむり、白き雲、汝が胸の上を流れもゆけば、　はてもなき平和の、汝がものとなるにあらずや",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "海はなが身の鏡にて、はてなき浪の蕩揺に、汝はなが魂打眺む　海は汝が身の鏡にて、と云はれるとなんだか罪でも犯した気持になる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてなき浪の蕩揺に、汝はなが魂打眺む……「なーるほど…」と思ふのは、恐らくボオドレエルが私自身より意識的であることに気が付くからである。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等ともに闇くして、且はひめやか。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が底を探りたる、者とてはなく、汝がゆたけき内奥を、知るものとてなかりけり、さまで汝等秘密をば、守らんこと敏なりき！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　　　（しかも汝とていまは亡し）",
              "citation": {
                "source": "四八　黄泉路",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔つて疲れて私の瞼はイラ痒いとは云へ、人よ汝がそのやうなことを気にするのであれば、あゝ、それは世間をばかり心の中に相手として置いてゐるからだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "天日の下に口をあけ汝の過去を哄笑せよ。",
              "citation": {
                "source": "昔の小出新道にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝の歴史を捨て去れかし。",
              "citation": {
                "source": "昔の小出新道にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等おのれを愛するが如く、汝の隣人を愛せよ。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝唯一人のそれとも最後の、情人か？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……愛せよ揺籃より柩にまで汝を愛せし者を愛せよ、わが愛したる者のみ独り、今も猶我をば愛す。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "火に充ちし手のナポリの聖女、心菫に泣ける薔薇、聖ギヂルが花、汝は見しや天の砂漠に汝が十字架？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちよ、白き霊体、燃ゆる汝が空より落ちよ、――地極の聖女はわが目にはいと聖なれば！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠は汝が眼の裡に微笑むでゐた……此の世を去つた炬火、空にて再びともれよ！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　惡魔よりも孤獨にして汝は氷霜の冬に耐へたるかな！",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて何物をも信ずることなく汝の信ずるところに憤怒を知れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて欲情の否定を知らず汝の欲情するものを彈劾せり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて何物をも汝は愛せず何物もまたかつて汝を愛せざるべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝　寂寥の人悲しき落日の坂を登りて意志なき斷崖を漂泊ひ行けどいづこに家郷はあらざるべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "情慾萩原朔太郎手に釘うて、足に釘うて、十字にはりつけ、邪淫のいましめ、齒がみをなして我こたふ。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雪とひのきの坂上に〕宮沢賢治雪とひのきの坂上に粗き板もてゴシックを辛く畳みて写真師の聖のねぐらを営みぬぼたと名づくる雪ふりていましめさけぶ橇のこらよきデュイエットうちふるひひかりて暮るゝガラス屋根",
              "citation": {
                "source": "〔雪とひのきの坂上に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が枡に足を蹈み込んだばかりに、肥つた四十年配の女が二人、飛び込んで来て、「ああよかつた、端ッこでもあつてこそよございました、もう五分早ければよございました、惜しいことをしました、私は今朝から一服もしません、ええでも一幕見てから一服することにいたしませう」なぞと、イキセキ切つて云ふのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私あの家、面白いの家と思いました』と幾度も繰返して口惜しがった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に買った大久保の家に、書斎を新しく建て増しする時、一切の設計や事務を妻に一任して、自分は全く無頓着で居たが、それでも妻が時々相談を持ちかけると、『もう、あの家よろしいの時、あなた言いましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩秋の日に、庭の桜が返り咲きをしたのを見て、『春のように暖かいから、桜思いました。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
