        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こゝろ宮沢賢治曇りてとざし風にゆるそれみづからぞ樹のこゝろ光にぬるみ気に析くるそのこと巌のこゝろなり樹の一本は一つの木規矩なき巌はたゞ巌",
              "citation": {
                "source": "こゝろ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌ト一雄、丈夫デ可愛ラシイ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲母の口して歌つたよ、背ろに倒れ、歌つたよ、心は涸れて皺枯れて、巌の上の、綱渡り。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は苦笑しながら直ちにも雲を変じ巌に化しても大事ないとは思った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、重く堅い巌を火の力により劈き、山形にわたくしを積み上げさせたということは、仇おろそかのすさびに出来る仕事ではない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "命終せんとして雲に化し巌に化す。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屏風巌をめぐりて般若方等二つの滝の見ゆる処に出ず。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌丈な鉄棒の頂上に鉄の円盤を固定したもので、人の手の力くらいでは容易に曲げ動かすことが出来ないように出来ている。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "円タクで白山坂上にさしかかると、六十恰好の巌丈な仕事師上がりらしい爺さんが、浴衣がけで車の前を蹣跚として歩いて行く。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　慶長十七年卯月十三日　豊前小倉の海上の　離れ島に（Ｏ・Ｌ）Ｔ　父の敵佐々木巌流と　彼を護る剣士三十余名と　決戦すＳ＝海上　数艘の小舟に分乗した、佐々木巌流の一隊。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪然たる巌流、先頭の舟上に立つ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて巌流等の、　舟は島に着く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸を巌流を先頭に進む三十有余名。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌流大刀の鞘を払って、鞘を捨てた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "城下より来たりて源叔父の舟頼まんものは海に突出し巌に腰を掛けしことしばしばなり、今は火薬の力もて危うき崖も裂かれたれど。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その岩が雨に洗い出されて山のいただきには奇巌がいたるところに露出している。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒霞渓の巌と紅葉については、土地の者の私たちよりもよその人たちの方がくわしいだろう。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の中へつき出た巌の上に立っている宿屋では、夏の客をむかえるとて、ボートをおろしている。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五輪峠五輪峠と名づけしは、　　　地輪水輪また火風、（巌のむらと雪の松）　　　峠五つの故ならず。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝくらき黄泉路の巌に、　　その小き掌もて得なんや。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早池峯山巓石絨脈なまぬるみ、　　　　　苔しろきさが巌にして、いはかゞみひそかに熟し、　　ブリューベル露はひかりぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車中〔二〕稜堀山の巌の稜、　　一｜木を宙に旋るころまなじり深き伯楽は、　　しんぶんをこそひろげたれ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足がうごいてゐるかどうかもわからずからだは何か重い巌に砕かれて青びかりの粉になってちらけるやう何べんも何べんも倒れては又楢夫を抱き起して泣きながらしっかりとかゝへ夢のやうに又走り出したのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その巌丈な石の壁は豪雨のたびごとに汎濫する溪の水を支えとめるためで、その壁に刳り抜かれた溪ぎわへの一つの出口がまた牢門そっくりなのであった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて二階に寝床を拵えてくれた、天井は低いが、梁は丸太で二抱もあろう、屋の棟から斜に渡って座敷の果の廂の処では天窓に支えそうになっている、巌乗な屋造、これなら裏の山から雪崩が来てもびくともせぬ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私も嬉しいわお妙ちゃん」笑いながらこんな事を云った。",
              "citation": {
                "source": "ひな勇はん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのいわおのような体をした覆面の頭目の体がふがいなくもフラフラよろめいたかと思うと、やがて、腰のへんからふたつに折れて、ドシンと床にひっくりかえった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬や　春先、　見かけるのは　たいてい　土のなか、　おうし土手のてっぺん　岩場のところ、　つまり　むぎむぎいわおの　ふもと。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして　見えてくる、　いわおの下、　きつねめさんの　こしらえた　おうちの　ひとつ。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　歩いてほどなく遠くに見えてくるウミガメフーミ、いわおの小さなでっぱりに、ひとり悲しそうにこしかけていてね、近づくにつれ聞こえてくるため息、まるでむねがはりさけたみたい。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
