      {
        "index": 1,
        "gloss": "blue rock-thrush (Monticola solitarius)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
