    "definitions": [
      {
        "index": 1,
        "gloss": "director (of a hospital, institution, academy, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其処で患者は増すし却々人気も好かつたが、暫くして院長に大学出が来ると、父が大学出でないといふ理由の下に副院長に大学出を呼び寄せて父をその下にやつたのだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんないい人が、どうして死んだのだらう、と追悼記の一ばん前の頁をひらいて見ると、そこに、學院長Ｋ・Ｍといふ人の弔詞が在ります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草取りに来てゐた人も院長の車夫もレントゲンの助手もみな面白がって手伝ひに来た。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき窓に院長が立ってゐた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）院長はたうたうこらえ兼ねて靴をはいて下りて来た。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かな愚かな表情を、院長さんとその園芸家とどっちが頭がうごくだらうといった風の――えい糞考へても胸が悪くなる。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長がすぐ出て行って農夫に云った。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）院長は白いきれを杭の外へまはした。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "設計図を拵えて来て院長室で二人きりで相談しなければだめだと考へた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんたうにあなたのお助かりになつたのは、院長さんも不思議だと云つてらつしやいましてよ……」と、私の生命がどんなに危かつたかを初めて聞かしてくれた時、武井さんはしまひにかう力の籠つた聲で云つて、ぢつと私の顏を見詰めてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長さんも弱つて入らつしやるんですつて。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長が大事をとつてその日をなかなか許してくれないのがもどかしかつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勞働の時間には院長始め修道士全部が働きます。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、別に修道に關したものではないのですが、此處の院長はもと考古學者か何かだつたやうです。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長さんは創立後五十年だと云つてゐますから約あと三十年ですね。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして院長を始めすべての修道士がそれを取卷いて、生別の祈祷を捧げてやります。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長の軍医正が、兵卒に貯金をすることを命じたのだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方の板張りの壁には、白いペンキが塗られ、東側の壁には、院長の銅貨大の勳章を胸に三つ附けた肖像畫が高く掛けられて、十脚ほどの細長いテエブルがそのしたにひつそり並んでゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが、ここの院長かい。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長に案内され、葉藏の病室のまへまで來たとき、部屋のなかの陽氣な笑ひ聲を聞いた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」院長は、さう答へながらドアを開けた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」院長はふりかへつて兄へさう囁きつつ、葉藏の傍へあゆみ寄つた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長の眼は、眼鏡の奧で笑つてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長先生のお供をして、これからみんなでひるめしたべに出ませうよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「院長と四人して相談さ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君のいま着てゐるのは、院長から借りた着物だつてね。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長の息子の着物さ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長は朝はやく葉藏の病室を見舞つた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　院長はさう言つて、はにかんだやうな眼を海へむけた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
