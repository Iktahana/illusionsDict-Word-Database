[
  {
    "uuid": "54e46110-4c6f-572d-ad2a-2e20ecdd39b8",
    "entry": "今思うと",
    "reading": {
      "primary": "いまおもうと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
