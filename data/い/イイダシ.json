        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大臣の記者会見での言い出しは、予想よりもずっと穏やかなものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の冒頭、彼が「まず、この問題の根源から話しましょう」と切り出した言い出しには、一同が耳を傾けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、急にそんな言い出しでどうしたの？」と彼女は怪訝そうに尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "裁判官は、被告側の弁護士の最初の言い出しに、注意深く耳をそばだてた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その物語の言い出しは、読者の心に静かな感動を呼び起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いや、あのさ、実は…」という彼の言い出しに、場の空気が一変した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "相手の強硬な言い出しに、交渉は難航することが予想された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "寺の老僧とも懇意になり、ついにある時、自分がその住持になりたいと言い出し、夫人と次のような問答をした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、もっと早くから言えば何か方法もあったのに、いまさら、そんな事を言い出しても無理だとは思ったが、とにかく私は控室から料理屋の帳場に電話をかけた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日下女が薬取りから帰ると急に暇をくれと言い出した。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとふと主人は、こんなことを言い出した。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が少しも隔意なき得心上の相談であったのだけれど、僕の方から言い出したばかりに、民子は妙に鬱ぎ込んで、まるで元気がなくなり、悄然としているのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで家中の人が皆集って、それをどうしようかと相談しましたが、可哀相なような気持もするけれど、見ずに置くのも気にかかる、とにかく開いて見るがよいと、あれの父が言い出しまして、皆の居る中であけました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近――　三次此処まで来て立ち止って、勝坊に、Ｔ「隠れんぼうをして遊ぼうか」　と言い出した。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が、とある町角まで来た時、五郎蔵が此の筋を曲ろうと言い出した。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って言い出しにくい様子。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "村会議員は、ごた／＼言い出して、すぐ自分から引いてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし吉田は誰もみな一日の仕事をすましてそろそろ寝ようとする今頃になって、半里もある田舎道を医者へ行って来てくれとか、六十も越してしまった母親に寝ずについていてくれとか言うことは言い出しにくかった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田は母親がそれをおずおずでもない一種変な口調で言い出したとき、いったいそれが本気なのかどうなのか、何度も母親の顔を見返すほど妙な気持になった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは吉田が自分の母親がこれまでめったにそんなことを言う人間ではなかったことを信じていたからで、その母親が今そんなことを言い出しているかと思うとなんとなく妙な頼りないような気持になって来るのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、キザもキザ、それに私のような野暮な田舎者には、とても言い出し得ない台詞ですが、でも私は大まじめに、その一言を言ってやりたくて仕方が無かったんです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）なんて乱暴な事を平然と言い出しそうな感じの人たちばかりだ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンドレア・デル・サルトの、……」　ばかに大きな声で、突然そんなことを言い出した人があるので、笠井さんは、うしろを振りむいた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私も加わり、暫く、黙って酒を飲んで居ると、表はぞろぞろ人の行列の足音、花火が上り、物売りの声、たまりかねたか江島さんは立ち上り、行こう、狩野川へ行こうよ、と言い出し、私達の返事も待たずに店から出てしまいました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恋愛は神聖なり」なんて飛んでも無い事を言い出して居直ろうとして、まあ、なんという図々しさ。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前掛で涙を拭きながら、父の給料の事やら、私たちの洋服代の事やら、いろいろとお金の事を、とても露骨に言い出しました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも民主主義とは、――いや、これはどうも、あまりに唐突で、自分で言い出して自分でおどろいている有様で苦笑の他はございませんが、実は私は、まったく無学の者で、何も知らんのです。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか私がたいへん善人であるという事を言おうとして、「あなたはサタンだ」なんて言い出したわけではなかろう。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と申しますと、やまねこはまだなにか言いたそうに、しばらくひげをひねって、眼をぱちぱちさせていましたが、とうとう決心したらしく言い出しました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するともう、みんなはがやがやと言い出して、みんな水に飛び込んでしまいました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士は寝たままそれを眺め、又ひとりごとを言い出した。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、早よう……孫の墓へ参りました帰り途に、裏通りを近道して、祇園町へ帰ろうと致しましたれば……あ……あの桃の花の上がっておりまする、蔵元屋の……お墓の前で……」　すこし落着きかけた婆さんの歯抜け※が又もガタガタ言い出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は朝起きて、日曜日のことゆえ朝食も急がず、小児を抱て庭に出で、其処らをぶらぶら散歩しながら考えた、帯の事を自分から言い出して止めようかと。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今日こそ父に向い、断然｜此方から言い出して秘密の有無を訊そうと決心し、学校から日の暮方に帰って夜食を済ますや、父の居間にゆきました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして喜んで私塾設立の儀を承諾した、さなきだにかれは自分で何らの仕事をか企てんとしていて言い出しにくく思っていたところであるから。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも何よりも、おぬいが父を思いだす時思いださずにはいられないのは、父が死ぬちょうど一週間前、突然おぬいに、部屋の中を一まわり歩いてみたいから肩を貸してくれといいだした時のことだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしばらくしてから、やや俯向いたまま震えた声で、しかしはっきりといいだした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
