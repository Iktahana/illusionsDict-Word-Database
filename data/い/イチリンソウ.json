        "examples": {
          "standard": [
            {
              "text": "春先の雑木林を散策していると、落ち葉の間から白い一輪草が顔を出しているのを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "一輪草はその名の通り、細くて弱々しい茎の先に可憐な白い花を一つだけつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "植物図鑑の写真を頼りに、昨日山道で見かけた小さな花が一輪草だと確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一輪咲いたが一輪草、二輪咲くのが二輪草、まことの花を知る人もなし。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "花といへば、風鈴草、高山の虫取菫、蒜の花、一輪咲いたが一輪草、二輪咲くのが二輪草、まことの花を知る人もなし。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
