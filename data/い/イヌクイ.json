          "literary": [
            {
              "text": "（イール「ボブちやんさつきの犬こはかつたね」ボブ「でもあの犬食いつきやしなかつたよ」）さう！",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁方近くらしいぬくい朝ぼらけを告ぐるやうな鶏の声が、距離不明の辺から聞えて来た。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは日中はオバーなどはいらないくらいぬくい。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっとしている小ツルに、松江は笑いかけ、「な、コツやん、べんとが、まだ、ここで、ぬくいぬくい」　そういって腰のあたりをたたいてみせた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さんの手々、ぬくいぬくいなあ。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
