          ],
          "literary": [
            {
              "text": "パーソナルコンピューターの世界に物分かりのいい大人しかいなくなったら、どうなっちまうんだよ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お好み焼そのものも、いい大人の食うものとは思えない。",
              "citation": {
                "source": "ああ東京は食い倒れ",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それですよそれ、いい大人がそんな馬鹿をして、犠牲になるのは哀れな小犬なのだわ。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや風采といい大人びた態度など十も年上に覚えられる。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには評判のいいおとなしい詩人が、招待されたすべての客から賞讃されてすわっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
