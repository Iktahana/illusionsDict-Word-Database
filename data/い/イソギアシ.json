    "definitions": [
      {
        "index": 1,
        "gloss": "fast pace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "通勤ラッシュで、人々は皆、急ぎ足で駅へと向かっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプロジェクトは納期が迫っているため、急ぎ足で作業を進める必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "季節は急ぎ足で過ぎ去り、あっという間に冬の気配が濃くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は何か急用でもあるのか、いつもより急ぎ足で通りを横切っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "変化の激しい現代社会では、何事も急ぎ足で対応することが求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発表まで残り少ない時間で、彼は資料作成を急ぎ足で仕上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もうこんな時間か、急ぎ足で帰らないと夕飯に間に合わないぞ」と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、あの時の相手が龜と子供でなく、まあ、たとへば荒くれた漁師が病氣の乞食をいぢめてゐたのだつたら、あなたは五文はおろか、一文だつて出さず、いや、ただ顏をしかめて急ぎ足で通り過ぎたに違ひないんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次は勝坊の頭を撫でて、Ｔ「いい子だから早く帰んな」　と言い捨てて急ぎ足に去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　急ぎ足にすたすたと橋の袂にまで来た時、一人の浪人者とどんと突き当ってはずみを喰らって三次すってんどうと倒れた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近の通り　屋根の上からひらりと跳び下りた三次、その儘立ち去ろうとしてバッタリ急ぎ足にやって来たてっきり鉄と出合わした。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "若侍も「それでは致し方厶らぬ」と、進藤と別れ一同急ぎ足に走る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急速なるＦ・Ｏ）　＝（Ｆ・Ｉ）道――　急ぎ足に歩いて居る日下部典六の一行。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぎ足の典六等の一行。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、半次を振り返って、Ｔ「喧嘩らしい」　と二人急ぎ足に去る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉が又床几に腰掛けて茶を飲まんとした時、急ぎ足に半次が現れた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）　　　其の夜仲蔵をとっちめると云った五郎蔵の言葉が実現した　＝（Ｆ・Ｉ）夜の町　お光が急ぎ足に歩いて来る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前方から目明しふんぞり七兵衛がふんぞり返って急ぎ足に来る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　オヤッと若侍、急ぎ足に二人の傍へ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急ぎ足にて梯子を登る音す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時床の石畳みの上を急ぎ足で来る靴の音がした。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに急ぎ足に町を通り過ぎてゆく、彼等は一體何處へ行かうとしてゐるのか知ら？",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、夫は壁掛を手に取ると、急ぎ足にアトリエの方へ立つて行つた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、滿足らしい微笑を浮べながら、急に勢づいた樣子で今まで歩いて來た道を急ぎ足に戻り始めた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母が「早く」と目顔で……伊吉急ぎ足に近づく。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）６７＝（Ｆ・Ｉ）街道　急ぎ足に行く伊吉。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）67＝（Ｆ・Ｉ）街道　急ぎ足に行く伊吉。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいじゃ、先へ帰ります」　買物があるという姑を八百屋の店に残して、彼は暗い星の冴えた小路へ急ぎ足で入った。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一度、黒い煙突の影を振返ると急ぎ足で横町に外れた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "半三郎は赤面しいしい一礼して、急ぎ足に大根畠を踏み分けて行った。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い夜道を急ぎ足で歩きながら園は地面を見つめてしきりに右手を力強く振りおろした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして危くむこうからも急ぎ足で来る人――使い走りをするらしい穢ない身なりの女だったが――に衝きあたろうとして、その側を夢中ですりぬけながら、ガンベといっしょに来た時のように制帽を懐ろにたくしこんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廉平は急ぎ足に取って返して、また丘の根の巌を越して、苫船に立寄って、此方の船舷を横に伝うて、二三度、同じ処を行ったり、来たり。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱心たりと心｜急立ち、本郷の通へ駈出でて、東西を見渡せば、一町ばかり前に立ちて、日蔭を明神坂の方へ、急ぎ足に歩み行く後姿はその者なれば、遠く離れて見失わじと、裏長屋の近道を潜りて、間近く彼奴の後に出でつ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大学の制帽を被って、旅行用の大革包を提げた若い男が、四辺の光景を幾度か見返りながら、急ぎ足で角川家の門を潜った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、三日経ってまた赤玉へ行くと、瞳は居らず、訊けば、今日松竹座アへ行くいうたはりましたと、みなまできかず、道頓堀を急ぎ足に抜けて、松竹座へはいり、探した。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官服の怪人は、さびしいやしき町を、いそぎあしで歩いていきます。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
