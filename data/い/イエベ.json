        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "イエベ肌には、ゴールド系のアイシャドウやコーラル系のリップがよく似合うと言われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はイエベだから、暖色系の服を着ると顔色が明るく見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私のパーソナルカラー診断では、イエベ春タイプと診断されました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イエベ向けのファンデーションは、オークル系の色味が豊富です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イエベの人は、シルバーよりもゴールドのアクセサリーの方が肌になじみやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私は完全にイエベだから、オレンジ系のチークが手放せないの。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ブルベの友達とコスメをシェアする時、イエベの私には合わない色が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
