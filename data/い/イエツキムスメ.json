          ],
          "literary": [
            {
              "text": "淡島家の養子となっても、後生大事に家付き娘の女房の御機嫌ばかり取る入聟形気は微塵もなかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黒沼の家の娘が死んだそうで……」「家付き娘だな」「そうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「内儀のお滝は、好い女で五十そこそこで、家付き娘で、身体が弱い。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "「内儀のお瀧は、好い女で五十そこ／＼で、家付き娘で、身體が弱い。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            }
          ]
