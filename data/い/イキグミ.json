    "definitions": [
      {
        "index": 1,
        "gloss": "eagerness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新事業を立ち上げるにあたって、彼の意気組は周囲を圧倒するほど凄まじいものがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今度こそ絶対に優勝してみせる」という強い意気組が、彼の言葉の端々に表れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "口先だけの意気組ではなく、具体的な計画と行動でその熱意を示してほしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "格上の相手を倒そうという選手たちの凄まじい意気組が、スタジアムの空気を一変させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最初は盛んな意気組を見せていたものの、予期せぬトラブルが続くと次第に弱腰になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年温めてきた企画の実現に向けて、プロジェクトメンバーの意気組は今や最高潮に達している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は入社当時の瑞々しい意気組を忘れず、定年を迎えるまで常に新しい課題に挑戦し続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "つい今しがたまで示していた昂然たる意気組もプライドもあとかたもない。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度こそはと意気組を新たにしてかかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お沢　ええ、もう一層（屹と意気組む）ひと思いに！",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十一　慶造は言効なしとや、握拳を膝に置き、面を犯さんず、意気組見えたり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "変化出でよ、一喝で、という宵の内の意気組で居たんです。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真砂町、と聞返すと斉しく、屹とその座に目を注いだが、驚破と謂わば身をもって、影をも守らん意気組であった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　出がけの意気組が意気組だから、それなり皈るのも詰りません。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　双六谷へは、翌早朝と言ふ意気組、今夜も二世かけた勝敗は無しに、唯睦まじいのであらうと思ふ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に鬼神に感応ある、芸術家に対して、坊主の言語と挙動は、何となく嘗め過ぎたやうに思はれたから……其のまゝ肩を聳やかして、三つ四つ輝く星を取つて、直ちに額を飾る意気組。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本中を真半分に割って東の方に在るものは皆、満月に買うてやりたいほどの意気組であった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は市内｜櫛田神社（素戔男尊、奇稲田姫を祭る）、光雲神社（藩祖両公を祀る）、その他の神事能を、衷心から吾事として主宰し、囃子方、狂言方、その他の稽古に到るまで一切を指導準備し、病を押し、老衰を意とせず斎戒沐浴し、衣服を改めて、真に武士の戦場に出づる意気組を以て当日に臨んだ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は意気組さえよければ型の出来栄えは第二第三と考えていたらしい実例がイクラでも在る。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃互いに二十代であった両氏の意気組は非常なもので稽古もずいぶん猛烈であったが、サテ能の当日になると文字通り焦げ附くような暑さであった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜多流ばかりが能でないという事を事実に証明してやろう……という程のことでもなかったが、それ位の意気組でわざと宝生流のために尽力した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鼻を折る」とか「折られる」とかいうのもこれと同様の意味で、こちらの「どうするか見ろ」とかかって行く意気組と共に、先方の同じような突張り返った鼻の表現がタタキ落とされるかヘシ曲げられるかして、「もう堪忍」とか「無念」とかいうセンチメンタルな表現になるのを形容した言葉であります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鼻息が荒い」というのは、決して凹まないという猛烈な意気組が鼻の先に横溢して、意志や感情の風雨雷電をはためかしているのを鼻息になぞらえたものでありましょう。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実か虚偽か、本気か冗談か、平気か狂気か、イカサマ師か怪物か、そうして有罪か無罪か判断に苦しむ大胆さ、しかも生前の主人ダメス王の真価値は勿論、神の権威の軽重までも計りそうな意気組を示しております。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の岩戸の昔よりという意気組であります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず山中毒とでも申すか、五里霧中とやらに※徊いました手前、真人間から見ますると狂人の沙汰ですが、思いの外時刻が早く、汽車で時の間に立帰りましたのを、何か神通で、雲に乗つて馳せ戻ったほどの意気組。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは一つこの意気組みで会を起そうではないか。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、彫工会の発会等もすべて落着し私はこれから大いにやろうと意気組んでいた矢先、大病に罹りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大病をした時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる悪党、または如何なる芸術家も及ばない天才的な、自由自在な、可憐な、同時に斃れて止まぬ意気組を以て、冷厳、酷烈な現実と闘い抜いて来たか。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロ文化の末路　しかしこうした江戸草創時代の元気横溢した平民の気象――逃げ水を追つつまきつつ家を建てた時代の芳烈な彼等の意気組は、太平が続くに連れて、次第に頽廃的傾向即ちブル気分を帯びて来た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その困難を打ちひらいて、若い時代にふさわしい希望と生活にうち向う気力を鼓舞しようとする意気組から、これらのおびただしい恋愛論は簇出したのであったろうか。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜は一つお願いがあって参りました」　そういう私の意気組みが平生と違っていたと見え、「そうですか、何かむずかしいことですか」と氏はほほ笑んでいられた。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "馬専門の彫刻家のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "「老いて楽をしようと思えば若いうち蟻のように働け」「圧しつけられてこそ味の出る沢庵」と、搾取と闘おうとするわれわれの当然の意気組みをそらすような一番始末にいけない「諦め」でフぬけとなるよう、塩梅しているところは巧なものである。",
              "citation": {
                "source": "『キング』で得をするのは誰か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日から明日へと作家の意気組が向うよりも、今日かかる朝夕の有様のきのうは、おとといはと目が誘われてゆく底に、極めて複雑な内外の現代の心理がひそめられている。",
              "citation": {
                "source": "今日の文学の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "森律子が大正二年に渡欧した折の意気組はまだ新鮮で、徐々に女優が商業化されたものになってゆく一歩が、無邪気に歩み出されていたのであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの十頁の紙にどれ丈けの尊いものが費されてあるかを思ひますと涙せずにはゐられません、両氏の強いあの意気組みと尊い熱情に私は人しれず尊敬の念を捧げてゐた一人で御座います。",
              "citation": {
                "source": "編輯室より（一九一四年一一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきぐみばかりつよくて、さて、書くてがかりがつかめるのかわからなくなる。",
              "citation": {
                "source": "両輪",
                "author": "――創造と評論活動の問題――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
