[
  {
    "uuid": "e180ca06-87a1-587e-a0e2-909211e9acae",
    "entry": "意気組",
    "reading": {
      "primary": "いきぐみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
