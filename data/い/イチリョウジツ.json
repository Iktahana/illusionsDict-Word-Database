    "definitions": [
      {
        "index": 1,
        "gloss": "(a) day or two",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「納期については、一両日中にスケジュールを調整して、改めて正式にご連絡差し上げます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「熱は下がったみたいだけど、病み上がりなんだから、あと一両日は家でゆっくり休んでいなさい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "注文した本が届くまでに一両日かかるそうなので、週末の連休にゆっくり読むことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また出ますと云うたら宿は何処かと聞いたから一両日中に谷中の禅寺へ籠る事を話して暇を告げて門へ出た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその一両日前の新聞記事に巡査が高圧線の切れて垂れ下がっているのを取りのけようとして感電したことが載せてあったのを思い出したので、友人にそれを読んだかと聞いたら読んだという。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムお気に入りの銀子が、手洗いの湯やタオルを盆に載せて持って行くと、ちょうど診察が済んだあとで、一両日中に入院でもするような話であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの一両日に、坂田と云う道学者が先生を訪問はしませんか、と尋ねて、来ない、と聞いただけを取柄。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ただいまさしあげました鶫は、これは、つい一両日続きまして、珍しく上の峠口で猟があったのでございます。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月号を今｜編輯していますので、一両日中に頂けますと何よりです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "師走もあと一両日、商人、尻に火のついた思いでございます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう飼い主の家に相談して一両日静養させてやる事にした。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一両日の間は時々｜子猫を捜すかと思われるような挙動を見せた事もあったが、それもただそれきりで、やがて私の家の猫にはのどかな平和の日が帰って来た。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもしあなたが、滞在しておられるなら、一両日中にはあなたと一緒に出かけることが出来ると思いますが、――とにかく、この紙は置いて行って下さい。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご逗留なら、一両日中にはご同行しようかと思いましたが――では、この紙はあずからせてください。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一両日中は二人とも荷ほどきしたり、私物をうまく置こうと悩んだりしながら時間をとられたが、終えると徐々に腰も落ち着いてきて、新しい環境に慣れ始めていった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "一両日もあれば疲れもとれるだろう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ではぼくは一両日中にその真鍮箱と紙との成り行きをご報告に参ります。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィルソンさん、一両日中には意見をお知らせしましょう。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は古井、稲垣両氏と長崎に至る約にてその用意を取り急ぎおりしに、出立の一両日前、重井、葉石、古井の三氏および今回出資せる越中富山の米相場師某ら稲垣と共に新町遊廓に豪遊を試み、妾も図らずその席に招かれぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義妹夫妻がここに赴任してゐるので、一両日のつもりで途中下車をこころみたのであつたが、この有りさまでは切符の期間も切れさうだ。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄様も一両日中に手紙を差しあげるとか申して居りますが、何分御存じのとほり筆無精ですから当てにはなりません。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、一両日中にＲを案内して軍港見学の許可を乞ひ、鳥海、摩耶、愛宕その他を拝観する念願だつた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は回答を一両日延ばした。",
              "citation": {
                "source": "『ユリイカ』挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさうと、住居不定のまゝ今迄幾度かの召喚にも応ぜられなかつたゝめにいよいよ一両日中に解決しないと、汚名が決定するといふ瀬戸際に及んだので、彼は召喚状をふところにしてやはり母の許を訪れるより他はなかつた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妹がおりましたが、一両日前にほかへやりました」と、栄之丞は火鉢に粉炭をつぎながら答えた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この造船所の構内で、茲一両日の間に、誰れか誤って機械油をぶちまけて了った、と言う様な事はなかったでしょうか？",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "車中大月はこの犯罪は、大変微妙なものであるが、もう大体の見透はついたから、茲一両日の内には大丈夫犯人を告発して見せると言う様な事を、自信ありげな口調で二人に語り聞かせた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いま、裕福な自分の物質的な地位の上に刻々に迫ってくる黒い影を感じながら、この一両日の間と言うものは、どんなにか恐ろしい苦悩の渦に巻き込まれていた事だろう。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子は彼を「酒と刀」だと言つてゐたが、一両日前彼が子供達を其の山房へつれて行つてから、彼等のあひだにＭ、Ｈ君が子供達に好かれてゐないことが解つた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "一両日前から、彼は水着や帽子を買ひに、長男と小さい京子とをつれて、丸の内へ行つて見た。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は京子と約束したとほりに、一両日で又海岸へ行く積りであつたが、帰れば帰つたでつひ用事に絡らみつかれた。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "予はこの監に来てから、最初一両日は換刑の者と一しょにおかれ、次に一週間ばかり独房におかれ、最後には他の軽禁錮の者とともに三人でおかれた。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
