[
  {
    "uuid": "45d64b15-d776-5017-85cc-7d47338685f4",
    "entry": "一両日",
    "reading": {
      "primary": "いちりょうじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
