          ],
          "literary": [
            {
              "text": "」かう云つて、無暗には人を入れず、渠は一閑張りの禿げかかつた机に倚つて、好きな思索に耽るのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「書齋」は、義雄が白地の浴衣を着たまま机に右の片肱をかけ、横向きに洋書棚を背にして、その前の壁ぎはに、今一つの一閑張りのところ／″＼禿げたのを置いて、上に棕梠の盆栽をのせた場面のが寫つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一閑張りの机が一時は流行しました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "深山は古い笹村の一閑張りの机などを持って、別の家へ入って行った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "入って行くと、子供は産衣そのままの姿で、蚤を避けるために、風通しのよい窓の側に取り出した一閑張りの広い机のうえに寝かされてあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「去年も今頃だったろう、あれは幾日位だったろうかな　少し暇のある夕飯後など、彼等は、小さい一閑張りの机の上に地図を拡げ乍ら話し合った。",
              "citation": {
                "source": "われらの家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六疊敷きの、外に向つたところに小さい一閑張りを置いて、その上で義雄が筆を走らせてゐるそばへ來て、かの女は片ひぢを突いて横になり、黄の勝つた中形｜矢絣りの廣島銘仙の綿入れの、太く時色の※の出たところを、足袋の親指でさはりながら、云ひにくさうに、「あたいでも成れるだろか」と聽いたこともあつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱入り一閑張りの、細長い柱かけの、瓢箪の花入れのお土産を取出して見せながら、母は言い憎そうにいうのだった。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうキチンと座敷の中がとり片づけられて居、トランプをするために買つたと云ふ大きな一閑張りの机が、座敷の真ン中へ、彼の花車な体をぐたりと靠せかけさせるために持ち出されてゐた。",
              "citation": {
                "source": "イボタの虫",
                "author": "中戸川吉二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言ったまゝ、後は復た黙あって此度は一層強い太息を洩らしながら、それまでは火鉢の縁に翳していた両手を懐中に入れて、傍の一閑張りの机にぐッたりと身を凭せかけた。",
              "citation": {
                "source": "別れたる妻に送る手紙",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "容易ならぬ時代を思い顔な子息の勝重をかたわらにすわらせて、客と一緒に大きな一閑張りの卓をかこんだところは、それでも同じ血を分けた親子かと思われるほどだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "布団は、郷里の妹が手織りで作ったのを送って来たが、机は夜店で一閑張りを買った。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六畳のまん中に、一閑張りの朱机が一個、硯箱、インキ壺、雑然とした書類の束。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "場末の貧弱な下駄屋の二階の、ただ一間しかない六畳に、一閑張りの破れ机を二つ並べて、松村武とこの私とが、変な空想ばかり逞しゅうして、ゴロゴロしていた頃のお話である。",
              "citation": {
                "source": "二銭銅貨",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
