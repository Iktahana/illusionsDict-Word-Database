          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その政治家の威高な態度は、国民の反感を招いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は実力もないのに、部下に対して威高な態度をとっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「私の言うことだけが正しいんだ！」と、彼は終始威高な口調でまくしたてた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の成功体験が、彼の性格に威高な側面をもたらしたのかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その作家は、自身の作品に対する揺るぎない自信からか、どこか威高な雰囲気を漂わせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の威高ぶりは、周囲との軋轢を生む原因となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "神と坐す大稜威高領らせば、八紘一つ宇とぞ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三段抑々蒙古ときこゆるは草莽にして胡沙を馳駆し、万里北に蔓つて勢漢土に臨むや、金を滅し、宋を傾け、余威高麗に及んではしばしば本朝をもうかがふ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも全国で合祀励行、官公吏が神社を勦蕩滅却せる功名高誉とりどりなる中に、伊勢、熊野とて、長寛年中に両神の優劣を勅問ありしほど神威高く、したがって神社の数はなはだ多かり、士民の尊崇もっとも厚かりし三重と和歌山の二県で、由緒古き名社の濫併、もっとも酷く行なわれたるぞ珍事なる。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "せだかさは、稜威高き所の真物といふ事で、真物は其神格を褒めたのだ。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "えびすらの稜威高しと仰ぐ日を待たで去りにしわが妻あはれ妻逝きて早や五十日木犀のかをれる庭も荒野のごとし　もうなにも書くことがないやうな気もするが、日記をめくつてゐると、また言ひたいことが出て来るかも知れない。",
              "citation": {
                "source": "妻の日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした威高さは、さすがに自ら備つてゐた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした威高さは、さすがに自ら備っていた。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "文官のかたにはさほど面倒な註文はなく、唯うやうやしく見えさえすれば事は済むのでしたが、武官になると註文がなかなかむずかしくて、上長の前では柔和さが第一、目下にたいしてはどこまでも毅々しく、威高気に見えなければいけないのです。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がいかにその妻を熱愛していたかは、焼津の旅先から、留守居の妻に送った手紙によく現われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "早ク見タイモノデス』という焼津の手紙でも解るように、妻と同伴することなしには、どんな旅行も楽しくないほど、夫人を熱愛していたからだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "と質問してみて下さい、と答えて逃げ去ったとかいう話しがあるけれども、何千万年まえの世界には、どんな動物がいたか、一億年のちにはこの世界はどんなになるか、そんな話は、いったい実になるものかどうか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしのからだを、しっかり抱いてもらいたかった。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が講義のあいまあいまに大学の裏門から公園へぶらぶら歩いて出ていって、その甘酒屋にちょいちょい立ち寄ったわけは、その店に十七歳の、菊という小柄で利発そうな、眼のすずしい女の子がいて、それの様が私の恋の相手によくよく似ていたからであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はフランス叙情詩の講義を聞きおえて、真昼頃、梅は咲いたか桜はまだかいな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの低い声で、「きょうは八十八夜」そうひとこと呟いたかと思うともう、てれくさくてかなわんとでもいうようにむっくり立ちあがって両肩をぶるっと大きくゆすった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五年、十年生きていてもらって、私が多少でもいい仕事をして、お父さに喜んでもらいたかった、とそればかり思います。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑惑を抱いたからだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（釈迦は諦観したであらうが、諦観した人として歩いたかどうか私は知らぬ。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼く片親の手一つで育ってあまり豊かでない生活が朧げに胸にしみ浮世の木枯しはもう周囲に迫っていたから、何かの刺戟はすぐに訳のわからぬ悲しみを誘うたのだ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事がすんでそこらを片付けるうち風呂がわいたから父上から順々にいってからだを清める。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の露国海軍のブルータルな勢力の圧迫が若い頭に何かしら強い印銘を与えていたかもしれない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真逆に墓表とは見えずまた墓地でもないのを見るとなんでもこれは其処で情夫に殺された女か何かの供養に立てたのではあるまいかなど凄涼な感に打たれて其処を去り、館の裏手へ廻ると坂の上に三十くらいの女と十歳くらいの女の子とが枯枝を拾うていたからこれに上根岸までの道を聞いたら丁寧に教えてくれた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また出ますと云うたら宿は何処かと聞いたから一両日中に谷中の禅寺へ籠る事を話して暇を告げて門へ出た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何を言っていたかは今少しも覚えていない。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時自分は訪問してそういう方面のどんな話をしていたかは思い出せないが、ただ一つ覚えていることがある。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう方面からそういう材料を得ていたかまたその材料がどれだけ真に近いものであったかは自分には全然分らない。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規は世の中をうまく渡って行く芸術家や学者に対する反感を抱くと同時に、また自分に親しい芸術家や学者が世の中をうまく渡る事が出来なくて不遇に苦しんでいるのを歯痒く思っていたかのように私には感ぜられる。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の寸法を取らねばならぬに何処へ行っていたか。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "医科は死骸を解剖すると聞いたから断った。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎は、舟をゆはへ附けよと言はれて、さてはこの馬鹿も何か感づいたかな？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
