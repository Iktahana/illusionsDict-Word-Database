    "definitions": [
      {
        "index": 1,
        "gloss": "water of life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "砂漠で遭難した彼にとって、オアシスの水はまさに命の水だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "何日も続いた断水の末、蛇口から出た一杯の水が命の水に思えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "長距離走の後、コーチが差し出してくれたスポーツドリンクは、乾ききった身体にとって命の水だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "こういう時代において、それ自身だけに任せておくととかく立ち枯れになりやすい理論に生命の水をそそぎ、行き詰まりになりやすい抽象に新しい疎通孔をあけるには、やはりいろいろの実験が望ましい。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あくる朝、命の水を汲まうとすると、釣瓶に一杯、汚い獸の毛が浮いて上る……三毛猫の死骸が投込んであつた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、一定の定つた生命の水量を撒き散らす彼の運命に役立つことであつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類亡滅の運に向つて居ることを覺る時になつたらば、其の掘鑿し難い智慧の井を深く／＼掘鑿せんと、恐ろしい猛烈鋭利な意識の錐や鶴嘴を振り廻して、そして燃ゆるやうな生存慾の渇を止めんが爲に生命の水を汲まうとするで有らうか。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ではついででございますから命の水を一とびんと死の水を一とびんほしゅうございます。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまはまたウイリイをお呼びになって、命の水と死の水を持って来い、それが出来なければすぐに命を取ってしまうとお言いになりました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウイリイは銀のびんをもらって来て、馬のさしずどおりに、一つへ命の水という字を彫らせ、もう一つへは、死の水という字を彫らせました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はウイリイに、親烏が立って出るまで待っていて、その留守に木へ上って、巣にいる子烏を一ぴき殺して、命の水を入れるびんを、そっと巣の中に入れておくように教えました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女は、つぎに命の水をその死骸へふりかけました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女は仰せを聞いて、さっそく、死の水を王さまにふりかけて、それから、命の水をかけて生きかえらせてお上げしました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今度命の水をかけようと思いますと、もう水が一としずくもありませんでした。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を鳥からもとの人間にして、あんな遠い遠いところからつれてかえったり、あんな大きなお城をここまで持って来たり、命の水や死の水を取って来たりするようなことが、ほかのだれに出来ましょう。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "命の水っていう位でしょう。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の沙漠に生命の水を求めつつあったヨブは、たまたま三友の来訪に接して、あたかも隊客旅が遥かに渓川を望見せし如くに感じた。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類滅亡の運命に向っていることを覚る時になって、その掘削の難しい知恵の井を深く深く掘削しようと、猛烈で鋭い意識の錐や鶴嘴を振り廻して、そして燃えるような生存欲の渇を止めようとして、生命の水を汲もうとするのであろうか。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄泉の洞なる戀人に生命の水を掬ばむと、七つの關の路守に、冠と衣を奪はれて、「あらと」の邦におりゆきし生身素肌の神の如、ああ爭ひの七八日、銀杏は征矢を射つくして、雄々しや空手眞裸に、ほまれの創の諸肩を、さむき入日にいろどりて、み冬の領にまたがりぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来、水――うまい水を飲まない、そのためでもあらうか、何となく身心のぐあいがよろしくない、よい水、うまい水、水はまことに生命の水である、あゝ水が飲みたい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "然うしていよ／＼冴え渡る生命の水底に樹はつくりものゝやうに動かない。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神流れ今入る我は永えの命の水と流れゆくなり。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "神流れ今入る我はとこしえの　　　　　　　　命の水と流れゆくなりとこしえの命の水と流れゆく　　　　身はかくのみにあり経しものをですからして、私がその前に「善悪を横に截る道」と申しましたときにも、私の気持は、これがそのときの、善悪を横に截るときの気持であったのであります。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから川にはいるときに、そこにはとこしえの命の水と一つになれると思って神流れ今入る我はとこしえの　　　　　　　　命の水と流れゆくなりこういう気持になりましたときにも、前に申しましたときにはたいへんな悟りであった。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とこしえの命の水と流れゆく　　　　身はかくのみにあり経しものを　つまり私は初めからその命の水の中にはいって、これまでいっぺんも命の水から出たことがなかった。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めからずっと命の水の中にはいって流れていたのである。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら其無感覚の如く見える土にも、恐ろしい地辷りあり、恐ろしい地震があり、深い心の底には燃ゆる火もあり、沸く水もあり、清しい命の水もあり、燃せば力の黒金剛石の石炭もあり、無価の宝石も潜んで居ることを忘れてはならぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命の水が湧いて居る様だ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ちのめされた彼のさまよう足取は、何時しか運命の水際にきた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
