[
  {
    "uuid": "9c3ddad3-afec-5a8e-80a5-c72dd529f223",
    "entry": "生き生き",
    "reading": {
      "primary": "いきいき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と",
