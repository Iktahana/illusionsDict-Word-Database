      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in a lively way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちの笑い声が響く公園は、いつも生き生きとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この品種は日当たりと水やりが適切だと、葉が驚くほど生き生きと茂るんですよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "作者の筆致は、歴史上の人物たちをまるで現代に蘇らせたかのように、生き生きと描き出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "震災からの復興が進み、被災地の商店街には少しずつ活気が戻り、店員たちの表情も生き生きとしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の落語は、登場人物一人ひとりが生き生きとしていて、聴き手を飽きさせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域の湿地帯では、多様な生物が共存し、生命力に満ちた生態系が生き生きと営まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「最近、顔色がとても生き生きとして、元気になったみたいだね」と、久しぶりに会った友人が私に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "と、聞えてくる音楽には心惹かれ、ちよつとは生き生きしもするのですが、その時その二つつは僕の中に死んで、あゝ　空の歌、海の歌、ぼくは美の、核心を知つてゐるとおもふのですがそれにしても辛いことです、怠惰を※れるすべがない！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一度ヴアイオリン彈きのクライスラーが舞臺にあらはれたのを見て、まるで狼が洋服を着て出て來たやうな大變「エトランジエ」の感じを起したことがあるが、こんどの感じもそれで、プルウストが彼の祖父さんや祖母さんをより生き生きと書けば書くほどその同じ「エトランジエ」の姿がくつきりして來る。",
              "citation": {
                "source": "「親近」と「拒絶」",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは人の心を撲たずにはおかない、不思議な、生き生きとした、美しさだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、胸には貴い感動がまた強く蘇り、一種の快い創作的興奮が私のすべてを生き生きさせた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地に當る靴音は生き生きして高く夜の空氣に反響した。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一人の人間の文章の達成とは、やや極端に言へば、その人なりの個性や氣質を十分に生き生きと生かし、織りなす文章を作り上げるといふ事に外ならない。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "口数をあまりきかない、顔色の生白い、額の狭い小づくりな、年は二十一か二の青年を思い出しますと、どうもその身の周囲に生き生きした色がありません、灰色の霧が包んでいるように思われます。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時だけは顔色が美しい桜色をして目の光もなんとなく生き生きしているようであった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは実に明るい、快活な、生き生きした海なんだ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポーリンさんにシマノフさん、いらっしゃい」　ウエイトレスの顔は彼らを迎える大仰な表情でにわかに生き生きし出した。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると今まで鈍い眠りに包まれていた病室が急に生き生きした活気を帯びて来る。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてなめらかな泥汁にぬれた土の肌も見る見る生き生きとした光沢を帯びて来るのである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜のふけるに従って歌の表情が次第に生き生きした色彩を帯びて来た。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この家政婦の行方不明をキッカケにして、忘れかけていた煙突問題が、又もや、生き生きと私の頭に蘇って来たから不思議であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は気の毒に思った、その柔和な顔つきのまだ生き生きしたところを見て、無残にも四足を縛られたまま松の枝から倒さに下がっているところを見るとかあいそうでならなかった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲のおおぜいの乗客はたった今墓場から出て来たような表情であるのに、この二人だけは実に生き生きとしてさも愉快そうに応答している。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の妾だった京都は、罹災してみすぼらしく、薄汚なくなった旦那の大阪と別れてしまうと、かえってますます美しく、はなやかになり、おまけに生き生きと若返った。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "カシワの木は、生き生きとした、緑のこずえを、力づよくのばしました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、目は光りかがやき、顔にも生き生きとした、赤みがさしています。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから生き生きとした音を出させようとして作った普通の鼓とは音色が違う筈である。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だけどあなたは無垢な生き生きした坊ちゃんでした。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには壁の美人画の永久に若い、生き生きした微笑から、一種の圧迫を感ずるくらいにまで神経が弱って行った。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方の表現に於ては、言葉が極めて有機的に使用され、その一つ一つの表象する心像、假名づかひや綴り語の美しい抑揚やが、あだかも影日向ある建築のリズムのやうに、不思議に生き生きとした魅惑を以て迫つてくる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両唇の角をちょっと上へ反らせるとひとを焦らすような唇が生き生きとついていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからこまかい虫の集りのように蠢いていた、新嘉坡の町の灯がだんだん生き生きと煌めき出した。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "引きしまつた彼の上皮の下には、生き生きとして落ち付いた力が寂しく光つてゐるのであつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上、と聞いて、かず枝のからだは急に生き生きして来た。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず賤しからず貴からず暮らす家の夏の夕暮れの状態としては、生き生きとして活気のある、よい家庭である。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面魂にもその言葉つきにも、悟空が自己に対して抱いている信頼が、生き生きと溢れている。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その少女の未完成と無垢とが彼女の墓の戸を開いたままにさせてをり、そのためその少女は死んでゐても、一方では生の半分をいきいきと保ち、もう一方では他の大きな傷口をひらいてゐる半分の方へ開いてゐるといつた、一種の能力をもつてゐるのです。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
