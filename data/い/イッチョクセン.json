        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その道は町まで一直線に続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼はゴールに向かって一直線に走り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は怒って、一直線に家に帰ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "紙の端から端まで、定規で一直線を引く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで勃然として床を蹴り、一直線に私の所へ飛んで來たのだといふ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "登竜門というものは、ひとを市場へ一直線に送りこむ外面如菩薩の地獄の門だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた船が一直線に進んでいる時遥かな水平線上の雲などを見ていれば雲も動かず船も動かず、いつまでも同じ処で波を切っているような気がする。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらと少し種類はちがうが、紙上に水平に一直線を描いて、その真中から上に垂直に同長の直線を立てると、その垂直線の方が長く見える。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して恒星が地球を通ずる一直線上に羅列していたらばどうであろうか。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全に裸体で豊満な肉体をもった黒髪の女が腕を組んだまま腰を振り振り舞台の上手から下手へ一直線に脇目もふらず通り抜けるというものすごい一景もあった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔エジプトの天文学者は地上に環を立てて北極星に面せしめて置き、環の影が丁度一直線になる日を見て春分秋分を定め、これを基として暦を定めたという事で、その時の環が今日でもアレキサンドリアの博物館に保存してある。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は野猪のやうに椅子を振りまはして、一直線に岡本潤へ打ちかかつてきた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どんな小さな瀕死人でもがその市立病院に一直線にはひつて行かうと思ひつめさへしたら、サガン公爵ですら、その行列を止まらさない訣には行かない。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然路が右へ曲ると途方もない広い新道が村山｜瀦水池のある丘陵の南麓へ向けて一直線に走っている。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広大な松林の中を一直線に切開いた道路は実に愉快なちょっと日本ばなれのした車路で、これは怪我の功名意外の拾い物であった。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "城壁の外門へ一直線である。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翡翠は光のやうに飛去り、川烏は電報配達夫のやうな一直線。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう挙動を繰返しながら一直線に進んで行くのである。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで鉄の鶴は無人の境を行くようにどこまでも単調な挙動を繰返しながら一直線に進んで行くのである。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風速の強いときほど概してこの扇形の頂角が小さくなるのが普通で、極端な例として享保年間のある火事は麹町から発火して品川沖へまで焼け抜けたが、その焼失区域は横幅の平均わずかに一二町ぐらいで、まるで一直線の帯のような格好になっている。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼬のように一直線に門前の茅原の暗に消え込んだ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……青い空と白い太陽の下にただ一人、線路を一直線に進んでゆく誇らかな心……。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上を遠く眺めると、一直線に流れてくる水道の末は銀粉を撒いたような一種の陰影のうちに消え、間近くなるにつれてぎらぎら輝いて矢のごとく走ってくる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始時代そのまゝで幾千年人の足跡をとゞめざる大森林を穿つて列車は一直線に走るのである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊笹の径を通りぬけると果して、思ひがけない大道が深林を穿つて一直線に作られてある。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはかれが家の庭を流れてかの街を貫くものとは異なり、遠き大川より引きし水道の類ゆえ、幅は三尺に足らねど深ければ水層多く、林を貫く辺りは一直線に走りて薄暗きかなたより現われまた薄暗き林の木陰に隠れ去るなり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸に石垣のようなものがどこまでも一直線に連なっていて、その前に黄色く濁った海が拡がっている。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の名はヤコフ・イリイッチと云って、身体の出来が人竝外れて大きい、容貌は謂わばカザン寺院の縁日で売る火難盗賊除けのペテロの画像見た様で、太い眉の下に上睫の一直線になった大きな眼が二つ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の横を曲ったお媼さんの俥が、邸をめぐった長い珊瑚樹の生垣に添って走り尽すと、やがて、茫としてつきる処が見えぬほど、広く続いた耕地の中心を一直線に専断した平坦な県道に、敏捷な、軽快な姿を現わすのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は最う、さつきから荷車が唯辷つてあるいて、少しも轣轆の音の聞えなかつたことも念頭に置かないで、早く此の懊惱を洗ひ流さうと、一直線に、夜明に間もないと考へたから、人憚らず足早に進んだ。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上まで殆ど一直線に付けられた巌石の道で、西側には老杉亭々として昼なお暗く、なるほど道の険しい事は数歩｜前の巌角の胸を突かんばかり、胸突き八丁の名も道理だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それから人ごみの中を二三百歩ばかり一直線に歩いて来ると彼はハタと足を佇めた。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その左手の草原の尽きる処に、青白く一直線に横たわっているのはテニスコートであろう。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは眼の前に重なり合った草の茎の隙間から見るテニスコートの白い一直線の上を、ソロソロと後しざりして来る薄茶色のセイラアパンツであった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
