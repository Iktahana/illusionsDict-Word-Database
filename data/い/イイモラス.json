    "definitions": [
      {
        "index": 1,
        "gloss": "to forget to mention",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
