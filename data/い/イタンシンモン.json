        "examples": {
          "standard": [
            {
              "text": "歴史の教科書では、中世ヨーロッパの異端審問がしばしば暗黒時代の一例として語られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その会議での厳しすぎる質問攻めは、まるで現代の異端審問のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ガリレオ・ガリレイは、その科学的発見のために異端審問にかけられたことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の型破りな提案は、保守的な組織内で異端審問にも似た激しい批判にさらされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宗教改革の時代には、異端審問が思想の自由を抑圧する手段として用いられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「昨日の取締役会での社長の追及は、まるで僕に対する異端審問だったよ」と彼は疲れた顔で言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中世の魔女狩りは、異端審問の極端な形態の一つとして理解されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
