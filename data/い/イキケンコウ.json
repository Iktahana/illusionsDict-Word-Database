      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in high spirits",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新チームは初戦に向けて、意気軒昂たる様子で練習に励んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新規プロジェクトの成功を誓い、メンバーたちは意気軒昂と士気を高め合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長い闘病生活を終え、退院した彼は、以前にも増して意気軒昂として、新たな人生を歩み始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台に立った若手俳優は、輝くばかりの笑顔で、意気軒昂に観客の視線を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "難解な論文の発表を終え、研究室の仲間と祝杯をあげながら、「これでまた新しい発見ができる」と皆、意気軒昂だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "困難な状況にもかかわらず、彼女は常に意気軒昂で、周囲に活力を与える存在だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「よし、この仕事も片付けて、今から山にでも登りに行くか！」と、友人は意気軒昂に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "＊ワレラコクキヤウニアリ　妻子を初め東京の諸友に、その安別から打電した時には、私もまた意気軒昂たるものがあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼の意気軒昂たるものがあったであろう。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌四日にも、幕軍は敗勢を返さんとして戦ったが、此日仁和寺宮｜嘉彰親王が、金甲馬に跨り、前駆に錦旗を飜して、陣頭に進まれたので、絶えて久しき錦の御旗を仰いだわけで、官賊の別が判然としたので、薩長の軍は意気軒昂となり、幕軍は意気沮喪して、いよいよ敗勢の著しいものがあった。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向うには、残忍な、いかつい顔をした、赤髭の若い男が、ゲートルを巻いた脚を開いて突っ立ち、片方の肱は腰に曲げ、片方の手には、猟用の鞭を振り上げて、あたかも勝ちほこった馬鹿大将みたいに、意気軒昂としていた。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光景は経験のない者には伺い知ることが難しいところだが、例えば勇士が敵を望んでいよいよ意気軒昂となるようなものであることを疑わない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は、啓吉も久野も、今度久しぶりで、ヒョックリ上京して来た青木も、銘々それ／″＼に意気軒昂たるものであった。",
              "citation": {
                "source": "祝盃",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも私の記憶に残ってるのは、この級が同盟休校を企てた事があって、その岸君が、私や三之助君のいるところで、如何にも意気軒昂として、「校長を追い出すのだ」　と言った姿だ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が行ってやるものかい」　と、老人は意気軒昂として叫んだ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから行ってみましょう――』　畔柳博士は、しばらく頸をかしげていたが、『よかろう――』　そういうと、三人は意気軒昂と夜道をいそいだ。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は正に意気軒昂、邪は遂に正に勝たずとの信念何人も動かすべからず、気既にさしもの兇悪なる支倉を呑んでいるようであった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　闇太郎は意気軒昂、てっきり、そこに伏せ勢があると認めた、河岸小屋の方へ呼びかけた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語道断なみすぼらしい風俗の横行はあつても、意識的に羽目を外した行動の人目をひくやうな闊達さもなく、まして自ら「地獄」行きをもつて任ずる意気軒昂たる青春の姿もみあたらぬ。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本店はその昔、意気軒昂で名を成した名人寿司として有名なものであったが、キリンも老いてはの例にもれず、ついに充分の生気は消え去ってしまった。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気骨稜々意気軒昂たる気構えは、今様一心太助といってよい。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場氏は意気軒昂だ。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも笠置を落城させて、意気軒昂たる者共だ。",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに反しましてお味方の勢は、勝に乗りまして意気軒昂、然らば今夜｜逆寄せ仕り、一挙に追い散らしあそばすこそ、肝要かと愚考いたされまする」。",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯は意気軒昂我れ能く政党の外に超然として議会を操縦するを得可しと信じたるに拘らず、議会は寧ろ侯の行動を非立憲的と為して、荐りに不信任動議を提出したりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パンの会」のこと創刊号以下雑誌は一向売れなかつたが、同人たちは孰れも意気軒昂たるものがあつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "養子に行くにしても、今更好い口がない」意気軒昂の水鳥会　僕は茫然自失という形だったけれど、御方便なもので、奮起一番、方針を立て直した。",
              "citation": {
                "source": "合縁奇縁",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も若くて、意気軒昂としていたのであろう。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以降詩人がそれらを気にすることはなく、意気軒昂と道を進みました。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに陰謀の要点に触れると、声は多少低くなりますが、それに附随して議論を闘わすという段になると、意気軒昂として、火花を散らすの勢いです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の意気軒昂さは、察してくれたまえ。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "大石は意気軒昂だった。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の大政党は意気軒昂のうちに樹立されて、憲法の精神に拠って治績をおさめようとする抱負もありながら、徒らに内訌に終始しつつ、一議会もみずに醜い末路をさらしたのである。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "――漫才は一人では稼げませんからねえ」　ぽんたんは意気軒昂の頃は、「――なんか、おもしろいネタありませんか。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて誰が、名将イスコラスが敗戦に向って突っこんだときのように意気軒昂に、戦勝へと突き進んだか。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "意気軒昂、目も自ら高きを望む。",
              "citation": {
                "source": "母校復興",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大海の鯛を釣る」　と言って、僕は意気軒昂たるものがあった。",
              "citation": {
                "source": "ロマンスと縁談",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
