[
  {
    "uuid": "5fc50202-10e1-5f08-93fa-342cd3963fcf",
    "entry": "意気軒昂",
    "reading": {
      "primary": "いきけんこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
