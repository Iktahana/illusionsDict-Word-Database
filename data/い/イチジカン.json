    "definitions": [
      {
        "index": 1,
        "gloss": "one hour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎朝、自宅から職場まで電車で移動するのに、おおよそ一時間かかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今日の会議は予定されていた一時間では終わらず、質疑応答にさらに三十分を要した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「やばい、もう一時間も経過している！待ち合わせに遅れそうだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このドキュメンタリー番組は、生態系の変化について深く掘り下げるため、特別に一時間枠で放送された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このソフトウェアのインストールには、平均して一時間程度が見込まれます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長距離フライトの遅延により、目的地への到着が一時間ほど遅れる見込みだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末の午前中、集中して読書に一時間を使うのが、最近のささやかな楽しみになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "寢衣をきて起きた僕と、暗い陰鬱な電氣の下で、約一時間ほど話をした。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　晩飯が済んで一時間もすれば耕二は床に就くのが常である。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも机の抽斗には小さな鏡が入れてあって、時によると一時間もランプの下で鏡を睨めている事がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の姿のちらちらする日には竹村君は面白そうに一時間の余も話し込んでいるが、娘の顔を見せぬ日は自然に口が重くてそうかといって急に帰るでもなく、朝日を引切りなしに吹かして真鍮のしかみ火鉢の片隅へ吸殻の山をこしらえる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、起きて、ふたりで顏を洗ひに井戸端へ出て、そこでもう藝術論がはじまり、一時間ちかく井戸端をぐるぐるめぐり歩いて最近の感想を述べ合ひました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鼻の穴を気にしながら遂々十一時間、――その間に昼飯と三時休みと二度だけ休みがあったんだが、昼の時は腹の空いてる為めに、も一つはミキサーを掃除していて暇がなかったため、遂々鼻にまで手が届かなかった――の間、鼻を掃除しなかった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーツは、ブリッジで、涼風に吹かれながら、ソーファーに眠っていたが、起き上って来て、「どうしたんだ」「左舷に燈台が見えますが」「又、一時間損をしたな」と、メーツは答えて、コムパスを力一杯、蹴飛ばした。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ状態が一時間二時間三時間と經過しても一向に變りがない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間前の伊香保とは丸で別な伊香保が出現したやうに思はれた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場迄來ると汽車はいま出た計りで、次の田端停り迄は一時間も待たなければならなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで日本のような、世界的に有名な地震国の小学校では少なくも毎年一回ずつ一時間や二時間くらい地震津浪に関する特別講演があっても決して不思議はないであろうと思われる。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "転向の原因、勢力消長の決定因子が徹底的に分らない限り、一時間後の予報は出来ても一昼夜後の情勢を的確に予報することは実は甚だ困難な状況にあるのである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時「オイ君の食ってるビフテキは一時間三十｜浬で走っているぜ」と教えるのは少々馬鹿げているではないか。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず今日乗客船の速いので一時間二十五｜浬くらい、かなりに速いと云わねばならぬ。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、診察の順番を待つ間――一時間近く――うかうかとその場景に見入って居りました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれだけが彼女を一時間も悲しく泣かした。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間で行ってくるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう涼しいからね」　ジョバンニは立って窓をしめお皿やパンの袋を片附けると勢よく靴をはいて「では一時間半で帰ってくるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも、単に棒の頭で球をなぐって飛ばせると云うだけではないことがわずかに一時間半ばかりの見学でよく分ったような気がした。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜匁の分銅を一分間吊した後と、一時間あるいは一昼夜吊しておいた後とは幾分の差がある。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京辺と四国の南側の海岸とでは満潮の時刻は一時間くらいしか違わないし、満干の高さもそんなに違いませんが、四国の南側とその北側とでは満潮の時刻は大変に違って、ところによっては六時間も違い一方の満潮の時に他の方は干潮になる事もあります。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この海峡は大洋から瀬戸内海に通ずる入口の中で一番広いから内海に出入りする海水も主にここから出入りするので、潮流もなかなか早く通例一時間三、四海里くらいの速度であります。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＢの辺では流れの早さは最も盛んな時で一時間十海里くらい、Ｃの辺でもあまりこれに劣りません。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし上流のＤの辺では一時間二、三海里くらいのものです。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一時間半ばかりたって遂に絶命した。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "従て夜もおちついてはねむれない　眠てもすぐさめる　疲れるから眠ることはねむるが一時間もたつともう目がさめる。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の分は僅であったから一時間半ばかりでもぎ終えた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いうち就寝前の一時間を実験室か書卓で費やしたが、晩年はやめた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が良くなくても根気さえあれば人が一日に一時間ずつ費やして会得しまた仕遂げる事を、二時間三時間ずつかければ会得し遂行されよう。",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "談話に費やす労力　人間が談話をしたり、歌ったり、演説したりする時には、肺の中の空気を若干の圧力で押し出しているが、このために要する器械的の仕事はどれだけであるか、平たく云えば一時間しゃべるにはどれだけの労力をするかという事を測定した人がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
