        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は寝相が悪く、朝起きると布団がいつも寝汚い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供が寝汚くて、朝にはいつもシーツが乱れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわ、寝汚かったみたいで、髪がボサボサだよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ねえ、自分のベッドくらい片付けてくれない？ すごく寝汚いよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旅籠の部屋には、誰かがつい先ほどまで寝汚く使っていたかのような、乱れた寝具が残されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "私は寝方が寝汚い方で、朝には枕がいつも定まっていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "睡眠専門医は、「寝相の悪さからくる寝汚さは、睡眠の質にも影響しかねません」と注意を促した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
