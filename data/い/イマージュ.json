        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は知らない親友に就て微細な描写や家庭生活や人となりやエピソードなど彷彿と目のあたり見るが如くに活写するが、これはみんなその時ふいに思ひついた彼の一瞬のイマージュにすぎない。",
              "citation": {
                "source": "足のない男と首のない男",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "題名だけを見て、絵を見ない方が、むしろ多くの美しいイマージュを描くことができる。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼女はこのごろ、何かのイマージュにつかれているらしいよ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も経験ずみだが――イマージュが答えさせるんだ」「いやだ――どういうことなの？",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし気味がわるいわ、イマージュなんて……」「わたしにもよくわからないんだけれど、蜂谷さんがベルネのところにいらしたときは柴垣さんや皆さん、ちょくちょくあすこへ遊びにいらしてたんじゃないの？",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家は自分のイマージュで、自分の中に在る絵を描くんだ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（オウィディウス）　（a）わたしは常に心の中に、一つのイデ〔観念〕・ある混沌としたイマージュ〔心像〕・をもっている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
