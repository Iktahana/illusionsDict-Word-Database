    "definitions": [
      {
        "index": 1,
        "gloss": "groove in a shamisen player's fingernail caused by the friction of the string of the instrument",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "師匠の左手の人差し指には、長年の鍛錬を物語る深い糸道が刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この古い三味線の棹には、前の持ち主がつけたであろう無数の糸道が残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の爪にできた糸道を見るだけで、どれほど熱心に稽古に励んでいるかがわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "お大は姉と違つて、幼い時分から苦勞性の女であつたが、糸道にかけては餘程鈍い方で、姉も毎日｜手古摺つて居た。",
              "citation": {
                "source": "絶望",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しは糸道が明いているのだからといって、三味線も教えてくれた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "安兵衛　（コソコソと）糸道のあいてない婆さんが弾くてことは、年代記物だな。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "someone's ability to play the shamisen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの若さで、彼の糸道はすでに名人級だと評判だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「まだまだ糸道が甘い」と、師匠は弟子に厳しく言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女の糸道には、聴く者の心を揺さぶる何かがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
