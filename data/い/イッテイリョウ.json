[
  {
    "uuid": "0dc16796-b965-5902-a34f-7379bd56bbcb",
    "entry": "一定量",
    "reading": {
      "primary": "いっていりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
