        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "忙しさにかまけて、つい医者に掛かるのを後回しにしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「風邪をこじらせる前に、早めに医者に掛かったほうがいいですよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "症状が数日経っても改善しない場合は、速やかに医者に掛かってください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "医者に掛かる際は、現在服用している薬を医師に正確に伝えることが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「昨日から胃の調子が悪いから、今日の午後は医者に掛かってくるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "専門の医者に掛かるためには、まず、かかりつけ医の紹介状が必要になることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旅先で急に体調を崩し、やむを得ず現地の医者に掛かることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
