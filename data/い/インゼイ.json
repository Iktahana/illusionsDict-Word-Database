    "definitions": [
      {
        "index": 1,
        "gloss": "royalty (on book)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の著者の翻訳者には印税のかなりな分け前を要求して来るというような噂も聞いた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "印税がはいってもすぐなくなってしまう。",
              "citation": {
                "source": "私の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近いうちに旧作の印税がはいることになっている。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "空腹を防ぐために子への折檻をひかえた黄村、子の名声よりも印税が気がかりでならぬ黄村、近所からは土台下に黄金の一ぱいつまった甕をかくしていると囁かれた黄村が、五百文の遺産をのこして大往生をした。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "著書は十五六種あるが、皆印税になって居る。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又印税は何割だと云うだろうが、私のは外の人のより少し高いのだそうだ。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾割の印税を取った処が、著書で金を儲けて行くと云う事は知れたものである。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のこれまでの生涯を追想して、幽かにでも休養のゆとりを感じた一時期は、私が三十歳の時、いまの女房を井伏さんの媒酌でもらって、甲府市の郊外に一箇月六円五十銭の家賃の、最小の家を借りて住み、二百円ばかりの印税を貯金して誰とも逢わず、午後の四時頃から湯豆腐でお酒を悠々と飲んでいたあの頃である。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お伽草子」を書き上げて、その印税の前借をして私たちはとうとう津軽の生家へ来てしまった。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は原稿料や印税の事など説明して聞かせたが、半分もわからなかったらしく、本を作って売る商売なら本屋じゃないか、ちがいますか、などという質問まで飛び出す始末なので、私は断念して、まあ、そんなものです、と答えて置いた。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、原稿料にしろ印税にしろ、自分ひとりの力で得たと思ってはいけないのだ、みんなの合作と思わなければならぬ、みんなでわけるのこそ正しい態度かも知れぬ、と思ったりした。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へちまの花」の印税を昨日、本屋からもらいましたので。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も「へちまの花」の印税がはいったばかりのところですからお金持であります。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つねに明日の希望があるところが競馬のありがたさだと言っていた作家も、六日目にはもう印税や稿料の前借がきかなくなったのか、とうとう姿を見せなかった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そんな売れない本から印税がはいるはずはなかった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千箱だと一万円ですね」「今買うて置かれたら、来年また上りますから結局の所……」「しかし僕は一万円も持っていませんよ」　当にしていた印税を持って来てくれる筈の男が、これも生活に困って使い込んでしまったのか途中で雲隠れしているのだと、ありていに言うと、老訓導は急に顔を赧くした。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本の定価が千五百円で、印税と呼ばれる報酬の割合が一割だったとすると、一冊あたりの取り分は百五十円。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者に関しては一割が慣例の印税率ですが、訳者では六分前後が常識的です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが絶版書をコピーする際は、その人たちに印税分がいきません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなうなら、より多くの印税を受け取りたいという期待も持っています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き下ろし文庫の『パソコン創世記』の定価は三百九十円で、印税率は慣例通りの十パーセントでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初版部数が二万ですから、私の受け取った印税は、税込みで七十八万円。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方で私が、紙の本やＣＤ―ＲＯＭ版から印税を得ていることを考慮して、「一部分のみを公開する」という提案でしたが、膨らみはじめた新しい妄想と折り合いを付けるためには、是非全体を使ってもらおうと考えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ何よりもの、その証拠としては、一度び彼が現れて、水車が回る如く訳文の紙片が厚くなるに従つて、わたしの相好は牡丹の花のやうに崩れて、稍ともすれば馬小屋の天井裏からモロコシ酒を盗み出して、印税の嵩ばかりを、万円、万円と算えて、うつゝを抜した。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、到頭その方は思い切って、先輩や友達仲間の傑作選集を出版して、その印税を河野に贈ることにした。",
              "citation": {
                "source": "神の如く弱し",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この選集で得られる印税が、河野に対する香奠になるのではあるまいかと思うほど、河野の病状は険悪であった。",
              "citation": {
                "source": "神の如く弱し",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
