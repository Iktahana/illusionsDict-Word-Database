[
  {
    "uuid": "491a530d-9269-5c51-802b-bd34989105a7",
    "entry": "慰労",
    "reading": {
      "primary": "いろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
