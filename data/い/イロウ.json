  {
    "uuid": "b09fc75b-d518-5e5f-a3e5-433a25677aa4",
    "entry": "胃ろう",
    "reading": {
      "primary": "いろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gastric fistula",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "網シャツの人は、馬に乗って、またかけて行ったし、子どもらは、ぼくらの仲間にはいろうと、岸に座って待っていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに例の杉屏の前までやった　裏からはいろうと云う心でもなくまあ……のぞき込みにきたのだ。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな目の子勘定をして紳士淑女の辛抱強いのに感心する一方では自分でこの仲間にはいろうという勇気を沮喪させていた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの時は、こっちに鍬がいろうとは思わなんだせにやったんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やっぱし、あしこのところからはいろうとしたのか？",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、いろうたって大事ござんせんぞな。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして便所へはいろうとする時に、そこの開き戸を明ける前に、柱に取付けてある便所の電燈のスウィッチをひねる。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見送って、お初は自分の家へはいろうとすると、半七は空家の中から不意に声をかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "青｜瓊玉かゞやく天に、　　　　　れいろうの瞳をこらし、これはこれ悪業乎栄光乎、　　　かぎすます北斎の雪。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくお湯にはいろう。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "看板にそう書いてあるじゃないか」「はいろうじゃないか。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐はその下の円い穴にはいろうとしてくるっと一つまわりました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんがもう大丈夫だから家にはいろうといったけれども、ぼくははいるのがいやだった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島へ行くには船もいろうし、山の奥へ入るには野宿だってしなけりゃならない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくももうきみらの仲間にはいろうかなあ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小郷は何思ったのか、「おい、はいろう」　君勇をうながして、その映画館の中へふらふらとはいって行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丁度だ」　はいろうとした途端、中から出て来た一人の男がどすんと豹吉に突き当りざまに豹吉の上衣のかくしへ手を入れようとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの私の句は酒（悪酒でないまでも良酒ではなかつた）のやうであつた、これからの私の句は水（れいろうとしてあふれなくてもせんせんとしてながれるほどの）のやうであらう、やうでありたい。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にひとりだけ、ペーテルという男の子は、動物をからかうのはいけないことだと言って、仲間にはいろうとしませんでした。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お姫さまがベッドにはいろうとしたら、ちょっと押してごらん。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく長くなって、いばってみても、大きな黒い帽子をかぶった、ちっぽけな黄色いろう人形にもどってみても、なんの役にもたちません。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、美術学校にはいろうと思っていたんですけど、……」「いや、つまらん。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが哀しみにくるめけるももいろうすき日のしたに白く光りて涙ぐむ洋銀の皿をたづねゆく草むら深く忘れつる洋銀の皿はいづこにありや。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを書き終えたら、風呂へはいろう。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽど、蹴球部にはいろうかと思った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴球部へでも、はいろうかと思ったのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主任のひとも、眉間にありありと不快の表情を示して、「じゃ、なぜ春秋座へはいろうと思ったのですか？",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が夜おそく通りがかりの交番に呼びとめられ、いろいろうるさく聞かれるから、すこし高めの声で、自分は、自分は、何々であります、というあの軍隊式の言葉で答えたら、態度がいいとほめられた。",
              "citation": {
                "source": "一歩前進二歩退却",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本浪曼派へはいろう、そのお土産として「道化の華」を発表しよう。",
              "citation": {
                "source": "川端康成へ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗は政宗だ、誰に遠慮がいろうか。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
