        "examples": {
          "standard": [
            {
              "text": "選挙が近づくと、彼は一家眷属を引き連れて地元の挨拶回りに奔走する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その土地の名家は、一家眷属を率いて地域の祭事を代々取り仕切っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "戦国武将は、戦に負ければ自らの一族だけでなく一家眷属もろとも滅ぼされる覚悟だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "おそろしい祟りはそれからそれへと手をひろげて、津の国屋の一家眷属にわざわいするのではあるまいか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            }
          ]
        }
