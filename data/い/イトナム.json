    "definitions": [
      {
        "index": 1,
        "gloss": "to run (a business)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父から引き継いだこの喫茶店を、彼は一人で営んでいるんだ。昔ながらの落ち着いた雰囲気は、常連客に愛されている。毎朝早くから開店し、丁寧にコーヒーを淹れるのが彼の日常だ。 '今日もいい天気で、お客さんも来てくれるといいな'と彼は独り言を言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その間に彼等の新家庭を営むべき Tofts（Little Baddow における邸宅の名）の工事を監督するため毎週二、三度は新郎新婦｜駒を並べて出かけて行った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな国定教科書風な感傷のなかに、彼は彼の営むべき生活が示唆されたような気がした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も卒業までと思ったろうし、又大学までとも志して居たろうけれど、人は一日も早く独立の生活を営む方が可えことはお前も知って居るだろう。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日蓮上人の宗教が、法華経をいよいよ時代化し、人々題目を口に唱えつつ現実生活に営むところに全仏教精神は活きるとしましたその簡易化、民衆化、生活化は、誰もよく知るところであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の色はやや青く、蜘蛛はその囲を営むのに忙しい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金をかけて、茶座敷を営むより、此の思ひつき至つて妙、雅にして而して優である。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "安行の葬儀は市郎全快の上で営む事に決したので、一旦は火葬に附し、其遺骨は広い座敷の正面に祭られてあった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿は聖人に似たりといへども心は不平に濁りて騒ぎ、すみかを山中に営むといへども人を恋はざる一夜も無く、これ貧賤の報のみづから悩ますところか、はたまた妄心のいたりて狂せるかと、われとわが心に問ひかけてみましても更に答へはござりませぬ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其諺通りなら定基は早速に僧を請じ経を誦させ、野辺の送りを営むべきであった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚の営むべき一周忌にわざと一月遅れて、昔香以の恩蔭を被った人々が、団子坂の小倉是阿弥の家に集まって旧を話し、打連れて墓に詣でた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀尾井第を営むとて、姑く東叡山に住ませ給ふ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣にしたがいて帰東の途に上りしときは、相沢とはかりてエリスが母にかすかなる生計を営むに足るほどの資本を与え、あわれなる狂女の胎内にのこしし子の生まれんおりのことをも頼みおきぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その俺が地下に、ありったけの智能を絞って自己の棲処――窖を営む。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が……ともかくもそのような事情で、首尾よく逮捕の手をのがれました私は、彼女と共に石狩川の下流を越えまして、例の絶対安全の神秘境に恋の巣を営むことになったのです。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後俺唯一人暮し遂に詩人としての放埒な生活を営むに至つた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに海幸を守る蛭子社を数町｜乃至一、二里も陸地内に合併されては、事あるごとに祈願し得ず、兵卒が将校を亡いしごとく歎きおり、ために合祀の行なわれたる漁村にはいろいろの淫祀が代わりて行なわれており、姦人の乗じて私利を営むところとなる。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きは乱心の縊死ということになっているので、世間の手前、あまり華やかな葬式を営むことを遠慮したのであるが、それでも会葬者はなかなかに多かった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし番頭と心中したということになっている以上、無論に表向きの葬式を営むことも出来ないので、日の暮れるのを待ってこっそりと棺桶をかつぎ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は小間物屋の二階で型ばかりの法事を営むことになって、兄弟子の紋七は昼間からその世話焼きに来ていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、おじさんの菩提寺の僧を頼んで、表向きは得体の知れないお文の魂のための追善供養を営むということにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "村里を左様に離れた畑中に、ひとり花やかな館を営む所以を不思議と思つたところが、彼は同村民を野蛮で吝嗇の徒と排して、夙に街道の旅人を招ぶべき念であつたとのことである。",
              "citation": {
                "source": "水車小屋の日誌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくても子供たちは、冒険を好み、変化を好んだのに、その親たちの中には、兇暴な日常生活を営む者もあった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが為に慰めらるるとにはあらねど、その行へる残忍酷薄の人の道に欠けたるを知らざるにあらぬ貫一は、職業の性質既に不法なればこれを営むの非道なるは必然の理にて、己の為すところは都ての同業者の為すところにて、己一人の残刻なるにあらず、高利貸なる者は、世間一様に如此く残刻ならざるべからずと念へるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は改善の人たれと冀しを、貫一は今この家の主となれるに、なほ先代の志を飜さずして、益す盛に例の貪を営むなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め予ロンドンに著いた夜勝手が分らず、ユーストン街にユダヤ人が営む旅館に入って日夜外出せず。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その百姓生活を長く営むことを許されなかった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "好子と愛の生活を営むやうになつたお蔭で、そしてそれが或る人達には彼に取つて、苦悩の種子としか思はれないところから、妻を失つた彼の家庭へ入つて、子供達の面倒でも見ようといふ人が、余り幸福でない、多くの女のなかにあるのであつた。",
              "citation": {
                "source": "水ぎわの家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそこに越えることの出来ない溝渠があるというならば、私は寧ろ社会生活を破壊して、かの孤棲生活を営む獅子や禿鷹の習性に依ろう。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野の獣にも生殖を営むべき時期は一年の中に定まって来るのに、人間ばかりは已む時なく肉慾の為めにさいなまれなければならぬ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましろきそらの蔓むらに、　雨をいとなむみそさゞい、黒き砂糖の樽かげを、　　　ひそかにわたる昼の猫。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
