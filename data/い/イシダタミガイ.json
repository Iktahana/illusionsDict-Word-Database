        "examples": {
          "standard": [
            {
              "text": "磯の潮だまりには、石畳貝の群れが活発に動き回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この石畳貝は、学術的にはモドントラ・ラビオと呼ばれ、特定の海域に生息する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕食には、獲れたての石畳貝を塩茹でにして、シンプルな味付けで楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、砂浜で珍しい形の石畳貝を見つけ、宝物のように大切に持ち帰った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「見て！この石畳貝、縞模様がきれいだね！」と、娘が声を弾ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境調査の結果、この湾の石畳貝の生息数が過去最高を記録したと報告された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
