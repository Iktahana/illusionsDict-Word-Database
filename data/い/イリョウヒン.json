          "literary": [
            {
              "text": "医療品などを積込む。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "香港を出発する時、野戦病院の医療品の中から、パビナールが相当量紛失するという事件が起きた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い番士小屋と糧秣庫が焼けなかったし、番士小屋には医療品があったので、敵味方の差別なく、負傷者を小屋へ運んで、みんなで応急の手当にかかった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
