    "definitions": [
      {
        "index": 1,
        "gloss": "first base",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ボテボテのゴロを打った瞬間、彼はバットを放り投げて一塁へと全力疾走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "際どいタイミングのプレイだったが、塁審の腕が横に広がり一塁はセーフになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ピッチャーの牽制球が後ろに逸れた隙を突いて、一塁ランナーがすかさず二塁へと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "本軍の先鋒青木大尉は、率先して進み、第一塁を陥れて勇躍更に坂を上るが、薩軍の弾丸は雨の様に降りそそぎ、午後の三時になっても占領する事が出来ないので退却した。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一塁を抜いたと思うとすぐ奪還される始末なので、こちらにも、塹壕、胸壁が必要であるとて、工兵が弾雨の間を作業した。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、絶頂の一塁は猶敵手にある上に、薩軍は兵力を増加した様子である。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、ゴム球の野球が好きで、松岡が投手、久米が捕手、自分は一塁で、学校中を風靡したものだが、松岡の旨かつた事と、久米の大車輪のプレイ振とは、今でも髣髴として忘れられない。",
              "citation": {
                "source": "学生時代の久米正雄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二塁間突破をねらったヒットエンドランは、ライナーになって、ジャンプした二塁手にとられ、飛び出した一塁走者も刺されて、一瞬にしてチェンジになってしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとつは通称「上の道」で、校舎裏玄関から出て、陸上グラウンドと細長い校舎にはさまれ、途中で直角に曲がり、グラウンドの短いほうの辺、野球場の一塁側ファウルエリアに沿い、一塁のわきから短い橋をわたり、本棟が建つ台地の一〇五のまえに出るものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "本線はさらに、野球場一塁側の土手に沿って、東棟の台地と野球場の台地をつなぐ橋の下を抜け、二、三〇メートルいったところで、あちこちに下草がのぞく荒れ地のなかに、茫漠と消えている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一塁手は「旗竿」と称せられる細長い大工の子で、二塁手は「すずめ」というあだ名で駄菓子屋の子である、すずめはボールは上手でないが講釈がなかなかうまい、かれは安場コーチの横合いから口をだしていつも安場にしかられた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学の生徒は制服制帽整然とうちそろうて一塁側に並んだ。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと球をつかんだかと思うと一塁へ三尺も高い球をほうりつける。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき五大洲は安打して一塁をとった、つぎのクラモウはバントした、手塚はそれを取って二塁へ投げようか一塁へ投げようかと疑惧してるうちに双方を生かしてしまった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "一塁手の旗竿は二塁打を打って千三が本塁に入った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "一塁や三塁よりへファウルがとびこんでも、人のことが気にかかって仕方がない。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に、この辺は神経衰弱の致すところかも知れないけれども、各選手がグローブを一塁又は三塁のコーチャーボックスのあたりへ投げすてゝベンチへ戻ってくる。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま一塁か三塁よりへファウルフライがあがって、スパイクがグローブにひっかゝってエラーしたら、どういうことになるのだろうと気にかかって見ていると頭痛の種になるのである。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし保守思想というものは、こういうハツラツたるスポーツに於ても在るもので、先日読んだ野球雑誌に、日本野球のベストメンバーというのを見ると、一塁が川上でも西沢でも飯田でもなく、死んだ中河になっている。",
              "citation": {
                "source": "戦後新人論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして中河こそは不世出の一塁手で、生れながらのプロ野球人だなどと絶讃しているのである。",
              "citation": {
                "source": "戦後新人論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしラッキーストライクに大鹿が加入して、三番にピースの国府一塁手、四番にキャメルの桃山外野手がとれたら、攻守ともに百万ドル。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの門札をしらべると、ピース軍の至宝、好打の国府一塁の生家である。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日のメンバーは河野泉谷のバツテリーに遊撃橋戸、一塁森本二塁押川三塁小原に、外野は猪瀬久野鈴木の三人であつた。",
              "citation": {
                "source": "野球界奇怪事　早慶紛爭囘顧録",
                "author": "吉岡信敬",
                "note": "青空文庫"
              }
            },
            {
              "text": "打者は一塁を廻り、帽子を飛ばして二塁へと突進する。",
              "citation": {
                "source": "昼の花火",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒット打ったのは、一塁側の選手なんだよ」「……いけないの？",
              "citation": {
                "source": "昼の花火",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその一本の悩みを抜き去るためには、それに連なる志方、神吉、高砂、野口、淡河、端谷などの衛星的な小城をまず一塁一塁陥し入れてからでなければ、敵の本拠たる歯根を揺がすことは出来ないからである。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは播摂の二国に境し、道らしい道もありませんが、あれを越えれば、摂津の物資を三木に輸送し三木の城兵が摂津へ通うことも、さして至難ではございませぬ」「摂津の荒木が寝返った今日では、すでにそこには一塁を新たに築いて、三木か摂津かいずれかの兵を籠め、また輸送路も切り拓いているに違いありません。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、秀吉の軍は、一塁一塁を力攻して、いまはかつて官兵衛がいた頃の平井山の本陣をずっと前方へすすめ、依然として、なお陥ちずにいる三木の城と対い合っていた。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても十年以来、たえずせんぐんばんばのあいだを往来あそばし、あしたに一塁をぬきゆうべに一城を｜ほふられるおはたらきをなされながら、そのおいそがしいさなかにあってなおおくがたのおんおもかげを慕いつゞけていらしったのでござりましょうか。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
