[
  {
    "uuid": "ec9520db-8e56-5a4a-8315-b12979517856",
    "entry": "威嚇的",
    "reading": {
      "primary": "いかくてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "threatening",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その犬は、縄張りに侵入した人間に向かって威嚇的な吠え声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議中、彼の威嚇的な眼差しは、反対意見を述べる者を萎縮させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "軍事パレードは、周辺国に対する威嚇的なデモンストレーションとして受け止められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜の森は、風の音と木々のざわめきが合わさり、威嚇的な雰囲気を醸し出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は威嚇的な態度で取引条件を突きつけ、交渉を有利に進めようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "捕食者は獲物に向かって威嚇的な咆哮を放ち、距離を詰める機会をうかがっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その威嚇的な警告文は、侵入者に対して強い警戒を促すものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "室へ戻って、友人にハガキを書いていると、富士の雲が引いて取ったように幕を明け、銀磨きの万年雪が、巨獣の斑紋のように二筋三筋キラリと光って、夏の富士にして始めて見るところの、威嚇的な紫色が、抜打に稲妻でもひらめかしそうに、うつぼつと眉に迫って来る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その立体構成面の威嚇的偉大さを、駭くべき簡単なる曲線で、統整して、しかも委曲に至っては、富士で謂うところの八百八谷の線から、おのずと発生する凹凸面の、複雑なる入り乱れのために、眼もあやになることを如何ともしがたい。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、蜂はあわてて穴から出て來たが、忽ち松葉に向つて威嚇的な素振を見せた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟味与力は罪人をよび出して今日はいよいよ拷問を行うぞという威嚇的の警告をあたえ、なるべくは素直に自白させるように努めるのであるが、それでも本人があくまでも屈伏しない場合には、係り役人は高声にかれの不心得を叱りつけて、さらに初めて拷問に着手するのである。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は酔い、或は醒め、或は夢み、自分の頭脳は種々の混乱を来した末に、お杉｜婆の威嚇的命令の下に重太郎の嫁たるべく約束した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃声は守衛が威嚇的に射ったものだろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "守衛がまた威嚇的に発砲したのであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦士等が舟の上から発する妙な威嚇的な喊声。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤井に先を越されたという想いと、一つにはその生徒の英雄を気取った、威嚇的な態度に対する義憤から、飛び出してみたものの、一人相撲の感があった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると闇い木陰に潜伏して居て嫁の車が近づいた時突然、其の車を顛覆させてやれといふやうな威嚇的の暴言をすら吐くことがある。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は少し威嚇的に訊ねた。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師その人に成心が無く、威嚇的で無かったということも、この作品を快くしました。",
              "citation": {
                "source": "二つの作品",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ただし」というとまた威嚇的、「ご承知なくば是非に及ばず、剣戟をもってお相手致す。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」緑色の鋭い賢い眼をした祖父の神は、常に人間の誤ちに目をとめていて、それを罰したり、こらしめたりするのが仕事の、威嚇的な形式的な神であった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三条にいる小さい人たちもかわいそうな顔をして母を恋しがっていましたが、選って残しておいでになったのにはそれだけの考えがあるのでしょうから、あなたに愛されない子供達を私の手でどうにか育てましょう」　とまた多少｜威嚇的なことを夫人へ言ってやった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧二",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けると車などを持って来て、常陸守の帰りを促す腹だたしげな、威嚇的な言葉を使いが伝えたため、「もったいないことですが、万事あなた様をお頼みに思わせていただきまして、あの方をお手もとへ置いてまいります。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこは随分大きなお寺がたくさん有る処でありまして、耶教撲滅の意味で、威嚇的に大きくたてられたお寺ばかりです。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい窓に雪の降りこめてゐるのを眺め、富岡は、尨大で威嚇的な人間社会の切断面を覗いた気がした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おい、お勝』再びその声は響いた、――今度はその音調はもっと威嚇的であった。",
              "citation": {
                "source": "幽霊滝の伝説",
                "author": "THE LEGEND OF YUREI-DAKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり「切」は「斬」であって、事一銭に関する如き微罪といえども、斬罪の厳刑をもってこれを処分し、毫も仮借することなきぞとの意を示した威嚇的法文と見るのが穏当と思われる。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方とも「親愛なる親方よ」というアメリカふうの俗語を冒頭に、威嚇的言辞を用いて新しい犯行を揚言し、手紙には「売春婦でない婦人にはなんらの危害を加えないから、その点は安心していてもらいたい」という意味を付加して、ともに「斬裂人ジャック」と、署名してあった。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝負だア――」　と威嚇的に叫んだ。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その間もジリジリと敵の勢は、威嚇的に無言に逼って来る。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で……」と云うと冷泉華子は、穏かではあるが気味の悪い、叮嚀ではあるが威嚇的の、矛盾した微笑を浮かべたが、「で、あなたがどう隠し、どう口をお噤みなさろうと、最後には一匹の蝶のありかを、きっと云わせてお目にかけます。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、そうだよ、「釜無しの文」だよ」こう云いながらその男は、ヌッと部屋の中へ入って来たが「婆さん」と、ひどく威嚇的に「お前あっちへ行っていな、俺ら「爺つあん」に用があるんだからな」　雇婆さんが行ってしまった後、二人はしばらく黙っていた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲の繁った木立によって、一切外界と交渉を断ち、一劃をなした別世界に、一種威嚇的な空気を纏い、物云わず立っている気味の悪い存在！",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "線香の煙がもう／＼とあたりをこめ、威嚇的な鐘の音が、かん、かんと鳴り通した。",
              "citation": {
                "source": "四谷、赤坂",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今朝早く、常見からの速達郵便が届いて、昨夜一晩寝て考えた上のことだが、期限はお待ちするけれど、ついては確実な保証人を一人たてて貰いたく、さもなくば止むを得ざる手続きを取ると、威嚇的な文句なのです。",
              "citation": {
                "source": "白い朝",
                "author": "――「正夫の童話」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方の岸には武器をたずさえ、武装した藩の武士たちが充ち満ち、対岸には百姓一揆の大衆が、莚旗や神社の幟や、節句に用うる吹き流しをさえ立て、時々威嚇的に喊声をあげたり、竹法螺や法螺貝を吹き立てたりした。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
