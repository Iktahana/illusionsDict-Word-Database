[
  {
    "uuid": "504077be-2959-52c7-912d-c93ba9bc7951",
    "entry": "生きる力",
    "reading": {
      "primary": "いきるちから",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
