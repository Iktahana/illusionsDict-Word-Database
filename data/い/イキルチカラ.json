      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "zest for living",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "重い病気を乗り越え、彼女の顔には失われていた「生きる力」が再び宿り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の回復の早さに、医師は「この子は本当に生きる力に満ちているね」と感心していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親は子供の自主性を尊重し、内なる「生きる力」を育むことが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "どんな困難に直面しても、希望を失わず、前を向く「生きる力」こそが人間を強くする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "挫折を経験した彼だが、「大丈夫、まだやれる、生きる力は残ってる！」と自分に言い聞かせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雨上がりの虹を見て、ふと「当たり前の日常こそが、一番の生きる力なのかもしれない」と感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "被災地から届く温かい支援は、人々の「生きる力」を支える大きな力となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "斯くて、慧鶴は生きる力を求めて、わずかに自分の中にある名望の慾に探り当てた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の生きる力というものにも、前の医者の話と同じ道理があるようです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に自分の生きる力ばかりを鞭打って飽くまでやり通そうとするのは、それはゴムの紐を最大限に引伸して、いつまでも使えるものと思うのと同じことです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの話の中には、生きる力の秘密が囁かれているからです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰ぐ力と、信念と、自分の力と、この三者は、時に円融し、時に鼎分（三つに分れること）し、そこに反省あり、三昧境あり、以て一歩一歩、生きる力の増進の道を踏み拓いて行くのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の底から腐って、生きる力も張合いもなくなるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからお前はもう善良なものでは生きる力を得られなくなった。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "というキリストの慰めが、私に、「ポオズでなく」生きる力を与えてくれたことが、あったのだ。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きる力が衰えている筈はない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この繰り返しの中で、自分と自分の生活を見つめる目を育て、強く生きる力を育てていく。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を持ちこたえる気力のないものが、自分を憫んで、自ら生きる力もないその命を仕末するにはこうするよりほかに途がないと言わぬばかりに、ちいさな泡が、ぶくぶく、ぶくぶくと、かすかに二度三度湧きあがって来たばかりだった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きる力のこれほどに強大なのを眺めていると、自分までがおのずと心強いようにも感じられて来るではないか。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちはこの人生において自分たちの幸福を、自分たちの生きる力こそがつくってゆくものであることを、腹から知らなければならないと思います。",
              "citation": {
                "source": "生きるための恋愛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真理と美との人類的遺産を十分理解し、それをよろこび、それに励まされて人間らしく生きる力を、子供らが持つことを希望していたらしい。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "流し元の草の中に、捨芹が青々と花をつけてゐる、生きるものゝ生きる力のめざましさ、省みて恥ぢ入つた。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、松本氏がああいうやりかたで自分の真情を吐露されたのは、それで松本氏の気がすみ、生きる力となったのなら、よいではないかと思います。",
              "citation": {
                "source": "私も一人の女として",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "烈しい愛の感情を、具体的な日常の、そのときどきの事情に応じて必要な形で活かし、あるときは愛情ふかい看護人とし、或る時は活溌な助力的な友達として、或る時はまた美しいけもののように素朴で豊富で、きつく、新鮮な女として生かしてゆくのでなかったら、生きる力としての愛のねうちはどこにあるでしょうか。",
              "citation": {
                "source": "私も一人の女として",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の力が一方で最大限にその破壊の力を振るっている時には、ますます他の一方で創造の力、生きる力としての科学の力、それを動かす科学者としての情熱が必要と思われたに違いない。",
              "citation": {
                "source": "キュリー夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い生きる力は、そういう我知らぬエゴイズムに満ちるときもあるのだ。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はもう生きる力をどこかへなくしてしまったのだろうか。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、考えて見れば、年少時代から今日まで、何らかの理想――夢を最高度に描いて、それによって鼓吹されることなしには生きる力の出ない性格であるらしい。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その妄想の執着が存する限り僕は生きる力がその執着から湧き出してくることと信じている。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物はこの境遇の中で、ゴーリキイに生きる力の源泉となったと同時に、限りない屈辱、軽侮、不安を蒙る原因となった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "教養そのものの中にさえ、「士族の娘」という意識に立って、彼女を窮屈にしている幾多の古い力が与えられて来ているけれども、一人になった生活感情をさぐってみれば、なかなか逞しく不屈に生きる力ももっている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パール・バックは、中国の庶民の女の生きる力のつよさ、殆ど毅然たる勇猛心を実によく感得した。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その難関を突き抜けて行くうちに次第に強く生きる力を与えられます。",
              "citation": {
                "source": "今日になるまで",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私は本当はもう、とうから生きる力をうばはれて居ります。",
              "citation": {
                "source": "背負ひ切れぬ重荷",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きる力のびる力をもつてゐる限りのものは自分で勝手に、すきなものを吸収することの出来るやうに自然はいろ／＼なものを豊富すぎる程与へてゐますものね、私たちはいくつ取つても／＼たりないほど沢山のものに恵まれることが出来るのです。",
              "citation": {
                "source": "九州より",
                "author": "――生田花世氏に",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
