    },
    "definitions": [
      {
        "index": 1,
        "gloss": "threat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "動物が縄張りを守るために行う威嚇行動は、しばしば相手を遠ざける効果がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "犯人は被害者をナイフで威嚇し、金品を奪った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "相手国の軍事演習は、周辺諸国への政治的な威嚇と見なされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "裁判官は、証言を歪めようとする試みを厳しく威嚇した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は集団の中で力によって相手を威嚇し、自分の意見を通そうとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう二度とそんなことをするな、と彼は相手を威嚇した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「おい、邪魔するならただじゃおかないぞ」と、不良は相手を肩で威嚇した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "學校の廊下には、べたべた推薦のビラが張られて、選擧事務所なども、ものものしく、或るものは校門の下に立つて、登校の生徒ひとりひとりに名刺を手交し、よろしくたのみます、といつて低くお辭儀をして、或るものは、中學校の先輩といふ義理のしがらみに依つて、後輩を威嚇し、饗應、金錢、などといふばかな噂さへ立つた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉間には狐疑の深い皺がきざみ込まれ、小さい灰色の眼には淺間しい殺意が燃え、眞蒼な頬は威嚇の怒りに震へて、黒ずんだ薄い唇は嫌惡と侮蔑にひきつつたやうにゆがんでゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室へ戻って、友人にハガキを書いていると、富士の雲が引いて取ったように幕を明け、銀磨きの万年雪が、巨獣の斑紋のように二筋三筋キラリと光って、夏の富士にして始めて見るところの、威嚇的な紫色が、抜打に稲妻でもひらめかしそうに、うつぼつと眉に迫って来る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その立体構成面の威嚇的偉大さを、駭くべき簡単なる曲線で、統整して、しかも委曲に至っては、富士で謂うところの八百八谷の線から、おのずと発生する凹凸面の、複雑なる入り乱れのために、眼もあやになることを如何ともしがたい。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、蜂はあわてて穴から出て來たが、忽ち松葉に向つて威嚇的な素振を見せた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "植民地の労働者をベラ棒に安い、牛か馬かを使うような調子に働かせるために、威嚇し、弾圧する。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近松少佐は思うままにすべての部下を威嚇した。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それでも工人は、軍隊に庇護される感じは受けずに、威嚇されるのだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高取は、蛋粉工場においても、工人達が兵士の威嚇を受けて、すくみ上っているのを知っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑法上の逮捕と同じような威嚇の方法で君を捕える。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかりし間他の軍夫は、しばしば同情の意を表して、舌者の声を打消すばかり、熱罵を極めて威嚇しつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステッキなど持って歩くと、犬のほうで威嚇の武器と勘ちがいして、反抗心を起すようなことがあってはならぬから、ステッキは永遠に廃棄することにした。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩侯の宝物蔵にあったという、由緒づきの大な遠目金を台つきで廻転させるのであるから、いたずらものを威嚇するのは十分だが、慌しく映るものは――天女が――縞蛇に――化鳥に――　またたちまち……「やあ、轆轤首の女だ、運五郎。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟味与力は罪人をよび出して今日はいよいよ拷問を行うぞという威嚇的の警告をあたえ、なるべくは素直に自白させるように努めるのであるが、それでも本人があくまでも屈伏しない場合には、係り役人は高声にかれの不心得を叱りつけて、さらに初めて拷問に着手するのである。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は酔い、或は醒め、或は夢み、自分の頭脳は種々の混乱を来した末に、お杉｜婆の威嚇的命令の下に重太郎の嫁たるべく約束した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉間には狐疑の深い皺がきざみ込まれ、小さい灰色の眼には浅間しい殺意が燃え、真蒼な頬は威嚇の怒りに震へて、黒ずんだ薄い唇は嫌悪と侮蔑にひきつつたやうにゆがんでゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "易者の哲理萩原朔太郎　すべての易者たちは、彼の神祕な筮竹を探りながら、威嚇するやうな調子で言ふ。",
              "citation": {
                "source": "易者の哲理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "易者の哲理萩原朔太郎　すべての易者たちは、彼の神秘な筮竹を探りながら、威嚇するやうな調子で言ふ。",
              "citation": {
                "source": "易者の哲理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方富之助が死の空想を飾り、之を多樣に構想して居る間に、遠い姉に對する不祥な豫感が、絶えず、現實的の威嚇となつて彼を襲うてゐた。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩愛に絡まれている安宅先生の鏡に在る自分は、魅惑に牽き付けられている蝶子さんの鏡にも、生活に獅噛み付かれている老女二人の鏡にも映り反して、既に在る映像と他より映れる映像とは、唾棄し合い、嘲笑し合い、威嚇し合っている。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡の中の分身また分身、唾棄からは吐息が生れ、嘲笑からは悲憤が生れ、威嚇からは憂愁の限りない嗚咽が生れる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は新米の乞食のわたくしを見て、女と侮り矢庭に「擲るぞ」と拳を振上げて、威嚇しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃声は守衛が威嚇的に射ったものだろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "守衛がまた威嚇的に発砲したのであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我れわれもそう思ったもんですから、毎晩代るがわるに小屋の周囲を見廻って、威嚇にピストルを撃ったこともあります。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人をしかった上官にも見せてやりたかったんやが、『その場にのぞんで見て貰いましょ』と僕の心を威嚇して急に戦争の修羅場が浮んできた。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紛争が続き、結局、独逸は（ビスマルク流の遣り方だ）軍艦五隻をアピアに入港させ、其の威嚇の下にクー・デ・タを敢行した。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦士等が舟の上から発する妙な威嚇的な喊声。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛は太く短くまっ黒で、おどおどした両の小さい眼を被いかくすほどもじゃもじゃ繁茂していやがる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、橇に積んだボール紙の箱を乾草で蔽いかくし、馬に鞭打って河のかなたへ出かけて行った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
