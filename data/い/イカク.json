[
  {
    "uuid": "f76328dd-ecdb-56b6-b7ef-44bfb8b7369d",
    "entry": "威嚇",
    "reading": {
      "primary": "いかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
