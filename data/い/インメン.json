    },
    "definitions": [
      {
        "index": 1,
        "gloss": "face of a seal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "印刻の夜業ランプには、硝子玉のレンズを掛けて、その明りの焦点に印面をおき、先の鋭い印刀で、パリッパリッと、微細な印字を彫ってゆくのである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……これを、それがしに賜わるのですか」　関羽は一応、恩誼を謝したが、受けるともなく、印面の文を見ていた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "改めてできてきた印面には、漢の一字がふえていた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色燦爛として、印面には、八字の篆文が刻してある。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
