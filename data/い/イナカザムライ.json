  {
    "uuid": "35813a9a-82b4-501b-9f87-2383465794e0",
    "entry": "田舎侍",
    "reading": {
      "primary": "いなかざむらい",
      "alternatives": [
        "いなかさぶらい"
      ],
      "is_heteronym": false
    },
