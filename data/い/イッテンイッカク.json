[
  {
    "uuid": "f741af96-4d14-5ce5-b1e7-a1b0f3f216fb",
    "entry": "一点一画",
    "reading": {
      "primary": "いってんいっかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
