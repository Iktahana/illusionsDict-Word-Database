        "examples": {
          "standard": [
            {
              "text": "初期費用はかかるが、月額料金を払い続けるより一括購入してしまったほうが最終的には安上がりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オフィス移転に伴い、デスクや椅子をすべて同じメーカーで一括購入し、大幅な値引きを引き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「宝くじが当たったら、あのマンションを一括購入してやるんだ」と彼は冗談めかして語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライセンスを一括購入することで、社内の全デバイスに最新のセキュリティソフトを導入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "八百や魚やなどが、当番の一括購入となり、うちの組は十軒三十二人。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
