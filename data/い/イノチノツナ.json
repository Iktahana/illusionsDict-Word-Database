[
  {
    "uuid": "e14bfc53-9093-5231-9282-9bac76ab7f1f",
    "entry": "命の綱",
    "reading": {
      "primary": "いのちのつな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
