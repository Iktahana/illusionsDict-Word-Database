          ],
          "literary": [
            {
              "text": "」妹が意見を述べる。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかしまた、」主人は、ひどくもったい振って意見を述べる。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく世間の中には、宗教と科学とは両立しないとか、宗教は文化に逆行するとかいう意見を述べる人があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "万年筆の丸善に於る需要をそう解釈した余は、各種の万年筆の比較研究やら、一々の利害得失やらに就て一言の意見を述べる事の出来ないのを大いに時勢後れの如くに恥じた。",
              "citation": {
                "source": "余と万年筆",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そもそも「舞」とか「謡」とか「囃子」とかいうものの本来の使命はどこに在るか……その本来の使命が「能」ではどんな風に果されつつあるか……という事に就いて、私一個人の無鉄砲な意見を述べる事は出来ようと思う。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分の意見に耳を傾けてくれる者に対しては、養父弥平のとっている態度のいっさいを否定し、自分の意見を述べることがあった。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "考え込む友人の前で突然、それも一五分も沈黙したあとで、もっともらしい意見を述べる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも先生のいわるる通で、この時分の先生の容体は、人々各番に毎日看護に来るという有様であるから、以上のごとき複雑な問題に意見を述べるなどいうこと出来るはずがないのである。",
              "citation": {
                "source": "竹乃里人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ風にその記者について意見を述べる批評家は出て来ないか。",
              "citation": {
                "source": "黒猫",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の意見を述べる前に、兎に角皆様の御意見を承わろうじゃありませんか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の意見を述べる前に、兎に角皆様の御意見を承はらうぢやありませんか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　かくの如き問題はその道の学者に教えを乞うべきで、私如きものが回答するのは僭越極まる次第であるが、私の尊敬する白柳秀湖、清水芳太郎両氏の意見を拝借して、若干の意見を述べる。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの二つは正直に白欄にしてあるのであるが、敢えて大胆に意見を述べることとする。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩、自分は最後の時間をうけもっていたのでおそく出席し、そもそもその講習会員がどんな発端からそういう話をはじめたのかわからず、鹿地亘が意見を述べるのを聞いていた。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて情報処理事業グループのマシンにＰＣ―８００１の継承を求めた渡辺和也も、Ｎ―10プロジェクトに参考意見を述べるために加わって、オープンアーキテクチャーの重要性を訴えた後藤富雄と加藤明も、浜田たちが一六ビット機を開発していることは当然承知していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "生物学の意見を述べる物理学者は小犯罪を犯すものと見られ、賢明に芸術を研究する実業家の商業的敏捷性もまた疑われつつある。",
              "citation": {
                "source": "科学的新聞記者",
                "author": "桐生悠々",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに私が県地にいて小学教育を督励していた経験では、是非とも強迫就学となし、その教育費も他の租税の如く、賦課するのでなければ結局の目的は達せられないという事を知っていたから、最前地方官会議の随行中文部省に出頭した時もこの意見を述べるし、また九鬼文部大輔にも面会してこの事を話して置いた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "野だの癖に意見を述べるなんて生意気だ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、自分の発表した議論によつて自分を束縛し、或は意見を述べることによつて自己弁護するからである。",
              "citation": {
                "source": "頃日雑記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "間をおいて、考え考え、ただ自分の意見を述べるだけで満足して、良一の意見は求めなかった。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人なかで何か意見を述べることが、私には殆んど出来ない。",
              "citation": {
                "source": "孤独者の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これに対し、私は今自分の意見を述べることを差控へよう。",
              "citation": {
                "source": "官立演劇映画学校の提唱",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三の質問を発しはしたが、私の訊きたいことはまともに答へられず、僅かに日本語達者な柯、関両氏がその親日的辞令をもつて、あたらずさはらずの意見を述べるだけである。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私の意見を述べることにする。",
              "citation": {
                "source": "戯曲及び戯曲作家について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる制度の具体案については、私はまだなんら意見を述べる資格はない。",
              "citation": {
                "source": "映画アカデミイについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は前者を選んだのだ」　私はこれに対して私の意見を述べる必要はなかつた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は国語教育について特に専門的な意見を述べる資格はないが、演劇方面の仕事に関係して痛切に感じてゐることは、俳優技術確立の基礎条件として、この国語教育の欠陥を先づ埋めなければならぬといふ事である。",
              "citation": {
                "source": "演劇統制の重点",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いのはかう云ふ時代精神は、言葉の自然の変化の中に現はれてゐると云ふことを、私はこの書物で教へられて驚いてゐるのでありますが、例へば……フランス語の例で十分説明はつきかねますが、十六世紀の頃には、自分の意見を述べるのに、相手の立場といふものを必要以上に考慮にいれる習慣がありました。",
              "citation": {
                "source": "文学者の一人として見た現代日本語",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
