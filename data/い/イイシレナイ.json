[
  {
    "uuid": "86c711e8-bcff-5d1a-886b-fa39fbdc5f52",
    "entry": "言い知れない",
    "reading": {
      "primary": "いいしれない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
