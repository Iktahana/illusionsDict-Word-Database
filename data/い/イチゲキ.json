[
  {
    "uuid": "9fcc51b3-8a5e-5270-875b-90e66a9090d7",
    "entry": "一撃",
    "reading": {
      "primary": "いちげき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
