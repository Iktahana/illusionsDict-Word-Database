        "examples": {
          "standard": [
            {
              "text": "イエール大学の研究チームが、地球温暖化に関する画期的な報告書を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はイエール大学で歴史学を専攻し、後に著名な歴史家となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まさか、あのイエール大学に留学するなんて、すごいじゃないか！」と友人は目を丸くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イエール大学は、その美しいゴシック様式のキャンパスでも有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くのノーベル賞受賞者を輩出しているイエール大学の教育水準は、非常に高いと評価されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はイエール大学のロースクールに進学するため、猛勉強を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イエール大学の図書館には、貴重な古書が数多く所蔵されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
