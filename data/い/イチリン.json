    "definitions": [
      {
        "index": 1,
        "gloss": "single flower",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "野道に名もなき花が一輪だけ咲いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女の髪には、真っ赤な薔薇が一輪飾られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "庭で摘んだ一輪の向日葵を、空き瓶に生けて窓辺に置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たとえば裏の竹藪に蛇が出たとか、蟇が鳴いてるとか、蟻の山が見つかったとか、梅の花が一輪｜咲いたとか、夕焼が美しく出ているとかいうようなことを、だれか家人の一人が発見すると、一々それをヘルンの所へ報告に行く。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンポポの花一輪の贈りものでも、決して恥じずに差し出すのが、最も勇気ある、男らしい態度であると信じます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原には矮小な夾竹桃がただ一輪真赤に咲いている。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロモンの栄華も一輪の百合の花に及ばないという古い言葉が、今の自分には以前とは少しばかりちがった意味に聞き取られるのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一輪の朝顔の花にしても、ある朝ある家のある鉢の朝顔をある方向からある距離から撮影した具体的の朝顔の花であるのに、文字の「朝顔の花」は時間空間から抽象された朝顔の花であるからである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "童女は黒地に赤い縞の洋服を着て、右の手に花を一輪もっている。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう訳だか分らないが、あの右の手の何とも名状の出来ない活きた優雅な曲線と鮮やかに紅い一輪の花が絵の全体に一種の宗教的な気分を与えている。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ科学の野辺に漂浪して名もない一輪の花を摘んではそのつつましい花冠の中に秘められた喜びを味わうために生涯を徒費しても惜しいと思わないような「遊蕩児」のために、この取止めもない想い出話が一つの道しるべともなれば仕合せである。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミサコ女史よ、巴里ではミモザの花は一輪いくらしますか。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、一輪お高うございますわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊濁点付きの二倍の踊り字は「／″＼」-------------------------------------------------------一　五六台の一輪車が追手に帆をあげた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一本しかない一輪車の車軸は、巨大な麻袋の重みを一身に引き受けて苦るしげに咽びうめいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一輪車は菱形の帆をふくらましたまゝ貧民窟から、その兵営の土煉瓦のかげへかくれて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一輪車が咽ぶその反対の方向では、白楊の丸太を喰うマッチ工場の機械鋸が骨を削るようにいがり立てた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に目も眩んで倒れそうになると、禍はこの辺が絶頂であったと見えて、隧道を抜けたように、遥に一輪のかすれた月を拝んだのは、蛭の林の出口なので。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "代赭色の小鉢に盛り上がった水苔から、青竹箆のような厚い幅のある葉が数葉、対称的に左右に広がって、そのまん中に一輪の花がややうなだれて立っている。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄干の隅の花鉢に近づいてその中から一輪の薔薇を取り上げてみると、それはみんな硝子で出来ている造花であった。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり人造でもマーブルか、乳色ガラスのテーブルの上に銀器が光っていて、一輪のカーネーションでもにおっていて、そうしてビュッフェにも銀とガラスが星空のようにきらめき、夏なら電扇が頭上にうなり、冬ならストーヴがほのかにほてっていなければ正常のコーヒーの味は出ないものらしい。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう人たちが、もし途上の一輪の草花を採って子細にその花冠の中に隠された生命の驚異を玩味するだけの心の余裕があったら、おそらく彼らはその場から踵を返して再び人の世に帰って来るのではないかという気もするのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後方に一輪車が取り付けられ、そうして三つの輪の中央のサドルに腰をかけた人がペダルを踏んで推進する仕掛けになっている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンポポの花一輪の信頼が欲しくて、チサの葉いちまいのなぐさめが欲しくて、一生を棒に振った。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀器の光、ガラス器のきらめき、一輪ざしの草花、それに蜜蜂のうなりに似たファンの楽音、ちょうどそれは「フォーヌの午後」に表わされた心持ちである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと其処にファニーが素足のままで手に一輪の薔薇を捧げて急がしくはいってきた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠義を尽くしながらかえって主人に叱られた犬のような遠慮と謙遜とを身ぶりに見せながら父の側に近づいて、そっとその手にまた一輪の薔薇の花を置いた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上の小さな一輪挿しには椿、さつき、菜の花、海棠、山吹、薔薇という順序に花が挿されて、最後の薔薇が花を開き切らない中にそこを去るようになりました。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、自分のを並べ果てて、対手の陣も敷き終る折から、異香ほのぼのとして天上の梅一輪、遠くここに薫るかと、遥に樹の間を洩れ来る気勢。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆の中より、水際立って、美しく水浅葱に朝露置いた大輪の花一輪、白砂の清き浜に、台や開くと、裳を捌いて衝と下り立った、洋装したる一人の婦人。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お若と云うのは、一輪の冬牡丹を凩に咲かす間もなく、その家で煩いついて、いわゆる労症の、果はどっと寝て、枕も上らないようになると、件の間夫の妹と称する、いずくんぞ知らん品川の女郎上り。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱れて咲いた欄干の撓な枝と、初咲のまま萎れんとする葉がくれの一輪を、上下に、中の青柳は雨を含んで、霞んだ袂を扇に伏せた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが肉体いちぶいちりん動かさず、すべて言葉で、おかゆ一口一口、銀の匙もて啜らせ、あつものに浮べる青い三つ葉すくって差しあげ、すべてこれ、わが寝そべって天井ながめながらの巧言令色、友人は、ありがとうと心からの謝辞、ただちにグルウプ間に美談として語りつがれて、うるさきことのみ多かった。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
