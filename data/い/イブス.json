        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "蚊が多かったので、線香を焚いて部屋を煙でいぶした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "囲炉裏で魚をいぶし、じっくりと旨みを凝縮させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い小屋の壁は、長年の薪の煙にいぶされて真っ黒になっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「早く體あ倒にして、松葉の煙で燻すが可い。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い繊細な薬指のところに指輪を嵌めた手で、巻煙草を燻すお新の手付を眺めると、女の巻煙草は生意気に見えていけない、そうは山本さんは思わなかった。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄も芝居に就ては全たく興味がなささうだつたけれども、例の如く鷹揚に構えて、黒い頭を燻す程、葉巻をゆらした。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄も芝居に就ては全たく興味がなさそうだったけれども、例の如く鷹揚に構えて、黒い頭を燻す程、葉巻をくゆらした。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "振返って見ると、一方の畦の上には菅笠、下駄、弁当の包らしい物なぞが置いてあって、そこで男の燻す煙草の煙が日の光に青く見えた。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三吉はえらく煙草を燻すように成ったナ」と森彦はすこし顔をシカめた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を飲むじゃなし、煙草を燻すじゃなし……よくああ自分が責められたものだと思って、私は何時でも感心して見て来る。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "8920　　　　闇の女鉢に五徳に鋭い鉞、洗う水も燻す火も、何もかも御殿に用意してあります。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三輪の親分が氣を揉んで、見境もなく人を縛りますぜ」「そんなこともあるまい」　平次は相變らず赤蜻蛉の亂れ飛ぶのを眺め乍ら、鐵拐仙人のやうに粉煙草の煙を不精らしく燻すのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "第廿七吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三輪の親分が気を揉んで、見境もなく人を縛りますぜ」「そんなこともあるまい」　平次は相変らず赤蜻蛉の乱れ飛ぶのを眺めながら、鉄拐仙人のように粉煙草の煙を不精らしく燻すのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "第廿七吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等はすべて、屋内にかけ渡した竿からぶら下っていて、火から出る煙が結構それを乾し燻す。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方には掛架があり、魚はこれにひっかけて燻す。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に、道の上から人の跫音がしたと思うと、彼の前に、狩衣の裾をくくり上げて、手に松明を持った公卿屋敷の奉公人らしい男が立って武蔵の顔を燻すように、松明の火を突き出した。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "初期にはどうであったか知らぬが、少なくとも今日の西洋人はただ口中を燻すばかりで、鼻の穴からもめったに煙を出さない。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "線香をいぶすのにも、お経を読むのにも早過ぎた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「林茂光がくるやうになつてから、だいぶすべてが調つて來たが、僕はその時分から大概負けなかつたよ。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊がうるさいけれど、蚊帳のない暮しむきなので、皿におがくずを入れていぶす。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廓の女でも、躰は売っても心は売らないと、口はばったく言えた時代で、恋愛遊戯などする女は、まだだいぶすけなかったのだ。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場所は、今はだいぶすでに開墾されて立派な畑地になっていた。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれ、だいぶすずしくなったから、はいってねましょうか。",
              "citation": {
                "source": "風七題",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、だいぶすいてきた車内の男女は、おばあさんに見られぬ前から、ともすると視線をおばあさんに集めがちだつた。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴたつと止つてゐる水兵達のすぐ傍の、稻田の水のついた地面へ、それ等の彈丸は落下し、その一つ一つは霰の素早いぶす／＼いふ音を立てて、輕く水を撥ね飛ばした。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの違い棚に蚊とり線香をいぶす瀬戸物の容器があるでしょう」「それぐらいのことは知ってる。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその刑罰は、子供らを逆さに吊してこれをいぶすのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを蜂の巣の下でいぶすんだ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大盗の恋「おい法達、いぶすのはもういい加減にしてくれないか。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の客人をいぶすのは禁物だったかもしれない」　最前ここへ訪ねて来て、そこに居合せた雲霧と四ツ目屋も、声を合せて笑いながら、「なあに、おれたちは極めつきの白浪だ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、おりんはどうしたの」「さあ、それは分らねえが」　こんな会話をつづけ合っていると、どこからともなく、柴をいぶすような白い煙が、自分たちの足元へ低く這ってきたので、「や。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通山村に入ってよく見かける実例は、今日では石油を襤褸に浸していぶすものであるが、以前は竹の串に髪の毛を少し綰ねて挾み、その片端を焦がしたもの、あるいは野猪の生皮を一寸角ばかりに切って、これもちょっと焼いて竹のさきに挾んだものなどを立てる。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
