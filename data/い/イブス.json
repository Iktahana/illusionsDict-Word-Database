        "examples": {
          "standard": [
            {
              "text": "使い古した銀の食器は、空気にいぶされて鈍い光沢を放っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長期間放置されていた鉄製品は、水分と空気にいぶされてすっかり錆びついていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの古銭は、長い年月を経ていぶされたような独特の色合いが魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
