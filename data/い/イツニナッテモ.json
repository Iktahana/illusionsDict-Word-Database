          ],
          "literary": [
            {
              "text": "それはいつになっても変改されない。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い話がむやみに人殺しをすれば後には自分も大概は間違いなく処刑されるということはずいぶん昔からよくだれにも知られているにかかわらず、いつになっても、自分では死にたくない人で人殺しをするものの種が尽きない。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、いつになってもその朝の御飯はなかった。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに較べて、いつまでも処女性を持ち、いつになっても感情のまま驀地に行くかの女の姿を見ると、何となく人生の水先案内のようにも感じられた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いつになってもお顔の色は妙に優れず、お眼が血走って、いつもイライラなさっていられるのを見ますと、私共は、まだ本当にお加減はよくなっていられないのだなと、思われたほどでございます。",
              "citation": {
                "source": "幽霊妻",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴くべき時に聞き、味わう時に味わわねば、いつになっても聞く事もできなければ、また知る事もできないのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、この有名なる富める友人のお蔭で、その邸に出入しては、自分の財布に相談してはいつになっても得られないような御馳走にありついたり、遇には独り身の鬱血を払うために、町はずれの安待合の格子をくぐるに足るお小遣を彼からせしめたこともあった。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災のときこれの親父に死なれましてからってもの、もう手も足も出なくなっちゃいましてね」と、徐ろに永い、いつになっても限りのない貧の託ち話を始める。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、師匠だけが、いつになってもその技を良しとしない。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械へ向ける気持だけは、いつになっても変らなかった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭陵の酒を買わせるやら、桂州の竜眼肉をとりよせるやら、日に四度色の変る牡丹を庭に植えさせるやら、白孔雀を何羽も放し飼いにするやら、玉を集めるやら、錦を縫わせるやら、香木の車を造らせるやら、象牙の椅子を誂えるやら、その贅沢を一々書いていては、いつになってもこの話がおしまいにならない位です。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もちろん気に入ったと言っても、今まで描いたもののうちではというくらいなところですが――とても思う通りには、いつになっても、描けはしません。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来いつになっても働く人間の姿は見えず、ある個所は橋をかけるように堤防と堤防とをきりはなしたまま、鉄橋はなかった。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになっても本能的に馴染むことの出来ないところがあって、ひろ子に一種の苦しい気分を起させるのであった。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その豪壮を極めたケルト・ルネサンス式の城館を見慣れた今日でさえも、尖塔や櫓楼の量線からくる奇異な感覚――まるでマッケイの古めかしい地理本の插画でも見るような感じは、いつになっても変らないのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パドミーニ、パドミーニを呼んで」　腰の痛みだけは、私にもさすが触らせない……しかしパドミーニは、いつになってもこの室へ戻ってこない。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、池はもう温んだらしい底光りのする水の面に、堤をめぐった桜や柳を鮮にじっと映したまま、いつになっても竜などを天上させる気色もございません。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる楽天主義的な目隠しをとってしまえば、鴉はいつになっても孔雀になることはできない。",
              "citation": {
                "source": "十本の針",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "また時にはいつになっても春を知らない峰を越えて、岩石の間に棲んでいる大鷲を射殺しにも行ったりした。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、若者はいつになっても、容易に消息を齋さなかった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この機会にやらなければいつになってもやれないに違いない、あたりを一わたり眺めて見たが、人の気配はなかった。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇太郎、まちにまったが、老年宵ッ張りの師匠の菊之丞さえ、もう床についてしまったというのに、いつになっても、雪之丞が戻らぬので、気にもなり、いら立たしくもなって来た。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷の上、彼のアイガーの頂には帽子雲がかぶさって、いつになっても、晴れる様子は見えない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことじゃ、いつになってもきまりっこないわよ。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになってもその正体がつかめないのだ。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはいつになってもこの断片的なものを溺愛する。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、つかまりそうで、つかまらないことは、いつになっても同じです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして首を斬られて、梟される御当人と来ちゃ、これも酔興とはいえねえが、それでもあんなところへ上りたがる首が、いつになっても絶えねえのは浅ましいことだね。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
