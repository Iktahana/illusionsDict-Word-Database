        "examples": {
          "standard": [
            {
              "text": "雅楽において壱越調は、その明るく堂々とした響きから、祝宴の場で奏でられる曲に多く用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "管弦の代表曲である「越天楽」の壱越調は、正月の定番曲として日本人に広く親しまれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この曲は壱越調ですから、もっと主音のニ（D）の響きを意識して奏でてください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "壱越調は呂の旋法に属し、洋楽の長音階に近い明るい色彩感を持っているのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞楽「胡蝶」は壱越調の代表的な曲であり、その軽快なリズムが春の訪れを想起させる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "龍笛の指穴を正確に押さえ、壱越調特有の流麗な旋律を響かせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "元来、壱越調｜呂旋であるべきこの曲が平調で唄われるさえ訝しいのに、宮声に凄切の気韻があったのはどうしたわけか。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
