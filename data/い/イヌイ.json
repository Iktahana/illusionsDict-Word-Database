        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「戌亥の方角に蔵を建てれば家が栄える」という言い伝えを守っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "磁石の針を頼りに、戌亥にあるはずの古井戸を探し歩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この屋敷の戌亥の角には、魔除けのためにヒイラギが植えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕暮れ時、戌亥の空に一番星が輝き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その英吉が、金の性、お妙が、土性であることは、あらかじめお蔦が美い指の節から、寅卯戌亥と繰出したものである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一法は、戌亥子丑寅と五支の名を唱えつつ五指を折り固むるのだと。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "……戌亥にあたって丘があり、辰巳に向かって池がある。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……戌亥に二棟の土蔵がある。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此の山のていたらく……戌亥の方に入りて二十余里の深山あり。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日見という山名の起原に就ては、河原沢村の所伝に従えば八日見山ト申ハ、日本武尊東夷征伐ノ時、東国ノ海陸御巡幸有テ、夷賊追伐ノ御祈トシテ筑波山ニ登ラセタマヒ、遥ニ御覧アツテ、衆山相連ナレル中ニ殊ニ秀タル瞼山戌亥ニ当テ有リ、八日以来、見ヘタリト宣シヨリ、山ノ名ヲ八日見山ト名付ケ給フトナリ。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この崎から伊勢の港湾までは五里足らずだから、「助けたまえ、お伊勢さま」とそのほうへ向いて拝んでいるとき、急に風が戌亥にまわった。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "折あしく戌亥の強風。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、毎夜｜戌亥の空に一つの箒星が現われて、最初は長さ三、四尺で光りも弱いが、夜のふけるにつれて大きくなって行く。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか、地の女好きにこの探索の心が手伝って、町内の若い者が三、四人、毎夜のように交替って近江屋の前からお艶の後を尾けつけしたが、本八丁堀を戌亥へ突っ切って正覚橋を渡り終ると、先へ行くお艶の姿が掻き消すように消えて失くなるという怪談じみた報告を齎して、皆しょんぼり空手で帰るのが落ちだった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分さん、これを何と解いたもので御座いませう」「箒から辰巳、鎌の鼻から未申、鍬の耳から戌亥、口の中の眼――と讀むんだらうな。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "荒神箒",
                "note": "青空文庫"
              }
            },
            {
              "text": "その戌亥（西北）が空井戸だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "荒神箒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――（仲秋望の夜｜戌の刻、石筍の影地に落つるところ）――とある」「此方には――（戌亥に五歩、丑寅に七歩、石猿を叩いて道自ら開くべし）――とある」「御坊」「山浦氏、素より不浄の宝だが、大久保石見守の血を引く我々を此処まで導いた上は、この儘にもいたし難い。",
              "citation": {
                "source": "大江戸黄金狂",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "又考ふれば隱岐より戌亥の間四十里斗にして、石見より亥子の方八十里。",
              "citation": {
                "source": "他計甚※（竹島）雜誌",
                "author": "松浦武四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "より船を出して戌亥の方に向て遣り凡四十リといへり。",
              "citation": {
                "source": "他計甚※（竹島）雜誌",
                "author": "松浦武四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風が変った、丑寅が戌亥に変ったぞ、気をつけろやーい」　船の上では船員が、挙げてこの恐ろしい突発的の暴風雨と戦っています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戦がある」「大乱の兆しが見える」「宮門の戌亥に、虹が立った」夜の人出に紛れこんで、こう囁き廻る者がある。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、北門の戌亥口に配するに、水野忠重、大須賀康高。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――明夜、戌亥の頃を計って」「張遼と侯成を呼べ」　呂布も、遂に心をきめた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世で、りっぱにたたかいぬいた人にとってはです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンネ・リスベットこそ、そういう、りっぱにたたかいぬいた人なのです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の小亭のようなものが、脚を水上にはだけてぬいぬい立っている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は若者のくつのかたわらに、おのれの小さいぬいとりのあるくつをならべてぬぐと、青いもすそをあとにひいて水面にとんだ。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫、ざあざあ洗って洗いぬいた上、もう私が三杯ばかりお毒見が済んでいますから。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は始終私自身の力を信じていいのか疑わねばならぬかの二筋道に迷いぬいた――を去って、私には物足らない都会生活が始まった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二　今でもハムレットが深厚な同情をもって読まれるのは、ハムレットがこのディレンマの上に立って迷いぬいたからである。",
              "citation": {
                "source": "二つの道",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達の腹がルウテル博士のそれのやうに、ぽんぽこぽんにふくれあがるまで歌つて歌つて歌いぬいて呉れい。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらと闘いぬいて出て来ると、敵は何とかケチをつけるため、父親が一札を入れたおかげで出されたのだとか、あやまったからだとか「今回の検挙によって思想上に一転機を来した」から釈放されたとか、ブル新聞に書き立てさせる。",
              "citation": {
                "source": "逆襲をもって私は戦います",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "インベルの「日記」はレーニングラードがナチスの包囲線を戦いぬいた記録として注目すべきものだと云われている。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中処々行乞、伊野町へ十一時着いて一時まで行乞（道中いそいだので老同行を追いぬいたのは恥ずかしかった、すまなかったと思う）、銭三十四銭米六合戴いた、仁淀川橋、土佐紙などが印象された。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
