[
  {
    "uuid": "35db7b68-02bd-5164-8d34-00522c1b2793",
    "entry": "衣嚢",
    "reading": {
      "primary": "いのう",
      "alternatives": [
        "かくし"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pocket",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ジャケットの衣嚢に手を入れて、車の鍵を探した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "古いコートの衣嚢から、忘れていた一枚の写真が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は衣嚢からくしゃくしゃのメモを取り出して広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "」「衣嚢にあるけど……」「そうやな。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」貝の火兄弟商会の、鼻の赤いその支配人は、ねずみ色の状袋を、上着の内衣嚢から出した。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士は別段気にもとめず、手を延ばして状袋をさらひ、自分の衣嚢に投げこんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）例の楢ノ木大学士が衣嚢に両手を突っ込んで少しせ中を高くしてつくづく考へ込みながらもう夕方の鼠いろの頁岩の波に洗はれる海岸を大股に歩いてゐた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士は上着の衣嚢から鼠いろの皺くちゃになった状袋を出していきなり投げつけた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」貝の火｜兄弟商会の赤鼻の支配人は云ひながらすばやく旅費の袋をさらひ上着の内衣嚢に投げ込んだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る子は前掛けの衣嚢から干した無花果を出して遣ろうといたしました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士は別段気にもとめず、手を延ばして状袋をさらい、自分の衣嚢に投げこんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）例の楢ノ木大学士が衣嚢に両手を突っ込んで少しせ中を高くしてつくづく考え込みながらもう夕方の鼠いろの頁岩の波に洗われる海岸を大股に歩いていた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」貝の火兄弟商会の赤鼻の支配人は云いながらすばやく旅費の袋をさらい上着の内衣嚢に投げ込んだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておぬいさんの手紙を素直に洋服の内｜衣嚢にしまいこんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下に出ると動物学の方の野村教授が、外套の衣嚢の辺で癖のように両手を拭きながら自分の研究室から出てくるのに遇った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "園の手は自分でも気づかないうちに、外套と制服の釦をはずして、内｜衣嚢の中の星野から託された手紙に触れていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三隅の家の軒先で、園はもう一度｜衣嚢の手紙に手をやった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから今日の英語は休みたいからといって、今朝白官舎を出る時この手紙を頼まれてきたんですが……」　そういいながら園は内｜衣嚢から星野の手紙を取りだした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "純次はどことなく締りのない風をして、無性に長い足をよじれるように運ばせながら、両手を外套の衣嚢に突っこんだまま、おぼつかなく清逸の眼の前を歩いていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見るとややあわてたような気持になって、衣嚢の中から電報を取りだして、今度はその日附を調べてみた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして机の上にあった三通の手紙を洋服の内衣嚢に大事にしまいこんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは衣嚢から卷煙草を出して火を摺りながら、四方を建物で圍はれた中庭に眼をやつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見學者の中にも欠呻をしながら、患部の切片を入れたガラス瓶を衣嚢にしまつて、そろ／＼歸仕度をするものがあつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して手術衣を脱がうとするとその衣嚢の中でかちつと堅いものにぶつかり合ふ音を聞いた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは何げなく衣嚢に手を突込んで指先きに觸れたものをつかみ出して見ると、それは解剖臺から持つて來た四つのガラス瓶だつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の後に立つてゐて、お付合のやうに笑ひながら窓側の柱に懸つてゐる時計を眺め、更に大形の懐中時計を衣嚢から出して見た。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と雀部は煙草入を衣嚢に蔵ひながら笑つた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』両手を衣嚢に入れてがつしりした肩を怒らせながら、雀部は同情のある口を利いた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると衣嚢から反古紙を出して、朝日に融けかけた路傍の草の葉の霜に濡れた靴の先を拭いてゐた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』雀部は両手を上衣の衣嚢に突込んで、高い体を少し前へ屈めるやうにしながら、眼で笑つて言ふ。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜の朝、「秋」は匂ひも新らしく新聞紙折り、さはやかに衣嚢に入れて歩みゆく、寄せてくづるる波がしら、濡れてつぶやく銀砂の、靴の爪さき、足のさき、パツチパツチと虫も鳴く。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのし等まだ去なんのかいのう？",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、俺ら、初めからそんなこた皆目知らんじゃが、なんとかならんかいのう。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
