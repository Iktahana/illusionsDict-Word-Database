          "literary": [
            {
              "text": "「隠匿物資のことなんです。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "静安寺路の可なり立派なアパートに住んで、主として隠匿物資の摘発回収に当っていた。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他関係法令として物価制限令や隠匿物資供出令なども出る。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの工場に隠匿物資があるはずだとて、大がかりな家さがしが行われたのである。",
              "citation": {
                "source": "骸骨館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「農民新聞」や「コムソモーリスカヤ・プラウダ」「モスク※夕刊」などに報道される富農の隠匿物資の目録は、伸子に笑止なようなその暗い貪婪が苦しいような心持をおこさせた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "板橋の場合、発見した隠匿物資は、配給所がごまかしていたものではなかったのだから、委員会は、先ず連合軍に申し出たらよかったろう。",
              "citation": {
                "source": "人民戦線への一歩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各地で隠匿物資の摘発が行われている。",
              "citation": {
                "source": "青年の生きる道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
