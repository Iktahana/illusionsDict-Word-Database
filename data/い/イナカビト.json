[
  {
    "uuid": "5b6b4555-6203-524e-a817-949aafbc73f0",
    "entry": "田舎人",
    "reading": {
      "primary": "いなかびと",
      "alternatives": [
        "いなかじん",
        "いなかうど",
        "でんしゃじん"
      ],
