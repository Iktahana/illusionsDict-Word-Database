        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "忠臣は、主君の暴挙を「諫め」たが、聞き入れられなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "親友からの「諫め」の言葉に、彼は深く反省した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "上司の誤った判断に対し、部下は勇気を出して「諫め」を述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の言葉は、厳しい「諫め」であったが、私にとっては成長の糧となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史書には、愚かな王への賢者の「諫め」が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議では、独断的な社長への「諫め」の声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの時の先輩の「「それは違う」という諫めがなければ、今の自分はなかっただろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "蹌踉めくままに静もりを保ち、聊か儀文めいた心地をもつてわれはわが怠惰を諫める、寒月の下をゆきながら、陽気で坦々として、しかも己を売らないことをと、わが魂の願ふことであつた！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥らの　うたはきこえず　　空は今日　はなだ色らし、倦んじてし　人のこころを　　諫めする　なにものもなし。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹌踉めくままに静もりを保ち、聊かは儀文めいた心地をもつてわれはわが怠惰を諫める寒月の下を往きながら。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、おとなしい彼は母を諫めることも出来なかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば御家相続の子無くして、御内、外様の面｜諫め申しける。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁酒会員である以上は、自分の力の及ぶかぎり飲酒を諫めなければならないとも思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人が溺れている悪い習慣の結果を考えるなら、不愉快を忍んでも諫めだてをするのが当然だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と涙ながらに諫めかけると、息子は平氣なものです「また始まつたよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と怨めしさうな目をして居るではないかと諫めても見たが、馬子はどうしても聞き入れない。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日、甲午、小御所東面の小庭に於て、和田新左衛門尉常盛以下の壮士等切的を射る、是弓馬の事は、思食し棄てらる可からざるの由、相州諫め申すに依りて、興行せらるる所なり、故に勝負有る可しと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿四日、癸卯、晴、将軍家先生の御住所医王山を拝し給はんが為、渡唐せしめ給ふ可きの由、思食し立つに依りて、唐船を修造す可きの由、宋人和卿に仰す、又扈従の人六十余輩を定めらる、朝光之を奉行す、相州、奥州頻りに以て之を諫め申さると雖も、御許容に能はず、造船の沙汰に及ぶと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち曹国公李景隆に命じ、兵を調して猝に河南に至り、周王｜は燕王の同母弟なるを以て、帝もかねて之を疑い憚り、の長史王翰というもの、数々｜諫めたれど納れず、の変を告ぐるに及び、此事あり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に疏を上りて、諸藩を削るを諫めたる高巍は、言用いられず、事｜遂に発して天下動乱に至りたるを慨き、書を上りて、臣願わくは燕に使して言うところあらんと請い、許されて燕に至り、書を燕王に上りたり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門が新皇と立てられるのを諫めて、帝王の業は智慧力量の致すべきでは無い、蒼天もし与みせずんば智力また何をか為さん、と云つたとある。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門の家隷の伊和員経といふ者も、物静かに将門を諫めたといふ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将平員経のみではあるまい、群衆心理に摂収されない者は、或は口に出して諫め、或は心に秘めて非としたらうが、興世王や玄茂が事を用ゐて、除目が行はれた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "妲己や褒※のような妖怪くさい恐ろしい美人を譬えに引くのも大袈裟だが、色を貪るという語に縁の有るところがら、楚王が陳を討破って後に夏姫を納れんとした時、申公巫臣が諫めた、「色を貪るを淫と為す、淫を大罰と為す」と云ったのを思い出して、色を貪るのを愚なことだと云いもしたろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴僕の中の心のあらい者は、主人を神とも思っているから、然様でござる、それは一段と味も勝り申そうと云い、少し物わかりのした者は、それは酷いとは思ったが、諫め止めるまでにも至らなかった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗円　大恩教王の御教は日月輪の如く明かれども、波羅密多の岸は遠く、鈍根痴愚の我等風情に求道の道は中々の難渋、それ故に互に諫め励まし、過あれば戒め懲らし、よしや歩は遅からうとも、いやさ精進懈怠はあるまいと、誓ひし言葉を覚えて居やるか。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏姫が父を諫めて、賞罰は政の枢機なることを説き、一言は以て苟且にすべからざるを言ひ、身を捐てゝ父の義を立てんとするに至りては、宛然たるシバルリイの美玉なり。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ性として人とともに歎き、人とともに笑ひ、愛憎二つの目もて久しく見らるることを嫌へば、かかる望をかれに伝へ、これにいひ継がれて、あるは諫められ、あるは勧められむ煩はしさに堪へず。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳の霊公が臣下の妻と通じその女の肌着を身に着けて朝に立ち、それを見せびらかした時、泄冶という臣が諫めて、殺された。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈巫、字は子霊、一に巫臣ともいう者が之を諫めた。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）荘王は好色家であるよりも、野心的な政治家だったので、直ぐに巫臣の諫めを容れた。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に、荘王と子反とを諫めた申公巫臣が、漸く夏姫に近づいて来た。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも余りに斎田氏の稽古振りが酷烈なので、夫人が襖の蔭からハラハラしながら出て来て、「そんなにお叱りになっては……」　と諫めにかかると斎田氏の癇癪が一層高潮した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜右衛門尉一人｜諫めをも意見をも申して候。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "元就の策略を看破して諫めて、「元就が厳島に城を築いている事を後悔しているのならば、それを口にして言うわけはない。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶が此処にて討死しようとするのを三浦諫め、「一先ず山口へ引とり重ねて勢を催され候え。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時は、文学青年で詩文ばかり作っていたので、板垣信形に諫められた位である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
