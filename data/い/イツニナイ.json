          ],
          "literary": [
            {
              "text": "栄一は父が何時に無い用事があるなどと云ふから不審で堪らなかつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな女の子がほしいわねえ」と妻がいつにない事を言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいつにないまじめくさった顔つきをして頭を横に振った。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も言いようがないから黙っていますと、お俊もいつものおしゃべりに似ず黙っているのでございます、蚊帳の中から透して見ると、薄暗い洋燈の光が房々とした髪から横顔にかけてぽーッとしています、それに蒸し暑いのでダラリとした様子がいつにないなまめかしいように私は思ったのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんは肱枕をして寝てみたり、いつにない夜延をしたり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一事が万事、なるほど昇給に取り残されるのも無理はないと悲しくわかり、その旨あの人にきつく言うと、あの人は、そんなことまでいちいち気をつけて偉くならんといかんのか、といつにない怖い顔をして私をにらみつけた。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ、おれに、いつにないやさしい口調で、あなたも今月はずいぶん、お仕事をなさいましたし、気休めにどこか田舎へ遊びにいらっしゃい。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君はいつにない主人が余りの未練さをやや訝りながら、「あなたはまあどうなすったのです、今日に限って男らしくも無いじゃありませんか。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろから随いて走ってるわてが可哀想や言うて、どんぐり（飴）くれはったさかい」　いつにないはきはきした声だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばちゃん、どこイ行くねん」　と、君枝が随いて行こうとするのを、他吉はいつにない怖い声で、「阿呆！",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの因果でわいが河童路地を夜逃げせんならん」　いつにない強い口調だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のほうを見ていつにない顔を赤くしたらしいのが薄暗い中にも自分にわかった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて経験のない私にも、このいつにない三毛の挙動の意味は明らかに直感された。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつにない出来事なので、どの家の腕附の椅子に掛けてゐる爺いさんも、胸に動悸をさせながら、片々の目でその妙な物を見てゐた。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ大戸をあけたばかりの茶屋では、次郎左衛門がいつにない早帰りに驚かされた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでもおとなしくあの人の機嫌を取って、見捨てられないようにする工夫が専一だと、いつにない、弱い心持ちにもなった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きな関東平野にもいつにない御無沙汰をした。",
              "citation": {
                "source": "野の花を",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、三万両もの大金をただくれてやるんでござりまするか」　握り屋の握り屋らしい面目を遺憾なく発揮いたしまして、七郎兵衛が不服そうに申し立てたものでしたから、右門のいつにない初雷がその頭上に落下いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三はいつにない困惑の情を見せて、いくたびもふうっと大きなためいきをついたことでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかいつにない物哀れな夕方のやうな心持がする。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつにないお爽やかな御気色、主水之介何よりの歓びにござります」「なに！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　檢査員をじろつと横目で見て、駒平は、いつにない不機嫌な面持で云つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "富豪と番頭６・20（夕）　去年の夏の事、亜米利加にはいつにない暑い日が続いた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟子はいつにない師匠の不機嫌に、先刻のふざけた真似とは打つて変つて神妙に鼠のやうに小さくなつてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国で聞えた新聞紙｜紐育トリビユウンの創立者ホオレエス・グリイリイは、優れた新聞記者の多い米国でも、とりわけ優れた記者として聞えた男だが、ある日政府筋の役人に会ふと、その役人はいつにない厳つべらしい顔をして言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来は大帝のお成りを喜んで、室をきれいに飾りつけた上、色々の献上｜物など並べ立てて置いたが、それがひどく気に入つて、大帝はいつにない上機嫌の体で食卓についた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　葉子はいつにない引き締まった表情で、彼の顔色を窺った。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と新吉はいつにない冷やかな態度で、「私のところにいるのは、いつまでいても、それは一向かまわないようなもんだがね。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
