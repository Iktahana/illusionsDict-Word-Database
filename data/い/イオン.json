    "definitions": [
      {
        "index": 1,
        "gloss": "appoggiatura",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この曲の冒頭では、短三度の倚音がメロディに深い憂愁を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "楽譜には倚音が明記されているが、演奏者の解釈によってその長さは微妙に変わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バロック音楽では、倚音は装飾音として頻繁に用いられ、楽曲に華やかさを加える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の作曲は、予想外の倚音を巧みに挿入することで聴衆を驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「そのフレーズの倚音は、もっと丁寧に解決させてください」と指揮者は指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "倚音の有無一つで、同じメロディでも印象が大きく変わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古典派の作品における倚音は、時に和声的な緊張を高める役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは主音の上にかかる倚音である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねいおんちゃん、へにゃしないねい」　三児は一時金魚の死んだのに驚いたらしかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "行かねばならないおんつぁんを、親身に送るものは、不良青年の極印を押された勃凸が一人ゐるばかりなのだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上このような浅ましい姿で尊いおん眼に触れました。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが教科書から目を起こせば、地図の一枚もないおんぼろ教室の様子は、教科書に嘘が書かれていることを突きつけてくるのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『もう金魚へにやしないねいねいおんちやん、へにやしないねい。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年七月、西園寺（さいおんじ）内閣が倒れて桂内閣がそれに代わった。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるを三十になるやならずの若いおん身で若松城が石一つになるまでも戦い抜こうと言う御心意気は、思うだに颯爽として胸がすくわ。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来でもみかけたようなレイン・コートの一隊が広場をグルリと列で取り巻き、手に手におそろしく太いおんなじ形のステッキをついている。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ古いおんぼろ自動車のことだから、エンジンを直すといっても簡単にはいかない。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の強いおん坊なんざ惚れちまは。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とぶとりの　飛鳥の都に、日のみ子樣のおそば近く侍る尊いおん方。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "とぶとりの　飛鳥の都に、日のみ子様のおそば近く侍る尊いおん方。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ、そうだろ、ポケットにこんなにたくさんの金をもってる男がよ、古いおんぼろ服のまんまでいかれもしねえじゃねえか。",
              "citation": {
                "source": "うまい商売",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでおきせの罪に至るの経路もまともに聞きまこと同情に値するものであることがよくよく聴衆に肯かれるし、心から圓朝またこの弱いおんなへ温かい涙をふりそそいでやっているではないか。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "又ひところ、「イキで、こうとで、ひとがら」と云われた「いいおとこ」「いいおんな」に関する明治の合言葉があったけれども、この「こうと」は「高等」で、こんなところに高等と当時はやりの「漢語」を持ち出したところに、「年代」を見るべく、この「こうと」には同時にまた「コート」にかかったかけ言葉の意味があった。",
              "citation": {
