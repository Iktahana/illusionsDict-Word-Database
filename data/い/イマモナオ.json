    "definitions": [
      {
        "index": 1,
        "gloss": "still",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この静かな田舎町では、今もなお昔ながらの祭りが大切に受け継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "流行り廃りがある中で、彼の作品は今もなお多くの人々に愛されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃の約束が、大人になった今もなお、彼の中に生き続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖母が教えてくれた知恵は、時が経った今もなお、私の指針となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "既に年経て、古く物さびた庵の中には、今もなお故人の霊がいて、あの寂しい風流の道を楽しみ、静かな瞑想に耽っているように見えたか知れない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の家郷を慈母の懐袍に求めた蕪村は、今もなお我らの心に永く生きて、その侘しい夜半楽の旋律を聴かせてくれる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否今もなおこの凩に吹き散る雲の影のようななんらかの希望の影を追うているではあるまいか。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、春になって、街道に青く角芽ぐむ柳の糸を見るたびに、大井川上流の深谷に秘められて、黙々と、皺だらけな、深刻な顔を、水に覗かせている老楊が……ああ、今もなお、鮮やかに眼に。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震が如何にして起るやは今もなお一つの疑問なれども、ともかくも地殻内部における弾性的平衡が破るる時に起る現象なるがごとし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがしかし、今もなお私の記憶に残っているものは、あの不可思議な人外の町。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる多くの人々の、あらゆる嘲笑の前に立って、私は今もなお固く心に信じている。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助を中にして三つの墓並び、冬の夜は霙降ることもあれど、都なる年若き教師は源叔父今もなお一人｜淋しく磯辺に暮し妻子の事思いて泣きつつありとひとえに哀れがりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっくに分別のできた大人が、今もなお熱心に――厚紙でサンドウィッチのように挾んだうえから一思いに切ってみたら？",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もなお、哀れな女の顔が目のさきにちらつく。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と今もなお且つ信じないように、渋に朱を加えた赤い顔で――信ぜんのじゃ！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もなお懐中せる今朝の写真に心附けば、憔れ果ててその面影は無けれども、気ばかり肖たる処あり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、あのとき、学生の言った言葉は、今もなお、わたしの頭にこびりついています。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしには、今もなお目に見えるようですよ。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今もなお私は「月ヶ瀬」のぶぶ漬に食指を感ずるのである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "家には由三郎という弟があるので、お妻はどうでも他家へ縁付かなければならない身の上であるが、今もなお親の手もとに養われていた。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もなおこのありさまで浮ぶことが出来ないから、どうぞ亡きあとを弔ってくれと言った。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎を格殺したり岩に矢を立てたりした飛将軍李広の驍名は今もなお胡地にまで語り伝えられている。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、昭和五年に鹿児島へ行ったが、西郷隆盛以下薩軍の諸将の墓地が、壮大であるのに引きかえ、西南戦争当時の官軍の戦死者を埋葬した官軍墓地と云うのが、荒寥としていたのは、西南戦争当時の薩摩の人心の情勢が今もなおほのかに残っている気がして、興味を感じた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その怒りが今もなお佐古の心の中に残っていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、この書に現われたシナ民族には、立派にいわゆる「狐」なる超自然的なものが存在していて、おそらく今もなお存在しているにちがいない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に今もなおそれを実行しているのであるが、彼は自身で寝床を始末し、ほかの船員らにもこれを実行させている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "このものすごい絶叫は、今もなお私の耳にひびいている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もなお時どきにびくりとしたり、または頭の上の甲板に死んだ人の神経的な速い跫音を聞くように思ったりして――。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死後、皇帝は青春美の理想的型として彼の像などを多く作らしめ、その傑れた彫像は今もなおヨーロッパ各地の博物館に残っているのである。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もなおその宮殿の古跡などがある。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるからに口説の際も常に予を戒めて、ここな性悪者め、他し女子に見替えて酷くも我を棄つることあらば呪殺してくれんずと、凄まじかりし顔色は今もなお眼に在り。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかに今十九にもなって、そうとは信じもすまいけれども、口でいうような幼心は、今もなお残っている。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘たちは、袖を絞ったために今もなお、よくその説句を覚えていると、云って聞かせました。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員楽器に和して、自由の歌を合奏す、悲壮の音水を渡りて、無限の感に打たれしことの今もなおこの記憶に残れるよ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
