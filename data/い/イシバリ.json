[
  {
    "uuid": "72ea9150-80ac-5e1a-b9c1-5abe3757c96a",
    "entry": "石張り",
    "reading": {
      "primary": "いしばり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
