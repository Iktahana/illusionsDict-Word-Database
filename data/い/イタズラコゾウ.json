          ],
          "literary": [
            {
              "text": "やがて、雨があがると、いたずら小僧がふたり、そこへやってきました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずら小僧どもは、そのそばを走りながら、手をたたいてよろこびました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子は気違いになってから、いたずら小僧かとぼけ婆さんのように、ばつの悪い時、よく空寝をやるようになった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃には庭の大きい柿の実もだんだん紅らんで、近所のいたずら小僧が塀越しに竹竿を突っ込むこともあったが、阿母さんは例の「誰だい」を呶鳴る元気もなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずら小僧はそのあとをつけていって、わざと犬をけしかける者もあった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはかのいたずら小僧であることを半七もすぐ覚った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは先月、あの喜平と大工の勝次郎とが清水山へ行く相談をしている時に、誰にたのまれて仕事場の材木を倒した」　さすがのいたずら小僧も俄かに顔の色かえて、唖のように黙ってしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田はクルリとその友達の方に向き直ると、いたずら小僧のように片っ方の目をパチパチとした。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "権太郎は今年十四で、町内でも評判のいたずら小僧に相違なかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじが死ぬと間もなく、阿母はどこへか行ってしまって、兄貴と自分とは孤児同様に取り残されたのであると云った時には、いたずら小僧の声も少し沈んできこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内で札付きのいたずら小僧も、その小さい心の底にはこうした美しい、いじらしい人情がひそんでいるのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずら小僧らしい次八もおとなしく小膝をついた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百発の砲弾は、まるでいたずら小僧の群を襲う熊蜂の群のように、敵艦にとびついていったが、まことにふしぎな、そして奇怪な光景であった。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に置いておけば、自分が漁に出た不在中に、村のいたずら小僧どもからどんな目にあわされるかわかりません。",
              "citation": {
                "source": "正覚坊",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥はいたずら小僧みたいな目をして、悦んでそれを聞いていた。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は………実は……」　僕は、先生の前に出たいたずら小僧の様に、どもった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたにささげたジョンより、「まあ、まあこのいたずら小僧！",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジョウは、「あたし、あのいたずら小僧をひっぱって来て白状させ、うんとしかってやります。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子のリップは、いたずら小僧で父親に生きうつしで、やがては父親の古着といっしょに、その性癖まで受けつぐことはあきらかだった。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、このいたずら小僧は、なぐられて部屋から追い出されてしまいました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、このいたずら小僧は、私が林檎の木蔭を歩いている隙をねらって、頭の上の木を揺さぶりだしました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つの節は「黒坊のいたずら小僧」と云うのでした。",
              "citation": {
                "source": "二つの短い話",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお母さんの家へ来る道の小さな橋の処まで来かかると、彼は笛をしめして「黒坊のいたずら小僧」を吹き始めました。",
              "citation": {
                "source": "二つの短い話",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時十二歳の二人のいたずら小僧の顔には、驚愕とも当惑とも慙愧ともつかぬ異常な表情が現われていたに相違ない。",
              "citation": {
                "source": "記憶ちがい",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずら小僧のニールスは、おとうさんやおかあさんの留守のまに、小人をからかったため、小人の姿に変えられてしまいました。",
              "citation": {
                "source": "「ニールスのふしぎな旅　下」まえがき",
                "author": "矢崎源九郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからも、森バトや、ムクドリや、野ガモにであいましたが、みんな口ぐちに、チビスケのいたずら小僧に歌のじゃまをされたといっては、くやしがっていました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来は悪くなかったが、いたずら小僧だったよ」「丸尾先生は如何でしたか？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が僕の腕をアルコールで拭いているところへ、「先生今日も又いたずら小僧共が裏の梅を盗みに来ています」　と薬局生が注進に及んだ。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くのいたずら小僧どもが、きたないこじきむすめがたおれているのを見て、あつまってきたのです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
