        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その肖像画は、まるで本人がそこにいるかのような生き写しだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "息子の顔立ちは、父親の若い頃の生き写しだと、祖母はよく言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事件現場の再現映像は、当時の状況を生き写しのように克明に映し出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "生まれたばかりの子猫は、母親の生き写しで、思わず笑みがこぼれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この絵、僕の書いたものとそっくりだよ！ まさに生き写しだ！」と友人は興奮気味に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新のAIアバターは、人間の表情を生き写しのように再現する能力を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "源兵衛が、　「この娘を生んで直ぐだった」　半五郎、お静を見て、　「そう云やァ姐さんに生き写しだ」　お静、テレてる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "出世を競り合うて呪咀い合うものと聞いた、蔵元屋の前の御寮さんが、コッソリ里子に遣ったままにして置いた芋屋の娘……正しく蔵元屋の血統を引いた、お熊さん同様の一点の疵もない卵の剥き身、生さぬ仲の芋屋の老人夫婦を真実の親と思い込んでの孝行振りまで、お熊さんと瓜二つの生き写し。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後｜仙台へ行ってＫ君を訪問すると、そこにいた子猫がこれと全く生き写しなのでまた驚かされた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリストファーネスの「雲」を読んで学者たちが蚤の一躍は蚤の何歩に当たるかを論ずるところなどが、今の学者とちっとも変わらない生き写しであることをおもしろいと思うのであった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の絵画や彫刻やは、部分的なるデテールの描写を丹念にし、実物の風景や人物やが、真にそこにある如き生き写しを主眼としている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹に生き写しというべき若い娘の姿が、きょうも彼の眼先にあらわれたからである。",
              "citation": {
                "source": "離魂病",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは妹を連れているので、西岡はあくまでもそれを追って行こうとはしなかったが、二度も三度も妹に生き写しの娘のすがたを見たということがどうも不思議でならなかった。",
              "citation": {
                "source": "離魂病",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "最前チョットお話ししました棺の中でお経を聞いてビックリした豪傑で、お寺の天井に居る羅漢様と生き写しの面相で、商売の古道具屋に座って、煙草を吸うております中に蜘蛛が間違えて巣を掛けよるのを知らずにおったという大胆者で御座います。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは若宮のお顔が驚くほど源氏に生き写しであって、別のものとは決して見えなかったからである。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうやら、ご人相が伊豆守様おことばに生き写しでござりまするが、もしやご貴殿は江戸からおこしの近藤右門どのではござらぬか」「いかにも、さようにござる」「やっばり、ご貴殿でござったか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "キッティのアラビア馬がその人力車を突きぬけて行ってしまったので、誰かウェッシントン夫人に生き写しの婦人が、その人力車と、黒と白の法被を着た苦力を雇ったのであってくれればいいがと思った最初の希望は外れた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、あのようにソッと私を御覧になりました愛情にみちみちたお眼づかいまでが、ソックリそのまま、私のお母様に生き写しでおいでになりましょうとは夢にも想像致しておりませんでしたので、失礼な言葉か存じませぬけれども、あの時貴方様は、私のお母様の生れかわりとしか思われなかったので御座います。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして顔が出来上りますと、それに鬚や髪の毛を植えて、関羽と張飛は眉まで植えまして、お母様のお得意の浮き出し人形が出来上りますとその厳めしさと立派さは眼もさめるようで、ことにその中でも張飛の眼は、お父様に生き写しのように思われました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども最前あの櫛田神社の額を見ながら、人の噂をきいているうちに、あの犬塚信乃の押絵の顔が、中村半太夫の舞台に生き写しであることがわかった。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳さんは二十四、五で、顔付きもからだの格好も阿母さんに生き写しであったが、男としては少し小柄の方であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初めてお目通り仕まつりまする」　千枝太郎は、草に手をつきながらそっと見あげると、正面に坐っている若い女――無論それが三浦の孫娘の衣笠であろう――年こそ少し若いが、その顔かたちはかの玉藻に生き写しであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳さんは廿四五で顔付きもからだの格好も阿母さんに生き写しであったが、男としては少し小柄の方であった。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王は、その小屋で、主に生き写しの二人の男の子と三人の女の子を見た。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまた至って優しい、――あなたの知っておらるる浩一に生き写しじゃ、よく似ている」「似ていますか？",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親はいても、互に生き写しな気弱さや生活上の無気力で、どちらも頼りにはならなかった。",
              "citation": {
                "source": "光のない朝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時何気なく十字架に彫られた、受難の基督の顔を見ると、不思議にもそれが卓の向うの、外国人の顔と生き写しであつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "癇癪の起し具合はお父さんに生き写しだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が呉一郎と全然無関係な、赤の他人だと思っている間は、その痛みを感じないが、一度、呉一郎の姿と、自分の姿が生き写しだという事がわかると、その痛みを突然に思い出す。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……この顔は……さっきの……呉モヨ子と……」「生き写しだろう……」　と正木博士はすぐに引き取って云った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "姪の浜の一農家の娘、呉モヨ子の眼鼻立ちが、今から一千百余年｜前、唐の玄宗皇帝の御代に大評判であった花清宮裡の双※姉妹に生き写しなんていう事は、造化の神でも忘れているだろうじゃないか」「……………」「歴史は繰り返すというが、人間の肉体や精神もこうして繰り返しつつ進歩して行くものなんだよ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伜の嬢次がコンドルに誘拐されましたのは四歳の時だったそうでありますが、その容貌はもとより皮膚の色から、髪毛の生え際に至るまで妻と生き写しでありまして、少し大きくなりましてからは声までも妻の声と間違いましたそうで、ただ耳だけが小生のと同じ恰好をしていた事を記憶しております。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、その可遊と云う男が、これがまた、井筒屋生き写しと云う男振りでさ。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟　　　　　　　シャルル・ボドレエル黒葉水松の木下闇に並んでとまる梟は昔の神をいきうつし、赤眼むきだし思案顔。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟　　　　　　　シャルル・ボドレエル　黒葉水松の木下闇に　並んでとまる梟は　昔の神をいきうつし、　赤眼むきだし思案顔。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟黒葉水松の木下闇に並んでとまる梟は昔の神をいきうつし、赤眼むきだし思案顏。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
