          "literary": [
            {
              "text": "盆栽生け花のごときも、また日本人にとっては庭園の延長でありまたある意味で圧縮でもある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生け花展覧会の批評などもややこれに類している。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず手近なところでたとえば生け花の芸術を考えてみる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生け花に限らず、造園でも同様である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの朝早く、お堂はすでに生け花と奉納された提灯で飾り付けられていた。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の湯生け花のけいこまでした令嬢にゃ似合わンぞ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人は妙齢の淑女なればにや、夏ながらさまざまの生け花の寄贈多かりき。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その生け花には「川島家」の札ありき。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、現在生け花の先生をしているひとびとのあり様を見ると、これがまことにもって料理人に対していったことが、そっくりそのままに当てはめられる。",
              "citation": {
                "source": "伝不習乎",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "生け花の先生には自然の趣などということは、なんの縁も関わりもないものであるらしい。",
              "citation": {
                "source": "伝不習乎",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「なべ料理」の材料の盛り方ひとつにしても、生け花と寸分違わないと思っている。",
              "citation": {
                "source": "鍋料理の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "生け花というのは、自然の草や木を、自然にあるままに活かそうというので、そのためにいろいろ工夫をする。",
              "citation": {
                "source": "鍋料理の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "近隣の子供三、四人、および菓子屋の職人某、向かい側なる印版屋の主人、同町の生け花師匠某ら、いずれも夜を異にして見たりといい、それより大騒ぎとなりて、米吉の屋前には毎夜人の山を築き、雨戸を攀ずるもの、戸をたたくもの、石を投げ込む者さえあり。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、言ふでせう、茶の湯生け花歌ヘエケエの親類見てえな」「詩歌管絃か琴棋書畫だらう――、そんな六つかしいことも出來るのか」「唐天竺の都々逸も心得て居るし、笛も吹けば琴も彈くんですつて」「それで、質も置けば、飯も炊くと來れば大したものだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "華魁崩れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに茶の道具とか、生け花とか、いろいろな時間があつて、この老人は一日たつぷりした暮しだなと思つた。",
              "citation": {
                "source": "故郷を辞す",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣友今昔ものがたり釣友がきて誘い出す雨あがり　囲碁、将棋、盆画、盆石、歌、俳諧、書画、骨董、生け花、茶道にいたるまで、友だちもいろいろあるが、よき友は得がたいものである。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて行きついた家はちんまりと門もなしに生垣をめぐらして、話にきいたとおり役をやめて娘三人と書、画、茶、生け花とめいめいくろうと乃至素人ばなれのした技と楽しみをもち、つつましやかに安楽に団欒しつつ余生を送ってる老士官の住居にふさわしいものだった。",
              "citation": {
                "source": "結婚",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "座っているのは太陽降り注ぐ盆地、コブラのとぐろが生け花の縄と化し、感覚のない手にまきついている。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろに下がり、陽気にフンフンと口ずさみ、生け花を観賞している。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまだ母が勤め奉公時代に父と母との間に交された艶書、大和の国の実母らしい人から母へ宛てた手紙、琴、三味線、生け花、茶の湯等の奥許しの免状などであった。",
              "citation": {
                "source": "吉野葛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、八人いる職人たちの躾もきびしく、みな子飼いから育てられ、読み書きはもちろん、生け花、茶の湯までひととおり習わされ、書画のよしあしなども、小さいころから実物について教えられた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは茎の根元から切り取った生け花らしいもので、夏の炎天にさらされて、すっかりしおれている。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "傘付きランプがちゃんとあり、柔らかい光が古い家具や絵画を照らし、生け花が高価なツボに見事に飾られている。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "大奥様、僕も離れへ行って、生け花のお手伝いをさせてください。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘茶か、立花（生け花）か。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が道楽に創めた立花（生け花）、闘茶（茶道）なども、やがて観世清次どのの舞能のごとく、案外、ゆくすえ世の文化に大きな開花を見せるやも知れません。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほうれん草は、台所用いけばなにあらず。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
