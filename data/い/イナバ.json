      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Inaba (former province located in the east of present-day Tottori Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔話「因幡の白兎」は、この因幡の国で起こったとされる物語だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "因幡地方の祭りは、古くからの伝統が今も息づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は因幡地方出身で、その土地の訛りが時折顔を出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その八十神たちは、因幡の国に、八上媛という美しい女の人がいると聞き、みんなてんでんに、自分のお嫁にもらおうと思って、一同でつれだって、はるばる因幡へ出かけて行きました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、因幡の気多という海岸まで来ますと、そこに毛のないあか裸のうさぎが、地べたにころがって、苦しそうにからだじゅうで息をしておりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鷹はかしこまって、その鳥のあとをどこまでも追っかけて、紀伊国、播磨国へとくだって行き、そこから因幡、丹波、但馬をかけまわった後、こんどは東の方へまわって、近江から美濃、尾張をかけぬけて信濃にはいり、とうとう越後のあたりまでつけて行きました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日のこと……思い出したように道具を荷いで因幡町の恩師、浅川一柳斎の道場へ出かけた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十余年前まで但馬因幡地方で馬極めて稀なり、五歳ばかりの児に馬を知るやと問うと、顔を長く四疋と尾あり人を乗せると答う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本でも上杉家の勇将｜新発田因幡守治長は、染月毛てふ名馬の、尾至って白きを、茜の汁で年来染むると、真紅の糸を乱し掛けたごとし。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃は小春の眞晝すぎ、因幡ざかひを立ちいでて、晴れ渡りたる大空を南の吉備へはしる雲、白き額をうつぶしに、下なる邦のあらそひのなじかはさのみ忙しきと、心うれひに堪へずして、顧みがちに急ぐらむ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、京橋の築地、かの本願寺のそばに浅井｜因幡守という旗本屋敷がありました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年は正月早々からとかくに雨の多い春でしたが、二十二三日からからりと晴れて、暖い梅見日和がつづいたので、浅井の屋敷では主人の因幡守が妾のお早と娘のお春を連れて、砂村の下屋敷へ梅見に出かけることになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "因幡守は四十一歳、お早は二十四歳、お春は十五……ちょっとお断わり申して置きますが、このお春というお嬢さまはお早の妾腹ではなく、お蘭という奥さまの子で、奥さまはそれほどの容貌よしでもなかったが、その腹に生まれたお春は京人形のように可愛らしい、おとなしやかなお嬢さまであったそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで主人側は因幡守、お早、お春の三人、それにお付きの女中が三人、供の侍が三人、中間が四人でしたが、船が狭いので侍や中間は陸を廻り、主人側三人と女中三人は船で行きました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰も助からなかったんですか」「船頭は泳ぎを知っているから、いざというときに川へ飛び込んで助かりましたが、因幡守という人は水心がなかったと見えて沈みました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも因幡守とお早と女中二人、あわせて四人の死骸を探り当てましたが、娘のお春と女中のお信、この二人のゆくえは知れませんでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "関係者一同に固く口止めをして、その船に乗っていたのは妾と娘と女中ばかりで、主人の因幡守は駕籠で帰った為に無事であったと云い触らしました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから四、五日後に因幡守は急病頓死の届けを出して、当年十七歳の嫡子小太郎がとどこおりなく家督を相続しました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい主人の因幡守が乗っていないとしても、三千石の旗本の娘と妾と三人の女中を沈めた一件ですから、災難だとばかりは云っていられません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいか、牛込水道｜町の堀田庄五郎、二千三百石、これは浅井因幡守の叔父だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから京橋南飯田｜町の須藤民之助、八百石、これは因幡の弟で、須藤の屋敷へ養子に貰われて行ったのだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "深川浄心寺脇の菅野大八郎、二千八百石、これは因幡の奥方お蘭の里方で、ここからも内密に頼んで来ている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主の因幡は若い時から評判の美男で、お蘭はどこかで因幡を見染めて、いろいろに手をまわして縁談を纒めたのだと云うから、惚れた亭主だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　浅井因幡守の屋敷は本願寺のわきで、南小田原町から眼と鼻の間にあるので、半七はすぐにその屋敷へゆき着いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなことだ」「あの一件の当日、主人の因幡という人は陸を帰る筈だったそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことになるせいか、因幡という人は船が嫌いで、いつも砂村へ行く時には、片道は船、片道は陸と決まっているので、当日も船で行って、陸を帰るという筈だったのを、どういう都合か、帰りも船ということになって、あんな災難に出逢った……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは因幡國のうちだと思ふだけでも、何となく旅の氣分を改めさせた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと古い傳説を、傳説といふよりも古い神話の殘つた地方を、松林と砂山の多い因幡の海岸に見つけることも出來た。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "因幡の國境を離れて伯耆に入つたころは、また夕立がやつて來た。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて涙も一緒に水道の水でごしごしこすった顔を因幡の兎のように赤むけに光らして、しんから切なさそうにそのひとが席へ帰って来たとき、三十二人の全級はどういう感じにうたれたろう。",
              "citation": {
                "source": "歳月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "因幡の兎のようにされたわたしの同級の可哀そうな插話にしろ、もしあの時代の令嬢たちが、卒業すればあとにはお嫁に行くことしか目標がないような教育をうけず、家庭の空気がそういう風でなかったら、どうしてはっきりわかるほどの薄化粧などして学校へ来たりするだろう。",
              "citation": {
                "source": "歳月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ乞食僧を知らざる者の、かかる時不意にこの鼻に出会いなば少なくとも絶叫すべし、美人はすでに渠を知れり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが神話　いんしゅう、いなばの小兎。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
