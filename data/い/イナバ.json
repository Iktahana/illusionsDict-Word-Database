  {
    "uuid": "1f98e26c-aa0c-59f2-8986-d1ddc7e6a839",
    "entry": "因幡",
    "reading": {
      "primary": "いなば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
