          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父は昔気質の職人だが、驚くほど今い感覚を取り入れた斬新な作品を作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "そのような古いやり方よりも、もっと今いアプローチを取り入れた方が若者には受け入れられるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女のファッションはいつもどこか今い雰囲気を纏っていて、すれ違う人々の目を惹きつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その今いふ予想といふものが、作品に形式を与へるものでもあらうし、とまれ作品に「存在の姿」を与へるものである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その今いふ記録慾――言換れば「回想の時間」。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今いちばん適当なＨの量を仮にＫだとすると、上式をＫに等しいと置いたときにその式を満足するような時間ｔに相当する時季がその人のいちばん気持のいいときになる勘定である。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思い浮かべるたびに、私は今いる都会のどこへ行っても電燈の光の流れている夜を薄っ汚なく思わないではいられないのである。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると、どうしたことかさ、今いうその檜じゃが、そこらに何もない路を横断って見果のつかぬ田圃の中空へ虹のように突出ている、見事な。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは僕らが今いたところから三、四丁離れた山の尾の一段高くなって頂が少し平らなところであった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「取つた」と云ふことを云ひたくない為に、三度云ひ淀んだ被告の態度は、ある者をして吹き出させやうとしたが、自分が今いかめしい法廷の中に居るのであると気がついたとき僅に笑を噛み殺した。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰助は、幕の蔭よりこれを見て、躍り出んと思えども、敵は多し身は単つ、湍るは血気の不得策、今いうごとき情実なれば、よしや殴打をなすとても、死に致す憂はあらじ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――しかし、小郷虎吉は今いないよ」　今日はたれもいないと、さっき宮子がある意味を持たせて言ったのを、鶴雄は覚えていたのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくら三人は湯崎の方へ話しながら歩いて行ったが、ぼくが、今いる宿の待遇が悪いので宿を変えようと思っているというと彼は是非自分等のいる宿に来い、隣の部屋が空いているからとすすめたので、ぼくは、幾分不可解な気持もしないではなかった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　均平は今いる世界の周囲にも、事変当初から、あの空地で歓送されて行った青年の幾人かを知っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上むりして努めてみたって、たいしたことにもなるまい、こうして段々老いてゆくのだ、と気がついたときは、人は、せめて今いちどの冒険に、あこがれるようにならぬものであろうか。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永楽の時、史に曲筆多し、今いずくにか其実を知るを得ん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さし肩というのは、菩薩肩というのとは反対で、菩薩肩は菩薩像のような優しい肩つき、今でいう撫肩であり、さし肩というのは今いう怒り肩で漢語の所謂鳶肩である。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今いつた活東が辨慶橋でやつたやうに。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ありがたいことには、神様、今いちどだけ、私をおゆるし下さいました。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯見ると、何うしたことかさ、今いふ其檜ぢやが、其処らに何もない路を横截つて見果のつかぬ田圃の中空へ虹のやうに突出て居る、見事な。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今いふお稽古もそれである。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の今いる所は、南緯十三度、西経百七十一度。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "押入の中にはいっていないか」「さア」と、それでも押入の戸は明けて、「――今いるんですの？",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち今いった四人と、それから五人目の男はカートライトと云ったんだ。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "今いる部屋の戸が開け放たれると、喪服に黒い面紗という装いの女性が室内に入ってきた。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば今いるこの家に厄介事を持ち込むことになると考えて、あえて出て行くしかないと友人が思っているのは、私にもよくわかった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎の木は今いっぱいの花ざかり、香わしい接骨木はビロードの様な芝生の周りを流れる小川の上にその長い緑の枝を垂れています。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "行末は人の前に出でゝ、神のみことばをも傳ふべきに、今いかでかさる戲せらるべき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は今いかなる事を答へしか知らず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ兄は手に水桃をささげもち、いつさんにきみがかたへにしたひよる、この東京の日くれどき、兄の戀魚は青らみてゆきて、日毎にいたみしたたり、いまいきもたえだえ、あい子よ、ふたり哀しき日のしたに、ひとしれず草木の種を研ぐとても、さびしきはげに我等の素脚ならずや。",
              "citation": {
                "source": "幼き妹に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンチテエゼの成立が、その成立の見透しが、甚だややこしく、あいまいになって来て、自己のかねて隠し持ったる唯物論的弁証法の切れ味も、なんだか心細くなり、狼狽して右往左往している一群の知識人のためにも、この全体主義哲学は、その世界観、その認識論を、ためらわず活溌に展開させなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にもうこのごろは、お互い腹のさぐり合いで、十年来の友人でも、あいまいな事をちょっとだけ書いて寄こして、あなたみたいに、長い手紙を書いてはくれません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、何々学院の何々女史とでもいつたやうな者が「子供の純真性は尊い」などと甚だあいまい模糊たる事を憂ひ顔で言つて歎息して、それを女史のお弟子の婦人がそのまま信奉して自分の亭主に訴へる。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
