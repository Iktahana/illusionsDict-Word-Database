[
  {
    "uuid": "7168ccdd-f4f3-5da7-beb3-e8b085fac730",
    "entry": "今にも",
    "reading": {
      "primary": "いまにも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
