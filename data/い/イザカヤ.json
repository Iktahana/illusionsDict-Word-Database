        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仕事帰りに同僚と駅前の居酒屋に立ち寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は友人と久しぶりに居酒屋で旧交を温めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この辺りには、地元の食材を活かした美味しい居酒屋が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今日の飲み会は、新しい居酒屋を試してみようか。」と提案があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観光客にも人気の、伝統的な雰囲気の居酒屋が賑わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は居酒屋で隣り合わせた客と意気投合し、深夜まで語り明かした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの赤提灯が灯る居酒屋は、どこか懐かしい気持ちにさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "新宿の或る居酒屋で、商人たちの話を聞いて悲しくなつた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風や酒肆に詩うたふ漁者樵者　街道筋の居酒屋などに見る、場末風景の侘しげな秋思である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えてろ」Ｓ＝亀崎の宿の旅籠「大野屋」（夜）　土間が居酒屋になって居る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝居酒屋（夜）　土間で三次が床几に腰掛けてチビリチビリやって居る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガンダラ彫刻した夜の女の手が闇から出て私をシセロの居酒屋に引張ると足とも手ともつかぬ黒い肉体を蛇のように私の首に巻きつけて、蛇酒を調合したソーマ酒の杯をかちあわして一気にあおってしまった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　居酒屋　ゾラの「居酒屋」を映画化したものだそうである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　フランス映画「居酒屋」でも淪落の女が親切な男に救われて一│皿の粥をすすって眠った後にはじめて長い間かれていた涙を流す場面がある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイ」とお光は下て来て自分を見て、「オヤ兄様」と言ったが笑いもせず、唯だ意外という顔付き、その風は赤いものずくめ、どう見ても居酒屋の酌婦としか受取れない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船の外でも西洋小間物屋の店先や、居酒屋の繩のれんの奥から聞こえて来るのが通りすがりに聞かない事はなかった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「仕方ありませんからそこを出て村の居酒屋へいきなり乗り込んであった位の酒を瓶詰のもはかり売のも全部片っぱしから検査しました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄暖簾も居酒屋めく米屋の店に、コトンと音をさせて鶏が一羽｜歩行いていたが、通りかかった松崎を見ると、高らかに一声鳴いた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州訛だが、いや、そのために一層妙になまめいて、忘れもせぬ、それは十日前故郷を出る時お互い別れを告げるのに随分手間の掛った居酒屋の花子だ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、或る日のこと、彼女は一人の若者を見初めたので、その魔法を用いたのだが、下婢に欺かれて、若者の髪の毛のつもりで、実は居酒屋の店先にあった羊皮の革袋から※り取った毛を燃してしまった。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は大社の大鳥居のまえの居酒屋で酒を呑みながら、外の雨脚と小走りに走って通る様様の女の姿を眺めていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は居酒屋ののれんをぱっとはじいて外へ出て、傘をお持ちなさい、と言葉をかけた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言い置いて次郎兵衛は居酒屋へ引返して亭主を大声で叱りつけながら番傘を一ぽん借りたのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よう、よう、よう、ようと居酒屋のなかから嘲弄の声が聞えた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居酒屋の卓を殴った。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草盆がばらばらにこわれ土塀や板塀に無数の大小の穴があき、居酒屋の卓に罅ができ、家の炉縁がハイカラなくらいでこぼこになったころ、次郎兵衛はやっとおのれのこぶしの固さに自信を得た。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎は朝っぱらから居酒屋へ出かけたのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにも江戸は半丁あるくと他郷だと言われるほどの籠みあったところなのに、こうしてせまい居酒屋に同日同時刻に落ち合せたというのは不思議なくらいです。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、村から戦争にいったわかもののひとりで、居酒屋のむすこでした。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この居酒屋のむすこから、「戦争にいった村のわかものは、みんな戦死してしまった。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は、気まずい思いで顔を見合せ、とにかく利左の後を追って行くと、利左はひどく汚い居酒屋へのこのこはいって行って、財布をさかさに振り、「おやじ、これだけある。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言い、蹌踉と居酒屋を出た。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正門のすぐ向いに茅屋根の、居酒屋ふうの店があり、それが約束のミルクホールであった。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと自分が日本橋の裏通りの居酒屋へは入つた事があつたが、その時、親子づれの浪花節語が門口で国定忠次を語つて行つたあとで、居酒屋の内でもてんでんに調子づいて、いろいろの歌を歌ひ出したのに遭遇した。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
