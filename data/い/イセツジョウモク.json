        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "異節上目は、アリクイ、ナマケモノ、アルマジロを含む哺乳類の一群で、中南米を主な生息域としている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "脊椎に特殊な関節構造を持つことからその名がついた異節上目は、代謝率が低いことでも知られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「異節上目の動物たちは、どれも独特の進化を遂げていて興味深いね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "分子系統学の進展により、異節上目は北方真獣類やアフリカ獣類と並ぶ主要な系統と見なされるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "絶滅した巨大な地上性ナマケモノやグリプトドンも、かつて繁栄した異節上目の仲間である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "異節上目に属する動物の多くは、鋭い爪を持ち、アリやシロアリを食べるか、樹上で生活するなどの特異な生態を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へぇ、アルマジロって異節上目っていうグループに入るんだ。アリクイの親戚みたいなものなのかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
