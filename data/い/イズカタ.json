[
  {
    "uuid": "5371cd0d-b92f-5cc7-b89e-563e2a3629d6",
    "entry": "何方",
    "reading": {
      "primary": "いずかた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
