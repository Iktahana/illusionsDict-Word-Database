          "literary": [
            {
              "text": "いよいよ薄っぺらになるばかりであって、今日の青年の書いたもの、言うことを聞いても一向｜駄目じゃ、イガイガでヒョッと人のことを聞き噛ったことが多い。",
              "citation": {
                "source": "今世風の教育",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "貉はガイガイガイと鳴き、狐はコンコンコンと鳴く、ケインケインケインと鳴くもありました。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
