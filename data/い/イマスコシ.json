    "definitions": [
      {
        "index": 1,
        "gloss": "a little more",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "完成まで、今少し時間が必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "塩を今少し加えると、味が引き締まりますよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "目標達成まで今少しのところまで来ている。気を抜かずに頑張ろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「今少し、昔の話を聞かせてもらえませんか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし何を言っていたかは今少しも覚えていない。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "椰子の木や琉球の芭蕉などが、今少し延びたら、この屋根をどうするつもりだろうといつも思うのであるが、きょうもそう思う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の仕事が一段落ついて、今少しすれば食欲｜三昧の時が来る。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今少しく規模を大きくして一村、一市街の幅員と同程度なる等温線の凹凸やその時間的変化となれば、既に世人の利害に直接間接の交渉を生ずるに至る事あり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今少しく精細に云って見るならば、役人の家庭、職人の家庭、芸人の家庭、学者の家庭、新聞記者、政治家、農家、商家、其の外に貧富の差がある、智識の差がある、夫婦諸稼の家庭もある、旦那様奥様の家庭もある、女の多い家、男の多い家、斯く数えて来たらば際限がない。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君も語れ予先ず語らんなど云える前言に対しても何分此の儘止められぬ、ままよ書過しは書過しとして兎に角今少し後を続けて見ようと決心した。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味に於て、予の最も強く主張する叫びの意味の多い歌であるが、予の好みはその叫びの声が今少し潤いを帯びてありたいのである。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今少し前に巡査がきまして牛舎を見廻りました。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせおそくなったんですから、この景色のよい所で少し休んで行きましょう」「こんなにおそくなるなら、今少し急げばよかったに。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の心持が今少しませて居ったならば、この二日の間にも将来の事など随分話し合うことが出来たのであろうけれど、しぶとい心持などは毛ほどもなかった二人には、その場合になかなかそんな事は出来なかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて伍長の肩書も持たば、鍛工場の取締りとも言はれなば、家は今少し広く、小女の走り使ひを置きて、そのかよわき身に水は汲まさじ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはいずれにしても、今の苛立たしい世の中を今少し落着けて、人の心を今少し純な集中に導くためには、このような音楽も存外有効ではないだろうか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或夜大友は二三の友と会食して酒のやや廻った時、斯ういう事を言ったことがある「僕の知っている女でお正さんというのがあるが、容貌は十人並で、ただ愛嬌のある女というに過ないけれど、如何にも柔和な、どちらかと言えば今少しはハキハキしてもと思わるる程の性分で何処までも正直な、同情の深そうな娘である。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄気味の悪い「ひげ」が黄鼠のような目を輝らせて杉の杜の陰からにらんだところを今少し詳しく言えば、　豊吉は善人である、また才もある、しかし根がない、いや根も随分あるが、どこかに影の薄いような気味があって、そのすることが物の急所にあたらない。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、私はまだ大佐の外出前だらうと思つて、寢床を離れたのは六時頃であつたが、矢張大佐等は、今少し前に家を出たといふ後、またの形をなして居る處、其處に大佐の後姿がチラリと見えた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし折角ここまで来たものでござりますれば、今少し辛抱してお捜しなされて……」「そりゃ勿論死ぬまでも捜す決心だ。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時は口も利かれぬ程の重態であった坑夫｜体の負傷者も、医師の手当に因て昨今少しく快方に向ったので、警官は直ちに取調を始めた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ともいへない樂しい世界へ、今少しのことで手が屆きさうに思はれるときの快よい焦燥と、そのぞくぞくするやうな心臟のよろこび、そのほつとする心もち、甘つたるい悲しさ、しぜんと涙ぐむやうになる情緒の昂進。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かといふに、彼等が今少しの間この恐ろしい事實、即ち彼等の船が「うづまき」の中に卷き込まれて居たことに氣が付かずに居たならば、彼等はその幸福を夢みて居る状態に於て、やすらかに眠ることができたかも知れなかつたのである。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇がむしろ真にレアリズムに徹底して、痛烈なる芸術至上主義に立つならば、すくなくとも日本の詩人は、今少しよき境遇に有り得るだろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし日本に自然主義が渡来せず、過去の浪漫主義がそのまま延びて行ったら、すくなくとも、最近では、今少し世界的に進出していたであろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "護謨を延ばして、今少し引っ張ると切れると云う所迄構わず持って行く。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "文士ならば同業の人に対して、たとい無名氏にせよ、今少しの同情と尊敬があって然るべきだと思う。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが此の火の玉より今少しく大きい火の玉が西の方より滾転殺到して来た。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば定基の妻にしても妬忌の念が今少し寡かったら如何に定基が力寿に迷溺したにせよ、強いて之を去るまでには至らなかったろうと想われる。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "病の苦しみか労働の苦しみか、どちらかを今少し減じ給え。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "今少し經てば、己の中の人間の心は、獸としての習慣の中にすつかり埋れて消えて了ふだらう。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今少し経てば、己の中の人間の心は、獣としての習慣の中にすっかり埋れて消えて了うだろう。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、いますこしそっとして置いたほうがよい。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、私が、いますこし、お金持であったら！",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
