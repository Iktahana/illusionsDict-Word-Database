    "definitions": [
      {
        "index": 1,
        "gloss": "exaggeration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「世界一おいしいなんて、それはいくらなんでも言い過ぎだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "部下のミスを厳格に注意するのは当然だが、人格まで否定するような発言は明らかに言い過ぎだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の類いまれなる演奏技術を「神業」と称しても、決して言い過ぎではないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「さっきの言葉は少し言い過ぎだったかな。傷つけるつもりはなかったんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一過性のブームを「文化の変革」とまで煽るのは、いささか言い過ぎの感がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いくら腹が立ったからといって、あんな言い過ぎには黙っていられません」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "天才という言葉すら言い過ぎに聞こえるほど、彼の生み出す作品は独創性に満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "右門と伝六そッと覗いて見ると、　敬四郎、お兼の前にペコペコ頭を下げて、　「ワシが言い過ぎた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "インチキ新聞の記者になったり、暴力団の走り使いになったり、とにかく、ダメな男に出来る仕事の全部をやったと言っても決して言い過ぎではないかと存じます。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作業仮説に従えば「唐崎の松は花よりおぼろにて」も、松と花との対立融合によって立派に完結しているので、この上に「かな」留めにしては言いおおせ言い過ぎになってなんの余情もなくなり高圧的命令的独断的な命題になるのであろう。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋ではないかも知れないが、しかし、これが恋だと言って、果して言い過ぎだろうか。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪傑肌とでも言うんだろうが、「坊や」は言い過ぎであると思う。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "追伸、この手紙に、僕は、言い足りない、或は言い過ぎた、ことの自己嫌悪を感じ、『ダス・ゲマイネ』のうちの言葉、『しどろもどろの看板』を感じる。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝手なことばっかり喋って……」　君枝の涙を見て、蝶子はさすがにいい気なことを言い過ぎたことに気がついた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言い過ぎたと思ったが、陽子はもう家を出る肚をきめていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その満足は、非常に愉快なものだ――といっては、言い過ぎになる。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、さすがにおれは、おれのおかげで……と言っても、そんなに言い過ぎではあるまい――お千鶴をわがものにして、船場新聞の社長で収まり込んでいるお前を見ると、こいつ、良い気になりやがって、いっぺん失脚させてやったら、どんな顔をするだろうか、とひそかに思わぬこともなかったのだ……。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、全く幸福だと言っては言い過ぎだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "物足りないというのは言い過ぎであろうが、ほんとうに孤独な人間がある場合には同棲のねずみに不思議な親しみを感ずるような事も不可能ではないように思われたりした。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、私の前途は洋々であると一般に思われていたと言っても、言い過ぎではないでしょう。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが（筑紫哲也じゃないが）それにしても、これを読んだオレは「終焉」は言い過ぎじゃないかと思った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が、戦争の勝敗の鍵を握っている、というのは言い過ぎであろうか。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宋学は子思や孟子から展開しているのであるから、朱子が『中庸』に在るところのものを知らない訳などは無い、その点全氏は少し言い過ぎている。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のは言い過ぎで、どうぞ悪しからず思ってください」　案外にもろく折れられて、栄之丞もほっとした。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体が何事にも執念く、些細な日常瑣事にすら余りクドクド言い過ぎる難があるが、不思議に失明については思切が宜かった。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物の行為的直観的とか、概念的とかいうのは、言い過ぎといわれるでもあろう。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろそこにはゴタゴタしたことがあって――俺の方で少し言い過ぎたようなこともあったが――何だか、昨夜なぞは節ちゃんの様子が変だ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親の乳房を求めて泣く子供が方々に見られるのであるが、既に母親は死しているのに、その屍に取り付いて泣く赤んぼのいたいけな姿は、この世での地獄と云っても決して言い過ぎでない様な気がするのである。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "西宮さんはちッともお臥らないで、こなたの……」と、言い過ぎようとして気がついたらしく、お梅は言葉を切ッた。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "西部戦場での決戦さえまだ手を附けない独逸が、連合軍側が口穢く言い過ぎるように如何に狂暴であるにしても、その武力を割いて西比利亜に及ぼし、兼ねて日本を脅威しようとは想像されません。",
              "citation": {
                "source": "何故の出兵か",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯く言えば、言い過ぎであろうか。",
              "citation": {
                "source": "「草野心平詩集」解説",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし言い過ぎであるならば、心平さんと読者とにお詑びをしましょう。",
              "citation": {
                "source": "「草野心平詩集」解説",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学は単に記述するのみで説明するものでないというのは、言い過ぎであるにしても、それは決して目的の言葉において説明するものではない。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……それはわたしが言い過ぎたかもしれませんわ。",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし冗談いいすぎたようである。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱心の余りいいすぎたと思った彼女は、「何も私は義弟さんのこと悪いう積りやおまへん」　と最後に附け加えた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "章三は鈍感ではなかったから、貴子が春隆の悪口を余りにいいすぎることに気がついた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
