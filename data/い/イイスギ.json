[
  {
    "uuid": "a763e340-929d-5c6b-a3d4-4c95b70d037f",
    "entry": "言い過ぎ",
    "reading": {
      "primary": "いいすぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
