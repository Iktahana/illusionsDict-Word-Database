          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "提出前に、誤字脱字がないか今一度書類の隅々まで確認してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "皆様の厚いご支援を賜りたく、今一度のご協力を何卒よろしくお願い申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "あの日の情熱を思い出すために、原点に立ち返って今一度自分を見つめ直したい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今一度小春の日光を見ればそれでよい。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御厚意を謝します、しかし今一度お考え直しを願いたいことは――もしあれ等がフランス固有の唄も混ぜて唄うとしたらどうでしょう。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのおっかさんがきまして、民や、決して気を弱くしてはならないよ、どうしても今一度なおる気になっておくれよ、民や……民子はにっこり笑顔さえ見せて、矢切のお母さん、いろいろ有難う御座います。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かに心を落付ながら、私は今一度目をひらいて、事実の真相を眺め返した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は再び寝床の中にもぐると、今一度シイ・ファン・ユウの電報を開いて読むのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先ず自分の思いついた画題は水車、この水車はその以前鉛筆で書いたことがあるので、チョークの手始めに今一度これを写生してやろうと、堤を辿って上流の方へと、足を向けた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「江藤さん、」と返事が無いから、少女は今一度、やはり小声で呼んだ。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "与えしものも言葉なく受けしものも言葉なく、互いに嬉れしとも憐れとも思わぬようなり、紀州はそのまま行き過ぎて後振向きもせず、源叔父はその後影角をめぐりて見えずなるまで目送りつ、大空仰げば降るともなしに降りくるは雪の二片三片なり、今一度乞食のゆきし方を見て太き嘆息せり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ち付いて……とにかくここへ今一度おかけ下さい。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一度、黒い煙突の影を振返ると急ぎ足で横町に外れた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非とも英、伊戦争にまで展開させて、欧州を今一度大混乱に陥れ、ロシアの極東政策をお留守にさせちゃって、その間に支那奥地の英、仏の勢力と、共産軍の根拠をタタキ潰さなくちゃならんというのが、日本の当局者の意向なんです」「そう都合よくまいりましょうか」「行きますとも。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうじゃない」　今一度シンミリとそういううちに眉香子は、その肉つきのいい白い腕を長々と青年の肩に投げかけた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は今一度眼をこすった。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一度左右の寝姿を見まわした。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を見下している四ツの顔が皆、白い歯を現わして冷笑しているのを見ると、たちまち眼を釣り上げ、歯を喰い締めて今一度、心の底から唸った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとを見送った眉香子未亡人は、今一度、維倉青年を見下してニッコリと笑った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い鼻の頭を今一度、念入りにコスリ上げると、炭俵の上からガサガサと一膝進み出た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵元屋の家でもそげな理由で、前の晩の暮方に覗いた塵箱を翌る朝、今一度覗いてみますると、晦日の晩なぞに蟹の塩｜茹の喰残しが真白う山盛りになっておる事が間々御座いまする。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに最早、年頃のことじゃけに、早よう何処かへ嫁に遣って一刻も早くお嬢様の足を洗わせねば、わたしゃ心配で心配で夜の目も寝られませぬという、乳母のお島どんの涙ながらの物語……」「う――むむ」　松倉十内は腕を組んで今一度太い、深い溜息を吐いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは処々に灰色の薄汚れの付いた、夜具か何かを包む風呂敷らしかったが、その中央の折目に近い処に付いている真黒い血の塊の痕跡と、一目でわかる片隅の刃の血糊を拭いた痕跡と、処々に粘り付いている長い髪毛を見まわすと、今一度赤い唇をペロリと出して、大切そうに折り畳んで、懐中の奥に仕舞い込んだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして王宮にお伴をして、今一度この若い美しい王様のためにお祝いをしました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とにかく今一度モトの処へ帰らなければと思い思い、タッタ今見て来た店の順序をタヨリに最初に降りた階段を上ってみるとヤットわかった。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐石というものは、こんなに早くお茶を飲んでしまっちゃいけなかったのかとも思い、又は懐石というものは一品も喰い残しちゃいけないものと聞いていたようにも思えて内心すくなからず迷ったが、ともかくも今一度箸を執って無理やりに嚥下してしまった。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども何となく胸がドキドキしたから、念のため今一度ふり返ってみると、線路の上はもう何も見えなかった。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは否の一語を今一度叫けんで置きます。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか少女を今一度僕の手に返したい。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にあの少女の今一度この世に生き返って来ることは僕の願です。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまいちどお取調のほど、ひとへにお願ひ申し上げまする。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまいちどは、つい昨年の冬。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれぞ勇を鼓して、いまいちどくぐる者はないか」「…………」「戦場と思うたら行けるはずじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
