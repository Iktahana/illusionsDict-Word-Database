    "definitions": [
      {
        "index": 1,
        "gloss": "single seater (e.g. boat, aeroplane, airplane)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "小型偵察機は、その機動性を活かすため一人乗りに限定されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "川下りには、手軽に楽しめる一人乗りのゴムボートが人気を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "レース用自動車の多くは、ドライバーの感覚をダイレクトに伝える一人乗り構造を採用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "通勤用に開発された新型電動スクーターは、驚くほど軽量な一人乗りモデルだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事故現場の状況から、墜落したのは一人乗りの小型グライダーであった可能性が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この観覧車のゴンドラ、一人乗りって書いてあるけど、二人でも乗れるのかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "宇宙開発初期には、有人宇宙船も一人乗りの実験機が試作された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一人乗りに同乗ができるかい」「そこはまたお話合いで、よろしいようにしてお乗んなすってください」　おもしろ半分に※るを、白糸は鼻の端に遇いて、「おまえもとんだ苦労性だよ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　この客車にＩ―町の弁護士が一人乗りあわせていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ船の港に進み入り候に、丸木船漕げる土人多く見え申し候中に、十二三の子の一人乗りたるを見て、「君の如き子よ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、Ｓ君が突然、「君一人乗りたまえ。",
              "citation": {
                "source": "帰途",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人乗りの豆潜水艇のようだが……」「将軍よ。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "海面から、この艇の背中が漸く没する位、つまり数字でいえば、波面から二三十センチ下に潜り、それ以上は潜らない一人乗りの潜波艇だ」「ふむ、ふむ」「これを作ったわけは、如何なる防潜網も海面下二メートル乃至十数メートル下に張ってあるから、普通の潜水艦艇では、突破は困難だ。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや駕籠もすたれかけて、一人乗り、二人乗りの人力車、ないし乗合馬車がそれにかわりつつある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆絵の画いてある一人乗りないし二人乗りの人力車がどれほど町にふえて来たと言って見ることもできないくらいで、四、五人ずつ隊を組んだ千金丹売りの白い洋傘が動いて行くのも彼の目についた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "轎　　一人乗りで二人の轎夫が棒で肩に担いで運ぶもの。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、その上に乗ってもだいじょうぶだろうと、一人乗り、二人乗りしました。",
              "citation": {
                "source": "愛は不思議なもの",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "僚艦にも通訳が一人乗りこんでいた。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思う仔細があったので、その他に私は一人乗りの筏を一隻｜製造らせた。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌十七日にエッカという一人乗りの馬車を雇うて、ビンビテーという山の下まで四日間ほどの道程を荷持と共に参りました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "女と云えば、ひろ子のほかには子供づれの細君が一人乗り合わしているきりである。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船に女が一人乗り合せたのがどうしたんだい、はじめのうちは船は女の物だの、正座を張れのと、さんざん人を煽てておいて、この暴風雨になると、みんなわたしにかずけて、人身御供に海へ沈んでくれとはよく出来た。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のキャプション付きの図（fig55990_457.png、横215×縦200）入る］図‐457　人力車は一人乗りで狭く、そして背が高くて頭重だから、乗っている人は、しょっ中均衡に注意していなくてはならぬ。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "高価な荷を積み、グライドがその横にたった一人乗り、小型船は矢のように川を下った。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "べか舟というのは一人乗りの平底舟で、多く貝や海苔採りに使われ、笹の葉のような軽快なかたちをしてい、小さいながら中央に帆桁もあって、小さな三角帆を張ることができた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は箱庭の線路の上へ、箱庭の果てから夜汽車を送り、林芙美子がその客車へと、一人乗り込む姿を想像している。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通は粗末な黒塗りで一人乗りと合箱、芸者と合乗りなどの図々しいのもあって、当時「合乗り幌かけ、テケレッツノパア」と唄ったくらい。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人乗り宇宙艇にたった一人でいたのです。",
              "citation": {
                "source": "親友たち",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰か空ボートに一人乗り込んで、どこか近くに係留しろ」　と警察艇の指揮官が命令。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
