[
  {
    "uuid": "b96b98fb-5dcc-5b6a-a376-9150cb3e2532",
    "entry": "行きがかり上",
    "reading": {
      "primary": "いきがかりじょう",
      "alternatives": [
        "ゆきがかりじょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
