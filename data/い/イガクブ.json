    "definitions": [
      {
        "index": 1,
        "gloss": "faculty of medicine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の息子は小さい頃から医師を志し、猛勉強の末、難関として知られる医学部に合格した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新の研究によると、特定の遺伝子変異がアルツハイマー病の発症リスクを高める可能性があり、これはとある大学の医学部で発見されたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地方の医師不足を解消するため、政府は特定の地域枠を設けた医学部の定員増加を検討している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は医学部の学生時代に、国際的な医療ボランティア活動に積極的に参加し、貴重な経験を積んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「いやあ、医学部の講義は専門用語が多くて、覚えるのが本当に大変だね」と彼は友人につぶやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "少子高齢化社会において、医学部が果たすべき役割は、単なる医師養成にとどまらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "近年、女性医師のキャリア支援を目的としたプログラムが、複数の医学部で導入され始めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "帝大の医学部に在籍。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、この地方の新聞社の記者だと称する不精鬚をはやした顔色のわるい中年の男がやって来て、あなたは今の東北帝大医学部の前身の仙台医専を卒業したお方と聞いているが、それに違いないか、と問う。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年は、或る大学の医学部の研究室に、つとめていた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年は、或る大学の医学部の研究室に、つとめてゐた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ大学医学部が下谷にある時の事であった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝……四月二十七日の午前十一時頃の事、雨の音も静かなＱ大医学部、大寺内科、第十一号病室の扉を静かに開いて、私の異母弟、友石友次郎が這入って来た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "香櫨園の家は経費が掛るので、やがて寿枝は大阪市内の小宮町にこぢんまりした借家を探して移ることになつたが、果して修一は阪大医学部の卒業試験の勉強で忙しいと口実を設けて、一人で夙川の下宿へ移つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "早川というのは九大医学部の寺山内科に居る、医学士の医員で、記者仲間に通った色魔に相違なかった。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日取り損ねた九大工学部の記事を、漁りなおしに行くべく、今川橋の下宿から、電車で筥崎の終点へ行く途中、医学部前の停留場を通過すると、職業柄懇意にしている筥崎署の大塚警部が飛び乗って来たので、脛に傷持つ私はちょっとドキンとさせられた。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊間では進化学者として有名であるが、専門は微生物学で、慶応大学医学部の豫防医学の教授である。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶応大学医学部の加藤元一博士とその一番弟子である林髞博士も亦、生理学者だ。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学部の博士製造のカラクリは氏に聞くべきであろう。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同船の誰かれ――日本人学生Ｎ氏とＮ氏夫人の英吉利婦人、Ｔ大学医学部教授Ｔ博士、などとみんな一緒に上陸して、出帆までの町の内外をドライヴする。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸から帰国の途にある作曲家のＨ・Ｒ氏――日本風に姓が上である――の一家や、Ｋ大学精神病学教室のＫ博士、Ａ大学法医学部のＫ教授。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "心意生理学の知識を外国から伝へたは、多分、東京大学の医学部と文学部が真先きであつたらう。",
              "citation": {
                "source": "斎藤緑雨と内田不知菴",
                "author": "坪内逍遙",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし保が助教授になっていたのは藩学の儒学部で、道悦が小学教授になっていたのはその医学部である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "感冒で寝込んだ後、微熱が去らないので、当時医学部の内科教授をして居られた島薗博士に診察して貰ふと、病気はたいしたこともないが、なんにしても痩せてゐて、よくないからだだから、転地して少し休養されるが可からう、私が診断書を書いて上げるから、とのことであつた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は私の所で断られたものだから、次には親戚関係のある医学部の市川教授を訪ね、そこで所要の旅費を調達した。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等小学校時代に結核を患った稲盛は、この経験もあって大阪大学の医学部薬学科を志望したが果たせず、家族の強い勧めで二期校の鹿児島大学に進んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで九州大学医学部の学生に逢って道を聞けば、川を渡って川を上り十町くらいまで行って谷を登るとのことであった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州帝国大学法医学教授　　　　　　　　　　　　　若林鏡太郎医学部長　この名刺を二三度繰り返して読み直した私は、又も唖然となった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……では……こちらへどうぞ……」　九州帝国大学、医学部、精神病科本館というのは、最前の浴場を含んだ青ペンキ塗、二階建の木造洋館であった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その廊下の突当りに「出入厳禁……医学部長」と筆太に書いた白紙を貼り附けた茶褐色の扉が見えた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚しいのになるとこの原稿を読んでから、精神病の研究がイヤになって、私の受持っております法医学部へ転じて来た者が一人、それからモウ一人はやはりこの原稿を読んでから自分の脳髄の作用に信用が措けなくなったから自殺すると云って鉄道往生をした者が一人居る位です」「ヘエ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をいうにも新興医学部の最高の使命と名誉とを中心とする、必死の論争なのですから、真に血湧き肉躍るものがありましたでしょう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が……こうして評判に評判を重ねた、医学部の卒業式の当日になりますと、意外にも、恩賜の銀時計を拝受すべき当の本人の正木医学士が、いつの間にか行衛不明になっている事が発見されまして、又も、人々を驚かしました」「ホウ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業されてから十八年の長い間、全く消息を絶っておられた正木先生が、思いがけなく当大学、法医学部の私の居室をノックされましたのには、流石の私もビックリ致しました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに御紹介致しまするは、九州帝国大学、医学部、精神病科本館の裏手に当って、同科教授、正木先生が開設されましたる、狂人解放治療場の「天然色、浮出し、発声映画」と御座います。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方のかべに、一メートル四方もある大きな鏡が、はめこみになって、まわりに、うつくしいがくぶちがついています。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
