        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の物置の扉が壊れたので、板切れで応急処置を施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "解体現場からは、多量の板切れが運び出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "趣味の木工で使うため、ホームセンターで色々な種類の板切れを購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大工：「この板切れ、どうする？ まだ使えるか？」\n施主：「「そうねぇ、薪にするにはもったいないかしら。」」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "屋外のバーベキューコンロに火をつけるため、乾いた板切れを数枚用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現代アートの素材として、意図的に選ばれた板切れが展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それに何せ薄い板切れでいい加減に作つた舟だから、水がしみ込んで來て危いのよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "板切れの舟は危いから、もつと岩乘に、泥をこねつて作りませうよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚さ一センチ程度で長さ二十センチもある扁平な板切れのような、たとえば松樹の皮の鱗片の大きいのといったような相貌をした岩片も散在している。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、そうは思っても、お姫さま自身が、海の上をただよっている、船の材木や板切れに、気をつけなくてはなりません。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに何せ薄い板切れでいい加減に作つた舟だから、水がしみ込んで来て危いのよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "板切れの舟は危いから、もつと岩乗に、泥をこねつて作りませうよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいありがとう」と手に持った厚紙の蓋を鑵詰へ被せると、箱の中から板切れを出して、それを提げて、得意になって押入の前へ行く。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞうぞうと潮鳴の如く、ごうごうと嵐の如く空気はいちめんに騒ぎ廻り、板切れ、着物、トタン屋根、いろんな物が灰色の空中をぐるぐる舞つている。",
              "citation": {
                "source": "長崎の鐘",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲しいものは、なるべく大きな板切れと、なるべく広い布であった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び越し難い石から岩へは彼が渡した板切れの橋がかけてあつた。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、自分が棺を造っているのだと云うことも忘れて了って、だんだん加わって来る気持良い興奮の中に、間もなく彼は三つの箱をばらばらの板切れにして了った。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "納屋を探して、必要なほどの木切れや板切れを取り出して來た。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一条様のお屋敷だよ」「ああそうか、右衛門様のな」　板切れをひっ放す音がした。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平日でも細い板切れへ竹づッぽのガンクビをつけたのをもって、お店から小僧さんが沢山買いに来た。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の手前に壊れかかったというよりは拾い集めた板切れで建てたような小屋がある。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はしばらくたじろいだ氣持で眺めてゐたが、思ひ切つて褞袍を脱ぎ、流し場にあつた板切れで掻き※して、少し熱目なのを我慢してはひつたが、さすがに顏を洗う氣にはなれなかつた。",
              "citation": {
                "source": "湖畔手記",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "板切れ数枚を縄でくゝり、肩にぶらさげてゐる。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、ボール紙で造つた黒い冠、笏の形をした板切れ、同じく木製の珍妙な沓だのいふ品々が揃つてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "房一は、行儀よくまだ冠を頭にのつけたまゝの小谷と練吉と並んで板切れの上に坐つてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきから口々に何か叫び、又しづまりかへつてゐた下方で突然又あの板切れの井桁積みがくづれる音がした。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らず火の粉が火になった板切れとまじって雪と降る、その中に職業学校が包まれてしまって……。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の陰気さは前と少しも変りはなかったが、押入の張板が一枚、あり合せの板切れで、刑事の手によって置き換えられたことを思うと、今迄の何とも云えぬ不気味さが、朝の光りのように白々しくなって、何処かへ消え失せてしまった。",
              "citation": {
                "source": "白血球",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞうぞうと潮鳴のごとく、ごうごうと嵐のごとく空気はいちめんに騒ぎ回り、板切れ、着物、トタン屋根、いろんな物が灰色の空中をぐるぐる舞っている。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日一日、眺め暮らし、見たとおりの山の形を板切れに消炭でなぞっておき、翌朝、明けきらぬうちに甲板へ出て眺めかえすと、昨日見た形とちがわない。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもなにか書き残して置こうと、板切れに鉛筆で筏の上の反乱と人肉嗜食の顛末のあらましを書きつけた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "首だけ出して、波にさらわれた板切れに追いすがる。",
              "citation": {
                "source": "生きること作ること",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて板切れを抱いて水を跳ね飛ばしながら駛け上がって来る。",
              "citation": {
                "source": "生きること作ること",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくお互いに思想の乾かされた板切れをいくつか持って坐りこみ、それぞれのナイフの切れ味を試みつつそれを削り、カボチャマツのはっきりした黄色がかった木目を賞美した。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "めたん子逃げろよバカだなといはれても、めたん子はにやにやしながら、かーんと板切れに蜂を叩く音を立てた、蜂は怒つてゐるから栗の實のやうに硬いからだを鯱張らせてゐて、かーんと勇ましい音を立て叩き落された。",
              "citation": {
                "source": "めたん子傳",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の裏手とか腰板つづきの、人の氣づかない處で石をつみ重ね、板切れで家のやうな物を建てて夕方には毀して去つた。",
              "citation": {
                "source": "神のない子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
