          ],
          "literary": [
            {
              "text": "」　咲子は息急き帰つて来た。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の北方ビサンチン湾へ、物見に出して置いたゴーという土人が、息急き切って走って来たが、「大きな船が五隻揃ってビサンチン湾へはいって来た」とこういうことを告げたものである。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が指図するまでもなく、誰か走った者があると見えて、瓦屋伊助が息急きって駈けつけて来た。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "うし紅珊瑚",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして哀れな舊い機械を發條線の切れるのも構はず、ある限りの力を出して卷き直しでもするやうに、無理やり息急ききつて歩いて行つた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年もやっと、三月頃から起き出して……この夏、もっともっと早く来ようと思ってたんですが家がやかましくてなかなか、出られないもんですから……」　と、私は息急き切って、病気で来ることのできなかった今日までの事情を、まず詫びました。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を出て、まっすぐに上諏訪へ行き、わきめも振らずあの宿へ駈け込み、そうして、いきせき切って、あのひと、いますか、あのひと、いますか、と騒ぎたてる、そんな形になるのが、いやなので、わざと上諏訪から一つさきの下諏訪まで、切符を買った。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多数の人の血眼になっていきせき追っかけるいわゆる先端的前線などは、てんでかまわないような顔をしてのんきそうに骨董いじりをしているように見えていた。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰐口は晩酌の最中で、うるさいと思ったが、いやにしつこく挑んで来るので着物を脱いで庭先に飛び降り、突きかかって来る才兵衛の巨躯を右に泳がせ左に泳がせ、自由自在にあやつれば、才兵衛次第に目まいがして来て庭の松の木を鰐口と思い込み、よいしょと抱きつき、いきせき切って、この野郎と叫んで、苦も無く引き抜いた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、いきせき切って、ひどく見すぼらしい身なりの女が出産とどけを持って彼の窓口に現われる。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物なれど喰うこともならず、みやげにもならず、うれしからぬものなりと思いながら、三の戸まで何ほどの里程かと問いしに、三里と答えければ、いでや一走りといきせき立て進むに、峠一つありて登ることやや長けれども尽きず、雨はいよいよ強く面をあげがたく、足に出来たる「まめ」ついにやぶれて脚折るるになんなんたり。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はいきせき駆けてくる。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも兩手に麥酒瓶を持つて、いきせき切つて來た。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多助は彼の道恩を送っていきせき帰って来ましたが、此の体を見て驚きましてブル／＼顫えております。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　次郎君は、いきせききって、カニ怪人のことをはなしました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきせききって西洋館にたどりつき、時計塔を見あげますと、いつのまにおりたのか、もう道化師のすがたは見えませんでした。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木村さん、二十めんそうから電話がかかったそうですが」　ぶかのひとりが、いきせき切って、たずねました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきせききってかけこんできた、ふたりの少年の話をきくと、おとうさんや書生などが、その町かどへかけつけてさがしましたが、あのあやしいじいさんも、箱車も、どこへいったのか、かげも形も見えませんでした。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社のむこうの出口にまわっていた、少年探偵団員のひとりが、いきせききって走ってきました。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いきせききって知らせました。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　またべつの部下が、いきせききって、いうのです。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そのとき、お堂のほうから、白いきものに、腰ごろもをつけた番人の若いぼうさんが、いきせききってかけつけてきました。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
