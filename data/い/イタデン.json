    "definitions": [
      {
        "index": 1,
        "gloss": "crank call",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "深夜、執拗にかかってくるイタ電に悩まされ、ついに電話番号を変更することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "消防署や警察へのイタ電は、一刻を争う救急・救命活動を妨害する極めて悪質な行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「またイタ電だよ。いい加減にしてほしいよね」と彼女は不機嫌そうに受話器を置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近はスマートフォンの拒否設定やフィルタリング機能のおかげで、イタ電の被害に遭うことも少なくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "単なる悪ふざけのつもりで行ったイタ電であっても、法的には業務妨害罪に問われる可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "非通知設定で特定の店舗に執拗にイタ電を繰り返していた男が、威力業務妨害の疑いで逮捕された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さっきから線路の左がわで、ぐゎあん、ぐゎあんとうなっていたでんしんばしらの列が大威張りで一ぺんに北のほうへ歩きだしました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
