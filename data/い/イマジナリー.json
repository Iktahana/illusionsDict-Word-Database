          "literary": [
            {
              "text": "言わば√-1を含むイマジナリーな部分から成る拡散現象であるとも言われる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "形に表わす事の出来ないイマジナリー・ナンバーや、無理数や、循環少数なぞを数限りなく含んで……。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君に警告しておくが、君は実在の人間ではなく、イマジナリーの人間なんだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり何でもわれわれと同じには、やれないってことを、よく頭にいれておいてもらいたい」　イマジナリーの人間！",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
