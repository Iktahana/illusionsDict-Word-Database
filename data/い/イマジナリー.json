        "examples": {
          "standard": [
            {
              "text": "子供の頃、空想の世界でイマジナリーな冒険を繰り広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その小説の登場人物は、現実には存在しないイマジナリーな生き物と友達になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の頭の中には、いつもイマジナリーな音楽が流れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "言わば√-1を含むイマジナリーな部分から成る拡散現象であるとも言われる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "形に表わす事の出来ないイマジナリー・ナンバーや、無理数や、循環少数なぞを数限りなく含んで……。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君に警告しておくが、君は実在の人間ではなく、イマジナリーの人間なんだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり何でもわれわれと同じには、やれないってことを、よく頭にいれておいてもらいたい」　イマジナリーの人間！",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
