        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "工事現場の周囲には、安全確保のため頑丈な板囲いが設置されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家庭菜園では、野菜の成長を助けるために、畑の縁に板囲いを施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イベント会場では、展示エリアを区切るために、景観に配慮したデザインの板囲いが使われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "強風から植えたばかりの若木を守るため、一時的に板囲いで囲った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この掘削現場、板囲いがしっかりしているから、外から覗かれても大丈夫だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "海岸線沿いの浸食対策として、波の衝撃を和らげるための特殊な板囲いが導入された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "唯一様の色彩と動作との中にうようよと甲板の掃除をして居る時でも、船艙の板囲いにずらっと列んで、尻をついて休んで居る時でも、イフヒムの姿だけは、一団の労働者から浮き上った様に、際立って見えた。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱鬧を極めたりし露店はことごとく形を斂めて、ただここかしこに見世物小屋の板囲いを洩るる燈火は、かすかに宵のほどの名残を留めつ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小半町ほども普請の板囲いをして、池上商事会社新築場と掲示看板が横えられています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その板囲いが外れたところに表附はオフィス風で、何の変哲もありませんが、その造作を越したうしろに聳えている蔵造りの家が集まってるらしい瓦屋根は、勾配を四方八方へ幾つにも分ち下ろして、なにさま大きな旧家の住宅に見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨がまたしめじめと降りかけた時に、私たちは養狐場の高い板囲いの潜り戸を開けてもらっていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人ぐらいしか並べない樋のような監視所、その板囲いの隙間から、直下の砂浜を差し覗いた――この驚駭、この動顛、この大畏怖、この寂光。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸通りに向いた方は板囲いになっていて、横町に向いた寂しい側面に、左右から横に登るようにできている階段がある。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に板囲いのしてあるのを思い合せて、普請最中だなと思う。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂利船、材木船、泥船などをひしひしと纜ってある蛤町の河岸を過ぎて、左手に黒い板囲い、※と大きく胡粉で書いた、中空に見上げるような物置の並んだ前を通って、蓬莱橋というのに懸った。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は立ち上って、「鱒の人工孵化をお目にかけましょうか」　と板囲いの一棟へ私を案内した。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は課業の休みの時間になりますと、よく便所の背面から弓の道場の板囲いの蔭に隠れて、あの廃屋の二階に上りました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの廃屋の二階を、私が大切な瞑想の道場としている事を夢にも御存じない校長先生と、傴僂の老人の川村書記さんとは、いつも学期末の近付いた放課後になると、職員便所の横のカンナの葉蔭から、通行禁止の弓道場の板囲いの蔭伝いに仲よく連立って、コッソリと入って来られるのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "板囲いの待合所に入ろうとして、男はまたその前に兼ねて見知り越しの女学生の立っているのをめざとくも見た。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、空地には板囲いがめぐらされ、歌舞伎座建築場の大きい杭が打ち立てられたので、その座名も初めてはっきりした。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは丁度、東京ビルの横に、板囲いをされた広い空地の中であった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小竹とした暖簾の掛っていたところは仮の板囲いに変って、ただ礎ばかりがそこに残っていた。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして板囲いのなかをあっちこっち歩いて見たり、杜松などの植わった廂合いの狭いところへ入って、青いものの影を見せたりした。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "面会所のそばの、自分の番の来るのを待っている間入れて置かれる、一室二尺四方ばかりの俗にシャモ箱という小さな板囲いの中には、「極悪男三郎速かに斬るべし」というような義憤の文句が、あちこちの壁に爪で書かれていた。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "西角は、ひどく塵のたかった銀行の鉄窓と、建築にとりかかったばかりの有名な時計屋の板囲いとに、占められている。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴やかな朝日は、そのじじむさい銀行の鉄窓の棧と、板囲いのざらざらした面とを照した。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、大抵のとき、前に云った建築敷地の板囲いの前に自分を現した。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "新建築の板囲いが出来る。",
              "citation": {
                "source": "モスクワ日記から",
                "author": "――新しい社会の母――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガーガーが、フランツ来い来いと呼んでるだろう」　裏は空地で、余りよく耕されていない礫まじりの甘藍や蕪の畑、粗末な板囲いの家畜小屋があった。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「か」の字川の瀬の中に板囲いをした、「独鈷の湯」と言う共同風呂がある、その温泉の石槽の中にまる一晩沈んでいた揚句、心臓痲痺を起して死んだのです。",
              "citation": {
                "source": "温泉だより",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、うちから見えない道端の板囲いのかげで、しばらく立ち話をした。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一人で散歩する、金網を板囲いでしきられた遊歩所のようなところもこの建物を囲った石塀のそばにありましたが、狭い金網の中にも青々と雑草が繁っていて、倉庫のようなところに、背の低い真赤なけしの花が一輪｜可憐に咲いていました。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽屋は近いうちに建築される東亜相互生命保険会社の板囲いと背中合せになっていて、そこへ行くのには演技場内から楽屋口を通って行くのと、一度表へ出て裏口から這入るのと二つの道しかない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに誰だかわからない二三人が、ダシヌケに私を押し除けながら板囲いの外へ出ようとした。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
