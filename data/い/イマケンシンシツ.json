        "examples": {
          "standard": [
            {
              "text": "一人暮らしのワンルームは、ソファベッドを置いて居間兼寝室にしています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "来客が泊まることを想定して、普段は居間兼寝室を客間に変えられるように工夫しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "限られたスペースなので、居間兼寝室で快適に過ごすための家具選びが重要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二階が本部兼居間兼寝室だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "残りの四坪が四壁を丸木に囲まれた居間兼寝室で、様式は和洋折衷、といふよりも、之がつまり最も自然な手のこまない様式だからに他なりませんが、先住は呑気な人で、蒲団も書物も食器も往時あつたがままの同じ場所へそつくり残してありました。",
              "citation": {
                "source": "淫者山へ乗りこむ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "応接間はあいにくふさがつているので、二階の居間兼寝室へ通す。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
