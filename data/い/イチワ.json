    "definitions": [
      {
        "index": 1,
        "gloss": "one (bird or rabbit)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "見て！公園の池に一羽、アヒルがいるよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "窓の外を、小鳥が一羽、優雅に飛んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔話では、不思議な力を持つ一羽の白鳥が登場することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私と幸福との間に一羽の鷲が――不幸なこつた不幸な！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こうした刈入時の田舎の自然と、収穫に忙しい労働の人生とが、屋根の上に飛びあがった一羽の鶏の主観の影に、茫洋として意味深く展開されているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯枝に止った一羽の烏は、彼の心の影像であり、ふと止り木に足を留めた、漂泊者の黒い凍りついたイメージだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の車庫のトタン屋根に雀が二羽、一羽がちょんちょんと横飛びをして他の一羽に近よる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植半の屋根に止れる鳶二羽相対してさながら瓦にて造れるようなるを瓦じゃ鳥じゃと云ううち左なる一羽嘲るがごとく此方を向きたるに皆々どっと笑う。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の梢に群れていた鴉の一羽立ち二羽立つ羽音が淋しい音を空に引く。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした茫漠たる冬田の中に一羽くらい鴫が居るのを見付け出すということは到底｜素人には出来ない芸当であったが、さすが専門家の要太の眼には、不思議なフィルター・スクリーンでもあるかのように、実に敏感に迅速にそれを発見するのである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "直径百メートルもあるかと思う円周の上を走って行くその円の中心と思う辺りを注意して見るとなるほどそこに一羽の鳥が蹲っている。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要太郎も少しだれ気味で網を高く上げて振るとバタ／＼と一羽飛び出して堤を越して見えなくなった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要太郎の指をさす通りにグサ／＼と下駄の踏み込む畔を伝って土手へ上ると、精の足元からまた一羽飛び出して高く舞い上がった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが手始めでそれからは取るは取るは、少しの間に五羽、外に小胸黒を一羽取った。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千羽に一羽の毒がある」と云ってこの鳥の捕獲を誡めた野中兼山の機智の話を想い出す。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の天幕作りに取りかかる、古生層地は白峰までつづき、鳳凰地蔵一脈の間で、深谷にフツリと切れているのが、よく見える、人夫たちは雷鳥三羽を捕獲した、みんなして二羽を醤油飯に、一羽を焼いて喰った。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石の急壁を登りかけていると、雷鳥が一羽、ちょこちょこと前を歩いている、晃平が、狙いをつけて一発放したが、禽は横に逸れて、截られた羽が、動揺した空気に白く舞った、一行手取りにするつもりで、暫く追いかけて見たが、掌中の物にはならなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三合四合と登るほどに、黒砂は凝結したように、ポロポロと硬くなって、時に生れどころの解らない大霧が、斜面を這って、煙のように舞い立つこともあったが、五合へ来たときには、それも拭うように晴れて、北風が起り初めた、鳶が一羽、虚空に丸く輪を描いて山体の半分を悠揚と匝ぐって、黒い点となって、遥かに消え失せた。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪を下りて行くと別莊だか茶店だかゞあつて其前の養魚池の岸にかはせみが一羽止まつて居たが、下の方から青年團の服を着た男が長い杖をふりまはして上がつて來たので其のフアシズムの前に氣の弱い小鳥は驚いて茂みに飛び込んでしまつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熔爐の屋根には一羽の鴉が首を傾けて何かしら考へて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから一羽の鶴がふらふらと落ちて来てまた走り出したインデアンの大きくひろげた両手に落ちこみました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この語は coq から来ていて、一羽の雄鶏が数羽の牝鶏に取巻かれていることを条件として展開する光景に関するものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで筆を擱こうと思ってふと縁先の硝子障子から外を見ると、少しもう色付きかかった紅葉の枝に雀が一羽止ってしきりに羽根を繕っている。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話によると、Ｋ先生は教場の黒板へ粗末な富士山の絵を描いて、その麓に一匹の亀を這わせ、そうして富士の頂上の少し下の方に一羽の鶴をかきそえた。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼のうちは空に一羽の雀が啼いても吠える。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一羽の燕が迷ひ込んでゐて、疲れた翼を振つて、出口を捜してゐるのであつた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう、それは一羽の小鳥らしかつた。",
              "citation": {
                "source": "夢",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日｜樋口という同宿の青年が、どこからか鸚鵡を一羽、美しいかごに入れたまま持って帰りました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "城山の森から一羽のからすが羽をゆるやかに、二声三声鳴きながら飛んで、浜のほうへゆくや、白痴の親は急に話をやめて、茫然と我れをも忘れて見送っていました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一羽のからすを、六蔵の母親がなんと見たでしょう。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇帝は金のいすにこしをかけて、なんべんもなんべんもおよみになって、いちいちわが意をえたりというように、うなずかれました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼には、彼女のしぐさが、いちいちわざとらしく思われた。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉はいちいちわたしの記憶に符合している。",
              "citation": {
                "source": "謎の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
