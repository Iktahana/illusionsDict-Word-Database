[
  {
    "uuid": "6500e0d3-61a2-5639-a30b-27cc52281e39",
    "entry": "意表外",
    "reading": {
      "primary": "いひょうがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
