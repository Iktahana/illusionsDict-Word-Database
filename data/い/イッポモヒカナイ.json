        "examples": {
          "standard": [
            {
              "text": "「絶対に譲れない！」彼は、長年の夢であったこの土地の購入について、一歩も引かない覚悟だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "反対派の圧力にもかかわらず、環境保護団体は開発計画への反対で一歩も引かなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の頑固さは有名で、一度決めたことは一歩も引かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この値段でしか売れないんだ！」店主は、商品に対する自信から一歩も引かなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかるに味方の過半数を斬られて一人も逃げず一歩も引かない、この分では最後の一人が斃れるまでこの斬合いは続くであろう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
