    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suspicious",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "見慣れない男が家の周りをうろついていて、とても訝しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の証言にはいくつかの食い違いがあり、訝しく感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そんなうまい話があるなんて、どうも訝しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の急な態度の変化に、皆が訝しい目を向けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鼈甲屋や、衣裳屋、指物屋なぞの出入りが間遠になって来たのは、どうも怪訝しいと言う近所界隈の取沙汰じゃ……吾々もドウモそこいらが臭いような……事件の起りはその辺ではないかと言いたいような気持がするが、それから奥の深い事情が一つも判然らんけに困っとる。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "廉平は我ながら、訝しいまで胸がせまった。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前達が寝よる位置がわかれば良えのじゃが……ところで、それにしても怪訝しいのう。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし可訝しい、いや可訝しくはない、けれども妙だ、――あの時、そうだ、久しぶりに逢って、その逢ったのが、その晩ぎり……またわかれになった。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は――――「……小説が上手に書けますように……」　どうも可訝しい、絵が上手になりますように、踊が、浄瑠璃が、裁縫が、だとよく解えるけれども、小説は、他に何とか祈念のしようがありそうに思われる。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして腕を組み直しながら、今一度よく考え直してみましたが、そのうちに私は又、とても訝しい……噴飯したいくらい変テコな事実に気が付いたのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、首をくくるのに、目隠をするのは可訝しい。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはまだ自宅に電話が引いてないせいではないかとも思ったが、それにしても怪訝しいと言うので、よく姉たちと話合ったものであったが、この不思議は間もなく解けた。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前原稿を毎日書いていた位の男が、死ぬと急に原稿が何であるかということを知らなかったのはどうも訝しい。",
              "citation": {
                "source": "あの世から便りをする話",
                "author": "――座談会から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたら伯母さんが怪訝な顔をして、「それは訝しい。",
              "citation": {
                "source": "あの世から便りをする話",
                "author": "――座談会から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって先生、科学的には非常に信用が置けるし、言うことも普通であるし、友誼も潔癖であるほど厚いし、殊に細君のことなど潔癖で、細君が死んでから他の女には絶対に接しなかったという程の人格者としては訝しいですが」「いや、それが訝しくない。",
              "citation": {
                "source": "あの世から便りをする話",
                "author": "――座談会から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "訝しいとは思ひ乍ら、私は別に深く其理由を考へても見なかつた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "課長は無論唯若い看護婦に施けたと云ふだけで揶揄つたので、實際又醫者や藥劑師や他の看護婦の居た前で施けたのだから、何も訝しい事が無い。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "訝しい事には、此時お定の方が多く語つた事で、阿婆摺と謂はれた程のお八重は、始終受身に許りなつて口寡にのみ應答してゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定はもう日が暮れかかつてるのに、まだ引張り※されるのかと氣が氣でなくなつたが、一町と歩かずに本郷館の横へ曲つた時には、東京の道路は訝しいものだと考へた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "訝しいとは思ひ乍ら、私は別に深く其｜理由を考へても見なかつた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "課長は無論唯若い看護婦に施けたと云ふだけで揶揄つたので、実際又医者や薬剤師や他の看護婦の居た前で施けたのだから、何も訝しい事が無い。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "訝しい事には、此時お定の方が多く語つた事で、阿婆摺と謂はれた程のお八重は、始終受身に許りなつて口寡にのみ応答してゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定はもう日が暮れかかつてるのに、まだ引張り廻されるのかと、気が気でなくなつたが、一町と歩かずに本郷館の横へ曲つた時には、東京の道路は訝しいものだと考へた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「訝しいぢやないか、僕の顔を見ていきなり笑ひ出すなんて。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が禁めたつていふのに、随分｜訝しいぢやないか。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、焼いたパンの中から鼻が飛び出したなどというのも訝しいし、当のイワン・ヤーコウレヴィッチはいったいどうしたのだろう？",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「代官からの命令とあれば是非もない――尤も、どうしてそんなことが代官の耳に入つたのか、すこし訝しいけれど――結婚をさせてやることにする。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『隣の本山さんへ來る牛乳配達と訝しい。",
              "citation": {
                "source": "反古",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母から手紙が來るのは訝しい、用があるなら呼んで呉れゝば好いのにと思つて、明けて見ると驚きました。",
              "citation": {
                "source": "反古",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一葉は、ふとその日の訝しい友の言葉を思い出したので、歌子によってその惑いを解いてもらおうとしたのであった。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "凄いところが在りそうな気がして、たまらなく薄気味が悪いから怪訝しい。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どうも怪訝しい。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪訝しい怪訝しいと思ったが、この男の過去には何か暗いところがあるらしい。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上ではない、その下のほうの濠に、いぶかしい品がぶかりぶかりと浮いているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
