[
  {
    "uuid": "d7760b9a-0623-58c9-a157-710232db20d5",
    "entry": "訝しい",
    "reading": {
      "primary": "いぶかしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
