        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "警察の統計によると、昨年度の家出人の届け出件数は過去最低を記録した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "駅前で家出人の特徴が記されたチラシを配り、市民に情報提供を呼びかける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深夜の繁華街を徘徊していた少女が補導され、家出人として保護された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "NPO団体は、行き場を失った家出人の若者たちにシェルターを提供している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まさか自分の息子が家出人になって捜索願を出すことになるとは、夢にも思わなかった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "身元不明の遺体が、十年前から行方が分からなくなっていた家出人と判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒に紛れて生活する家出人たちの実態を、ルポルタージュで浮き彫りにする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「その鉤に当った人は、その年きっと幸運を釣るというわ」と、言って、わたくしが苦笑しますと、葛岡はわたくしの言う通りその鉤を背広の襟元へ刺しながら、「ちと、幸運でも見舞って呉れなくちゃ、正月から家出人の心配なんか、つく／″＼有難くない」　と呟きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月二十一日願い主　芝入舟町甚七店束巻き師　源五兵衛家出人お係りさま御中　というのが一通。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月二十二日願い主　芝入舟町甚七店束巻き師　源五兵衛家出人お係りさま御中　というのが一通。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月二十三日願い主　芝入舟町甚七店束巻き師　源五兵衛家出人お係りさま御中　というのがその第三通めでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が快い高鼾を掻いている間に、その枕許を起重機が軋み、刑事に追われた泥棒が走り、ゴミ箱に睡るルンペンの心臓がハタと停り、死所を求めて彷徨う家出人が大金の入った蟇口を拾い、硝子壜に白い牛乳が一杯詰められては蓋をされてゆくのだ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し私の調べた所では検挙せられた様子もなく、家出人の届出にも似よりのものはなかった。",
              "citation": {
                "source": "愛の為めに",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふしぎな電話　きゅうにある家出人事件がおきて、そのことについて蜂矢探偵は一生けんめいに走りまわっていたので、れいの茶釜破壊の日から約二十日間を、怪金属事件の捜査から、手をぬいていたのだった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくその家出人も、ついに探しあてられて、ぶじ家にもどり、蜂矢の仕事も、ここに一段落となった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（目賀野氏はもはや閣下ではない筈ですが……）と皮肉をいってやりたくなった田鍋課長だったけれど、それは差控えることにして、「どういう人物だか、詳しくお話下さらんので、われわれには正体が分りませんが、とにかく家出人の捜査申請は本庁でも毎日受付けて居りますから、どうぞ届書を出されたい」　と返答をした。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、只々重大人物博士の失踪について非常なる憂慮と不安と焦燥とを覚えている次第でございます」「失踪事件ならば、先刻も御教えしたとおり家出人捜査｜申請をせられたい」「それは分って居ります。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "敏腕な部課員はすべて前線に駆りだされ、捜査局は防諜事務に専念し、各区の自警団とわずかばかりの老年の臨時警官の手で辛うじて治安の最後の線を保持していた状態だったので、捜査局の文書箱には三百件に及ぶ家出人、失踪者の捜索願が積みあげられたままになっていた。",
              "citation": {
                "source": "青髯二百八十三人の妻",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "家出人や、駈落者が遠くへは行かないように、この不動尊の足を縛っておくと、動けなくなってやがて帰って来るとの迷信がある――それを信じて、昔の朋輩のお君のために、この娘は不動尊の足を縛りに来たのだが、それが、米友さんの足を縛ったことになったのも有難い……と。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
