        "examples": {
          "standard": [
            {
              "text": "多くの国際機関が、石打ち刑を非人道的刑罰として非難している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代の法律では、姦通などの特定の罪に対して石打ち刑が科せられることがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "石打ち刑の存廃を巡る議論は、国際社会において重要な人権問題として取り上げられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "報道によると、一部の国では未だに石打ち刑が合法的な刑罰として執行されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「石打ち刑は文明社会において許されるべきではない、残虐な刑罰だ」と、その人権活動家は涙ながらに訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国連は、女性に対する石打ち刑の即時停止と、すべての加盟国における廃止を強く求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
