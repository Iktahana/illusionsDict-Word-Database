    "definitions": [
      {
        "index": 1,
        "gloss": "soldier's comfort bag",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はＴ君に貧しい慰問袋を送りました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰問袋も寄こさないで下さい。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、内地から着いた手紙や、慰問袋を兵営から病院へ持ってきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、持って来た慰問袋を開けていると、看護長がぶら／＼病室へ這入ってきたことがある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰問袋には一ツ／＼何か異ったものが入れてあった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦友は、這入ってきた看護長を見ると、いきなり、その慰問袋から興味をなげ棄てた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二　慰問袋　壁の厚い、屋根の低い支那家屋は、内部はオンドル式になっていた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人の××ばかりでなく、キキンの郷里から送られる親爺の手紙にも、慰問袋にも××××がかくされてあるのに気づいた中隊幹部は非常にやかましくなってきた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　でも、慰問袋は、一人に三個ずつ分配せられた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、彼等は、もう、白布の袋の外観によって、内容を判断し得るほど、慰問袋には馴れていた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者は開けたばかりの慰問袋や、その中味や、子供の手紙にどんなことが書いてあるか、そういうことをたずねるのだった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夕方、彼等が占領地から営舎に帰ると、慰問袋と一緒に、手紙が配られてあった。",
              "citation": {
                "source": "チチハルまで",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずしい慰問袋を作り、妻にそれを持たせて郵便局に行かせる。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平「じゃ、やはり和子様は……」葉子「はあ、母は一番はじめの慰問袋送って直きに、死なはりましてん」庄平「……そうでしたか、では僕のお礼の手紙が着いた時には……？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると、伊藤は須山のあとを取って、「赤い慰問袋」の話をしたり、戦争になってから少しも自分たちが生活が楽にならなかったことなどを話した。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "缶詰に、ハミガキに、それから慰問袋もあんたの分とあたしの分と二つあるわよ。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜はバラックの中で、明るい電灯のもとに震災慰問袋の中に入っていた古雑誌を展げて読み耽っていた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰問袋を女が三人あつまって拵えているわきでその児が見物していたが、やがて、それなんなの、ときいた。",
              "citation": {
                "source": "くちなし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "にこにこしてゐる日は、にこにこすることが重なるもので、重い慰問袋をぶらさげて、森茉莉さんがニコニコしながらはいつて來ていふには、　こしらへてゐるうちに、こんなに入れてしまひましたの。",
              "citation": {
                "source": "四人の兵隊",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇女流のみなさんから、「輝ク」へよせられる、皇軍將士への慰問袋が、日に日にうづたかく重なつてゆくのも、なんともいへず嬉しい。",
              "citation": {
                "source": "四人の兵隊",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまも心に叫ぶのは、人々よ、母をいたはれといふこと、戰線に送る慰問袋は、故國日本の母をも悦ばすであらうといふことである。",
              "citation": {
                "source": "四人の兵隊",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "村にも北支への召集が下って女子青年の慰問袋作りが補習学校を中心にはじまった。",
              "citation": {
                "source": "鏡の中の月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "広治がそれを見て思いつきから慰問袋へ入れてやったのであった。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○達ちゃんへ慰問袋を送り出す。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕たち、こんど慰問袋の中へ、お馬にやるものも入れて送らない？",
              "citation": {
                "source": "村へ帰った傷兵",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうだ、ここんところ、東北の饑饉騒ぎで、兵隊さんに送る慰問袋の方を、すつかり怠けてゐた。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、慰問袋に添へてあつた手紙が、たとへ純粋な銃後女性の感謝と激励の文章であるにもせよ、すこし長すぎはせぬかと思はれた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの幸福はそこにあるのだ」　満洲、華中、マレイと、彼女の手紙と慰問袋が執拗に彼を追いかけて来た。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰問袋をこしらえてやります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "達ちゃんには、近日慰問袋を送ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
