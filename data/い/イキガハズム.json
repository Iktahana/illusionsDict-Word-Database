        "examples": {
          "standard": [
            {
              "text": "マラソンでゴールした選手は、喜びと疲労で息が弾んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "久しぶりに会う旧友の姿を見つけ、彼女は思わず息が弾んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは公園で夢中になって遊び、みんな息を弾ませていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発表会の出番を待つ間、彼の胸は高鳴り、息が弾むのを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ジェットコースターを降りると、興奮のあまり息が弾んでしばらく声が出なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "好きなアニメの話になると、彼はいつも息を弾ませて熱く語る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "流石に異様な緊張の為に息が弾むのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
