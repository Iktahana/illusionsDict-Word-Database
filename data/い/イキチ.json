[
  {
    "uuid": "67437c1f-65ec-5cd7-ae18-fbef27abb432",
    "entry": "生き血",
    "reading": {
      "primary": "いきち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
