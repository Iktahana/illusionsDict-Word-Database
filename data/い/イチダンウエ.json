[
  {
    "uuid": "31a3eecf-c802-52fe-b59f-dbd09b575809",
    "entry": "一段上",
    "reading": {
      "primary": "いちだんうえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
