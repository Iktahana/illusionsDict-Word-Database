    },
    "definitions": [
      {
        "index": 1,
        "gloss": "a cut above",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨年のチャンピオンチームの決勝戦でのパフォーマンスは、他の出場者を一段上行くものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この新型スマートフォンのカメラ技術は、現在の市場にある製品群を一段上行くものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのシェフの伝統料理への革新的なアプローチは、彼のレストランを他店より一段上に見せている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の分析能力は、その分野のほとんどのエンジニアを一段上回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "評論家はそのピアニストの解釈を、過去の演奏を一段上行くものだと絶賛した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、このコーヒー、いつものより一段上だね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その企業の長期的なビジョンは、持続可能性に焦点を当てることで、競合他社を一段上行くものとなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の仕事ぶりは、常に周囲から一段上と見られており、信頼も厚い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "直接五感に触れる万象をことごとく偶然と考えないとすれば、経験が蓄積するにつれて概括抽象が行われ箇々の方則を生じ、これらの方則が蓄積すれば更に一段上層の概括が起る。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあの崖を登って行って見ないか」「行けそうだな」　自分達はそこからまた一段上の丘へ向かった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙人は建築が上手で、弘法大師なども初は久米様のいた寺で勉強した位である、なかなかの魔法使いだったから、雲ぐらいには乗ったろうが、洗濯女の方が魔法が一段上だったので、負けて落第生となったなどは、愛嬌と涎と一緒に滴るばかりで実に好人物だ。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って科学上の問題に比べてむつかしさの程度が一段上にある。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人より一段上の自由なものを老人は得て居るらしくはあるが、そこにゆったりと納り込んで独で楽しんでいられるほどその自由に自信と幅を持っていないらしい。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又一段上つて、云はば内陣ともあるべき幅一間程の細長い板の間の奥に龕がある。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともズット以前の明治三十年頃までは、深良家の先祖代々が住んでいた巨大な母家が、雑木林の下の段の平地に残っていたが、それが現在の牛九郎爺さんの代になると、極端な労働嫌いの算盤信心で、経費が掛るといって、その一段上の雑木の中に在るタッタ三｜室しかない現在の離家に移り住むようになった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へると、退いてゆくやうでやつぱり一段上の螺旋を廻つてゐるのでは無いか。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三等の食堂は一段上になっているので、下の雑居室は真上からそのまま瞰望せるのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂浜から一段上ると、その車前草に縁どられた径が続く。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまあパーソナルコンピューターの世界では、小型化をめぐってこんな時間が流れたが、この余波がワークステーションと呼ばれる一段上の処理能力を持つ兄貴分にも及ぶことは時間の問題だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで出てきたのが、一段上のＲＩＳＣ（吉野家）レベルでのＩＢＭ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為めに普通教育より一段上の教育を受けさせて置こうとした。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあくまでも澄み切った芸で、真の音楽として批判すれば一段上の技倆があるとも言えると、こんなふうに源氏は思った。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫君を美しいと思って、夫人に劣っていないと見たものの思いなしか、やはり一段上の美が夫人にはあるようで幸福な人と不運な人とにはこれだけの相違があるものらしいなどと右近は思った。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの二つの見方が、何方も本当ではあるが、しかし何方も主観に偏つたセンチメンタルな見方で、不動不変な自然は、心理は、愛はまだその一段上に位置して、大きな不壊なリズムを刻みつゝあるのである。",
              "citation": {
                "source": "自からを信ぜよ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は右より見、或は左より見て、そしててんでにその説を主張してゐるが、何故もう一段上にあがつて、心即物、物即心といふ境まで行かないのであらうか。",
              "citation": {
                "source": "エンジンの響",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "現象即実在論のもう一段上位に位してゐる境地は、そこを指してゐるのではないか。",
              "citation": {
                "source": "エンジンの響",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が一段上に立つて、そして人を教へるやうな態度に出るからいけないのだ。",
              "citation": {
                "source": "大阪で",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が宗教は好いが今の坊主が嫌ひだといふのは、実はかういふ感じをいふのであつて、人間を田舎者か何かのやうに見て、一段上に立つて、くだらぬことを説法してゐるから嫌ひなのである。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを斬りとる方法をいろいろ頭の中で考へてみたが、とにかく、何かよく切れる刃物で少し力を用ひれば濟みさうに思はれ、たださうすることだけで、自分が人間とは一段上の全く別な生物になれるやうな氣持ちがした。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから思想上で人生問題の解決が付くか否か解らんが、一方で人間に「仁」の気象を養ったら、何となく人生を超絶して、一段上に出る塩梅で、苦痛にも何にも捉えられん、仏者の所謂自在天に入りはすまいかと考えた。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の生れた家は舊本陣と言つて、街道筋にあつて、ずつと昔は大名などを泊めたのですから、玄關も廣く、その一段上に板の間がありました。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　兎に角、春信以下、たいていは錦絵の方が肉筆よりも一段上だと思われました。",
              "citation": {
                "source": "浮世絵画家の肉筆",
                "author": "――花は霞を透してひとしおの風情があるもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "御身分から申しても宮様が一段上の方なのですもの」　などと姫君に語りながらも、明石はいささか自信を持つことができるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一段上の御身分という思いなしからでしょうか、はなやかな御｜美貌は何と申し上げようもないくらいにお見えになりましたね」　こんなことを言ってほめそやした。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに液晶の解像度をもう一段上げることで、電子の紙は実現できる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいくと弘法の方が一段上の戦略家だと思った。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段上ると上台所だった。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
