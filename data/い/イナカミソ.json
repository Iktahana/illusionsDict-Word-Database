          ],
          "literary": [
            {
              "text": "大根一本四銭は高いな、田舎味噌百匁八銭。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌を頂戴した、田舎味噌のおいしさは。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹹い田舎味噌は摺鉢で摺る時少しばかりお砂糖を交ると美味しくなります。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌のできたてはナマナマしく濃いので、私には田舎味噌のほうがよく、それのみを用いている。",
              "citation": {
                "source": "三州仕立て小蕪汁",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
