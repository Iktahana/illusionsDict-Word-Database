        "examples": {
          "standard": [
            {
              "text": "お味噌汁には、コクのある田舎味噌を使うのが我が家の定番です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この田舎味噌は、米麹ではなく大麦で作られているのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖母が作った田舎味噌の味は、格別だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "田舎味噌特有の、少し甘みのある風味が好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "大根一本四銭は高いな、田舎味噌百匁八銭。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌を頂戴した、田舎味噌のおいしさは。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹹い田舎味噌は摺鉢で摺る時少しばかりお砂糖を交ると美味しくなります。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌のできたてはナマナマしく濃いので、私には田舎味噌のほうがよく、それのみを用いている。",
              "citation": {
                "source": "三州仕立て小蕪汁",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
