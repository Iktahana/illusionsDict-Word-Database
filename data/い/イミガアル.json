[
  {
    "uuid": "2cf65772-56b4-56f8-9e5d-309cebe24add",
    "entry": "意味がある",
    "reading": {
      "primary": "いみがある",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行-不規則"
      ],
