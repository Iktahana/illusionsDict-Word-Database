          ],
          "literary": [
            {
              "text": "女の子に縄張りのことで言いがかりをつけたのだった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに僕の場合では、読者がまるで僕の言語を理解せず、僕の思想の主題するところを知らないで、意外な思いがけない解釈から、勝手な言いがかりをしてくるのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼んだぞ源右衛門』源右衛門『じゃと申してあまりな無法の言いがかり』蓮如『年甲斐もない。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも御門徒の一大事に就ての談合と、道々も口を酸くして聞かしてやったではないか』おくみ『それがほんとなら、大事ないけれど』源兵衛『言いがかりもいい加減にしやれ、さあ、もう夜明けも間近だ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「多代子さんがうっかり出て行ったら、おそらく何かの言いがかりでもして、往来なかでひどい目にでも逢わせるつもりでしたろう。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の次第も其の烈しさも本文中に述べた通りで（私の見たのも矢張言いがかりを付けて来た方が返り討ちに会ってワアワア手離しで泣きながら帰って行ったが）昔と少しも変る所が無い。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "変な言いがかりを本当にしようと何やらでっち上げたに決まってる。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "八橋と言い合わせて、おれと手を切るためにわざとあんな無法な言いがかりをしたのではないかとも疑った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちに確かな証拠を握っていない以上は、逆捻じに言いがかりを付けられて、飛んだ目に逢うことがある。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでうっかりした返事をすると、それを言いがかりに執念深く絡みついて来るお絹のいつもの癖を知っている彼は、なるべく逆らわないように避けているのを唯一の楯と心得ているので、今夜もおとなしく黙って聞いていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」男は思いがけない言いがかりに、腹立ちと可笑さとのごっちゃになった表情をした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "手こそ下しませぬが、この泥斎が殺したも同然、無実の言いがかりに責められるを悲しんで、知らぬまに窯へはいり自害したに相違ござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とんでもないお言いがかりをおっしゃっちゃ困ります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "変な言いがかりはつけっこなしにしてもらいましょうぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "身に覚えもない言いがかりを申しおって、誰袖とやらはゆめおろか、源七とやらも幽霊も見たことないわッ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そのかわり、あの質屋のおやじがあっしをつかまえて、おかしな言いがかりをつけやがってね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、おのれ途方もない言いがかりをしおる。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかりでなくそれ以上に出ることをアカデミシャンは色々の言いがかりでみずから禁止しているのだ。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、常識的な眼を以ってみれば、あんなことはつまらないことで、殊に肝腎な手続がすっかり完了している現在、どんな馬鹿げた言いがかりをされようと更に問題でないこと位は、彼にも分っていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい嫁の血族に精神病の系統のあることが後に公判廷で立証されたにしても、姑の不法な言いがかりが専擅苛酷な夫婦の離別に及ばなかったならなおこの逆上はしなかったであろう。",
              "citation": {
                "source": "姑と嫁について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸にはこうした無頼武士がはびこって、相手が弱いと見ると、何かにつけて言いがかりをつけ、金銭をゆするはおろか時によると、剣を抜いて、挑みかかることもある故、気をつけるがいいと、いわれていたが、早くも、かような羽目に落ちて、どうさばきをつけたらよいか、途方に暮れた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それア飛んでもない言いがかりだよ。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんですか、言いがかりをつけて！",
              "citation": {
                "source": "南京虫殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりな言いがかりです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せても枯れても新家の徳兵衛は、妻子を食わすだけの用意は欠かさぬぞ、貴様こそ、そんな言いがかりをして、この身代が欲しいのやろ」「笑わせなさんな、親類寄合いの時、わしをこの家の後嗣にと、相談のきまったのを、こんなけがらわしい家はいやと、きっぱり断わったわしの舌の根を見ておくんなされ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは分りきったところだが、それをこんな見えすいた言いがかりで表すところが幼い。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが耳にはいると、銭湯屋も黙ってはおれず、いいがかりの機会をねらっていた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供にしてはませた、女の貞操を非難するようないいがかりをつけて真佐子に絡まった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いいがかりに止むを得ず、厭な顔して、「じゃ、御酒を上るだけになすって下さいよ、お肴は？",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジャムはジャムじゃん」「ジャムじゃなくて、“じゃん” ていうのは、どういう意味かって、きいてんだよ」　慶一はわけがわからず、なにかいいがかりをつけて、ケンカを売っているのかな、と考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
