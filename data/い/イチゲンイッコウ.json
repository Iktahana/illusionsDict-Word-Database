      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "every word and act",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公人としての立場をわきまえ、自らの一言一行が社会に与える影響を常に意識すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供は大人の一言一行を驚くほど敏感に察知し、それを鏡のように映し出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼のリーダーシップは、その一言一行に宿る揺るぎない自信と誠実さに基づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大統領候補の一言一行が、世界各地の株式市場や為替相場に多大な影響を及ぼしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "憧れの先輩の一言一行から、プロとして働くことの厳しさと誇りを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "SNSの普及により、有名人の一言一行が瞬時に拡散され、時には激しいバッシングの対象となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "真の信頼関係は、口先だけの甘い言葉ではなく、日頃の一言一行の積み重ねによって築かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "仁三郎の一生涯を通ずる日常茶飯が皆、是々的で、一言一行、一挙手一投足、悉く人間味に徹底し、世間味を突抜けている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野に対する大木の一言一行、それははがきに書く文字のはしにまで、矢野を思う心がこもっている。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらこれら諸女の譚は、道義に立脚した全くの戯作でなく、それぞれかつて実在した事蹟に拠って敷衍したものなれば、要は時に臨んで人を感ぜしめた一言一行を称揚したまでで、各生涯を通じて完全｜無瑕と保険付きでない。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、第一頁から犯人があがるまで全体が伏線のようなもので、どの一頁、どの一行、登場人物のどんな一言一行でも、漫然と読んでいるわけにはゆかない。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞してゐると、人間の一言一行が、どんなに人間の心を動かすものであるかを痛感する、うれしい事でも、おもしろくない事でも。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその謹厳なる事は一言一行の末にも及びたりき。",
              "citation": {
                "source": "恒藤恭氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち家に居り家族相互いに親愛恭敬して人生の至情を尽し、一言一行、誠のほかなくしてその習慣を成し、発して戸外の働きに現われて公徳の美を円満ならしむるものなり。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王莽は引經文奸とて、一言一行經書や聖人に託して、大惡をなし遂げたのである。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に君側に左右して、傳達を掌どる彼等は、その一言一行によつて、他人に大なる影響を與へることが出來る。",
              "citation": {
                "source": "支那の宦官",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "重きは斬衰の親から、輕きは※麻の親に至るまで、苟くも喪服を着くべき關係に在る者は、法律上必ず特別の規定を設けて、一言一行と雖ども、その尊卑長幼の關係如何に應じて、犯罪に對する刑罰を、普通一般の他人の場合と同一に取扱はぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "）クリストの一言一行に永遠の註釈を与へてゐるパピニさへこの事実はマタイを引いてゐるのに過ぎない。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "）それからクリストの一言一行を忠実に挙げてゐる余裕もない。",
              "citation": {
                "source": "西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも膝の拔けた紺の背廣を着て、一言一行極端に粗野な紳士であつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "新聞記者を憎むの記",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にそれが英雄として示される場合、偶像的地位を占めてゐる場合、その英雄振り、偶像振りには、甚だ東洋的ならざるところがあり、殊に、作者が意識的に附加した時代的特色が、寧ろ一種の『気障つぽさ』であるところから、かういふ事情に通じない見物は『シラノ』の一言一行に反感をもたないものでもない。",
              "citation": {
                "source": "『シラノ』雑感",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "其一言一行は世人の熱心に注意する所となれり。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　先輩の一言一行も忘れられないかのように、次郎はそれを私に語ってみせた。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にせよ多年の懸案であった学校生活を一擲して、いよいよ文学者生活に入ることになったのであるからその、一言一行に生き生きした打晴れた心持の現われているのも道理あることであった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二十八年の暮から二十九年に掛けて一言一行の上にきびきびしく現われておる。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿の一言一行こそは、善悪を超えて、そのまま人倫の大道と申すべきだ。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の一言一行は愛から生れ、愛によりて動き、そこに、愛にあらざる何物もない。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし短時間に於いてのことであるにせよ、一言一行とても時間的進行の過程の無いものは無い。",
              "citation": {
                "source": "歴史とは何か",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言一行でも、それをいはない前しない前といつた後した後とでは、それを聞いた人しかけられた人またはそれにあづかる事物に、何ほどかの変化を与へるのみならず、それによつて自己自身に変化が生ずる。",
              "citation": {
                "source": "歴史とは何か",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、どんな一言一行でも、上記の如き生活の変化によつて、或はその他の道すぢによつて、そのはたらきをかならず後の生活に及ぼす、といふことである。",
              "citation": {
                "source": "歴史とは何か",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて第八には、人は孤立して生活するのではないから、一言一行も他人との、また集団としての社会との、交渉をもつものであり、一くちにいふと生活は社会的のものだ、といふことであるが、これについては多くいふ必要があるまい。",
              "citation": {
                "source": "歴史とは何か",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし短時間においてのことであるにせよ、一言一行とても時間的進行の過程のないものはない。",
              "citation": {
                "source": "歴史の学に於ける「人」の回復",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言一行でも、それをいわない前しない前といった後した後とでは、それを聞いた人しかけられた人またはそれにあずかる事物に、何ほどかの変化を与えるのみならず、それによって自己自身に変化が生ずる。",
              "citation": {
                "source": "歴史の学に於ける「人」の回復",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、どんな一言一行でも、上記の如き生活の変化によって、あるいはその他の道すじによって、そのはたらきをかならず後の生活に及ぼす、ということである。",
              "citation": {
                "source": "歴史の学に於ける「人」の回復",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて第八には、人は孤立して生活するのではないから、一言一行に他人との、また集団としての社会との、交渉をもつものであり、一くちにいうと生活は社会的のものだ、ということであるが、これについては多くいう必要があるまい。",
              "citation": {
                "source": "歴史の学に於ける「人」の回復",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って又微々たる村の女性の一言一行までが、思いがけぬ大きな暗示にもなるのである。",
              "citation": {
                "source": "夢と文芸",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
