[
  {
    "uuid": "d6085d9c-46c8-5f43-8c6b-735d68a1c568",
    "entry": "行き過ぎ",
    "reading": {
      "primary": "いきすぎ",
      "alternatives": [
        "ゆきすぎ"
      ],
      "is_heteronym": false
    },
    "grammar": {
