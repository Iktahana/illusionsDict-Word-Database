[
  {
    "uuid": "89406e26-31d4-5caa-8c1f-af585056a405",
    "entry": "言いなりになる",
    "reading": {
      "primary": "いいなりになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
