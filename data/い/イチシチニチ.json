[
  {
    "uuid": "c7358dbe-babf-5966-b160-41b7eb7ad904",
    "entry": "一七日",
    "reading": {
      "primary": "いちしちにち",
      "alternatives": [
        "ひとなぬか",
        "ひとなのか",
        "いっしちにち"
      ],
