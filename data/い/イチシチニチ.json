    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seventh day after a person's death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故人の一七日の法要を営むため、親族が再び菩提寺に集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "葬儀の慌ただしさがようやく落ち着いた頃、早くも一七日の朝を迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仏教では、死後一七日ごとに審判が行われ、四十九日に来世の行き先が決まるとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「早いもので、今日でちょうど一七日ですね」と、弔問に訪れた僧侶が遺族に語りかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一七日の供養として、祭壇には故人が生前好んだ菓子と季節の花が供えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初七日にあたる一七日が明けると、遺族は少しずつ日常生活のペースを取り戻し始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かれはその日からすぐに祈祷をたのむことになったが、行者は一七日のあいだ日参しろと云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし其の一七日を過ぎても、かれの祈祷は終らなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "行者は更に一七日の参詣をつづけろというと、久次郎はやはりその指図にそむかなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "母のお豊はむしろ我が子をすすめて出してやるほどであったが、久次郎の参詣が初めの一七日が過ぎて更に二七日となり、又もや三七日となり、四七日とつづくようになったので、店の番頭どもは少し不安を感じて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来ならば一七日の祈祷で当然その禍いを祓い得べきであるのに、今度の祈祷に限って不思議にその験がみえない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡て一七日、術成ると稱し、出でて昌黎に對して、はじめて羞ぢたる色あり。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お沢　はい、（間）はい、あの、一七日の満願まで……この願を掛けますものは、唯｜一目、……一度でも、人の目に掛りますと、もうそれぎりに、願が叶わぬと申します。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八箇国を一月ばかりに切従へられて、七｜斛の芥子を一七日に焚いたなぞは、帯紐の緩み加減も随分｜太甚しい。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの……それでお医者様が手放したもんですから、照吉さんが一七日塩断して……最初からですもの、断つものも外に無いの。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの、そのね、谷中へ願掛けをした、満願、七日目よ、……一七日なんですもの。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折入ってお願いは、相叶うことならば、お台所の隅、お玄関の端になりとも、一七日、二七日、お差置きを願いたい。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は良人の容体の危篤に陥りしより、ほとんど一月ばかりの間帯を解きて寝しことあらず、分けてこのごろに到りては、一七日いまだかつて瞼を合さず、渠は茶を断ちて神に祈れり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『遺老説伝』に、尚金福王命国公懐機築建長堤以便往来懐機以海底已深無力可施恭備祭品祈天告神一七日間海水乾涸即国内人民婦女運来石塊云々とある記事や『那覇由来記』に、扨沖道を築ける事は、前代尚金福王の御時国公といふ人有り、人を利し世を治むる故に、斯名付、其比封王有唐家の勅使此首里往復の路不平なり。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人俄に改め一七日にして石を布山を平ぐ、云々。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一七日の後には、藻に頼もしい道連れができた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、藻が清水へ夜詣りにゆくことを一七日の後に初めて知って、彼はいつになく怨んで怒った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれから一七日の間、斎戒して妖邪の気を払わなければならないと思った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くその祈祷をはじめい」「では、一七日のあいだ身を浄めまして、加茂の河原に壇を築かせ、雨乞いの祈祷を試みまする」　玉藻が雨乞いの祈祷は関白家から触れ出された。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度其日が一七日と氣がつきましたから、平常嫌ひな代數と幾何の教科書を賣つて、三十錢許り貰ひました。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度其日が一七日と気がつきましたから、平常嫌ひな代数と幾何の教科書を売つて、三十銭許り貰ひました。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑の執行されたのはブルノが五二歳の春二月の一七日であった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三八年一一月一七日倉田百三　大正三年（一九一四）　　　退学直後　あなたはどんな正月をしましたか。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "seven days",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故人の四十九日法要までは、一七日ごとに供養を行うのが習わしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この薬は一七日服用を続けると効果が出始めると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "提出期限は本日より一七日以内とします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "入院から一七日が経ち、医師の許可を得て退院することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいシステムの導入まで、残された期間は一七日しかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "勅命が下されてより、一七日の間、民は静かにその知らせを待った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "種を蒔いてから一七日ほどで、ようやく小さな芽が出始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
    ],
