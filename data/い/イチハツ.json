          ],
          "literary": [
            {
              "text": "濕つた杉の根方には鳶尾の花が咲いてゐる。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡蝶花　しやが、鳶尾草は同じ類なり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合もいろいろあるなかに、鳶尾草のよけれども、あゝ、今は無し、しよんがいな。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶尾草の濃紫にほひすみれのしぼ鹿子、春山祇の來て遊ぶ泉のもとにつきぬれば胸もとゞろに、かの君を今こそ終に得てしかと思ふ心のそらだのめ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶尾草の花、清淨無垢の腕の上に透いて見える脈管の薄い水色、肌身の微笑、新しい大空の清らかさ、朝空のふと映つた細流。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "白百合、紅百合、鳶尾草の花、信頼心の足りない若いものたちよりも、おまへたちの方がわたしは好だ、滅んだ花よ、むかしの花よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鳶尾根末、亜鉛華、麝香草、羊脂、魚膠、雷丸油、疱瘡で死んだ嬰児の脳漿、それを練り合わせた塗抹剤……お着けすることに致しましょう」　髪を梳る音がした。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねぢあやめとも言ふ鳶尾草に似た馬藺を形つた金具のだしをつけたからの名であらう。",
              "citation": {
                "source": "まといの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも述べた通り、神事のさし物には、薄の外に荻・かりやすをも用ゐるから、植物学的の分類に疎かつた古人が、菰・菖蒲・鳶尾草などを同類と見て、戦場の笠じるし・さし物にも用ゐた名残りだといふ事も出来よう。",
              "citation": {
                "source": "まといの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "路並の茅葺屋根には、棟に鳶尾か菁莪らしいものが青々と茂って花が咲いていた。",
              "citation": {
                "source": "秩父のおもいで",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいくとこの文楽師匠は赤でなし、青でなし、巧緻に両者を混ぜ合わせた菖蒲、鳶尾草、杜若――クッキリと艶に美しい紫といえよう。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一方では藤の花房を立てたように薄紫の花をつけた桐の木、屋根の棟に菁莪や、鳶尾などの青々と繁っている茅葺の家、そことなく洩れ来る梭の音に交って、うら若い女の歌う声、路のへに飛び交う燕の群。",
              "citation": {
                "source": "秩父の渓谷美",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓家は恐ろしく大きな草｜葺きの屋根を持っていて、その脊梁には鳶尾に似た葉の植物が生えている。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある村の家は、一軒残らず屋根に茂った鳶尾草を生やしていた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根が並外れて高く、その平な屋梁には、一面に百合や、鳶尾や、その他の花が咲いていた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京附近では、青い鳶尾がこの装飾に好んで用いられるらしい。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶尾の葉はみなぬれにけり初しぐれ　　　　鼠弾「鳶尾」はシャガと読むのであろう。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏近くなって庭の古木は青葉を一せいにつけ、池を埋めた渚の残り石から、いちはつやつつじの花が虻を呼んでいる。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜の髭のなかのいちはつの花の紫が、夕風に揺れ、二人のいる近くに一本立っている太い棕梠の木の影が、草叢の上にだんだん斜にかかって来た。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉藏は、いちいちはつきり答へた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭にはかんかん陽があたって蝉の声の降るなかにいちはつがちらほら咲いていた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽はまぶしいほど山地に反射して、道端に咲くいちはつの花が鋭い白星のように見える。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀の力彌の肩衣はいちはつぐさか、――雨がへるぴよいと飛び出た宙がへり、青い捕手の幕切はええなんとせう、夜の雨に。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみなへし、へらしだ、われもかう、烏萩、こうや万年草、いちはつ、狐の行灯、烏瓜、ぶらぶら提灯花、孔雀歯朶、盗棒萩、犬虱、しほん、獅子舞ひ蓮華、猫柳……等々と、一見見渡したゞけで忽ち百種類も数へあげることが出来るのである。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隅に花壇があって、ゆすらうめ、鉄線蓮、おんじ、薊、ルピナス、躑躅、いちはつ、などのようなものが植えてあった。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まん中に噴水があって、そのまわりにいちはつがぎっしりと繁っておりました。",
              "citation": {
                "source": "トリスタン",
                "author": "TRISTAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの裏の白い「いちはつの花」が一輪今朝咲きました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
