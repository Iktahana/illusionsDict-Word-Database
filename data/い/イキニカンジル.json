    "definitions": [
      {
        "index": 1,
        "gloss": "to be positively affected by someone's strength of spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若手社員は、上司が困難なプロジェクトに昼夜を問わず奮闘する姿に、大いに意気に感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "逆境に立ち向かう彼の闘志あふれるプレーに、観客は皆、意気に感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "友人が「絶対に成功させる」と熱く語るのを聞き、私も思わず意気に感じてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "戦国時代の武将が、わずかな兵力で大軍に立ち向かった話に、多くの人々が意気に感じたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その先生の、専門分野への深い愛情と情熱のこもった講義に、学生たちは皆、意気に感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "権利擁護のために声を上げ続ける彼らの行動に、多くの市民が意気に感じ、支援の輪が広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
