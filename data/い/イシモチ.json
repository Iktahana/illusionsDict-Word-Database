[
  {
    "uuid": "86d67a6b-98d9-516a-a11d-db540065592c",
    "entry": "石持",
    "reading": {
      "primary": "いしもち",
      "alternatives": [
        "イシモチ"
      ],
      "is_heteronym": false
    },
    "grammar": {
