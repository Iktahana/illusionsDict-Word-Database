    },
    "definitions": [
      {
        "index": 1,
        "gloss": "great man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古の伝承には、その峠を一人で守り抜いたという偉丈夫の武士が登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "主人公は、堂々たる体躯と揺るぎない精神を持つ、まさに偉丈夫であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政界の偉丈夫と称された老政治家が、力強い演説を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いやあ、本当に偉丈夫だね、あの人。頼りになるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "広い肩幅と、断固たる眼差しは、まさに偉丈夫の面影を宿していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "度重なる困難に直面しても、彼はコミュニティの偉丈夫として毅然とした態度を保ち続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、幾多の困難を乗り越え、その重責を担う偉丈夫として人々の尊敬を集めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私が東京の大学へはいって、郷里の先輩に連れられ、赤坂の料亭に行った事があるけれども、その先輩は拳闘家で、中国、満洲を永い事わたり歩き、見るからに堂々たる偉丈夫、そうしてそのひとは、座敷に坐るなり料亭の女中さんに、「酒も飲むがね、酒と一緒にビイルを持って来てくれ。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やさ男どころか、或る神学者の説に依ると、筋骨たくましく堂々たる偉丈夫だったそうではないか。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の目に移つた人は骨格の逞しい偉丈夫である。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "且犁湖単于の弟だが、骨骼の逞しい巨眼赭髯の中年の偉丈夫である。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前なるは手に錫杖をついた一癖ありげな偉丈夫。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙信は、川中島の一騎討などから考えるとどんな偉丈夫かと思われるが、「輝虎、体短小にして左脛に気腫あり、攣筋なり」と云うから、小男で少しびっこと云うわけであるから、その烈々たる気魄が、短躯に溢れて、人を威圧した有様が想像される。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　六尺ちかい偉丈夫も、ほとんど泣かんばかりである。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲を思ひ切り短く刈り、脳天に一握り程の頭髪が残つてゐる刈り方だつたが、Ｂのやうな偉丈夫ならば、好もしかつたが、彼だと見るからに軽卒で、それを眺めた時には彼の細君は、思はず噴き出して、彼の気嫌を損ねたのであつた。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに奥の間へ案内されると、広い座敷のなかにはただひとつの榻を据えて、ひとりの偉丈夫が帽もかぶらず、靴も穿かずに、長い髪を垂れて休息していた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの無名の偉丈夫は、いわゆる剣侠のたぐいであることを、役人は初めてさとった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇ氏は私の想像を裏切つて、拳闘選手でゝもあるかのやうな素晴らしい偉丈夫であつた。",
              "citation": {
                "source": "交遊秘話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その多くは老人か、偉丈夫に化けて来るのであって、寧ろ男性的である。",
              "citation": {
                "source": "妖怪漫談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）馬車を駆つて消え去り、今度はモーゼのやうな姿の老偉丈夫が、また肩を叩いて、「フローレンスの学生！",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は背広、フロック、袴羽織思ひ／＼の服装で、誰が誰やら一寸は薩張り分らなかつたが、能く見ると其中に霜降の背広に黒の山高帽を冠り、鼻眼鏡をかけた英姿颯爽の一偉丈夫がある。",
              "citation": {
                "source": "旅日記",
                "author": "東海道線",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、間もなく彼は、そこの角で制服の偉丈夫に掴まってぺこぺこおじぎしている。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服の偉丈夫なら巡査にきまってるから――。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "座に入り来つたのは、洋服を著た偉丈夫である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天滿與力は町人から袖の下を取るのに妙を得てゐる形だけの偉丈夫であつた。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、呼び留めながら、駈けて來たのは、昨日多田院で見た天滿與力の、形だけは偉丈夫然とした何某であつた。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨にうたれた伸びほうだいの髪は、ものすごく顔にへばりつき、ひげは草むらのように乱生し、水玉がたれている、かたはば広く丈高い偉丈夫！",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラザルスがそばを通ると、誰もその顔を正視する者もなかったが、その重い足音がまったく聞こえなくなると、かれらは宮殿の奥深くへだんだんに消えてゆくやや前かがみの老偉丈夫のうしろ姿を穿索するように見送った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラザルス",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど人好きのするゆつたりした偉丈夫だ。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを交番へひきずりこんだのは喫茶店のマダムで、年は三十二だと云ったが、大柄で、骨が太く、顔にケンがあり、噛みつかれそうな偉丈夫だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "若党をかえりみて、「コレ、コレ、あれなる偉丈夫は何者であるか、きいてまいれ」「ハ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞きしにまさる偉丈夫。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてその郎等には、鬚長く怖ろしげなる蝦夷式偉丈夫をもって、「げに吉き兵かな」と思わしめたりしなり。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田幾之進は五十がらみの六尺豊かの偉丈夫。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "参事官が椅子につくかつかぬに、私から三人目に居た山田が、何か述立てようとすると、直後に見張って居た帝釈天の谷口が、後から肩口を握んで小突いた、すると壇上の椅子に居た次席の偉丈夫山本さんが突立上って、谷口を睨め底力のある声で叱り付けた。",
              "citation": {
                "source": "監獄部屋",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでベラールは、最盛時のナポレオンといった、堂々たる偉丈夫で、態度も如才なく、慇懃で、音楽も文学もよくわかる。",
              "citation": {
                "source": "悪の花束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉丈夫――それに、戦国の野武士のおもかげがあった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
