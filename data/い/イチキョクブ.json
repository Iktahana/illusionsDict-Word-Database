[
  {
    "uuid": "8e244d10-1389-56e8-9381-19c60be98478",
    "entry": "一局部",
    "reading": {
      "primary": "いちきょくぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
