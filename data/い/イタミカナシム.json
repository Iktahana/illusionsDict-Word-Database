        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "突然の訃報を受け、世界中のファンが偉大な音楽家の死を悼み悲しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事故現場には今も花が絶えず、犠牲者を悼み悲しむ人々の姿が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今はただ、故人の冥福を祈り、静かに悼み悲しむ時間を持ちたいと思います」と、遺族は沈痛な面持ちで語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦没者の追悼式典では、参列者全員が黙祷を捧げ、国のために散った尊い犠牲を悼み悲しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は長年連れ添った愛犬の死を、単なる動物としてではなく、一人の家族を失ったかのように深く悼み悲しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "震災から十年の節目を迎え、人々は失われた多くの命を改めて悼み悲しむとともに、復興への決意を新たにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "劇団の創設者の急逝は団員たちに大きな衝撃を与え、皆がその偉大な指導者を失ったことを悼み悲しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
