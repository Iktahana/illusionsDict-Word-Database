          ],
          "literary": [
            {
              "text": "十二月と二月の八日はそれぞれに事始事納の儀とあって、前夜から家々に笊目籠を竿の頭へ付け檐へ押し立てて、いとこ煮を食するのがそのころの習慣だった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって君、これは何という木かしらんが、栗の木じゃないぜ、途方もないとこに栗の実が落ちてちゃ、ばれるよ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、だんだんまた山が両方から逼って来て、肩に支えそうな狭いとこになった、すぐに上。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその雪と月のあかりで見るといちばん高いとこに小十郎の死骸が半分座ったようになって置かれていた。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船酔ひに青ざめた中学生はも少し大きな学校に居る兄やいとこに連れられてふらふら通り私が眼をとぢるときはにせもののピンクの通信が新らしく空から来る。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とし子が私を呼ぶといふことはない呼ぶ必要のないとこに居る。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって君、これは何といふ木かしらんが栗の木ぢゃないぜ、途方もないとこに栗の実が落ちてちゃ、ばれるよ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして、あんな高いとこにぶらさがって、光ってるんなら光っているがいい。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、今でこそ、こうやって寒いとこに、くさりでつながれているんだが、そんなことのなかった時のことだって、知ってるんだ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇子は、ようし、とおっしゃって、履仲天皇の皇子で、ちょうどおいとこにおあたりになる、忍歯王とおっしゃるお方とお二人で、すぐに近江へおくだりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も母も失って、伯父の家に引き取られ、わがままないとこに虐げられながら、彼女は孤独な寂しい日々を暮していたのだ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ、とれたか」「ええ、随分ありましたよ、うんとなってるね高いとこに……届かなかった僕あ」　一太は両手に懐の栗を出して見せた。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなたも」と、千代子は義雄を返り見たが、鋭いにらみを避けるやうにして、「こんなみすぼらしいとこにゐないだツていいでせう？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ、夜っぴて、爺さんと二人っきりでさ、火もないとこに無言の行だったからなあ」　ゴム靴の釦をはめている中尾の背へ、龍子は気弱く、「恩に着るわよ」と声をかけた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇麗な顔と奇麗な言葉と感じとを思ったワイルドもさみしいとこに死ななければならない運命をもって居た。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠洲からダアバンまでワラタ号に乗って来て、余り「頭が重く」て揺れの激しいとこに、不安を感じて旅程を変更し、ケエプ・タウン港まで行く筈だったのが、他の便船に依る心算で急にダアバン港でワラタを下りた客が一人あった。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、『きたないとこに置くなよ』と云つたさうである。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "八歳の昔なれば、母の姿貌ははっきりと覚えねど、始終｜笑を含みていられしことと、臨終のその前にわれを臥床に呼びて、やせ細りし手にわが小さき掌を握りしめ「浪や、母さんは遠いとこに行くからね、おとなしくして、おとうさまを大事にして、駒ちゃんをかあいがってやらなければなりませんよ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯ぎれのいいとこに色気がある。",
              "citation": {
                "source": "人生案内",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『僕のいとこに当る、或る王様が、金の林檎を三つ取って来いと僕に言いつけたんです、』と彼は答えました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "おツネさんとは私の母でお鉄おばさんのいとこにあたっていた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、一どわかれをつげて、つぎの朝、またいってみますと、壱岐は自分の家にやる手紙をだして、これをやしきへとどけてくれ、それからお父上にあったら、これこれつたえてくれといい、またべつに、諭吉のお母さんのいとこにあたる大橋六助という人にあてた手紙をとりだして、「これを大橋のところへもっていけ。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "諭吉のまたいとこに、増田宋太郎という青年がありました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "広島で寝ている未亡人の、またいとこに当る縁のため、早くから此処に住んで管理人になっているが、この家屋敷は何か複雑な関係で二重の抵当に入っていて、どこをどうにも動かせないため、仕事と言ってはほとんど無いらしい。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七「八、狼は飛んだ近いとこに居るよ」「何處です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "狼の牙",
                "note": "青空文庫"
              }
            },
            {
              "text": "カギ半の裏に……」　ふるい東海道に面し、海を見はらす小高いとこにあるカギ半は前崎の雑貨店で、炭や味噌醤油もあきなっていた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子のまたいとこにあたる津山進治郎は、ただ一人の医学博士であるというばかりでなく木曜会には何かの角度から発言権をもつ存在であることが感じられた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はずかしい話だが、わたしのいとこに卑劣漢がいる。",
              "citation": {
                "source": "青君の追跡",
                "author": "THE PURSUIT OF MR. BLUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「明日はもっと近いとこにせえへんか、久しぶりで宝塚はどやろ？",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいで夏過ぎてからも、大阪の家が近いとこにあったさかい常時｜孰方ぞから呼び出しては逢うてたら、或る時女学校時代のお友達から綿貫のことについて妙な噂あるのん聞いた。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
