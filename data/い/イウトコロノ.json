[
  {
    "uuid": "0155df39-67b6-52c5-a417-07b23e58f97f",
    "entry": "言うところの",
    "reading": {
      "primary": "いうところの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
