[
  {
    "uuid": "2f7dab06-8a3e-52ca-95c3-d9f708771670",
    "entry": "一滴",
    "reading": {
      "primary": "いってき",
      "alternatives": [
        "ひとしずく"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one drop (of fluid)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「砂漠で遭難した彼にとって、水一滴はダイヤモンドよりも価値のあるものだった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「隠し味として、最後に醤油を一滴垂らすだけで煮物の風味がぐっと引き立つ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼女の目から涙が一滴、静かに頬を伝って落ちるのを見て、彼はかける言葉を失った」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "コップに一杯の砂糖水をつくって、その上に小さな罎に入った茶褐色の薬液の一滴を垂らすと、それがぱっと拡がって水は乳色に変わった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、にはかに勢ひづいて、一滴のこさず飮みほして、ほろりと醉ひ、「や、月が出てゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨汁一滴を落したやうな感じだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでにその膏藥を一滴おれの手のひらに載せて見せてくれねえか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水が飲みたあい」　と、炎天の下で乾物になりさうな程も、焙られて怒鳴りながら駆けて、帰つた子供たちは、井戸に飛びついてポムプを押すのだが、井戸からは一滴の水も出ないのだ。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗濯などには一滴たりとも使へはしないし、顔だつて二ヶ月も洗つた事は無いのだ。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本新聞に墨汁一滴が出る様になってから猶一層である。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューインガムを噛む税関吏の顔は日本人から見れば俳諧があるかもしれないが税関吏の胸の中には一滴の俳諧もありそうもない。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧の滴の大きさは色々あるが、直径おおよそ一｜分の百分一くらいのもので一滴ごとに凝結の中心となるべき核をもっている。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の葉の水気が集つて一滴の露となり、腐れた酒の蒸気が冷たいランビキの玻璃に透明な酒精の雫を形づくる迄のそれ自身の洗練はかりそめのものではない。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕闇の風、軽ろく雨を吹けば一滴二滴、面を払うを三人は心地よげに受けてよもやまの話に入りぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところで天幕生活をしたらさぞ愉快であろうといったら、運転手が、しかし水が一滴もありませんという。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見ると一と息で登れそうな気がするが、上り口の立て札には頂上まで五時間を要し途中一滴の水もないと書いてある。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでかりに地球歴史のある一定の時期において、ある特別の地点において、特殊の国語が急に発生したと仮定すると、それはちょうど水中にアルコホルの一滴を投じたと同様に四方に向かって拡散を始めるであろうと仮想される。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすけた障子紙へ一滴の水をたらすとしみができるが、その輪郭は円にならなくて菊の花形になる。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木々の葉が夕立にでも洗われたあとであったか、一面に水を含み、そのしずくの一滴ごとに二階の燈火が映じていた。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、ある書物に引用された実例によると、ある医者は、街上でひかれた十歳になるわが子の瀕死の状態を見ても涙一滴こぼさず、応急の手当に全力を注いだ。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は泥にうつぶして、いまこそおいおい聲をたてて泣かう泣かうとあせつたけれど、あはれ、一滴の涙も出なかつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は泥にうつぶして、いまこそおいおい声をたてて泣こう泣こうとあせったけれど、あわれ、一滴の涙も出なかった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モトモトテニスらしいものが出来るのは、正直のところ一滴も酒の飲めない筆者の一組だけで、ほかは皆、支那の兵隊と一般、テニスなんてロクに見た事もない連中が吾も吾もと咽喉を鳴らして参加するのだから、鬼神壮烈に泣くと言おうか何と言おうか。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様は一滴も飲めないのだから選手たる資格はない。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この冬に肺を病んでから薬一滴飲むことすらできず、土方にせよ、立ちん坊にせよ、それを休めばすぐ食うことができないのであった。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その軽き一滴二滴に打たれて梢より落つる木の葉の風なきにひるがえるさまを青年は心ありげにながめたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』熱き涙一滴、青年が頬をつたいしも乙女は知らず。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "また思う、赤露のマルキシズムには一滴の俳諧もない。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の時代から一滴の酒も入れない家庭に育ちながら、そして母も自分も禁酒会の会員でありながら、他人の飲酒をいちがいに卑しむ心持は起らなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一滴落すにもこれ見よがしだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "指の間には紅一滴、見る見る長くなって、手首へ掛けて糸を引いて血が流れた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このために、炎天に一滴の汗も出なかつたのは、敢て歌の雨乞の奇特ではない。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不斷一滴も嗜まない、一軒となりの齒科の白井さんも、白い仕事着のまゝで傾けた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
