          "literary": [
            {
              "text": "その男が、いま演劇の世界に第一歩を踏み出すに当って、まずい答案を書いたなら、一生消えない汚点をしるす事になる。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このスパルタ式の訓練は彼の右の膝頭へ一生消えない傷痕を残した。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このスパルタ式の訓練は彼の性格へ一生消えない傷痕を殘した。",
              "citation": {
                "source": "芥川龍之介論",
                "author": "――藝術家としての彼を論ず――",
                "note": "青空文庫"
              }
            }
          ]
        }
