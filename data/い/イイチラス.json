        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "根も葉もない噂をあちこちで言い散らして回る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は不満を言い散らすだけ言い散らして、自分から解決策を探そうとはしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんな出鱈目を言い散らされては、こちらの面目が立たないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の非を認めず、周囲が悪いのだと言い散らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "酔った勢いで、実現不可能な大言壮語を居酒屋で言い散らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいつ、またどこかで適当なことを言い散らしてるんじゃないか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "嘘を言い散らして周囲を混乱させるのは、彼のいつもの手口だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "社内のあちこちで機密事項を言い散らすなんて、守秘義務の欠如も甚だしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また、勇気を得たのなんのと、その場かぎりの興奮から軽薄な大袈裟な事ばかりを言い散らす人は、昔から、なまけものの、お体裁屋にきまって居ります。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に、相手構わず「ファシスト」と言い散らす人々でさえも、この言葉になにがしかの情緒的重みを持たせている。",
              "citation": {
                "source": "ファシズムとは何か",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を浴びせるよ、寝呆けたことを言い散らすと」「だって、いるものは、仕方があンめい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
