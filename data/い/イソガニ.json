        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "潮だまりを覗き込むと、小さな磯蟹が慌てて岩陰に隠れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供たちはバケツを片手に、夢中になって磯蟹を捕まえている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "味噌汁の出汁に磯蟹を入れると、磯の香りが豊かな深い味わいになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "防波堤の隙間には、びっしりと磯蟹が張り付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「わ、見て！こんなに大きな磯蟹は初めて見たよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "磯蟹は、日本の岩礁海岸ではごく普通に見られるカニだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "釣りの餌にするため、足元で素早く動く磯蟹を捕まえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "そのとき患者は、窓のそとの石垣を傳つてあそんでゐるたくさんの小さい磯蟹を見て、きれいだなあ、と言つた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
