      {
        "index": 1,
        "gloss": "Asian shore crab (Hemigrapsus sanguineus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
