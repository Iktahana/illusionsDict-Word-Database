        "examples": {
          "standard": [
            {
              "text": "緊急出産で、赤ちゃんは一糸もまとわず、冷たい空気に晒された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "観客が見守る中、登場人物は一糸もまとわず、真実を語り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "嵐の中、彼は一糸もまとわず、助けを求めて叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さて、エビルはかすり傷だらけの身体に一糸もまとわず、髪の毛を剃られたサムソンの如くに悄然と、前を抑えながら家に戻った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一糸もまとわずはだかにし……」「はずかしめようとするのだな！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "側室が一糸もまとわず、髪も解いて寝所へはいるのは、凶器など持ちこむ危険を防ぐためだ、という通説がある。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
