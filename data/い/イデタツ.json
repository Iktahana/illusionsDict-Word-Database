          ],
          "literary": [
            {
              "text": "木魚の音のポン／＼たるを後に聞き朴歯の木履カラつかせて出で立つ。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日も、懐中も、切詰めた都合があるから、三日めの朝、旅籠屋を出で立つと、途中から、からりとした上天気。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ表通りをハッキリと、「歓呼の声に送られて　今ぞ出で立つ父母の国　勝たずば生きて還らじと」　若く太い合唱の声が空気を揺がせて過ぎる。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政枝の声は「――――　今ぞ出で立つ父母の国　勝たずば」――――微かに唄っているようだ……。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖アントニオと我馬との思召だにくるはずば、正三時には出で立つべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "大黒天は大国主命を仏化したという説は足利氏の代に既にあったので、『古事記』に大国主の兄弟八十神各｜稲羽の八上姫を婚せんと出で立つに、大国主に袋を負わせて従者として往った話あり。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から行けば、時も亦好きに非ずや』と、裸男知つた風の事云へば、なるほどと山神感服して、共に出で立つ。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜光命も、『我も』とて出で立つ。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "三本木へとて、出で立つ。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首は、今出で立つ汝等節度使の任は、まさに大丈夫の行くべき行旅である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻第十九　　　　　　　　　　　○春の苑くれなゐにほふ桃の花した照る道に出で立つ※嬬　〔巻十九・四一三九〕　大伴家持　大伴家持が、天平勝宝二年三月一日の暮に、春苑の桃李花を見て此歌を作った。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大君のしこのみ楯」と勇んで出で立つたわれわれの兄弟、夫、父、親、息子たちは、いづれも、昨日までは、われわれと共にあつて、野良に出で、算盤をはじき、事務所に通つてゐたのであります。",
              "citation": {
                "source": "優にやさしき心",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日よりは　かえり見なくて　　　大君の　醜の御楯と　　出で立つ　われらは◯暢彦が英に聞いている。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雲は、それを引纏うて身がまえをするのは、多分、これから茂太郎と兵部の娘の行方を探すべく、出で立つの用意と見えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸を出る時は、無論、道庵の慈姑頭で出て来たが、信州へ入ってから急に気が強くなって、武者修行に出で立つべく、総髪を撫下げにした間はまだよろしいが、松本へ来て、川中島の農民が、農は国の本なりと喝破したのに感激して、佐倉宗五郎もどきの農民に額を剃り下げてしまったのは、いまさら取返しのならない失策でした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉は、地下茎から出で立つ一本の長い茎の頂から一方は花穂となり、一方はこの葉となって出ていて長柄があり、それが三｜柄に分かれ、さらにそれが三｜小柄に分かれて各｜小柄ごとに緑色の一｜小葉片が着いている。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の扇屋熊谷で、幸四郎の熊谷が編笠深々と出で立つのを見ると、さすがにこの舞台姿は、そのいなりのままで既に獲易からざる眼福なることを思います。",
              "citation": {
                "source": "役者の顔",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "※今ぞ出で立つ父母の国　勝たずば生きて還らじと　誓う心の勇ましさ　或は草に伏し隠れ……　果てしなく軍歌は歌われていく。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くる朝つとめて駒ヶ岳へと出で立つ。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに幕下へ発向の触れをまわして、兵数も増して五千余騎となし、夜と共に出で立つ準備にとりかかった。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おたがい武門は、かく続々と前後して戦場に出で立つ折。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、それらの文学と深い関係のある、或る意味ではその先覚者と目される正岡子規の、日清戦争に従軍した際の句に、行かばわれ筆の花散る処までいくさかな、われもいでたつ花に剣秋風の韓山敵の影もなし　等があるばかりである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月の半ば過ぎ、花の盛りにはおくれたれど、雜沓せざるを、その代りの取柄にとて、萩の舍先生と共にいでたつ。",
              "citation": {
                "source": "小金井の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ軍にいでたつ人に贈つたかういふ種類の歌はもつとあるが、今は割愛することとする。",
              "citation": {
                "source": "愛國歌小觀",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し彼女は昔の彼女ならず、お金持の紳士となら三日でも一週間でも泊りに行くが、庄吉ときてはとてもバアでは飲む金がなくて、後輩お弟子とオデン屋でのむ、後輩お弟子にまだいくらか所持金のあるのを見とゞけると、あそこへ連れて行け、者共きたれ、といでたつ。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水はこんなにきれいでたつぷりしてゐるだらう。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し彼女は昔の彼女ならず、お金持の紳士となら三日でも一週間でも泊りに行くが、庄吉ときてはとてもバアでは飲む金がなくて、後輩お弟子とオデン屋でのむ、後輩お弟子にまだいくらか所持金のあるのを見とどけると、あそこへ連れて行け、者共きたれ、といでたつ。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "例のお神楽師にいでたつ一行のうちにも、然るべき音曲の堪能者が無いという限りはありますまい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○若い連中も次々いでたつてゆくことですが、これ等こそ、第一線のはな／″＼しい、それこそ決戦の庭に突進してゆくことでせう。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王にふんする鬼が、附近の女を奪って帰ると、それを、田村麿にいでたつものが、奪い返して大王の首を斬る、という幼稚｜古朴な仮装劇が、ある時代に、若いものの手で行われたことがあるという。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
