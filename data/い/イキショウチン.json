[
  {
    "uuid": "1b86b731-145f-5eba-be05-4ad65c20080b",
    "entry": "意気消沈",
    "reading": {
      "primary": "いきしょうちん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
