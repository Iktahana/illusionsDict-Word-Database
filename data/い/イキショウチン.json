      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "low spirits",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "決勝戦で惨敗を喫した選手たちは、試合後のロッカールームで意気消沈していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年温めてきた企画案を会議で一蹴され、彼はすっかり意気消沈してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "第一志望の大学に不合格となり、息子は数日間、意気消沈した様子で自室に引きこもっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "信頼していた部下の裏切りを知り、社長は意気消沈の体で深く肩を落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなに意気消沈しなさんな。一度の失敗で全てが終わるわけじゃない」と、先輩が優しく励ましてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "期待していたボーナスの額が予想を大幅に下回り、職場には意気消沈した空気が漂った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不慮の事故で愛犬を亡くした彼女は、それ以来、意気消沈して外出もままならない状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "連日の猛暑による農作物の壊滅的な被害を前に、農家の人々は意気消沈せざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこには、希望を持って階段を上る人の列と、意気消沈して降りてくる人の列、その二つの人の流れがあってねぇ、わしらは何とかして列に無理矢理割り込み、ついに事務所の中に入ったんです……」「それは何とも面白い経験をなされました。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く自ら筆を操る事が出来なくなってからの口授作にも少しも意気消沈した痕が見えないで相変らずの博引旁証をして気焔を揚げておる。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のことで、ほとんど意気消沈しておりましたのが、この仕事で大いに勇気附けられ、また紛れました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "栃の木で老猿を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼を、致命的な意気消沈から救うのは、僅に一つの反抗心があるばかりであった。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、この二三月はそんなに目立つ程ではないが、何となく意気消沈したような所があり、鳥渡した物音にもギクッとしたり、講義中に詰らない間違いをしたり、いつも進んでする手術を、態と若い助教授に譲ったり、些細な事ながら、少し平素と変った所があったのだ。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は意気消沈したが、世の中は北原ばかりぢやない。",
              "citation": {
                "source": "新作いろは加留多",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種意気消沈してしまう。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山の前と違って、いささか意気消沈の気味だが、早く村に出て、ビールでもチトローネンワッサーでも、一杯飲みたいと、此時は、そればかりが望みだった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "不機嫌そうに顔をしかめて、意気消沈したもののようである。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよみんな意気消沈した。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反し敗れた鶏は意気消沈して、一時に肉が落ち味も劣ってしまう。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金はなし、女房に寝込まれ、私は意気消沈、地道いっぽうの仕事にもあき、まぐさ屋もわずか数ヵ月で廃業である。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、渾身の案が、――鉄輪の空に秘宝館を再現するという会心のアイディアが、場に大笑いをもたらしたものの、誰からも真剣に取り合ってもらえなかったことですっかり意気消沈して以来、自ら湯けむりの像を考えるのはやめ、人の案に口を出すだけになってしまった。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに、いつも懐中にいた美しい鳥の甘く優しい歌がなければ、失意の詩人は意気消沈してしまったに違いないでしょう。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのひどい意気消沈の合い間合い間には、子供らしい嘲笑的な快活さが起こってきた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは意気消沈して病床に伏せている。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして、大物の予想屋は意気消沈。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "底値になればマナーはそのころ意気消沈しているから、介入して安値で買い戻す。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "その信頼を冒涜したのは、あんたの良心だ」　トリガーセンが意気消沈して暖炉に腰をかがめた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人は歩いて帰ろうかとも考えたが意気消沈していたのであまり体を動かす気力もなく、紀伊国屋の階段を降りて地下鉄に乗り、軽い頭痛を自覚しながら体調が不振なのは風邪でもこじらせたのだろうかといぶかった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "無節操、優柔不断、不健全な活気の気まぐれな噴出に続く臆病な意気消沈、利己的な残虐性、および犯罪的な弱さ、はマケドニアとの戦いからローマ軍による最終的な征服までのギリシアの公的生活の特徴である。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は意気消沈したときには彼のことを考え彼の精神から勇気を得た。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすべてが懶く、熱に浮かされ、乱れた悲しい目つきを暗夜のうちに据え、宴楽の帰りのにぎやかな連中を乗せてそばを通りすぎてゆく楽しい馬車の響きとほこりとに脅かされ、意気消沈して、頭をはっきりさせるために途上の胡桃の木立ちのかおりを胸深く吸い込みながら、家に帰っていった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦二年目の八月といえば、日本カイビャク以来これほど意気消沈していたことは例がない。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "心細そうなというのは、私の佗しい心からの感じかもしれないが、案外それは、いつか見た、小さな犬をおどかしていた憎ったらしい大きな犬が何かそこにいわれがあって、すっかり意気消沈して心細い声を挙げているのかもしれないぞと私は思ったりして、そう思うと佗しい心も慰められたりした。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、――私の意気消沈も、朝野のこの一撃でついに底をついた感じで、逆に不思議な元気が出てきた。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はとても悲しく意気消沈した思いのまま服装を整えに行った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは言え、痛ましいぐらい哀れに、ニタは意気消沈し、笑いにも憂鬱な陰があった。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
