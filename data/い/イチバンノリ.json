          ],
          "literary": [
            {
              "text": "元康の士｜筧正則等が之に乗じて進み、門を閉ざす暇を与えずに渡り合い、松平義忠の士、左右田正綱一番乗りをし、ついに火を放って焼くことが出来た。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後森部の戦に一番乗りして、始めて許されたと云う。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "行長と清正とが一番乗りを争って、清正が勝ったと云う話は伝説である。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番乗りの火がかりは、水はなし、続く者なし、火の玉は突立ったり、この時、戸が開いたのと、人あおりで、それまで、火で描いた遠見の山のようだった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先手の者が馳せ帰って、「青木新兵衛大坂城の一番乗り仕って候」と注進に及ぶと、忠直卿は相好を崩されながら、「新兵衛の武功第一じゃ――五千石の加増じゃと早々伝えよ」と、勇み立とうとする乗馬を、乗り静めながら狂気のごとくに叫んだ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄手をあれほどに駆け悩ました左衛門尉の首を挙ぐるさえあるに、諸家の軍勢に先だって一番乗りの大功をわが軍中に収むるとは、何という光栄であろうと、忠直卿は思った。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ド、ド、ドウ、　ハイヨウ、　ド、ド、ドウ、　と乱れ太鼓のとどろく間を、三騎、五騎とうしろに引き離して、胸にくっきりと真紅の胴が、浮きつ沈みつしぶきの中をかいくぐっていったかと思うまもなく、平七の葦毛は、ぶるぶると鬣の雫を切り乍ら、一番乗りの歓呼の土手へ、おどるように駈けあがった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前代未聞のこの怪事件を最初に発見し、そしてその現場に一番乗りをした上に、全世界の報道網に対し輝かしき第一報を打つことに成功したデンマーク新報のアイスランド支局員ハリ・ドレゴの命名によるものであった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "到着　ドレゴと水戸が、やっぱり一番乗りだった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番乗りはしたけれど……」　とドレゴは口惜しそうな声を出した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからというもの水胆があるという事は私の得意で、未知の淵や、急流などへ一番乗りをしたものだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄三郎の父は庄八郎と云って惣蔵のすぐの弟であったが、武勇にかけては一族の中でも並ぶもののない武士であって、有名な海口の戦では一番乗りをしたほどである。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それこそ本当に遠い昔、彼がわずか十九歳の頃、晴信を進めて高遠城を攻め、一番乗りをした時のことを、フッと意識へ上せたのであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、大いにやろうぜ」「ああ、やるとも、やるとも、地球人類の名誉にかけて、このことは成功させてみせる」「火星へ一番乗りができたら、僕は火星の上で土になっても悔いないぞ」　乗組員たちは永年火星探険に強い憧れをもち今日まで苦労を積んできた人ばかり、デニー老博士に応えて協力を誓った。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところは大東京で一番乗り降りの客の多いといわれる新宿駅の、品川方面ゆきの六番線プラットホームで、一つの事件が発生した。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ一番乗りの特種を下さい！",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く戦国時代の一番乗り気分と少しも違わぬのである。",
              "citation": {
                "source": "聴衆０の講演会",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一番乗りをするつもりらしい。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "われこそ一番乗りと先がけを狙う者は多かろう。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊谷父子が一番乗りであったが、城の木戸口が開かぬので駆け入れなかった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その徐州兵長――高田という人でしたけど、徐州一番乗りばっかりいうもんで、みんなそういっていました――殺してやろうと思ったことがあります。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "師親は相模国毛利庄の宮崎八幡宮を信仰していたので、「さだめし八幡宮の奇瑞ならんと石をふところに入れ、江の川を一番乗りに打ち渡り」抜群の軍功をたてて安芸国吉田庄に三千貫の知行をえた。",
              "citation": {
                "source": "広島という名の由来",
                "author": "薄田太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝は、一番乗りと暗いうちから手あぶりをさげて氷の上へ行く。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度もし戦争があったら、伝九郎は退却の一番乗りをやるぞ」「なあに敵の足をなめて降参するさ」「どっちにしても腰ぬけの見本ができよう」　と勝手ほうだいにののしりたてた。",
              "citation": {
                "source": "だんまり伝九",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右左にはずらりとおもだった家臣がいならんで、功名帳を書きあげられた順に、なに城の一番乗りはだれだれ、かれ城の一番槍はだれだれ、兜首何級はだれだれ――と、手柄によって、あるいは食禄を増されるもの、あるいは賞与の品をもらうものなどがある。",
              "citation": {
                "source": "だんまり伝九",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……かれは多田淡路守の二男で名を新蔵といい、二十五歳になる今日まで前後七たびも合戦に出ているが、一番乗り一番槍の功名はさて措いて、まだ兜首ひとつの手柄もたてていない。",
              "citation": {
                "source": "石ころ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦左、鳶の巣山の一番乗りのところ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしッ、いちばんのりは、井上君だ。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
