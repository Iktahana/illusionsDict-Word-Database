    "definitions": [
      {
        "index": 1,
        "gloss": "Asian house martin (Delichon dasypus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ね、あすこにはやぶうぐいすや岩燕やいろいろ居るんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧見臺に立つて見ると、昨夜の幽味は少しも無くて瀧は明らかに見え、無數の岩燕が瀧飛沫の煙の中を、朝の日の光を負ひながら翼も輕げに快く入亂れて上下左右してゐる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其のほか鴨や、山鳥や、シギや、岩燕や、鴎や、あらゆる鳥達が、小川の岸に集つて、口の周囲を染めたり、羽を洗つたり、白粉をつけたり、紅をつけたり、手をそめたり、熱心に化粧をしてゐるのですから、その賑やかなことといつたら、ちやうど海水浴場へ行つたやうな賑やかさでした。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀑の左に直立せる絶壁の面に穴多く、岩燕出入して、虹の中に舞えり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常の燕ならで、岩燕軒端に土巣を構ふること數十百の多きに及ぶ。",
              "citation": {
                "source": "阿武隈川水源の仙境",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い洞窟の内部は岩燕の巣食ふところとかで、無數の翼が兩岸の岩をかすめて飛んだ。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど一羽の若い岩燕がその洞窟にある巣から離れて、私達の歩きりすることも出來た。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチパチパチパチパチパチと、岩燕が群をなして颯と頭上を翔け過ぎた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、河原の崖の周囲を、無数の岩燕が飛び翔っていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々彼が谷川の石の上に、水を掠めて去来する岩燕を眺めていると、あるいは山峡の辛夷の下に、蜜に酔って飛びも出来ない虻の羽音を聞いていると、何とも云いようのない寂しさが突然彼を襲う事があった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に上層は幾百羽となく岩燕の大群が巣を作つて、その周囲に飛翔してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "数十羽群れた岩燕であった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩燕が滝壺を巡って啼き、黄色い苔の花が咲いていた。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが頭をすれすれに、岩燕がヒューとばかり鋭い翼の音をたてて、一羽は一羽の後を追いながら、大円を画いてかけて行く。",
              "citation": {
                "source": "山と雪の日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "その燕がたちまち小さく、小さくなって花崗岩の中腹ぐらいに行ったと思うと、そこに胡麻をまいたように群がった岩燕の群の中に消える。",
              "citation": {
                "source": "山と雪の日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年ばかり前の夏、巣から落ちた岩燕の雛を巣へかえしてやるために截り立った崖を登ってゆく途中、足を踏みはずして崖の下へ転げおち、海岸の流木にしたたか腰を打ち、それ以来こんなみっともない歩き方をしなくてはならないようになった。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも一ヶ所雪倉岳への登りに、赤石岳の南側のように巨岩の累積したキレト状の場所があって、岩壁には無数の岩燕が群れていた。",
              "citation": {
                "source": "北岳と朝日岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪や羚羊も恐れて近かねば、岩燕や雷鳥でも躊躇するだろう、何だか形容のしようもない。",
              "citation": {
                "source": "穂高岳槍ヶ岳縦走記",
                "author": "鵜殿正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩燕が鏑矢のような音たてて翔び交う。",
              "citation": {
                "source": "案内人風景",
                "author": "百瀬慎太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、四十羽と群なす岩燕は、この巌の大伽藍を守護する小さな精霊たちのように、見なれない自分たちを巡って目前の空中を飛び交う。",
              "citation": {
                "source": "一ノ倉沢正面の登攀",
                "author": "小川登喜男",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰を渡る風でもないし、岩燕の声でもなし、およそ私がそれまでに聞いたどんな音よりも可憐でもあり微妙でもある。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩燕は邸のありとあらゆる小壁や軒蛇腹に巣をかけている。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝や谷川にはつき物のような、岩燕は空に舞っているし、鶺鴒は岩の上を飛んでいるし、五位鷺は岸の蘆の中に、片足でいかめしく立っていて、カラリと晴れた今日の風景は、美しく清らかで幸福そうであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩燕が群をなして谷風に舞い※る木の葉のように飛んでいる。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は何時の間にかすっかり曇って、薄紫の霧が小窓の方からのろのろ匐い下りて来る、其中を縫って高く飛鳴する岩燕の姿が影絵の如く消えたり顕れたりする。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀、岩燕、山雀、かわら鶸などが、入り交り、立ち交り、彼を悩ます。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風にして、明けがたから日暮れ時まで、まるで悪態をつくように、かわら鶸、山雀、岩燕、雀などが、その老いぼれの胡桃の樹を目がけて、若樹のなかから飛び出して行く。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩燕　その日の夕方は、魚がいっこうかからなかった。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが釣竿を垂れていると、一羽の岩燕がその上に止まった。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬でも、この岩穴の中に越年する、いわつばめがすんでいました。",
              "citation": {
                "source": "しんぱくの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
