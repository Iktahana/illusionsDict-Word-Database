          ],
          "literary": [
            {
              "text": "いい事だか、悪い事だか、私にもわからない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでも、いい事ではないか。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言はなくたつていい事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、また、言はなくてもいい事を呟いてみる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だつて、あなたは、何もいい事をしてやしないんだもの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の恋人は、どんな処に埋められても、その処々によってきっといい事をします。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい事をしたよ」　彼等は、朝の潮に洗われた空気に相応しく快活に笑った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいい事だか悪い事だか見当が付かないが、ともかくもどうする事も出来ない事実である。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と其の男、Ｔ「その又、仲蔵の　男ッ振りのいい事ッたら」　と馬鹿に賞めて居るのを、　窓の中で、嘉助老人嬉しそうに聞いて居た。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい事、聞いて　来ました」　と五郎蔵の傍へ寄ってポシャポシャ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の傾向を徹底させて行くとつまりは何もかいてないカンバスの面がいちばんいい事になりはしないか。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような例を挙げると、年中怠けてばかりいる学生が、一年に一日「勉強デー」を設けるのや、あるいは平生悪い事ばかりしている男が、稀に「善行デー」を設けるのと同じような事で、それも一応は誠にいい事だと思われる。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ニイチェもいい事を言います。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、先輩はいい事を知らせてくれた。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは、まあ、無論そういうものでしょうが、僕はね、これはね、いい事だと思うんです。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、いい事をしたいんです。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども苦しい間は人をたのんで楽になると人をそねむのはぜんたいいい事なんでしょうか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは犬の年の子供がした、いい事と悪い事を集めたものさ」「ヘー。",
              "citation": {
                "source": "犬のいたずら",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを説明してもらいさえすれば、もう決して笑わなくてもいい事になるのであった。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんごをかじりながら街頭をあるくよりも、環視の中でメリーゴーラウンドに乗るよりもむしろいい事かもしれないのに、何かしらそれを引き止める心理作用があって私の勇気を沮喪させるのであった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた黒板に文字や絵をかいたりして説明する必要のある講義でも、もし蓄音機と活動写真との連結が早晩もう少し完成すれば、それで代理をさせれば教師は宅で寝ているかあるいは研究室で勉強していてもいい事になりはしまいか、それでも結構なようでもあるがまたそうではなさそうでもある。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪は頭のいい事にあった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある先生などは特に彼の頭のいい事を確かに認めていたらしい。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は現代のあらゆる忙しい人たち、一日も新聞を欠かし得ないような人たちが、試みに寸暇をさいてこういう思考実験をやってみるという事は、そういう人たちにとって非常にいい事でありはしないか、また多数の人がそれを試みる事によって前に言ったような新聞の悪い影響がいくぶんでも薄められはしないだろうかと思ってみた。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子も燕もはるかにこれを見て、今日も一ついい事をしたと清い心をもって夜のねむりにつきました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジャンとピエールとは初めの間は市場などに行って、あわれな声を出して自分のかたわを売りものにして一銭二銭の合力を願っていましたが、人々があわれがって親切をするのをいい事にしてだんだん増長しました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫のいい事をいうにしても大概にしておくがいい。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いい事がある。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前髪にささって、その、容子のいい事と言ったら。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいいことであるかどうかは、間もなく分るであらう。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
