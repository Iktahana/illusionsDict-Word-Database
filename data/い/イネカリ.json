    "definitions": [
      {
        "index": 1,
        "gloss": "rice reaping",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末は家族総出で稲刈りを行い、心地よい汗を流した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おじいちゃん、コンバインの運転交代するよ。稲刈りもあと少しで終わりだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "稲刈り機が入らない田んぼの隅は、今でも鎌を使って手作業で刈り取っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "稲刈りが終わった後の田んぼには、どこか寂しげな秋の気配が漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、丁度稲刈りの最中だった。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の稲刈りでは、女たちにまでいじめられて、さんざん苦しんだためからだのきかなくなるほどくたぶれてしまった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の稲刈りで、よし田ん中へ這ったって、苦しいのなんのというもんかと力んで見る。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の稲刈りなどは随分みじめなものであった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよさんやおはまや、晴ればれと元気のよい、毛の先ほども憎気のない人たちと打ち興じて今日も稲刈りかということが、何となしうれしく楽しくなってきた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まアきれいな稲刈りだこととほめるものもあれば、いやにつくってるなアとあざけるものもある。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作はもとから話下手ときてるから、半日並んで仕事をしていてもろくに口もきかないという調子で、今日の稲刈りはたいへんにぎやかであろうと思った反対にすこぶる振るわないのだ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来はこの秋二軒が稲刈りをお互いにしたというも既におとよさんの省作いとしからわいた画策なのだ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう考えて見るとただおとよさんが目的を達したばかりで、今日の稲刈りには何の統一もなかった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲刈りは稲さえ思うだけ刈り上げさえすればよいわけだが、仕事の興味という点からいうと、二軒いっしょになって刈るというところに仕事以外の興味がなければならないのに、今度の稲刈りはどうもそれが欠けておった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "多勢でしたらおもしろかろうと思って二軒いっしょにお互いこの稲刈りをしたのだが、なんだかみんなの心がてんでん向き向きのようで、格別おもしろくなかった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この稲刈りにはおとよさんがいなかったらかえってほかの者らには統一ができたのだ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲刈りから見れば休んでるようなものだ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨日の稲刈りはにぎやかでしたねい。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "満蔵はとんだことを言い出して困ったと思うような顔つきで、「昨日の稲刈りでおとよさアは、ないしょで省作さアのスガイ一｜把すけた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらおとよさんはおれがあんまり稲刈りが弱いから、ないしょで助けてくれたには相違ないけど、そりゃおとよさんの親切だよ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよさんがおれに親切なは今度の稲刈りの時ばかりでない。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそうこの前の稲刈りの時にもおれが鎌で手を切ったら、おとよさんは自分のかぶっていた手ぬぐいを惜しげもなく裂いて結わいてくれた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木犀に萩にすすきに葛、いろいろの花が咲き出しました」「いろいろの花が咲き出しました」「霧にとんぼに稲刈りに、面白い時令となりました」「面白い時令となりました」「二百十日に二百二十日、白露に彼岸の秋分に、不動様のお開帳も近づきました」「みんなみんな結構で」「ホ、ホ、ホ、ホ、おかしなお方！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるでこれや稲刈りだな。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲刈りが始まったので、村の農家から狙われていた別家久左衛門の米倉も、ようやく視線を解かれた形だが、ほっとする暇もなく、今度は野菜専門に作っていた遠方の村の親戚から狙われ出した。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月――日　稲刈りがすすんでいる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "来じとすらしも（万葉巻十）後の歌などは殊に、約束の秋即稲刈りの時節が過ぎたのに、と言ふ風に見えるが、実は「時」を起すだけなのは極端である。",
              "citation": {
                "source": "日本文章の発想法の起り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "里の人々は『越後山に雪が降ったから、そろそろ稲刈りがはじまるだんべ』というのだ。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "由次は十六だが、昨年の稲刈り時分から眼に見えて背丈が伸び、いまでは親父の肩の辺まで届きそうになっていた。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲刈りてにぶくなりたる螽かな　　　　子規　子規はよく稲の中道を散歩して螽を研究したことがあった。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供等も重荷を負ふて秋の雨籬の豆赤さ走りぬいざ摘まん稲刈りて残る案山子や棒の尖十月五日　小諸俳人小会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲刈りの人も見えなくなって霧がそのまま闇になってゆく。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは稲刈りの時期のことであるが、菊千代がかれらの田の近くを歩いていたとき、竹次といくとが激しくいい諍っているのを見た……菊千代は独りで、森から丘へぬけて、知らない山道を下りて来ると、偶然かれらの田の脇へ出たのである。",
              "citation": {
                "source": "菊千代抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
