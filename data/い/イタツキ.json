    "definitions": [
      {
        "index": 1,
        "gloss": "being on stage when the curtain opens",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若手俳優が初めて大舞台で板付きを経験し、緊張で体が震えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の役は板付きから始まり、観客の注目を一瞬で集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "演出家は、役者が板付きの際にどのように感情を表現するかを細かく指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "板付きの場面は、舞台全体の雰囲気を決定づける重要な要素だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今回の主役は板付きだから、登場の仕方が重要だよ」と監督が念を押した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は板付きで現れるやいなや、その存在感で舞台を支配した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "板付きが多い役は、役者にとって事前の集中力と精神力が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二　台所見物に行った賢夫人と千々子さまが、電気レンジがどうの、オーヴンがどうのといいながら上段ノ間へ帰ってくると、そのあとから、画板付きの大きなスクリプトを、紐で首から吊るした、さっきの調査班の若いひとが入ってきた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハックネス先生が二重反射板付きの奇妙な電球をポケットから取り出し、こう言った。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔土をも掘らん汗もせん〕宮沢賢治土をも掘らん汗もせんまれには時に食まざらんさあれわれらはわれらなりながともがらといと遠しにくみいかりしこのことばいくそたびきゝいまもきゝやがてはさのみたゞさのみわが生き得んとうしなへるこゝろとくらきいたつきのさなかにわれもうなづきなんや",
              "citation": {
                "source": "〔土をも掘らん汗もせん〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はたらきまたはいたつきて、　　もろ手ほてりに耐へざるは、おほかた黒の硅板岩礫を、　　　にぎりてこそはまどろみき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔日本球根商会が〕日本球根商会が、　　　　　　　よきものなりと販りこせば、いたつきびとは窓ごとに、　　　春きたらばとねがひけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女餓鬼の官女のような母親はそこで食味に執しながら、一人息子が何でもよいたつきの業を得て帰って来るのを待っている。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此れだんべ爺、蕎麥つ粉へえつてたのな、俺らどうしたんだか知んねえから桶ん中さ明けて置いたつきや、そんぢや爺がんだつけなあそら、どうして袋さなんぞ入えてたんでえ爺は」おつぎは事もなげにいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉はいたつきを垣衣、弟は我が名を萱草じゃ。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁に倚りゐて傍を見れば、森の祖母君宵よりのいたつきにや疲れ給ひけむ、かかる騒がしき中にして、ゐながらに眠りて、物も知らでぞおはする。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年か昔、ここへステーションが出来るというので、何か一つ新しいたつきをと求めて集った家々である。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にこの茂子の発狂と小妻の死に次いでじきに、新聞紙によって重きいたつきを伝えられていた明治天皇の崩御がなかったなら、春風楼の人々は「呪われて」おかしなものになったかも知れない。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州の田植ゑ人に歌謡を与へたのは、平家物語を初めて弾いた生仏と言ふ盲人だと言ふのが、「菅菰抄」以来の説ですが、其菅菰抄には、今一説あつて、某大寺の住僧が、奥の人々のあぢきないたつきを憐んで田植ゑに唄を与へたのだといふ伝へもあつたやうです。",
              "citation": {
                "source": "東北民謡の旅から",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんが、『いたつきの床に臥している童子フョードルの本復』を祈願に、晩祷に出かけたり、聖パンを頂きに早朝のミサに出かけたりするたびに、カテリーナ・リヴォーヴナは病床に附添って、のどが渇くといえば水を飲ませる、時間どおりに薬をあたえる、という甲斐甲斐しさだった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "老先生は長のいたつき、後妻のお蓮さまという大年増が、師範代｜峰丹波とぐるになって、今いい気に品川まで乗りこんできている源三郎を、なんとかしてしりぞけ、道場をぶんどろうと企んでいるのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心配の積り積りて、軽からぬ御いたつき。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな病氣か知りませんが、ほとんど癈人と言つてよく、床に就いたつきりで、何を訊ねても、はつきりした答はありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "處女神聖",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんなにお身體が不自由なのに、腹卷だけは自分で締め直し、決して私共に背中を見せなかつたことです」「湯に入るときはどうする」「行水をお使ひになりましたが、その時でも腹卷は卷いたつきりで、身體を拭いてから、新しい腹卷と、自分で取替へられました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "系圖の刺青",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけを聽かうか、お孃さん」「――」　女は俯向いたつきり、物を言はうともしません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一應疑つて見たが、困つたことにあの増屋の房太郎といふ伜は、お菊が死んでからがつかりして床に就いたつきりだよ」　伊太松は平次の疑ひの先をくゞつて、早くもそこまで手を廻してゐたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "艶妻傳",
                "note": "青空文庫"
              }
            },
            {
              "text": "――合歓木をお植えなされ候ことわが身のいのちを覚えそろ、御いたつきの趣き承まわり及び候より、夜々、合歓木の樹蔭にて御平癒を祈りまいらせそろ、おはこびある折のありや否やは知らず、せめて祈りの夜々のみは赦したまわり候え。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひかり」というのは赫奕たる牡丹の形容で、同じく子規居士に「一輪の牡丹かゞやく病間かな」という句があり、また「いたつきに病みふせるわが枕辺に牡丹の花のい照りかゞやく」「くれなゐの光をはなつから草の牡丹の花は花のおほぎみ」などという歌もある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では……そなたは、お父君のおいたつきが癒るようにと、その小さい手で、御仏の像を作っていたのですか。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御所の門廊をふかく進んで、「聖光院｜門跡範宴少僧都、師の僧正のいたつきのため、召しを拝して、代りにまかり出でました」　取次の上達部は、「お待ち候え」と、殿上へかくれた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "wooden floor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
