[
  {
    "uuid": "9252e72a-fbee-52dc-858e-22d9423ccee8",
    "entry": "移住者",
    "reading": {
      "primary": "いじゅうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
