    "definitions": [
      {
        "index": 1,
        "gloss": "emigrant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい在留資格の創設により、高度な専門技術を持つ移住者が増加傾向にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "貧しい生活から抜け出すため、多くの人々が新たな土地へ移住者として渡った時代があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地域社会に溶け込むため、移住者向けの日本語教室が毎週開催されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この国際都市では、様々な国の移住者が独自の文化を持ち込み、多様性に富んだコミュニティを形成している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "慣れない環境での生活は、移住者にとって精神的にも肉体的にも大きな負担となることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「息子が海外で移住者として頑張っているんですよ。時々寂しくなりますけど、応援しています。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "移住者という題なのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした悲しい移住者は、思ひきりよく故郷と縁を絶つては來たものの、一足都會の土を踏むともう直ぐその古びた、然しながら安らかであつた親讓りの家を思ひ出さずにはゐられない。",
              "citation": {
                "source": "田園の思慕",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて更にその子、即ち悲しき移住者の第三代目になると、状態は餘程違つて來る。",
              "citation": {
                "source": "田園の思慕",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私も亦「悲しき移住者」の一人である。",
              "citation": {
                "source": "田園の思慕",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一囘の移住者等が國を船出する時は三百戸ばかりであつたが、紀州の熊野沖で難船し、百五十戸分の溺死者を生じた爲め、半數だけ（それが現今では僅かに三十戸）が北海道開拓の祖である。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地に散在している移住者の、木造の小屋からは、皆一様に夜業の淡い灯火の余光が洩れていた。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始林を背景にして散在した移住者の小屋から、事務所はやや離れたところにあった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　移住者の小屋から炬火が出て来た。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二ニ白人ノ新移住者印度人支那人ノ移住者ガ取得スル所ヲ、已ニ早ク日本國民タリシ彼等ニ拒絶スベキ理由ナキヲ以テナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の初年に横浜へ移住奨励のため、政府が移住者に土地を与へた事がある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこの頃には、どこの開墾村でも初代の移住者たちは年をとって、二代目が中堅となっており、村役場の三層楼も年とともに古びて来た。",
              "citation": {
                "source": "村の三代",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾百人かのそれらの移住者の中には「どてら」に脚絆麻裏穿きという風俗のものがあり、手鍋を提げたものがあり、若い労働者の細君らしい人達まで幾人となくその中に混っていたことを思出した。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはかうである――マオカへ初めて來た移住者等のうち、越年の用意に氣が附かなかつた爲め、海がいよ／＼結氷するに至つてから、あちらにもこちらにも餓ゑを叫ぶものが出來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一囘の移住者等が國を船出する時は三百戸ばかりあつたが、紀州の熊野沖で難船し、百五十戸分の溺死者を生じた爲め、半數だけ（それが、現今では、僅かに三十戸）が北海道開拓の祖である。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し私達のやうな市内からの移住者は一人もゐない。",
              "citation": {
                "source": "月二夜",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の初年に横浜へ移住奨励のため、政府が移住者に土地を与えた事がある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "移住者達は三万七千の霊を怖れ、その原形をくづすことを慎んだのかも知れぬ。",
              "citation": {
                "source": "島原の乱雑記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内の政治は必然的に移住者たる勤人階級の参加を拒み、局地的な施設は主として金利生活者の選択に委ねられ、祝祭の行事は最も文化的教養の低い階級によつて多くはリードされつゝあるのである。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新開地の文化は、移住者の間を潜つて、歴史的逆転をなしつゝある。",
              "citation": {
                "source": "移転記録",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なによりも、私は、彼女が両親と共に山陰の田舎町から東京に出て来て、見知らぬ周囲のなかで、さゝやかな移住者の生活をしてゐたといふところに大きな原因があると思ふ。",
              "citation": {
                "source": "妻の日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮、北海道の移住者も殆んど無い。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅僧に限らず村の知識階級は概して移住者でありすべて好色のために悪評であつた。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識階級の移住者には小学校の先生があるが、この人達も評判がわるい。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一まとめに何千人というのはないが少数ずつ次々とあって、コマの移住者の比ではないようだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山に住む人々の三　警察と鉄道に従事する人達は他郷からの移住者が多い。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路の側に立っているポイント・メンこそはこの山の上で寂しい生活を送る移住者の姿であろう。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "年も万延元年と改まるころには、日に日に横浜への移住者がふえた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "野毛町、戸部町なぞの埋め立てもでき、開港当時百一戸ばかりの横浜にどれほどの移住者が増したと言って見ることもできない。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶摘みだ烙炉だ筵だと騒いでいる木曾の季節の中で、男女の移住者の通行が続きに続いた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
