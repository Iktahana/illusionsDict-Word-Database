    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Ishikawa Prefecture (Hokuriku area)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "能登半島地震の影響で、石川県の沿岸部では津波の発生も懸念されました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "金沢市は石川県の県庁所在地であり、兼六園やひがし茶屋街などが有名です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "北陸新幹線延伸により、石川県へのアクセスが格段に向上しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "石川県は、九谷焼や加賀友禅といった伝統工芸品で全国的に知られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今年の夏は、涼しい石川県に避暑に行こうかと思っているんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "日本海に面した石川県は、豊かな海の幸の宝庫でもあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政府は、石川県を含む北陸地域への誘客促進策を強化しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "石川県｜能美郡片山津の、直侍とは、こんなものかと、客は広袖の襟を撫でて、胡坐で納まったものであった。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月二十六日、二代目尾上多賀之丞、石川県金沢に死す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは当時石川県のある顕官の令夫人、以前は某と云う一時富山の裁判長だった人の令嬢で、その頃この峠を越えて金沢へ出て、女学校に通っていたのが、お綾と云う、ある蒔絵師の娘と一つ学校で、姉妹のように仲が好かったんだそうです。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトの友の会では、去年の十月、革命記念祭に向って見学団派遣を計画し、農民代表として石川県の農民の山野芳松という小父さんが決定されるまでに運んだ。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一期生すなわち当時の三年生は、愛知県人と石川県人とがいずれも十名ばかりずつで互いに覇を争って来た。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は何で石川県人と愛知県人とがそうして争わなければならないのかは分らなかった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの友人等の敵になる石川県人が訳もなく憎らしくなった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその少年の一人のいた石川県人どもが、まず僕を目のかたきにしだした。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川県の奴等もよくこうして殴った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、何がもとだったのか、愛知県人と石川県人との間にごたごたが持ちあがった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川県人は東京やその他の県の有力者に助けを求めた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前中、父様と松坂屋へ、石川県の工芸品陳列会へ行って見る。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日程は静岡県一市七町村、奈良県九町村、石川県六町村、三重県十二町村となつてゐて、東京出発以来既に四週間、あと三重県の数ヶ村を残すだけである。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、渡道後四代、初代は石川県人というのが二、三名いたが、何代になるかわからない、どこからきたかおぼえていない、と答えた人数のほうが多かった。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対価値からいえば、もちろん国宝展などには及ばないが、驚くべきことは、これらの名品が全部、石川県下の隠れた収集家の手元から出品されたという点である。",
              "citation": {
                "source": "根強い北陸文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "積雪量の最も多い地域は新潟と富山の両県で、石川県の山間部、山形県の山寄りの土地などがこれに亜ぐのである。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学は、石川県の小松中学で、その頃この北陸の片田舎には、文学熱が大いに興っていた。",
              "citation": {
                "source": "一人の無名作家",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが石川県の石川郡などでは、そのように二つに分けて挽かなかったとみえて、蕎麦を篩にかけて残った滓がメクソだといっている（風俗画報二三〇号）。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに石川県などは地租改正の当時、ほとんと全部の字以下の地名をイロハまたは甲乙丙丁等にしてしまった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川県へいったり、高等工業で図案の時間を受持って話をすることができたのは、それが働きました。",
              "citation": {
                "source": "美術学校時代の岡倉先生",
                "author": "板谷波山",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一　　昭和十九年十一月下旬石川県羽咋郡一ノ宮村字寺家　藤井巽様（はがき）横須賀郵便局気付ウ二七　膽七八三八部隊玉井隊　藤井春洋たび／＼の便り及び小包ありがたうございました。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六　　昭和十九年十二月下旬石川県羽咋郡一ノ宮村字寺家　藤井巽様（封書）横須賀郵便局気付ウ二七　膽七八三八部隊玉井隊　藤井少尉○いよ／＼年も暮れに近くなつて来ました。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八　　昭和二十年一月上旬石川県羽咋郡一ノ宮村字寺家　藤井巽様（封書）横須賀郵便局気付ウ二七　膽七八三八部隊玉井隊　藤井少尉○年が明けても一向、正月らしい気分もしません。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二一　　昭和二十年二月石川県羽咋郡一ノ宮村字寺家　藤井巽様（はがき）横須賀郵便局気付ウ二七　膽七八三八部隊玉井隊　藤井春洋手紙は二、三日前につきました。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　石川県の富来湾は同県でも有名な漁場であるが、漁場の習いとして毎年のように、漁船の幾艘かが海上で暴風雨の為めに遭難し、稀には五人七人の漁師が屍体となって浜に打ち揚げられることもある。",
              "citation": {
                "source": "屍体と民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川県｜羽咋郡富永村では、死者を納棺する際に藁縄、或いは白布を以て屍体を緊縛した。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川県江沼郡橋立村では死者に最も親等の近い婦人が、白帷子を被つて号泣しつつ葬列に従うがこれを帷子被りと云うている。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉の隅に物捨甕も置かれあり四月九日　暁烏敏より書状あり、その末に、嘗て石川県北安田に其寺を訪ひたる時の句しるしあり。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は石川県から勉強するために東京へ送られた学生の一人であります。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川県｜能美郡川北の出身地を蜻蛉笠に被った男が、「俺等が郷里では県税を一円十三銭出せば漁り放題ですからの、大負けにして上げます。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
