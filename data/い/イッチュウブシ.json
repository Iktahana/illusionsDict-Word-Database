    },
    "definitions": [
      {
        "index": 1,
        "gloss": "type of jōruri (dramatic recitation accompanied by a shamisen)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日は、江戸時代から伝わる一中節の演奏会へ足を運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "祖母は若い頃、趣味で一中節を習っていたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "資料館には、一中節で使われた三味線の名器が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "一中節の名は都一閑斎である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に一中節において父の名を襲ぎ、二世紫文となった人である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "合方は一中節を奏する。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱり一中節を稽古している。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "表へ出れば一中節の師匠、裏へ行けば常磐津の家元、左樣いふ町の中に住ひながら、未だに私は自分の家へやはらかな空氣を取入れることも出來ずに居ります。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所横網町に住める一中節の師匠。",
              "citation": {
                "source": "鸚鵡",
                "author": "――大震覚え書の一つ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お麻さんはいつもそれらの後始末ばかりしていたが、彼女は一中節の都の家元から一稲の名をもらっていたので、その名びろめを旦那が思いたった時は――彼女に対する日頃の謝意というより自分の道楽の方が勝ったであろうが、二日に渡った盛大な催しを柳橋の亀清楼で催した。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九　宇治紫山　僕の一家は宇治紫山という人に一中節を習っていた。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は勿論一中節などを稽古するほど通人ではない。",
              "citation": {
                "source": "槐",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "父には一中節、囲碁、盆栽、俳句などの道楽がありますが、いずれもものになっていそうもありません。",
              "citation": {
                "source": "文学好きの家庭から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "各種の三味線楽と、雅楽類だったのだが、私は、おゆるしをうけて、浜子の箏を主にして、三味線は一中節の新人西山｜吟平、雅楽は山之井氏の一派にお願いしようとした。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで賃仕事の片手間に一中節の稽古をし、もし上達するものとすれば師匠になるのも善いと思ひ出した。",
              "citation": {
                "source": "素描三題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一中節はむづかしかつた。",
              "citation": {
                "source": "素描三題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一中節の師匠になることはとうとうお宗さんには出来なかつた。",
              "citation": {
                "source": "素描三題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「矢っ張り一中節を稽古してゐる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の知っている父は、禿頭の爺さんであったが、若い時分には、一中節を習ったり、馴染の女に縮緬の積夜具をしてやったりしたのだそうである。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ来たなと思いますから、お若さんはお捻をこしらえ待っております、例の門付は門口にたって三味線は弾いておりますが唄はうたいません、上手な師匠がやっても何うも眠気のさすが一中節でげすから、素人衆……エー旦那方が我れ面白の人困らせ……斯ういうことを申しますと暗の夜がおっかないんでげす。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニあの野郎生意気をいいアがって、向う脛ぶっぱらえなんかと仰しゃるお気早な方もございますが、正直に申すとまア左様言ったようなもので、扨て門外にたちました一中節の門付屋さんでげすが、頻りに家の内をのぞいて居ります。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九　お賤は調子が宜し、酒が出ると一寸小声で一中節でもやるから、新吉は面白いから猶近しく来る。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が嵩じては、かの一中に謡はれた、勝山に迄なるので、一中節では、彼女が道中の途次、湯巻を落したが、其まゝ道中を続けたと言うて、大いに此を讃美してゐる。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、一中節の好きな大倉さんが来ておらぬのも不思議であった。",
              "citation": {
                "source": "美音会",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は七福神の祠のそばにあつたのが、いつのまにか社務所の横、なにがしといふ一中節の師匠の、とてつもなく大きい古琴塚のうしろに移され、それがいかにも片隅の幸福を愉んでゐるやうな樣子なのに、私は思はず微笑した。",
              "citation": {
                "source": "九月朔日",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "二番目は菊五郎の「紙治」これは丸本の「紙治」を舞台に演ずるやう河竹新七のその時｜新に書卸せしものにて一幕目小春髪すきの場にて伊十郎一中節の小春をそのまま長唄にしての独吟あり廻つて河庄茶屋場となる二幕目は竹本連中出語にてわれら聞馴れし炬燵の場引返して天満橋太兵衛殺の場となる。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "また梅が散る春寒の昼過ぎ、摺硝子の障子を閉めきった座敷の中は黄昏のように薄暗く、老妓ばかりが寄集った一中節のさらいの会に、自分は光沢のない古びた音調に、ともすれば疲れがちなる哀傷を味った事もあった。",
              "citation": {
                "source": "銀座",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "われにはまた来歴ある一中節の『黒髪』がある。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しく薗八一中節の如き古曲をのみ喜び聴いていたわたしは、褊狭なる自家の旧趣味を棄てて後れ走せながら時代の新俚謡に耳を傾けようと思ったのである。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ江戸風と申しても薗八一中節なぞやるには『梅暦』の挿絵に見るものよりは少し古風に行きたく春信の絵本にあるやうな趣ふさはしきやに存ぜられ候。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその夜、私と共に罹災された嘉奈子刀自は、青春を明治三十年代の吉原に起臥された、一中節の名手で、ために近時、静岡の疎開先から寄せられた往時追憶の一文には、「中引けの金棒が揚屋町の角にチヤリン／＼と聞えてくる時分になると大門迄お客を送つた妓たちが、仲の町のお茶屋の縁に二人三人と集つてくる。",
              "citation": {
                "source": "東京万花鏡",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはその日どんな話をしたか覚えてゐないが、二三日してから又出かけて行つて、その時始めて彼女の一中節を聞いた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お笛の部屋から爪弾きの三味の音に合せて、一中節の渋い唄声が嫋々と聞えていた、――珍しや、寛いだ勘兵衛がお笛に唄わせながら、さっきから独り盃をあげているのである。",
              "citation": {
                "source": "嫁取り二代記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
