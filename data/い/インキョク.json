        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわちアーク灯の陰極になっている炭の棒を不断廻転させ、陽極には金属の棒を用い、これを水素または炭酸瓦斯で包んでなお強い磁力をアークの光部に作用させる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽極には大袋に亜鉛を入れたものを用い、陰極には銅板を用い、二・五ボルトの電圧で千アンペアの電流を通すと陰極の方へは純銅がだんだんに附着し、陽極には硫酸と酸素が出て来る。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃ある人が金剛石を真空管内に封入し、これに強い陰極線を当ててみたところが、金剛石は摂氏二千度近く熱せられ真黒な骸炭に変化したそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな長方形の真空ガラス箱内の一方にＢ教授が「テレラ」と命名した球形の電磁石がつり下がっており、他の一方には陰極が插入されていて、そこから強力な陰極線が発射されると、その一道の電子の流れは球形磁石の磁場のためにその経路を彎曲され、球の磁極に近い数点に集注してそこに螢光を発する。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これの陰極像などは立派に週期的と呼ばるべきものである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰極管ノ水冷ニ特ニ注意ヲ要ス。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰極管が光りだした。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰極（−）に近い部分には、そのような傾向は認められなかった。",
              "citation": {
                "source": "墨流しの物理的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二図乙に示すように、陽極に近い部分には星状の割れ目が出来るのに、陰極に近い部分では円い孔になるということは、墨膜の表面張力が脂の膜の表面張力より大きい為に、中心部の脂が円形に拡がることを示している。",
              "citation": {
                "source": "墨流しの物理的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かようにして例えば速い陰極線に対する運動法則を出すことが出来ます。",
              "citation": {
                "source": "相対性理論",
                "author": "アルベルト・アインスタイン",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰極線の屈曲に関してこの法則は全く満足的に経験と一致することが示されました。",
              "citation": {
                "source": "相対性理論",
                "author": "アルベルト・アインスタイン",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば『レントゲンと生命』などで、あの変圧器、整流器、陰極線などの線画の説明は、作った人はあれで誰にもよく分るように現象を説明したつもりであろうし、また私たちには、説明の意図がよくうかがえて面白いのであるが、一般の観衆には結局は分らないのである。",
              "citation": {
                "source": "科学映画の一考察",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "装置は、北大の黒岩博士と進藤君とがつくってくれたが、電磁オッシログラフと、陰極線オッシロスコープとを使った電子機械である。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この神と気との交渉は、晦つきて朔に転じ、陰極まりて陽発するの機微に通ずる。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊地氏は、電子の集合である陰極線を、薄い雲母板を通過させて、回折像を写真にとったのだが、これはラウエ斑点が丁度Ｘ線の波動性を立証したと同じに、陰極線の回折が、電子の波動性を決めたのは面白い。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時真空管内で、陰極に近い所に暗い部分があることを発見した。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物枯れて陰極まり、一｜陽生じて来復の時ではないか。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆地のせいもあろうが暗灰色ともなんともいいようない陰極の天地であった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
