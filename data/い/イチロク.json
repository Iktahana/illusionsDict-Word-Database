[
  {
    "uuid": "ff50077c-da02-519c-8e02-5c47cd529dba",
    "entry": "一六",
    "reading": {
      "primary": "いちろく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
