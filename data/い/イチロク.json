    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(rolling) a 1 and a 6 (with two dice)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "サイコロを二つ振ったら、見事に一六の目が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ここで一六を出せば逆転できるという場面で、彼は大きく深呼吸して壺を振った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "まさか三回連続で一六が出るとは、今日の彼は何かに憑かれているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "盤上のコマを進めるため、彼は念を込めてサイコロを転がし、見事に一六を引き当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もう一歩進んで姓名の代りに囚人のように三一六五八九二四といったような番号をつけるのも最合理的な一方法であるかもしれないが、そうなるのはやはり悲しい。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そのランゲナウ莊園の主であつた若い祖先は、男爵ピロヴァノ中隊所屬の旗手として、一六六三年ハンガリイにおいてトルコ軍と戰ひ、僅か十八歳で戰死したのだつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "※「……一六六三年十一月二十四日、リンダのランゲナウ、グレニツ及びチィグラの領主、オットオ・フォン・リルケは、匈牙利にて戰死せし弟クリストフの遺せるリンダに於ける所領地を讓渡せられたり。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六　三時間の後、工場は、堅固な土嚢塁と、鉄条網と、拒馬によって、武装されてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがあらゆるものの分割の終局たる分子の大きさは水素が、　　　　　　　　　　〇、〇〇〇〇〇〇一六粍　　砂糖の一種が　　　　　　　　　　〇、〇〇〇〇〇〇五五粍　　というように計算されていますから私共は分子の形や構造は勿論その存在さえも見得ないのです。",
              "citation": {
                "source": "手紙　三",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョット見ると活字みたいですが、一六二六年に英国で出来た筆写本なんです。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん一六八〇年度の英国の筆写本なんでゲスから相当の珍本には間違い御座んせん。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人力車が六台玄関の横に並んでいたが、車夫どもは皆な勝手の方で例の一六勝負最中らしい。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中阿歌麿氏著、「諏訪湖の研究」上編七一六ページにこれに関する記事と、写真がある。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九一六年一月、「白樺」所載）",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕も、無駄を平気でやれるような人間になろう」第一六課　誤解された時　純理より言うときは、世の中に誤解のないものはありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流自喜偶歩、と云ふので、一六が釜日でえす、とそゝり出る。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一六）拝殿の一夜　サア天狗様へ御｜挨拶も済んだというので、一同は奥殿の片隅を拝借し、多くはビショビショに濡れたまま、雑嚢や新しい草鞋を枕に横わったが、なかなか以て眠られる次第ではない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にも取らないで、口のなかに低声におよみなすったのが、市内衛生会委員、教育談話会幹事、生命保険会社社員、一六会会長、美術奨励会理事、大野喜太郎。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『新小説』一九一六［大正五］年四月号）",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正五（一九一六）年二月",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "半月も経った頃だったろうか、確か上塩町の一六の夜店の時だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一、一六、夜）（「三八九」第五集）",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――明治四四、三、一六―一七『東京朝日新聞』――",
              "citation": {
                "source": "マードック先生の『日本歴史』",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三一六　明治三十九年二月十一日　午前十一時―十二時　本郷區駒込千駄木町五十七番地より廣島市猿樂町鈴木三重吉へ　昨夜君の手紙がつきました。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大正五（一九一六）年一月",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『一六、三五の采粒かの、はい、ござります。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にも取らないで、口のなかに低声におよみなすつたのが、市内衛生会委員、教育談話会幹事、生命保険会社々員、一六会々長、美術奨励会理事、大日本赤十字社社員、天野喜太郎。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠は日曜日に休まずに一六に休むので、弟子が集まっていたのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六　僕が強く当ったので、向うは焼けになり、「じゃア勝手にしろ」という気になったのではあるまいか？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝来の年が西暦一五四九年、島原の乱が同じく一六三七年であるから此間九十年近い歳月がある。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、外国商人が裏面で布教し、国内のキリスト教信者の反抗も意外に強かつたので、三代将軍家光は、数度にわたつて、外国商船の往来を禁じ、遂に、寛永十六年（紀元二二九九西暦一六三九）七月、和蘭人と支那人を除く他の外国人との貿易を一切禁止したのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（このひとハワイ帰りに似合わず、どこか淋しい翳がある）一六　京都。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "dice gambling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若い頃は一六に手を出して、親の遺産をすっかり身ぐるみ剥がされたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その裏路地の奥では、夜な夜な一六が開かれており、怪しげな男たちが出入りしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "一六の勝負に熱くなりすぎた客同士が、土間で殴り合いの喧嘩を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は一六で一財産築いたと豪語していたが、その後の末路は誰も知らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "(armed) robbery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "街道沿いで一六に遭い、財布だけでなく身につけていた着物まで奪われてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "夜更けの峠道は一六が出ると噂されており、旅人は皆明るいうちに通り抜けようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼はかつて一六を働いて島流しになったという過去を、誰にも言わずに隠していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "押し入った一六は、刃物をちらつかせながら店の主を脅し上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "Edo period to early Meiji non-working day falling on all days of the month with a 1 or a 6 in it (when written in kanji numerals, i.e. the 1st, 11th, 16th, 21st and 26th days of the month)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明日は一六の休日だから、子供たちを連れて浅草にでも遊びに行こうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "役所に勤める彼は、一六のたびに仲間と連れ立って酒を飲みに繰り出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "一六の休みにあわせて、呉服屋の番頭が実家へ帰省するための暇乞いに来た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "明治の初め頃までは、日曜日ではなく一六のつく日が公の休みとして定着していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
    ],
