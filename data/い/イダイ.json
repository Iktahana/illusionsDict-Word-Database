[
  {
    "uuid": "99ed97f4-c88b-5377-b343-a0e0d7d6e22b",
    "entry": "偉大",
    "reading": {
      "primary": "いだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
