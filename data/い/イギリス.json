[
  {
    "uuid": "b4def068-14b7-59da-9845-3b27ce85601b",
    "entry": "英吉利",
    "reading": {
      "primary": "イギリス",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
