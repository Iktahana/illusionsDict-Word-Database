    },
    "definitions": [
      {
        "index": 1,
        "gloss": "United Kingdom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "イギリスのEU離脱交渉は、依然として難航している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "来年、夏休みにイギリスを旅行する計画を立てています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史の教科書には、スコットランドとウェールズを含むイギリスの多様な文化が紹介されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イギリスの金融市場の動向は、世界中の投資家が注目している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「イギリスの紅茶は香り高くて美味しいね。」と友人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イギリスの大学で、神経科学の最先端研究が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "オールド・ロング・サインを歌い、炉辺の団欒を思い、その郷愁を白い雲にイメージする英吉利文学のリリシズムは、偶然にも蕪村の俳句において物侘しく詩情された。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利の田舎おやじらしい、塔の欄干から外へ墜ちかけた。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、英吉利人は疑い深くて完全に引っかからなかった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、窩棚の向うの兵営のそのさきに、英吉利人のヘアネット工場ある、私の妹、そこの女工、毎日、ふけとゴミばかり吸う」と、時以礼はつづけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利人の公司、仲買人と巡警に金掴ましている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……英吉利人、米国人、独逸人、日（云いかけたが、時以礼は口を噤んだ）……みな、支那、百姓、工人、苦るしめる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和蘭陀の公子は本望でせう……實は其が望みだつたらしいから――　鸚鵡は多年馴らしてあつて、土地の言語は固よりだし、瓜哇、勃泥亞の訛から、馬尼剌、錫蘭、澤山は未だなかつた、英吉利の語も使つて、其は……怜悧な娘をはじめ、誰にも、よく解るのに、一ツ人の聞馴れない、不思議な言語があつたんです。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの發音法は大部分大陸｜讀方（コンチネンタル・メソツド）を用ゐられた樣ですが、日本で云ひ慣らされたバツカスとか※ーナスとか云ふのは英吉利讀にされたと見えますから其邊は一寸讀者に注意して置いて遣らないと惡いだらうと思ひます。",
              "citation": {
                "source": "『傳説の時代』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて個人としての同情や反感を度外に置くと、独逸だの仏蘭西だの英吉利だのといふ国名は、自分に取つてもう重要な言葉でも何でもなくなつて仕舞つた。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利のやうに個人の自由を重んずる国が、強制徴兵案を議会に提出するのみならず、それが百五対四百三の大多数を以て第一｜読会を通過したのを見ても、其消息はよく窺はれるだらう。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初｜英吉利の雑誌にはニーチエといふ名前が頻りに見えた。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利の思想界にあつて別に新らしい名前でもない。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルトンとシエクスピヤを嘆美しながらも、それらの詩人を有する英吉利は、彼から見ると独乙の発展に妨害ある一種の邪魔｜物に過ぎなかつた。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "又見よ、かの中央｜亜弗利加の黒奴がすなる如く、吾人の足に接吻しては礼拝幾度か低頭し、ひたすらに吾人の愛顧の衰へざらむことを憂ふるものは英吉利にあらずや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "義光ちゃんという子は父親は外交官なので在外中、英吉利婦人のナースをつけられたという話で英語は綺麗に喋りましたが日本語にはまだとき／″＼舌たるいものがありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤は、憲法調査のために外遊し、憲法学者、独逸のグナイスト、墺国のシュタインに教へを聞き、仏蘭西、英吉利を歴訪して、参考資料を蒐めて帰つた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時｜英吉利人の一家族、我歌を聞きて立ちとまり、歌ひ畢るを待ちて、長らしき人われに銀貨一つ與へき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後には許多の英吉利人あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利人のかゝる習をなしゝは、美しき號衣の好き座席を得しむる利益を知りたるためなるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利の老婦人ありて、年若き男女と共に、拿破里へ往かんと、此山の麓を過ぎぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "）客は英吉利語に伊太利語まぜて、此國の人の心鈍く氣長き爲に、旅人の迷惑いかばかりぞと罵りしが、やうやく思ひあきらめたりと覺しく、大なる紛※を結びて頭巾となし、兩の耳も隱るゝやうに被り、眼を閉ぢて默坐せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利人ほど心忙しきものはなし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "文に天祐に依りてみて、英吉利人なりしよと云へば、外の一人｜冷笑ひて、君はいづれの國をも同じやうに視給ふか、劵面にも北方より來しことを記せり、無論｜魯西亞領なりといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの隣房なる英吉利婦人の色蒼ざめて心冷なるは、我が堪ふること能はざる所なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年｜英吉利人ひとり山賊に撃ち殺されしは、此巖の上にての事なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "オテルロとは彼シエエクスピイアの戲曲ヱネチアの黒人の主人公にして、市長の家は其舊館なれば、英吉利人は此地に來る毎に必ずこれを尋ぬること、マルクス寺又は武庫に殊ならずといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "和蘭陀の公子は本望でせう……実は其が望みだつたらしいから――　鸚鵡は多年｜馴らしてあつて、土地の言語は固よりだし、瓜哇、勃泥亜の訛から、馬尼剌、錫蘭、沢山は未だなかつた、英吉利の語も使つて、其は……怜悧な娘をはじめ、誰にも、よく解るのに、一ツ人の聞馴れない、不思議な言語があつたんです。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を人ともおもはぬ、殆憎げなる栗うり、やさしくいとほしげなるすみれうり、いづれも群ゐる人の間を分けて、座敷の真中、帳場の前あたりまで来し頃、そこに休みゐたる大学々生らしき男の連れたる、英吉利種の大狗、いままで腹這ひてゐたりしが、身を起して、背をくぼめ、四足を伸ばし、栗箱に鼻さし入れつ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「かくて漁師の娘とはなりぬれど、弱き身には舟の櫂取ることもかなはず、レオニのあたりに、富める英吉利人の住めるに雇はれて、小間使になりぬ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "加特力教信ずる養父母は、英吉利人に使はるるを嫌ひぬれど、わが物読むことなど覚えしは、彼家なりし雇女教師の恵なり。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
