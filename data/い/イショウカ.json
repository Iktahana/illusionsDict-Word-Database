        "examples": {
          "standard": [
            {
              "text": "胃小窩の深さは胃の部位によって異なることが知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "胃小窩の底部には、消化酵素や胃酸を分泌する胃腺が多数開口している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電子顕微鏡を用いて、胃小窩の微細な構造を詳細に分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "胃小窩を覆う上皮細胞は、胃酸から胃壁を守る粘液を産生する重要な役割を担う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「先生、この患者さんの生検組織では、胃小窩の配列が不規則に見えますね。」と研修医が述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヘリコバクター・ピロリ菌感染は、胃小窩の細胞に慢性的な炎症を引き起こすことが知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "胃小窩の細胞は活発な新陳代謝により、常に新しい細胞へと置き換わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「象の夢でも見ていたのでごいしょうか。",
              "citation": {
                "source": "親という二字",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると母親ももう鼻声になって、「私、あの娘にあんな病気しられて、もう、どないしょうかと思うてます。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
