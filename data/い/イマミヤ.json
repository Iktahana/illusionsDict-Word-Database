        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この地の開拓にあたり、人々の安寧を願って今宮が建立された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供の頃、村はずれの今宮の境内でよく遊んだものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "次の角を曲がった先に、小さな今宮様がお祀りされていますよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
