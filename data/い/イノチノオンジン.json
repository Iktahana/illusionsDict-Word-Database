        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海で溺れていた私を助けてくれたあの青年は、私にとって一生の命の恩人です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君は僕の命の恩人だ！ 何かお礼をさせてくれ」と、彼は私の手を何度も強く握った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "倒産寸前だった父の会社を救ってくれた伯父を、私たちは家族全員の命の恩人だと思っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "おれはお前の命の恩人だぞ。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんは、すると、あなたの命の恩人ということになりますね。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」王子は再び以前の、こだわらぬ笑顔にかえってラプンツェルの傍に腰をおろし、「君は、私の命の恩人じゃないか。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとにお前さんは、わしの命の恩人ぢや。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貞造は、貴女の実の父親で、またある意味から申すと、貴女の生命の恩人ですよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその人を命の恩人と思い、今は行方は判らぬが、もしめぐり会うことがあれば、この貯金通帳をそっくり上げようと名義も秋山にして、毎月十日に一円ずつ入れることにしたのです。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "命の恩人を探す人生紙芝居」という変な見出しで書きたてましたので、私はこれは困ったことになったわいと恥しい思いをしていました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、自分の嫌な男を一生の命の恩人として持っていることは、いかに不快であるかを考えた。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お京にとっては命の恩人、また私にとりましてもな」平左衛門改めてお礼をいった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あねごは命の恩人じゃアねえか！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私にとりましては生命の恩人、決しておろそかには存じません」「ただそれだけでございましょうか」お町不足そうにせまって行く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……命の恩人というところで、たしかに俺もあの娘を、最後には真剣に愛したが、しかし元々二人の恋、変則なものと認めていい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからお前さんがいってくれりゃ、吉治の分も、わしの分も、二重の生命の恩人となるわけだよ。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には生命の恩人ですからね。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほう、生命の恩人だと仰有るか。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命の恩人である貴方のお名前を……」「あたしの名前？",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような偏土に来て、しかもこのような神秘な尼僧院の中で、そして一夜を一つ衾に夢を結んだ生命の恩人である尼僧から、突然懐かしい父の名を耳にしようなどとは夢にも思いがけぬことだった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……樹明君から胃の名薬（一名白米）が到来した、何といつても米と水と塩とさへあれば、私は当分死なゝいですむ、命の恩人だ、井月の口吻をまねすれば、千両、千両！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「命の恩人だが、もう、こんな命は、要らねえから、要らねえ命を助けてもらったのに、恩も、へったくれもねえ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下は、命の恩人だ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "急げば、明後日には、京へ入れようが、その足で、とにかく、叡山へ参ろう」「では、若旦那、大津から坂本へ出まして、そこから」「そう」　小太郎は、頷いて「父の墓参も致したいし、義観と申す、命の恩人にも、礼を申したい」「お兄様」　と、深雪が「お姉様の、お墓は？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すみません、あなたは、ぼくの生命の恩人です。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう先輩であり、命の恩人でもある帆村が、所もあろうに、大陸のこんな所に突然姿を現わしたものであるから、三千子が花瓶を取り落としそうになったのも、無理ではない。",
              "citation": {
                "source": "鬼仏洞事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "命の恩人たるおれの命令に、そむく気だな。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいお色、おい女丈夫、お前は命の恩人だぜ」「そう思ったら邪魔にせずに、精々これから可愛がるといいわ」「あの時お前が来なかろうものなら、女勘助っていう奴に、おれはそれこそ殺されたかもしれねえ」「ご身分を宣ればよござんしたに」「莫迦め、そんなことは出来るものか、がんじ搦みにされたんだからなあ。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（団八、厭な野郎だが、云って見りゃア命の恩人、自由になってやらなけりゃアならないだろう）　その辺は心得ているのであった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（敵討つ身でなかったなら、何のみすみす命の恩人の、お玉殿をそんな目に！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お吉は命の恩人であった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「命の恩人ではござりませぬか」　織江はなおもいいつづけた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
