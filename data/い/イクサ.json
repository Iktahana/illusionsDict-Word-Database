            }
          ],
          "literary": [
            {
              "text": "然し三造は正々堂々と戦はうと思つてゐるのである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造くらゐ正々堂々と戦はうと思つてゐる者はない。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、戦いは尚つづく。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子戦死の報を聞くや、つと立って台所に行き、しゃっしゃっと米をといだという母親のぶざまと共に、この男の悲しみの顛倒した表現をも、苦笑してゆるしてもらいたい。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは程度の差はあっても、この戦争に於いて日本に味方をしました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはこの大戦争に於いて、日本に味方した。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大戦中にも、その頃の新聞、雑誌のたぐいを一さい読むまいと決意した事がありましたが、いまもまた、それに似た気持が起って来ました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中に、あんなにグロテスクな嘘をさかんに書き並べて、こんどはくるりと裏がえしの同様の嘘をまた書き並べています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは対戦中の右翼小説ほどひどくは無いが、しかし小うるさい点に於いては、どっちもどっちというところです。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか新聞で、かれの自戦記を読んだが、あの文章は、忘れがたい。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで知ったことでございますが、あの恐しい不思議な物音は、日本海大海戦、軍艦の大砲の音だったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東郷提督の命令一下で、露国のバルチック艦隊を一挙に撃滅なさるための、大激戦の最中だったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一線に於いて、戦って居られる諸君。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分、十分、私は足袋と悪戦苦闘を続けた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦死と出征であったのに。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「長女の婿は三、四年前に北支で戦死、家族はいま小坂の家に住んでいる筈だ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦地の人々も、おそらく同じ気持ちだと思います。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの多くは欧州大戦の疲弊が一時的に案出したものに過ぎず、芸術本来の要求に発したよりも芸術的スランプの救済要求に発したものと考ふべき理由がある。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの歌曲は、そのもつと前、欧洲大戦前後の好況時代に流行した、外国オペラの明朗な翻訳曲に比すれば、遥かに憂鬱で哀傷的のものであつたが、音楽として尚甚だ上品のものであり、その精神には健全で浪漫的な青春のリリシズムが情操して居た。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には秋のような日が照り渡って、地上には麦が実り、大鎌や小鎌を持った農夫たちが、至るところの畑の中で、戦争のように忙がしく働いている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉における木曾義仲の崇拝や、戦国時代への特殊な歴史的懐古趣味を、一方蕪村の平安朝懐古趣味と比較する時、両者の異なる詩人的気質が、おのずから分明して来るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中に一本大きな赤椿があって、鵯の渡る頃は、落ち散る花を笹の枝に貫いて戦遊びの陣屋を飾った。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処で買ったかと聞いたら、町の新店にこんな絵や、もっと大きな美しいのが沢山に来ている、ナポレオンの戦争の絵があって、それも欲しかったと云う。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概は勇ましくまた殺伐な戦闘や簒奪の顛末であるが、それがただの歴史とはちがって、中にいろいろな対話が簡潔な含蓄のある筆で写されていたり、繊細な心理が素朴な態度でうがたれていたりするのをおもしろいと思った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一つの特徴としては、王の軍中に随行して、時々の戦の模様や王の事蹟を即興的に歌った詩人（Scalds）の歌がところどころにはさまれている事である。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オラーフ・トリーグヴェスソンが武運つたなく最後を遂げる船戦の条は、なんとなく屋島や壇の浦の戦に似通っていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王が代わりに自分の弓を与えたのを引き絞ってみて「弱い弱い、大王の弓にはあまり弱い」と言って弓を投げ捨て、剣と盾とを取って勇ましく戦った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この美しい音楽の波は、私が読んでいる千年前の船戦の幻像の背景のようになって絶え間なくつづいて行った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音が上がって行く時に私の感情は緊張して戦の波も高まって行った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上のいくさの話が出て子供等が急におとなしくなったと思うたら、小さいのとせいちゃんは姉上の膝の上ではや寝てしまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
