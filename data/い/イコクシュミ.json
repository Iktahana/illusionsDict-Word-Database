          ],
          "literary": [
            {
              "text": "実に無意味なおもちゃであるがしかしハーモニカやピッコロにはない俳味といったようなものがあり、それでいて南蛮的な異国趣味の多分にあるものであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして女がゆく、すずしい白のスカアトその手に持つた赤皮の瀟洒な洋書、いつかしら汗ばんだこころに異国趣味な五｜月が逝く……新しい銀座の夏、かなしくよるべなき人工の花、――石竹と釣鐘艸。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "家屋は日本風であるが海に向つて開いた玄関、廊下、翼家の欄間には流石に紅や黄の窓硝子が箝められ、庭の隅々にはまた紅い松葉菊を咲かしてあるといふ風に、如何にも異国趣味の瀟洒な住宅であつた。",
              "citation": {
                "source": "雲母集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父はそうした異国趣味のエロ商売で、日本に亡命して来る印度の志士や、潜入して来る各国のスパイ連を片端から軟化させているという噂だ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは南蛮屋の奥座敷、屋号に似つかわしい南蛮風の部屋で、青い絨緞、オレンジ色の壁、白堊の天井、黒檀細工の円卓、ギヤマン細工のランプなど、この時代には珍しい、異国趣味が漂っている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風の兵船を描き出した、大型の油絵が金ぶちにはめられ、壁の一所にかけられてあるのも、また好もしい異国趣味である。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反復が芸術的に素朴な手法でされているものだから、希望される最も低い意味での風景的異国趣味さえ損われてしまっている。",
              "citation": {
                "source": "イタリー芸術に在る一つの問題",
                "author": "――所謂「脱出」への疑問――",
                "note": "青空文庫"
              }
            },
            {
              "text": "異国趣味なところは微塵もない。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数寄屋河岸に事務所をもち、かつて骨董癖のある英人弁護士の事務所に働いたこともあるので、自分でも下手ものの骨董品や、異国趣味の室内装飾品などが好きであったが、庸三はある連帯の債務を処理してもらったことから、往来するようになったものだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも民族的な違いそのものを決定的なアルファとし、オメガとするところに異国趣味を根とするブルジョア文学の国際的要素の特性がある。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝国主義のファッショ化につれて、このブルジョア文学中へ国際的らしい主題をもちこむ異国趣味は、直に民族主義の武器としてつかわれるものだ。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア勃興期に、ブルジョア文学の異国趣味は植民地発見熱の反映として現れた。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は無智な軍用ペンをふるって、ブルジョア異国趣味から狂気的民族主義へ飛躍しているのだ。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この実例だけでも、ブルジョア文学の領域内で、異国趣味を基礎とする国際主義は民族主義の泥沼にはまってついにファッショ化するものだということが十分明瞭に示されている。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス散文の規範のようなメリメは異国趣味でロマンティックな題材と情熱とを、厳しく選択して理性的に配置した文章の鮮明な簡勁な輪廓の中にうちこんでいる。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或るものは異国趣味の裡に、或るものは歴史小説の中に、ジョルジュ・サンドは彼女の穢れない女性の霊魂の描写の中に。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちの文学は、当然、異国趣味でない国際的関係とその感情、世界史の積極的発現への評価をふくむはずである。",
              "citation": {
                "source": "「道標」を書き終えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう老婦人の姪に、異国趣味そのものとも言いたいマドマゼエルのような人が生れたのも決して不思議は無いと岸本は想って見た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "船に乗ってからも岸本はあのマドマゼエルの異国趣味が日本人と結婚するところまで突きつめて行ったかと思いやった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "構成派が革命に対するインテリゲンツィアの任務を過大評価している点、的はずれな機械力への讚美、生産労働に対する異国趣味を、はっきり批判するようになって来た。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生や若い勤人中の所謂文学好きは、構成派の詩人たちの科学性に対する異国趣味にひきつけられた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生産への異国趣味を排撃せよ！",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは工場へ舞い込んでびっくりしているインテリゲンツィアの生産に対する異国趣味だ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "異国趣味を通じて、より進んだと信じられている文化形態を通じて、民族の人民的文化の質が隷属状態に変化してゆく危険がある場合、国際性は、はっきり、ブルジョア文学の個人主義にたつ世界人主義と区別されなければならない。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（国姓爺合戦）それは僕等自身の異国趣味にも未だに或満足を与へるであらう。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが金筋の入った正服を着て、当時はまだ珍しかったバナナだの、パイン・アップルだのの籠をさげて帰って来る姿は、自分の異国趣味を十分満足させた。",
              "citation": {
                "source": "大人の眼と子供の眼",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はアカシヤの花にノスタルジアの匂いを嗅ぎ、清澄な空の高さを仰いでは、希望の欣びを知り、棧橋の人混みにまぎれて異国趣味に睦み、山の上から眼下に横たわる街々を眺めては平和を愛し、支那人の顔を見つめて首をかしげ、綺麗な道路と赤瓦の住宅とにおいて、知識人の表情と小市民気質とを理解した。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際あり来たりの独楽、凧、太鼓、そんな物に飽きたお屋敷の子は珍物好きの心から烈しい異国趣味に陥って何でも上等舶来と言われなければ喜ばなかった。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて異国趣味の室である。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
