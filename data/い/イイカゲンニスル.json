          "literary": [
            {
              "text": "馬鹿もいい加減にするがいいわ。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "不人情もいい加減にするがいい……手前等あタッタ今までその芸妓を……」「黙れ黙れッ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時江、むずかりもいい加減にするもんじゃ。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減にするがいい！",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "未練もいい加減にするがいい。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談もいい加減にするがいい。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひあがるのもいい加減にするといいわ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人に迷惑をかけるのもいい加減にするもんだ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、―――三十三箇所を残らず廻っちゃあ大変なんで、いい加減にするつもりだが、―――とにかく福良から徳島へ渡って、それから帰ります」「お土産は淡路人形ですな」「うん、そう。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも子　冗談もいいかげんにするものよ、人を馬鹿にして。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見当違いもいいかげんにするがいい。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう僕も饒舌はいいかげんにする。",
              "citation": {
                "source": "片信",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でつとめても出来ませんよ、　極端に走る人がつとめていいかげんにする事は出来てもねえ、　私の様な人間はこれっきりなんですよ。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたもいいかげんにするもんですよ。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんにするわけではないが、どうしてもそうする。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほほほ、いいかげんにするものですよ、源様。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮山　……（それを見ているうちに、はじめてフテブテしくニヤリとして）あんたも、しかし、いいかげんにするがいいなあ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんにするがええぞ。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "机上の空論もいいかげんにするがいい。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けおしみも、いいかげんにするがいい。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに五日間なんて、でたらめもいいかげんにするがいい。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フフフ……、でたらめもいいかげんにするがいい。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
