          ],
          "literary": [
            {
              "text": "まさかいくら何でも、本ものは入れて走れないので、清水を八分目くらゐ湛へた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼け出された様な火夫の服のまゝではいくら何でも帰れないと、家を飛び出す時に着ていた着物を新聞紙に包み、何喰ぬ顔で船から降りようとすると船長が怪しんでそいつは何だ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら何でも風呂だけはと銭湯に出掛けて行くのにもこっそり後を尾行け、自宅に風呂場を作らねばならぬと思った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、自分だって、真夏に毛糸のセエターを着て歩くほど、いくら何でも、そんな、暑さ寒さを知らぬお変人ではありません。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、相手が、一八七六年生れ、一昔まえの、しかも外国の大作家であるからこそ、私も甘えて、こんな試みを為したので、日本の現代の作家には、いくら何でも、決してゆるされる事ではありません。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へん、お菰の子の癖に」　するとしまは、むっとした様子を見せ、「お新造さん、いくら何でも、それだけはおよしなさいませ」　母は「なに関うものか」と言いますが、多少の後悔の色は見せます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝいう訣れをするなんて、いくら何でも僕は諦め切れないよ」　わたくしは、その背を子供をなだめるように撫でゝやりながら、「いゝから／＼人間が入って出て来られないほど魅力のある奥山なんて、何処にもありやしないから――先生には、またきっと会えるわ――」　山の麓は春から初夏の爽かさに進んでいます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かやもめで、それもいたし方ないとはいうものの、ミルクで育たぬわけでもなし、いくら何でも初七日もすまぬうちの里預けは急いだ、やはり父親のあらぬ疑いがせきたてたのであろうか――と、おきみ婆さんから教えられたのは、十五の時でした。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらそや、いくら何でもチビスの乳は飲めんさかいナ。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一万九千円を握っただけで能事足れりとするような、けちな肚ならともかく、いくら何でも、そんな非合法な、かつ信用に関するような真似は、お前がやりたくても、おれがやらなかった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら何でも辛棒がしきれませんや。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしイドリスは、そればかりはおゆるし下さいまし、いくら何でも王さまと一つのお湯へはいるのは、もつたいないかぎりですと言つて、かたくおことわりしました。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワトソン君、いくら何でも僕はまさか、不動の木偶を立てて、それで欧羅巴で最も敏感な連中を、瞞著し得ると思うような、たわけ者ではないつもりだよ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、\"COME HERE AT ONCE\"（すぐに来い）と云うだけのことだよ、いくら何でもこの招待状では、彼は万障を繰合せても来ると思ったのさ。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら何でも、君のめざとい診察にかかれば、死にかけだなんて思ってもらえそうにない。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこれではいくら何でもあんまりなので、アウトラインだけ手短に書く。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら何でも私はこの小さい女王さんを情人にしようとはしない。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ話し合ってみた揚句、いくら何でも可哀相ですから、貴方にお願いして置いて頂こうじゃないのって……そう言っていたとこよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら何でも僕に禁酒法案の説明をさせるなんて余りぢやないか。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、最後にはたつた一人か二人の人間が残る勘定になるが、いくら何でも、わずか一人や二人の智慧で一億の人間がだませるわけのものではない。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら何でも自分の血を分けた子だのに、顔を見に来てくれなかったのは、私はとにかく、死んだ子が可哀そうだと怨んだ。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら何でもあまり見すぼらしいことしてお産をするのは心細うござんすから。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら何でも、こんなものはきまりがわるくて持ち出せやしませんわ。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度私にも加勢しろと、青柳がそう言うんだけれど、いくら何でもそんな罪なこと私に出来やしませんわ。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら何でももう元日の朝だといふのに、何処をふらついてゐるんでせうね。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇の名において、これほどの犠牲を費した戦争が全部国際悪であり、人民の運命を破壊したものとは、いくら何でも信じきれない思いがある。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら何でも僕は第三回の殺人を待つていたわけじやないんだ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら何でも、チイット炯眼過ぎやせんか……それは……。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あ、そんなことだけはいくらなんでも、先生の前でいはない樣にと、あれほどいつて置きましたのに、やつぱり頭の狂つてゐるものに、何と申し聞けて置きましても仕方が御座いませんのですねえ。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは夫人、いくらなんでもちっとはお痛みあそばしましょうから、爪をお取りあそばすとは違いますよ」　夫人はここにおいてぱっちりと眼を※けり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
