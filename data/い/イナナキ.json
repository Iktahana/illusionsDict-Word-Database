        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夜、静かな牧場に響く馬の嘶きに、森の動物たちも耳を澄ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "訓練された競走馬は、スタートの合図を待つ間、興奮した嘶きを漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遠くから聞こえる力強い嘶きは、野生の馬が仲間を呼んでいるかのようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ひゝと嘶きて引放れていぬべき顔したり」と述べており、駒の嘶きを「ひゝ」と写している。",
              "citation": {
                "source": "駒のいななき",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代に入って、鹿野武左衛門の『鹿の巻筆』（巻三、第三話）に、堺町の芝居で馬の脚になった男が贔屓の歓呼に答えて「いゝん／＼と云ながらぶたいうちをはねまわつた」とあるが、この「いゝん」は『落窪物語』の「いう」と通ずるもので、馬の嘶きを「イ」で写す伝統が元禄の頃までも絶えなかったことを示す適例である。",
              "citation": {
                "source": "駒のいななき",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬が嘶きあい、背でリンリン鈴が鳴った。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻尾を焼かれた馬が芝生のある傾斜面を、ほえるように嘶き、倒れている人間のあいだを縫って狂的に馳せまわった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉はお花が土蔵の前の石段に腰掛けて唱う唱歌をききながら茶室の窓に倚りかかって居眠り、源造に誘われて釣りに出かけて居眠りながら釣り、勇の馬になッて、のそのそと座敷をはいまわり、馬の嘶き声を所望されて、牛の鳴くまねと間違えて勇に怒られ、家じゅうを笑わせた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（駒、高嘶きす）〔――この時、看客の笑声あるいは静まらん。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺院は随一の華主なる豆府屋の担夫一人、夕巡回にまた例の商売をなさんとて、四ツ谷｜油揚坂なる宗福寺に来りけるが、数十輛の馬車、腕車、梶棒を連ね輪を駢べて、肥馬｜嘶き、道を擁し、馭者、馬丁、車夫の輩、手に手に桝を取りて控えたる境内には、一百有余の俵を積み、白米｜筵に山をなせり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち鞭の鳴るとともに、二頭の馬は高く嘶きて一文字に跳ね出だせり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幕の羅馬字よ、くるしげに馬は嘶き、大喇叭鄙びたる笑してまたも挑めば生あつき色と香とひとさやぎ歎きもつるる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏の朝風に軍馬は嘶き、旗印ははためいて、戦機は充満した。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に明治十四年の『ネーチュール』から片方の履を失った馬が鍛工の店頭に立ちて追えどもまた来る故、その足を見てこれと解り履を作りて付けやると、これで済んだかという顔付で暫く鍛工を見詰め、一、二度踏み試みて快げに嘶き疾く馳せ帰った話を引きいる。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、それが水を出て、だんだんに里の方へ近付いて来ると、家々に飼ってある馬があたかもそれに応えるように、一度に狂い立って嘶き始めた。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬狩りの群れは二、三人幾組にも分れて、川筋から里につづく要所要所に待ち伏せをしたが、月の明かるい夜にはかの嘶きが決して聞えないで、いつも暗い夜に限られているために、その正体を見届けるのが頗る困難であった。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分にも暗くてはどうにもならないので、かれらは松明を持って出る事にすると、その夜には一度も嘶きの声が聞えなかった。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな晩には出て来るかも知れないと、馬狩りの群れは手配りして待ち構えていると、やがてかの嘶きの声がきこえた。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しい馬は相変らず三日目か五日目には異様な嘶きを聞かせて、家々の飼馬をおびやかしていた。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さながら狂馬のごとくに鬣逆立てながら、嘶きつづけて挑みかかったと見るまに、疾走中の早馬は、当然のごとく打ちおどろいて、さッと棒立ちになりました。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこそまさしく京できいたヘゲタレじゃ」　苦が笑いしながらとって返すと、血の海の断末魔の悲しい嘶きをつづけながら、のたうち苦しんでいる愛馬の首を、わが子のようにしッかと抱きかかえて、声も絶え絶えと嘆き悲しんでいた若者へ、詫びるように呼びかけました。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこそまさしく京できいたヘゲタレじゃ」　苦が笑いしながらとって返すと、血の海の断末魔の悲しい嘶きをつづけながら、のたうち苦しんでいる愛馬の首を、わが子のようにしッかと抱きかかえて、声も絶え絶えと嘆き悲しんでいた若者へ、詑びるように呼びかけました。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第五話　三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今自分の背中から落っこちたものを見ますと、自分の主人の紅矢ですから、畜生ながら気にかかると見えまして、しきりに紅矢の身体を嗅ぎながら、ぐるぐる歩きまわっていましたが、やがて首を擡げて高く悲し気に嘶きました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお使いから詳しい様子を聞いて、青眼先生はどうしたことであろうと立っても居てもおられず心配をしているところへ、不意に表の門の前で馬の嘶き声が聞こえましたから、もしやと思って駈け出して見ますと、こは如何に、紅矢は銀杏の樹の根元に血まぶれになって倒れていて、傍には「瞬」が心配そうにうろうろしています。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ほのぼのと明け放れた朝霧の中で、若者のタイキは花々しい嘶きを挙げて快走した。",
              "citation": {
                "source": "パンアテナイア祭の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は奴の醜い嘶きに打たれると、折角の憐れな芝居も台なしにされたテレ臭さで、嘔吐を覚えさうに顔を顰めた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うせもう狎れる気遣ひはありはしない――私は、あきらめて、奴の嘶きに、好い気味だ！",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｚは私がいたづらに鳥の羽根で鼻腔を突いてやつた時と同様のワラヒ声に似た嘶きを挙げて、連続的に屁を放つた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると私達は、私達の眼の前に、馬の嘶きに酷似した異様の笑ひ声を挙げて、馬とも鬼とも牛ともつかぬ冷酷な太十をはじめ五郎、閑吉、その他の化物の顔がづらりと並んだのを発見した。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼーロンは、突然歯をむき出すと、鼻つまりのやうな鈍重な声で醜い嘶きを発した。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ういふものか、いや、それは私の心底に真の愛情が湧かぬ為だらうが、如何ほど私が奴の空機嫌をとつても一向に慣れるけしきもなく、その憎態な嘶きで飼手を飛びあがらせたり、尻尾の房で面体を振り払つたりするばかりであつた。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時すぎ、支部馬の力のないいななきと、馬車の車輪のガチャ／＼と鳴る音がひゞいて来た。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三の窓をめくった時金具の磨きのぴかぴか光る騎馬が一騎高くいななき乍ら眼近の道芝に蹴込んで来た。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
