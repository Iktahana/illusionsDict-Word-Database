        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はちょっとしたことで相手を陥れようとする、意地が悪いところがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、面白半分に人の秘密をばらまく意地が悪い噂を流した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "上司は部下のミスをことさら強調し、意地が悪いとも取れる叱責をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの子、わざと友達の作品を壊したんだって！意地が悪いわね！」と母親は呆れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その悪役は、敵を苦しめることに喜びを感じる、極めて意地が悪い存在だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の皮肉は、言葉の裏に隠された意地が悪いニュアンスを帯びていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "待ち合わせ場所にわざと遅れてきて、相手を苛立たせるなんて、意地が悪いにもほどがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "古い者は、意地が悪い。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、じつさい意地が悪いよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」兄さんは、少し意地が悪い。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供じゃあるまいし、こんな赤い大鼓をかついでお宮まいりだなんて、板倉様も意地が悪い。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と骨も砕くる背に被いで、戦くばかり身を揉むと、「意地が悪いわ、突張るんだもの。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のつむじがここらに（手真似にて）こう曲がっている奴はかならず意地が悪い。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "申し上げないでおりますのも意地が悪いようにとられることですし、困ってしまって上がったのでございます」　微笑を見せながらそのあとを大輔は言わない。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつてＹ―さん、づゐぶん私には皮肉だつたぢやないの、私が親しまうとしても、いつでも意地が悪いんだもの。",
              "citation": {
                "source": "草いきれ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと、めんどうを見てくれていますか」　これは、新入生と服部の両方に対して意地が悪い。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やがて、「どうも君は意地が悪い。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "血のめぐりが悪いのか、あるいは意地が悪いのか、こういう場合にも彼はさのみに慌てている様子もみせず、いつもの足取りで徐かに歩いて来るらしいのが、又もや長三郎を焦燥たせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺も意地が悪い。",
              "citation": {
                "source": "夏ちかきころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はこれで、仲々意地が悪いよ。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう今から予定を変へられて耐るもんぢやない」「ぢや、赤羽根まで行つて、木賃宿へでも泊らうか」「随分意地が悪いな」「だつて仕方がないぢやないか」　二人は砂地の疲れを十分癒して、ゆつくり休んでからその家を出かけた。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "「随分、あのお粒つて女、意地が悪いのねえ、たまンないわ、あンなの‥‥どんなところにも悪型つてゐるものなのね。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フフフ……」「どうも貴方は意地が悪いんですなあ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "関さんも甚だ意地が悪いのだ。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　私は、入って来た時、よっぽど、あの潜戸の猿を落して、母親に閉め出しを食わしてやろうかと思ったが、それも、あんまり意地が悪いようで、それまでにはし得なかった。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣席のすることはどうしても意地が悪い――もしその中に自分の素性を知った者があっての上ですることではなかろうか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠枝　　漫画家つて、何うしてかう、意地が悪いんでせう。",
              "citation": {
                "source": "喧嘩上手",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女のずるさを見抜くところも、シンラツで、意地が悪いが、又、めざましい。",
              "citation": {
                "source": "由起しげ子よエゴイストになれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地が悪いようですが、堅くおことわり致しますよ」　亮作は無言であった。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地が悪いっていうよりゃ、気が利かないってほうですし、それに、大事をしでかそうったって、ああ尻が重くっちゃ」　時として、彼女は、あっさり承認する――　もし彼に、けちな虫さえつかなければ、やがては、羽振りを利かす人間になるだろうと。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "クララの説によると黒い眼の子は意地が悪い、人がよくない、猶太人かジプシイでなければ黒い眼色のものはない。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥さんはずいぶん意地が悪いですね」「どうして？",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方の御年歯を伺ったのが意地が悪いの」「そう云う訳でもないですが、何だか意味のあるような、またないような訊き方をしておいて、わざとその後をおっしゃらないんだから」「後なんかありゃしないわよ。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お見それして、すみません」　このひとたちは、どうしてこう意地が悪いのだろう。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……意地が悪いでしよ？",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
