        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「早いもので、私もとうとう五十路を迎えることとなりました」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "五十路を過ぎて、ようやく自分の本当にやりたいことが見つかった気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は五十路を迎えてなお、現場の第一線で後輩たちを鼓舞し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "五十路の坂に差し掛かり、以前よりも体力的な衰えを意識する場面が増えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「五十路の手前で一念発起し、海外留学に挑戦することに決めました」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "四十路から五十路へと移り変わる時期は、家庭環境や仕事の役割が大きく変化する転換期でもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "五十路の夫への誕生日プレゼントとして、少し上質な万年筆を贈ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "）都路は五十路あまりの三つの宿、……公子　おお、それだ、字書のように、江戸紫で、都路と標目が出た。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しかる我やとも、えは求め得ず、常こがれ果敢なみしもの、子らが爲め、五十路近く、やうやうと手に入りにけり。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しかる我やとも、えは求め得ず、常こがれ果敢なみしもの、子らが為め、五十路近く、やうやうと手に入りにけり。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は五十路ばかりにて頭の霜繁く夫よりは姉なりとぞ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿五年勤続の祝いも五、六年前に済んで、もうやがて五十路にも近かろう。",
              "citation": {
                "source": "大橋須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄干にあらわれたるは五十路に近き満丸顔の、打見にも元気よき老人なり。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "この尼法師、年はもはや五十路を越えているが、その容貌はつやつやしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十路を越えて、まだこんなに水々しいところが何よりの証拠で、都にあって祇園精舎の鐘の声を聞くよりは、ここに閑居して沙羅双樹の花の色の衰えざるを見ていたい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、母公としては、それも気のすすまない顔で、「聞けば、劉玄徳とやらは、年も五十路というではないか。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――身はいまだ無病、年も五十路の前、今にして、その任におこたえしなければ、やがて老いては、如何に思うとも、これを微忠にあらわすことはできなくなりましょう。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにせん、この病体」「なんの、お父上とて、まだ五十路、御養生次第では」「は、は、は……。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個の大器が、百戦百難の風雪を凌いで、年もようやく五十路に入り、いよいよその風貌にも年輪の威を加えてきたものとみな頼もしく見ていたのである。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物語に題は通えど、これは東の銭なしが、一年思いたつよしして、参宮を志し、霞とともに立出でて、いそじあまりを三河国、そのから衣、ささおりの、安弁当の鰯の名に、紫はありながら、杜若には似もつかぬ、三等の赤切符。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
