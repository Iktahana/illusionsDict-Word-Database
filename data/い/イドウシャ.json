        "examples": {
          "standard": [
            {
              "text": "工場内の搬送ラインで、自動制御の移動車が部品を運んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "製鉄所の熱い鋼材を運ぶため、耐熱仕様の移動車が稼働している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「次の工程まで、この移動車に載せてスライドさせてください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "）一、右の三項の間、演出助手、カメラマン、照明部、録音部、大道具、小道具、移動車の係などそのときの仕事に関係あるものは残らず手を休め、静粛にこれを注視している。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
