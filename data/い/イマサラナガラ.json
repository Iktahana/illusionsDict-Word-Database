[
  {
    "uuid": "d67ec5d2-fd63-5791-ac8b-bec4152a3c14",
    "entry": "今更ながら",
    "reading": {
      "primary": "いまさらながら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
