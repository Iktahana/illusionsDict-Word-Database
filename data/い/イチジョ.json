[
  {
    "uuid": "930eccc9-bc03-5f03-9a19-2f6381c262f9",
    "entry": "一助",
    "reading": {
      "primary": "いちじょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(some small) help",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "本報告書の内容が、貴殿の今後の研究の一助となれば幸いです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "皆様から寄せられた義援金は、被災地の復興の一助として役立てられます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "正確な情報の共有は、風評被害を未然に防ぐための一助となるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ささやかな品ですが、新生活の一助としてお使いください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この新制度が、深刻化する少子化問題の解決の一助となることが期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "私の拙い経験談が、皆様の将来のキャリア形成の一助になればと願っております。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "社内の業務効率化の一助とするため、最新の管理システムを導入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "全集が弘く読まれる事を希望しつつ、広告の一助にもと一寸一言申述べます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の譬喩は拙ではあるが、ルクレチウスが現代科学に対して占める独特の位地を説明する一助となるであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、もともと、家庭教師を呼ぶ事には反対だったのですが、沢田先生のおくらしの一助という名目に負けて、おいでを願う事にしていたのであって、まさか、そんな無責任な綴方教育を授けているとは思いも寄らず、毎週いちど、少しは和子の学課の勉強の手伝いをして下さっているものとばかり思っていた様子でした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヱジプトでは四年に一度天狼星が日の出と同時に現はれるので、かうした天文現象の文献が古代埃及の年代を計算する一助となつてゐるといふことである。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此中プチアリンは消化作用の一助をなすに止まり、ムチンは蓋し外物の強烈の刺激を緩和する為に存せりと覚しく、味を解きて人に伝ふるものは、実に水の力なり。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の頃、私はパラオ民俗を知る為の一助にもと、民間俗信の神像や神祠などの模型を蒐集していた。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに万一助からなくたって責任は無い。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ貴殿の一助たるべきか」と言って来た。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に残ったのはただ一人第一助手だけであった。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりわが友人の辣腕の一端を知らしめる一助となるのであるから。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "願う、余の慈父と師友との祈祷空しからずして、この著のさらに世の憂苦を除き去るの一助として存せんことを。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの菌は、米国植物興産局の当事者たるスウィングル氏（予と同時にフロリダにあって研究した人）も近年予に聞くまで気付かなんだらしいが、予は三十年前から気が付きおり、染料として効果著しきもので、貧民どもに教えて、見るに随って集め蓄えしめたら大いに生産の一助となる事と思う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三年前、文学における古典の摂取が云われはじめた時分は、プロレタリア文学運動の退潮を余儀なくさせた社会事情が他面対立的な文学にも貧困の自覚を与えており、それに対して文芸復興が唱えられ、古典の摂取は、当時にあっては、現代の文学的発展のための一助として、教養として云われていたのであった。",
              "citation": {
                "source": "文学上の復古的提唱に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人にわからない文壇生棲間のもつれでもあってのことだろうが、この全く非文学的なセンセーションは作者が希望するしないにかかわらず「絶壁」を問題作とする一助となり、モデルであると名のり出た人々を脚燈の前に立たせた。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "産児制限と国の工業化が解決の一助だろう」。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この定斎、それほどに利くか利かぬかは姑く問題の外として、かくも江戸ッ児に調法がられるこの持薬で、三百年来事欠かなんだ吾儕の祖先をおもうと、その健康、その体力、恐らくはかれら気で気を医し、むつかしく言えば所謂精神療法の一助として、不知不識にこの定斎を用い来たったのであろう。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "この硯はながらく私の側にあって、今でも私の絵の一助をつとめていますが、この硯をみるたびに中島先生のご恩をしみじみと感じるのであります。",
              "citation": {
                "source": "あのころ",
                "author": "――幼ものがたり――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな慌しい書き方をした文章でも、江口を正当に価値づける一助になれば、望外の仕合せだと思っている。",
              "citation": {
                "source": "江口渙氏の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらも、香水選択の一助となるだらう。",
              "citation": {
                "source": "「香水の表情」に就いて",
                "author": "――漫談的無駄話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコで講師の交換でもすれば、幾分か両者間の誤解を釈く一助にもなろうかと考えるものがあるに至った。",
              "citation": {
                "source": "人格を認知せざる国民",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本が長い間世界から孤立していたのは、自省をする一助となって茶道の発達に非常に好都合であった。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令い斯くまでの極端に至らざるも、婦人の私に自力自立の覚悟あれば、夫婦相対して夫に求むることも少なく、之を求めて得ざるの不平もなく、筆端或は皮肉に立入りて卑陋なるが如くなれども、其これを求めざるは両者の間に意見の衝突を少なくするの一助たる可し。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に世上｜有志の士君子が、その郷里の事態を憂てこれが処置を工夫するときに当り、この小冊子もまた、或は考案の一助たるべし。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にこの冊子、たとい今日に陳腐なるも、五十年の後には却て珍奇にして、歴史家の一助たることもあるべし。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお下りて筋骨の丈夫なる者は腕押し、枕引き、足｜角力も一席の興として交際の一助たるべし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "がそれは先ず私の船の阿呆らしい航海日記とか航海のうちに感じた事柄を記してこれから乗船せんとする人、あるいは已でに乗り込んで間のない人たちへ報告して多少の参考ともなり、心の準備の一助とかあるいは長途の旅の講談｜倶楽部ともなれば幸だと思う次第である。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、一度封を切った作品はも早や古手となってしまって二度の勤めは嫌がられる傾向を持ったりするので、勢いその絵は小品ならば万一にでも生活の一助とならぬ事もないが、大作であったりしては、画室で埃をあびて重ねられて行く。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "この猥談が若し温故知新の一助となり、猥談が必ずしも猥談のみに終らなかつたならば、望外の幸である。",
              "citation": {
                "source": "支那猥談",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府は、父君が、保守家ゆえ、わしを立てて、幕府の進歩的方針の一助にしようと、考えているらしいが、問題は、開国するか、せぬかの一つではない。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
