          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は国内でも一二を争う腕利きの外科医として知られ、全国から難手術の依頼が絶えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この地域は県内でも一二を争う豪雪地帯であり、冬場の除雪作業は住民にとって死活問題となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は党内でも一二の有力者と目されており、その一挙手一投足が政界全体の注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今回の経営再建において、不採算部門の切り出しは優先順位の一二に置くべき最重要課題です」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その老舗旅館は、この温泉街でも一二を争う格式の高さを誇り、古くから多くの文客に愛されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "我が社の基幹製品は、北米市場において一二のシェアを長年維持しており、極めて高い競争力を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（一九三七・七・一二）",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三六・一二・二四）",
              "citation": {
                "source": "夏の夜の博覧会は、かなしからずや",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお恵みが下ります時には、やさしくうつくしい夜の歌と櫂歌とをうたはうと思つてをります……（一九二九・一二・一二）",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三六・一二・一一）",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "………（一九二四・一二・二九夜）",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に一二度見ただけだから、もう大部分は忘れてしまったが、夢のような記憶の中を捜すとこんな事が出て来る。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その好例は赤石山（三一二〇米突）の赤石沢などで、およそ山巓から三百米突も下まで、大崩石で埋まっている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "落日の華やかさもなく、けさがたからの風は蕭々と一日じゅう吹き続けたまま暮れて行くのであるが、翁には心なしか、左手の垂れ雲の幕の裾が一二尺｜掠り除れて行くように思われた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は翁は一日歩いて、また一二尺掠り除かれた雲の裾から山の麓を、より確かに覗き取ったが、歩めども歩めども山の麓の幅の尽きらしい目度を計ることができなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "組んだ指の一二本だけ、組み堅め方を緩めて、ひょくひょく蠢めかしているのは、娘が何を言い出すことやらと、まだ、親振った軽蔑の念と好奇心と混ったものを山の祖神がいささか心に蓄えていることの現れと見れば見られる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴海はもう名物の絞りを売っている店は一二軒しかない。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、おれ先に叫ぶから、みんなあとから、一二三で叫ぶこだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一一年にはプラーグの正教授に招聘され、一九一二年に再びチューリヒのポリテキニクムの教授となった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や予が生活を得るまでには猶少くも三四年は間があって、母の命八十を必し難しとすれば、予は自分の功名心や、遠い先の幸福などに望を掛けて、大きな考を起す暇がないのである、年少気鋭の時代は何人にもある、予と雖も又其の内の一人であれば、外国へ飛び出さんとの念を起せるも一二度ではなかった。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『万葉集』の第七巻の歌 （一二三九番）に「浄奚久」とあるのを「サヤケク」と訓してあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛籠の底に納めたりける一二枚の衣を打かへして、浅黄ちりめんの帯揚のうちより、五｜通六通、数ふれば十二｜通の文を出して旧の座へ戻れば、蘭燈のかげ少し暗きを、捻ぢ出す手もとに見ゆるは殿の名。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一二年の暮にレーリーの末男が死んで、幸福な彼の晩年にも一抹の黒い影がさした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに此等の青年たちは、最近一二の雜誌に現はれた詩によつて、始めて蒲原有明なる名前を知り、自分等より尚後輩の新進詩人――老年の新進詩人――と思ひ込んで居るのだらう。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば最も多作な天才と雖も、一生に眞の名詩集は僅か一二册しか書いてゐないことがわかる。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二三で鉢巻をして手を叩く遊戯。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那で一二と云う支那料理店があると云う話です。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "○舞台は一二分間空虚になりおる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、餘儀なくされてゐた長い中絶のおかげと、それから非常に價値はあるのだが何としても一九一二年の日付をもつてゐる諸感動の上に立ち戻らねばならないので、私は異常な立場に陷つてゐるのです。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悲歌」は一九一二年（ドゥイノで）著手せられ、その後スペインや巴里で一九一四年まで斷片的に書き繼がれてをりましたが、戰爭がこの私の最大の仕事を完全に中絶せしめたのでした。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭五・一・二〇）　現住所　麻布區新龍土町一二",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが大｜概一｜局に一時間乃｜至一時間半、一二度は三時間餘にも及んだことがあるのだが、さう鋭くもなく敢へて奇手｜妙策も弄せず靜かに穩かにもみ合つてゐる光｜景たるやたしかに「櫻かざして」の感なくもない。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後のブルジョア文学は、一二の作品で農民を題材としていることがあっても、ほとんど大部分が主として、小ブルジョア層や、インテリゲンチャにチヤホヤして、農民をば、一寸、横目でにらんだだけで素通りしてしまった。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『一二｜度行つた事があります。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店のをばさんが、だいいちに心配しはじめた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆景春夏すぎて手は琥珀、瞳は水盤にぬれ、石はらんすゐ、いちいちに愁ひをくんず、みよ山水のふかまに、ほそき滝ながれ、滝ながれ、ひややかに魚介はしづむ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
