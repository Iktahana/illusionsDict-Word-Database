[
  {
    "uuid": "3245a4d0-9a1a-5899-985d-b0b54c7c5022",
    "entry": "医学者",
    "reading": {
      "primary": "いがくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
