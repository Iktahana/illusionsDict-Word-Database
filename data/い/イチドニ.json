          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このソフトウェアを使えば、全てのデータを一度に分析できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この料理を作る際は、全ての香辛料を一度に加えます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の停電により、町中の明かりが一度に消えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「一度に全部理解するのは難しいから、少しずつ進めよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "一度にたくさんの荷物を持とうとすると、落としてしまうかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その印刷機は、一度に100枚の用紙を処理できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "原材料価格の急激な上昇は、一度に全ての製造業者に影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いろんな詩の方法が一度に三つも四つも私に見えて来て僕はもう此の一文を打切ります。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまれ、一度に改まりもしまいが、なるべくはよいやうにと、詩稿の事も少しは考量に入れなくては、不可まいではないか。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴場へ行って清澄な温泉に全身を浸し、連日の疲れを休めていると、どやどやと一度に五、六人の若い女がはいって来て、そこに居たわれわれ男性の存在には没交渉に、その華やかな衣裳を脱いで、イヴ以来の装いのままで順次に同じ浴槽の中に入り込んで来た。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の動物園の森で一度に鳴き出す色々の鳥類のけたたましい声が聞こえる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の視線一度に此方へ向かえば新郎のパナマ帽もうつむきける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身の血が一度に血管を破つて体外にほとばしり出たやうな感じがした。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしい悲しみと、歯噛みしたいような憤怒とが、一度に彼の腹の底からこみ上げて来た。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの品数を一度に容れ得る「鍋」を自分は持っているだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯々面白いのは、此の何萬囘の足音が一度にかたまつて發しないで、實にうまく一樣に時間的に配分されて、勿論多少の自然的偏倚は示しながらも統計的に一樣な毎秒平均足音數を示してゐることである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一度にもっと渾然として而も純粋で爽かな充足を欲した。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二人は一度にはねあがってドアを飛び出して改札口へかけて行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二人は、まるで一度に叫んで、そっちの方へ走りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとみんなは、ぼちゃんぼちゃんと一度に水にすべって落ちた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私どもは一度に叫びました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空がくるくるくるっと白く揺らぎ、草がバラッと一度に雫を払いました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして美しさの頂点に達したときに一度に霜に殺されるそうである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が付いたら室町の三越の横を走っていたので、それではじめてあらゆる幻覚は一度に消えてしまって単調な日常生活の現実が甦って来た。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の手前兄夫婦の手前、泣くまいとこらえてようやくこらえていた僕は、自分の蚊帳へ這入り蒲団に倒れると、もうたまらなく一度にこみ上げてくる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのお手紙をお富が読みましたから、誰も彼も一度に声を立って泣きました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィッチを入れると数十の電燈が一度に灯ると同じように、この植物のどこかに不思議なスウィッチがあって、それが光の加減で自働的に作用して一度に花を開かせるのではないかと思われるようである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、空の光の照明度がある限界値に達すると、多分細胞組織内の水圧の高くなるためであろう、螺旋状の縮みが伸びて、するすると一度にほごれ拡がるものと見える。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光の加減で烏瓜の花が一度に開くように、赤外光線でも送ると一度に爆薬が破裂するような仕掛も考えられる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全級一度に教授することによって教員の手が明く。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "叺のような物に母貝を沢山に並べたのを一度に写真にとる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は二人一度にズバリ――　平土間騒然たり。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、一度にはちっと問題が大き過ぎますね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）よくまあそんなに何もかも一度にお話しなさる事が出来ましたのね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "河面一面にせり合い、押し合い氷塊は、一度に放りこまれた塵芥のように、うようよと流れて行った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いますぐいちどに、すべて問題を解決しようと思うな。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちょうの実はみんないちどに目をさましました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
