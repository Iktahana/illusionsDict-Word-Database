    "definitions": [
      {
        "index": 1,
        "gloss": "hand-clapping performed to celebrate the conclusion or completion of something (3-3-3-1 rhythm, done once)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議の終了後、参加者全員で一本締めを行い、プロジェクトの成功を祈願した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「それでは、皆様、盛大なる拍手で、我らがヒーローに一本締めをお願いします！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "宴もたけなわではございますが、ここで一本締めで、本日の幕を閉じたいと思います。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "single clap after a cheer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「やったー！」と叫んだ後、彼らは興奮冷めやらぬまま、勢いよく一本締めをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「よし、これでよし！一本締め！」と、チームメイトとグータッチをしてから、軽く手を叩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プロジェクトが無事完了し、皆で「お疲れ様！」と声をかけ、最後は一本締めで締めくくった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
