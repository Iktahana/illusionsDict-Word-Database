    "definitions": [
      {
        "index": 1,
        "gloss": "sentence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明日の午前十時から、東京地裁にて被告人に対する判決の言い渡しが行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裁判長から懲役三年の実刑判決の言い渡しを受け、被告は法廷で崩れ落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "上司から突然の解雇の言い渡しを受けた彼女は、震える声で「承知いたしました」とだけ答えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "審判員による失格の言い渡しに納得できず、選手は競技場の真ん中でしばらく立ち尽くしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "懲戒免職の言い渡しに際し、その根拠となる事実が当局から淡々と読み上げられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まさか、ここで有罪の言い渡しを受けることになるとは……」と、彼は裁判所の前で力なく呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "命令の言い渡しは、本来であれば全職員が揃った場で行われるべき重要な手続きである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "でも明日は先生の公判の判決の言い渡しがあるらしいの。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、明日は演出家の田村が検事局で判決の言い渡しがあるので来られないだろう。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、美術学校にはいりたかったのですが、父は、前から自分を高等学校にいれて、末は官吏にするつもりで、自分にもそれを言い渡してあったので、口応え一つ出来ないたちの自分は、ぼんやりそれに従ったのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と実に威張って言い渡した。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と口を曲げて憎々しげに言い渡した。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は薄笑いして、勝治の目前で静かに言い渡した。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三時間温泉にいるんですよ」　温灸という言葉ならあるが、温泉灸療法とは変な言葉だと、われながら噴きだしたくなるのをこらえこらえ、おごそかに言い渡したものだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで佐佐は何やら取調役にささやいたが、まもなく取調役が町年寄に、「御用が済んだから、引き取れ」と言い渡した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "召されて劉が出頭すると、太守はおごそかに言い渡した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかった、えらい、もう用はなかろう、お帰りお帰り、源太が大抵来るかも知れぬ、撞見しては拙かろう、と愛想はなけれど真実はある言葉に、お吉｜嬉しく頼みおきて帰れば、その後へ引きちがえて来る源太、はたして清吉に、出入りを禁むる師弟の縁｜断るとの言い渡し。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "毘女｜其式の裁判は朝飯前の仕事と答えて夫に教え、大薬妻の教えのままに翌日商主の五馬を牽き来て池辺の岩上に立たせ、水に映った五馬の影を将去れ、〈もし影馬実に持つべき者なしと言わば、夢中行欲の事もまた同然なり〉、と言い渡したので、国王始め訴訟の当人まで嗟賞やまなんだという。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節柄そんな噂を伝えると、それから又いろいろの間違いを生ずるというので、司令部では固く秘密を守るように言い渡したのであるが、問題が問題であるだけにその秘密が完全に防ぎ切れないらしく、将校たちはさすがに口をつぐんでいても、兵卒らは佐山君にみな打明けて話した。",
              "citation": {
                "source": "火薬庫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "師冬はおごそかに彼等に言い渡した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小坂部はおごそかに言い渡した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "判決言い渡しの日は、この次の月曜日ということになって、法廷は閉じられました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "月曜日の午前、予定の通り、ジゴマ中学生の判決言い渡しがありました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「被告｜何某を禁錮一年に処す」という主文の宣告があった後、いくら待っても、執行猶予の言い渡しが続きませんでした。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "放免するとき、右門は姉妹たちに寂しい声で言い渡しました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "（独醒雑志）　　　紅衣の尼僧　唐の宰相の賈耽が朝よりしりぞいて自邸に帰ると、急に上東門の番卒を召して、厳重に言い渡した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はやはりきのうの通りの姿で、彼にむかって言い渡した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんじの罪は斬に当る」と、天師はおごそかに言い渡した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときに、魚は甕のなかからしきりに哀れみを乞うと、天師はまた言い渡した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節柄そんな噂を伝えると、それから又いろいろの間違いを生ずるというので、司令部では固く秘密を守るように言い渡したのであるが、問題が問題であるだけにその秘密が完全に防ぎ切れないらしく、将校たちはさすがに口をつぐんでいても、兵卒らは佐山君にみな打ち明けて話した。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "退かれませ」　彼女は命令するようにおごそかに言い渡した。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝太郎も一緒に来やれ」　改めてなんの言い渡しはなくとも、これで彼の勘当はゆるされたのである。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠るな」と、泰親はかさねておごそかに言い渡した。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏はしても父の名に泥を塗るなと、千歳を出る時きびしくいいわたした父の言葉も思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一が、舎監の指し示した折り畳みイスに坐ると、「きてもらったのは、きみの部屋のことだ」　と、きびしい顔つきで慶一の目を見て、寮長がいいわたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな……」「いいから、いこうぜ」　高志が、議論はおしまい、という声でいいわたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "できはどうあれ（高志自身、慶一やワラや山崎に、これについて、ひとことでも感想をいったら、たとえそれがほめ言葉でも、二度と四〇七の秘蔵食料は食べさせない、といいわたしたぐらいだ）、テレビの画面にキャンパスや子どもたちが映っているので、父兄たちはけっこう楽しんだようだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
