        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一体全体、こんな夜中に何の用だ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あれほど反対していた彼が、なぜ急に賛成に転じたのか。一体全体、理解に苦しむ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この難解な古代文書は、一体全体、誰が何のために書いたのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「お前は一体全体、自分の立場を分かっているのか！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "もつと悪い場合を想像すれば、文学の雑文を書かうとして、何の文学に関するネタもない所から、どうも鬱々として、その揚句、「一体全体文学が陰気だぞ！",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その由を弁解したら、それもさうかと一応は分つたらしかつたが、それでも猶そのお説教を続けるのは、僕にやつぱり一体全体「誠意がないのか」それとも、大概の老人がさうであるやうに、たゞもう剛情なのか。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体全体、猪口兵衛どん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お丹真顔になりて、「だがね、皆で頂戴いたしますというと黙ってどこかへお隠れなすったから可いのだろうと思いまして……」　巡査はじれ込み、「一体全体ここをどこだと思っちょるんだ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一体全体どんな情景をこのブリキとカンナ屑の都から摘出しようとこころみているのかしら？",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体全体何んでもドンゾコまで分ッてる世界ではない。",
              "citation": {
                "source": "ねじくり博士",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体全体百姓を廃めて、皆んな商人になれなんて、何処の世界にそんな馬鹿な話があるんだ。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何をどうしていいか、自分自身が何であるか、一体全体どうしたらいいんだか、さっぱり一切がわからなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたつてえんだよ、一体全体……」と祖母は呟きながら、ちよつと母の方を見て「近所にみつともないぢやないか。",
              "citation": {
                "source": "疳の虫",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "築土新吾殿、一体全体、獲物というのはどんな物でござるな？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体全体なんのために、こんなところにいたのだろう？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一体全体どうしたんだ、どうして刀が重いんだ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体全体何がなんでえ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体全体菊というものは、一本の淋しきにもあれ千本八千本の賑しきにもあれ、自然のままに生茂ッてこそ見所の有ろう者を、それをこの辺の菊のようにこう無残々々と作られては、興も明日も覚めるてや。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は金庫が開かないのだ」「えッ、金庫が……」と中谷氏――そういえば思いだしたが、この人は助役の中谷銃二氏に違いない――が愕いて「そりゃまた一体全体どうしたんです。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを無くしたとは、一体全体何ごとだ！",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一体全体どうなるのか。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体全体どんな農奴を手にお入れになったかってことをさ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所長はテーブルに近づくなり、最も強い苦蓬入りのウォツカを一杯ついで、『わしは一体全体、あのチチコフという男が何者なのか、ぶち殺されたって分りませんよ』と言った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもやソモソモ一体全体。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙、不思議じゃ一体全体。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもやそもそも一体全体。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "餓鬼のくせに驚き入った野郎だが、一体全体………………………があるもんかどうか――「聞かしてもらいてえもんだ。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体全体何事が起きたのだろう、私は英語で日本の公使館に電話で話させて下さい、と頼んだが、英語が通じません。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体全体何時何処で、どんな約束を致しましたので？",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもさ、一体全体、どいつがこんなことをしたんだろう。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体全体何んのために、そんな所へ行くのだろう」「それはね」と云ったが老婦人の声は、この時いくらか真面目になった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の玉がとび出るほどお金を取られましただ」「しかし、いったいぜんたい、お前のところの『ウィル旦那』は鎌や鋤なんぞをどうしようというのかね？",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいぜんたいどうしたんだ」　同僚が警笛を吹いたので、たちまち宿直の連中がかけつけて、人事不省の警官をとりまいて、元気をつけてやった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえヴィクトル、いったいぜんたい、どうしたんだ。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
