        "examples": {
          "standard": [
            {
              "text": "戦友たちが次々と倒れる中、生き残れたのは全くの命冥加に尽きる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "九十歳を過ぎてもこうして元気に畑仕事ができるなんて、本当に命冥加なことです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あんな大病を患って、また桜を見られるとは。命冥加なことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "妄念は起さずに早うここを退かっしゃい、助けられたが不思議なくらい、嬢様別してのお情じゃわ、生命冥加な、お若いの、きっと修行をさっしゃりませ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで命を預け置かむ、命冥加な老耆めが。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄念は起さずに早う此処を退かつしやい、助けられたが不思議な位、嬢様別してのお情ぢやわ、生命冥加な、お若いの、屹と修行をさつしやりませ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうとは存ぜず私は王様の力で、あの小アジアの市を木端微塵に叩き毀していただきたいと存じ、それをお願ひに上つたのでござりますが、お言葉を承はつてみればそれも致方のないこと、早速｜生命冥加な市に告げ知らせるでござりませう。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "送るものは、早く癒って、また帰って来なさいと、主侯夫妻まで部屋に来て見送ってくださったが、命冥加にもどうやら命はとりとめた。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽め、命冥加な」　良輔が呟きつつ、ついて行った。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「併し、わしも、命冥加だぞ」　大作が、振向いて、笑った。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「命冥加な大工め。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、五間向うに、数羽の雛とともに戯れている雷鳥、横合から不意に案内者が石を投じて、追躡したが、命冥加の彼らは、遂にあちこちの岩蔭にまぎれてしまう。",
              "citation": {
                "source": "穂高岳槍ヶ岳縦走記",
                "author": "鵜殿正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "命冥加な奴だ」　しかし直家のこの考えは一ヶ月経たずに裏切られた。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "命冥加の坊主だよ」　途端に、人影バラバラと物の影から現われたが、「姐御、駕籠に召しましょう」　ズラリ駕籠を取り巻いた。",
              "citation": {
                "source": "村井長庵記名の傘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "命冥加と思うがいい」　人丸左陣は痛快そうにこう小声で罵りながら先へ立って走り出した。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに懲りて以後気をつけい――命冥加な奴め。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生きてゐたのか平次、命冥加な奴だ」　苦りする御家人喜六、右手の刄は、油斷なく灯にギラリとうねります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生きていたのか平次、命冥加な奴だ」　苦りする御家人喜六、右手の刃は、油断なく灯にギラリとうねります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工｜棟梁の広瀬大膳と、奉行の藤木権之助は、「命冥加な奴めが」と、捕えておいた河和田の平次郎の側へ来て、懇々と、説諭を加え、「上人の有難いお旨を、忘れるでないぞ」と、いい聞かせた上、縄を解いて、放してやった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖める遑もなくそれを茶碗で酌み交わして、「どうも、業腹でならねえ」　とか、「忌々しい若造だぞ」　とか、「命冥加な野郎だ」　などと、後のまつりに過ぎない繰り言を肴にして、「親方、腹をすえておくんなさい、戸外を見張っていた奴がどじだったんで」　と、彼を酔わせて、先へ寝かすことにみな努めた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが命冥加な野郎でごわすな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこれが兄上でなく、正季の手で汝を処分していたなら、その素ッ首は、無事に、尊氏の許へは返されまい」「…………」「命冥加な奴ではある。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
