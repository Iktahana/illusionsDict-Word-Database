[
  {
    "uuid": "ff53f224-1b23-53fe-8aec-c48f5e407f32",
    "entry": "異常性",
    "reading": {
      "primary": "いじょうせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
