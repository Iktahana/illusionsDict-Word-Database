          ],
          "literary": [
            {
              "text": "あまりばかばかしくて、行末のことも案じられ、もうこの上は、庭の木の枝にぶら下るか、顳※にずどんと一発やるか、或は両国橋あたりから身を投げるかするより外はあるまいと、さんざん思い悩んで、仕事もせずのほほんとしていた。",
              "citation": {
                "source": "失策記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子バクダンを自分のキライな奴の頭の上でドカンと一発やることについて、その本性に於ては人をはばかり世をはばかるところはない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）いいかね、君がもし、どうあっても自殺したいと言うのなら、森の中へ行って、ずどんと一発やるがいいさ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
