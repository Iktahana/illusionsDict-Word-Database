          "literary": [
            {
              "text": "」「生き顔より、死に顔のほうがよいようじゃな。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "病には命換ふやとかなしみき生き顔を見る老のうれしさ除夜に、人の家に宿りて。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            }
          ]
