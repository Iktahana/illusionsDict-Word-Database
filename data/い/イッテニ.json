    },
    "definitions": [
      {
        "index": 1,
        "gloss": "single-handedly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は若くして会社の経営を一手に引き受けることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のイベントの企画から運営まで、彼女が一手に担当することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その難問の解決は、すべて彼に一手に任されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害時には、ボランティア団体が被災地への支援物資の配給を一手に担った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それに今まで聞えなかったかすかな音もみんなはっきりわかり、いろいろの木のいろいろな匂まで、実に一一手にとるやうです。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつおまえさんあれを一手に引き受けて遺作展覧会をやる気はありませんか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは黙つて茶をのみながら其処らを見まはすと、菓子や果物のほかに軽い食事も出来るらしいが、家内は夫婦と娘の三人きりで、主人が料理を一手に引受け、女房が勘定をあづかり、娘が給仕をするといふ役割で、他人まぜずに商売をしてゐるらしい。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪野は小さい時分から、米の大問屋へ奉公にやられ、機敏に立ち働き、主人の信用を得ていたが、主人が亡くなり妻の代になってから、店を一手に切りまわしていたところから、今までの信用を逆に利用し、盛んに空取引の手を拡めて、幾年かの間に大きな穴をあけ、さしも大身代の主家を破産の悲運に陥れたものであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "分家も方々に散らばっており、息のかかった人たちも多いので、その附近の地盤を堅めるのに、その勢力はぜひとも必要であり、投票を一手に集めるのにその信望は利用されなければならなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂田は第一手に、九三の端の歩を九四へ突いたのである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "平手将棋では第一手に、角道をあけるか、飛車の頭の歩を突くかの二つの手しかない。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、第一手に端の歩を突くのは、まるで滅茶苦茶で、乱暴といおうか、気が狂ったといおうか、果して相手の木村八段（現在の名人）は手抜きをした。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、続く対花田戦でも、坂田はやはり第一手に端の歩を突いた。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、安井左近大夫、原彦次郎等もようよう引退いて、盛政と一手になったので、盛政少し力を得て、清水谷の峠へ退いて備を立直そうとしたが、秀吉の軍は矢鉄砲を打って追かけるので、備を直す暇もなく崩れた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "将棋のほかには常識も理論もない人、――といふだけでも相当難物だが、しかもその将棋たるや、第一手に角頭の歩をつくといふ常識外れの、理論を無視したところが身上の人である。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時電気通信を一手に握っていたＡＴ＆Ｔは、独占禁止法の縛りによってコンピューターへの進出を禁止されていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにそもそも、さまざまなマイクロコンピューターの右総代となって人間様とのインターフェイスを一手に引き受けるべきパーソナルコンピューターが、なっとらん。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども慧き畔柳は事の密なるを策の上と為して叨に利の為に誘はれず、始よりその藩士なる鰐淵｜直行の一手に貸出すのみにて、他は皆彼の名義を用ゐて、直接の取引を為さざれば、同業者は彼の那辺にか金穴あるを疑はざれども、その果して誰なるやを知る者絶えてあらざるなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには専属の技師のほかに、滝口立山の両坑を随時一手に引受ける、謂わば技師長格の菊池技師が、数日前から行っている筈であった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "剰す所は燕麦があるだけだったが、これは播種時から事務所と契約して、事務所から一手に陸軍｜糧秣廠に納める事になっていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも知らずに十郎次は、菊路の巧みな誘いの一手に汚情を釣り出されたとみえて、ますます色好みらしい面目をさらけ出しました。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のいない世帯のことを一手に引受けて、そのあいだには畑も作る。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階建で間口二｜間足らずの、細々と美しく飾りたてた明るい店で、まるで周囲の店々から零れおちるジャズの音を掻きあつめるように、わけもなくその横町の客を一手に吸いよせて、ぬくぬくと繁昌していた。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方は千二百｜刷つて居て、外に官衙や銀行會社などの印刷物を一手に引受けてやつて居るので、少し宛積立の出來る月もあると、目の凹んだ謹直家の事務長が話して居たが。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方は、千二百刷つて居て、外に官衙や銀行会社などの印刷物を一手に引受けてやつて居るので、少し宛積立の出来る月もあると、目の凹んだ謹直家の事務長が話して居たが。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「矢の倉まで行かう、風琴は持ち合さなかつたが、舟歌は一手に引きうけたぞ、ヘツヴ・ハウ、ヘツヴ・ハウ My heartful......sky wearing my solitary heart upon thy sleeve ……どんなもんだい。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地の理想を一手にかね備えた街を各民族が取り合いしないという筈はない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は地主で同時に村の日用品を一手に商ふ本家の伯父の家に寄食してゐた。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この村で酒、醤油などを一手に商ふ高田屋の店の前である。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中は激しい勤労奉仕が多く、ことに私の家では亭主が病んでいるため隣組のおつき合いは残らず妻が一手に引受けねばならず、見ていてはらはらするようなことが多かつた。",
              "citation": {
                "source": "わが妻の記",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵隊も呑気でいいなあ」と竹村君が云うと「あなた方も気楽でしょう」といってにやにやした。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞食ではねえだよ」といってにこにこした。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これならば十億キロぐらい離れても受影ができるよ）　といってにっこりとされた。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は強いて勇気を出して、「なアに、自分の家にいる心持さ」　独りごとをいってにっと笑いながら、抜き足さし足で食堂の方へ入って行った。",
              "citation": {
                "source": "空家",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
