[
  {
    "uuid": "94c605ba-7e54-5023-80bf-fae31334d67f",
    "entry": "一手に",
    "reading": {
      "primary": "いってに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
