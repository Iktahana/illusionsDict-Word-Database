          "literary": [
            {
              "text": "第三、医療制度の不徹底。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆の生活不安なるものの内には医療制度の社会的不備を含ませねばならぬ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "医療制度改革の運動家　シゲリストは医学史を単なる研究対象としてだけでなく医学の社会的な問題を解決する方法と考えていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "医療制度にたいするシゲリストの考えは著書「文明と病気」から知ることができる。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "医療制度にたいするシゲリストの考えは本書からも知ることができる。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
