          ],
          "literary": [
            {
              "text": "中には光線が森を射通す工合であろう、青だの、赤だの、ひだが入って美しい処があった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には光線が森を射通す工合であらう、青だの、赤だの、ひだが入つて美しい処があつた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五寸の的などに十本射通すがものはなかろうぞ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "烱々たる眼光が、白覆面を射通すように見すくめました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "射通すようにおそろしい主水之介の烱々たる眼光です。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者を見ると、チェスタートンで、紛うかたもない丸肥りの彼が、モヤモヤの髪の下に、心持三白の、射通す而も人間的な眼を耀かせて居る写真迄ついて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "覗ひを定めて幻影の金的の只中を射通す名手の矢先きにも等しい。",
              "citation": {
                "source": "谷崎潤一郎氏の作品",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しく錬磨を怠ったれど、桶皮胴の二枚｜肋、三つ重ねを一町先から裏掻しまでに射通すことさして困難とも覚え申さぬ、論より証拠、いざ、ご覧あれや」　声もろともに射出す征矢に先に進んだ騎馬武者一騎、真っ逆様に馬より墜ち、次に進んだ騎馬武者は馬もろともに倒された。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家光が茶碗を取り上げて、唇まで持つて行くと、宗壽軒の唇が歪んで、障子を射通すやうな瞳が、キラリと光ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金色の處女",
                "note": "青空文庫"
              }
            },
            {
              "text": "家光が茶碗を取り上げて、唇まで持って行くと、宗寿軒の唇が歪んで、障子を射通すような瞳が、キラリと光ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金色の処女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときたま眼が合うと通胤は父にむかって射通すような視線を向けた。",
              "citation": {
                "source": "城を守る者",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "理智的な引締った頬、美しい口髭、笑うと非常に愛嬌のある白い歯並、全体に親しみのある顔立ちであったが、その中に一重瞼の余り大きくない目だけが、時折り相手の腹の底を射通すような鋭い輝きを見せた。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村は来るたびごとにぜひ米国の医者に健康診断を頼んで、大事なければ思いきって検疫官の検疫を受けて、ともかくも上陸するようにと勧めてみたが、葉子はどこまでもいやをいいとおすので、二人の間には時々危険な沈黙が続く事も珍しくなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どの筋がそうどす――浮気するたらどこに書いとおす」　ひろ子は思う壺に嵌りすぎて、おかしいのと照れるのとで、少し赧くなりながら説明した。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそいでこないとおすまうがおくれるお弟子がむかへにピヨン　はね　ピヨン　はねピヨン　ピヨン　はね　はね蛙の　蛙の　関取ヤーイ。",
              "citation": {
                "source": "未刊童謡",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方法は二つあるから、どちらか一つを取ってごらんなさいとおすすめしようというのであります。",
              "citation": {
                "source": "俳句の作りよう",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各種のメロディを皆同じような調子で歌いとおすのは、学校向きとでも言おうか、少し飽気なくもある。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
