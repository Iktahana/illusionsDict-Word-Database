[
  {
    "uuid": "0c3e188a-9731-5bcd-b4ae-400a3077e584",
    "entry": "引見",
    "reading": {
      "primary": "いんけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "audience",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "丹泉の俗物でないことを知って交っていた唐氏は喜んで引見して、そしてその需に応じた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "巳の時の夫人には、後日の引見を懇請して、二人は深く礼した。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――梶鶴雄君は小生の教え子にて、学力優秀、品行方正にて家庭教師として最適の人物と愚考仕り候わば、宜しく御引見の上御採用下され度く願い上げ候……。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "直に引見されぬのは勿論上首尾で無い証拠だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は政宗を笠懸山の芝の上に於て引見した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉の前に景綱も引見された時、吉隆が、会津の城御引渡しに相成るには幾日を以てせらるる御積りか、と問うたら、小十郎は、ただ留守居の居るばかりでござる、何時にても差支はござらぬ、と云ったというが、好い挨拶だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "具平親王は文を好ませたまいて、時の文人学士どもを雅友として引見せらるることも多く、紀ノ斉名、大江ノ以言などは、いずれも常に伺候したが、中にも保胤は師として遇したもうたのであった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹泉の俗物で無いことを知つて交つてゐた唐氏は喜んで引見して、そして其需に応じた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソオル巡査部長、警察醫の三人はたつた二日前に老富豪がソオルを引見した書齋で暫く協議を重ねた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠三郎、大小を棄て、是非にと願うので、将監これを引見した。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "直木は、こゝで客も引見すれば、この卓子の上で原稿もかいた。",
              "citation": {
                "source": "碁の手直り表",
                "author": "菊地寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつを、二階の十畳の広間に引見した大人は、風通小紋の単衣に、白の肌襦袢、少々汚れ目が黄ばんだ……兄妹分の新夫人、お洲美さんの手が届かないようで、悪いけれども、新郎、膏が多いとお心得下さいまし。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ、自分が青年の名に依って尋ねて行けば、案外快く引見するに違いない。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、たやすく引見はしてくれましたが、結果は案外にも不首尾だったのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は、心を静めて、両氏を引見した。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本国政府は、この機に際し、親愛なる日本国民に敬意を表さんがため、記念塔を特に一等巡洋艦マール号に積載してお届けすることにしました」　とは、駐日某大国大使パット氏が、新聞記者団を引見して、莞爾として語ったところであった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ、自分が青年の名に依つて尋ねて行けば、案外快く引見するに違ひない。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "内閣の椅子を占めることに対して情熱を感じた左派のグループ中、加藤勘十と鈴木茂三郎等が中心となって外国記者団を引見し、社会党左派が共産党に接触を保ってきたのは、勤労大衆を同党の組合総同盟に獲得するためであった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して場外の名は京師に騒いで、大中四年に宰相になった令狐綯も、温を引見して度々筵席に列せしめた。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄機は人を屏けて引見し、僮僕に客を謝することを命じた。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは誰の紹介をも求めずに往ったのに、飯田さんは快く引見して、わたくしの問に答えた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次で蘭軒は文化三年に春水を広島の邸宅に往訪し、最後に四年に春風を長崎の客舎に引見したのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」余語等三人を引見したのは、自宅に於てしたらしくも聞えるが、或は天神下に舎つた後の事であつたかも知れない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山はこれを引見して語を交へた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山はこれを引見して話を聞いた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは奇異の念をなして引見した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋で弟の絶息した後、来弔の客を引見した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして客を引見した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百二十　わたくしは池田京水の孫全安さんを引見して、先づわたくしの京水の事蹟を探討した経過を語つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといういんけんな刑罰であろう。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
