        "examples": {
          "standard": [
            {
              "text": "海岸近くの公園には、大きな犬樟の木が数本生えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "犬樟の葉は、椿の葉に似て厚みがあり、光沢があるのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "春になると、犬樟の木に小さな白い花が咲き始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たぶの木は玉樟とも犬樟ともいふので樟科の、その葉の匂なども樟に似た木である。",
              "citation": {
                "source": "庭さきの森の春",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も多いのはたぶ、犬ゆづり葉の二種類で、一は犬樟とも玉樟ともいふ樟科の木であり、一は本当のゆづり葉の木のやゝ葉の小さいものである。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
