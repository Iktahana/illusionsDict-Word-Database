[
  {
    "uuid": "e35bd8e6-c775-5c41-b51b-4cda0c2bcc73",
    "entry": "異常者",
    "reading": {
      "primary": "いじょうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
