[
  {
    "uuid": "e50fe372-e511-5e23-9247-f8c23a11ee3f",
    "entry": "言い知れぬ",
    "reading": {
      "primary": "いいしれぬ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "連体詞"
      ],
      "ctype": null,
      "inflections": null
