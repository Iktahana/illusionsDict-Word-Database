    "definitions": [
      {
        "index": 1,
        "gloss": "indescribable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山頂から見下ろす雲海の景色は、まさに言い知れぬ美しさだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その絵画は、見る者の心を捉えて離さない言い知れぬ魅力を秘めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の努力が報われた時、彼は言い知れぬ喜びを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深い森の中で道に迷った時、言い知れぬ不安に襲われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "故郷の祭りで聞いた笛の音は、遠い記憶を呼び覚ます言い知れぬ郷愁を帯びていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "廃墟となった洋館には、言い知れぬ不気味さが漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの研究者が語る宇宙の真理には、言い知れぬ深みがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このワインは、一口飲むごとに言い知れぬ複雑な香りが広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だが彼が帰化を決心し、日本の土となることを覚悟した時、言い知れぬ寂しさとやるせなさが、心の底にうずつき迫るのを感じたであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち、言い知れぬ恐怖に、強く強く抱き合ったまま、身じろぎもせず、そのお庭の葉桜の奥から聞えて来る不思議なマアチに耳をすまして居りました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした雲の変化ほど見る人の心に言い知れぬ深い感情を喚び起こすものはない。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その闇のなかへ同じような絶望的な順序で消えてゆく私自身を想像し、言い知れぬ恐怖と情熱を覚えたのである。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの単調な謡いの節の一つ一つに言い知れぬ芸術的の魅力を含んでいる事がわかる。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓を構えて、矢を打ち番えて、引き絞って、的に中った音を聞いてから、静かに息を抜くまでの刹那刹那に、言い知れぬ崇高な精神の緊張が、全身に均衡を取って、充実して、正しい、美しい、かつ無限の高速度をもった霊的リズムの裡に、変化し推移して行く事を、自分自身に感ずるであろう。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "千軍万馬を往来した将軍の風格、狂瀾怒涛に慣れた老船頭の態度等に現わるる、犯すべからざる姿態の均整と威厳は、見る人々に言い知れぬ美感と崇高感を与える。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人翁に見送られて門を出て自動車に乗ると、さすがに主人翁の言い知れぬ平民的な好意ぶりに感謝する気になった。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に私の真正面に刻一刻と大きな形をあらわして来る真黒な鉄の車に対して言い知れぬ魅力を感じた。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の気なしに抛って置くと、いつの間にやら月は盥の中に丸く映っている」　普通のことのようですが、本当の体験を、月と盥に事よせて語っているので、普通の中に言い知れぬ趣があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限に対するこの懸命の働きそのものの上に、言い知れぬ悲壮な気持ちと、使命に殉じている安心光明が油然と胸中に湧くのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさの間に言い知れぬ恐怖と絶望に囚われたらしく、眼を真白に見開いて、一心に彼を凝視したまま、ハアハアと喘ぎつづけるのであった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤな事を、イヤと言えず、また、好きな事も、おずおずと盗むように、極めてにがく味い、そうして言い知れぬ恐怖感にもだえるのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は孤独だ、と末弟は言い知れぬ寂寥の感に襲われた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、もう、それには、とはげしく拒否して、私は言い知れぬ屈辱感に身悶えしていた。",
              "citation": {
                "source": "黄金風景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェリアは勇敢な男だったが、それでもこの影のようにつきまとう言い知れぬ恐怖には、震えるほかなかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い知れぬ深刻、たといがたき崇高がこの一節において感ぜられる。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、お母さまは、もうお亡くなりになったのだと意識したら、言い知れぬ凄しさに身震いして、眼がさめた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには六兵衛も呆気にとられて少しぼんやりと突っ立っていたるが、自分の眼のまえに倒れている磯貝の死骸をみると、彼は俄かに言い知れぬ恐怖におそわれ、掴んでいたる雛鳥を投げ捨てて、これも早々に逃げ帰りしなり。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外に正直らしい、鷹揚な、しかもその底には怖ろしい野性がひそんでいるらしい彼の前に曳き出された時に、栄之丞は言い知れぬ怖れを感じた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めから相手に足らないやつとは思っていたが、それでも栄之丞を見事に蹴倒してしまったということは、次郎左衛門に言い知れぬ満足を与えた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもだんだんと深く馴染むに連れて、殊に一つの屋根の下に朝夕一緒に暮らすようになってから、彼女の妖艶な眼の底に言い知れぬ一種のおそろしい光りの忍んでいることを林之助は漸く発見した。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「執り殺すなら、殺してみろ」　こういう口の下から、彼は言い知れぬ恐怖に囚われて、とてもお絹の呪いに堪えられないような不安をも感じた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里と自分とは、もう切り放すことのできない羇絆が結び付けられたことを観念すると同時に、彼は言い知れぬ悔みと悩みとにひしひしと責めつけられた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言い知れぬ恐怖に囚われて、二人はやはり石のように黙っていた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは彼女を心静かに家に帰らせるために、そのまま顔をそむけて立ち去ったが、すぐに自分は言い知れぬ下品な卑劣漢であったことを感じた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い知れぬ懐かしさと、助かったという思いを胸に渦巻かせながら……。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、そうした冒険的な緊張味の中に彼女は言い知れぬ神秘的な生き甲斐を感じつつ生きて来たものであろう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ふけて静かにこの書を読んでいると、いいしれぬ孤独と寂寥の中にあって、ひとりでに涙が流れてくることもしばしばあった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ともいいしれぬ感情が私の腸を抉るのであった。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
