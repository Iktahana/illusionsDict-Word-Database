      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "British person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ロンドンで開かれた国際会議では、多くのイギリス人が専門知識を共有していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は旅行先で出会ったイギリス人から、現地の文化について多くを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのプロジェクトには、イギリス人のエンジニアが加わり、技術的な貢献が期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ドキュメンタリー番組では、ロンドンでの生活を綴った一人のイギリス人の体験談が紹介された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの新しいカフェのオーナー、面白いイギリス人なんだよ」と友人は教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "18世紀の日本を訪れたイギリス人の記録は、当時の社会を知る上で貴重な資料となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "斜向うのイギリス銀行、ロイド・ナショナル・プロヴィンシアル・バンクの支店から出て来た髭の生えたプラスフォアのイギリス人が日当りの好さそうな卓を選んで席を取った。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、程近くのイギリス人の家でいつとなく鳴りはじめたピヤノの音が、その沈默をくすぐるやうに間遠に聞こえてたただ一｜脚のトイスが、いや、あまりにもそれとかけ隔たつたさういふみじめな現実のすべてがうつすりとよみがへつて※た。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その間、島津久光の家来が横浜郊外の生麦でイギリス人を斬つたり、浪士たちが品川御殿山の外国公使館を焼いたり、イギリス船が下関や鹿児島を砲撃したやうな事件も起つた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは先祖代々の宗教を守っているのに、土人の中には少し金ができるとすぐイギリス人のまねをして耶蘇信者になるのがある、あれはいけない、どの宗教でもつまり中身は同じで、悪い事をすな、ズーグードと言うだけの事だ、などと一人で論じていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　善良な男だ――古き良きイギリス人――素朴で実直、そして温和、目は大きく熱意のこもった青色、顔は大きく端正。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "横入りしやがったこのイギリス人こそ何様のつもりだ！",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺があいつの居場所をつきとめたときには、もうこのイギリス人と結婚したあと。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、＊一八〇一年の事件をよく知っている参事官は、進んでその話に調子をあわせて、イギリス人に攻撃をしかけました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人の考にては、異様の声の主は断じてイギリス人にあらざりきと覚ゆ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭き声の主はイギリス人なりしこと確実なりと云へり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア人だとか、イギリス人だとか、スパニア人だとか、フランス人だとか云ふが、要するにその申立をした人が自国の人でなくて、外国の人だと思つたのだ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ語の分からないイギリス人はドイツ語だらうと云ふ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス語の分からないスパニア人は、発音から推測してイギリス人だらうと云ふ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（５）一七五六年六月二十日、インド土人の大守シュラジャー・ドーラーによって、百四十六人のイギリス人の俘虜が、カルカッタのわずか十八フィート四方の狭い牢獄のなかへ押しこまれた。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに述べておいてもよいであろうが、予の話している人物が生れのみならず教育においてもイギリス人であるということを、予は従来一度ならず聞いていた（もちろん、非常に多くのありそうにもないことを含んでいる風評なるものを信じはしなかったが）のであった。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス人で、パリに二年住んでいる。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス人の声ではないことは確かだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭い声のほうはイギリス人の声であった、――これは確かだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども鋭いほうの声に関しては、その特異な点は、――彼らの意見が異なっていたということではなくて――イタリア人と、イギリス人と、スペイン人と、オランダ人と、フランス人とがそれを説明しようとしているのに、めいめいがみんなそれを外国人の声だと言っていることなのだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス人はドイツ人の声だと考えているが、『ドイツ語はわからない』のだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペイン人はイギリス人の声であることは『確かだ』と思っているが、『彼は英語を少しも知らないので』、ぜんぜん『音の抑揚で判断する』のだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（３）Edmund Hoyle（一六七二―一七六九）――種々の競技に関する書物を著したイギリス人で、特にホイストの法則を最初に組織的にした人として知られている。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者はイギリス人の作家、ダグラス・アダムス。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アダムスの『銀河ヒッチハイカーズ・ガイド』は、いかにもイギリス人らしい持って回った言い方や冗談だらけで、おまけに著者の計算間違いが加わり、私にとっては何とも読みづらい代物でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらこれがイギリス人の心、ウォルフ将軍のような心をどれだけ慰めたか、実に今日までのイギリス人の勇気をどれだけ励ましたか知れない。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それである歴史家がいうたに「イギリス人の書いたもので歴史的の叙事、ものを説き明した文体からいえば、カーライルの『フランス革命史』がたぶん一番といってもよいであろう、もし一番でなければ一番のなかに入るべきものである」ということであります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
