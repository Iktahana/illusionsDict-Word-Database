[
  {
    "uuid": "173f7f6e-2ce2-5d62-b109-cd0a7f5e0530",
    "entry": "イギリス人",
    "reading": {
      "primary": "イギリスじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
