        "examples": {
          "standard": [
            {
              "text": "住民票は実家に置いたまま、大学の近くのアパートを居所として生活している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "長期出張のため、ホテルを仮の居所として届け出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この書類には、現住所と居所の両方を記入する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
