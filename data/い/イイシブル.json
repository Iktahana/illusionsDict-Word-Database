          ],
          "literary": [
            {
              "text": "と誰に言はせても、ちよつと言い渋るやうに、困つた顔をして見せる。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "と誰に言わせても、ちょっと言い渋るように、困った顔をして見せる。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハスレルはぼんやりした無関心な眼でじっと見つづけながら、彼を言い渋るままに放っておいた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の人は自尊心から、或は謙遜から物をいいしぶる。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
