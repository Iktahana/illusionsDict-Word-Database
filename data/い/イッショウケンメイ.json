    },
    "definitions": [
      {
        "index": 1,
        "gloss": "very hard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "迷子になった小さな男の子が、泣きじゃくりながら一生懸命に母親の名前を呼んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "明日のプレゼンのために、チーム全員で昨夜は遅くまで一生懸命に資料の修正作業を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "庭の片隅で、朝顔の芽が太陽の光を浴びようと一生懸命に小さな葉を広げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は決して器用ではないが、何事にも一生懸命に取り組む姿勢だけは誰からも評価されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――父はそのことのために、私の兄弟五人を全部大学迄はやると言つて今開業して一生懸命になつてゐるのだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから一見閑静な田舎に住まっていては、とても一生懸命な自分の仕事に没頭しているわけにはいかない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩を慰みと思っている軍人党と、一生懸命の弱虫との挌闘にはたいてい利口な軍人の方が手を引く。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまた、母親が一生懸命にそそのかす。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆、興覺めなほど、一生懸命である。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ幼稚園へも行かれないような幼児が多いが、みんな一生懸命に傾聴している。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで達二は、一生懸命それを跡けて行きました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、五年も十年も一生懸命骨を折って勉強をした人の、外目にはともかくも相当なコントリビューションにはなるであろうと思われるものが些細な欠点のために落第させられたり、二十年も事務室の金庫に秘蔵されるようでは、先ずよほどの自信家でない限り論文提出について逡巡せざるを得ないであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから、私は一生懸命になってたしなんで居るんでさ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍麿は宣長の研究から導かれて、古典における実例を一生懸命に調べて、はじめてそんな使いわけがあることがわかったのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際もしも全市民が協力して一生懸命に消火にかかったらどうなるか。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者がこの器械の事を近着の科学雑誌で読んだ後、場末の町を散歩していたら、とある米屋の店先で小僧がズックの袋に豆かなにか入れたのを一生懸命汗を垂らして振っていた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に戦争になるかもしれないというかなりに大きな確率を眼前に認めて、国々が一生懸命に負けない用意をして、そうしてなるべくなら戦争にならないで世界の平和を存続したいという念願を忘れずにいれば、存外永遠の平和が保たれるかもしれないと思われる。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平凡な結論ではあるが、学生のときには講義も演習もやはり一生懸命勉強するに限るのであろう。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、自分の部屋に一人きりでゐる時に、私は翌日貴方に言ふべき言葉を一生懸命に用意するのです。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやり方がうまいんで、どうしても犯人の手掛がつかない、係長初め何人かの仲間、警察の人達までが一生懸命に奔走し始める。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、手に力がないので一生懸命にひねっても、独楽は少しの間立って廻うのみで、すぐみそすってしまう。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の顔を斜に見た処で、無論少年の手には余る画題であるのを、自分はこの一挙に由て是非志村に打勝うという意気込だから一生懸命、学校から宅に帰ると一室に籠って書く、手本を本にして生意気にも実物の写生を試み、幸い自分の宅から一丁ばかり離れた桑園の中に借馬屋があるので、幾度となく其処の厩に通った。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "南国の盛夏の真昼間の土蔵の二階の窓をしめ切って、満身の汗を浴びながら石油ランプに顔を近寄せて、一生懸命に朦朧たる映像を鮮明にかつ大きくすることに苦心した当時の心持ちはきのうのことのように記憶に新たである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年九月一日｜被服廠跡で起った火焔の渦巻を支配したと同じ方則がここにも支配しているのだろうと思って、一生懸命に眺めていたが、この模糊とした煙の中から、そう手取早く要領を得た方則を読取る事は容易な仕事ではないのであった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく一生懸命で絵を描いている途中でどうしてこんな考えが浮き上がって来たものか、自分でも到底分らない。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学を奨励する目的で作られた機関が、自己の意志とは反対に、一生懸命科学の進歩を妨害しているという悲しむべき結果になる事もあるようである。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうと知ったら藤吉も安心したんでしょうが、間違いの起るときは仕方がないもので、一生懸命に内の様子をうかがっていると、そこへまた丁度に帰って来たのが亭主の宇三郎です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌女寿もだんだんに酔いがまわって来て、婿になれというのか亭主になれというのか、訳の判らないようなことを媚かしい素振りで云い出したので、気の小さい弥三郎は顫えるほどに驚いて、一生懸命に振り切って逃げて帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも怖い物見たさ聞きたさに、いつも小さい身體を固くして一生懸命に怪談を聞くのが好きであつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は自分のあとを嗣がせるつもりで、子供のときから一生懸命に長唄を仕込んだが、お俊は肩揚げの下りないうちから男狂いをはじめて、母をさんざん泣かせた挙句に、深川の実家を飛び出して、上州から信州越後を旅芸者でながれ渡って、二、三年前に久し振りで江戸に帰ってくると、深川の母はもう死んでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "年のわかいお捨は俄かにおそろしくなって、返事もしないで一生懸命に逃げ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間を掘り出すのに一生懸命だった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹は口から泡をふいていっしょうけんめいはさみをつかいました。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかり合っては大へんだから、どいつもみな、いっしょうけんめい、じぶんの稲を扱いていた。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
