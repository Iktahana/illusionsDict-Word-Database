        "examples": {
          "standard": [
            {
              "text": "A社のプランは安いがサポートが薄く、B社は高いが保証が手厚いため、どちらの契約も一長一短がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "電車通勤とマイカー通勤にはそれぞれ一長一短があり、住んでいる地域によってどちらが良いか変わってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新しく導入したシステムは処理速度が上がった反面、操作画面が複雑になっており、現場の評価は一長一短だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "結局まあ、損も得も無く、一長一短といふやうなところか、久しぶりで思ふぞんぶん歌つたり踊つたりしただけが得、といふ事になるかな？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外生活と市内生活と、所詮は一長一短で、公平にいえば、どちらも住みにくいというのほかはない。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉と妹、一長一短で、どうも決心がつきません、というのだから贅沢な話だ。",
              "citation": {
                "source": "律子と貞子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬も悪くはないが、しかし、まあ一長一短というところだろうな。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不滅ノ真理ハ微笑ンデ教エル、「一長一短。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外生活と市内生活と、所詮は一長一短で、公平に云えば、どちらも住みにくいと云うのほかはない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の優劣は固より容易に言ふべからざるも互に一長一短ありて甲越対陣的の好敵手たるは疑ふべきにあらず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "王國維の中元五年説と私の建元六年説とは、一長一短ではあるが、その長短を對比計量して、建元六年説の方が、より無難かと思ふ。",
              "citation": {
                "source": "司馬遷の生年に關する一新説",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が今日人を一目で判断して好悪を決し、信用不信用を決するには、たゞこの悲しみの所在によつて行ふので、これは甚だ危険千万な方法で、そのために人を見間違ふことは多々あるのだが、どうせ一長一短は人の習ひで、完全といふものはないのだから、標準などはどこへ置いてもどうせたかゞ標準にすぎないではないか。",
              "citation": {
                "source": "石の思ひ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が今日人を一目で判断して好悪を決し、信用不信用を決するには、ただこの悲しみの所在によって行うので、これは甚だ危険千万な方法で、そのために人を見間違うことは多々あるのだが、どうせ一長一短は人の習いで、完全というものはないのだから、標準などはどこへ置いてもどうせたかが標準にすぎないではないか。",
              "citation": {
                "source": "石の思い",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この恰も談笑に似たものをさへ、もし論争と見るならば、この論争は潤一郎の公論と龍之介の新説と、ともに一長一短があつて勝負なしの引分けでもあらうか。",
              "citation": {
                "source": "個人的な余りに個人的な饒舌",
                "author": "＝龍之介対潤一郎の小説論争＝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどれにも一長一短はあって、いずれを可とし、いずれを不可とすることは出来ない。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も一長一短で、かれらは七代目のように、春彦の饒舌をおとなしく聞く能力はなかった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
