    "definitions": [
      {
        "index": 1,
        "gloss": "to build oneself a hermitage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若き日の歌人は、世俗を離れて山奥に庵を結び、歌道に専念した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "定年を機に、故郷の片隅に小さな庵を結び、晴耕雨読の生活を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の生涯最後の傑作は、人里離れた森の中に庵を結んで生まれたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "喧騒から逃れ、静かに思索にふけるため、彼は湖畔に庵を結んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "師の教えを守り、弟子は町の外れに庵を結び、ひたすら書に打ち込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代社会の雑踏から離れ、精神の平穏を求めて尼僧は庵を結んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "緑平老の肝入、井師の深切、俳友諸君の厚情によつて、山頭火第一句集が出来上るらしい、それによつて山頭火も立願寺あたりに草庵を結ぶことが出来るだらう、そして行乞によつて米代を、三八九によつて酒代を与へられるだらう、山頭火よ、お前は句に生きるより外ない男だ、句を離れてお前は存在しないのだ！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日、句稿整理、私にはまだ自選の自信がない、しかし句集だけは出さなければならない、句集が出せなければ、草庵を結ぶことが出来ないのである。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨、まるで梅雨のやうだ、歩いたり、考へたり、照会したり、交渉したり……、たゞ雨露を凌ぐだけの庵を結ぶのもなか／＼である。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山深く何にか庵を結ぶべき、心の中に身はかくれけり」で、何にも鎌倉へ引込むの、何々のと、場所を引込むのではないが、煩い仕事を減じて、一、二年聖人の書を読む余裕が欲しいと思うている。",
              "citation": {
                "source": "人格を認知せざる国民",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "山深く何か庵を結ぶべき心のうちに身はかくれけり　一身を物的境遇より退かせて、心的境遇に入らしむることも、これまた麒麟老ゆるも駑馬に劣るに至らざる工夫。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "北条団水の「一夜舟」に、京都東山に庵を結ぶ碩学があり、一夜写経に没頭してゐると窓から手をさしのべて顔をなでる者があつた。",
              "citation": {
                "source": "日本の山と文学",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
