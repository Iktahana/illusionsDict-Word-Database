          ],
          "literary": [
            {
              "text": "孝明天皇御一年忌に際し、慶喜に対して献金のことを申出でたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "和子がまた、おじいさんと二人で、留守をするようになったのは、お母さんの一年忌を前にした、初夏のことでありました。",
              "citation": {
                "source": "おるすばん",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜尾四郎一年忌で染井の墓地へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「む、そんな噂も聞いたなあ」「もう親分の一年忌も済み、笊組の奴等もすッかり油断している頃合だ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
