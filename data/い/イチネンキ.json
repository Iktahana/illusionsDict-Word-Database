        "index": 1,
        "gloss": "first anniversary of a person's death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "来月、祖母の一年忌なんだ。みんなで集まって法要を営む予定だよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "〇〇様の一年忌法要を〇月〇日〇〇寺にて執り行います。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの日から一年忌を迎えるにあたり、改めて故人の功績を偲ぶ会が開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あっという間の一年だった。今日、父の一年忌を迎え、静かに手を合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "著名な作家である山田太郎氏の一年忌を記念し、追悼特集が組まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そういえば、来週、従兄弟の一年忌なんだって。お焼香に行こうと思ってる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "孝明天皇御一年忌に際し、慶喜に対して献金のことを申出でたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "和子がまた、おじいさんと二人で、留守をするようになったのは、お母さんの一年忌を前にした、初夏のことでありました。",
              "citation": {
                "source": "おるすばん",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜尾四郎一年忌で染井の墓地へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「む、そんな噂も聞いたなあ」「もう親分の一年忌も済み、笊組の奴等もすッかり油断している頃合だ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
