[
  {
    "uuid": "f35a5434-0606-57b5-a8a7-82f3c8d1efa3",
    "entry": "頂く",
    "reading": {
      "primary": "いただく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
