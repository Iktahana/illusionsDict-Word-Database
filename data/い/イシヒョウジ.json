[
  {
    "uuid": "65d398bb-66fd-5b31-accf-0df58abf7f50",
    "entry": "意思表示",
    "reading": {
      "primary": "いしひょうじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
