    "definitions": [
      {
        "index": 1,
        "gloss": "to warn against",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "医師は患者に対し、過度な飲酒が健康を損なうことを厳格に戒めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "先生は生徒たちが廊下を走らないよう、常日頃から戒めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「油断は禁物だぞ」と、リーダーは浮き足立つメンバーを戒めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それでこそ例えば津浪を戒める碑を建てておいても相当な利き目があったのであるが、これから先の日本ではそれがどうであるか甚だ心細いような気がする。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは一方にお万を戒めると共に、久次郎を追い遠ざける手段を講じた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリジナリティの無いと称せらるる国の昔話に人まねを戒める説話の多いのも興味のあることである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、それがこの道の行儀作法ででもあるように、戒めるのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "平穏無事のときに悟空の行きすぎを引き留め、毎日の八戒の怠惰を戒めること。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育家は妄想を起させぬために青年に床に入ってから寐附かずにいるな、目が醒めてから起きずにいるなと戒める。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時長州藩、京都留守居役、乃美織江の手記によれば、形勢緊迫と共に、有志等に軽挙を戒めること痛切であつた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は猶足人や少歳にまで聲を掛けて、これは大事のことであれば考違ひをしてはならぬと戒める……。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――駒形河岸裏の侠客出石屋四郎兵衛が、日ごと夜ごとのようにこの大川筋で入水する不了簡者達を戒めるためと、二つにはまた引取手のない無縁仏を拾いあげてねんごろに菩提を弔ってやろうとの侠気から、身内の乾児達に命じて毎夜こんな風に見廻らしている土左船なのでした。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうして世の道楽者を戒めるのである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時鎮守の森の陰あたりから、夜を戒める柝木の音がかち／＼と聞えて、それが段々向ふヘ／＼と遠かつて行く。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその意見に基づいて伜の長三郎を戒めたが、今や幸之助に対しても同様の意見をほのめかして、若い侍の冒険めいた行動を暗に戒めると、幸之助もおとなしく聴いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が夜通し厳重に見張っているあいだは別になんの変ったこともなかったが、少し油断して横着をきめると、半鐘はあたかもかれらの懶惰を戒めるように、おのずからじゃんじゃん鳴り出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかに償金を出せとも云いませんが、その乱暴者を処分して、今後を戒めるようにしてくれと云うのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時｜或人が好戦論者を戒めるために普仏戦争の前アルフオンス・カアルの言つた言葉を引証してゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正四（一九一五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の失敗を省みて、気短かと早合点とを戒める。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘えるな、甘えるな――媚びるな、媚びるな――自分を甘やかすな、他人に媚びるなと自から戒める言葉である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｂ―は戒めるように言った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍聴券が出されたと云う事も彼女一つの例を以て、多くの他の場合を戒めるという意味であったのでしょうが、暁子が若し心の底から自分の境遇と結果について述べる力を持っていたならば、彼女の云いたかった事は何でありましょう。",
              "citation": {
                "source": "「女の一生」と志賀暁子の場合",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "濫読を戒めるのは大切なことである。",
              "citation": {
                "source": "如何に読書すべきか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこんな家の主人を相手に何か共同の發展をしようとしてゐる友人の、大して望みありさうでもない努力を戒める氣になつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞭は徒弟の曲を矯めるためとも、また、師匠自らの惰を戒めるためともみられる。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又この憂鬱な影の為に我我の浮薄を戒めるのであらう。",
              "citation": {
                "source": "わが散文詩",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　皆話し終えてから、矢代は幸子を戒めるつもりで言葉も、さして苦しまず自然に出て来たのを一層好都合に感じて云った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "論ずる人の考では欧米の婦人の一部に種種の事情から結婚を厭う風のあるのを見て日本婦人を戒めるつもりでしょうが、それは白昼に幽霊の出るのを恐れるのと一般全く無用な心配です。",
              "citation": {
                "source": "女子の独立自営",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや林大学頭が引証した「左伝」の語は、左氏が不義を戒める趣意で書いたものであって、決して論拠となすことは出来ない。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "書を著わし、文を草して、しばしばこの種の誤謬に陥ることあるに鑑み、ここにこれを書して自ら戒めるのである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀野隆三、自らきびしく、いましめるところあってか、この本のあとにもさきにも、原作者フィリップに就いて、ほとんど語っていない。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、筍をさかさにした形のアイスクリンの器をせんべいとは知らず、中身を嘗めているうちに器が破けてはっとし、弁償しなければならぬと蒼くなって嗤われるなど、いくら眼をキョロキョロさせていても、やはり以後かたくいましめるべき事が随分多かった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、筍をさかさにした形のアイスクリンの器をせんべいとは知らず、中身を嘗めているうちに器が破けてハッとし、弁償しなければならぬと蒼くなって嗤われるなど、いくら眼をキョロ／＼させていても、やはり以後かたくいましめるべき事が随分多かった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to admonish",
        "register": "standard",
