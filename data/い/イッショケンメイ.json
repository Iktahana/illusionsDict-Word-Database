        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "中世の武士は、主君から与えられた領地を一所懸命に守り抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「一所懸命」という言葉の語源は、武士が命をかけて一つの土地を守ったことにある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その武将は、先祖代々の土地を一所懸命の覚悟で治めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
