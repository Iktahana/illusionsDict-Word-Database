    "definitions": [
      {
        "index": 1,
        "gloss": "very hard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は目標達成のため、寝る間も惜しんで一所懸命に勉強している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女が一所懸命に作った料理は、どれも心のこもった味がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供たちが一所懸命にボールを追いかける姿に感動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "新しいプロジェクトを成功させようと、チーム全員が一所懸命だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "その特殊な文章は、丁度小學校の一年生が、鉛筆の心を舌で嘗めつけながら、一所懸命で紙の上に書きつけてる、あの片假名の作文を聯想させる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の眞晝近く、地上のすべての事物は、人も、樹木も、家屋も、電柱も、また砂にまぎれる小蟻さへも、息を途絶えさすやうな劇しい暑さに疲れ果てて、ぢつと聲をひそめて立つてゐるやうに思はれるその眞晝近く、私は理科大學研究室の窓際の机に向つて、一所懸命に蘭科植物の葉色素研究の爲めに顯微鏡を覗き込んでゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一所懸命にその演説者の言葉の意味を拾おうと思って努力したが、悲しい事には少しも何の事だか分らなかった。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであの死骸を蔵元屋から担い出いた大風呂敷か何かが、そこいらに棄てて在りはせんかと一所懸命に探しまわったが、怪しい縄一筋、細引一本見当らんじゃった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もそれじゃ来年は勉強をして、猪のようにあばれて悪い事をする児と、猪のように一所懸命に好い事をする児の名前を集めよう。",
              "citation": {
                "source": "犬のいたずら",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "金襴の着物を着た儘王様の椅子を飛び降りて「ワンワンワンワン」と吠えながら一所懸命に追っかけました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キイキイキイキイ助けてくれ」　と一所懸命もがいておる処へ、最前ドブに落ちた鳥さしがモチ棹を追っかけて来てこの様子を見ると、「雀が鵙を取ってくれた」　と喜んで鵙の首をキュットひねって袋に入れてモチ棹を担いで帰って行きました。",
              "citation": {
                "source": "鵙征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとからポチが一所懸命吠えながら追っかけて行きますと、やがて泥棒は通りかかったお巡査さんに捕まってしまいました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかして助けたいと一所懸命に考えましたが、とうとう一つうまいことを考え出しまして、瓶を手に持ったままお台所の方へ走って行きました。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逃がしてなるものか」　と泥棒は一所懸命となって、とうとう虻をタタキ落として追っかけてゆきました。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "痛いのとがなられるのとで、一所懸命の力で歩かうとするのぢやが、どうしたつて動けない。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな感心したか……ガチャ、ガチャ、ガチャ、ガチャ、ガチャ」　とたった一人一所懸命にやっているうちに、「お兄さま。",
              "citation": {
                "source": "がちゃがちゃ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "助けてくれ」　と言いながら一所懸命逃げて行きました。",
              "citation": {
                "source": "狸と与太郎",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が審判官になります」　二人は一所懸命に押しました。",
              "citation": {
                "source": "二人の男と荷車曳き",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうして彼女を無事に逃がして遣りたいというような願望を、夢うつつのように抱きながら一所懸命の思いで腹ばいに起き直った。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞に祈祷するものは一所懸命なり、祈祷者はその心靈に於て明らかに神と交歡す、彼自ら何を言ひ何を語りつつあるかを知らざる也。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君達が一所懸命にやれば愉快になる、然し……」「それは違ひます。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲目の三味線弾は自分の足場を一所懸命で捜して居た。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（此奴に負けてはたいへんだ）　と思ったので、きっと唇を噛んで老婆の顔を睨みかえしたが、一所懸命であるから数瞬もしなかった。",
              "citation": {
                "source": "天井裏の妖婆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、わるいことはあれしまへんけど、お祖父ちゃんは足つかう商売やさかい、疲れが出んように思て……」　こうして願を掛けているのだと、君枝は一所懸命な手の動きでそれを示した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で、苦労してこれだけの人間になりました言うて、お父さんの前へ早よ出られるようにしよ思て、一所懸命になってるわての気持は、あんたには判れしめへんのんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんせ蝶子はんは一生日蔭者で終りとうない思て、一所懸命苦労して来やはったのに、いざその苦労が報いられるいう矢先きになって、維康さんのお家の方からそんな扱いされはったんでっさかい……。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "隆太郎は一所懸命に爪立ち爪立ちした。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは、この煩いでは、とても助からん思って、今、娘の処へ暇乞いに往って、帰っておると、お武家さんが見つけて、斬りに来たから、一所懸命になって逃げて来た。",
              "citation": {
                "source": "鬼火を追う武士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いけねえのか」「そればっかりは、どうぞ」　お岩は一所懸命であった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "打とうと思ったところで、鉄砲などの的るような者でもない、それに一所懸命に狙っておっては、わたしの云う事が判らないであろう」　少女の口辺には微笑が浮んでいた。",
              "citation": {
                "source": "女仙",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、一所懸命になって、そんな人間を探し出して、自分の流派の後継者として、精彩を尽して薫育をする。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "金太は最初のうちこそお妖怪のことを頭においていたが、鮒が後から後からと釣れるので、もう他の事は忘れてしまって一所懸命になって釣った。",
              "citation": {
                "source": "おいてけ堀",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　おみねはうす暗い行燈の下で一所懸命に手内職をしていたが、ふと其の手を止めて蚊帳の中をすかすようにした。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺は一所懸命だった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
