          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末、公園には親子連れで賑わい、色とりどりの凧が青空に舞っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お父さん、もっと風に乗せて！そうしないと、凧が落ちちゃうよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "毎年正月には、地域によっては巨大な縁起物の凧が揚げられる風習がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "強風注意報が発表された地域では、安全のため凧揚げは控えるよう呼びかけられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統的な「いかのぼり」は、その独特な形状と、揚げる際の技術が特徴とされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初めて凧を揚げる子供に、糸の捌き方や風の読み方を丁寧に教えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遠くの山並みを背景に、ぽつんと揚がった凧が秋空を悠然と漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "なんと鍋屋横丁の裏辺りから東京高等学校の辺りにかけてといふものは、いやな東京の郊外中でもわけてもいやな所であり、硝子障子から外をみると、枯草の野ッ原の中で子供が三つ凧を揚げてゐる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれもこれも白い菱形の小さな凧で、僕の魂の如くはかなく風に浮揚してゐる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧のかげ夕方かけて読書かな夕立やかみなり走る隣ぐに沓かけや秋日にのびる馬の顔鯛の骨たたみにひらふ夜寒かな秋ふかき時計きざめり草の庵石垣に冬すみれ匂ひ別れけり　彼の俳句の風貌は、彼の人物と同じく粗剛で、田舎の手織木綿のやうに、極めて手触りがあらくゴツゴツしてゐる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の部凧きのふの空の有りどころ　北風の吹く冬の空に、凧が一つ揚っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その同じ冬の空に、昨日もまた凧が揚っていた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青空の上に浮んで、昨日も今日も、さびしい一つの凧が揚っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそのちがった空に、いつも一つの同じ凧が揚っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち言えば、常に変化する空間、経過する時間の中で、ただ一つの凧（追憶へのイメージ）だけが、不断に悲しく寂しげに、穹窿の上に実在しているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば藪入やよそ目ながらの愛宕山藪入のまたいで過ぬ凧の糸　など、すべて同じ情趣を歌った佳句であるが、特にその新体風の長詩「春風馬堤曲」の如きは、藪入の季題に托して彼の侘しい子守唄であるところの、遠い時間への懐古的郷愁を咏嘆している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした彼の郷愁は、遂に無限の時間を越えて凧きのふの空の有りどころ　と、悲しみ極まり歌い尽さねばならなかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　今ではどうだか知らないが、私の国では村の豪家などで男子が生まれると、その次の正月は村じゅうの若い者が寄って、四畳敷き六畳敷きの大きな凧をこしらえてその家にかつぎ込む。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り株ばかりの冬田の中を紅もめんやうこんもめんで頬かぶりをした若い衆が酒の勢いで縦横に駆け回るのはなかなか威勢がいい、近辺のスパルタ人種の子供らはめいめいに小さな凧を揚げてそれを大凧の尾にからみつかせ、その断片を掠奪しようと争うのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大凧が充分に風をはらんで揚がる時は若者の二人や三人は引きずられるくらいの強い牽引力をもっている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧揚げのあとは酒宴である。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪家に生まれた子供が女であったために、ひどく失望した若い者らは、大きな羽子板へ凧のように糸目をつけてかつぎ込んだなどという話さえある。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧のうなりがブンブンと聞えている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また森林に入ってからは、途は前ほどに均らされておらず、木の根岩角は、旧道のおもかげを存して古のお中道が、断絶された凧の糸のように、頭上に懸かっているのが指さされる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、紙凧の糸のようにすっとのして行って、思いがけないような遠い売場に佇む。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十幾本の鉤を凧糸につけて、その根を一本にまとめて、これを栗の木の幹に結び、これでよしと、四郎と二人が思わず星影寒き大空の一方を望んだ時の心持ちはいつまでも忘れる事ができません。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あったな雨｜降れば無ぐなるような奴凧こさ、食えの申し訳げなぃの機嫌取りやがて。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は高くあがっていて、凧の唸りがいくつも聞えた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな場合になってしまうと、私は糸の切れた紙凧のようにふわふわ生家へ吹きもどされる。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨の鬚は、凧の呻りに用ゐられます。",
              "citation": {
                "source": "島",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍にいた奴凧が大層気の毒がって、「章魚さん、もう喧嘩はおよしなさい」　と仲裁しました。",
              "citation": {
                "source": "章魚の足",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "群雄割據のやうにいろんな話が一時に頭を擡げて來て、たつた一人の私をひつぱり凧にしてゐます。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は廢めたのか知らん」と思ひながら横道を這入つて覺束ない足駄の歩みを運ばすと子供が凧の絲目をなほして居るのに遇つた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地こそ雪解の悪路なれ、からつと晴れ渡つた青空は、気持よくぬくまつて、いくつかの凧が窓のやうにあちこちに嵌められて居る或る日の午後に、父の死骸は小さな店先から担ぎ出された。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの心は糸の切れた凧のように狂って飛ぶ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "えた村の空も一つぞ凧　去来葛飾や江戸を離れぬ凧　其角美しき凧あがりけり乞食小屋　一茶物の名の鮹や古郷のいかのぼり　宗因糸つける人と遊ぶや凧　嵐雪今の列子糸わく重し人形凧　尺草（大正七年一月『趣味之友』第二十五号）",
              "citation": {
                "source": "凧の話",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語の遊戯を主とする者は江戸を以て鑑とすなり花に樽　　　　　　宗因うつり行くはやいかのぼり紙｜幟　　　　　同かけまくもかしこやこゝの踊かな　　　　同宇治橋の神や茶の花さくや姫　　　　　　同花や上野とつはた本の人家迄　　　　　　似春の如し。",
              "citation": {
                "source": "古池の句の弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
