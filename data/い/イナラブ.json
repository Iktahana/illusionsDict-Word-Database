[
  {
    "uuid": "7d2eb633-4aa8-57cd-8b05-503f8375cdbf",
    "entry": "居並ぶ",
    "reading": {
      "primary": "いならぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
