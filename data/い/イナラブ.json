    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to sit in a row",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祭壇の前には紋付き袴に身を包んだ親族が居並び、厳かな雰囲気の中で式が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新幹線のホームには、出張帰りのサラリーマンたちが整然と居並んで列を作っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "豪華なシャンデリアの下、各国から招かれた賓客たちが居並ぶ光景は圧巻の一言だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "プノンペンの街、タマリンドの街路樹、メコン河の流れ、シソワット王の城内、彼方には椰子の林があり、赫熱とした熱帯の強烈な太陽の直射と、熱風を避けた王城内でノラの母はシソワット王と廷臣の居並ぶ玉座のまえで、オーケストラと数十人の唄い手の歌声のなかで華麗な彼女はカンボジヤの踊りを舞うのだった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の、ひとのよい無學ではあるが利巧な、若く美しい妻は、居並ぶ近親たちの手前、嫉妬でなく頬をあからめ、それから匙を握つたまま聲しのばせて泣いたといふ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の、ひとのよい無学ではあるが利巧な、若く美しい妻は、居並ぶ近親たちの手前、嫉妬でなく頬をあからめ、それから匙を握ったまま声しのばせて泣いたという。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだランプをつけないので薄暗い土間に居並ぶ人影もおぼろである。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この男は世の中に怖いものがないのであろうか」　弓子はピシャリと小郷の顔を撲りたい衝動を感じながら、「それから、もう一つ投書が来てるんですが……」「あはは……小郷虎吉ついに投書欄の人気者になったか」「投書の内容は、実は……」　居並ぶ芸者や舞妓の顔を、素早く見廻して、弓子はズバリと言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡すと、居並ぶ若い娘たちは何れもしるこやぜんざいなど極めて普通の、この場に適しいものを食べている。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "船がいよいよ汽笛を鳴らして船首を外海に向け始めた時、ナポレオンが居並ぶ島民らと共に船に向って手を振ったのを、私は確かに見た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女も美しい軽羅を着てベンチへ居並ぶ。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」不安ノ谷むかし晴々と静かな小谷があったそこに人の住まうことはなしみな信じて戦に出向いたのだ穏やかな目をした星々が夜ごと居並ぶ空色の物見から花畑を下に見守ってくれるとあいだに日がな赤の陽射しもだらりと寝そべっていると。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ居並ぶ其処の人たちに陳謝し、サテ徐ろにこの石油くさき男を引つ立てねばならなかつた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがいよいよ子爵夫人の格式をお授けになるという間際、まだ乳房にすがってる赤子を「きょうよりは手放して以後親子の縁はなきものにせい」という厳敷お掛合があって涙ながらにお請をなさってからは今の通り、やん事なき方々と居並ぶ御身分とおなりなさったのだそうです。",
              "citation": {
                "source": "忘れ形見",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者達は、銘々慎しみの心を、表に現わして紫や緋の衣を着た老僧達の、居並ぶ祭壇を一斉に注視しているのであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち並ぶ名士達の間に、細く残された通路を、足早に通り抜けて、祭壇の右の婦人達の居並ぶ席に就いた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お礼を済ました家中の者が左右に開いて白髪小僧を真中にして居並ぶと、やがて向うの入り口から大勢の家来が手に手に宝石やお金を山盛りに盛った水晶の鉢を捧げて這入って来て、白髪小僧の眼の前にズラリと置き並べました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事が、未亡人と被害者との関係を審問しはじめた時、居並ぶ人々は一斉に非常な注意をその方に集注した。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "こやつが担がれて惨憺たる悲鳴を挙げる態を想像すると、其処に居並ぶ誰を空想した時よりも好い気味な、腹の底からの爽々しさに煽られた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こやつが担がれて惨憺たる悲鳴をあげる態を想像すると、そこに居並ぶ誰を空想した時よりも好い気味な、腹の底からの爽々しさに煽られた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者達は、銘々慎しみの心を、表に現はして紫や緋の衣を着た老僧達の、居並ぶ祭壇を一斉に注視してゐるのであつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、居並ぶ百姓達は皆笑つた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お由の家の大炉には、チロリチロリと焚火が燃えて、居並ぶ種々の顔を赤く黒く隈取つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "居並ぶ人々は狼狽へた様に居住ひを直した。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "居並ぶ人々は狼狽へた樣に居住ひを直した。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お由の家の大爐には、チロリ／＼と焚火が燃えて、居並ぶ種々の顏を赤く黒く隈取つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と居並ぶ百姓達は皆笑つた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも各社のマシンを集めてベンチマークを行ってみると、一六ビット機としては思い切って低めの価格設定を行ったＰＣ―９８０１が、居並ぶマシンの中でも抜群の数値を叩き出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀の方の背後に居並ぶ側女の間に微かなサザメキが起った。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝原氏が声をかけると、卓子のまわりにずらりと数名の人々が居並ぶ。",
              "citation": {
                "source": "中支生活者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、それとも――女か――或いは、男女の如何に係らず、お由羅派を討つか、それとも、牧仲太郎一人を討つか――この点を、計って見たい」　居並ぶ人々は、黙っていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "心をしずめて、めいめいの面体見おぼえるがよろしかろうよ」「は、して、まそっと詳しゅう、居並ぶ人々の、順、なりふりをお聴かせ下さりませ」　雪之丞は、乾いた舌で嘆願するのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おととい鴎座の試験を受け、そこにいならぶ芸術家たちが、あまりにも、ご自分たちのわずかな地位をまもるのに小心翼々の努力をしているのを見て、あいそがつきたのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
