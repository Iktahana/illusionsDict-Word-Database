    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to say",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「そんな本当かどうかも分からないことを、軽々しく言うものではありません」と、厳しく注意された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は、自分の夢を叶えるためにはどんな苦労もいとわないと言って、単身海外へ旅立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議の席で反対意見を言うのは勇気がいるが、自分の信念を曲げるわけにはいかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は困っている人を見かけると、何も言わずにそっと手を差し伸べるような誠実な人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ありがとう」という感謝の言葉は、何度言っても、また何度言われても心温まるものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "気象予報士が言うには、今年の夏は太平洋高気圧の影響で記録的な猛暑になる見込みだという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "言うまでもないことだが、公的な場での発言には相応の責任が伴う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "互いに自分の非を認めず、「言った言わない」の水掛け論が延々と続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私も時々笑談を言う。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時、妻はわざわざ私の所へやって来て、『遅くなりますから、お先へ休ませて戴きます』と言う、丁寧に三つ指をついてお辞儀をし、それから自分の寝床へ入る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "度々のことで面倒だから、今度から止めにして、先へ勝手に寝ることにしろと何度も言うが、妻は婦道に背くと言い、なかなか承知しないので困っている云々（大意）と。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようなこと、決してないのです』と夫人が言うに対しても、『心からの話、真面目のことです』と言い、『仕方ない！",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "世のおとなたちは、織田君の死に就いて、自重が足りなかったとか何とか、したり顔の批判を与えるかも知れないが、そんな恥知らずの事はもう言うな！",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生を棄てて逃げ去るのは罪悪だと人は言う。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がＡと言う作品を創る。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岸君も、亀井君も、お座なりを言うような軽薄な人物では無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理にも、そう言う。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "象徴と譬喩と、どうちがうか、それにさえきょとんとしている人がたまにはあるのだから、言うのに、ほんとに骨が折れる。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なんて、こんな事を言うと、非科学的だといって叱られるかしら。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、プウシキンの読者だったあのレニンが、いま生きていたら、何と言うでしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして自分の実際の身長よりも二寸くらい低く言うそうである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いても立ってもおられぬ、とはあんな思いを指して言うのでしょう。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりかえして言うが、実現は困難でない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は馬場みたいに出鱈目を言うことはきらいですねえ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に五十円出せと言うのですけれども、ばからしい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふつうのパンフレットです」「すぐそんなことを言うからな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レニエはうまいことを言う。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「――中傷さ」「それじゃ言うが、そのしどろもどろは僕の特質だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちだけがまるはだかだ」「へんなことを言うようですけれども、君はまるはだかの野苺と着飾った市場の苺とどちらに誇りを感じます。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのうちに君、眼がさめて見ると、――」「おっとそれあ言うな」馬場は右手を鼻の先で力なく振って、太宰の言葉をさえぎった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎さんには、死んでも言うものか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実は、小説よりも奇なり、と言う。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中さんがあらわれて、どうぞ、と言う。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方八方に、幾久しゅう、幾久しゅうとばかり言うのも、まがぬけているような気がして、こんどは、「末永くお願い申します。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しっかり飲め、と言うのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも悪びれずに言うその態度は、かえって男らしく、たのもしく見えた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酒だってあるし、」大隅君は、酒を飲みながら、叱るような口調で私に言うのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私には、そう言うのが精一ぱいの事であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "専門用語では、こうした細胞の自滅現象を「アポトーシス」と言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼い娘は、自分の履いている靴のことを親しみを込めて「くっく」と言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この地方では、冬に山を越えて吹いてくる冷たい北風のことを「あなじ」と言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "数学において、分母と分子を入れ替えて得られる数のことを「逆数」と言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ひまわり」を英語で何と言うか、電子辞書を引いて隣の席の友人に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "儒教の教えでは、親を敬い、真心を込めて尽くす心を「孝」と言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to go (e.g. \"the alarm went ping\")",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝、目覚まし時計がピピピという音で目が覚めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い板張りの廊下を歩くと、足元で床がミシミシという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "電子レンジがチンというまで、あと数十秒待たなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "突然、車のタイヤがキキーという鋭い音を立てて急ブレーキがかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "沸騰したやかんがシュンシュンというので、コンロの火を止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬の夜、窓の隙間から風がヒューヒューという音が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強風に煽られて、建物のドアがバタンという音を立てて閉まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
    ],
