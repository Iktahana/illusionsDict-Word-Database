[
  {
    "uuid": "c0c200e9-11ef-53d2-90d6-e0fa29cc886e",
    "entry": "引退",
    "reading": {
      "primary": "いんたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
