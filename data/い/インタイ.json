      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "retirement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三度が三度同じ返答で、紹巴は「ウヘー」と引退った。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を弟子であり甥でもある現マネージャア、ヂュプラに譲って生れ故郷のブレターニュのルンヌスに引退した。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）その二（食事を終った教団の人々は、めいめい食器を始末し、その辺を清潔に掃除し、威儀を正して左右に引退く。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符の表に、有るべき理由の無い一字が、もし有ったら、いつも控え控え断念めて引退る、その心がきっと届くぞ！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が肯かないほどのものを、男が掛合われて引退る奴がありそうな事だと思うのかい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と彌次馬の士官水兵は吾も／＼とやつて來たが、成程武村の脛は馬鹿に堅い、皆一撃の下に押倒されて、痛い／＼と引退る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と泣寝入に引退りぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "引退りて腰元一人、三指にて侍べれり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さゝ身の煮くたらしを、ほう／＼と吹いてうまがつて、燒豆府ばかりを手元へ取込み、割前の時は、鍋の中の領分を、片隅へ、群雄割據の地圖の如く劃つて、眞中へ埋た臟もつを、箸の尖で穴をあけて、火はよく通つたでござらうかと、遠目金を覗くやうな形をしたのでは大概岡惚も引退る。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは構わないで、湯にでも入ったら可かろうと、湯治の客には妙にそぐわない世辞を言うと、言に随いて、ではそうさして頂きます、後生ですわ、と膠もなく引退った。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際、五十銭か六十銭ならば知らず、二円五十銭の書物を買って下さいなどといい出しても、お小言を頂戴して空しく引退るに決っている。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れも奥へ引退って、再び石を投げ初めた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二代目河竹新七が引退の作にて、菊五郎の明石島蔵、左団次の松島千太、いずれも好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時成実の隊の下郡山内記というものが、此処で打死しても仕方が無い、一旦は引退かれるが宜くはないか、と云った折に、ギリギリと歯を切って、ナンノ、藤五郎成実、魂魄ばかりに成り申したら帰りも致そう、生身で一歩でも後へさがろうか、と罵って悪戦苦闘の有る限りを尽した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで右衛門は自尊心や自重心を傷つけられたに過ぎぬ結果になって、甚だ面白く無く、手持無沙汰になって、定基の妻や母にも面目無く、いささか器量を下げて、腹の中は甚だ面白からず、何様ぞ宜く御考えなされまして、という位を定基に言って引退るよりほか無くなった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も争いを仕に来たので無いのは知れきったことだが、負けたようになって引退ることは厭だった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋な感謝の念の籠ったおじぎを一つボクリとして引退ってしまった。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はもっと早く引退ってもよかったと思っていたらしく、客もまたあるいはそうなのか、細君が去ってしまうとかえって二人は解放されたような様子になった。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が鉄瓶を小さい方の五徳へ移せば男は酒を燗徳利に移す、女が鉄瓶の蓋を取る、ぐいと雲竜を沈ませる、危く鉄瓶の口へ顔を出した湯が跳り出しもし得ず引退んだり出たりしている間に鍋は火にかけられる。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "新学士に是非と云って、達引きそうな朋輩はないか、と煩く尋ねるような英吉に、厭なこった、良人が手を支いてものを言う大切なお嬢さんを、とお蔦はただそれだけでさえ引退る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "席貸をと思いましたが、やっぱり夜一夜じゃ引退るんです。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸張を垂れた御廚子の傍に、造花の白蓮の、気高く俤立つに、頭を垂れて、引退くこと二、三尺。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとの山端へ引退り、さらば一服｜仕ろう……つぎ置の茶の中には、松の落葉と朱葉が一枚。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私は後へ引退った。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と、屈んで私に挨拶して、一人で合点して弁当を持ったまま、ずいと引退った。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼はごく手短かに引退の理由を話した。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈江は「一応考えてみましてから」と一旦、整理室へ引退った。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時木村と花田は関根名人引退後の名人位獲得戦の首位と二位を占めていたから、この二人が坂田に負けると、名人位の鼎の軽重が問われる。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲月斎玉兎嬢ことウノ子さんは未だ興行界を引退なさらない前からいつも私の処へ来て深透レントゲンをやっておられたのです。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "事ある毎に彼に呼び付けられて、お説教を喰って引退っていた事が、事実上に証明されて来る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
