        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このプロジェクトでは、私は言われたことをやるだけのただの一兵卒ですよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "最初は一兵卒として入社したが、今では部長としてチームを率いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "たとえ一兵卒の立場でも、会社をより良くするための提案はできるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
