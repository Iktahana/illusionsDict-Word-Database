    "definitions": [
      {
        "index": 1,
        "gloss": "to colour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "常陸の国の天羽槌雄神が作った倭文布の帯だけが、ちらりと女神の腰に艶なる人界の色を彩る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にオリーヴ油のアンショアを乗せ蝦の肉で彩るのだった。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋鹿子の背負上した、それしゃと見えるが仇気ない娘｜風俗、つい近所か、日傘も翳さず、可愛い素足に台所｜穿を引掛けたのが、紅と浅黄で羽を彩る飴の鳥と、打切飴の紙袋を両の手に、お馴染の親仁の店。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "非ず、湖の冬を彩る、紅の二葉三葉。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラットフォームで、真黒に、うようよと多人数に取巻かれた中に、すっくと立って、山が彩る、目瞼の紅梅。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして夢を彩る五欲の歓楽、幻を織る四季の遊娯、いづれか虚妄ならざらん。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　かかる折から、柳、桜、緋桃の小路を、麗かな日に徐と通る、と霞を彩る日光の裡に、何処ともなく雛の影、人形の影がう、……　朧夜には裳の紅、袖の萌黄が、色に出て遊ぶであろう。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とすらりと立った丈高う、半面を颯と彩る、樺色の窓掛に、色彩｜羅馬の女神のごとく、愛神の手を片手で曳いて、主税の肩と擦違い、「さあ、こっちへいらしって、沢山お煙草を召上れ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を彩る青葉の緑、鼈甲の中指に影が透く艶やかな円髷で、誰にも似ない瓜核顔、気高く颯と乗出した処は、きりりとして、しかも優しく、媚かず温柔して、河野一族第一の品。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰衣のような幅広の前掛したのが、泥絵具だらけ、青や、紅や、そのまま転がったら、楽書の獅子になりそうで、牡丹をこってりと刷毛で彩る。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌の面に浮模様、末を揃へて、上下に香の図を合はせたやうな柳条があり、虹を削つて画いた上を、ほんのりと霞が彩る。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかり、明星の天降って、梁を輝かしつつ、丹碧青藍相彩る、格子に、縁に、床に、高欄に、天井一部の荘厳を映すらしい。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の中央に、漆の色の新しい、黒塗の艶やかな、吾妻下駄を軽く留めて、今は散った、青柳の糸をそのまま、すらりと撫肩に、葉に綿入れた一枚小袖、帯に背負揚の紅は繻珍を彩る花ならん、しゃんと心なしのお太鼓結び。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家にとつての、世上の諸々の現象は、作家の様々な夢を、在り得べく色彩る軽羅だ。",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "青田の畦畔には處々に萱草が開いて、田の草を掻くとては村落の少女が赤い帶を暑い日に燃やさない日でも、萎んでは開いて朱杯の如く點々と耕地を彩るのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言つて、晴れてゐたら月がさぞ美しく渓を彩るであらうと思はれるやうな、底の明るみを持つた空を仰いだ。",
              "citation": {
                "source": "耶馬渓の一夜",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真紅や、白や、琥珀のような黄や、いろ／＼変った色の、少女のような優しい花の姿が、荒れた庭園の夏を彩る唯一の色彩だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝平は、こうして若い美しい妻を得たことが、自分の生涯を彩る第一の幸福であるようにさえ思われた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの商店のうちでも、絵草紙屋――これが最も東京の歳晩を彩るもので、東京に育った私たちに取っては生涯忘れ得ない思い出の一つである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても歌舞伎双六は歳晩の絵双紙屋を飾り、あわせて歳晩の巷を彩る一種の景物で、芝居を愛する人も愛せざる人も、絵双紙屋の店さきに立って華やかな双六のいろいろをながめた時、おのずと“春近し”の感を起こさぬ者はなかったであろう。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "真紅や、白や、琥珀のやうな黄や、いろ／＼変つた色の、少女のやうな優しい花の姿が、荒れた庭園の夏を彩る唯一の色彩だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝平は、かうして若い美しい妻を得たことが、自分の生涯を彩る第一の幸福であるやうにさへ思はれた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "終に、中古以來の人の日常生活と結びついたもので、能なぞの舞臺面をも彩るものの一つは、扇の活用であることをこゝに書き添へよう。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁を早く知る小鳥たちのように、私たちが歓呼の声をあげると、間もなく紫に、紅にささべり彩る日の出が霧を染めて登って来るのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十六日　曇、后晴、行程七里、高岡町、梅屋（六〇・中）暗いうちに起きる、鶏が飛びだして歩く、子供も這ひだしてわめく、それを煙と無智とが彩るのだから、忙しくて五月蠅いことは疑ない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の夜を彩る街の灯の数だけ使われる日本語ワードプロセッサーを、ＰＣ―１００越しに夢見たジャストシステムは、このＰＣ―９８０１によって願いを成就させた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためか、真白な四肢と、深紅の水着――、それを彩る血潮との対照が、ひどく強烈に網膜につきささるのであった。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、佐藤の作品中、道徳を諷するものなきにあらず、哲学を寓するもの亦なきにあらざれど、その思想を彩るものは常に一脈の詩情なり。",
              "citation": {
                "source": "佐藤春夫氏の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘆や白楊や無花果を彩るものは、どこを見ても濁った黄色である。",
              "citation": {
                "source": "沼地",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "固より妊娠は彼女のうちに神秘な母性をよび覚すが、それも彼女の情感を彩るだけで、彼女の心意を撼がしはしない。",
              "citation": {
                "source": "意欲の窒息",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
