[
  {
    "uuid": "3b097daf-6961-5528-9664-515c91a66c63",
    "entry": "言わば",
    "reading": {
      "primary": "いわば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "so to speak",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで観察力の弱い人は、言わば一生を退屈して暮らすようなものかもしれません。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わば未だ取止めのない卵的の恋であるから、少しく心の力が必要な所へくると話がゆきつまってしまうのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは当世流の理屈で、だれも言うたと、言わば口前だ。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本の土地が言わば大陸の辺縁のもみ砕かれた破片であることには疑いないようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある遠い所がある近い所よりも交通的には近くなったりして、言わば空間がねじれゆがんで来た。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は西洋人のように自然と人間とを別々に切り離して対立させるという言わば物質科学的の態度をとる代わりに、人間と自然とをいっしょにしてそれを一つの全機的な有機体と見ようとする傾向を多分にもっているように見える。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは言わば多少気のきいたノート・ド・カルネー（手帳の覚え書き）ぐらいにはなるかもしれないが、しかし日本俳句の力強さも、振動性も拡張性もない」というのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに絵巻物と、その後裔であるところの活動映画も言わばやはり一種の「時の器械」である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに宣伝という事は、言わば「世の中をただ一色に塗りつぶそうとする努力」である。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「私は言わば偶然にセリストになった。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその少し強制がましい調子のなかには、自分の持っている欲望を、言わば相手の身体にこすりつけて、自分と同じような人間を製造しようとしていたようなところが不知不識にあったらしい気がする。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして吉田の寐られないのはその気持のためで、言わばそれはやや楽しすぎる気持なのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と蔵の中に、何とやらと言った、その口の下……「手前じゃ、まあ、持物と言ったようなものの、言わばね、織さん、何んですわえ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひなは七月に行った時はまだ黄色い綿で作ったおもちゃのような格好で、羽根などもほんの琴の爪ぐらいの大きさの、言わば形ばかりのものであった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに今もいる鴨羽の雌は人間で言わば仲を取りなし顔とでもいったような様子でそば近く寄って行って、いつもとは少しちがった特殊な低い鳴き声を発していたそうであったが、そのうちにある日突然その暴君の雄鳥の姿が池では見られなくなったそうである。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは言わば固液気三態の原子構造の説明と見られる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わば√-1を含むイマジナリーな部分から成る拡散現象であるとも言われる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、たとえば理論から出した最大｜剪断応力の趨向を示す線系が、実物試片のリューダー線や、「目に見える割れ目」とだいたい一致していたとしても、それは言わば偶然であって、必ずしもそうならなければならないというだけの根拠はまだ具備していないのである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上述べたものの多くは、言わば「並行縞」と呼ばれるべき形態のものであったが、このほかになお「放射縞」と言わるべきものがある。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばピアノの鍵盤や、オストワルドの色見本は、言わばそういう方向への最初の試歩である。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる頭のいい人は、言わば足の早い旅人のようなものである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のいい人は、言わば富士のすそ野まで来て、そこから頂上をながめただけで、それで富士の全体をのみ込んで東京へ引き返すという心配がある。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう点では新聞の社会記事というものは言わば宝の山の地図、しかも間違いだらけの粗末な地図以上の価値はないと言ってもよい。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは言わば細胞組織の百貨店であって、後年のデパートメントストアの予想であり胚芽のようなものであったが、結局はやはり小売り商の集団的｜蜂窩あるいは珊瑚礁のようなものであったから、今日のような対小売り商の問題は起こらなくても済んだであろう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わば白粉ははげ付け髷はとれた世にもあさましい老女の化粧を白昼烈日のもとにさらしたようなものであったのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わば違った動物なのである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言わば某陶工が帝展において金牌を獲たときにその作品に使われた陶土の採掘者が「あれはおれが骨折って掘ってやった土をそっくりそのまま使って、そうした金牌をせしめておきながら涼しい顔をしている」と言って憤慨するのと似たことが実際にしばしば起こるのである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画も言わばナンセンス映画で、ストーリーとしては実にたわいないものである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は言わばたわいもない春宵の空想に過ぎないのであるが、しかし、ともかくもわれわれが金城鉄壁と頼みにしている頭蓋骨を日常不断に貫通する弾丸があって、しかもほんの近ごろまではだれ一人夢にもそれを知らずにいたというだけは確かな事実なのである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸竹の柄の節の上のほうを細かく裂いて、それを両側から平面に押し広げてその上に紙をはり、その紙は日月の部分蝕のような形にして、手もとに近いほうの割り竹を透かした、そういうものが、少なくもわれわれの子供時代からの団扇の定義のようなもので、それ以外のものは言わば変種のようなものであった。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
