    "definitions": [
      {
        "index": 1,
        "gloss": "to celebrate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "町の店屋へ買い物に行くと、お前さんの故国でもワイナハトを祝うかなぞときくのがだいぶありました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月をめでたいとして祝うことを始めて発明した人があったとしたら、その人はやはりなかなかえらい人であったろうと思われるのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を掴んで釣し下げた女の顔の形をした、ぶらり火というのが、今も小雨の降る夜が更けると、樹の股に懸るというから、縁起を祝う夜商人は忌み憚って、ここへ露店を出しても、榎の下は四方を丸く明けて避ける習慣。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫様にお祝儀を申上げ、われらとても心祝いに、この鯉魚を肴に、祝うて一献、心ばかりの粗酒を差上げとう存じまする。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペエトル一世が、王女アンの結婚を祝う意味で、全国の町々に、このような小さい公園を下賜せられた。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は、どうも、お正月にはかえって数の子だの豆だの、わざと粗末なたべものばかりで祝うのですからね、痛快な国ですよ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春じゃないか」旧正月を祝うとて浜に引揚げられた漁船には何れもへんぽんとして旗が飜っていた。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "刃物で斬られた夢を見れば、金が身に入るといって祝うじゃあないか。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来ならば、めでたいと祝うのが当然でありながら、それを聞いて近江屋の夫婦は一種の不安に襲われた。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟丙の家で鐘の完成を祝う宴が催され多数の客が来ている旨を、豎牛が答える。",
              "citation": {
                "source": "牛人",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二十三か四の年の暮が仙崖さんの絵の通り『サルの年祝うた』になってしもうた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのも、我々が現れたときちょうど祈祷書を懐にしまい、朗らかに祝うがごとくその邪悪な花婿の背を叩いたからだ。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉卿は曾て卞家の婢を頼んで、非雲の裸浴を覗いた事あるから、粗ぼ其樣子を知り居た筈だが、埃及の回徒に在ては、新婚の夜、新夫が新婦の顏を初めて見る直前、顏見せ料若干錢を渡し、さて否がるのを強て其顏を露はし視て「神樣辱けない、今夜お目出たう」と祝うと、新婦もお目出たうと祝う。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫様にお祝儀を申上げ、われらとても心祝ひに、此の鯉魚を肴に、祝うて一｜献、心ばかりの粗酒を差上げたう存じまする。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その凶報はおだやかなりし老人の胸を攪乱したばかりでなく、宵祭りを祝うべき平和な家庭をもかきにごした。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "婚姻の席上では酒の後には長く繼がる樣といふ縁起を祝うて、一つには膳部の簡單なのとで饂飩を饗すのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これがお前の門出を祝うお酒だよ」こう言って一口飲んで弟にさした。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は縁起を祝う日ですからね、泣いてはいけませんよ」　言い残して出て行く源氏の春の新装を女房たちは縁に近く出て見送っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "千年の春を祝うのにふさわしい日である。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏羲嬉しさの余り、その婦に汝が朝手初めに懸った業は、※まで続くべしと祝うて去った。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "古スウェーデン三大祭の一たるジサ祭はこの記念のために始められたので、かの国キリスト教に化した後も、毎年二月初めの日曜にこれを祝うて今に絶えぬと、ロイドの『瑞典小農生活』に出づ。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活祭の節、キリスト教徒が鶏卵を食い相｜贈遺するに付いて、諸他の習俗、歌唄、諺話、欧州に多いが、要するに天の卵より雛の生まれ出るにキリストの復活を比べ、兼ねて春日の優に到ると作物の豊饒を祝うたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故我を打つかと問うと、知れた事、麦藁塚に遇わば多く入れ多く入れと豊作を祝う詞を述べながら右へ遶るのだ、それを何も言わずに左へ遶ったは違法だという。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時唱う歌の一つに「猪の子神さん毎年ござれ、祝うて上げます御所柿を、面白や云々」、『華実年浪草』十に、ある説に亥子餅七種の粉を合せて作る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十一年出板、永尾竜造君の『支那民俗誌』上に一月七日支那人が鼠の嫁入りを祝う事を載す。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく当夜謹慎して鼠を饗するは年中の鼠害をなるべく差し控えてもらう心から出たのを、鼠はその頃交わるもの故、鼠の婚儀を祝うものと心得るに及び、和漢ともに鼠の嫁入りと称うるに至ったのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "上子の子の剋、臼を搗けば鼠種尽きるというも実は本末顛倒で、鼠が殺し尽されて今年の収穫は早この通りと、臼をつく多忙を示し祝う意に出たと考う。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で正月に餅を鼠に祝う代りにこのパンを取り寄せて与えるがよかろう。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――『金剛』は、かどでをいわう信号旗をかかげた。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹船の祝儀といって、沖で祝儀をつけてやることが出来れば、ことしの鰹は大漁だと縁起をいわう。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            }
          ]
        }
