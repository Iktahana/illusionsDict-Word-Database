          "literary": [
            {
              "text": "材料は割合に平凡でも生け方で花が生動するように少しの言葉のはたらきで句は俄然として躍動する。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に調べると、人に優雅で芸術的な花の生け方を教えることのみを務めとする、先生がいるという事実が判って来る。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
