    "definitions": [
      {
        "index": 1,
        "gloss": "stone knife (Jomon-period tool, shaped like a rice spoon)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
