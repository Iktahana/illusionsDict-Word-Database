          ],
          "literary": [
            {
              "text": "お前が一人でやつて行けるものでもないし。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は陸にもかうして上つて來れるし、また海の底へも、もぐつて行けるから、兩方の暮しを比較して眺める事が出來るのだが、どうも、陸上の生活は騷がしい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の上に俯伏して居れば雀のお宿に行けるなんて、あははは、馬鹿な事だが、でも、どれ、それではひとつお言葉に從つて、ちよつと行つてまゐりませうか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし案内の剛力（名を勝又琴次郎という）が、今まで幾回も登山したが、頂上へ登らずに、下山したのは、ただの一度しかないと「山運の好い男」を誇っているのが、何だか便りのようにも思われて、私と弟とは、その男に先導されて、闇の中を、行けるところまで行くことにした。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して大年増の莫蓮を荷って行ける逞しさもまた知恵も備えた眼ではない。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそういう考えを裁くために、東京から汽車で二時間ほどで行ける海岸の旅館へ来た。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では震災後、東京に飲食店が夥しく殖えたが、それは飲食店開業が一番手早くて、どうにかやって行けるからだと聞いた。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人はしばらく棚をさがしてから、「これだけ拾って行けるかね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはもう、ほんたうの天上へさへ行ける切符だ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつをお持ちになれぁ、なるほど、こんな不完全な幻想第四次の銀河鉄道なんか、どこまででも行ける筈でさあ、あなた方大したもんですね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちどこまでだって行ける切符持ってるんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりもこうすればうまく行ける。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ている自分が「その絵の中に這入って行ける」ような絵はあるまいか。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ安易な心持で自然に額縁の中の世界へ這入って行けるように思う。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、両人も東京へ行けるかも知れない。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな物を東京へ持って行けるんじゃなし、イッケシ（親戚のこと）へ預けとく云うたって預る方に邪魔にならア！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前等両人でどこへ行けるもんか。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金で街へ遊びに行ける。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、もう十三寝たら浦潮へ出て行けるんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　十三寝ると病院列車に乗って浦潮へ出て行ける。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、又、「アルファベット数えてしまえば、親爺や、お袋がいるところへ帰って行けるんかな。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうところは見つからんか、そこへ出りゃ、すぐイイシへ行けるんだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの特技があれば世界を胯にかけて食って行けるのだと感心した。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿、考へてもみろ、仔細も云はずに暇を貰いに行けると思ふか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだけあれば、妻と老母と、二人の子供が、一ヵ月ゆうに暮して行けるのだ！",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れかさきに扉を開けて這入って行きさえすれば、あとは、すぐ、皆ながおじけずになだれこんで行ける。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、社会でうろ／＼した末、やっぱし俺等のような士鼠が食って行けるのはこの鉱山だけだ、どこをほっついたっていゝこたない、と思って帰って来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと行けると思う人はと云ったら内藤君や四人だけ手をあげた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男バナナと隠元豆を入れたる提籠を携えたるが領しるしの水雷亭とは珍しきと見ておればやがてベンチの隅に倒れてねてしまいける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春なれば茶摘みの様汽車の窓より眺めて白手拭の群にあばよなどするも興あるべしなど思いける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
