      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "obediently",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "部長の指示には唯々諾々として従う部下は、時にチームの活性化を妨げることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "コンサルタントはクライアントの要求に唯々諾々として応じるのではなく、専門的な見地から改善案を提示すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は権力者に唯々諾々として仕え、自らの良心を犠牲にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「社長、この計画に反対意見はありませんか？」と問われ、彼は唯々諾々として「ありません」と答えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統に唯々諾々として従うばかりでは、時代の変化に対応できなくなるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親の言うことには唯々諾々として従っていた子供が、成人してから自分で判断を下すことに苦労するケースは少なくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "最初の中は多少は、自分自身の立場も、発揮したいような傾向も見えたが、しかし今はもうとても歯がたたないと観念して、ただホームズの為すままに、唯々諾々として、後からついて来るだけのことになってしまった。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、項羽の暴政は益々烈しくなつたが、范増はそれ以来唯々諾々として一言も王を諫める事をしなかつた。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏へ署名して判を押すのだが、僕は判を持っていないから、君の名でやってくれないか」　雄吉が、青木の依頼を唯々諾々としてきいたのはむろんである。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも自分が、青木の命令によって、唯々諾々として○○銀行支店へ引き出しに行った百円の小切手に相違なかった。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が、心を掛けるとどの女も、唯々諾々として自分の心のままに従った。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男性（夫をも含む）を虐待し、その苦痛を忍受しつつ唯々諾々として自分の美の光りを渇仰する有様を見て、初めて愛欲の徹底的満足を受ける実況は、容易に覗い得られぬと云うに止めておく。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、作者は、また唯々諾々としてこれに応ずるということである。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは太平の世には、上士たちの命令を唯々諾々としてきいていた。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その買値は、時価よりもうんと安かったけれども、売り手は別に不足をいわず、唯々諾々として、彼のつける値段に満足した。",
              "citation": {
                "source": "変な恋",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて近衛首相が各大政党の領袖を招いた挙国一致政策の支持を求めた際、安倍党首が唯々諾々として引き下ったということも、少なからずファッショ化の名を高からしめたようだ。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も唯々諾々としてその命に従い、あるいは又、内部に反感等を抱きながら表面には唯これに従うごときは、わが望むところにはこれなく候。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "大内自身、組織的な決定に唯々諾々として従い、与えられた仕事だけをこなすタイプの人間ではない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い換えれば国の法律なり風俗なりに対して全く服従出来ないことがあったなら、即ち心に服従することを欲しないことあるのにかかわらず、表向だけ唯々諾々としてこれを遵奉するは自ら欺くというもので、内部の矩を踰ゆるものではなかろうか。",
              "citation": {
                "source": "自由の真髄",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはその理想さえ主張出来得れば、曾て犯した唯心論的文学の古き様式をさえも、唯々諾々として受け入れているではないか。",
              "citation": {
                "source": "新感覚派とコンミニズム文学",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "病弱の身体で、あの気紛れな――今は大へんよくなったが――癇癪持ちの夫に仕えて、些の不満も現わさず、唯々諾々として忠実を守っている姿は涙ぐましいものがある。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黙つて、唯々諾々として僕につきあつて呉れませぬか。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は第一の左甚五郎の如く、たゞ唯々諾々として己れを造つた人間に弄ばれ、其人の娯樂の爲に動くやうな人間を造るのであらうか。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは第一の左甚五郎の如く、ただ唯々諾々として己れを造った人間に弄ばれ、その人の娯楽のために動くような人間を造るのであろうか。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く唯々諾々として命令に服しているんだ。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒中に筍をほってこいといわれても、唯々諾々としていられるのは、一方では親という絶対の専制君主の下に生まれ落ちるから圧迫されて、極端に奴隷的の心持ちをやしなわれ、一方ではのんきなむかしの時代の人は、いまの人よりはずっとずっと鈍感であったからだろうと思います。",
              "citation": {
                "source": "親子の愛の完成",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "収入もまたかりにお客が二千円くれたのに千円ですと言って、その中から千円分の税金と部屋代、（折半に近い金額）を支払われても、パレス側は一切、女からのあてがい扶持で、唯々諾々としていなければならない。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽上ではあまりに自信が乏しかったので、自分の感情に頼ることができないで、音楽長やバイロイトの免許者らがワグナーについて与えてくれる注解を、唯々諾々として傾聴していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし頼該自身がまことに唯々諾々として高松へ移ったので、家臣たちの反対は騒動に及ばずして歇んだ。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "態※送って来た人が唯々諾々として送られて行く。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは非常な変り者で、理解し難い命令を下す様なこともあろうが、それを少しも反問せず、唯々諾々として遵奉するという約束で、その代り給金は世間並の倍額を与えることにした。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟はその子に対しては、いつも唯々諾々としているようであった。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
