[
  {
    "uuid": "af0ee268-d07c-59e9-a0a1-b64a53f96cba",
    "entry": "唯々諾々として",
    "reading": {
      "primary": "いいだくだくとして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
