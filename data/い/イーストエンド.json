        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「イーストエンドの中国人の話をした。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして10月５日にスピタルフィールヅ（イーストエンド）で２例が起きた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とアイダが訊くと、「イーストエンドのシャドウェルへ行った。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千人以上の子供たちが、お年寄りは言うまでもなく、イーストエンドで死んだ。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "イーストエンドから流れ込んできて、豪邸をめちゃめちゃにしています」　ヒューバート医師は帽子と外套をひっつかんで出て行った。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りに暑いのでイーストエンドですら毎週の残忍な殺人事件さえ起こりません。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒が洪水のようにイーストエンドに流れ込んでいる。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼けつく陽光の下、数日間、熱風とほこりが続いた後、密集地域のイーストエンドは突然、水が一滴も出なくなった。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "無分別が習いのイーストエンドはその日の割当水量を早々と使い果たし、血走った男どもがもっとよこせと通りでわめき散らしていた。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "下町のイーストエンドではいつも騒動が起こっている。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
