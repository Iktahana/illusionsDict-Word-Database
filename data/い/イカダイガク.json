          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は現役で国立の単科医科大学に合格し、周囲を驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重篤な急患がドクターヘリによって、設備が整った近隣の医科大学附属病院へと緊急搬送された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "某医科大学の研究チームが、難病の早期発見に繋がる画期的な検査手法を確立したと発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「将来は医科大学に進んで、国境なき医師団の一員として活動したいんです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "医科大学の入試を巡る不正得点操作問題は、医学教育界全体の信頼を大きく揺るがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へえ、あの先生は有名な医科大学の学長まで務めた方だったのか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地域の基幹病院としての役割を果たすため、その医科大学は最新の手術支援ロボットを導入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まあ、私立の医科大学は学費が非常に高額なことでも知られているからね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "昔の医科大学の時計台もとくに無くなった。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は医科大学生Ｆ兄弟の宅へ招ばれ、素晴らしく大きなクリスマス・ツリーの下で御馳走になり乍ら、医科大学の教室でつくるツリーへかける飾付けは、人間の心臓や肺、そのあらゆる人体諸臓器の形をボール紙で造らえて色彩をつけたものだという話など聞き夜を更かしました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを長年考えていたのであるが、近ごろ大阪医科大学病理学教室の淡河博士が「黒焼き」の効能に関する本格的な研究に着手し、ある黒焼きを家兎に与えると血液の塩基度が増し諸機能が活発になるが、西洋流のいわゆる薬用炭にはそうした効果がないという結果を得たということが新聞で報ぜられた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は非番だもんで、医科大学へ葛木さんを訪問したです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に思切って、医科大学に刺を通じて面会を求めたです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高峰がそのころはまだ医科大学に学生なりしみぎりなりき。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "医科大学の助教授である彼女の夫が肺を患って寝こんでしまった時、他に男手のない二人暮しの家が物騒だというので、柔道部の選手をしていた轡川に言わば用心棒代りに寝泊りしてもらうことにした。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その区長さんの長男で医科大学に行っている駒吉というのが、ちょうどその時に帰省していて、この話をきくと恐ろしく同情してしまった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシヤの医科大学の女学生が、或晩の事、何の学科やらの、高尚な講義を聞いて、下宿へ帰って見ると、卓の上にこんな手紙があった。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロシヤの医科大学の女学生が、或晩の事、何の学科やらの、」というような頗る不親切な記述があったばかりで、他はどの頁をひっくり返してみても、地理的なことはなんにも書かれてありません。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原作に於てはこれからさき少しお読みになれば判ることでありますが、女房コンスタンチェひとり、その人についての描写に終始して居り、その亭主ならびに、その亭主の浮気の相手のロシヤ医科大学の女学生については、殆んど言及して在りません。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柄こそ大きくても青年は医科大学を出たばかりで二十五歳の助手だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は名を光行とて、医科大学の学生である。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上条に下宿しているものは大抵医科大学の学生ばかりで、その外は大学の附属病院に通う患者なんぞであった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どう、ここから池の端へ降りて、不忍の池の橋を渡って、医科大学の裏の静かな道を一高の前へ出て、あすこで梅月の蜜豆を喰べて、追分のところで、別れるの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一　築地｜明石町に山の井｜光起といって、府下第一流の国手がある、年紀はまだ壮いけれども、医科大学の業を卒えると、直ぐ一年志願兵に出て軍隊附になった、その経験のある上に、第二病院の外科の医員で、且つ自宅でも診察に応じている。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　書生が案内をする暇もなく、医科大学教授杉村茂君がずつとはいつて来る。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の文壇の唯一舞台であった『読売新聞』の投書欄に「蛙の説」というを寄稿したのはマダ東校（今の医科大学）に入学したばかりであった。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "医科大学生と間違えて部屋の番号を聞いたのかしらんと思って、五、六歩あるいたが、急に気がついた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "医科大学がＭだし、明治がそうだし、まだあるだろう。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友人は、己の秘に行った自恂の行為を、いっしょに宿にいた友人が、下宿の者や、附近の者にふれ歩いたと思いだして、それから皆の顔に嘲笑が見えだし、その友人と大喧嘩をした結句、素人下宿へ往ったが、どうも素振が怪しいので、私と、も一人、その当時医科大学へ往ってた友人と二人で、見に往った。",
              "citation": {
                "source": "妖影",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃彼は医科大学生だつたが、卒業までには十年も費し、その間二度も癲狂院に入院した。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治××年にＴ医科大学を卒業して産婦人科の教室に半年あまり厄介になり、両親の希望によって、すこぶる未熟な腕を持ちながら日本橋のＫ町に病院を建てて診察に従事しました。",
              "citation": {
                "source": "メデューサの首",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "△△医科大学が、まだ△△医学専門学校と申しました時分のことで御座います、私は、産婦人科教室の看護婦を勤めて居りましたが、患者の受持ではなく、手術場を受け持って、手術の際に、ガーゼを渡したり手術道具を渡したりする役を致して居りました。",
              "citation": {
                "source": "手術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、私はＴ医科大学を卒業して二年間、内科教室でＢ先生の指導を受け、それから郷里なる美濃の山奥のＨ村で開業することに致しました。",
              "citation": {
                "source": "安死術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様は俺より人間の身体の中のことはずっと委しいはずだから、一つよく考えて見てくれ」　仙波はもと、Ｔ医科大学の病理学教室の小使をしていたことがあって、人間の解剖に馴れていたので、京山はこういったのです。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
