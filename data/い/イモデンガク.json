          "literary": [
            {
              "text": "あすこなら、芋田楽なり雀焼なり、何ぞ肴が見付かろう。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋田楽に、鶉でも焼かせて、一献酌もうではないか」四　酒は好きでなかったが、兄の機嫌を損じてはと、「では、支度させましょう」と、右門は先に、戸外へ出て、若党の佐田承平と、仲間の六助とを呼び立てた。",
              "citation": {
                "source": "柳生月影抄",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな商売なりゃこそ芋田楽などといふものも食ふなり、面白し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙っているが、ひもじそうに見えたので、観音堂の境内で、串にさした芋田楽を買ってやると、お三輪も乙吉も、歩きながらムシャムシャ食べる。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
