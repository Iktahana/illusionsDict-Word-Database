        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今しき世の中では、こういった古い習慣は敬遠されがちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今しき若者は、そんなことまでスマホで済ませるのかい」と祖父が驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今しきの流行を追いかけるのも疲れるが、全く知らないのも不便だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その夢の中で、天照大神と高皇産霊神のお二方が、建御雷神をおめしになりまして、葦原中国は、今しきりに乱れ騒いでいる。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日の約束がもう五日になるでねえか」　半七は表から覗いてみると、今しきりに呶鳴っているのは、三十五六の赭ら顔の大男で、その風俗はここらの馬子と一と目で知られた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "原口は今しきりに美禰子に何か話している。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "最もわかりやすい例で言えば昨今しきりに問題になつている映畫藝術は決して觀念から生れたものでなくて、或る時代に活動寫眞が發明された爲めに生じたものである。",
              "citation": {
                "source": "唯物史觀と文學",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い大きな枯木の上で、カラスが拡声器をすえて、今しきりに、こんなことを喋っています。",
              "citation": {
                "source": "ペンギン鳥の歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが、僕の工場には今しきりにロシアの手が這入って来てるのでね。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤坂の芸者にひっかかった尻ぬぐいその他すっかりさせた男、段々隣保館で勢力を得て、今しきりに反竹内熱をたきつけて乗とろうとして居る。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外で食事をとったり、帰宅を急がなくてもいい身の上になったことが、今しきりに顧みられた。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かが今しきりに戻って来るようだ。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "短かい、単調な、笛の音は、あつちの家からも、こちらの小屋からも、今しきりにもの珍しげに鳴りひびくのであつた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かが今しきりに戻つて来るやうだ。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今しきりに夢みる、真昼の麦畑から飛びたつて、青く焦げる大空に舞ひのぼる雲雀の姿を……。",
              "citation": {
                "source": "心願の国",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうね、そのことについて今しきりと考えているのです……。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『今しきりに啼いてゐるところだから、非常にいい都合だ。",
              "citation": {
                "source": "仏法僧鳥",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "原口は今しきりに美禰子に何か話してゐる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、兵士等の鞆の音が今しきりにしている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『今しきりに啼いているところだから、非常にいい都合だ。",
              "citation": {
                "source": "仏法僧鳥",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは、高度三百キロメートルどころか、その十分の一にも足りない高度の成層圏飛行で、今しきりに冷汗をかいているのですからなあ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見の心のなかでは、今しきりに幻想が渦を巻いている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼等は今しきりに私の方を指さしながら、互に顔を見合せているのです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここヘルモン山のほとり、ミザルの丘近く、ヨルダンの水源湧きて流るる地に立ちて古の詩人のうたえる歌が、今しきりにわが脳裏を去来する。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鈴虫が今しきりに声を張って鳴いて居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今しきりに考えて居ります、明日どうしようかと。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく坐しきあてに墨磨り唐やうの画をたしなみと書を楽しみと田のそなた堀に柳のしだれたる離家の※に老いていましき藩札藩札は赭き紙ぎれ、皺に寂び黴くさき札、うち廃り忘られし屑、うち束ね山と積めども、用も無し邪魔ふさげぞと、放られてあはれや朽ちぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまいましき門閥、血統、迷信の土くれと看破りては、我胸の中に投入るべきところなし。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまいましき門閥、血統、迷信の土くれと看破りては、わが胸のうちに投げ入るべきところなし。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜひなく財布のそこをはたきて船を雇えば、ひきちがえて客一人あり、いまいましきことかぎりなし。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながれるたる　高一少年をさらってゆく外国の貨物船が、いましきりに日本の軍艦から砲撃されています。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまいましきは武男――　　　　　　　＊　「武男、武男」と耳近にたれやら呼びし心地して、愕と目を開きし千々岩、窓よりのぞけば、列車はまさに上尾の停車場にあり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまいましきは武男――　　　　　　　＊「武男、武男」と耳近にたれやら呼びし心地して、愕と目を開きし千々岩、窓よりのぞけば、列車はまさに上尾の停車場にあり。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
