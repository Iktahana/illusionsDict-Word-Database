        "examples": {
          "standard": [
            {
              "text": "災害現場から、数体の遺体が見つかり、その多くが遺体袋に入れられて搬送された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "警察は、事件現場から発見された遺体について、慎重に遺体袋への収容作業を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「遺体袋には、検死官が記入した情報がすべて記載されているはずだ」という指示が飛んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "救急隊員は、急いで遺体袋を準備し、遺体の損傷を防ぐよう慎重に扱った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大量の遺体が発生した場合、遺体袋の確保が迅速な対応の鍵となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この遺体袋は、温度管理機能も備わっている特殊なものです」と担当者は説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
