    "definitions": [
      {
        "index": 1,
        "gloss": "news from home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅先で受け取った一通の家言を読み返し、遠い故郷の情景に思いを馳せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦地からの返信には、緊迫した情勢よりも、庭の果実が実ったといった些細な家言が記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遠く離れた異国の地で、風の便りに届くわずかな家言だけが、孤独な日々を支える糧であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「せっかくの帰省なのだから、今夜は積もる家言をゆっくりと聞かせておくれ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ああ、こうして家言を交わしていると、まるで昔に戻ったかのような心地がするよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「久しく家言が途絶えているけれど、田舎の両親は元気にしているだろうか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "故に牧水氏を始めとし、前田夕暮氏でも齋藤茂吉氏でも、當時の歌人は皆僕等の詩を理解して居り、常に一家言の批評を持つてた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦節は貞くす可からずの一句、易の爻辞の節の上六に、苦節、貞くすれば凶なり、とあるに本づくと雖も、口気おのずから是道衍の一家言なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒薔薇栽培にも一家言を持っていた。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢判断にも一家言を持つこのオレが分析すれば、ＦＭ　ＴＯＷＮＳという可能性を秘めた原石にオレはもう一化けを期待しているということなのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今其の道家といふものを實に就いて檢して見ると、伊尹、太公、辛甲、鬻子、管子、老子、文子、冠子、周訓、黄帝、力牧、捷子、曹羽、郎中嬰齊、臣君子、鄭長者、楚子、道家言等九百九十三篇が擧げてある。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『琅邪代酔編』二に拠れば、董元英の『談藪』には道家言う、鶏犬を先にして人を後にするは、賤者は生じやすく貴者は育しがたければなりとある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "司馬遷の時は、歴史の編纂は、之によつて一家言を立て、自分の創作とするつもりがあつたのが、後にはその意味が變つて、人のものを編纂することになつた。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれどもこれ一家言のみ。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句を以て最上の文学と為す者は同じく一家言なりといへども、俳句もまた文学の一部を占めて敢て他の文学に劣るなし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎俳句の将来についての一家言――俳句は畢竟階級的なものではありえない、階級意識を高唱するには川柳的なものが出来るであらう、そして大衆的娯楽文芸として俳句は堕落すると共に、詩としても高上し純化するであらう、それが真の俳句であり、芸術家の芸術であり、純日本的なユニイクなものである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く本私刑史、曰く支那刑法史、曰く経子一家言、曰く周易一家言、曰く読書五十年、この五部の書が即ちこれである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは其書の善悪を知らぬが、要するに一家言である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛至上主義者も、この事件について、一家言をたてるものも、家庭にあって、子女を前にしては、説が矛盾するといった。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は此方面に就ては省略し、たゞ哲學史と哲學との關係に就て學風の推移を考察し、之を自家所見の圈内に導き入れて一家言を提出し、以て此變移を體驗し又誘導せられた先覺に對する賀壽記念の料に充てんとするのである。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "定メテ其ノ心ニ逆カフコトモ有ランナレド、ソハ余ガ一家言トシテ宥シ給ヒネ。",
              "citation": {
                "source": "好古小言",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、武家言葉が、とがめるのを、お初、「おたすけ下さいまし、いま、あとから乱暴者が――」「なに、乱暴者？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物を遣らして見ると帳面ぐらいはつけ、算盤も遣り調法でべんちゃらの男で、百姓を武家言葉で嚇しますから用が足りる、黒の羽織なぞを貰い、一本｜帯して居る、其のうち　富「古い袴が欲しい、小前の者を制しますには是でなければ」　などとべんちゃらをいう。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常にお世辞のいい同氏の反駁を、僕が取立ててかれこれ云ふ筋合でもなし、殊に、演出に関する興味ある一家言は、僕を首肯せしめるに足るものであつた。",
              "citation": {
                "source": "稽古のしかた",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し然りとすれば、其れは雄が大なる心得違で、賦には賦の體あり、一家言を論述するには又た論述の體があつて、兩者を混同することは勿論惡い。",
              "citation": {
                "source": "楊雄と法言",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は理想國の名を、如何にも地方の學者らしく、字面からこじつけ引きよせた一家言であつたのだらう。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも一家言をもち、自信をもち、放言し、自分が行くところ可ならざるはない「器用人」だと思い込んでいる人のことをゲーテはいうのである。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来一家言は論理性の欠如をその特質とする。",
              "citation": {
                "source": "一家言を排す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池寛の「話の屑籠」は現今文壇における一家言の代表的なものであつて、一部識者の好評を得てゐることは、我国の教養がその真実の論理的訓練に不足してゐることを明かにしてゐるにすぎない。",
              "citation": {
                "source": "一家言を排す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてそれを書きました時は、一家言として、自分の一己の主張があつて書いたのであります。",
              "citation": {
                "source": "支那の書目に就いて",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "史記を見ると、いろいろのものを集めて一纏めにして自分の一家言を作るのであると云つて居る。",
              "citation": {
                "source": "支那の書目に就いて",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那では之を一家言と申しまして、皆人によつて言ひ傳へが違ふので、即ち異部名字と同じやうなことであります。",
              "citation": {
                "source": "大阪の町人學者富永仲基",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "史記の如きは明かに其の思想を以て書かれたもので、陳杞世家の末には人民に功徳の有つた人の末孫が或は帝王となり或は大諸侯となつたのであつて、それには世家言あり本紀言ありと斷つてゐる。",
              "citation": {
                "source": "尚書稽疑",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつきり分りよいのが卜筮でありますが、左傳・國語の卜筮に關したことは、日本でも卜法の上から注意した人がありまして、谷川龍山といふ人が「左國易一家言」といふ本を作つた位であり、それに左傳・國語の卜筮に關した記事が大方載つて居ります。",
              "citation": {
                "source": "支那歴史的思想の起源",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の議論に就いては私は餘り贊成をせぬ所もあり、又贊成をする所もありますけれども、南北の書派の議論は阮元の一家言で、私は全部贊成を致しませぬ。",
              "citation": {
                "source": "弘法大師の文藝",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
