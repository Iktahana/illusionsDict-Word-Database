        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "強盗は抵抗した店員の息の根を止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの革新的な技術は、旧来の産業の息の根を止めるほどの衝撃を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "度重なる規制強化が、零細企業の息の根を止めかねない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "度重なる予算削減は、その研究プロジェクトの息の根を止めてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう！あの人のせいで、私の企画の息の根が止まったじゃない！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その差別的な発言は、多様性を重んじる社会の息の根を止めるものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "独占的な価格設定は、市場の健全な競争の息の根を止めてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「これで突けば可いのです」「…………」「さては貴方はこんな女に未だ未練が有つて、息の根を止めるのが惜くてゐらつしやるので御座いますね。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで息の根を止めるやうな一矢を報いることは、私の残虐な興味から愉快でしたが、――「友達と」と言つた言葉で直ぐに私は照子のやうなその友達のグループを連想すると、何となくさうしてしまふことが惜しまれて、――と、芝居に行つて見たくなりました。",
              "citation": {
                "source": "愚かな朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、貴方の不具な部分をもってせずには、誰一人博士に、自殺の証跡を残して、息の根を止めることは不可能だったのですよ」「すると、敷物の波は何のためだい」熊城が横合から訊ねた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたの腕なら、舞台から笄を投げても、三斎めの息の根を止めることは出来ようが、それでは、望みの十分の一を、達したとも申されぬ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その徹底的――いいか徹底的だぞ、徹底的に息の根を止めるには、われわれが出馬しないと、どうしても駄目なんだ。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度こそ逃がさず追い詰めて、息の根を止めるでございましょう」　狂信者の群を見廻したが、「向こうへ逃げて行くあの男こそ、我々にとっては無二の敵、教法を妨げる法敵でござる。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またしても、最近（二十三年七月二十日）たまたま実施されることになった「事業者団体法」は実に協会の息の根を止めるような形になって現われて来た。",
              "citation": {
                "source": "日本出版協会論",
                "author": "嶋中雄作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう一息で小鳥の息の根を止めるところだった。",
              "citation": {
                "source": "狂人日記",
                "author": "ギィ・ドゥ・モオパッサン　Guy de Maupassant",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、この関ノ孫六で、貴殿の息の根を止めることと致そう。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも出会ったら最後、息の根を止めるだけじゃなくって、お前や坊主まで、後腐れを怖がってバラすにきまっている。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上建物は明治時代の古風な煉瓦で、其処から麗人奈々子を奪い去ったとすれば、飛降りることなどは思いも寄らず、奈々子が承知の上で無ければ、息の根を止めるか気を喪うかしたまま、引っ担いで梯子で降りるか、逞しい縄梯子でも用意しなければならないわけです。",
              "citation": {
                "source": "笑う悪魔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊敬ばかりを要求して発達しないうちに改革の息の根を止めるような古い慣習がこの大学には無かった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくこれが最後になるだろうと、レックミア侍従が独り言を言ったのは、その朝、マザロフの息の根を止める邪魔をしたからであった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はいま気力十分だから、お前の猪首を絞めて、息の根を止める事も出来る。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの手で、息の根を止めるのは不気味だとみえ、お頭の※龍さまに、ご処分を願いますッて、口を揃えての嘆願なんで」「そうか。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
