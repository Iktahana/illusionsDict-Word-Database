[
  {
    "uuid": "30e19c4f-a36e-5803-9eed-920d0bfd031a",
    "entry": "一般大衆",
    "reading": {
      "primary": "いっぱんたいしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
