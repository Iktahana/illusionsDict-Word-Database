        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水泳が苦手な友人も、犬かきならなんとか泳げると言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、海で溺れそうになった時、必死で犬かきをして岸までたどり着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "犬かきは、初心者でも比較的簡単に習得できる泳ぎ方だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "黒いふんどしの子供たちは、犬かきや、蛙泳ぎや、平泳ぎを、唇が青くなつてガタ／＼ふるへるまで、練習します。",
              "citation": {
                "source": "プールと犬",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いふんどしの子供たちは、もう犬かきや、蛙泳ぎばかりしてはゐません。",
              "citation": {
                "source": "プールと犬",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、水が乳首の辺まで来たところで、彼は浅い方に向かってほんの一間ばかり、犬かきをやって見せた。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ犬かきをして、横｜桁にしがみつくばかり。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
