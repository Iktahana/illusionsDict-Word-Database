          ],
          "literary": [
            {
              "text": "黒いふんどしの子供たちは、犬かきや、蛙泳ぎや、平泳ぎを、唇が青くなつてガタ／＼ふるへるまで、練習します。",
              "citation": {
                "source": "プールと犬",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いふんどしの子供たちは、もう犬かきや、蛙泳ぎばかりしてはゐません。",
              "citation": {
                "source": "プールと犬",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、水が乳首の辺まで来たところで、彼は浅い方に向かってほんの一間ばかり、犬かきをやって見せた。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ犬かきをして、横｜桁にしがみつくばかり。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
