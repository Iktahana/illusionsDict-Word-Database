    "definitions": [
      {
        "index": 1,
        "gloss": "nodding off (while sitting)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜遅くまでゲームをしていたせいで、午後の歴史の授業中にうっかり居眠りをしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "暖かい春の陽気に誘われて、縁側で新聞を読んでいたはずの父が気持ちよさそうに居眠りをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "会議室の一番後ろの席で居眠りしていた新入社員を、部長が咳払いでやんわりと注意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さては五十鈴の流れ二見の浜など昔の草枕にて居眠りの夢を結ばんとすれどもならず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ていたとき、私のすぐ右側の席にいた四十男がずっと居眠りをつづけて、なんべんとなくその汗臭い頭を私の右肩にぶっつけようぶっつけようとしていた。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある猫は料理番が台所で居眠りをして火事を起しかけたのを主人に急報した。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の暖かい日にはうとうと居眠りをした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は快げに居眠りをしている。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の旅行は単に月並な名所や景色だけを追うて、汽車の中では居眠りする亜類のではなくて、何の目的もなく野に山に海浜に彷徨するのが好きだという事である。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居眠りなんぞをすると花輪が歪むからな。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい／＼、こいつ居眠りをしているよ」暫らくして後藤は西山の耳もとへきて囁いた。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗保が、揺れる薪の上からおりて来ると、三人は、スパイが居眠りをしているのとは反対の北側へ集った。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪は、なだれのように、居眠りをしている×××の頭上を××××、××した。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉清輝は、警戒兵も居眠りを始める夜明け前の一と時を見計って郭進才と橇を引きだした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向い側に小間物を行商するらしい中年女が乗って、大きな荷物にもたれて断えず居眠りをしていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」居眠りをしていたばあさんは、ふと眼を開けた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚の閣下は浴槽の縁に頭をゆすぶりながら、居眠りをしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄砲の照準をきめながら、フラ／＼ッと居眠りをしたりした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんは長火鉢を前に三毛を膝へ乗せて居眠りをしている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居眠りしながら歩いていたのでは国道でも田んぼへ落ちることなしに目的地へは行かれまい。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海道を居眠りして来た乗客が品川で目をさまして「ははあ、はがなしという駅が新設になったのかなあ」と言ったのも同様である。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "“Nevermore”　空の蒼く晴れた日ならば、ねこはどこからかやって来て、庭の山茶花のしたで居眠りしている。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見給え、この湖水の岸にしゃがんで、うつむいて何か考えている写真、これはその頃、先輩たちに連れられて、三宅島へ遊びに行った時の写真ですが、私はたいへん淋しい気持で、こうしてひとりしゃがんでいたのですが、冷静に批判するならば、これはだらしなく居眠りをしているような姿です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分遠い道のりだったので、私は歩きながら、何度も何度も、こくりと居眠りしました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉はお花が土蔵の前の石段に腰掛けて唱う唱歌をききながら茶室の窓に倚りかかって居眠り、源造に誘われて釣りに出かけて居眠りながら釣り、勇の馬になッて、のそのそと座敷をはいまわり、馬の嘶き声を所望されて、牛の鳴くまねと間違えて勇に怒られ、家じゅうを笑わせた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は無言で仕事をしていたが、母の手は折り折りやんで、その度ごとにこくりこくりと居眠りをしている。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何んだ、試験だ……試験ぐらい貴様、教場に行って居眠りをしていりゃあ、その間に書けっちまうじゃねえか」「俺に用がなければ行くぞ」　石岡が顔色も動かさずにそういいながら座をはずしかけた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春｜日和の暖かい日にはうとうと居眠りをした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　……居眠りいたいて、ものもあろうず、棺の蓋を打つよりも可忌い、鉄槌を落し、釘を溢す――釘は？",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の旅行は平々凡々、未醒子ははや居眠りを始める。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コラコラ、今から居眠りをするようでは駄目じゃッ」と、髯将軍の銅鑼声はまず車中の荒肝を拉ぐ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト今まで居眠りをしていた剛力先生、二人共ノソノソやって来て、吾輩等の背後から猿臂を伸ばして水筒を掴もうとする。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側にすわって、いねむりしていたおばあさんは、目をあいてかぶと虫を見ると、「なんだ、がにかや。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
