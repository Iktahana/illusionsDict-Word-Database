    "definitions": [
      {
        "index": 1,
        "gloss": "to persuade someone to accept the inevitable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "説法が旨いで、因果を含めるに可いわい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と因果を含めるようにいわれて、枝の鴉も頷き顔。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松の内ア仕様がねえ」と、お菊にも因果を含めるより外に、何んとする術もなかった。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ因果を含めるのでも、親元へ返すぶんには、死あるのみ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子に因果を含めるために帰朝させたと考えても妙な話。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩泊めて因果を含める積りのところ、ついそのまゝ同棲してしまったんです」「成程、お察し申す。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お關と一緒にして、暖簾をわけてやる筈でしたが、かうなると、因果を含めるより外に仕樣もございません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "結納の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お富、――若旦那はお店へ歸つたが、三百八十兩の金が戻らなきや、親類方や古い奉公人の手前、増屋の跡取りに直るのがむづかしい事は、お前にも判るだらうな」　改めて彦兵衞は、娘に因果を含めるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "巾着切の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの事件を未然に防ぐための努力をしなかったという責任は免れまい……」と因果を含める如く語ったことがあった。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お富、――若旦那はお店へ帰ったが、三百八十両の金が戻らなきゃ、親類方や古い奉公人の手前、増屋の跡取りに直るのがむつかしい事は、お前にも判るだろうな」　改めて彦兵衛は、娘に因果を含めるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巾着切りの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お関と一緒にして、暖簾を分けてやるはずでしたが、こうなると、因果を含めるより外に仕様もございません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "結納の行方",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
