          ],
          "literary": [
            {
              "text": "蝦夷国の大刀は、剣かは弓も刀も、鉄砲に対して力ない事を知つたが、尚そこに誇りを棄てないで、ひたすら其鍛錬の技術の神異を述べたのである。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "象山また復書を持ちて夷国に到らんと欲す、則ち曰く、「微臣別に謀を伐つの策あり、安んぞ風船を得て聖東に下らん」と。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが夷国の小卒を斬ったところでご名誉にはなりません。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことに捉われていたから、東京人は田舎者にずんずん追いこくられてしまったのよ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何｜吐すぞい、この野郎、贅沢べいこくなてえ、狐店の白ッ首と間違えてけつかるそうな、とぶつぶつ口叱言を申しましての、爺どのが振向きもせずに、ぐんぐん曳いたと思わっしゃりまし。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小さな声で、「おだいこくがおいでかね。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "左か、右か、毛縮緬などからめかいて、いやらしい、犬がしいこくとおなじじゃぞに、に、に。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり自分は倉地を死に神のもとへ追いこくろうとしていたのだなと思った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たれが、朝鮮から彼らを満州の荒地へ追いこくったかを！",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君みてえなげいこく人に闘牛の味が解って耐るもんか。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての権力をソヴェトへ※　餓えた農民と労働者は不決断な臨時政府がついにブルジョアの手先で彼らのものでないことを理解し、兵士は塹壕から、フロックコートを着てやって来る社会民主主義の煽動者をぼいこくった。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "反乱が起って坊主は勇敢な水兵に追いこくられ、艦橋からころげおちるところがある。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、父が私を望月庵のおだいこくにするために、何でも叔父が「まあ何よりも必要なのは裁縫がよく出来ることですね」と言ったとかで、その修行をさせるためであった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああれがけいせいけいこくと云い、金さえあれば自由になるものか、わしもやっぱり人の子じゃア……。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "打たれたたかれ追いこくられます。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五のグリーシャ、年がら年じゅうブガーノフの耕地さぼいこくられて、聖母さまのお水のんで命つないでた。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "村ぼいこくってくれっから※　ピムキンは、黄色いみっともない顔をふるわせ、二つの眼だけ空にある太陽のかけらはめたようにギラギラさせている。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文に曰く、“やみかわ、きちんど　に　けいこくする。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鬼王の文字に「キワウ」と假名づけがしてあるなど、いかにも藤村君らしいこくめいさである。",
              "citation": {
                "source": "緑蔭叢書創刊期",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、あるひのこと、ねずみさんは、がいこくからかへつたおぢさんから、ぼうえんきやうをいたゞきました。",
              "citation": {
                "source": "ゾウ　ト　ネズミ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その連中が、われわれに対してけいこくをこころみたのかな。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、おもてがわのほうの血を落したかとおもうと、それはうらがわに、いつか、よけいこく、にじみ出していました。",
              "citation": {
                "source": "青ひげ",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノルマンは、さんざ、巨人ハルクを、利用するだけ利用したうえ、ハルクが毒蛇のためにかまれて、もう再起する力がないと見るや、れいこくにも、ハルクを倉庫の中にすててしまった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに住む出家、比丘尼、だいこく、所化、男色の美少年、その他｜青侍にいたるまで、田畑を耕すこともなくて上白の飯を食い、糸を採り機を織ることもなくてよい衣裳を着る。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　振り向いて頓狂な声でつるが云うのを構わずに、更に一口ごくりとやると、つんと鼻にくる香りから舌重いこくの加減まで、かねて知ってる味だった。",
              "citation": {
                "source": "特殊部落の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こめだわらの　上に、だいこくさまを　かざって、青や　赤の　ふうせんだまが　いくつも　ついて　いました。",
              "citation": {
                "source": "はつゆめ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいこく行進曲をうたおう。",
              "citation": {
                "source": "日の当たる門",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして途方もなく大きな拳を振りまわしながら、一息に彼のいわゆる「ぼいこくってしまった」のを見た他の者は、思わず顔を見合わせて、長大息をした……。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺へかよいだいこくにいっていた妹も、いまではどこかの武家屋敷へ奉公にいっている。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹のあんたはあんたで、その必要がなくなってからも、好きで寺のかよいだいこくをするような女だ。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
