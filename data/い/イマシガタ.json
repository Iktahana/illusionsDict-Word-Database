[
  {
    "uuid": "d32a5fcb-3162-5c1b-a722-946683b42043",
    "entry": "今しがた",
    "reading": {
      "primary": "いましがた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
