    "definitions": [
      {
        "index": 1,
        "gloss": "information",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "現場から最新の一報が入った。状況は刻々と変化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事件の続報が入り次第、すぐに皆さんに共有します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その件に関する一報をお待ちしております。早めにご連絡いただけると幸いです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "全體何の役をやる積りか一寸御一報にあづかりたい。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第一報は、黒田如水の所へ京都の長谷川｜宗仁と云うものから飛脚が来たのである。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、きょう、ちょっと珍妙な事件があったので、前便の不備の補足かたがた早速御一報に及ぶ次第なのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて賓国を乗っ取った話（『民俗』二年一報、予の「話俗随筆」に類話多く出づ）、また柳田君の『山島民譚集』に蒐めた、河童が接骨方を伝えた諸説の原話らしい、『幽明録』の河伯女が夫とせし人に薬方三巻を授けた話などを取り雑ぜた作と見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎の話は主として支那で鬼が桃を怖るるという信念、それから「神代巻」の弉尊が桃実を投げて醜女を却けた譚などに拠る由は古人も言い、また『民俗』一年一報、柴田常恵君の説に、田中善立氏は福建にあった内、支那にも非凡の男児が桃から生まれる話あるを聞いた由でその話を出し居る。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御覧になったら、ハガキででも、御一報を願えませんか、本当にお気に向いた時でよろしいのですから。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前野氏へは、是非一報いたさいで叶わぬことじゃ」　玄適が、すぐそれに応じた。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして貴方の聴覚に訴へたまゝを逐一報告して下されば充分なのです。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前代未聞のこの怪事件を最初に発見し、そしてその現場に一番乗りをした上に、全世界の報道網に対し輝かしき第一報を打つことに成功したデンマーク新報のアイスランド支局員ハリ・ドレゴの命名によるものであった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより早いところ第一報を出そうではないか」　水戸はそういって、リュックの中から携帯用の超短波送受信機を取出して組立始めた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一報飛ぶ　若きハリ・ドレゴは、折角こうして怪奇きわまるゼムリヤ号の狂態現場に駆付けながら、これ以上手をつけ得ないことをたいへん口惜しがった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く第一報を送らないと、誰かにだしぬかれてしまう。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから僕たちは依然として、第一報を送り得る恵まれた立場にあるのだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、今こそ君は光栄ある報道者として、この驚天動地の怪事件の第一報を、最も十分なる表現をもって全世界に放送するのだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一報は、簡潔なのがいいぞ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球発狂の次に、ハリ・ドレゴの発狂が起りそうだ」「ははは、世界第一の報道記者がそんな気の弱いことでどうする、さあ、そのへんで、とにかくその第一報を全世界へ向かって送ろうや」　　渦巻く山頂　ハリ・ドレゴの発した“巨船ゼムリヤ号発狂事件”の第一報は、果して全世界に予期以上の一大衝撃を与えた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、“有名なる第一報者のハリ・ドレゴ”という博物館的栄誉だけが残されているだけであった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "遭難第一報　その日は過ぎてその翌日の正午、全世界の通信網はおどろくべきニュースを受取った。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第一報は、次のようなものだった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の十一時にＷＧＹ局が短波で呼出され、あの第一報が伝えられたんだそうな。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等生物団　第一報発表以後のわずか十八時間に、各社の第一線記者は悉くへたばってしまった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一報の電波発信者も分らず、この電波を発射した位置も分らなかった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきの第一報は無電で入った。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの事件の名称は、ゼムリヤ事件の名誉ある第一報発信者のドレゴが採用したとおり“地球発狂事件”と呼ばれることに本式の決定をみた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんもののナイチンゲールは、自分かってにうたいますし、いっぽう、つくりものの鳥は、ワルツしかうたわないのですから。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "死神は、頭に皇帝の金のかんむりをかぶって、片手に皇帝の金のつるぎを持ち、もういっぽうの手に皇帝の美しい旗を持っていました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぽう、子供たちは子供たちで、アヒルの子をつかまえようとして、ぶつかりっこをしては、笑ったり、わめいたり。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぽう、旅の仲間は、ヨハンネスがまだ眠っている宿屋にとんで帰りました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぽう、旅の仲間は、背中につばさをゆわえつけ、腰にサーベルをさげて、そして今夜は、むちを三本とも持って、御殿をさしてとんでいきました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぽう、ヨハンネスは、この国じゅうの王さまになっていました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
