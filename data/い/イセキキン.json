        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若手選手の海外移籍に伴い、クラブ史上最高額となる移籍金が支払われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "契約満了による退団のため、他球団への移動に際して移籍金は発生しない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "欧州サッカー界では、スター選手の獲得を巡って移籍金が年々高騰している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "チームの補強予算の大部分を、目玉選手の移籍金に充てることが決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まさか、あの無名選手にあれほどの移籍金がつくなんて驚きだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "契約書には、契約解除に必要な最低移籍金、いわゆるバイアウト条項が明記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "移籍金の額を巡って両クラブの条件が折り合わず、今回の獲得交渉は見送りとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
