        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "市三は、さきの鉱車よりも、もっと這入り方が少ない今度のやつを役員の眼前にさらすのは、罪をあばかれるように辛かった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は「猫のお湯屋」の絵草紙を見たことがあって、「あれがもし、日本の女たちの入る風呂の習慣としたら、同性たちと一緒に話したり慰め合ったりしながら湯に入れて、こんな便利な風呂の入り方はない」と羨ましそうにいった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにもおめがねどおり、紅屋の手代幸助と申す者でござります」「と申す者でござりますだけじゃ恐れ入り方が足りねえや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかさま不思議な入り方である。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "実用のための入湯でなくって、快感を貪ぼるための入浴なんだから」「そうむずかしい這入り方でもないんでしょうが、どうもこんな時に身体なんか洗うな億劫でね。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋の彼岸中日、入り方の光り輝く雲の上に、まざ／＼と見たお姿。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "をとゝひの日の入り方、山の端に見た輝きが、思はずには居られなかつたからである。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋の彼岸中日、入り方の光り輝く雲の上に、まざ／″＼と見たお姿。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋の彼岸中日、入り方の光り輝く雲の上にまざ／″＼と見たお姿。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "をとゝひの日の入り方、山の端に見た輝きを思はずには居られなかつたからである。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋の彼岸中日、入り方の光り輝く雲の上に、まざまざと見たお姿。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとといの日の入り方、山の端に見た輝きが、思わずには居られなかったからである。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "コルマックはひる時から日の入り方ちかくまで馬を進ませて来た。",
              "citation": {
                "source": "琴",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の入り方に一羽の鶇が樹の孔の上に垂れているほそ枝に来て、いさましい軽い歌をうたった。",
              "citation": {
                "source": "精",
                "author": "CATHAL OF THE WOOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "クウフリンの身辺には光があった、ちょうど日の入り方一時間前ぐらいの山々の夕ばえのような光であった。",
              "citation": {
                "source": "女王スカァアの笑い",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間はこの点において大に神に恐れ入っているようである、なるほど人間の観察点から云えばもっともな恐れ入り方である。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "信仰の世界に入る入り方は、人によっていろいろある。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "血糊の使ひ方と、巡禮の落入り方がうまいなとは思つた相だが、これが本當の人殺しとは誰も氣が付かなかつたらしい。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "血糊の使い方と、巡礼の落入り方がうまいなとは思ったそうだが、これが本当の人殺しとは誰も気がつかなかったらしい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "花見の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もラジオは今の処、トーキーなどの形とは違って、例えばテレヴィジョンというようなものと結び付いていないから、眼に訴えるセンセーションは全く断たれているわけで、それだけ耳に這入る這入り方も不自然に歪曲されている。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二　古代の占法は種々あるが、鹿の肩骨を燒いてヒビの入り方によつて占なうのを重んじ、これをフトマニといつた。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃はおまいりがたくさんありますかえ」と、半七は訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "みづから流転輪廻をはかるに、微塵劫を超過すれども、仏願力に帰しがたく、大信海にいりがたし。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはむかしから目の病に、霊験あらたかだといういいつたえがあって、そういう人たちのおまいりがたえない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方もいつもと違ひねいりがたく、と申内、前の弐枚障子、まことに明松を打懸たるごとくあかくなり、やれ、ぬき口よりやけしが、枕をあがれば直に真黒になり、又あかくなり、せふじ大にたかくやれ、火をとぼせとおらべ共、権平、念仏二声三声となへしが、いか様に申ても、声いだし申さず。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
