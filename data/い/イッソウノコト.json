        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この計画はリスクが高すぎる。一層のこと、もっと安全な方法を考えよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遠くへ行くのは骨が折れる。一層のこと、今回は見送ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう疲れたよ、今日は。一層のこと、ここで休もうか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "五郎蔵が「何か用か」と問えば、　児分甲が、Ｔ「親分、こうなりゃ　一層の事、日下部典六　とグルになっちゃ　どうですい？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心配するな、俺はもう何と云はれたつて姦通者に相違ないのだ、皆が皆寄つて群つて苛めるならもつと苛めろ、もつと苛めろ、一層の事ぐいと銀の槍でも突き通せ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの気軽く焼香に来てくれた心意気が嬉しいじゃないか」「一層の事、告別式をどこかの野ッ原に持出して、野人葬とすればよかったかも知れないね。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し村の噂が高くなると共に親類縁者の少しは小口の聞けるといふ手合が捨ておけないといふことで相談をした結果、それぢや兼次の家は財産は足らぬが貰ふといふなら一層の事おすがをやつたらよからう。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私もう、一層の事死んでしまひたい。",
              "citation": {
                "source": "海の中にて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを聞くと猿共は、赤い顔が青くなる程驚いていろいろ相談をしたが、何しろ喧嘩ずくでは狼に敵わないから一層の事、狼に喰い殺されないうちにここを逃げ出して、他の所にいい住居を探そうという事に決めた。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし女王になれないのならば、一層の事喰われて死んでしまった方がいい。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その娘の手紙なんですがね……実は、いま、こうして私が持ってるんですよ……いや、助役の話なんぞ繰返すよりも、一層の事この手紙をお眼に掛けましょう。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から考へて見ると、一層の事｜無ければ無いなりに、何うか斯うか工面も付いたかも知れないが、なまじい、手元に有つたものだから、苦し紛れに、急場の間に合はして仕舞つたので、肝心の証書を入れた借銭の方は、いまだに其儘にしてある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪役者が三人吉三をやる時にも、一層の事、本籍を大阪へ移してからやればいいと思う。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学を嫌がって絵ばかり描きたがるので勿論成績もよくなく身体も弱いから一層の事画家としてしまいたいというのである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年も七年も其途に親んで居て夫れでまだ彼れ位のものだとすれば一層の事止した方が宜しからう。",
              "citation": {
                "source": "貝殼追放",
                "author": "愚者の鼻息",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から考えてみると、一層の事無ければ無いなりに、どうかこうか工面も付いたかも知れないが、なまじい、手元に有ったものだから、苦し紛れに、急場の間に合わしてしまったので、肝心の証書を入れた借銭の方は、いまだにそのままにしてある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々出る、年よりたちの悔み言には、一層の事、筑前の国に接けといたら、よかつたらうに、と言ふ事である。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしにもおでん屋よりか、やるなら一層の事、あの方の店をやれって云うのよ。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は一層の事行くまいと決心して、氣をまぎらす爲にピアノの前に坐つて、よく諳記してゐるオペラ Rigoretto の處々を何といふ事もなく彈きつゞけた。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一層の事、実物をやめて影だけ描くのも一興だろう。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一層の事、やぶれかぶれに先斗町へでも遊びに行こうか、それとも、もう少し此処に辛抱して、気分の静まる折を待って居ようか。",
              "citation": {
                "source": "恐怖",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそうのこと、逆にその崩壊を善用するという態度に出るのが当然である。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の正月の艶々しい恋物語を知ってるだけに、冷たい、暗い、汚い寮で侘しく新年を迎えた君がいっそうのこといとしい。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを読むとまたいっそうのこと心細くなった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その愛らしい坊ちゃん坊ちゃんした君を知ってるだけに、今の荒んだ、歪んだ君がいっそうのこといとしい。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにあなたのようにその感想がややもすれば共通的性質を離れて著しく主観的になりがちな人においてはいっそうのこと遠慮しなければならない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
