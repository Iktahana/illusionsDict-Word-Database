          ],
          "literary": [
            {
              "text": "だが、何だ、それで家を畳むんじゃねえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "棲みなれた千葉の借家を畳むと、彼は広島の兄の家に寄寓することにした。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を畳むで神戸に引越さうとする段になると、江戸ツ子の夫人が承知しなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして置いても行かれませんし、そうかと言って、東京の家を畳むのも惜しいなんて言いますし――」「ああ、意気地の無いものは駄目です」と正太は妻の方を見て、アテコスるような調子で歎息した。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると家を畳むより仕方がない。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は東京の家を畳むとき、懐にして出た金は、ほとんど使い果たしていた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の家を畳むとき宗助は先祖の位牌を一つ残らず携えて、諸所を漂泊するの煩わしさに堪えなかったので、新らしい父の分だけを鞄の中に収めて、その他はことごとく寺へ預けておいたのである。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、一家を畳むといふ仕事は、これで面倒なもんですな……。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
