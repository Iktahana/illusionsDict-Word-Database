    "definitions": [
      {
        "index": 1,
        "gloss": "to live freely in the wilderness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
