    "definitions": [
      {
        "index": 1,
        "gloss": "relation of cause and effect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
