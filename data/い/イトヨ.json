[
  {
    "uuid": "f815e613-6050-5fc8-adea-d5dae4e7ab23",
    "entry": "糸魚",
    "reading": {
      "primary": "いとよ",
      "alternatives": [
        "イトヨ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
