      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "three-spined stickleback (Gasterosteus aculeatus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "川の上流で、イトヨが石の間に隠れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イトヨは繁殖期になると美しい婚姻色を出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イトヨの雄は巣を作り、卵を守る習性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "船は十一分の重量あれば、進行極めて遅緩にして、糸魚川に着きしは午後四時半、予定に後るること約二時間なり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏木から汽船に乗りますと、富山の岩瀬、四日市、魚津、泊となって、それから糸魚川、関、親不知、五智を通って、直江津へ出るのであります。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷見鯖の塩味、放生津鱈の善悪、糸魚川の流れ塩梅、五智の如来へ海豚が参詣を致しまする様子、その鳴声、もそっと遠くは、越後の八百八後家の因縁でも、信濃川の橋の間数でも、何でも存じておりますから、はははは。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、糸魚川から汽船に乗って、直江津に着きました晩、小宮山は夷屋と云う本町の旅籠屋に泊りました、宵の口は何事も無かったのでありまするが、真夜中にふと同じ衾にお雪の寝ているのを、歴々と見ましたので、喫驚する途端に、寝姿が向むきになったその櫛巻が溢れて、畳の上へざらりという音。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また越後の糸魚川、能生、直江津――そのどこへ売られたのか、捜しようがなかったのです。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寂寞を破つて、糸魚川の相馬御風君からたよりがあつた。",
              "citation": {
                "source": "間居",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸魚川に引つ込んだ相馬御風なんかも擧げてもいいかも知れない。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "清心院は糸魚川藩主松平日向守直春の女、福井藩主松平越前守｜慶永の養女、正弘の後妻｜謐子で、此夫人には男四人、女七人の子があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」謐子は糸魚川の松平日向守直春の女、越前の松平越前守｜慶永の養女で、正桓の夫人｜寿子は其出である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六日、姫川を下って大野村から自動車に乗り糸魚川にいたる。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中仙道を初め、三州街道や糸魚川街道、さらに北信では、あの千曲川から信濃川に沿って、その道路上に二キロ毎に設けられてあります水準点の高さの変動を測って見ますと、わずか三〇年そこそこの間にさえ、場所によっては二〇〇ミリも隆起している地方があり、また一〇〇ミリ近くも沈降している地方もございます。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本市から越後の糸魚川町に通ずる糸魚川街道は、平地から此山脈を仰望するに最も適した街道であって、五月下旬、麓の新緑が漸く濃やかならんとする頃、其上に未だ冬の粧を脱しない雪山の姿を望むことは、我国の山岳景観中に在りて優れたるものの一であるというてよい。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "登路　長野県北安曇郡北城村の四ツ家は、糸魚川街道に当り、且つ松本市から大町までは電車、大町から四ツ家までは自動車が通じているので、交通の便が最もよく、此処を登山口に選ぶ人が亦最も多い。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新潟県方面からは、糸魚川街道の大前｜若しくは平岩から大所に出で、夫より蓮華温泉に至り、蓮華鉱山跡を経て、鉢ヶ岳の南方越中との国境上に出で、山稜を南進して終に頂上に達するのであるが、距離も長く又信州口ほど楽でもない。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此落合から下は松川と呼ばれ、東に流れて平川と合し、姫川となり、北流して糸魚川町の西で日本海に入る。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫川は巣を作る魚として知られた糸魚を産する為に糸魚川の名がある。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「越後糸魚川と直江津との間に、名立といふ駅あり。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸魚川、境川、小川などが、車窓をふさがんばかりに壁立する前山の、囲みを破って海に落ちる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸魚川街道をバスで下瀬まで、崖に生えた萩が、花をバスの中に散らした。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉では古いラジオをかこんで糸魚川の尼さんやら、近くのお百姓さんやらが、都会人である私の横暴に白い眼を向けたというのが、丁度その晩、ＡＫから私の親友がフランス文学に関する放送をすることになっていたので、私はその時間に、ＢＫの浪花節をスイッチ・オフしたのである。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヌナカハは今の糸魚川町附近だという。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで呂宋兵衛さま」「なんじゃ」「ここはいったい、東海道のどのへんにあたりましょう」「まるで方角ちがい――北陸道の糸魚川と申すところだ」「すると向こうに見える岬は伊豆の国とはちがいますか」「あたりまえだ、北日本の海に伊豆はない。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣国の上杉景勝は、新潟城を攻めるために、蒲原郡に出撃中であったが、（秀吉、大坂を発して、大挙、北上の途につく）　という情報をうけとると、万一の変を考慮して、急に、兵を回し、越後の糸魚川城にはいって、八千余騎を、国境の変に備え、（佐々の背後を突くにもあらず、また、佐々のうしろを援くるにも非ず。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、糸魚川を去ること遠くない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一行の中から、木村｜秀俊が馬を飛ばし、糸魚川へ、先に、使いした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、すぐ御案内にといって、あんな若いのを、ただ一人、お迎えによこすなどとは」　――やがて、糸魚川の町口が見えた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "春日山殿よな」　秀吉は急いで、馬の鞍から降りかけたが、景勝は、莞爾として、振り仰ぎながら、「いや、そのままそのまま」　と、馬の口輪を取ったまま、糸魚川の町並木を通り、城門の内まで迎え入れた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴が落ちのびた地は富山であり、後、糸魚川に移り、木曾へ帰る機をうかがっていたが、やがて直江津の国府に庵を結び、晩年は高田市の出丸に住んで長寿をたもった。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして強い光でないとよく感じぬ、普通の花や人物でも撮るには非常な長時間かかる。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "炬燵の火もいとよし、酒もあたゝめんばかりなるを。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
