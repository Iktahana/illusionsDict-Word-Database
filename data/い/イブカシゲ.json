[
  {
    "uuid": "c830ca07-d2da-57af-a243-c49289c7f177",
    "entry": "訝しげ",
    "reading": {
      "primary": "いぶかしげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
