    "definitions": [
      {
        "index": 1,
        "gloss": "quizzical",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は私の説明を聞きながら、訝しげな表情を浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "謎の箱を前に、猫は訝しげに首を傾げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "店員は、値札のない商品を持ってきた客を訝しげに見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "女客も声のした方を訝しげに見る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹田なる鍛冶の夜業の火花闇に散る前を行過ぎんとして立ちどまり、日暮のころ紀州この前を通らざりしかと問えば、気つかざりしと槌持てる若者の一人答えて訝しげなる顔す。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とさも訝しげに、番頭の顔を熟と見ていう。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とさも訝しげに時次が謂えば、「まあ、あられもない扮装をしてどうしたというのだろう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家は訝しげに部屋の中を瞶めた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらを訝しげに見つめる目からは怯えと気難しさがうかがえ、無言で立ち上がりもせずに手で椅子ふたつを示した。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく妙な災難はインド人の部屋でも起こった――相手は無口で小柄な鉤鼻の男で、我々を訝しげに眺め回したが、ホームズによる建物の素描が終わりを迎えるとあからさまに喜んでいた。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "レストレードは拾い上げて、訝しげに目を見開いた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この詞のめでたげなるに、母上は喜び給ひながら、猶｜訝しげにもてなして、太き息つきつゝ宣給ふやう。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "してそのもとは」と、老僧は訝しげに実之助を見上げた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく彼らが死んでも、入場者の二、三人が、「この頃あの下足番の顔が見えないな」と、軽く訝しげに思うにとどまるだろう。",
              "citation": {
                "source": "出世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『其※事もないけれども……訝しげなもんだね。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "後れ馳せの老女｜訝しげに己れが容子を打ち※り居るに心付き、急ぎ立去らんとせしが、何思ひけん、つと振向て、件の老女を呼止めぬ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "比世の思ひ出に、夫とはなしに餘所ながらの告別とは神ならぬ身の知り給はぬ小松殿、瀧口が平生の快濶なるに似もやらで、打ち萎れたる容姿を、訝しげに見やり給ふぞ理なる。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "件の僧は暫したヽずみて訝しげに見送れば、焚きこめし異香、吹き來る風に時ならぬ春を匂はするに、俄に忌はしげに顏背けて小走りに立ち去りぬ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "遙々訪ね來りし主從二人、こゝ開け給へ』と呼ばはれば、内より燈提げて出來りたる一個の僧、『瀧口が庵は此處ながら、浮世の人にはる／″＼訪はるゝ覺えはなきに』と言ひつゝ訝しげなる顏色して門を開けば、編笠脱ぎつゝ、ツと通る件の旅人、僧は一目見るより打驚き、砌にひたと頭を附けて、『これは／＼』。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧口訝しげに、『足助殿には未だ御寢ならざるや』と問へば、重景太息吐き、『瀧口殿』、聲を忍ばせて、『重景改めて御邊に謝罪せねばならぬ事あり』。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "件の僧は暫したゝずみて訝しげに見送れば、焚きこめし異香、吹き來る風に時ならぬ春を匂はするに、俄に忌はしげに顏背けて小走りに立ち去りぬ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ絹坊、どうしたんだ」　僕は行人の訝しげな視線を熱く感じながら、靴先で彼女の脚をちょいと突いてみた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――けれど、あいにくこれといって手頃な別荘もございませず……」　みや子は訝しげに夫人を顧みた。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　志野は、罪のない訝しげな表情で房を見た。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御婦人の方がお二人で下に待っていらっしゃいます」　ジェルテルスキーは長い椅子からたちながら、金髪をかき上げ、水のような碧い眼を訝しげに動かした。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "温はこの詩を受けて読む毎に、語中に閨人の柔情が漸く多く、道家の逸思がほとんど無いのを見て、訝しげに首を傾けた。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "このニュースがあまりにも奇怪だったので、一同はまるで木で作った面のように間の抜けた顔をして、訝しげにハッと固唾をのんだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とお照は訝しげに問返しぬ。",
              "citation": {
                "source": "片男波",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫は、恐らく、硫黄や、黄燐くさい、栄養不良な工人の病的な肌の代りに、どうしたのか急に、汗と脂肪ぎった溌剌たる皮膚があるのを感じて、いぶかしげな顔をしただろう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぶかしげに頸を振る者もあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　山下が、いぶかしげにきいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "い號室の患者は、本をぱちんと閉ぢて、葉藏のヴエランダの方をいぶかしげに眺めた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に一碗の茶を未だ飲干さなかった、先生はツト心着いて、いぶかしげな目で、まず、傍なる少年の並んで坐った背を見て、また四辺を※したが、月夜の、夕日に返ったような思いがした。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
