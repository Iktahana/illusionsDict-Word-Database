        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祭りの準備は、会場の設営から屋台の飾り付けまで一式、地域の若者が担当した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "犯行に使われたと思われる証拠品一式が、彼の自宅から発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "契約書と添付書類一式を、内容をよくご確認の上、ご返送ください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
