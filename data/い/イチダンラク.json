[
  {
    "uuid": "f62c7f6c-7a3c-59cc-819f-fe15dc3a72a6",
    "entry": "一段落",
    "reading": {
      "primary": "いちだんらく",
      "alternatives": [
        "ひとだんらく"
      ],
      "is_heteronym": true
    },
    "grammar": {
