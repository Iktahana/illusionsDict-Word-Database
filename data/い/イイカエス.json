[
  {
    "uuid": "2e7d942e-6a0b-5a92-a4e2-b6905ab4c38a",
    "entry": "言い返す",
    "reading": {
      "primary": "いいかえす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
