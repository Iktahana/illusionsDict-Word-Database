          ],
          "literary": [
            {
              "text": "郊外の安文化住宅で、新婚の若夫婦がいちゃつくという意味ではない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間若い者のいちゃつくのを見てなんかおれるもんですか。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、勝手にしろよ、家へ帰って女房とさんざいちゃつくがいいや、助平野郎め！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "『忌々しいが、女にいちゃつくのは暫らく待とう！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちゃつくだけが能じゃねえやな」　と大和にひやかされると、根が好きな道、腕に覚えもあるから、何を小癪なと仲間に加わる。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人は、車の窓から手を出して、握手したり、手を触れあったりしていちゃつくんだ。",
              "citation": {
                "source": "あるドライブ",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女といちゃつくんなら此処だって出来る」　背筋に粟の立つような嫌悪感が宇治を襲った。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は給仕係といちゃつくふしだらな厨房娘にされてしまいました。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "さだめし、小屋から帰って来たあとで、また手を変えて、ゆっくりいちゃつく考えだったでございましょう」「…………」「金吾様、聞こえますか」「聞いておる」「ところが」「ウム」「それを嗅ぎつけた千束の稲が、この九兵衛を出し抜いて、金吾を殺ったと親分へ手がら顔をする気かなんかで、お粂の留守におしかけました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
