    "definitions": [
      {
        "index": 1,
        "gloss": "to give meaning (to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
