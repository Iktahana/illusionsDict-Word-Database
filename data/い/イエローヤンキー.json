        "examples": {
          "standard": [
            {
              "text": "長年アメリカに住んでいた彼は、話し方や仕草がすっかりイエローヤンキーのようだと評されることがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外ドラマの影響か、妙にオーバーリアクションな彼女を友人たちは「イエローヤンキーだね」とからかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あんた、イエローヤンキーみたいだね」と揶揄されても、彼は全く気にせず自分のスタイルを貫いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦後の混乱期には、アメリカ文化に憧れる若者たちがイエローヤンキーと呼ばれた時代もあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のファッションセンスや自信に満ちた態度は、一部にはイエローヤンキーと映るようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「彼の発言はいつもストレートすぎる。まるでイエローヤンキーだな」と陰口を叩く人もいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
