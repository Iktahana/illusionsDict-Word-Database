    "definitions": [
      {
        "index": 1,
        "gloss": "till just now",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "え、これってそういう意味だったの？ 今の今まで、全然気づかなかったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "いやー、まさか犯人はお前だったとは。今の今まで信じられなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この書類、ずっと間違ったやり方でやってたみたい。今の今まで、これで合ってると思ってたのに。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昨日の夜、急に背中が痛くなったんだ。いや、正確には昨日の夜からじゃなくて、今の今までずっと鈍い痛みがあったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "割烹着の胃に当る辺りが濡れてゐるところを見ると、今の今まで茶碗でも洗つてゐたという風だ。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今まで僕をよろこばして居た自然は、忽ちの中に何の面白味もなくなつてしまつた。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがドモ又におはちが廻ろうとは俺も実は今の今まで思わなかったよ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十｜年も相見ぬ間に、彼に妻子の出來た事は何も不思議はないが、實は今の今まで知らなんだ、况んや其人が今本國へ皈るなどゝは全く寢耳に水だ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ第一の喜悦は、先刻輕氣球の上で疑つた樣に、今の今まで、我等が泛べる此太洋は、大西洋か、はたアラビアン海かも分らなかつたのが、只今の水兵の言で、矢張私の想つた通り、此洋は、我等兩人が目指すコロンボ市にも、また櫻木海軍大佐等と再會すべき筈の橄欖島にも左迄では遠くない印度洋中であつた事と。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "山※同様の分際で、深川生れのお葉さんに惚れるとは、途方もない贅沢な奴だと、今の今までは馬鹿馬鹿しくもあり、腹立しくもあったが、斯うなって見ると自分にも罪が無いでもない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の口から斯んな騒ぎが出来したとは、今の今まで些とも知らなかったのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それと一緒に、今の今まで、あたたかい親切な人間とばかり見えていた叔父が、急に鉄のポストみたいに冷たい態度にかわって、傲然と私を睨み下しているのに気が付いて、又もビックリさせられた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今の今までつつましやかにうつむいていた伊奈子が大きな眼で上眼づかいに私を見て、頬をポッと染めながらニッコリと笑って見せたからであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今まで太郎坊を手放さずおったのも思えば可笑しい、その猪口を落して摧いてそれから種々と昔時のことを繰返して考え出したのもいよいよ可笑しい。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ちょいと外面へ汝が立って出て行った背影をふと見りゃあ、暴れた生活をしているたア誰が眼にも見えてた繻子の帯、燧寸の箱のようなこんな家に居るにゃあ似合わねえが過日まで贅をやってた名残を見せて、今の今まで締めてたのが無くなっている背つきの淋しさが、厭あに眼に浸みて、馬鹿馬鹿しいがホロリッとなったア。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と趙とは互いに顔を見合せて、ホッと吐息をつき、もはや危険がないとは知りつつも、まだビクビクしながら、今の今までどんな厚い皮でもたちどころに引裂くことの出来たその鋭い爪や、飼猫のそれとまるで同じな白い口髭などに、そっとさわって見たりした。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今まで、姉に対して、懐いていた不愉快な感情までが、カラリと拭われたように無くなってしまった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、菊枝がそれを言い出すと、爺さんや父親の、今の今まで彼女に示していた悦びの感情は、急に一変してしまったかのようであった。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやゆび姫をさらってきたコガネムシだって、今の今までそう思っていました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "……実は私も品夫さんのお父さんに関する村の人の噂を二三聞いているにはいたのですが、大部分誇張だろうと思いましたし、もしかすると岡焼き連の中傷かも知れないと思いましたから、今の今までチットも信じていなかったのですが……」「イヤ……村の者の噂は大部分事実なのです。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、私の、今の今まで「此世の中で俺の相手になんぞなりそうな奴は、一人だっていやしないや」と云う私の観念を打ち破って、私を出し抜けに相手にする奴があった。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今まで貫一が事を思窮めたりし心には、夫なる唯継にかく事ふるも、なかなか道ならぬやうにて屑からず覚ゆるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手も大体見当が付いてはおりますが、表沙汰にしましてはまた御迷惑をする方もあるだろうと、内所で手分けをして探していましたが、眼と鼻の間のこんなところに隠れていようとは、今の今までちっとも知りませんでした。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "義一さん、わたしこんな事はおくびにも出さずに今の今までしっかり胸にしまって我慢していたのですけれども、きょうはどうしたんでしょう、なんだか遠い旅にでも出たようなさびしい気になってしまって……」　弓弦を切って放したように言葉を消して葉子はうつむいてしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今までどことて似通う所の見えなかった叔母も、その姉なる葉子の母の着物を帯まで借りて着込んでいるのを見ると、はっと思うほどその姉にそっくりだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今まで焼くように定子の事を思っていた葉子は、田川夫人に対してすっかり反対の事を考えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは実際思いもかけぬというよりは、ありそうな事ではあるが今の今まで知らずにいた、それに葉子はあきれたのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明かさばこの身の恥になることと存じまして、今の今まで気どられまいと、色にも出さずひたがくしに隠しておりましたが、だんなさまのただいまのせつなげなおことばを承りましては、もう、もう、おろかな隠しだてしてはおられなくなりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今まで張りつめてゐた氣が一寸の間ゆるんで、彼女は一｜時の安心のためにがつかりしてしまつたのである。",
              "citation": {
                "source": "悔",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは今の今まで思ひも寄らなかつたことで、そこの前を通り過ぎる時軽く投げた一と目に、美しい女下駄をちらと入口に見てから、急に入るのが厭になつたのであつた。",
              "citation": {
                "source": "散歩",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、今の今まで信じてゐたものを※ぎ取られて行く驚愕のきはみであつた。",
              "citation": {
                "source": "嘘をつく日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "咽喉が乾いた」　それから熱い番茶を飲みながら二人の女の話を聞いているうちに何と……今の今まで私の脳味噌の中に浮かみ現われていた奇妙な家庭悲劇の舞台面が、いつの間にかグルグルと一変してしまったのであった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今までお姉さんと、その事ばっかり話していたとこなのよ」　この言葉を聞いた時に私はヤット決心が付いた。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はどんな苦しみにでも堪えられる強い女だと今の今まで思っていたんですが、このことだけには堪えられなかったのです。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
