          "literary": [
            {
              "text": "形勢険悪　一難去ってまた一難！",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一難去ってまた一難とはこのことだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "一難去ってまた一難――喬之助は、そんな気がした。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "一難去ってまた一難とはこのことかと、黙ったまま彼は頷垂れていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一難去ってまた一難……。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "教えてつかわすから、その鞍縁へ手をかけて見ろ」　一難去ってまた一難。",
              "citation": {
                "source": "江戸三国志",
