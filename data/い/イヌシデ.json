        "examples": {
          "standard": [
            {
              "text": "かつてこの村では、犬四手の木を伐って良質な炭を作っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "武蔵野の面影を残すこの雑木林は、コナラやクヌギに混じって犬四手が多く見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "犬四手の果穂は、まるで小さなエビがぶら下がっているような面白い形をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この家具は、粘り強くて加工しやすい犬四手の材で作られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "まんさくだの、かしわの葉、あかしで、いぬしで、いぼた、白い花の咲くがまずみ、うつぎ、赤い花の咲くはこねうつぎ、模様のようなやまにしきぎ、そんな名前を一つ一つていねいにおしえて下さいました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "池をひとめぐりすると、私は公園の西の端れのいぬしでの木立のある丘にゆき、そこにあるベンチに腰かけて休み、メリーの首輪から鎖をはずしてやる。",
              "citation": {
                "source": "犬の生活",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は都会育ちで木や草には馴染みがうすく、とんと疎い方なのだが、いつかいぬしでの樹に親しみを感ずるようになった。",
              "citation": {
                "source": "犬の生活",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぬしでの冬木立はよかった。",
              "citation": {
                "source": "犬の生活",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕方、私はいつものようにメリーを連れて池をひとめぐりし、いぬしでの木立のある丘にきて、メリーを解放し、ベンチに腰をおろしてぼんやりしていた。",
              "citation": {
                "source": "犬の生活",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
