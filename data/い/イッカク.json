    "definitions": [
      {
        "index": 1,
        "gloss": "one plot (of land)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市街地の一画を買い取り、そこに新しい商業施設を建設する計画が立ち上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖父が残した広大な敷地の一画に、小さな家庭菜園を作ってトマトを育てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "牧場の一画がキャンプ場として開放されており、週末には多くの家族連れで賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "絵巻物の一画面は言わば静的である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その静的な一画面から次の画面への推移のリズムによって始めてそこに動的な効果を生じる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽象映画　スウェーデンの一画家がはじめた抽象映画は、幾何学的形象の運動の連鎖であって「動く装飾」と言われている。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠のもの、畔に立つ榛の木、蛙の声、鳥の音、苟くも彼の郷土に存在する自然なら、一点一画の微に至る迄｜悉く其地方の特色を具えて叙述の筆に上っている。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて書かなくては済まない、遺さなくては悪いと思ふ事以外には一画と雖も漫りに手を動かす余地がない。",
              "citation": {
                "source": "艇長の遺書と中佐の詩",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして私はただのつまらない一画工になってしまった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高速度撮影や顕微鏡の利用、医療診断機器を使った特殊撮影などを通して、連続したドラマの一画面としてではなく、独立した映像として一こまを扱う感覚が、萩野さんの中には育っていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふこのミュンヘンの府に来て、しばし美術学校の『アトリエ』借らむとするも、行李の中、唯この一画藁、これをおん身ら師友の間に議りて、成しはてむと願ふのみ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一画家の中には、批評家や、画家仲間に見せるのを目的に制作してゐる人が少くないが、画家の数は多いといつても知れたものであるし、広く一般大衆へ見せるものであるといふ、絵画家の立場を取るべきで、この親切さは、平凡な絵を描くまいとする苦痛が伴つてほんとうに気持の良い努力ではないかと思ふ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "『北※瑣談』二に東山に七月十六日の夜立つる大文字の火唐土にもなしと孔雀先生も書き置かれたり、横の一画二十九丈、左の画四十九丈二尺、右の画四十七丈七尺八寸、余も如意嶽に上り、その穴を見しが広大なる物なりとあれば、日本の方が勝ちらしい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、応挙や探幽の大作の全部を集めて捜しても決して発見されない椿岳独特の一線一画がある。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、一画一画ハッキリと書いてあるので、スラスラと読めた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども一線一画の瞬間作用で、優に始末をつけられべき特長を、とっさに弁ずる手際がないために、やむをえず省略の捷径を棄てて、几帳面な塗抹主義を根気に実行したとすれば、拙の一字はどうしても免れがたい。",
              "citation": {
                "source": "子規の画",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の浅草千束町――詳しく云えば千束町の一部と猿之助横町の一画全部、三町四方に蟠かまる三百余軒の醜業窟六百余人の醜業婦は、このような理由で久しい間狙われていた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ色々な都合で固有名詞だけは、抹消したり、変改したりしたが、事実そのものには一点一画も私は修正を加えなかった。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊動円木、機械体操、廻転箱、また鞦韆、……そういうものの揃っている、小運動場の一画へ来た。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが題せる一字一画は、号泣、涕涙、その他すべて自然の許す限りの排悶的手段を尽したる後なお飽く事を知らざる本能の要求に余儀なくせられたる結果であろう。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日々の生活にあっては、今日と云い、今と云う、一画にぱっと照りつけた強い光りにぼかされて、微に記憶の蠢く過去と、糢糊としての予測のつかない未来とが、意識の両端に、静に懸っているのである。",
              "citation": {
                "source": "思い出すかずかず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りの小さい格子戸の家々の一画はとり払われて、ある大きい実業家の屋敷となっているが、三年前の二月ごろから表札が代って、姓だけを上の方にちょこんと馴れぬ筆蹟で書いたものが、太い石の門柱に出されている。",
              "citation": {
                "source": "からたち",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとその一画は某という株屋がもっていた林や原っぱであった。",
              "citation": {
                "source": "犬三態",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、これらの一画の上にある、この段丘とそこを耕している農民たちは、ずっと旧態のままであり、はるか古の五世紀あたりの姿と同じといっても過言ではないようだ。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この美を生命とする俳句的小説」と作者自身云っている作品は、「余」という超然派の一画工が主人公である。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「序の舞」は政府のお買上げになったもので、私の「草紙洗小町」「砧」「夕暮」の老境に入っての作の一画をなす、いわば何度目かの画期作とも言うべきものでありましょう。",
              "citation": {
                "source": "作画について",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり沈みきった気持ちを鼓舞し調査を続けていた和田の目が、ある一画をとらえ、そこで動かなくなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年｜仏蘭西に一画家あり。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の隅の一画に、継母は綿のはみ出た蒲団にくるまつて、終日黙つて節穴を睨めてゐた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "１１　クイーンの　おにわ　これが　まえに　おはなしした　きれいな　おにわの　いっかく。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
