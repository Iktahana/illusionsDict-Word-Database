          ],
          "literary": [
            {
              "text": "これは、ひょっとしたら、断頭台への一本道なのではあるまいか。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本道の兩側に三丁ほど茅葺の家が立ちならんでゐるだけであつたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本道の両側に三丁ほど茅葺の家が立ちならんでいるだけであったのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦焼場の煙渦巻く瓦町を抜けて太宰府へ通う田圃の中の一本道の東側。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "日蔭のない堀ばたの一本道を通って、例のうなぎ釣りなぞを覗きながら、この柳の下に辿り着くと、そこにはいつでも三、四人、多い時には七、八人が休んでいる。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日良寛さんは、野中の一本道を歩いてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とアヤは背中の荷物をゆすり上げて、「どうせ、一本道ですから。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは少しずつ次第に流に遠ざかって、田の畦三つばかり横に切れると、今度は赤土の一本道、両側にちらほら松の植わっている処へ出ました。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗って来た汽車をやり過して、線路をこえると、追分宿への一本道が通じていた。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人影もないその淋しい一本道をすこし行くと、すぐ森の中だった。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀造は梅田新道の方へ広々とした電車通りを走って行ったが、追われている背中には、その一本道は長すぎた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本道の前方にかすかにアパートの灯が見えた。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんりんりんりん、りんりんりんりん、いくら行ってもさした見物もないので、今度は工場の方へ向きを換えさすと、広い広い一本道を工場へ、駈けた駈けた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからずんずん一本道を河楊の並木に添って、この前見た燕麦の畑まで出て見たが、そこはもうおおかた刈られてしまって、例の長柄の草刈鎌も百姓の姿も見られなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本道を二三町も行った所で、私達は右手にポツンと一軒立っていた低い朝鮮家屋の前に立止った。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ場所はよし、和尚の取持はよし、麓の一本道に見張りさえ付けておけば、手入れの心配は毛頭ないので、入れ代り立代り寄り集まって手遊びするものの絶えぬところが面白い。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日本漫遊の途次、越後路まで来ると行けども行けども人家の無い一本道にさしかかった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "田楽狭間は桶狭間へ通ずる一本道の他は両側共に山で囲まれて居る。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は一本道であった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖畔に添うて行くうちに腕位の木が一本道に伐り倒してあつた。",
              "citation": {
                "source": "しらくちの花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "土手下から水際まで、狭い一本道の附いている処へ、かわるがわる舟を寄せて、先ず履物を陸へ揚げた。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "川岸づたいの一本道ですから見はぐる気づかいはありません。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋森家の表を緩やかな弧を描いて北側へカーブしている一本道の六間道路は、秋森家の石塀の西端からその石塀と共にグッと北側へ折曲っている。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく隠れ場所とてない一本道――。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も道路は、一本道！",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……つまり、あの一本道で、君と郵便屋が、こちらから二人の犯人を追って行く。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右を見、左を見、この川端の一本道を行きつ帰りつしているうちに私はいつか異様な興奮を覚えていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴ったかと思えばきげんが直り、直ったかと思えば途方もなく浮かれだして、口やかましくたたいているうちに道は稲荷橋まで一本道、その中州へ渡って駕籠もまた早いのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所は一真寺の裏門から始まった一本道をずっとまっすぐ右に来て、先は本港町へ通ずる越前家お下屋敷との間の細い路上なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の裏門からずっと出て、死骸を越えて、一本道をまっすぐたどっていったその曲がりかどに、杉の葉束の酒屋のしるしが、無言のなぞを物語り顔につるされてあるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
