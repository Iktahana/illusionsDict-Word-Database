[
  {
    "uuid": "136fbf32-bf88-5675-9bb0-5eb7cdcbbae1",
    "entry": "一人物",
    "reading": {
      "primary": "いちじんぶつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
