    "definitions": [
      {
        "index": 1,
        "gloss": "wooden wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古民家の板壁は、年月を重ねて深みのある色合いになっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、裏庭の物置小屋の板壁にチョークで落書きをして遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "台風で傷んだ板壁を修復するため、大工が丁寧に作業を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "板壁に飾られたドライフラワーが、素朴ながらも温かい雰囲気を醸し出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "隣の部屋からの話し声が、薄い板壁を通して微かに聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "おしゃれなカフェは、内装に木目を生かした板壁を取り入れ、落ち着いた空間を演出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭の目隠しとして設置された板壁は、隣家からの視線を遮るのに役立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "汽車から見た青森市の家はほとんど皆トタン葺またはコケラ葺の板壁である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土ほこりを浴びた板壁の板がひどく狂って反りかえっているのが多い。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　薄暗い、一寸、物が見分けられない、板壁も、テーブルも、床も黒い室へつれて行かれた。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "板壁の釘が腐って落ちかけた木造の家に彼等は住んでいた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狹くるしい白い板壁の部屋に、ひとがいつぱいつまつてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを大事に小脇にかかえて、板壁によりそいながら入口へとさぐり寄った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯気や煙で煤けたまわりを雇人の手が届く背丈けだけ雑巾をかけると見え、板壁の下から半分ほど銅のように赭く光っている。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "板壁の一方には中くらいの窓があって棚が出ている。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見まわすと、窓の上、四方の板壁には、フランクリン、リンコルン、ビスマークだ、西郷南洲、そうした世界的英雄の廉物の三色版がさも大業に掲げられてあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、草家、草家、板壁。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りの寺の庭に面した方にかけて縁がはが取りまはしてあつて、軒した一間ばかり隔てたところに板壁があり、そこには、父の手を入れた盆栽の棚が出來てゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁へ出て、はしご段の突き當りにある戸ぶくろへ左りの手をかけ、そのそばに植わつてる山吹の上から、北の生け垣が鍵の手に反れて板壁に換はつてゐる向ふの離れへ聲をかけ、「馨！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、板壁に映った自分の黒い影が、どうも、邪魔になってたまらない。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の青白く燃えだしたばかりの店には、二人の学生が来てそれが入口の右側になつたテーブルに着いて、並んで背後の板壁に背を凭せるやうにしてビールを飲んでゐた。",
              "citation": {
                "source": "雨夜詞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お幸ちやんは学生に首づたへ手をやられたなりに、学生と並んで板壁に凭れて笑つてゐた。",
              "citation": {
                "source": "雨夜詞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ポケットはちょうど状差しのような具合に教室の中へ、窓の下の板壁に垂れ下がるのだった。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　樫の板壁と高い窓のある古い広間が、聴取の場所にあてられた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の蒼白く燃えだしたばかりの店には、二人の学生が来てそれが入口の右側になったテーブルに着いて、並んで背後の板壁に背を凭せるようにしてビールを飲んでいた。",
              "citation": {
                "source": "萌黄色の茎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お幸ちゃんは学生に首ったまへ手をやられたなりに、学生と並んで板壁に凭れて笑っていた。",
              "citation": {
                "source": "萌黄色の茎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "好い女がいるな、と謙作は男の何人でも思うようなことをちょと思い浮べながら、右側のテーブルへ往ってぼろぼろの洋服の男の横顔の見えるように、白く塗った板壁を背にして腰をかけた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた体を一つのハンマーの如くにして、隣房との境の板壁に打つかった。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "両足を揃えて、板壁を蹴った。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "板壁は断末魔の胸のように震え戦いた。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はヘトヘトになって板壁を蹴っている時に、房と房との天井際の板壁の間に、嵌め込まれてある電球を遮るための板硝子が落ちて来た。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええと――　と、その考えを突き詰めようとすると、板壁一枚隣りの飯場の婆さんの、カン高い饒舌がうるさく耳につき出した。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "万福は入口の右側の板壁に添つて、横になつてゐるやうだつた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも彼らは禁錮刑囚のように、監房の板壁をながめた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと板壁の根の方から渓の水がひそかに流れ込んで来てゐるのである。",
              "citation": {
                "source": "渓をおもふ",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が前記の錦町署の留置場を出たあとで、そこの板壁にある落書きの中に、何か知らんが「不敬」な文字が発見されたそうだ。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "開いたかべの中から、まぶしいような白い光がさしてきました。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
