[
  {
    "uuid": "99dcef86-81a4-503c-9e17-ea3003c66d2f",
    "entry": "板壁",
    "reading": {
      "primary": "いたかべ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
