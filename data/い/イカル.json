        "examples": {
          "standard": [
            {
              "text": "雪国では、冬の間の保存食として大根や白菜を土の中に生かる習慣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "来春の芽吹きを待つ球根が、霜の降りた冷たい土の底に深く生かっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「炭火が消えないように、灰の中に生かっておきなさい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "掘り出した芋の一部は、来年の種芋にするために再び畑の隅に生かされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "土の中に生かっていた野菜は、凍てつく冬を越えて瑞々しさを保っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
