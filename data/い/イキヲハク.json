          ],
          "literary": [
            {
              "text": "一同は杖に倚って、水涸れの富士川を瞰下しながら、しばらく息を吐く。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の仕事を終えたらしい大工のような人が、息を吐く微かな音をさせながら、堯にすれちがってすたすたと坂を登って行った。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フーッと長い息を吐くと、芳烈な緑色の香気が私の顔を打った。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "息を吐くやうに、一度止んで、しばらくぴつたと靜まつたと思ふと、絲を搖つたやうに幽に來たのが、忽ち、あの大地震であつた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、はッはッと息を吐く。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが為に意外の時間を費して、今や初めて窟の入口へ辿り着いた時には、一隊の多くは既に疲れ果てて、そこらに有合う岩角に腰を卸して先ずほッと息を吐く者もあった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰を卸して扨ほッと息を吐くと、彼女は今更のように骨に沁む寒気を感じた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "次から次へと通り抜ける電車の轟きや、自動車のサイレンに全神経を脅かされる上に、薄いホコリが絶え間なく群集の足の下をくぐって彼の顔に迫って来るので、彼は口を利くどころか、息を吐く隙さえないくらいであった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、かぶりを振って溜息を吐く。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣は潮垂れてはいないが、潮は足あとのように濡れて、砂浜を海方へ続いて、且つその背のあたりが連りに息を吐くと見えて、戦いているのである。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "指すとともに、ハッという息を吐く。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "びしゃびしゃ……水だらけの湿っぽい井戸端を、草履か、跣足か、沈んで踏んで、陰気に手水鉢の柱に縋って、そこで息を吐く、肩を一つ揺ったが、敷石の上へ、蹌踉々々。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青年は肩を揺つて、唯大息を吐くのであつた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『あゝ、』　――返答が出来ないで、溜息を吐く顔を見て、遁げるやうに二三人摺り抜けた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上れるだけ一足でも高く、境に繞らす竹垣の根まで、雑木の中をむりやりに上って、小松の幹を捉えて息を吐く。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と答へて、傍を向いて溜息を吐く。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」溜息を吐くと、小池は卓子の上に肘をついて、圭子を見た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「首があると、被害の見当も、それで大体わかるのだが……」　刑事課長は溜息を吐くようにして言った。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋情が介在していることを知っていれば、極く簡単に済んだのかも知れなかったが、残念なことをした」　岡埜精神病院長はそう云って、溜息を吐くようにしながら、両手の中に頭を抱えた。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれを見詰めながら、自分自身の苦悩に疲れ切って溜息を吐くのが常であった。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い農夫は驚異の眼を※り、ほっと溜め息を吐くようにして、猟銃を自分の足｜許に立てた。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地の人たちゃあ、開墾の賃金をほとんど貰ってねえのだからなあ」「無茶なことばかり言って、困るなあ」　敬二郎は溜息を吐くようにして言った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私が箱を炉棚に戻すや、ホームズは頭を枕に沈め、ほっとして深く息を吐く。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま私の首筋に、袖口が熱くかかったなり、抱き据えて、腰をたてにしたまで、すべて、息を吐く隙がない。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "息を吐く隙がありません。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、はツはツと息を吐く。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「分んねえとう、何にも知らねえ者で他人の櫛なんぞ取つか」勘次は苦しい息を吐くやうにして「そんだら汝りや」と齒でぎつと噛み殺した樣な聲でいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次も疲勞した日の夕方には唐鍬を村落の店の軒下へ卸して一｜杯を傾けて來るのであるが、嘗て自分の家に運んだこともなければ臭い息を吐く間は卯平へ顏を合せたこともなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体が息を吐くなんて――だがどうも息らしかった。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "元気に噪いで喋べり捲ってるかと思うと、笑声の下から歎息を吐くものもあった。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
