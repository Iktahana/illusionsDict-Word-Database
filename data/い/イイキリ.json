[
  {
    "uuid": "47582804-b577-57c1-aab5-5ffe634011fd",
    "entry": "言い切り",
    "reading": {
      "primary": "いいきり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "affirmation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「国民への説明責任は、いかなる状況でも果たします」と、総理大臣は記者会見で断固たる言い切りをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "目撃者は「事件当時、被告人が現場にいたことをはっきりと見た」と、一点の曇りもない言い切りで証言した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の研究を経て、その仮説の正しさを裏付ける確証が得られたため、彼は「この理論は正しい」と科学者仲間にも言い切りを述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "契約の最終段階で、担当者は「納期遅延は絶対にありません」と、重役たちに最終的な言い切りをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もうお菓子は食べない！」という子供の強い言い切りは、親に一瞬の安堵感を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "破産報道について、企業側は「事実無根であり、経営は盤石です」という公式な言い切りを発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自分の選んだ道に迷いはなく、「これが私の生き方だ」という揺るぎない言い切りは、周囲に静かな感銘を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "八雲立ちといひたまはで、八雲立つと言い切り玉へるも彼の奇しき瑞雲に驚かせ給へる語勢なりなどいへる、ことに奇しき言なり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛していないと、言い切り得る。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩は恩、愛は愛だ」と昂然と言い切りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに彼は、観察と分析を極めれば、何事にもごまかされないとも言い切り、これをエウクレイデスの諸命題と同様に完全無欠だと結論づけた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には暴力にまで訴えようとしましたので、とうとう沢も決心して、奥さんが生きて見える間は決して、御言葉には従いませんと言い切りました。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどあくまで思い切る気は無いと言い切りました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その井戸の中へは、何百人の人が入って探険した筈だ……底の底まで空井戸だ……何があるものか」　子爵は冷罵に近い言葉で、こう言い切り乍ら、白麻のハンケチを出して額の冷汗を拭きます。",
              "citation": {
                "source": "古城の真昼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤波金三郎という人が泊った筈だが――と云うと、田舎風の大きい宿帳を持って来て、一二ヶ月のところをバラバラと開いて、此通り、藤田、伊藤などいう人は泊っているが、藤波金三郎という泊り客は、私が記憶して居るところでは、近年無かった筈だと言い切りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "白髪の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは七年前に行方知れずになられた、先代の大旦那に相違ありません」　老番頭金蔵は言い切りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "招く骸骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殺された正次郎さんでしたよ、――嘉助さんも、あの通り年を取ったし」　お徳は躊躇する様子もなくこう言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "路地の小判",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ、これだこれだ、どこにありました」「それを言う前に伺っておきますが、御新造は、その晩外へ出なかったでしょうな」「え、風呂場からお父様をここへお運びして、それからズッとつき切りでございました」　お冬は救いの綱を手繰るように、おどおどしながら言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "南蛮秘法箋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは別ですよ、叔母の隠密だから」　久太郎は噛んで吐き出すように言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死相の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "名指しされた石川良右衛門は、何か弁解をする積りらしく口を開きましたが、その言葉が出る前に、「もっとも、拵えの直しを頼まれたと言って、この間から旦那が持っていましたが」　お絹は言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か変ったことがありましたか、親分さん」　支配人の庄八の心許ない顔を見ながら、平次は静かに言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蝉丸の香炉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は、嫁のお雪と仲がよくなかったそうだな」　平次はズバリと言い切りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに隣のお角さんだって、小判の音ぐらいは聞いているでしょう、それから――」「…………」　多の市はちょっと考えましたが、「娘にちょっかいを出している経師屋の吉三郎の野郎だって娘から聞いていないとは言われません」「それっきりか」「ヘエ――」　多の市は覚束なくも言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "九百九十両",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうじゃな、平次」「拷問や牢問は、牢番与力配下の不浄役人の仕事で、手前ども手先御用聞の役目ではございません、恐れながらその儀は御容赦を願います」　平次は屹と言い切りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "名馬罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "「柴井町の友次郎を向うへ廻すのは厭だな」　平次は口にまで出してこう言い切りましたが、八五郎の必死の頼みを見ると、けんもほろろに断る勇気もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな肉の厚い三角に尖った小刀じゃない」「…………」「下手人は誰だか解らないが、お柳を殺したのは、その吉の道具でないことだけは確かだぜ」　平次は静かに言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "縁結び",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まアいい、――ところで庭木戸は内から閉っているようだが――」「ここは滅多に開けません」　一色友衛はしかと言い切りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度、その微妙な消息を春日藤左衛門に訊くと、「一色友衛にも鳩谷小八郎にも、娘をやると約束した覚えはありません」　とはっきり言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大名高家じゃあるまいし、医者が友達になっても構わねえように思うがどうだろう」「そう言えばそれに違いないようなものですが――」「それに、お前さんと周助は、同国だっていうじゃないか」「同国には同国ですがね」「やはりその切支丹仲間のようなものかい」　平次はズバリと言い切りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "南蛮仏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「燿ちゃん、そんなに心配しちゃいけない、僕がついてるじゃないか」　健一は隆々たる肩を聳やかして、こう強く言い切りました。",
              "citation": {
                "source": "水中の宮殿",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「残念乍ら、全部が真当の事です、私は小説家ではないのですから、こんな筋を細々と作る才能はありません」　佐々村村一は少し反り身に、昂然として言い切りました。",
              "citation": {
                "source": "法悦クラブ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処からも泥棒などの入る場所は無い筈ですが」　主人も番頭も、そう言い切ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうです東野さん――いや東野先生、ただとは言いません、打ち開けて下さればお礼はしますよ」「それは御免を蒙ろう、――どんな手紙を書こうと、あの人と僕との勝手な取引だ」　東野南次は言い切りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "代作恋文",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一方犯人自身はあくまでその陳述を曲げず最初より終始一貫、理路整然としてこの奇怪不思議なる殺人の動機を固執して、そこに必ずしも犯人の幻覚とのみ一概に言い切り得ざるものがあり、このところ法廷もこの前代未聞の殺人事件にかかって、大分頭を悩ませているように思われる。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、楽師長は、よけいこのとりをほめちぎって、これはまったく、ほんもののさよなきどりにくらべて、つくりといい、たくさんのみごとなダイヤモンド飾りといい、ことさら、なかのしかけといったら、どうして、ほんものよりはずっとりっぱなものだといいきりました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "邯鄲夢の枕の物語が語っているとおり、当時の未熟な荒っぽいインテリゲンツィア否定論などに対して、この作者は、そういう熱っぽいいきりたちもやがてさめる夢であろう、という暗喩を示したものと思われる。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとその悪者がみつかるだろう」　怪塔王は、モーターをこわした者がそのへんにいるといいきりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "end of sentence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
