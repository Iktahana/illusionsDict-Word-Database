          "literary": [
            {
              "text": "三脚のキャスターもガタがあるし、床のビニールタイルも移動撮影など考慮していないので、カメラが搖れる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二句「遠くなり近く」は今日の移動撮影の謂だらう。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "移動撮影の映画を見る感じだ。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
