[
  {
    "uuid": "bfab1ef3-1163-5c2a-84ff-b6e7de3434e1",
    "entry": "家付き",
    "reading": {
      "primary": "いえつき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
