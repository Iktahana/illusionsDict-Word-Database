        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "博物館で「古」の時代の土器や装飾品を見て、当時の生活に思いを馳せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「古」のロマンを感じさせる遺跡が、この山の奥深くに眠っているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の話す言葉遣いには、「古」の雅な響きが残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわー！これが「古」の時代の土器か！すごいな！」と子供たちは目を輝かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "……対象の知れぬ寂しみ神様はつまらぬものゝみをつくつた盥の底の残り水古いゴムマリ十能が棄てられました雀の声は何といふ生唾液だ！",
              "citation": {
                "source": "（ツツケンドンに）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣営の野に笑へる陽炎、空を匿して笑へる歯、――おゝ古代！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処に見られる感性は、古来「寒月」だの「寒鴉」だの「峯上の松」だのと云つて来た、純粋に我々のものである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、我々は、斯かる時にも猶環境の詮議を遂に女々しいことであるとした古人の考へに従ふべきであらうか？",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――寧ろ私は古代は叙事することによつて抒情を感ずることが出来たのだと言ふべきだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来自然を友とすることが多かつた我が国人は、感傷の綱の海を漕ぎゆくには余りに清廉であり、されば比較的清廉でなかつた人が用に与つて来たかも知れませぬ。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は茲で何も作文の稽古をしようとは思はない。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が私を抱いて、なんだか枯れかけた松林のやうな庭のやうな所を、そぞろに歩いてゐる古いフィルムでも見るやうに光景を、想ひ出すのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は起ち上つて、室の隅に行つて、原稿紙の反古や本や雑誌の堆の中を探しはじめた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りを行き切つて、明るい旧通りへ出ると、そこから直ぐと近くにある、彼が三年前に屡々買つたり売つたりしてゐた古本屋に、チヨツと寄つてみようかといふ気が起つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　（少し声を低く）ね、そこの反古紙にでも好いから、あなたの今迄の恋人の名前を書いてみない………？",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　いくとせもいくとせも前に忘れられたる人生の古い幻像です。",
              "citation": {
                "source": "よき祖母上に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしいものは未だ生れず、古いものは枯燥しきつて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした彼の哲学（人格の語る哲学であつて思想の語る哲学ではない）は、ある意味に於て、あの偉大なる古代ギリシヤ人のそれと全く共通する。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその他の者は、相変らず古典的な美文で、古典的な、熱のない脩辞を繰返して居るにすぎなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンが学校に行ってる間、夫人は暇を盗んで熱心に読書をし、手の及ぶ限り、日本の古い伝説や怪談の本を漁りよんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際もし彼の妻がインテリ女性であったとすれば、日本の古い伝説や怪談やを、女の素直な心で率直に実感することはできなかったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしば芥川君は、私の古い詩について意見を述べ、表現技巧の缺點を指摘された。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場のガードをくぐつて坂を登ると、暗い煤ぼけた古道具や、安物の足袋など店に竝べた、昔の宿場そつくりの町がある。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路は冬のやうに白つちやけて、昔ながらの大道店が、ガマの油や、オツトセイや、古着類や、縞蛇や、得體のわからぬ壞れた金物類などを賣つてる。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いノオトだけでは、間に合わなくなって来た。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いノオトのちりを吹き払って、カントやヘエゲルやマルクスを、もういちど読み直して、それから、酒をつつしんで新しい本も買いたい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理心中という古くさい概念を、そろそろとからだで了解しかけて来た矢先、私は手ひどくはねつけられ、そうしてそれっきりであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い質問、「知ることは幸福であるか」　　佐野次郎左衛門様馬場数馬。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、もう東京はいやだ、殺風景すぎる、僕は北京に行きたい、世界で一ばん古い都だ、あの都こそ、僕の性格に適しているのだ、なぜといえば、――と、れいの該博の知識の十分の七くらいを縷々と私に陳述して、そうして間もなく飄然と渡支した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど古着屋のまへでしたので、その店の古着を早速着せられました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯も、緑色の兵古帯でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来一流の作家のものは作因が判然していて、その実感が強く、従ってそこに或る動かし難い自信を持っている。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草｜生い、苔むして、いにしえよりかかりけむと思い紛うばかりなり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口の土間なんど、いにしえの沼の干かたまったをそのままらしい。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
