    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one-by-one",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一々口を挟まないで。今は私が話している最中なんだから」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんな些細なことまで一々報告しなくてもいいよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いちいち腹を立てていたら、この仕事は務まらないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一々説明されなくても、そのくらいのことは心得ています」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「人のすることに一々ケチをつけるのは、彼の悪い癖だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「過去の失敗を一々掘り返すのは、もうやめにしよう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一々確認するのは面倒だけど、ミスを防ぐにはこれが一番なんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんな奴の言うことに一々付き合ってられないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "勿論かういふことは、一々の短歌作品、一々の俳句作品に就いてそつくりそのまま当箝まることではないけれども、夫々の様式を規範的に観た場合そのやうに言ふことは先づ間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば裏の竹藪に蛇が出たとか、蟇が鳴いてるとか、蟻の山が見つかったとか、梅の花が一輪｜咲いたとか、夕焼が美しく出ているとかいうようなことを、だれか家人の一人が発見すると、一々それをヘルンの所へ報告に行く。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "会話が、少しもわからず、さりとて、あの画面の隅にちょいちょい出没する文章を一々読みとる事も至難である。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら技巧とは一々の場合に当つて作者自身の関心内にあることで、殊に芸術の場合には名辞以前の世界での作業であり、技巧論即ち論となるや名辞以後の世界に属する所から、技巧論といふものはせいぜい制作意向の抽象表情を捉へてそれの属性を述べること以上には本来出ることが出来ない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天井の低い家だし、一々気持が悪い。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に父上は戸棚から三宝をいくつも取下ろして一々｜布巾で清めておられる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上はこれに一々｜水引をかけ綺麗にはしを揃えて、さて一々青い紙と白い紙とをしいた三宝へのせる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこれらの人々から受けた親切は一々明細に記録しておいて、気長にそしてなしくずしにこれを償却しなければならないのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩といへば、小さい時から、もう恩だらけで、いまでも、一日も忘れられない恩人が、十人以上もありますし、一々お名前を擧げて言ふのも、水くさくて、かへつて失禮でせうし、『大恩は語らず』といふ言葉のとほり、私は今では、あまり口に出して言ひたくないのです。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に倉橋君が来る、晃平を殿として、一行が揃う、こう霧がひどくては、方角も何も解らない、晃平は荷を卸して、路を捜索に出たが、無益に戻って来た、岩の間を点接して、トウヤクリンドウ、ミヤマキンバイ、ミヤマウスユキソウ、チングルマなどがあったが、風と霧と雨の中で、一々眼に止めていられない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り数が多いから一々顔が覚えてられねえんだよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々そんなことに構っちゃいられないんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で待っていたお客に対して運転手が一々丁寧に、どうも気の毒だが御覧の通り一杯だからと云って、本当に気の毒そうに詫言を云っている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が新しくブラシを下す度に、「烟だよ」とか「電柱だよ」とか一々説明してくれる人もあつて、何だか少し背中や頸筋の邊がくすぐつたいやうな氣持もした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他炭の棒やホヤや附属器械のパテントを一々数え立てたら限りがない。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩尖、膝頭、臀部、あたま――翁の眼中、一々、その凸所の形に似通う山の姿が触覚より視覚へ通じ影像となって浮んで来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女神は一々、まじめに、その恋を求むる男たちに見向ったらしい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私はこの憎らしい、私を苦しめる痰を、吐き出すときに、一々、舌の上に載せて味ってやるんですよ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の休憩室には色々な飾り物が所狭く陳列してあって、それに「花○喜○｜丈」と一々札がつけてある。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "某氏はベデカの案内記と首引で一々引き合わして説明してくれたので大いに面白かった。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他「完全なる剛体」とか「摩擦なき面」とか「一定の温度」とか一々枚挙に遑はないが、こういう言葉を如何に理解し如何に自然界に適用すべきかという事を実験の途中で漸次に理解させるが肝要であろうと思う。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば台所における物理学の応用だけでも、一々列挙すれば一冊の書物が出来ようと思う。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気がどんなでも一尺差はやはり一尺差であって、呉服商が一々寒暖計と相談する必要がない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの概念の変化によって新しい事実の発見されるごとに一々新しい方則を捻出する事が避けられるのである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して一々何とか返事を出さなければならないのである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十六日政夫民子様　学校へ行くとは云え、罪があって早くやられると云う境遇であるから、人の笑声話声にも一々ひがみ心が起きる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "国語の音韻の変遷を考えるには、単に一々の音の時代的変化ばかりでなく、かような諸法則の変遷をも考えなければならない。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりそれらの音を色々に組合せて一々の語の形が出来、そうして色々の違った意味を違った音の形によって言い分ける、すなわち、区別して示すのである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、いちいちその研究発表を、いま、ここで、せずともよい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごらん下さい、私はいまこうしています、ああしていますと、いちいち説明をつけなければ指一本うごかせず咳ばらい一つできない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "every single",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「君は一々細かいことに口を出しすぎだ。もっと大局を見て判断してくれ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いちいち説明しなくても、資料を読めば大体の流れは把握できるはずだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "膨大な書類の束を、彼は一々手に取っては裏返して、不審な点がないか入念に調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「SNSのコメントに一々反応していたら、いくら時間があっても足りないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自分の手柄を一々自慢げに話すので、周囲からは少し煙たがられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お母さん、一々私のすることに干渉しないで。もう子供じゃないんだから。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裁判では、証拠品の一々について、その入手経路が厳格に問われることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
