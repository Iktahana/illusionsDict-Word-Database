    "definitions": [
      {
        "index": 1,
        "gloss": "sharing one's lot with another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「こうなった以上、君とは一蓮托生だ。最後まで付き合ってもらうぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "会社を立ち上げた時から、彼とは一蓮托生の覚悟でやってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "借金の保証人になった時点で、あなたも彼と一蓮托生になったようなものですよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "運命共同体というより、もはや一蓮托生という言葉のほうがしっくりくる関係性だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "おなじ道楽の一蓮托生といったような気持も手伝って、昔の恋仇の意地張はどこへやら。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一蓮托生と、さあ、皆乗つたか。",
              "citation": {
                "source": "光籃",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえと一蓮托生だ」　兼松は笑いながら、勘太と共に夜叉神堂のうしろに隠れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうなりやあお互えに一蓮托生ぢやあねえか。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一蓮托生、死なば諸共だ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こと日本市場に関する限り、アスキー、マイクロソフトと渡辺たちは、一蓮托生だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのときの、われら、何と云いました――一蓮托生と云いました、な」「しかし、阿賀妻さん」「はい」と彼は弱々しく答え、しかし目をみはって相手を眺めた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、君と一蓮托生の約束だったのう。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの仏教の安価なる一蓮托生説だの、基督教の一本調子な恋愛至上説だのは、僅かに真理の一部を掴んだに過ぎざる、甚だしく歪んだもので、到底今後の人類を率いるに足りない。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一蓮托生、うらみっこなし――。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄るな寄るな、この葉巻を持って来たのもその為めだ、こいつを桶へ投げ込むと、この建物は粉片微塵だ、探偵も娘っ子も一蓮托生よ、サア」　火のついた葉巻をふり上げると、「ワーッ」　四人の男女は、必死と逃げまどいましたが、元より狭い地下室、今更騒いだところで追っ付く道理はありません。",
              "citation": {
                "source": "古銭の謎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはゆる一蓮托生である。",
              "citation": {
                "source": "新憲法の解説",
                "author": "解説",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤も黒田内閣の組閣当初は大隈推薦者であるとともに支持者であり、彼と盟約をとり交わして一蓮托生を誓った間柄であるにもかかわらず、しかし今となると大隈の引責辞職によって激化する民心を抑えるよりほかに手段のないことを自認するにいたった。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然ある意味グローバさんと一蓮托生になったし、秘密を知ることになった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが嵌めようとしている若者は私の大好きな女性と一蓮托生です。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "一蓮托生ですし……」　男爵が言った。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつまた、今日は二人の間に、一蓮托生の約がむすばれためでたい日だ。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
