    "definitions": [
      {
        "index": 1,
        "gloss": "life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "どんな命も大切にされるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "限られた命を精一杯生きよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "都会の喧騒から離れて、自然の中で命の尊さを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この小さな命を守るために、私たちはここにいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "俺は廊下に立たされて、何がなし、「運命だ」と思ふのだつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "車が芝南寺の少し手前まで来ると、助手台に乗つてゐた谷丹三の親友が、急に停車を命じた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに不思議な運命のそれ自体単純にして、それを織成す無限に複雑な因子の離合の間に、今や我々に既に分つたことは、宮沢賢治は死後間もなく認めらるるに至つたといふことである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が現状の裡に身を置いて考へる限り、これは正しく運命のいたづらである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには概念を出来るだけ遠ざけて、なるべく生の印象、新鮮な現識を、それが頭に浮ぶまゝを、――つまり書いてゐる時その時の命の流れをも、むげに退けてはならないのでした。",
              "citation": {
                "source": "宮沢賢治の詩",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の感覚を通して這入つて来るものの中に安心立命してゐるのである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "村落の光る厩のうへに、かがやく愛の手は伸びゆきて、われの身は銀の一脈、ひそかに息づき生命はや絶えなんとする。",
              "citation": {
                "source": "厩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "努力を尽しても、猶天命は俟たねばならないものだといふことを、努力の際中でも予想出来るのでなければ、努力といふことも畢竟何のための努力か分らなくなり、そんな所から美は出て来ないと思ふのだ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々此の短歌なるものは、生活の傍に生じた芸術といふ感じの強いものであつて、短歌が、一人の人間の全生命となるといふ風のものではなかつた。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋持続の、人に於ける心理的状態は、強ひて言へば、未来を思ふとしては神を、現在を思ふとしては自己を、過去を思ふとしては運命を信じてゐるのだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、長いことはない、四五年の寿命だが、高等学校の文芸部の我鬼大将であつたこと以外に如何なる文学的経歴をも有しない男が、雑文家だの、批評家だの、評論家だのといふ肩書の下に、世間といふ舞台をのし歩くのである。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ風なら時代の如何を問はず運命を開拓してゆくのであらうと思つた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れにしても、それは成つてみれば運命の臼の加減といふほかないのであるが、成つてみるまでは人には各々胸の混沌、直観としてのイデエがあるばかりである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ彼には対象を名命し形容するすべての言葉と、その正確な眼との間の隙ばかりが気になる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕としてそんな用命にあづかつたことは生れて初めてでもあつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏の夜空の中に、電気広告の様々なのが、消えたり点つたりする下を、足を投げ出すやうな心持に、歩いてゆくことは、まるで亡命者のやうな私の心を慰める。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "主として運命は我等を導いて行つた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの悲しい宿命者も、さすがに日本に渡ってからは、多少の平和と幸福を経験した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも宿命的な詩人の悲願は、その有り得べからざる夢の国を、生涯夢見続けることの熱情にある。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして国籍を持たない家族が、財産上にも生命上にも、日本の政府から保護を受け得ないことを考えた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて病気の発作が起った時、ヘルンは自己の運命をすっかり自覚し、死後における妻子の保護と財産の管理とを、親友の法学士に一任して、後に心がかりのないようにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はさらに女中に命じて、念のために新聞を取り寄せさせた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら運命が、不幸にも我々を別離させた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の過去における一切の思想と感情とに、ある根本的の動搖があり、新しき生活の革命に入らうとする、けなげにも悲壯な心境が感じられた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命としての靈魂がない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私の信ずる所によれば、彼の自殺における「漠然たる不安」の一つは、近く來らんとする彼自身の心境的革命にまで、名状しがたき不安の困憊を感じたのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにその時、あらゆる天才の不運について、藝術家の宿命的な孤獨と悲慘について、彼が沈痛な聲で訴へたか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の詩人宿命生涯を貫く萩原朔太郎　僕は少年の時、島崎藤村氏と薄田泣菫氏の詩を愛讀した。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの一つの事が、他の何人にもまさつて、藤村氏が眞の本質的の詩人であり、生れたる宿命の詩人であることを證左して居る。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "）然るに島崎藤村氏だけは、今日の老年に至るまで、一貫してその魂に純のリリツクを所有して居るところの、眞の宿命的な詩人であつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "lifetime",
        "register": "standard",
