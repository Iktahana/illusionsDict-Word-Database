    "definitions": [
      {
        "index": 1,
        "gloss": "natural mineral pigments",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
