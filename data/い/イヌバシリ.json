        "examples": {
          "standard": [
            {
              "text": "家の周囲の犬走りに砂利を敷き詰めたら、歩くたびに音がして防犯にも良さそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「犬走りに雑草が生えないように、除草剤をまいておいてくれる？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軒下の犬走りで、雨宿りをしながら通り過ぎるのを待った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "竪に鉄の棒を打ち附けた窓で、その外には犬走りに植えた側柏が二三本｜埃を浴びて立っているのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中に犬走りという中段がある。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒューッ、ヒューッ、とつづけざまにおちてくる光――「いたッ、犬走りだ」　と頭のうえで声がしたとたんに、光をたよりに、バラバラと、つるべうちに射てきた矢のうなり、――鉄砲のひびき。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しまった」と龍太郎は伊那丸の身をかばいながら、石垣にそった犬走りを先へさきへとにげのびた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
