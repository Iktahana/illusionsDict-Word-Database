        "examples": {
          "standard": [
            {
              "text": "鎌倉時代、北条高時は熱狂的な犬合わせの興行に明け暮れたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古記録によれば、華やかな装束を纏わせた犬たちが犬合わせに臨んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての支配者層にとって、犬合わせは権威を示す重要な行事でもあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古典文学の記述を頼りに、当時の犬合わせの様子を屏風絵に再現する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "魚鳥の肉を食わせて毎月犬合わせといって闘犬会を催し、上下集まり見物した。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
