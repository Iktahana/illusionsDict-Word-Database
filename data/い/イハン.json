    },
    "definitions": [
      {
        "index": 1,
        "gloss": "violation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スピード違反で捕まり、免許の点数が引かれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は契約に違反したとして、多額の賠償金を請求された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業が環境基準に違反すると、社会的信用を失うことになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どれだけ法規違反ばかりをやっているか見せてやることが出来る。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫烟室へ行くも面倒なり、少し船の規則の違反ではあるが、此室で葉卷でも燻らさうと思つて洋服の衣袋を探りて見たが一｜本も無い、不圖思ひ出したのは先刻ネープルス港を出發のみぎり、濱島の贈つて呉れた數ある贈物の中、四｜角な新聞包は、若しや煙草の箱ではあるまいかと考へたので、急ぎ開いて見ると果然最上の葉卷！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは新聞紙法違反位の軽罪で、二三ヶ月の拘禁を受ける位の程度を考へたからのことであつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "大劇場附きの俳優が小劇場に出勤するは組合規約に違反すという反対論多く、諸新聞の攻撃もまた猛烈。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "権右衛門が統制違反で拘引された。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者は即ち主として皇太子暗殺を企ててゐたもので、此事件の發覺以前から不敬事件、秘密出版事件、爆發物取締規則違反事件で入獄してゐた内山愚童、前者即ちこの事件の眞の骨子たる天皇暗殺企畫者管野すが、宮下太吉、新村忠雄、古河力作であつた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、この人は選挙違反だろうと思った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみか、某事件の摘発、攻撃の筆がたたって、新聞条令違反となり、発売禁止はもとより、百円の罰金をくらった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この媾和条約違反から、夏の陣が起るのであるが、惣堀だけを潰す約束であったのに、二の丸三の丸の堀まで潰したので、大阪方が憤慨したと云う説、いや初めから二の丸三の丸を潰すことを大阪方も認めていたと云う説もあって、決しがたい。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太閣は、北条家の条約違反を怒って、遂に小田原征討を決心したのである。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの間にはきびしい鉄の掟があり、違反は死をもって償われる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活綴方を実践していた東北の教師たちも、治安維持法違反容疑で検挙され、書くことを通じて子供たちに時代を直視させようとする試みは押しつぶされていきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "出廷を求められた両市長は、「核兵器は国際法に違反すると考える。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "著作権切れの書籍を電子化して公開するプロジェクトを進めるエリック・エルドレッド等は、同法が合衆国憲法に違反するとの訴えを起こした。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇三年一月一五日、連邦最高裁によってこの訴えは退けられたが、ステファン・ブレヤー判事とジョン・ポール・スティーブンズ判事は、二〇年延長を憲法違反とする反対意見を付した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この締め切り違反の連続の中で、妥協なく注文を付け、しかも辛抱強く励まし続けてくれたのは、ソフトバンク書籍編集部の沖山克弘さんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ工場の労働者たちは、切り株浸水事件の後に、白水が積善会の積立金の会計報告等が一切ないことを鳴らし、かつ工場の扶助規則や未成年労働者使用等、規則違反が多いことなどを表面の理由として、資本家階級の間に、どんな策戦があるか探りを入れ始めたんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "固ヨリ削除セラレタル一行一句ト雖モ日本ノ法律ニ違反セル文字ニ非ルハ論ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "違反者ニ對シテ死刑ヲ以テセント云フハ必ズシモ希望スル所ニ非ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "違反者ノ罪則ハ、國家ノ根本法ヲ紊亂スル者ニ對スル立法精神ニ於テ、別ニ法律ヲ以テ定ム。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "違反者ノ罰則ハ、國家ノ根本法ヲ紊亂スル者ニ對スル立法精神ニ於テ、別ニ法律ヲ以テ定ム。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "之ニ違反シテ雇傭シタル者ハ重大ナル罰金又ハ體刑ニ處ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことがひとにわかるもんか」　「いえ、まったくです」　「とにかく遊ぶのがすでに条件違反だ。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことがひとにわかるもんか」「いえ、まったくです」「とにかく遊ぶのがすでに条件違反だ。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師法｜違反になりはしませんか」　相手は静かに私の瞳を凝視した。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　いのちの孤獨、われより出でて徘徊し、歩道に種を蒔きてゆく、種を蒔くひと、みづを撒くひと、光るしやつぽのひと、そのこども、しぬびあるきのたそがれに、眼もおよばぬ東京の、いはんかたなきはるけさおぼえ、ぎたる彈く、ぎたる彈く。",
              "citation": {
                "source": "ぎたる彈くひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはんや、他人に於いてをや。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつもの小流れや石原を越えて、山脈のかたちも大きくはっきりなり、山の木も一本一本、すぎごけのように見わけられるところまで来たときは、太陽はもうよほど西に外れて、十本ばかりの青いはんのきの木立の上に、少し青ざめてぎらぎら光ってかかりました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうが何ぼでもいいはんて買って呉なぃ」小十郎はそう言いながら改めておじぎさえしたもんだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつもの小流れや石原を越えて、山脈のかたちも大きくはつきりなり、山の木も一本一本、すぎごけのやうに見わけられるところまで来たときは、太陽はもうよほど西に外れて、十本ばかりの青いはんのきの木立の上に、少し青ざめてぎらぎら光つてかかりました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
