[
  {
    "uuid": "4b7c85b8-e29d-53b1-8182-dea2bc6a3305",
    "entry": "違反",
    "reading": {
      "primary": "いはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
