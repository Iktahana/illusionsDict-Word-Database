    "definitions": [
      {
        "index": 1,
        "gloss": "medicine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "近年、再生医学の発展が目覚ましく、難病治療への期待が高まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は幼い頃から人助けに興味があり、医学の道を志した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この画期的な手術は、現代医学の限界を押し広げるものとして注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地域の医療を支えるため、総合大学病院では様々な分野の医学研究が進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経験豊富なベテラン医師は、長年の臨床経験から培われた医学的知見を惜しみなく若手に伝えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まさか、ここまで医学が進歩するとはね」と、祖父は驚きを隠せない様子でつぶやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "病理学は医学の基礎となる重要な学問であり、病気の原因究明に不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして父の従兄から出る僅かの金で父はかつがつ軍医学校まで卒へた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにその頃郷里でただ一人の東京帝国大学卒業医学士であったところの楠先生の御厄介になることになった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が話し好きであったからたいていの医師は来るとゆっくり腰を据えて話し込んでしまうのであったが、この楠先生もよくお愛想に出した葡萄酒の杯を銜んだりして、耳新しい医学上の新学説などを聞かせてくれたような記憶がある。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）どういふ訳か大へんにわかにその博士を三人も使ってゐる偉い医学士が興奮して早口に云った。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また医学の方でも物理的療法という言葉が出来て、その方の専門家もあるくらいである。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年五月二十五日『東京朝日新聞』）　　　　　　　　　八十三　　　　　　六千年前の肉塊　近頃エジプトの医学校で木乃伊の解剖分析に従事している学者がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御馳走を喰えば栄養になり、喰い過ぎれば腹下りを起こすくらいのことは知っていたが、この、医学者でも物理学者でも何でもない助手Ｍ君の感冒起因説は当時の自分の医学上の知識を超越していたのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学士ロイトホルド。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（医学士に進み近付き握手せんとす。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの虚無主義者と看做されている主人公の医学生に賛同しているというので、貴族｜等は作者を攻撃する。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の医者だけでは不安で物足りなくって、町からも医学士を迎えた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学士はオートバイで毎日やってきた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてのかゝりつけの安斎医学博士の栄養説によると、台湾に住んでいてわざ／＼内地米を取りよせて食っていた者があったそうだが、内地米が如何にすぐれていようともそんなのは栄養上からよくないそうである。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「えゝ、しかし何は御不足でも医学博士、三角康正さんが、この一｜行にお加はり下すつて、篤志とまでも恩に着せず、少い徳本の膝栗毛漫遊の趣で、村々で御診察をなすつたのは、御地に取つて、何よりの事と存じます。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "化学、天文学、医学、数学なども、その歴史の初頭においては魔法と関係を有しているといって宜しかろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "国へ帰って後病を得て一年休学する事になり、友に託して荷物は親類へ預けてしまい、しばらくしての友の手紙に雪ちゃんの家は他へ譲り渡し、主人は寺番に、雪ちゃんはある医学士の家へ小間使に上がったが、主婦に関してはすべて消息を知る事が出来ぬとの事であった。",
              "citation": {
                "source": "雪ちゃん",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれでもまだ灸治の研究をする医学者の少ないのと同じような特殊の心理から火事の研究をする理学者が少ないとしたらそれは日本のためになげかわしいことであろう。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう、西洋のえらい医学の大家の夢にも知らない療養法を須崎港の宿屋で長い間続けた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後にまた麻布の伊藤泰丸氏から手紙をよこされて、前記原氏のほかに後藤道雄、青地正皓、相原千里等の各医学博士の鍼灸に関する研究のある事を示教され、なお中川清三著「お灸の常識」という書物を寄贈された、ここに追記して大泉氏ならびに伊藤氏に感謝の意を表したいと思う。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時自分のほかに先生から俳句の教えを受けていた人々の中には厨川千江、平川草江、蒲生紫川（後の原医学博士）等の諸氏があった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋医学なぞクソでもくらへだ』とあつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近医学の進歩につれて、この性欲なるものは、人体内の諸所より血液中へ分泌される内分泌物、すなわちホルモンの司る作用であって、そのホルモンが血液に混じて体内をめぐり、一方性欲を惹起させ、他方また精神、肉体を強靱ならしめていることが実証されて来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四八課　女のヒステリー　世間一般に言いならされたいわゆる「女のヒステリー」というものは、医学上でいうヒステリー症とは大変な相違があるようです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学上のヒステリーは一種の精神病を指し、それは女ばかりでなく男でも子供でも起るそうです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここに医学士、と記てあるですな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査に取っては、魚河岸の侠男が身を投げたよりは、年の少い医学士と云う人間の、水に棄てたものは意外であった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　医学士は思わず激した。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも孰にせい、私が思うたほどの事件でない、とだけは了解したのじゃけれども、医学士などは、出たら目じゃろう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「事態、私も怪訝に堪えんもんで、早急とはなしに、本郷方面へ、同僚の筋を手繰って捜りを入れると、葛木晋三と云う医学士はいかにもあるじゃね、そしてです、それは医科に勤めておらるるが、内科、外科、乃至婦人科、何でもないのじゃ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぼちゃを食わぬ主義や、いがくり頭で通す主義や、無帽主義などというのは愛嬌もあるが、しかし他人の迷惑を考慮に入れない主義もあった。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
