      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "telepathy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年の夫婦は、互いの些細な仕草や表情から以心伝心で気持ちを察し、言葉を交わすことなく食卓を囲む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "熟練のプログラマーたちは、コードレビューの際に、相手の意図を以心伝心で汲み取り、迅速にバグを修正していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台上で、主役と相手役は以心伝心で呼吸を合わせ、観客を魅了する感動的なシーンを創り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "禅の師弟間では、言葉での説明を超えた以心伝心による悟りの境地が重視される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この後、どうしようか？」と尋ねようとしたら、友人が「「うん、映画でも行こう！」って、まさに以心伝心だったね。」と笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "母親は、子供がまだ何も訴えていないのに、その微細な表情の変化から以心伝心で不安を感じ取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "交渉の場では、相手の微妙な表情の変化から以心伝心で本音を読み取ることが、成功の鍵となる場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の付き合いで、彼らの間には以心伝心な信頼関係が築かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さうして以心伝心に同じ哀憐の情が三人の上に益々深められてゆくのを感ずる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "リズムは以心伝心である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "径に被さった樹々の葉に、さらさらと渡って、裙から、袂から冷々と膚に染み入る夜の風は、以心伝心二人の囁を伝えて、お雪は思わず戦悚とした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "以心伝心というやつだそうである。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に云う以心伝心という事は、鼻の存在に依ってその可能性を裏書きされると云っても決して過言ではあるまいと考えられます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『彼女の僅かに残っている良心を恥かしめてやる』べき、以心伝心の遺託を、受けているのだった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『彼女の僅かに残つてゐる良心を恥かしめてやる』べき、以心伝心の遺託を、受けてゐるのだつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "申し分なしだろう」とか、「何にしろ以心伝心だからな」とつけ足した。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の心は、山岡が面白そうに幾度も繰り返して云った以心伝心という言葉のまわりを、丹念に廻っているのであった。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　以心伝心でうれしいような、不気味なような心持。",
              "citation": {
                "source": "一九二三年冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "問わず語らず、謂わば『以心伝心』で操縦することが出来るとは――。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は眼と眼を見合わせたが、以心伝心でお互いの心が通じ合った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妙だね、こりゃおつだよ、以心伝心、若いものに華をもたせようとするのかな。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "以心伝心で、傍に寄って来て鞄を並べておいてから、平気な顔で煙草の火を借りる。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復の省線のなかなどで、割合にすまして新聞などをひろげている人の顔に折々つよい興味を感じ、そこは微妙な以心伝心で、その人達の生活の心が、あながち新聞の紙面の縦横の寸法だけに、はまり切っているものでもないことを共感するのであった。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もこいつも、知らぬ他国を流浪の身の上だから、言葉は通じなくても以心伝心てやつ」「おい姐さん、以心伝心で口説いちゃいけねえよ」　と、白粉っ気はないが、道化らしい顔がのぞく。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "以心伝心と、刻苦修練と、十年、二十年、深山に寒籠りをし、厳寒の瀑布に修行し、炎天に咀し、熱火の中に坐して、ようよう会得しても、平常には何んの用も為さぬ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵道で尚ぶところの、以心伝心などということに、誰も興味を持たなくなった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし君、以心伝心という現象を知っとるかね、つまりこちらの思うことが、言葉を使わずに、直接先方に伝えられる――この現象をなんといって説明するかね、一寸六ヶ敷いじゃろう。",
              "citation": {
                "source": "白金神経の少女",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これは電気学的に説明が出来るんじゃ、感応作用、相互誘導作用、じゃよ――、つまり考える、ということによって脳に一種の電流が生じる、これに感応して相手の脳髄に電流が誘起されるのが以心伝心という現象なんじゃ。",
              "citation": {
                "source": "白金神経の少女",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、もう二度と目と目を見かわす必要もなく、お互に、これから先の行動を、以心伝心、のみこみ合ってしまったのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇太郎と菊之丞――名乗り合ったことはないが、以心伝心、雪之丞を中心にしてもうとうに、其の底まで読み合っている。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の自然の妙というものは以心伝心とかで、手を以て教えることも出来ず、口で云って聞かせることも出来ませんゆえ、親が子に伝えることも成らず、師匠が弟子に譲るわけにもまいりませんから、名人が二代も三代も続くことは滅多にございません。",
              "citation": {
                "source": "名人長二",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同顔を見合せましたまゝ別に評議もいたしませぬが、以心伝心で文治に十分の利を持たせ、結句平林は自業自得、殺され損ということに落着いたしました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "以心伝心とか、暗黙の裡に語るとかいふ甚だ神秘的な趣味を解する如く見えて、実は、誤解と泣寝入と気まづさとを生涯背負つて歩いてゐるのである。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "先の驚きがまだ貌から消えぬうちに、新しい驚きがその心を騒がしたので、以心伝心娘の驚きがすぐ自分の胸にも移ッた。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以心伝心｜黙契の中に貴君の心が通じているのですか」大原「イヤ一向通ぜん。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "non-verbal Zen Buddhist transmission to a disciple of the central tenets of Buddhism",
