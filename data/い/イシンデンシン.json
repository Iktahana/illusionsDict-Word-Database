[
  {
    "uuid": "bc1bbacc-806d-5720-918f-f0bab95c056a",
    "entry": "以心伝心",
    "reading": {
      "primary": "いしんでんしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
