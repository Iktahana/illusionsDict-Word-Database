    },
    "definitions": [
      {
        "index": 1,
        "gloss": "uniform",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試験問題は難易度が一様でなく、一部の学生から不満の声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この素材は表面の質感が一様で、非常に滑らかだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "出席者全員に一様の資料が配布された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の作品はどれも一様の高いクオリティを保っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "とんかく一様式と観らるべきものが感じられる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "湾も、港市――その家々も、たゞ一様にドス黒く見えてゐる。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、私事、神は信じたが宗教家といふ人間仕事の一様式にも吸引を感じなく、さりとて神学者にもなりたいと思はず、又、ユマニテは信じたが、例へば社会事業にどれといつて縁も生ぜず、さりながら、詩には心ときめいたのである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の俳句の特色として、人々の一様に言うところは、およそ次のような条々である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海水浴がえりの女の群の一様に大なる藁帽子かぶりたるなど目に立つ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか、仲間が一人来る、二人｜蹤いて来る、岩の上には、黒いピリオドが、一点、二点、三点――視線は一様に、鼠色のそれに向う。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、彼等は一様に、何かに性急に追いまくられてるように感じた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の流れや風の吹くのを見てもそれは決して簡単な一様な流動でなくて、必ずいくらかの律動的な弛張がある、これと同じように生物の発育でも決して簡単な二次や三次の代数曲線などで表わされるようなものではない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから波の長さがあまり一様なのもいけないらしい。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると三色の粉はすっかり一様に混じてもはや三色は別々に見分けが付かず、一体に灰色を帯びて見える。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この混合した粉を硝子板の表面に一様に篩いかけて後押し付けると三色の粉を不同なく板の上に密布し、顕微鏡で見れば全体がモザイックのようになっている。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの窓にはたくさんの顔がみな一様な表情を浮べてゐた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし品の意味は一様ではない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く何も比較の尺度のない一様な緑の視界はわれわれの空間に対する感官を無能にするらしい。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとまた下の二字を一様に汚して上の二字は綺麗に保存しているのもある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして柔らかく温かに湿った湯気の中に動いている人の顔にも、鏡の前に裸で立ちはだかって頬を膨らしてみたり腹を撫でてみたりしている人の顔にも、湯槽の水面に浮んでいるデモクラチックな顔にも、美醜｜老若の別なく、一様に淡く寛舒の表情が浮んでいる。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国へ渡るとなんだか急に呑気になった、巡査を見ても牛乳屋を見ても誰を見ても一様に呑気な顔をしていた。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「大きさ一様なる棒」とか「平面」とか「球面」とかいうものも厳密には実現し得られない事も忘れてならない。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに恒星の全質量が天球上に一様に分布されているとすれば総和は零となる。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "定まった弾条に定まった重量を吊し、定まった温度その他の同時的条件を一切一様にしても、その長さは一定しないのである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "波が砂をかきまぜているのに、どうして一様に交じらないでしょうか。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして奈良朝時代において色々のちがった人が書いたものにおいて、その用いる万葉仮名は必ずしも同じ文字ではないのに、皆一様に二類の区別が守られているのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "レビュー見学のノートから脱線してつい平生胸に溜まっていた教科書の不平をこぼしてしまったが、こういう脱線もまた一つのレビュー的随感録の一様式中の一景として読者の寛容を願いたいと思う。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその区々な表現の価値を定めるものも科学の場合とは無論一様でない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛は肩にたれて、まっ白な花をさした少女やそのほか、なんとなく気恥ずかしくってよくは見えませんでした、ただ一様に清らかで美しいと感じました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アジアの旅行中シナの大官からごちそうになったある西洋人の紀行中の記事に、数十種を算する献立のどれもこれもみんな一様な黴のにおいで統括されていた、といったようなことを書いている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがただ一様な色紙ではなくて、よく見るとその上には色々の規則正しい模様や縞や点線が現われている。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五回の爆声の間の四つの時間間隔は決して一様にはならないものらしい。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻も台所から顔を出して、「三人がよくならんでしゃがんでること、奈々ちゃんや、鶏がおもしろいかい、奈々ちゃんや」　三児はいちように振り返って母と笑いあうのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はしばしば思うた、もし武蔵野の林が楢の類いでなく、松か何かであったらきわめて平凡な変化に乏しい色彩いちようなものとなってさまで珍重するに足らないだろうと。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "common",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
