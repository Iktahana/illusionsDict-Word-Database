    "definitions": [
      {
        "index": 1,
        "gloss": "from the beginning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「失敗を恐れる必要はない。ダメだったらまた一からやり直せばいいだけだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "異国の地で、言葉もままならない状態から一から生活を築き上げた苦労は計り知れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "中心人物の離脱により、プロジェクトの計画を一から練り直すことを余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「専門用語を一切使わずに、この制度の仕組みを一から分かりやすく解説してください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新居への引っ越しをきっかけに、古い家具を処分して家財道具を一から揃え直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この老舗洋食店では、デミグラスソースを作るのに一から十日間かけて仕込みを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「過去のしがらみはすべて水に流して、もう一度一から信頼関係を築いていきたい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "なんて珍らしくもない話に大仰に驚いて見せたり、一から十まで嘘ばかりの社交を行ひ、天晴れ上流の客あしらひをしてゐるつもりのケチくさい小利口の大馬鹿野郎どもに、この龍宮の鷹揚なもてなし振りを見せてやりたい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手段は、一から十まで詭計である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん今でも未開時代そのままの模範的な迷信が到るところに行われて、それが俗にいわゆる知識階級のある一部まで蔓延している事は事実であるが、それとは少し趣を異にした事柄で、科学的に験証され得る可能性を具えた命題までが、一からげにして掃き捨てられたという恐れはないものだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一から十までの数がどうしても読めません。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一から見た十は十倍であるが、百から見た同じ十はわずかに十分の一だからである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば文士｜渡辺篤君の家庭の夜の風景を表現するとして、そうしてねずみが騒いだり赤ん坊が泣いたり子供が強硬におしっこを要求したりして肝心の仕事ができぬという事件の推移を表現するにしても、何もあれほどまでに概念的、説明的、型録的に一から十までを一々｜羅列して見せなくてもよいと思われる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅田さんのいうとおり、年のところに行くと少し明きすぎるようだが、わしらのような暮しでは一から十まで註文どおりにいかないのは覚悟していてくれんと埒はあくものではないぞ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに自分の奉事する學術は一から十まで實驗の上に立脚してゐる。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一から一を引くとなんにもなくなります。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一から二を引くと……」と言おうとしてクねずみは、はっとつまってしまいました。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一から二は引かれないよ。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は私の申立を一から十まで信用したかどうか判らないが、とにかくにヘボンの字書ならば買っておいても損はないという料見であったらしい。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳重な取調を受けても一から十まで「知りませぬ」「わかりませぬ」の一点張りで、女のようにヒイヒイ哭くばかりであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、一から十まで造り物の感じなのである。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は竹一にだけは、前から自分の傷み易い神経を平気で見せていましたし、こんどの自画像も安心して竹一に見せ、たいへんほめられ、さらに二枚三枚と、お化けの絵を画きつづけ、竹一からもう一つの、「お前は、偉い絵画きになる」　という予言を得たのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、単純そうな人たちは、自分の事を、やはりこの人たちと同じ様に単純で、そうして、楽天的なおどけ者の「同志」くらいに考えていたかも知れませんが、もし、そうだったら、自分は、この人たちを一から十まで、あざむいていたわけです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代に、あの馬鹿の竹一から、ワザ、ワザ、と言われて脊中を突かれ、地獄に蹴落された、その時の思い以上と言っても、決して過言では無い気持です。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて珍らしくもない話に大仰に驚いて見せたり、一から十まで嘘ばかりの社交を行ひ、天晴れ上流の客あしらひをしてゐるつもりのケチくさい小利口の大馬鹿野郎どもに、この竜宮の鷹揚なもてなし振りを見せてやりたい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてれふしどものいつたことを、一から十まで少しも言葉を飾らず、代官さまに伝へました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖以来茨城の結城郡に居を移した地方の豪族として、多数の小作人を使用する長塚君は、彼等の獣類に近き、恐るべく困憊を極めた生活状態を、一から十迄誠実に此「土」の中に収め尽したのである。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女自身手紙を出したり、電話をかけても、復一から実のある返事が得られそうな期待は薄くなった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人たちのする事は、一から十まで心理の駈引き、巧妙卑劣の詐欺なのだから、いやになる。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それは、一から十まで僕ひとりが悪かったのだから、たまらない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、姉さんも、兄さんの言う事を、一から十までは聞かない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「徒党」というものは、はたから見ると、所謂「友情」によってつながり、十｜把一からげ、と言っては悪いが、応援団の拍手のごとく、まことに小気味よく歩調だか口調だかそろっているようだが、じつは、最も憎悪しているものは、その同じ「徒党」の中に居る人間なのである。",
              "citation": {
                "source": "徒党について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "非難や嗤笑は、世の中の賢顏する詰らない男、ガスモク野郎、十把一からげ野郎の必ず所有してゐる玩具である。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たち一から七まで、目に従うて順に動くが可い。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うこと言うこと、一から十まで出鱈目だ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば、一から十までわたくしが悪かったのでございます。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはひとひらの芙蓉の花のやうでもあり、ながれゆく空の　雲のやうでもあり、わたしの身を　うしろからつきうごかすよわよわしい　しのびがたいちからのやうでもある。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
