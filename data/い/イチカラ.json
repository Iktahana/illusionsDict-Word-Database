  {
    "uuid": "f75d48be-1d14-5cd2-afd6-db5242b1f8e2",
    "entry": "一から",
    "reading": {
      "primary": "いちから",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
