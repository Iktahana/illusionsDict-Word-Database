        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大学でイタリア語の選択科目を取り、発音の難しさに苦労している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イタリア旅行のために、簡単なイタリア語のフレーズ集を毎日読んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "オペラを字幕なしで理解するために、イタリア語を勉強し直そうと思っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イタリア料理のレシピ本に載っていた、独特の食材名をイタリア語で確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "マリオ・モンティ元首相は、流暢なイタリア語で国民に語りかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "街角で迷っている観光客に、片言のイタリア語で道案内をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このワインはどこのものですか？」とイタリア語で尋ねると、店員さんが詳しく説明してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "片言のイタリア語でお神さんに「コレ、日本の地質学者。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときほど私はイタリア語というものを優美なものに思ったことはないような気がする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（タミール語 Kalisan. イタリア語 Calzoni）。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がペンク氏から借りて持って来た海図の巻物を、なんだと聞かれたから、いいかげんのイタリア語でカルタマリーナと答えたら、わかったらしかった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居られると割り込みになる旨、相手に説明しようとするも甲斐なく、なにぶん相手の英語以上にこちらのイタリア語がおぼつかないものであったから、やれやれと肩をすくめて、引き続きそわそわと友人を探して外を見るほかなかった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "発音に依りてイタリア語ならんと推測したれども、本人はイタリア語を解せざるゆゑ、何事を言ひしか分からざりきと云へり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア語の分からない、今一人のフランス人はイタリア語だらうと云ふ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "“La giostra”“Orfeo”などのイタリア語の詩の他に、ラテン語の詩、ギリシア語からラテン語への翻訳などの作がある。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "“Orfeo”は一四八三年に上演された劇的田園詩であって、イタリア語においては劇として上場された田園詩の最初のものであった。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア語には通じていない。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鱒二さん達が、日本橋のＧ――何とかといふ、何でもその名前はイタリア語か何かで、細君がブツブツ云ふといふほどの意味なさうだが――そこで待つてゐるさうだから、オペラはこれ位にして、駆けつけて見よう。",
              "citation": {
                "source": "出発",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、帰りにはオーストリア、スイス、イタリアと廻るつもりで、イタリア語の会話の本までも買った。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の巣鴨ではイタリア語をやった。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前中はアナーキズムとイタリア語との研究をやる。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア語は、文法を三十五ページばかり読んだ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア語も、後に差入れた文法の方が、よほどいいように思われたから、前のは止して、また始めからやり直している。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯川のイタリア語のハガキの意味はわからんと言ってくれ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これとイタリア語とは二カ月に各々一冊ぐらい読む予定だから、先日話したものを大至急送った上、さらに二月の面会の時にまた何か持って来てくれ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビュルタンの中に何かイタリア語の本が見つかったか。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリア語は本がなかったので碌に勉強もしなかったのだけれど、元来がフランス語とごく近い親類筋なので、一向骨も折れない。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はイタリア語ので二度も読んであきあきしたのだ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてあるときはイタリア語で暖いふくよかな風をそよがせ、またあるときはフランス語でエスプリと香気との風を吹かせよう。",
              "citation": {
                "source": "私の果樹園",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、博士の遺稿を見れば、イタリア語の原文によつたものではない。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、イタリア語に関して聞いたときにも、同じ意味の返事を受けたことがある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街で買物をするにはフランス語でも英語でも用事は足せるが、ギリシア語かイタリア語の方が便利のようだ。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス語やイタリア語を話せるし、風景画を描けるし、相当達者に歌も歌えるし、すばらしくダンスは上手だった。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェヴォンスの理論と私の理論とは、現われるとまもなくヒューウェル（Whewell）及びクールノーの古い試みと共にイタリア語に訳出された。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "各国の人種雑居せる実例は、当市発行の新聞（週刊、月刊をも含む）総計百八十九種のうち、スペイン語に属するもの百五十四種、イタリア語の分十四種、ドイツ語八種、英語六種、その他ロシア語、スウェーデン語、トルコ語等なりというを聞きて知るべし。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
