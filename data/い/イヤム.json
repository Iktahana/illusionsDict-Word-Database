    "definitions": [
      {
        "index": 1,
        "gloss": "to detest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その上にエネルギーの推移にまでも或る不連続性を否む事が出来なくなった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にまたこの芸術形式と自然形式とを比較するに、両者間にも否むべからざる一致が存している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "否むしろかくのごとき方則に従って力に反応する物を物質と名づけるのである。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "否むしろ、芥川龍之介と谷崎潤一郎とは、僕が小説について鑑賞し得る、唯一の二人だけの作家であつた。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否むしろ低級視さるべき、愚劣な馬鹿馬鹿しいものである。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否むしろ、教育によつて訓練してしまつた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生君と同じく君も亦生れた詩人の一人である事は誰も否むわけにはゆくまい。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護員は現在おのが身のいかに危険なる断崖の端に臨みつつあるかを、心着かざるもののごとく、無心――否むしろ無邪気――の体にて、「すべてこれが事実であるのです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの功績はどう考えても否む事はできないと思う。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯様にして権力の濫用を恣にする政治家は、事の真偽、理の当否を調査することなしに、只一概に大掴に、否むしろ虚を実と誣ひ、直と曲を邪み、何でもかでも思想の向上、流布を妨止するのであるとも思はざるを得なかつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "否むしろそれが無ければ、詩集としてのしめ括りがなく、大尾の完成が缺けるやうなものであつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否むしろ自由詩はかかる形式主義に反対し、リズムを破壊することに主張を持っている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否むしろ、叙事詩の真の魅惑は、その悲痛感によって尽きるのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（前略）あなたが、あなたの母子情を仲介にして若い男に近づいていることが無意識にもせよ、あなたの母子情を利用しているようで堪えられないと仰有れば、僕とても、僕に潜在していた不満な恋愛感を、あなたに接触することで満足させようとしたと云われても――否むしろ僕自身そう僕を観察さえするようになりました。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして天運も實に有り、人力も實に有ることを否む譯には行かぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人もこの眞實を否むことが出來ない。",
              "citation": {
                "source": "歌集「嘲笑」序文",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護員は現在おのが身の如何に危険なる断崖の端に臨みつつあるかを、心着かざるものの如く、無心――否むしろ無邪気――の体にて、「すべてこれが事実であるのです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青き酒青き酒、――など、汝は否む。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は文学といふ女神は、寧ろ老嬢として終るも、俗界の神なる「事業」に嫁することを否むべしと言ひたり。",
              "citation": {
                "source": "賤事業弁",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "何物とは知らず吾人の中に、斯くするを否むものあるに似たり。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼神なりとて否むべきか。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "心は進まねど強ひて否むべくもあらねば、宮は行きて指定の位置に立てるを、唯継は望み見て、「さう棒立ちになつてをつちや可かんぢやないか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰がこの否む可らざる目前の事実に驚異せずにはいられよう。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそこでは否むべからざる宿命の感じにおびえねばならぬ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁厭をまじないやむると訓んでいるのは古いことだ。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ些細なことだからむつかしいかもしれない。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くどいようだが、この百円はあんたに進呈する」「あらッ、だめよ」　と、弓子もすかさず、「くどいようだが、この百円はお返しします」　そして、おたがい顔を見合って笑いだしたが、鶴雄は笑いやむと、「悲願っておっしゃったでしょう。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ自作の影像が歪められているのを見るに堪え難い気持すら味っていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはは……」　笑いやむと、佐助は武者ぶるいしながら峠道を登って行った。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼ら一人一人に「許す」という一言を、身を割くように思いながら与えたのは、勢いやむことを得なかったのである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
