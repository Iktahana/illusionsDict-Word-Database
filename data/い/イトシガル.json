        "examples": {
          "standard": [
            {
              "text": "祖父は庭で育てている盆栽を、まるで我が子のように愛しがっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は拾ってきた猫をそれはもう愛しがって、毎日甲斐甲斐しく世話を焼いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は妹をとても愛しがっており、何でも言うことを聞いてしまうらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ほうほう、いほの毛布をいとしがること！",
              "citation": {
                "source": "格子縞の毛布",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで可愛がりいとしがるという。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼られれば頼られるほど、奥様をいとしがるのが男の人情です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
