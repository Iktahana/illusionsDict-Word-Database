    "definitions": [
      {
        "index": 1,
        "gloss": "primary evacuation shelter (for initial use in emergencies)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
