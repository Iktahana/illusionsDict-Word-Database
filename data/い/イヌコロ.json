        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わあ、見て！あそこに可愛い犬コロがいるよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子犬が庭で元気いっぱいに走り回る様子は、まさに小さな犬コロだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "道端で母犬に寄り添う犬コロたちが、道行く人の目を引いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人間の影一つ、犬コロ一匹通っていない真の寂莫無人の厳粛な地獄絵図としか見えなかった。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十銭に負けとき給え、ドウセ無料で拾って来たんだろう」　そんな奴には、よく犬コロをタタキ附けてやったもんだ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、いつも新聞社からの帰りがけに、散歩をしている通りの足取であったが、あんまり寒いせいか、途中には犬コロ一匹居なかった。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "出てからまた、犬コロのように買食いして歩いた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のひがみだが、自分の姿が犬コロに見えた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし少しでも動いたら、犬コロのように打ち殺すぞ」　サトーリスがパタッと止まった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄れば触れば、「あの三寸男が」だの「ちんちくりんのボロ布れが」のと、武大の家には町中の目が見通す節穴でもあるような騒ぎだし、あげくには、「いやはや、惜しい美肉が、犬コロの口へ落ちたもんさ」　と、囃されたりした。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんないい道があるのだから深山でもあるまいに」「ひょっとしたら、梁山泊の襲来ときいて、人間から豚や犬コロまで、さっと逃げ散ッてしまったものか」「そんなら部落の跡があるはずだろうに」「それもそうか……。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぬころ草のさかりがすぎてつゆ草の季節となつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぬころ草を活けて、これもをはりのよさを味ふ。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぬころぐさを活ける、去年をすぐおもひだす、おどり子草も咲いてゐる、すぐまた一昨年のことをおもひだす。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑草を活ける、甘草はよろしいな、いぬころ草は可愛いな。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに　こびとたちに　よれば、　そのおおきな　いきものに　けちらされたところは　ここから　ほんのすぐそば、　ぶさいくな　いぬころの　あんないで　まっすぐ　このサンタの　ひみつきちに　むかっているとのこと。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
