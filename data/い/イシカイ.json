        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "政府は、地域医療の維持に向けた医師会との連携強化を表明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新型感染症の対策として、医師会が市民への情報提供を積極的に行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の父親は長年、地元の医師会の役員を務めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師会は医療事故の再発防止策について、専門家委員会を設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この問題は、まず医師会で議論すべきだろう」と、彼は会議で述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "禁煙推進キャンペーンのため、医師会が広報活動を展開している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来年度の医療報酬改定について、医師会から厚生労働省へ意見書が提出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どうも話がおかしいというので、駐在所の旦那が色々と取調べたあげく、一週間ばかりしてから郡の医師会長の学士さんに来てもらって、件の白骨を見てもらうと、犬の骨に間違いない……という鑑定だったので又も大評判になった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにその救護班の主任が、その村の村医で、郡医師会の中でも一番古参の人格者と呼ばれている、松浦先生に当ったというので、村中の評判は大したものであった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧藩以来福岡市内｜薬院に居住し、医業を以て聞こえている前医師会理事故権藤寿三郎氏（現病院長健児氏令兄）は梅津只圓翁の係医として翁の臨終まで診察した人であるが、嘗て筆者にかく語った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又前医師会理事権藤寿三郎氏が言葉を飾る人でなかった事は周知の事実である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月のある朝、朝食後に腰を下ろして大英医師会報を読んでいると、呼び鈴の音が聞こえ、そのあと我が懐かしき友のあの高くどこか軋むような声が続いたのだ。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲人役の郡医師会長、栗野医学博士夫妻は、流石にスッキリしたフロックコートに丸髷紋服で、西日の一パイに当った縁側の障子の前に坐っていた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスとかペニスとかいうものは学校でも一番のチャンポンとかチンポンとかいう位じゃげな」　仲人の郡医師会長夫妻と、頓野老夫婦と、新郎新婦が、腹を抱えて笑い出した。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の医師会長のお世話で、隣村の頓野先生のお嬢さん……しかも女学校をば一番で卒業さっしゃったサイエンス……ええ……何が可笑しいか。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ……これ位｜芽出度い事は無いなあ医師会長さん。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲人の医師会長栗野博士が、その障子の隙間に胡麻塩頭を寄せて、少女の囁声を聞くと二三度軽くうなずいて立上った。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　八十四歳を売物にしてゐる卜新氏は、とうと医師会に一｜札を入れた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り込むと直ぐ、地方検事総長スワアート氏に会って、郡医師会の役員をしている同市の開業医Ｈ・ストックマン博士への紹介状を得た。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは維也納のある博士が、ある医師会の席場に試みた、終焉に関しての講演の筆記であった。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの当主はもう七十近い老人だが、まだ郡制のあつた先年まで郡の医師会長だつた人で、この地方での一二と云はれる有力者でもあつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つい半月ほど前、房一には初めてだつたが、郡の医師会が隣町であつたので、練吉と二人づれで出席した。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃向島にも医師会が出来て、おりおり寄合があり、扱った珍しい患者とか、その変った容態などを代る代る話合うことになりましたが、父はそれを非常に苦にして、「実に困ってしまう。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "県や市の衛生課、医師会、警察、みんなかねての計画どおり手際よく救護陣を敷いた。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　次にあげるコレラ伝染の諸例はベイリ博士（William Baly：1814-1861）著「コレラ流行についての王立医師会への報告」の多くの例から引用したものである。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベイリー博士は「コレラについての医師会への報告」において私の考えを詳細で公平に書いてくださっているが、炭坑で働いていない女性および子供たちが男性坑夫と同じように多く罹病していることについて私が言っていることに反対している。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和30年９月には、白老町名誉町民に選ばれ、同32年６月には北海道医師会から表彰をうけている。",
              "citation": {
                "source": "生きているコタンの銅像",
                "author": "――アイヌの慈父・高橋房次――",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学の方は、医師会の強力な統制が効いているためで、これはまた別の問題である。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらが××病院副院長Ｂ博士、こちらが××県医師会評議員、眼科のＣ先生です。",
              "citation": {
                "source": "美談附近",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで新聞に出す手は絶対にないな、医師会の半分が動き出すまでは……」と、Ｃ先生は応じた。",
              "citation": {
                "source": "美談附近",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "リナクルはアルドゥス社（ヴェネツィア）のためにギリシャの著書を編集し、ガレノスの著書を翻訳し、オクスフォード大学でギリシア語を教え、ラテン語文法を書き、英国医師会を創設した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような標品の幾つかはハーヴィがパドヴァから持って帰りロンドン医師会に存在している。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンで彼は医師会に属しケンブリッジで学位を取り診療を開始した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "1607年に医師会の評議員になり1609年に聖バーソロミュー病院の医師になった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "1615年に医師会のラムリ講師になり、任務はいわゆる『公開解剖」すなわち講義をすることであった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原稿は大英博物館にありファクシミリが医師会によって1886年に刊行された(26)。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は全国民のための健康保険制度をアメリカに導入することが医学史家としての任務と考えアメリカに来た直後から熱心に健康保険設立の運動を行い医師会や大学同窓会などから強い反対を受けるようになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
