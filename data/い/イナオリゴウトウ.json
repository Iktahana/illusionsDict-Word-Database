    "definitions": [
      {
        "index": 1,
        "gloss": "burglary turned robbery (i.e. when the burglar is detected)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "空き巣に入った犯人が、住人と鉢合わせして居直り強盗になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "深夜、突然の物音に目を覚ますと、そこには居直り強盗が立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は、近隣で発生した居直り強盗事件の捜査を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして私は信じるよりも、えゝ、どうせバカのついでだ、という居直り強盗の心境になった。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "照らしだされた板の間の、ねずみおとしの中に動くもの──なんだか居直り強盗にでも向かうような気がした。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "小判買いで儲かったあいだはだまってこの条約をおしつけておいて、もう小判が日本中にはなくなってしまった――あるにしても三井や鴻ノ池や大大名の金蔵の奥ふかく死蔵されてしまった今日となって、銀貨の品質に文句をつけて「贋貨」というのは居直り強盗というものである。",
              "citation": {
                "source": "明治の五十銭銀貨",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "居直り強盗というのはあるが、これは、居なおり婿のとりまきである。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはＫがその刹那に居直り強盗のごとく感ぜられたのです。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒するのも金儲けの一方法ではあろうが、始めはこそ泥だったのが、泥棒になり、居直り強盗になり、遂には庖丁を突きつけて強姦するに至るというのでは世も終りだ。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは感づかれたと思いましたから、私、急に居直り強盗になって、ホヽヽヽと笑って上げましたの」「豪いのね。",
              "citation": {
                "source": "髪の毛",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居直り強盗は好かったわ。",
              "citation": {
                "source": "髪の毛",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然う敏感じゃ勤まらない』と大将、まるで居直り強盗さ。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐに居直る」「居直り強盗か？",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やい間男」「なんだ、武大」　西門慶の長い体が、ぬうっと、寝台の下から出て来るやいな、まるで居直り強盗のような科白で、儒子の武大を睨めおろした。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
