    "definitions": [
      {
        "index": 1,
        "gloss": "transformation of the population of Japan into idiots (because of television)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
