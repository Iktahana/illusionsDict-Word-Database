    "definitions": [
      {
        "index": 1,
        "gloss": "spring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山奥の木立を抜けると、岩肌から清らかな水が湧き出す泉があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "砂漠を長く歩き続けた旅人にとって、オアシスに湧く泉はまさに命綱であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は豊富な知識を有しており、周囲からは「知恵の泉」と呼ばれて頼りにされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "子供たちの好奇心は尽きることのない泉のようであり、毎日新しい疑問を投げかけてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "素晴らしい芸術作品の数々を前にして、創作意欲が心の奥底から泉のように湧き上がってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小泉八雲　小サイ可愛イママサマ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼津　八月十八日小泉八雲　この情緒纏綿たる手紙は、新婚当時の手紙ではない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "オババサマとは彼の妻の母であって、名義上、小泉家の養子たる彼にとっては、姑の義母に当る老婦人である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私この小泉八雲、日本人よりも本当の日本を愛するのです』と言ったヘルンは、真に日本を熱愛した詩人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたヘルンの小泉八雲が、常に最も好んだ散歩区域は、寺院の閑静な境内だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "14　この會見の後、私は直ちに伊豆の温泉へ旅行した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに今日私は過去五年間の暗中模索、傷ましき躁宴の後に、聊か芸術の泉なるものが依て以て存する所以に想ひ到つた。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　要するに芸術の泉とは徒然草に、心の鏡が澄んでゐれば全ての物が正しく映る云々の裡にあるのであつて、東洋人は自然に対しては非常に心澄ませたが、人に対しては未だ澄むことなく、卑下しすぎたり頑なだつたりしてゐる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄泉の郷では彼女たちはもつと仕合せだ！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "故小泉八雲のラフカヂオ・ハーン氏は、日本人と日本の文化に対する唯一の最上の理解者であつたけれども、氏の鑑賞を以てしても、その愛読された俳句の程度は、上掲した加賀千代の人情的月並俳句に止まつてゐた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し簡単に言へば、常識的の批判からみて好い温泉である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから特別の新らしい趣味で、赤城や軽井沢のやうな高原的風望を好いといふ人や、反対に少し古い趣味で塩原のやうなアカデミツクの景色――山あり、谷あり、滝あり、紅葉ありといつたやうな景色――を悦ぶやうな人や、その他特別の意味での情趣をたづねるやうな人には、伊香保はあまり好かれない温泉である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、女性的とはいへ、山の温泉であるから、樹木が多く、雲や霧がふだんに立ちこめて、山巒といふ感じは充分にある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯や駒鳥はいつも鳴いてゐるし、樹陰の深い緑は所々にあるし、それだけで山間の別天地をなした鮮新な温泉町としてゐる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言つたやうな特別の注文さへなければ、だれも閑雅な好い感じをもつことができる温泉である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は可成所々――所々といつても東京附近だが――の温泉を歩いたが、未だこれといふやうな温泉には一つも行きあたらない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中、信州の渋とか湯田中といふやうな百姓めいた温泉、言はば「田舎者の湯治場」といつた感じのする所は何より嫌ひだ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした所は、単に温泉町そのものの気分が田舎めいて陰気くさいばかりでなく、周囲の自然そのものからして、妙に百姓じみて感じが重苦しい。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も野州の那須のやうに、温泉場としては、代表的な「田舎者の湯治場」でありながら、自然としては極めて明快な高原的眺望をもつた所もある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの新日本的の那須野と対照して、那須温泉そのものの薄暗い感じを思ふのは不快である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故といつて、あの温泉は、田舎の百姓が湯の隅で念仏を称へたり、不潔な女をひやかしたりするやうな、全然田舎風の空気をもつた浴場であつて、周囲の新鮮な自然と全く不調和であるからである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、田舎風の温泉でなくとも、塩原のやうな所はまた嫌ひである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあすこの福和戸のやうながらんどうの温泉、普通の駅路の両側に家が並んだやうな温泉は、どこか埃くさい気がするのと、まとまりのない不安な気がするので、とても落付いた気分になれない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉はやはり山の峡谷のやうな所に、そこだけで一廓をなしてゐなければいけない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他まだ嫌ひな温泉の種類をあげればたくさんある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆の伊東のやうな、海岸の温泉も嫌ひのものの一つである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて海岸の温泉には、温泉らしい情趣がすくない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいしくば、たずね来て見よいずみなる、しのだの森のうらみくずの葉。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことばは、よどみがちでしたが、やさしい心のいずみは、かえって、いきおいよく流れ出しました。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうち　たどりついたのが、　おかの　なかほど　わきだす　いずみ。",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
