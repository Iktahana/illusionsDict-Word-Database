    },
    "definitions": [
      {
        "index": 1,
        "gloss": "with a single blow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「橫綱は鋭い立ち合いの一瞬で、挑戦者を一撃のもとに土俵の外へと追いやった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「たった一つのスキャンダルが、彼が長年築き上げてきた名声を一撃のもとに葬り去った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼女は動かぬ証拠を提示し、相手の苦しい言い逃れを一撃のもとに封じ込めた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「熟練の猟師は深く息を吐き出し、遠くの獲物を一撃のもとに仕留めた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最新鋭のミサイルが放たれ、敵の司令部は一撃のもとに粉砕された。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「王者の放った完璧なカウンターが、挑戦者を一撃のもとにマットへと沈めた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一撃のもとに倒すといふやうな颯爽たる仇討ちではない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして富岡先生は常に猛烈に常に富岡氏を圧服するに慣れている、その結果として富岡氏が希望し承認し或は飛びつきたい程に望んでいることでも、あの執拗れた焦熬している富岡先生の御機嫌に少しでも触ろうものなら直ぐ一撃のもとに破壊されて了う。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "高潔｜沈毅な鼻の表現に万軍の信頼を集めつつ、天地を震撼する大魔王の鼻を一撃のもとに打ち砕いた英雄がありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――で一撃のもとに笑殺されて、つまり彼の言葉の反応どほり戯談の儘とほつたのだから好さゝうな筈なのに、何時までたつても照子の云つた結婚云々といふ言葉にこだわつてゐた彼だつた。",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うーむ、こいつが……」　杉田二等水兵は、怒心頭に発し、顔を朱盆のように赤くして、中国人ボーイを一撃のもとに――と思ったが、そのとき彼の後で、「わっはっはっはっ」　と、破鐘のように笑う者があった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には、空軍の精鋭が、かたい編隊をくんで、もし空から近よる敵機あらば、何国のものたるをとわず、一撃のもとに撃ちおとしてくれようと、ごうごうと飛びつづけている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ときには、恐ろしく手の早い奴がいて、隙だと見たら何の躊躇もなく一撃のもとに飛びかかる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "不運にも私の背後から駈け出して来た運転手が一撃のもとに仆された。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、彼は蟇に戯れかかっている一疋の牝鹿を見とめると、一撃のもとにその首を斬り落して咒禁師の方を振り向いた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命はある真昼の午後、この平々凡々たる家庭生活の単調を一撃のもとにうち砕いた。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "狒や大蛇も一撃のもとにあへない最期を遂げる外はない。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ号は博士を一撃のもとにたたき殺そうとして拳をふりあげた。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも一撃のもとに、頭を叩き割られてしまうだろうか。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その贅沢心を、或る日白木豹二が、一撃のもとに打ち壊してしまった。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、そんなことをすれば、首領は一撃のもとに自分を毒針でさし殺したかもしれない。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岸中尉は、うしろに弟をかばい、右手にはピストルを握りしめ、もしも近づく奴があれば、一撃のもとにうちたおすぞと、緑鬼をにらんだすさまじさ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも万一、その夫が真の万吉郎でない証拠を発見したときは、彼女は直ちに躍りかかって、その偽の万吉郎の脳天を一撃のもとに打ち砕く決心だった。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を殺したその場に於ては血に狂って、毒を食わば皿までと、無抵抗な幼児などまで一撃のもとに殺すような例は多々あるようだが、いったん興奮がおさまれば、オレは死刑になる身だからという理論を立ててむやみやたらに人を殺すことがそう簡単にできるものではなかろう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それから滝沢が、安彦をだきとめなければ、今度は公一が一撃のもとに殴り倒される段であったに相違ない。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトリエや研究室のハゲ頭どもは、一撃のもとに脳天をやられ、毛脛をやられ、みんな、おそれ入りましたと言った。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "兇器は重き鈍器にして、被害者の不意を見すまし、激しき勢を以て一撃のもとに行われしものと思惟さる。",
              "citation": {
                "source": "旅客機事件",
                "author": "大庭武年",
                "note": "青空文庫"
              }
            },
            {
              "text": "孰れにせよ、兇行は邪魔者がいなくなってから、油断をみすまして一撃のもとに行われたものである事は明瞭である。",
              "citation": {
                "source": "旅客機事件",
                "author": "大庭武年",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく一撃のもとにノビたんで、かえって良かったんだそうだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校のまわりにいた五人ばかりの水兵が一撃のもとに殺されたが、兵隊のほうもつぎつぎに射たれたり斬られたりして筏の上に倒れ伏した。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ちょうど一撃のもとに全員が蝋人形になってしまったかのようである。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの足もとの白い砂地には、一撃のもとに叩き落されてやつと這へるくらゐの赤蜂が、傷手に苦しみながらうじやうじやしてゐた。",
              "citation": {
                "source": "めたん子傳",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人がむちゅうになって褒めた女の人を私は見たことがない、何だ彼だと細かい事には触れないで、一撃のもとに彼は手きびしく難癖をつけた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "袴野すらも手に負えない貝ノ馬介を、一撃のもとにやった事が袴野の驚異以上のものだ、こういう驚異の元になるものを持つすてに、彼はにわかに警戒さえも感じた。",
              "citation": {
                "source": "舌を噛み切った女",
                "author": "またはすて姫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
