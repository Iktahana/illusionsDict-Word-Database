        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "契約書には、一方的な違変があった場合の罰則規定が明記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は約束を違変した友人に対して、失望の色を隠せなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "再三の督促にもかかわらず、支払い期日の違変が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "今回の計画変更は、当初の合意内容からの重大な違変とみなされる可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "よもや違変はあるまじと、母様もそれよりは、人の噂を深くはお心にかけたまはず。",
              "citation": {
                "source": "葛のうら葉",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンはそれがたいへん気に入り、『面白いの音』といいながら、頬をふくらして、ボオボオと吹き鳴らしては、また『いかに面白い』といって吹き続けた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉より他になかったとしたなら、この全体主義哲学は、その認識論に於いて、たいへん苦労をしなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたび私の「惜別」が橋になって、あなたから長いお手紙をいただきましたが、私は、たいへんうれしかった。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、妹さえ丈夫でございましたならば、私も、少し気楽だったのですけれども、妹は、私に似ないで、たいへん美しく、髪も長く、とてもよくできる、可愛い子でございましたが、からだが弱く、その城下まちへ赴任して、二年目の春、私二十、妹十八で、妹は、死にました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なくらいに顕著なおでこと、鉄縁の小さな眼鏡とたいへんなちぢれ毛と、尖った顎と、無精鬚。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の晩秋、ヨオゼフ・シゲティというブダペスト生れのヴァイオリンの名手が日本へやって来て、日比谷の公会堂で三度ほど演奏会をひらいたが、三度が三度ともたいへんな不人気であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、あんまり馬場を信じ過ぎると、あとでたいへんなことになりますよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば、たいへんな仲間ばかり集って来たものさ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は私も、たいへん画が好きで、画家の友人もたくさんあって、その画家たちの作品を、片端からけなして得意顔をしていた事もあったのですが、昨年の秋に、ひとりでこっそり画をかいてみて、その下手さにわれながら呆れてそれ以来は、画の話は一言もしない事にきめました。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのときは、たいへんな騷ぎであつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寫眞で見る、あの菊池幽芳氏と、たいへんよく似てゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の人もまた、マリヤ様、エス様が、たいへんありがたいおかたであるという事は、教会の雰囲気に依って知らされ、小さい時からお祈りをする習慣だけは得ていながらも、かならずしも聖書にあらわれたキリストの悲願を知ってはいないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教の問題に限らず、このごろの日本人は、だんだん意気込んで来て、外国人の思想を、たいした事はないようだと、ひそひそ囁き交すようになったのは、たいへん進歩である。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへん難渋の文章で、私は、おしまいまで読めなかった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣島の王はそれを、たいへん珍らしがつて保存して置いたことであらう。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝いただいて居る東奧日報に據れば、私の兄は、いま、縣會に於いてたいへん割のわるい役をして居るやうである、私、いま、兄上に叱咤されるのを覺悟のうへで申してゐるのであるが、勘平役者が黒衣にまはつたやうで氣持がよくない。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれまで、私の性格、體質などに就いて、ずゐぶん誇張されて言ひ傳へられ、たしかに私にも不用意な點があつて、明かにそれは私のいたらぬところであつたけれど、あらぬ傳説が一部の人たちに信じ込まれてゐた樣子で、たいへん評判がわるかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正二年といへば、私など、四、五歳のころで、そのころ此の本の出版が、どんな反響を呼んだか、知る由もないが、けれども、序文を見ると、たいへんな意氣込である。",
