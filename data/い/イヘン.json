[
  {
    "uuid": "2e6e341b-9833-53fb-8dde-56e40b8580fd",
    "entry": "異変",
    "reading": {
      "primary": "いへん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
