          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あんな猛吹雪の中を軽装備で登るなんて、全くいかれた命知らずの連中だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新入りの刑事は、ベテランも尻込みするような危険な潜入捜査を自ら買って出る命知らずだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「命知らずな真似はやめろ！」と隊長に怒鳴られたが、彼は燃え盛る炎の中に飛び込んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "科学もやはり頭の悪い命知らずの死骸の山の上に築かれた殿堂であり、血の川のほとりに咲いた花園である。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と車夫の吉造、婦人を一人輪の下に轢かんとせし、ようよう車を踏留め、胆を潰せしむかばらたち、燐寸にあたりて二三本折っぺしょり、ますます苛ち、「命知らずの馬鹿者め、何だって往来に坐ってるんだ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒磯は片手で和尚の肩を鷲づかみにして、この命知らずめが、とせせら笑い、和尚は肩の骨がいまにも砕けはせぬかと気が気でなく、「よせ、よせ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば敵の毛羽艶やかに峨冠紅に聳えたる鶏の如く、此方は見苦しき羽抜鳥の肩そぼろに胸｜露はに貧しげなるが如くであつたが、戦つて見ると羽ふくよかなる地鶏は生命知らずの軍鶏の敵では無かつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀相でね、お金子を遣って旅籠屋を世話するとね、逗留をして帰らないから、旦那は不断女にかけると狂人のような嫉妬やきだし、相場師と云うのが博徒でね、命知らずの破落戸の子分は多し、知れると面倒だから、次の宿まで、おいでなさいって因果を含めて、……その時｜止せば可かったのに、湯に入ったのが悪かった。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命知らずが、誰にも解りこないから、歌を一つ一つ、異変、畜類な声を張り、高らかに唱って、続くは横笛、ひゃらひゅで、緞子袴の膝を敲くと、一座を※し、ほほほ、と笑って、おほん、と反るんだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨でも越さずばなるまい」「まア、命知らずな。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六人もの生命知らずの壮漢を向うに廻しながら、鬚だらけの横頬で微笑しているらしかった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘヘヘ……」「……………………」　スッカリ気を呑まれたらしく生命知らずの連中が六人とも顔を見交して眼を白黒さした。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ何となしに気が合うて、死生を共にしようというだけでそこに生命知らずの連中が、黙って集まり合うたというだけで、そこに燃え熾っている火のような精神は文句にも云えず、筆にも書けない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が、海洋を行くや、疾風の如く、遠く安南、シャム、ルソン、マラッカ、フィリッピンにまで押し渡り、貿易が許されない場合は、忽ち両肌を脱ぎ、長刀を振つて命知らずの奮闘をした。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "などゝいふことを口にしてゐた愚か者のことだから、浮きたてば、何んな命知らずの井戸へでも飛び込み兼ねないのである。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生達に仕合を申し込むなんていふ命知らずはヤグラ沢の猪か狼でせうよ。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミツキイが日本語が喋舌れなかつたことも具合が好かつたし、精悍な風姿を持つてゐたので、例へば僕が、「こいつはね、横浜の不良少年でピストルのジヨンニーといふ命知らずなんだよ。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父からも命知らずめと叱られた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一味は兇暴、命知らず。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやなう、若、命知らずの者に手出しをなさるな。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "やい、命知らずの舵手よ、苦しい海に病み疲れた此小船を、速う巖礁角へ乘上げてくれ！",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて警察でも目をつけていたんだが、命知らずの連中の寄り合い場所だから、かの蜂の巣をつついて怪我をするようなことになってもよくないからと、いわば見て見ぬふりをしていたんだ。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし探偵という仕事は、命知らずの犯罪者相手のことですから、腕ずくでは俊夫君もかないません。",
              "citation": {
                "source": "紅色ダイヤ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学者などと云う者は縦しや如何ほど悪党でも、腕力で以て直接に人と格闘して取り挫ぐなど云う了簡はないもので、一身の危い様な場合には兎角に逡巡する者だよ、殊に此の様な室へ余が独りで忍び込んで居る所を見ては、何の様な命知らずだろうと奥底を計り兼ね、余が彼を恐れるよりも彼一層余を恐れたと見える。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして彼等はこの目的の下に、生命知らずの無頼漢をすぐり集めて、曲馬団を組織して捲土重来したものに違いないのである。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命知らずの兇状持ばかりを拾い込んでいる機関部へ来て、これだけの文句を並べ得る水夫は兼の外には居ない。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大作って奴は――いいや大作が、命知らずなのよりも、のめのめ捨てておくお上の気が知れぬ。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからか命知らずの硬骨漢があらわれて躍りこむかも知れなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗りこんだ生命知らずの土人は六十人。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、見よ、いよいよはじまった勇ましい生命知らずの日本海軍の戦法を！",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもばかりで、マンホールから、このおそろしいうちへしのびこむなんて、いのちしらずだよ。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――金陵は建康府の産で、あだ名を※命（いのちしらず）三郎とよばれています」「石秀さんか。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
