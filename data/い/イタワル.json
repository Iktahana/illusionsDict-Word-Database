[
  {
    "uuid": "60e81287-cd3a-5227-bc91-9b3a26ce3ded",
    "entry": "労る",
    "reading": {
      "primary": "いたわる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
