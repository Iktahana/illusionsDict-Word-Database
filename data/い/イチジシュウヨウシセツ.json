        "examples": {
          "standard": [
            {
              "text": "台風による避難指示が発令され、多くの住民が近くの小学校に設けられた一時収容施設に身を寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "入国管理局は、不法滞在者を一時収容施設に移送する手続きを進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "紛争地域から逃れてきた難民たちは、各国政府が用意した一時収容施設で共同生活を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事件の容疑者は、警察署の一時収容施設に留置され、事情聴取を受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "感染症の拡大を防ぐため、新たに発見された感染者は、指定された一時収容施設での隔離措置が取られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "港に到着した難民船の乗客は、まず健康診断を受けるための一時収容施設へと案内された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "災害対策本部では、被災者の受け入れ態勢を整えるため、複数の仮設住宅と一時収容施設を準備している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
