    "definitions": [
      {
        "index": 1,
        "gloss": "person who is overly conscious about appearing interesting (esp. online)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
