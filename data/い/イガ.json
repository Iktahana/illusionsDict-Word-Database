[
  {
    "uuid": "ba0fb8dd-71b7-5b8d-8e3c-c33b9e09c6e6",
    "entry": "衣蛾",
    "reading": {
      "primary": "いが",
      "alternatives": [
        "イガ"
      ],
      "is_heteronym": false
    },
    "grammar": {
