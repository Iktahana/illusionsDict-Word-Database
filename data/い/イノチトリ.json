        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この猛暑の中での水分補給の怠りは、高齢者にとって命取りになりかねない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プロのレーサーの世界では、わずかコンマ数秒の判断ミスが命取りとなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スキャンダルを強引に隠蔽しようとしたことが、結果的に彼の政治生命の命取りとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "命取りの強敵はもう深く体内に侵入しているがそんなことは熊にはわからない。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には、禍いのかたまりが十個あって、その中の一個でも、隣人が脊負ったら、その一個だけでも充分に隣人の生命取りになるのではあるまいかと、思った事さえありました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局これが幕府の命取りになつたのだが、三代の家光の鎖国以来百五十年の間に、世界の形勢は一変してゐた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかし、こんどの病気は命取りになるかも知れない。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "命取りなどというおそろしい言葉は、忘れようと思った。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪戯としては、命取りの悪戯であった。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、あの野郎の鉄砲とくると、がらはちまちまっとしていてちっせえが、わっちたち仲間でもおじ毛立つくれえな命取りでごんしてな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜はわざと飲み過した、焼酎一杯が特にこたへた、そしてぐつすり寝ることが出来た、私のやうな旅人に睡眠不足は命取りだ、アルコールはカルモチンよりも利く。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝまで来て、富岡と離れる位なら、東京に残つてゐた方がよかつたのだと、ゆき子は、今度の発病が、何となく、命取りの病気のやうな胸苦しさである。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、その右の膝小僧の上に大きな肉腫が出来たからで、私が母校のＷ大学のトラックで、ハイハードルの練習中にこしらえた小さな疵が、現在の医学では説明不可能な……しかも癌以上に恐ろしい生命取りだと云われている、肉腫の病原を誘い入れたものらしいという院長の説明であった。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後どのような優れた写真家が出てこの御像の真を撮影し得るようになるかは測り知れないが、恐らくその撮影はその写真家の命取りとなるであろうと想像される。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くあれは生命取りの瘤だっぺよ。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち命取りの胃がんは腹の中で刻々大きくなりつつあったのである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄貴、やっぱりこれが命取りだな」「うむ、刃物は大した切れ味だ」　こんもりと盛り上がった乳房の下を、一と刺し、キッサキが心臓に達したと見えて、衣類は朱に染まっているが、大して苦しんだ様子もないままに息は絶えていた。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お浦、そちのその重傷では、生命取り止むること覚束ないかもしれぬ。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「愚老が命取りますこと、殿には断じてなりますまい！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにほんとに太郎丸という奴、まるで命取りの腫物のような奴だ！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "労症労咳、繰り返していうようじゃが、命取りじゃ。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、髷を解いて見ろ」「女は元鍼の名人の圍はれ者だと言つたが、人の身體の鍼壺は六百五十七穴、そのうち命取りの禁斷の鍼が一ヶ所あるといふことだ」「あツ、ありましたよ親分」　八五郎は踊り上がりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "桐の極印",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三尺くらゐの竹筒に、疊針ほどの磨き竹に、先端を筒形に卷いた紙の羽根を附けたのを入れて、人間の息で五間も十間も先へ飛ばす吹矢は、徳川時代には鐵砲や弓矢に次ぐ恐ろしい飛道具で、もと／＼小鳥を捕つたり、的を射て遊んだりする道具であつたにしても、場合によつては、隨分命取りの危險な武器にもなつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "邪戀の償ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その養子の兵三郎が、七日の間に命を奪られるといふ騷ぎだ、本人は思ひの外落着いてゐるが、親の彦太郎の方が大變ですぜ」「誰がそんなに命取りの日限まで觸れて歩いたんだ」　ガラツ八の八五郎の、逆上せあがつた報告を輕く受けて、錢形平次は斯う問ひ返しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "秤座政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが命取りの種になろうとは思ってもみなかったでしょう」「…………」「銭形の親分さん、この敵を討って下さい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その養子の兵太郎が、七日の間に命を奪られるという騒ぎだ、本人は思いのほか落着いているが、親の彦太郎の方が大変ですぜ」「誰がそんなに命取りの日限まで触れて歩いたんだ」　ガラッ八の八五郎の、逆上せあがった報告を軽く受けて、銭形平次はこう問い返しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "秤座政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭に受けた傷が命取りだつたに相違ありませんが、その他、肩に打撲が一ヶ所、これは背中へかけて大きく青痣になつて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "路地の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "その約束は、惡戲の程度に止まり、もとより丹波樣の隱居の命までも取る意志はなかつたにしても、浪人北山習之進は腹からの、惡黨で、お國を奪られた怨みを忘れ難く、この計畫を命取り仕事にまで押しあげたのは詮方もないことでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "正月の香り",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが命取りの種にならうとは思つても見なかつたでせう」「――」「錢形の親分さん、この敵を討つて下さい。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "巨盜還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭に受けた傷が命取りだったに相違ありませんが、その他、肩に打撲が一ヶ所、これは背中へかけて大きく青痣になっております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "路地の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本風の剃刀は、峰が高くなつて居るので、振り廻したところで薄傷を負はせるだけ、命取りの兇器にはなりませんが、背と背を合せて縛つた二梃剃刀は、使ひやうに依つては、匕首のやうに鋭利な兇器になるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花嫁の幻想",
                "note": "青空文庫"
              }
            },
            {
              "text": "この騒音が命取りとなった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "この接触が命取りとなる。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
