        "examples": {
          "standard": [
            {
              "text": "地域住民は、迫りくる台風に一丸となって立ち向かう決意を固めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経営危機に瀕した企業は、全社員が一丸となって再建計画に取り組んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "監督は選手たちに「最後まで一丸となって戦うぞ！」と檄を飛ばし、チームは勝利を掴んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域のお祭りを成功させるため、ボランティアたちは一丸となって準備を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "研究チームは、未知の病原体解明のため、一丸となって解析を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "予期せぬシステム障害が発生したが、IT部門と各部署は一丸となって復旧作業にあたった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "市民の声は、行政への提言として一丸となって届けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "幾つも幾つも、そういう難関を突破して来て、今すべてが、打って一丸となって、それが悉く芸術に浄化せられて筆を持てば、真に念頭に塵一つとどめず絵三昧の境地に入れます。",
              "citation": {
                "source": "今日になるまで",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか一丸となって、わが大正昭和の女流俳句を永遠に光輝あらしめたい。",
              "citation": {
                "source": "桜花を詠める句",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためには公共図書館といわず、学校図書館といわず、打って一丸となって、よい本を書店がつくるように協力してやらなくてはならない。",
              "citation": {
                "source": "図書館法の成立",
                "author": "――燃えひろがる火は点ぜられた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――したがってこの仲間は国境を越え、皮膚の色とかかわりなく、全世界で一丸となって立ち上がることができるだろう。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "白老の名誉町民第一号の氏にたいし、いま老人の人達は、全山紅葉の時期までには氏の胸像を完成させ、その除幕式をかねて高橋氏の功績｜顕彰会をひらこうと、まさに町ぐるみ一丸となって、その達成に全力をあげている。",
              "citation": {
                "source": "生きているコタンの銅像",
                "author": "――アイヌの慈父・高橋房次――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、われわれが一丸となって戦い抜かなければならぬ未曾有の国運の中にあって、自分の坐り込んでしまった「特等席」を離れることは「良心」の名でも「高いものの」名でも「国」の名でも、いやでござると言い放っている事を意味している。",
              "citation": {
                "source": "俳優への手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれら残虐行為――スペインで、ソ連で、中国で、ハンガリーで、メキシコで、アムリッツァルで、イズミールで――のどれ一つとして、英国の知識階級全体が存在を認め、一丸となって非難したことはないのである。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
