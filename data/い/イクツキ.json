          ],
          "literary": [
            {
              "text": "七｜年幾月の其の日はじめて、世界を代へた天竺の蕃蛇剌馬の黄昏に、緋の色した鸚鵡の口から、同じ言を聞いたので、身を投臥して泣いた、と言ひます。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾月ぶりかの、お魚だから、大人は、坊やに譲ったんです。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾月か住んでいるうちに、買い物の不便にも馴れた。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "イワンの兄は、不思議なことにも、それから幾日経っても、幾月経っても幾十年経っても再び姿を現わしませんでした。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　汽車が新緑の憂鬱な武蔵野を離れて、ようやく明るい山岳地帯へ差しかかって来るにつれて、頭脳が爽やかになり、自然に渇えていた均平の目を愉しましめたが、銀子も煩わしい商売をしばし離れて、幾月ぶりかで自分に還った感じであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷を出でたつてから幾月の後であつたか、もう草木の葉に白く風が吹いて渡る、秋のはじめ頃だつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "定基は幾月か扱っていた問題だったから、自然と後が口を衝いて出て来た。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "無念骨髄に徹して歯を咬み拳を握る幾月日、互に義に集まる鉄石の心、固く結びてはかりごとを通じ力を合せ、時を得て風を巻き雲を起し、若君尚慶殿を守立てて、天翔くる竜の威を示さん存念、其企も既に熟して、其時もはや昨今に逼った。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "床にはいって目をつぶっているのでさえ、五分間は長く、胸苦しく感じられるのに、新ちゃんは、朝も昼も夜も、幾日も幾月も、何も見ていないのだ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なぜ自分はこんな奇妙な仕草を幾月にも亘って続けて、なお、倦まないのか、自分でも解らぬ故、やはりこれは一種の憑きもののせいと考えていいのではないかと思っている。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、何故自分は斯んな奇妙な仕草を幾月にも亙つて續けて、猶、倦まないのか、自分でも解らぬ故、やはり之は一種の憑きものの所爲と考へていいのではないかと思つてゐる。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と小稲は前に出でて、「もうお幾月ぐらい？",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "某は当時｜退隠相願い、隈本を引払い、当地へ罷越候えども、六丸殿の御事心に懸かり、せめては御｜元服遊ばされ候まで、よそながら御安泰を祈念致したく、不識不知あまたの幾月を相過し候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧血の性なりしゆえ、幾月か心づかでありけん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　再びほんのりとした意識が、還って来る迄に幾日経ったか幾月経ったか、それとも幾年経ったか判らなかった。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇とも雲とも土とも分らない道の上で何日経ったか判らない、いや日を数えるのでなく月を数えても、幾月経ったかも判らない、いやもう一二年も経って居るのかも知れない。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の妹を殺した女がたとえ幾月にもしろ、刑務所に……」「余計なお世話だよ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の牢へ送りかえされて幾月ものあいだ起りそうにもない次の犠牲を待つことになったのであろうか？",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから幾月か家でただのらくらして過したのち、私はイートンの学生になった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた昏睡状態が幾週間も――幾月さえもつづく。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾月ものあいだ私はその猫の幻像を払いのけることができなかった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年｜幾月の其の日はじめて、世界を代へた天竺の蕃蛇剌馬の黄昏に、緋の色した鸚鵡の口から、同じ言を聞いたので、身を投臥して泣いた、と言ひます。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことは何うでも関はないが、思へば、ほんの半夜とは云ふものゝ斯うして妻に別れて歩いてゐるなんていふことは、幾月振りであることだらう。",
              "citation": {
                "source": "川蒸気は昔のまゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し過ぎ行く幾月の間に人々は凋落し老衰して同時に一族の者は孰れも窮乏してしまつた。",
              "citation": {
                "source": "菠薐草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧血の性なりしゆゑ、幾月か心づかでありけん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾月かののちに第二の皇子が宮中へおはいりになった。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "篝火を焚いた番所がかすかに浮いて見えて、全体に人少なな湿っぽい空気の感ぜられる、こんな所に物思いのある人が幾月も暮らし続けていたのかと思うと、源氏は恋人がいたましくてならなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い母は幾月かの連続した物思いのために衰弱したからだで出産をして、なお命が続くものとも思っていなかったが、この時に見せられた源氏の至誠にはおのずから慰められて、力もついていくようであった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いくつきりとした顔、妹によく似た黒い眸、凜々しく引きしまつた唇、顔全体を包んでゐる上品な匂。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾月もいくつきもヒステリの牛小舍に似たる怒濤が暗礁に突撃するを見たり、おろかや波はマリヤのまばゆきみあしのいきだはしき大洋の口を箝し得ると知らずや。",
              "citation": {
                "source": "醉ひどれ船",
                "author": "LE BATEAU IVRE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
