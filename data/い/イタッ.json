        "examples": {
          "standard": [
            {
              "text": "指をドアに挟んで、「痛っ」と声が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "熱いコーヒーをこぼしてしまって、「痛っ」と思わず叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "角に小指をぶつけて、「痛っ！やっちまった」と呻いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "注射針がチクっと刺さった瞬間、「痛っ」と顔をしかめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "勢いよく立ち上がったら、頭を鴨居にぶつけて「痛っ」となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「痛っ、足首捻ったかも…」と、バランスを崩して転びそうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さあ、大へん、みんな、「あ痛っ、あ痛っ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、白粉べたべたの洋装婦人の立膝がもろくもぶっつぶれて、「あ痛っ、こん畜生。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でもございませんの、私、ぼんやりしておりましたので、随分驚いてしまって……痛っ……」シャンとしようとすると、足首が痛かったので、彼女は思わず声を立てて、青年の肩にすがった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雌蘂に抱かれた一｜疋の虫のように、美沢は、深々と呼吸づきながら、「痛っ！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうですな、ちょっと開けてみましょう……なかなか固くにぎりしめていますわい」　検事が、老人の人差指と中指とを、指先をつかんで無理にこじあけようとすると、今まで人事不省のままで眠っていた老人は、「あ痛っ！",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと――」　小太郎は、袖を握られて、振払いざま「無礼なっ」　女は、高い声で「あっ、痛っ」　と、叫んで、すぐ「いい男振るない。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し、もう、皺くちゃで――あ痛っ、毛をむしる奴があるか――何も、芝翫を、皺くちゃと申したのではない。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、痛っ、痛、たっ」　深雪は、ぐんぐん歩いていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、痛っ」　何者かが、ふいに、千二の持っていた懐中電灯を叩きおとした。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、痛っ、痛い痛い」　千二が飛上った。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度六ツ半頃、庭に盥を出させて萩の間で行水を使っていると、とつぜん隣の家で、きゃッという魂消えるような女の叫び声が聞え、続いて、「あ痛っッ、……陳さん、あなた、何で、あたしを、こんな目に……。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵藤は事の意外さに呆れて一瞬見下ろしていたが、やがて猛然とお蔦の髷を左手で鷲掴みにする）兵藤　貴様、なに奴だ※お蔦　痛っ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（徳之助を刺し殺さんとする）文太郎　（三人の争いを知り呼び子を吹いて、渦中に飛び込み、十手で政吉の腕を叩く）政吉　　あっ痛っ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵藤　貴様、なに奴だ※お蔦　痛っ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十「誰だい、誰だい――おお痛っ」　金蔵は、しばらく起き上れないで、腰のあたりをさすると、兵馬は丁寧に介抱して、「お怪我はないか」「いや、もう大丈夫。",
              "citation": {
                "source": "大菩薩峠",
                "author": "竜神の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ痛っ」「畜生」その狼狽ぶりを目がけて、山伏は、杖を振り上げながら、「外道っ」と、喚いた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――あ痛っ」法師の一人は、撲られた横顔をかかえ、よろめきつつ、「何をするかっ」いうまに、覚明の手は、もう一人の襟がみへ伸び、「こうする」ひき寄せて、腰帯をつかむと共に、ぶんと振廻して大地へたたきつけた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の初秋一「あ痛っ、あ痛っ」　庄次郎は、頭をかかえた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳をかためて、いきなり、「この野郎」「ア痛っ」「なんだって車の尻になど乗ってけつかるか」「いけないの」「当りめえだ」「おじさんがひっぱるわけじゃないからいいじゃないか」「ふざけるなっ」　城太郎の体は鞠みたいに地上へ弾んで、ごろんと、並木の根まで転がった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ア痛っ」「痛かった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "御作事方のお許しが出なくっちゃ、帰るわけにゆかねえな」「それじゃあ、朱実がいうには、淋しいから、やめてくれといいますんでね」「おい、のろけかい」「決して、あたし達は、そんな仲じゃございません」「そうめんでも奢りなよ」「――ア痛っ」「どうしたい」「頭の上から、青い柿が落ちて来やがったんで」「ははは。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けったいだな、女の頭痛ってやつは」「お願いだから、あっちへ行って。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "半分の顔を、両手で大げさにかかえて、「ア痛っ。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は」「じゃあ、探してみようか」「この野良犬め」「ア痛っ、撲ったな」「こんなことで、腹が癒えるもんか。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もすこし何かしてもらいてえのか」「ア痛っ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出直してな」「うそばッかり」「ア痛っ」　背なかをどやしつけられて、やっと放免された馬春堂先生、ほうほうのていで抜け裏を出て来ましたが、さすがに、色男にはなりたくないものだと、例の長い顎をなでてみる自信もこの時はないようでした。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『隠密か』　浪人が、襟がみを離すと、男は、『あ痛っ』　と、大地へのめった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ア痛っ……ア痛々』『痛いのがわかるなら、少しは、性があろう。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜を記念しようという、なんの意味もない決心を笑いながら固めて、二人、浅草へ呑みに出かけることになったのであるが、その夜、私はいっそく飛びに馬場へ離れがたない親狎の念を抱くにいたった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは、ふたりながら死んだように黙って呑んでいたのであるが、二時間くらいたってから、馬場はそろそろしゃべりはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
