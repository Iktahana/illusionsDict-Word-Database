      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wholeheartedly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「十年以上もの間、彼女はあの日交わした約束を信じて、一途に彼の帰りを待ち続けた」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一度決めたからには、他には目もくれず、目標に向かって一途に突き進むだけだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼は周囲の雑音に惑わされることなく、一途に真理の追及にその生涯を捧げた」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「幼い頃からの夢を叶えるため、彼女は一途に稽古に励み、ついに憧れの舞台に立った」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの子は本当に一途に彼のことを想っているのね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一途に打ち込み、丹精込めて作り上げられた工芸品には、作者の魂が宿っている」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今はただ一途に、病に伏せっている友の回復を祈るばかりです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さつきのことばと言へ、今の笑ひ声と言ひ明らかに自分を侮辱してると彼は一途に思ひつめた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬はかくて痩せ細り夏に雨を得て肉附くことを繰返しながら、瞳は一途にあえかなるものに向って求めているのだと土民はいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一途に悔いていればいい。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "お徳は自分の亭主の云うことを一途に信じて、為さんも夜釣りの仲間であると申し立てているものの、実はふたりが連れ立って出るところを一度も見たことはないのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂吉どのも、たゞ一途に聴聞の志ぢゃげなで、これからさっそく講ずるといたさう。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂吉どのも、ただ一途に聴聞の志じゃげなで、これからさっそく講ずるといたそう。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどうしても決心を新にして少しでも繋縛の気のあるところは早速に避け退き、ひたすら求道の一途に奔らねばならない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は折角、寝ても覚めても思索一途に嵌り込めるようになった心境の鍛錬を俗人との世間咄しに乱されてしまうのは惜しくて堪らなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲望を整頓し心を端然と正して一途に自分の方向に行かなければならないことはもちろんでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとひ膚身は汚さずとも、夫の目に觸れた、と云ひ、恥しいのと、口惜いのと、淺ましいので、かツと一途に取逆上せて、お艷は其の日、兩親たち、夫のまだ歸らぬ内に、扱帶にさがつて、袖はしぼんだ。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後の事情から考えると、一途に駈落ちとも決められず、さりとて怪談も疑わしく、みんなもその判断に迷ってしまったのです。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "平助と又蔵は無論にその不調法をきびしく叱られたが、主人は物の分かった人であるので、この不調法の家来どもに対して一途にひどい成敗を加えようとはしなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――小郷が殺された時間には、鶴雄はおれと一緒に歩いていたのだ」　小田はこのことに気がつかず、一途に鶴雄が犯人ではないかと、疑っていた自分の間抜けさ加減に苦笑した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは……」　信ずるのかと言われてみると、一途に信じこんでいたことが分る。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇蹟はあらわれず、勝とうと思えば勝てた筈だという彼のいいわけも和尚の大人気ない毒舌にかゝって一笑に附されてしまうと、一途に残念がった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んど天上なるものへの思慕の如く一途に汚れなきこの恋の精進を、みにくい悪魔の誘惑に邪げられることが堪えられなかった。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう一途に思ひつめては事を仕損じますぢや。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう一途にいふもんでない。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "画は彼が最得意とするところで、ひょっとしたら、これ一途に身を立てて行こうかとさえ思うときがあった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の學校ぎらひはその頃になつて、いつそうひどかつたのであるが、何かに追はれてゐる私は、それでも一途に勉強してゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一途に、そんな気持だった。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、友人の不名誉の病い慰めようと、一途に、それのみ思いつめ、われからすすんで病気になった。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の学校ぎらひはその頃になつて、いつそうひどかつたのであるが、何かに追はれてゐる私は、それでも一途に勉強してゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其室は当時｜家中に聞えし美人なりしが、女心の思詰めて一途に家を明渡すが口惜く、我は永世此処に留まりて、外へは出でじと、其居間に閉籠り、内より鎖を下せし後は、如何かしけむ、影も形も見えずなりき。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、あんな気取り屋の坊ちゃんを、これまで一途に愛して来た私自身の愚かさをも、容易に笑うことが出来ました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仄かに、とか、ひそかにとか、かそけくとか、また、一途にとか、ひたむきにとか、純粋にとか言うことを蹴散らかされて、一たい芸術があるかというのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠一は実直な男で酒も飲まず煙草も喫わず、たゞ一途に働いていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新手村の大晦日の夜と、それから城中での歌合せの夜の二度まで、自分を振り切るように逐電してしまった佐助が一途に恋しくて、思い余ったその挙句に、佐助たずねてのあてなき旅の明け暮れにも、はしたなく佐助ばりの口調が出るとは、思えば佐助も幸福な男である。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "順平さえ娘の腹に宿らなんだら、まからんやが雨さえ降らせなんだらと思い、一途に年のせいではなかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一途にこれのみと頼りにしている板場の腕が、この調子で行けば結構丸亀の料理場を支えて行けるほどになったのを、叔父叔母は喜び、当人もその気でひたすらへり下って身をいれて板場をやっている忠実めいた態度が、しかし美津子にはエスプリがないと思われて嫌に思っていたのだった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
