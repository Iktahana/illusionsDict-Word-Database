    "definitions": [
      {
        "index": 1,
        "gloss": "striped beakfish (Oplegnathus fasciatus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "石鯛を狙って磯釣りに出かけるベテラン釣り師が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高級魚として知られる石鯛は、料亭でも珍重される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水槽の中を悠然と泳ぐ石鯛の姿は、見る者を飽きさせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「いやあ、この石鯛の刺身は本当に絶品だね」と、彼は満足げに呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "岩礁帯に生息する石鯛は、その強い引きで釣り人を楽しませる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "市場で獲れたての新鮮な石鯛が、飛ぶように売れていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは今の季節の京都に必ずなくてはならぬ鰉の焼いたの、鮒の子｜膾、明石鯛のう塩、それから高野豆腐の白醤油煮に、柔かい卵色湯葉と真青な莢豌豆の煮しめというような物であった。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鯛、ブリ、石鯛、マグロ、鮫などの猛勇も、僕の手に掛っては何れも降参しているのだが、まだ鯨だけは退治したことがない。",
              "citation": {
                "source": "鯨を釣る",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふぐのうまさというものは、明石鯛がうまいの、ビフテキがうまいのという問題とはてんで問題が違う。",
              "citation": {
                "source": "河豚のこと",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たびふぐを前にしては、明石鯛の刺身も、鬼魚のちりも変哲もないことになってしまい、食指が動かない。",
              "citation": {
                "source": "河豚のこと",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は蘆屋の家の附近にもあるし、阪急電車の窓からでも幾らも眺められるので、京都に限ったことはないのだけれども、鯛でも明石鯛でなければ旨がらない幸子は、花も京都の花でなければ見たような気がしないのであった。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女がいつも東京に在って思いを関西の空に馳せる時、第一に念頭に浮かぶのは蘆屋の家のことであるのは云う迄もないが、何処か頭の隅の方に、折々は此処の店の様子や、親爺の風貌や、彼の庖丁の下で威勢よく跳ね返る明石鯛や車海老のピチピチした姿も浮かんだ。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月三十日（土曜）　朝飯に神戸の吉田から送られた明石鯛の浜焼、マヨネーズつけてやたらに食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺を誘って、サンボアへ、明石鯛の味忘れられず、野田屋からとらしたのを肴にのむ、うまい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいしだいに暗きなかに奥深くおちいりてゆく思あり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども二杯三杯とのむにつれて、僕はしだいしだいに落ちついて来たのである。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちにち、瓦斯すとほぶの火は青ざめて燃えあがり、密房の壁には、しだいしだいに怖ろしいものの形容を加へてくる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤葛はしだいしだいにおりて来た。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうウイ」「おうウイ」「おうウイ」「おうウイ」　壮い木客の声と前方の声は交互に聞えだしたが、その声はしだいしだいに熱を帯びて来た。",
              "citation": {
                "source": "死んでいた狒狒",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川幅は、だんだんせまくなって、天じょうも、しだいしだいに低くなってゆきました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "がしだいしだいに――ごくゆっくりと――言いようのない嫌悪の情をもってその猫を見るようになり、悪疫の息吹から逃げるように、その忌むべき存在から無言のままで逃げ出すようになった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし捕まえるものがないから、しだいしだいに水に近づいて来る。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあるものは、比丘尼小町うんぬんの妖々たるなぞのみでしたから、名人の秀麗な面がしだいしだいに蒼白の度を加え、烱々たるまなざしが静かに徐々に閉じられて、やがてのことに深い沈吟が始められたのはあたりまえなことでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯一杯と浴びるごとに、しだいしだいと心が静まったとみえて、ややしばし少年がきょとんとしていましたが、いよいよいでていよいよ奇怪千万でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、だんな、このとおりにわか天気じゃござんすが、きのうまでの梅雨で往来はまだぬかるみだから、ひとっ走りまたつじ駕籠でも仕立てますかね」　けれども、右門の行動のうちに、伝六のそのひとりよがりを、しだいしだいにぬか喜びとさせるがごとき節が見えだしましたものでしたから、少々不思議でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに面目のないしだいでござりまするが、この子たちの嘆きをまのあたり見聞きいたしまして、いかにもふびんでなりませなんだゆえ、老いぼれの身にくふうもつかず、子を捨てろと教えたのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいしだいに引き込まれる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鎌を月光に輝かせ、しだいしだいに足並みを早め、やがて藪地の裾をめぐり、その一隊が立ち去った時、藪の奥から女の声がした。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アクーリナ」はその顔をジッと視詰めた、しだいしだいに胸が波だッてきた様子で、唇も拘攣しだせば、今まで青ざめていた頬もまたほの赤くなりだした……「ヴィクトル、アレクサンドルイチ」トにじみ声で「お前さんも……あんまり……あんまりだ」。",
              "citation": {
                "source": "あいびき",
                "author": "イワン・ツルゲーネフ　Ivan Turgenev",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの異分子もまたＢ主義の名に掩われてしだいしだいに流転して行くうちには、Ｂ主義の意味が一歩ごとに摺れて、摺れるたびに定義が変化して、変化の極は空名に帰着するか、それでなければいたずらに紛々たる擾乱を文壇に喚起する道具に過ぎなくなります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに恥かしいしだいですけれど私はそう思われます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この御下命を得ました当時は、皇太后陛下がまだ皇后陛下でいらせられた際のことであり、考えてみますと、筆者の私としましても深い感慨に打たれまして、まことに恐懼の念に堪えないしだいでございます。",
              "citation": {
                "source": "あゝ二十年",
                "author": "――やっと御下命画を完成した私のよろこび――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「陸です、たしかに」「君の眼はどうかしてるよ」「いや、ドノバン、霧が風に吹かれてすこしうすくなったとき、みよしのすこし左のほうをごらんなさい」　このとき煙霧は風につれて、しだいしだいに動きだした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧が雨になり、雨が霧になり、雨と霧が交互にたわむれて半天にかけまわれば、その下におどる白泡の狂瀾がしだいしだいに青みにかえって、船は白と青とのあいだを一直線にすすむ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時ごろから川の行く手に一道のうっすりとした青い色が、しだいしだいに地平線上にあらわれた、それは海であった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいしだいに呼吸がおとろえて、あけがた、うすあかりが東にほのめくころ、この改悟の義人は、十五少年とケートとインバスにまもられて、その光ある最後の息をひきとった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
