      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "departed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これは、今は亡き祖父が使っていた万年筆です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今は亡き友人のことを思い出すと、いつも切なくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの老舗の喫茶店も、今は亡き建物となってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今は亡き偉大な芸術家の作品が、特別展示されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」　右は一千九百三十二年四月、三造京都大学を卒へて帰京して間もなくの頃、その頃三造の友人であり、今は亡き無邪気な男の死後発見された紙片の抜粋である。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は亡き祖母に連れられて。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳述、私は明治四十年四月の末に生れ、その年十一月三日に郷里を母と母方の祖母と三人で立ち、四日乗船、六日大連着、そこで父に出迎へられ、（その父も今は亡き数、――安らかなれかし！",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その松の樹には、今は亡き弟と或時叱られて吊り下げられたことがある。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時は、彼はいつも身のまはりから離したことのない、下僕や、小間使や、犬などを殘らず引きつれて、階上へ昇り、そして家扶が先に立つて、今は亡きかれの母の逝去の部屋の中へはひり込まなければ承知しなかつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶應義塾の文科生時代に級友の井汲清治、福原信辰、それに今は亡き宇野四郎等と先生ともどもに銀座へ歩き出たりした事は幾度かあつたが、その頃から殆ど二十年振の今日思掛ない事柄が老先生とのかういふ半日を與へてくれた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざつと言へば、今は亡き作家の中で芥川龍之介などは刻苦精勵型、直木三十五などは先づ奔放自在型だつたと言へるであらう。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　今は亡き、畏友、笠井一について書きしるす。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は亡き、畏友、笠井一もへったくれもなし。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川龍之介氏の事　今は亡き芥川龍之介氏が、大阪毎日新聞に入社したのは、たしか大正八年の二月末だったと思う。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "めつき憐なる疲れたるこのめつき、汝等のめつき、わがめつき、今は亡きめつき、今に來るべきめつき、終に來ずして已むとも、實は世に在る目付。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は亡き彼地の陪審官デニス・ペトロー御覧なさい、御覧なさい、そら、あすこへ製粉場の風車が歩いて来ますぜ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "魯庵の友喰ひ４・29（夕）　新著『きのふけふ』で、今は亡き数の美妙斎を始め、紅葉、緑雨、二葉亭などの逸事を書いた内田魯庵氏は、友人の台所の小遣帳から晩飯の菜まで知りぬいてゐるのが自慢で、隠し立をする友人には随分気味を悪がられた程の人だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は亡き人の、新聞王ノースクリツフ卿を訪問した若い新聞記者があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかに正宗白鳥氏は今は亡き人の平尾不孤、岩野泡鳴二氏を回想して、二人とももつと生きてゐたら、もつと仕事をしてゐただらうに、惜しいことをしたものだと言つてゐました。",
              "citation": {
                "source": "恋妻であり敵であつた",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平尾氏の親友で、今は亡き人の角田浩々歌客氏や、中井｜隼太氏などは、ふだんＯさんに慊らぬ感情をもつてゐましたから、この騒ぎを機会にＯさんときつぱり手を切らせたい、少なくとも深入りはさせたくないといつて、平尾氏の東京行を中止させようと努力しましたが、いつこくな平尾氏は何といつても肯き入れません。",
              "citation": {
                "source": "恋妻であり敵であつた",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は亡き深田康算先生からはさらに別の影響を受けた。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけで、今は亡き深田先生のことを思い出す場合、アナトール・フランスを連想することが多いのである。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "朽木氏は今は亡き人であるから、わたくしは其遺文を下に全録する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "金で大きく蓋の上に定紋の折鶴を現はした手匣とともに、今は亡き父の記念品となつて、病院の枕元に置かれてある。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は亡き、そのお袋というのは官吏の細君で、ひどく気だての優しい女であったが、然るべく赤ん坊に洗礼を施こそうと考えた。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、今は亡きその女は考えた。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時その寺に、今は亡きアファナーシイ神父が住まつてをられた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、さうぢや、今は亡きわしの祖父が妖女との勝負をやらかした話を一つ聴かせませう。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　　　＊　　　　　　　　＊　ある時、今は亡き僧正猊下がディカーニカを通られた折、この村の土地柄を褒められたが、往還を馬車で通り過ぎながら、急に一軒の新らしい民家の前で車を停めて、「この美しく彩色つた家はいつたい誰の家ぢやの？",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはどうしてだと聞いてみると、実は去年の今ごろ、今は亡き神戸の三谷氏が友達と二人で君と同じように飄然とここへやってきたが、そのとき三谷氏は現在君のいるところへ全く同じように腰をかけていたし、また同じく神戸の金光氏および有明の案内塚田君もやっぱり同じようにそこへ腰をかけていたのだ。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は亡き母に、永久に私の心にいや近く、私を守って下さることを望んで、私は生きている。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父つぁん――」　糸子は室の真中に立って、今は亡き父を呼んでみた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば、今は亡き前文相二宮中将が、組閣間もなく国民学校第二学期の始まっていることを十日も忘れての放送に、大きなケチがついたように感じたが、それは本当であった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　ひとり機上にかえった小浜航空兵曹長の胸の中は今は亡き青江三空曹のことで、はりさけるようです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
