[
  {
    "uuid": "0039c7e7-f30c-5adc-8234-c815729b207e",
    "entry": "今は亡き",
    "reading": {
      "primary": "いまはなき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
