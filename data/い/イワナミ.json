        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "当時Ｒ研究所での仕事に聯関して金米糖の製法について色々知りたいと思っていたところへ、矢島理学士から、西鶴の『永代蔵』にその記事があるという注意を受けたので、早速岩波文庫でその条項を読んでみた。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和五年十二月、岩波講座『物理学及び化学』）",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに今度新たに岩波文庫で読み返してみると、実に新鮮な記憶が残っていた。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石崖の上の端近く、一高の学生が一人あぐらをかいて上着を頭からすっぽりかぶって暑い日ざしをよけながら岩波文庫らしいものを読みふけっている。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波文庫の「仰臥漫録」を夏服のかくしに入れてある。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば岩波文庫の芭蕉連句集の（五一）と（五二）の中から濁子という人の句ばかり抜き書きしてみると、「鵜船の垢をかゆる渋鮎」というのがあってそこに「鳥」と「魚」の結合がある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和六年十一月渋柿）　　　　　七　短歌の連作と連句　近ごろ岩波文庫の「左千夫歌論抄」の巻頭にある「連作論」を読んで少なからざる興味を感じたのであるが、同時に連作短歌と連句との比較研究という一つの新しい題目が頭に浮かんで来るのであった。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画と連俳との比較については岩波版日本文学講座中の特殊項目「映画芸術」の中に述べてある私見を参照していただきたい。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田孝雄氏の「連歌及連歌史」（岩波日本文学講座）からは始めて連歌の概念を授けられ、太田水穂氏の「芭蕉俳諧の根本問題」からは多くの示唆を得た。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「つまり、スタンダールを読んでるようなひとっていう意味だ」　鶴雄は机の上に置かれた岩波文庫へ眼をやった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉は岩波文庫の『赤と黒』の上下二冊を冴子に渡した。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫から校正には岩波茂雄君の手を借りた。",
              "citation": {
                "source": "『心』自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "エグジスタンシアリスムという言葉は、巴里では地下鉄の中でも流行語になっているということだが、日本では本屋の前に行列が作られるのは、老大家をかかえた岩波アカデミズム機関誌の発売日だけである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "取上げて見ると、一册は厨川白村の「英詩選釋」で、もう一つは岩波文庫の「ロティの結婚」であつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロールの街には岩波文庫を扱つてゐる店が一軒も無い。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "取上げて見ると、一冊は厨川白村の『英詩選釈』で、もう一つは岩波文庫の『ロティの結婚』であった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロールの街には岩波文庫を扱っている店が一軒も無い。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度、もと岩波書店でおなじみの小山二郎君が、新たに出版業をはじめるというので、この機会にこれらの短文を集めて小冊子を、同君の店から上梓するようにしないかとすすめられた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章をまとめる際は、『岩波国語辞典』から始まって、『広辞苑』や講談社の『大字典』、平凡社の『大百科事典』、岩波書店の『近代日本総合年表』などを引きづめです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、『岩波国語辞典』と『リーダーズ英和辞典』という最も使用頻度の高い二つは、マシンで引いています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波書店にしても、研究社にしても考え方は同じです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに「岩波国語辞典」、「広辞苑」、「大字典」、「平凡社大百科事典」といった、日常、本を読む際に使用している参考図書の類も、電子本のページから呼び出したい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻訳の底本：「露伴全集　第二十七巻」岩波書店　　　1954（昭和54）年6月18日第2刷発行原作者：幸田露伴",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻訳の底本：「露伴全集　第二十八巻」岩波書店　　　1954（昭和54）年6月18日第3刷発行原作者：幸田露伴",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "円本は勿論、改造文庫、岩波文庫、春陽堂文庫のたぐい、二十銭か三十銭で自分の読みたい本が自由に読まれるというのは、どう考えても有難いことである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議だといえば、あの本――岩波文庫の魯迅選集――に掲載してある作者の肖像が、まだ強く心に蟠るのであった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波文庫本の解説で、斎藤茂吉氏は「甚五郎という人物はやはり鴎外好みの一人と謂って好いであろう」と云っておられるが、鴎外はこの佐橋の生涯の行きかた、それへの家康の忘れない戒心というものを、只、好みの人物という視点から扱ったのだろうか。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
