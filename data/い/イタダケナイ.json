[
  {
    "uuid": "e2d78d85-eae6-5770-80cf-0873056d7e67",
    "entry": "頂けない",
    "reading": {
      "primary": "いただけない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
