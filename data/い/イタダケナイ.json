    "definitions": [
      {
        "index": 1,
        "gloss": "unacceptable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "いくら親しい仲とはいえ、断りもなく人の私物を使うのは頂けない行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若手の期待株として注目されていたが、昨日の試合で見せた自暴自棄なプレーは頂けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "論理の飛躍が多すぎて、説明責任を全く果たせていない今回の記者会見は、甚だ頂けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デザインは秀逸なのだが、これほどまでに耐久性が低いとなると、実用品としては少々頂けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「冗談のつもりだろうが、公共の場で他人の容姿を揶揄するような発言は、大人として頂けないな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "企画の内容自体は評価できるものの、収支計画の見通しが極めて甘い点は頂けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "料理の味は申し分なかったのだが、注文を間違えても謝罪の一つもないという接客態度は頂けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「あたくしの言う事はどうしても聴いて頂けないの」　姫の切なげな懇願に昭青年は前後のわきまえも無くなって「では」と言って姫を川の中へ連れて入りました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『万事あなたの真似をすることを許して頂けないでしょうか？",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すみませんが内密で僕にその鼓を見せて頂けないでしょうか」「……………」　妻木君は返事をしないで又も私の顔をシゲシゲと見ていたが、やがて今までよりも一層静かな声で云った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやや失望したが、この娘に対して少しも僻んだり気おくれはしない「……あのとにかく見せて頂けないでしょうか」すると娘はまたはっきりした笑顔になり「では、とにかく、」と云ってそこにある麻裏草履を突かけて、先に立った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父がこのごろ天気続きの為めか、身体がだいぶよろしゅうございますので、お茶一つ差上げたいと申しますが、明日あたりお昼飯あがり傍々、いらして頂けないでございましょうか、お相客はどなたもございません。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新子さんにも、お目にかかりたいんですが、そう貴女からもお伝えして頂けないでしょうか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、早く行きねえよ」「なんの御用か存じませんが、もし直きに帰して頂けないと困りますから、家へちょいと寄らして下さるわけには参りますまいか」「家へ帰ったって、金次はいねえぞ」と、半七は冷やかに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お二人の先生方のようなお立派な地位や名望のある方々にまでも妾の誠実が信じて頂けないこの世に何の望みが御座いましょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し見えたら、文章世界に書く約束で西村（渚山）氏に聞いて頂けないかつて、お聞きになつて御覧なさいな。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日お手紙が来たので、今日はもう頂けないものと思つてあきらめて待たないでゐましたのに、来ましたので本当に嬉しうございました。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ならいいところへ出せさうなのですが、取し戻て頂けないでせうか。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見れば、まず私はお父様からは答えて頂けないものと思わなければなりません。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「突然でなんですけれど、お寿女さん、もし手すきでしたら暫らくの間貸して頂けないでしょうか。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『まことに恐縮ですが、ちょっとお立ちになって頂けないでしょうか？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "主筆　今度は一つうちの雑誌に小説を書いては頂けないでしょうか？",
              "citation": {
                "source": "或恋愛小説",
                "author": "――或は「恋愛は至上なり」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな声で、明日の夕方、近所の石河岸まで若旦那様に来て頂けないでしょうかと云うんだ。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それについて少しばかしお金が入るんだけど、三田さん、何とかして頂けないでせうかねえ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し出来るだけ確実な証拠を集めて当人に自白させなくてはなりませんから、それで何か参考になるような材料を頂けないかと思って伺った次第です。",
              "citation": {
                "source": "秘められたる挿話",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、女はすこしも刺激に感じない、しかも、例の如く男を酔はせる調子で、「御金は、彼所ぢや頂けないのよ」と云つた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し頂けないかしら。",
              "citation": {
                "source": "聖女人像",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "材木代や工賃などは、すぐに頂けないとすれば、証書を入れておいて貰いたいと、それだけの条件である。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私と御一緒にお出で下すって御自身で見て頂けないでしょうか？",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒子　　だつて、それを云はずにゐれば、姉さまに、あたしの気持がわかつて頂けないんですもの。",
              "citation": {
                "source": "驟雨（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの場合、許して頂けないものであつたとしても、御好意は御好意として受けて充分感謝の気持を表はすべきであつたのに、浅はかな生意気心から、反つて御厚志をふみにじつてしまつたことを考へると申し訳なくてたまらない。",
              "citation": {
                "source": "お泊り",
                "author": "平山千代子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、こちらの手袋さ、一つ原価でわけて頂けないかしら……。",
              "citation": {
                "source": "医術の進歩",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、伺ふと、加来先生のご容態はもう絶望だといふことですが、お願ひしてあつた原稿もたうとう頂けないことになつて非常に残念です。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぢや、どうしても入れて頂けないので御座いますか。",
              "citation": {
                "source": "水不足",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、母の胎内を出て、師僧に仕えてこの方、戒律を破ったことはありませぬ、それなのに、何故、お顔を拝ませて頂けないのでしょう」　すると、次第に霧が晴れ、大師のお姿がはっきりと見えてきた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "また支払日など弁当持参で半日以上もお屋敷一軒のために費さなければ御勘定が頂けないのです。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "三鞭酒の方はあまり頂けないが、まア、この仕掛が名物になっているようなわけで、安南じゃアだれ一人知らぬ者はない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
