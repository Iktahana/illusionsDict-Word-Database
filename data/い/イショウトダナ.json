          ],
          "literary": [
            {
              "text": "なにぶん寝台は低すぎ衣装戸棚は狭すぎる。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はよく二つ並べた箪笥の前に坐って鍵をがちゃがちゃいわせていたが、「あんたはんに見てもらいまよか」といって、衣装戸棚の中からいろんな衣類をそこへ取り拡げて見せたりした。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "サト子は、シヅにお別れの手紙を書くつもりで、衣装戸棚へ化粧箱をとりに行った。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなひとたち、相手にすること、ないわ」　シヅは衣装戸棚の前で、さっと服を脱ぐと、丸首シャツとスラックスの勇ましい姿になって、サト子のそばへ戻ってきた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうは、食堂へ行きます」　広大もない衣装戸棚に一着だけ吊ってある一帳羅のカクテル・ドレスに着かえると、サト子は朽葉色の絨毯を敷いた長い歩廊を、本館の食堂のあるほうへ行った。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台の上の深々とした羽根蒲団をパッと捲り挙げてみて、返す足で寝台の横手へ駈け込んで、大きな姿見の付いた衣装戸棚を全部あけっ放した。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "業者から納入直後、えりに名前を書いて、父の寝室・衣装戸棚に置きました」「じゃあ、これは晩餐会につけていたまさにそのえりですね。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
