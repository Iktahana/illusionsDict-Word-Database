[
  {
    "uuid": "c2980b79-cb03-5ea1-ac6d-7b44a85d7386",
    "entry": "無花果",
    "reading": {
      "primary": "いちじく",
      "alternatives": [
        "イチジク",
        "いちぢく",
        "むかか",
        "イチヂク"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "common fig (Ficus carica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この無花果は、ねっとりとした甘みとプチプチした種子の食感が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏の終わりから秋にかけて、旬を迎える無花果は、農園で摘みたてを味わうのが格別だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "食物繊維が豊富な無花果は、整腸作用も期待できるため、健康志向の人々に人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「受粉しなくても実がなる」とされる無花果の繁殖方法は、植物学的に興味深い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "無花果のコンポートは、ヨーグルトやチーズとの相性も抜群で、手軽に作れるデザートだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "市場で見る無花果は、瑞々しいものから熟したものまで、色とりどりで目を楽しませてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、この無花果、すごく大きいね！」と、子供は目を輝かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その時妾はふと、夜陰の無花果の木の下に潜む、黒衣の人間の険悪な顔を姿見に認めて、恐ろしい悲鳴をあげました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓に倚りかかり、庭を見下せば、無花果の樹蔭で、何事も無さそうに妹さんが佐吉さんのズボンやら、私のシャツやらを洗濯して居ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る子は前掛けの衣嚢から干した無花果を出して遣ろうといたしました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑も此男は父の死だ後、市街外れに在る小さな莊園を承嗣だので、此莊園こそ怠惰屋の店とも謂つべく、其白い壁は年古て崩れ落ち、蔦葛思ふがまゝに這纏ふた門は年中開つ放しで閉たことなく、無花果や芭蕉が苔むす泉のほとりに生茂つて居るのである。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方此方と搜す中、漸とのことで大きな無花果の樹蔭に臥こんで居るのを見つけ出し、親父は恭々しく近寄つて丁寧にお辭儀をして言ふのには『實は今日お願があつてお邪魔に出ました。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟過た無花果がぼたりと落ちる。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中腹が空て來たと見えてラクダルは面倒臭さうに手を伸して無花果を採て口に入れた。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝ暫くすると大きな無花果の實が少年の頬の上に落ちた。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年がこれを口に入るのは指一本動かすほどのこともない、然し左も疲れ果て居る樣で身動もしない、無花果は頬の上にのつたまゝである。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　これを聞くや否や、ラクダルは手に持て居た無花果を力任かせに投げて怫然と親父の方に振り向き『此兒を私の弟子にするといふのですか貴樣は？",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は来たりぬ、われ再びこの暗く繁れる無花果の樹陰に座して、かの田園を望み、かの果樹園を望むの日は再び来たりぬ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸の傍に大株の無花果がコンモリとしてゐる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に日はパツと輝いて、無花果の葉は緑の雫が滴るかと思はれるばかり、鮮麗に煌く。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん永いこと眠り、やがて熟し切った無花果が自然にぽたりと枝から離れて落ちるように、眠り足りてぽっかり眼を醒ましましたが、枕もとには、正装し、すっかり元気を恢復した王子が笑って立って居りました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女の泣顔の中から狡るそうな笑顔が無花果の尖のように肉色に笑み破れた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの皿と入れ違ひに、附近の山でとれたといふ採りたての無花果の実が、はじけ相な熟した果肉を漸く圧へた皮のいろも艶やかに、大きな鉢に入れられて濃いこうばしいお茶と一緒に運ばれました。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まあ無花果をたくさん喰べてな、お茶もこうばしいぞ、月が半分も、あの山の端に傾いた頃から話し出さうよ。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏手は極疎らな垣根で小川に接して居る許りであるが、そこには欅、樫、櫻、無花果などの樹がこんもりと繁つて居り、低い葡萄棚の下が鷄の小屋になつて、始終鷄の聲がしてゐる。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無花果の下では、近所の子供が二三人集つて七面鳥をからかつて居る。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が無花果の青葉の陰を落した井戸端へ出て米を磨ぐと、小八はいばった口を利きながらも、傍へ往って手桶へ水を汲んでやりなどして、長屋の嬶達のからかいの的となっていた。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごく頂上のところにだけ無花果の熟み破れた尖のように、裸の峰や、裂目のある岩山が顕われております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとかしたらベントナイトとかいうものが出るかも知れないなぞと小川の向う側の無花果の葉の茂みの蔭に、わたくしは茣蓙を敷き、肘枕をして流水の涼しい気を受けながら見るともなく見ております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざさらば馬鈴薯の畑を越え瓜哇びとが園に入り、かの岡に鐘やみて蝋の火の消ゆるまで無花果の乳をすすり、ほのぼのと歌はまし、汝が頸の角を吹け。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが佳※よ、鐘きこゆ、野に下りて葡萄｜樹の汁滴る邑を過ぎ、いざさらば、パアテルの黒き袈裟はや朝の看経はて、しづしづと見えがくれ棕櫚の葉に消ゆるまで、無花果の乳をすすり、ほのぼのと歌はまし、いざともに角を吹け、わが佳※よ、起き来れ、野にいでて歌はまし、水牛の角を吹け。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、さならずばもろもろの麝香のふくろ、桂枝、はた、没薬、蘆薈および乳、島の無花果、如何に世のにほひを積むも、――さならずば、もしさならずば――汝いかに陳じ泣くとも、あるは、また護摩※き修し、伴天連の救よぶとも、ああ遂に詮業なけむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "視よ、持つは炎か、華か、さならずば実の無花果か、兎にもあれ、かれこそ邪法。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱れ織無花果の園なにか泣く、野より、をとめよ、無花果の汝が園遠くわれは来ぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "草も、無花果の樹も実も無しと。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱れ織　――天草雅歌――わが織るは、火の無花果を綴りたる花※の猩猩緋。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　水ぶくれの按摩の面は、いちじくの実の腐れたように、口をえみわって、ニヤリとして、ひょろりと立った。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
