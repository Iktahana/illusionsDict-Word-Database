        "examples": {
          "standard": [
            {
              "text": "ゴール前で最後の力を振り絞り、選手は息せき切りながら駆け抜けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "猫を追いかけて公園を走り回っていたら、あっという間に息せき切ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "満員電車に乗り遅れまいと駅を駆け上がった結果、会議に遅刻しそうになり、息せき切ったまま部屋に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫か！」と友人が息せき切って駆け寄ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "急斜面を登りきった登山家は、息せき切りながらも眼下に広がる絶景に息をのんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "強盗犯はパトカーの追跡をかわすため、狭い路地を息せき切りながら逃走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "火災現場から子供を抱きかかえて脱出した消防士は、ヘルメットを脱ぎ、息せき切りながらも安堵の表情を浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
