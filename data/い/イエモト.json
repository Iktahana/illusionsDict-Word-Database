    },
    "definitions": [
      {
        "index": 1,
        "gloss": "head of a school (of music, dance)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "千家茶道の現家元が、次期家元として長男を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家元の薫陶を受け、若手能楽師たちは次世代の担い手として研鑽を積む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この流派の家元に弟子入りできるなんて、夢のようです」と、熱心に稽古に通う生徒は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現代においても、多くの伝統工芸において家元制度がその技法や精神性を伝承する上で重要な役割を果たしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家元に挨拶するため、早朝から多くの関係者が茶会会場に集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「家元が直接指導してくださる機会は滅多にないので、今回の講習会は貴重でした」という声も聞かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は佐藤春夫、室生犀星、北原白秋、千家元麿、高村光太郎、日夏耿之介、佐藤惣之助等の諸君の詩を、たいてい忠實に讀破してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろその比較ならば、却つて千家元麿などの方が適切だらう。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今の知つてゐる詩人で、千家元麿にこの同じ自然性を感じてゐる。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く言つて、千家元麿は「生れたる子供」「生れたる自然人」だ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "導かれた車室の中には、白鳥省吾、千家元麿、川路柳虹等の諸君が、いつもの親しい顏ぶりでそろつてゐた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家元としてコレ位出来ていればまず……なんて考え方は毛頭ない。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、見物の批評とか、家元としての資格とか言ったような、世間的、もしくは人間的な研究の対照標準をトックの昔に超越してしまっている。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがね、家元の弥次郎兵衛どの事も、伊勢路では、これ、同伴の喜多八にはぐれて、一人旅のとぼとぼと、棚からぶら下った宿屋を尋ねあぐんで、泣きそうになったとあるです。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――聞きねえ、親なり、叔父なり、師匠なり、恩人なりという、……私が稼業じゃ江戸で一番、日本中の家元の大黒柱と云う、少兀の苦い面した阿父がある。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "店のすぐ鼻の先が先斗町であるからだろうか、それともこの店が小鼓の家元の美貌の三人兄弟が男手だけで経営しているからだろうか。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼓の家元の若先生らしく、そうして出来るだけ立派な外出姿に扮装して来て頂きたい。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "席は加茂川の堤下の知れる家元の茶室を借り受けたものであった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然恋人同志になりかけてゐた二人の仲が、そんな経緯で変に醗酵せず、友情の方へ逸れて仕舞つたのではあるまいか――そして、華道の家元の父親の家へ戻つて、桂子は生花に取りつき出した。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに老人が呟いた、大沼勘六、その名を聞け、彼は名取の狂言師、鷺流当代の家元である。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月の勤めに一方ならず苦労いたし、外を歩行くも、から脛を踏んでとぼつきます……と申すが、早や三十年近う過ぎました、老人が四十代、ただ一度、芝の舞台で、この釣狐の一役を、その時は家元、先代の名人がアドの猟人をば附合うてくれられた。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その頃北に一人、向うへ廻わして、ちと目に余る、家元随一と云う名取りがあったもんですから、生命がけに気を入れて、舞ったのは道成寺。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家元がどうの、流儀がどうの、合方の調子が、あのの、ものの、と七面倒に気取りはしない。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて十年二十年、一座の座頭となりて後も、舞台に烈しき働しては、楽屋に倒れて、その弟子と、その妹と、その養う児と、取縋り立蔽いて回生剤を呑ませ呼び活けたる、技芸の鍛錬積りたれば、これをかの江戸なる家元の達人と較べて何か劣るべき。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん家元へ向ってのわたくしに花嫁候補の資格が欠けるためでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各流家元をはじめ長唄界総動員の豪華演奏で、空前の盛事であつた。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは怪霊雑記にある話で、幸若舞の家元になった幸若八郎と云うのが、京都へ登って往く途中、木曽路で出会った出来事であった。",
              "citation": {
                "source": "人面瘡物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫玉は後の正伝節家元春富士、乙芽は後の冬映である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼学者の渋江抽斎、書家の市河米庵、ないし狂歌師仲間の六朶園荒井雅重、家元仲間の三世清元延寿太夫等と同じく、虎列拉に冒されたのかも知れない。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに今少と、肴ば提げて来るけに……」　青柳喜平というのは当時から福岡の青物問屋でも一番の老舗で双水執流という昔風の柔道の家元で、武徳会の範士という、仁三郎には不似合いな八釜しい肩書附の親友であった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時翁の師匠、喜多能静氏（喜多流十三世家元。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "現家元六平太氏は十四世）は根岸に住んでいたが、その寓居を訪うた翁は「到って静かで師を尋ねて来る人もなかった」と手記している。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "現家元六平太氏が家元として引継がれた品物は僅かに張扇一対というのが事実であったから、能静氏も表面は立派な邸宅に住みながら、内実は余程微禄した佗しい生活に陥って居られたものであろう。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "現家元六平太氏が常に先代先代といって例に引くのはこの人の事である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、維新直後から能楽各流の家元は衰微の極に達し、こんなものは将来廃絶されるにきまっているというので、古物商は一寸四方何両という装束を焼いて灰にして、その灰の中から水銀法によって金分を採る。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
