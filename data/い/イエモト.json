[
  {
    "uuid": "96bfa3c1-bdb6-5809-995a-f0d62491b2e3",
    "entry": "家元",
    "reading": {
      "primary": "いえもと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
