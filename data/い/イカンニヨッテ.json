[
  {
    "uuid": "891abc62-deea-5038-bd72-4d7a9187acb6",
    "entry": "如何によって",
    "reading": {
      "primary": "いかんによって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
