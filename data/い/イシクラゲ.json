        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨日の大雨で、庭の石畳に石水母が一面に現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "石水母は乾燥すると黒く縮むが、水分を含むと再び膨らんで緑色に戻る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雨上がりの登山道では、足元の石水母が滑りやすいため注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園の広場に大量発生した石水母が、子供たちの靴を汚すと保護者が心配している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "早朝、森の奥深く、露に濡れた落ち葉の間に石水母が静かに息づいていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「見て、あの黒いブヨブヨ。ゴミかと思ったら石水母だよ。」と子供が指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水はけの悪い田んぼでは、稲の生育に影響を与えるほど石水母が繁殖することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
