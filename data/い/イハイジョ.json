        "examples": {
          "standard": [
            {
              "text": "寺院の奥には、多くの位牌が納められた位牌所があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "位牌所で、先祖代々の位牌を前に静かに手を合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しく建てられた位牌所は、明るく清潔感のある空間だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "金兵衛は、と見ると、この隣人は袂に珠数を入れ、かつては半蔵の教え子でもあった亡き鶴松のことを忘れかねるというふうで、位牌所を建立するとか、木魚を寄付するとかに、何かにつけて村の寺道の方へ足を運ぼうとするような人だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
          ]
        }
