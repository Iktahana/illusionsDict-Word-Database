    "definitions": [
      {
        "index": 1,
        "gloss": "hurriedly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「電車の時間に間に合わないから、急いで支度して！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「急いでいるところを申し訳ありませんが、こちらの書類に大至急サインをいただけますか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「雨が降り出しそうだから、急いで洗濯物を取り込もう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「急いで救急車を呼んでください！ けが人がいます！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「悪いけど、急いでこの資料を人数分コピーしてきてくれるかな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「火事だ！ 荷物はいいから、急いで外に避難して！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「急いでいるので、一番早く提供できるメニューを教えてください。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "然しまあ、よく視よう、鏡なんだもの、と緊張を増すと同時に、急いで先が読みたくなくなる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君は小僧が皿を包むのをもどかしそうに待っていたが、包を受取ると急いで表へ飛び出した。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリックの兵は急いで捕えようとしたが、王は用心深く盾を頭にかざして落ち入ったので捕える事ができなかった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空いつの間にか曇りてポツリ／＼顔におつれどさしたる事もなければ行手を急いで上へ／＼と行く。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また降り出さぬ間と急いで谷中へ帰れば木魚の音またポン／＼／＼。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草へ行く積りであったがせっかく根岸で味おうた清閑の情を軽業の太鼓｜御賽銭の音に汚すが厭になったから山下まで来ると急いで鉄道馬車に飛乗って京橋まで窮屈な目にあって、向うに坐った金縁眼鏡隣に坐った禿頭の行商と欠伸の掛け合いで帰って来たら大通りの時計台が六時を打った。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで朝飯かき込み岡崎氏と停車場に馳けつくれば用捨気もなき汽車進行を始めて吐き出す煙の音乗り遅れし吾等を嘲るがごとし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドレドレと精は急いで受取って足を握って羽をバタ／＼さす。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悶え苦しさに覚えず唸り声を出すと、妻は驚いてさし覗いたが急いで勝手の方へ行って氷を取りかえて来た。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来は「承知致しました」と急いで、そこを去つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はその時は全く子供のやうにハシヤギながら、急いでそれを開いて見たのであつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡兎が森の方からやつてくるのを見付けると牝狐は、急いで子供達に云つた、「何時もの彼が来たらば、私は家にゐないとお云ひ。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼は彼女と十分の歓を取るや、急いで帰途につくのだつた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、見えたにしても、もう皆登り切って、風呂に急いでいる筈であった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　子供たちは、余程急いで歩いたと見えた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が急いで急坂を上るのは、私の身心から発散する墓場の雰囲気が恐ろしかつたのだと、私は考へた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして爪先下りのなだらかな道を下へ下へとおりて行く、ある人はどこまでも同じ高さの峰伝いに安易な心を抱いて同じ麓の景色を眺めながら、思いがけない懸崖や深淵が路を遮る事の可能性などに心を騒がすようなことなしに夜の宿駅へ急いで行く。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの大體の色と調子の見當をつけた計りで急いで繪具箱を片付けてしまつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同病相憐む心から私は急いで其處を通り過ぎねばならなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目前の災禍に驚いて急いで研究機関を設置しただけでは遂げられると保証の出来ない仕事である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多勢の人が見ているのも無関心のようにわき見もしないで急いで行く。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあの小さな美しい星が我が地球の何百万倍も大きな火の玉で、それが何万となき群になって無辺の宇宙の果から果に測り難い使命を帯びて急いで行くのだと考えると、一種妙な心持になるのである。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛍光のような幽美な光りが女神の身体から照り放たれ、その光りの輪廓は女神の身体が進めば闇に取り残され、取残されては急いで、進む女神の身体に追い戻る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山は急いで近寄らなければ様子が判らないというような山容ではなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "獣のいのちの名残りにしてそれには淡く塩辛いのもあり、いくらか甘くて――」　といいかけたとき、女は急いで袖を自分の鼻口に当て手を差し出して止めた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の姿を見ると目出度いと言って急いで羽織袴で恭しく出迎えるような商家の主人もあった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭青年は急いで川砂利の上へ飛び下り、娘の傍へ駈け寄って、抱き起しながら「どうしたのですか」　と訊くと、娘は力無い声で、昨日から食事をしないので饑えに疲れ、水でも一口飲もうと、やっと渚まで来たが、いつの間にか気が遠くなってしまったというのでした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに細川方の幕僚で丹波を領している細川｜下野守教春も、その数に洩れず、急いで国元へ引返して行きました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年十七の春父が急いで国元へ引返す際、彼はすぐに騒ぎを打ち鎮めて京へ帰れる見込みで、留守の館には姫の従者として男女一人ずつ残しておきました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は気が気でなく急いで持って行くと、父は眉を皺めて、私に戻す。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
