[
  {
    "uuid": "796cf3b6-bd47-509f-b129-0341cc0f594b",
    "entry": "一日か二日",
    "reading": {
      "primary": "いちにちかふつか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(in) a day or two",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一日か二日、様子を見てから病院へ行くことにします」と彼女は電話で伝えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "審査の結果が通知されるまで、通常は一日か二日ほどお時間をいただいております。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あともう一日か二日あれば、もっと完璧に仕上げられたのになあ」と彼は悔しそうに溢した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出張で一日か二日家を空けるだけなので、特に大掛かりな準備は必要ないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オンラインショップで注文した商品は、入金確認後、一日か二日のうちに発送される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一日か二日、考えさせてください」と彼は慎重な面持ちで答え、席を立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "台風が過ぎ去れば、一日か二日で元の穏やかな海に戻るはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女のこの頃の来方は気紛れでなく、一日か二日置き位な定期的なものになった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はくりかえして言う、――どうしてあの品物が一日か二日より長いあいだこの茂みのなかに発見されないままでいたか、ということを理解するのはとてもむずかしい。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨をかこつけに、もう一日か二日も逗留していたいという継子さんの心持は、わたくしにも大抵想像されないことはありません。",
              "citation": {
                "source": "停車場の少女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い切った証拠は一日か二日のうちによう判る。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "はは、一日か二日を過ごさぬうちじゃよ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日か二日のうち――その謎をどう解いてよいかと、かれは思い煩らっていると、家来の一人が知らせて来た。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日か二日のうち――その解けない謎も気がかりであった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはたぶん絵島丸より一日か二日早く大北汽船会社の船が着いたはずだから、それが持って来たんでしょう。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして散つてしまつたと見ると、もう一日か二日の間に次の年の葉の芽が斯のやうに枝ぢゆうに萌え出て來て居るのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日か二日で書いた三十枚のあはたゞしい論文で史的唯物論を「批判」するには、私はあまりに貧小であつたといふよりもあまりに健全であつたといふこと位は、私は大宅氏に認めて貰ひたかつた。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨をかこつけに、もう一日か二日も逗留してゐたいといふ継子さんの心持は、わたくしにも大抵想像されないことはありません。",
              "citation": {
                "source": "停車場の少女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにある山奧の温泉は、川一面が湯で、上州でわかれた群の一人がその前の絶壁から落ちて怪我をした創傷を一日か二日で治したといふことがあつた。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "復讐と言っても侮辱を受けたその場で拳を振り上げたり、荒い言葉を使ったりするのではなく、その時は黙って、寧ろにや／＼笑って置いて、それから一日か二日、時には一週間、或は一ヶ月、いや、どうかすると一年もかゝって適当なチャンスを見つけ、最も小気味よい方法で復讐を遂げるのが常でした。",
              "citation": {
                "source": "痴人の復讐",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "日下部といって塾のためには忠実な教員も出来たし、洋画家の泉も一週に一日か二日程ずつは小県の自宅の方から通って来てくれる。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長くはいませんよ、ほんの一日か二日でいいから」お島はそう言って、姉に頼んだ。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月の末日に、殆ど例年の如く、この連嶺は、一日か二日か全く雲に包まれて姿を見せず、温度は俄に降下して、外套を求めたいほどのことがある。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一日か二日前にならなければ、はっきりした返事は出来ないと云う有様である。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が僅か一日か二日違ひで帰つたことが、何か不吉の前兆ででもあるかのやうにさへ思はれた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、一日か二日の旅だつたら、無理にでも、着いたらすぐ御神火を越して波浮へ出て泊りたいと思ふ位でした。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、よくこうして出かけますので……長い時は一週間も……短かい時は一日か二日位で帰って参ります。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども前に申した通り實は此等の書物を讀んで、彼方此方同じことを纏めることは隨分な仕事であつて最初私は一日か二日で出來るだらうと思つてやつて見た所がどうしてなかなか一週間も掛らなければ出來ぬことを發見しました、左樣の次第故自然今日は極めて不完全なお話ししか出來ぬと思ふ。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に冬ざれた路の上にも、たまに一日か二日づつ暖い日かげがさすやうになつた。",
              "citation": {
                "source": "あばばばば",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日か二日ぐらゐでそれつきり顏を見せない人達もあつたが、大抵はこのホテルにずつと長く滯在してゐるらしい。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんなことです、おばさん」「わたしを一日か二日、自由の身にしていただきたいのです」「それはいったいどういうわけですか」　とゴルドンがいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "重犯などでなくちょっとした盗みなどをした仲間下部などは、一日か二日｜後手に縛って、邸内の人の立集う所にさらして置き、十分諸人に顔を見知らせた上で、『門前払い』即ち追払ってしまう例である。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "………「それから一日か二日すると、お蓮――本名は孟※蓮は、もうこのＫ脳病院の患者の一人になっていたんだ。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
