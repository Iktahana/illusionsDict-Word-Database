        "examples": {
          "standard": [
            {
              "text": "「来年は猪年だから、年賀状のデザインにはウリ坊を描こうかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "十二支の最後に当たる猪年は、エネルギーを蓄えて次のサイクルに備える時期だと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "猪年生まれの彼は、何事にも真っ直ぐ突き進む性格で、周囲を驚かせることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地元の神社では、猪年を祝うための大きな絵馬が奉納されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『本草啓蒙』四七に「野猪年を経るものは甚だ大にして牛のごとくなるものあり、甚だしきは背上木を生ずるものあり」。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女も猪年で、二十五歳だそうだ。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
