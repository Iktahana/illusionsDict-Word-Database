[
  {
    "uuid": "9f09351a-974d-5794-b6a3-d268d9444fcb",
    "entry": "印象を与える",
    "reading": {
      "primary": "いんしょうをあたえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-一段"
      ],
      "ctype": null,
