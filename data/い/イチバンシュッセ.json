          "literary": [
            {
              "text": "「村で一番出世をしたのは、小池はんと、新田の五郎作やがな。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "人口三百万の大東京を中心にして、誰がよく、友人の中で一番出世をした男に廻り会へるか。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ西遠寺さんにお目にかゝる研究が一番出世の近道ですわねと言っていたよ。",
              "citation": {
                "source": "善根鈍根",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
