        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "健診の結果、初期の胃潰瘍が見つかり、医師から詳しい検査を勧められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多忙によるストレスと不規則な食生活が重なり、彼は胃潰瘍を患ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "胃潰瘍の治療薬を服用し始めてから、胃の痛みが軽減され、食欲も出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「最近胃の調子が悪いと思ったら、軽い胃潰瘍だったよ。」と友人が心配そうに話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ピロリ菌の除菌治療が成功したことで、胃潰瘍の再発リスクを大幅に減らすことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は胃潰瘍の悪化を防ぐため、喫煙と飲酒を控えるよう医師に忠告された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "症状が進行した胃潰瘍の場合、内視鏡による止血処置や手術が必要となることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いつか自分の手指の爪の発育が目立って悪くなり不整になって、たとえば左の無名指の爪が矢筈形に延びたりするので、どうもおかしいと思っていたら、そのころから胃潰瘍にかかって絶えず軽微な内出血があるのを少しも知らずにいたのであった。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）脈を取ったり血を検査したりしたが、別に何も云わないから、自分で胃潰瘍だという事を話して吐血前の容体を云おうとしたが声を出す力がなくて、その上に口が粘ってハッキリ云う事が出来なかった。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その後間もなく自分は胃潰瘍にかかって職を休んで引籠ってしまったので、教室の自分の部屋は全くそのままに塵埃のつもるに任せて永い間放置されていた。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを胃潰瘍で斃れた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早稲田文学士の肩書を持ちながら柔道五段の免状を拾っているお蔭で、辛うじてこのＱ大の柔道教師の職に喰い下っている武骨者であるが、ツイこの頃軽い胃潰瘍の疑いで、Ｑ大附属のこの病室に入院した。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その胃潰瘍が程なく全快して、出血が止ったので念のために、この胃潰瘍が癌になっているかいないかを調べる目的で｜Ｘ光線にかかって、レントゲン主任の内藤医学士から「異状無し」と宣告されたのでホットして帰って来て寝台に引っくり返ったばかりのところであった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この幼時に見た珍しい見世物の記憶が、それから三十余年後に自分が胃潰瘍にかかって床についていたときに、ふいと忘却の闇から浮かび上がって来た。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内田博士の敏感７・22（夕）　茶話子の敬愛する文学博士内田銀蔵氏が胃潰瘍で危篤を伝へられるのは、学界のために痛惜に堪へない次第である。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日たうとう吐血したが（悪友達は胃潰瘍だらうとおどかしたが）、それでも酒はやめない（やめられもしないし、やめやうともしない）、句がやめられないと同様に（業だ、業だよ）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が胃潰瘍で新潟の妾宅に永らく臥っていた頃、表むきはリウマチで動けないという母の代りに姉が出向いて十日余りも滞在したことがあった。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は胃癌であった、残る一人は胃潰瘍であった。",
              "citation": {
                "source": "変な音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は胃癌であつた、殘る一人は胃潰瘍であつた。",
              "citation": {
                "source": "變な音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "○胃潰瘍には刺撃性の食物を禁ず。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃潰瘍とか胃癌とかいう病気は刺撃性の物を好む人に多いと申ます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯荒木夫人、田中君を養子に迎える件を白紙に戻して、胃潰瘍をなおすために、甲州下部温泉へ向う。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなのでも村の人たちは酔を求めて浴びるようにのむから、山村の人たちの間では胃潰瘍が非常に多い。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "智恵子は到頭自宅に置けないほどの狂燥状態となり、一方父は胃潰瘍となり、その年父は死去し、智恵子は転地先の九十九里浜で完全な狂人になってしまった。",
              "citation": {
                "source": "自作肖像漫談",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年私の父が胃潰瘍で大学病院に入院、退院後十月十日に他界した。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年の胃潰瘍の吐血は、その後の寅彦の生涯を決定したものであるが、『病院の夜明けの物音』『病室の花』『春寒』などに、当時の心境がよく現われている。",
              "citation": {
                "source": "寅彦の作品",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局胃潰瘍、十二指腸潰瘍、乾性腹膜炎、慢性盲腸と、四つの診断が下され、やれやれということになっていた。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃潰瘍がだんだん進行して、先生は少し静養を必要とされ、時々津田さんのところなどへ遊びに行かれて、毛筆淡彩の素描などを試みておられた。",
              "citation": {
                "source": "「寺田寅彦の追想」後書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は例の胃潰瘍の大出血後ずっと学校を休んでおられて、三年振りか四年振りかでやっと正式に大学へ出て来られたという時代であった。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年越しの胃潰瘍が遂に破局に近い状態にまで来たのであった。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃潰瘍とか、十二指腸潰瘍とか、慢性腹膜とか、いろいろの診断があったが、結局長期の療養が必要であることは観念していた。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
