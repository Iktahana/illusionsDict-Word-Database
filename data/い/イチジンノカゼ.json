[
  {
    "uuid": "5068d665-d431-5069-a960-e9f38a2750d1",
    "entry": "一陣の風",
    "reading": {
      "primary": "いちじんのかぜ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
