    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gust of wind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "蒸し暑い午後の校庭に、一陣の風が吹き抜け、生徒たちの前髪を心地よく揺らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "スタートの合図とともに、彼は一陣の風のごとくトラックを駆け抜けていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "平穏な海面に一陣の風が走り、一瞬にして小さなさざ波が幾重にも広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "一陣の風が桜の枝を揺らすと、数えきれないほどの花びらが雪のように鮮やかに舞い散った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "彼の鋭い指摘は、停滞していた会議の場に一陣の風を送り込むような鮮烈さがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "一陣の風が路上の砂埃を激しく巻き上げ、通行人たちは思わず顔を背けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「窓を開けたら、一陣の風と一緒に金木犀の甘い香りが部屋に流れ込んできたよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「嘘ですよ」一陣の風がスケッチブックをぱらぱらめくって、裸婦や花のデッサンをちらちら見せた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又五分位すると不意に思出したやうに一陣の風がどうつと吹きつけてしばらくは家鳴り震動する、又ぴつたりと止む。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また五分くらいすると不意に思い出したように一陣の風がどうっと吹きつけてしばらくは家鳴り震動する、またぴたりと止む、するとまた雨の音と川瀬のせせらぎとが新たな感覚をもって枕に迫って来る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一陣の風小高い丘を襲えば、幾千万の木の葉高く大空に舞うて、小鳥の群かのごとく遠く飛び去る。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この哀れなる姿をめぐりて漂う調べの身にしみし時、霧雨のなごり冷ややかに顔をかすめし時、一陣の風木立ちを過ぎて夕闇｜嘯きし時、この切那われはこの姉妹の行く末のいかに浅ましきやを鮮やかに見たる心地せり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一陣の風がスケツチブツクをぱらぱらめくつて、裸婦や花のデツサンをちらちら見せた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一陣の風が吹いて、漁船のあたりからおびただしく春の枯葉舞い立つ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "一陣の風はさっと起って籠洋燈の火を瞬きさせた。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に一｜本、榎を植ゆ、年經る大樹鬱蒼と繁茂りて、晝も梟の威を扶けて鴉に塒を貸さず、夜陰人靜まりて一陣の風枝を拂へば、愁然たる聲ありておうおうと唸くが如し。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、不安そうに、樹の間をすかして空を眺めた準之助氏の顔にサッと一陣の風が吹き降して来た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の両側にある岩盤にしてもかなりの急斜面のため、種々の松の木が頭上を覆うように茂っており、一陣の風が吹くだけで大きくざわめく。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "川は三つの瀬を一つに、どんよりと落合つて、八葉潟の波は、なだらかながら、八つに打つ……星の洲を埋んだ銀河が流れて漂渺たる月界に入らんとする、恰も潟へ出口の処で、その一陣の風に、曇ると見る間に、群りかさなる黒雲は、さながら裾のなき滝の虚空に漲るかと怪まれ、暗雲忽ち陰惨として、灰に血を交ぜた雨が飛んだ。",
              "citation": {
                "source": "光籃",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一陣の風は砂を捲きて起りぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう変な事と問うとアレあそこに一陣の風雲とともに鷹群が舞い来ると答える。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは丁度一陣の風によつて惹起された水の上の波が、互に相剋しつゝ結局鏡のやうな波のない水面を造り出すに至るのと同様である。",
              "citation": {
                "source": "運命と人",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子の背後の雨戸と硝子戸とが、バタ／＼と音を立てゝ外れると、恐ろしい一陣の風が、サッと室の中へ吹き込んだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち、この驚くべき Cross country racer 達の目眩しい流れを、地をゆるがせて一陣の風と共に私達の眼前を通過すると、奇体に猛烈なあの Fox Trot を踏みながら、まつしぐらに野を越え、丘を蹴り、畑をよこぎつて見る間に指呼の彼方に影を没した。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子の背後の雨戸と硝子戸とが、バタ／＼と音を立てゝ外れると、恐ろしい一陣の風が、サツと室の中へ吹き込んだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏の葉の一陣の風なきに散る風情は正にこれである。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さほど強い風でもなかったが、もう野分と言うのだろう、一陣の風がさらさらと音するかと思ううちに、この夏中さしわたし二尺あまりもある大きな葉の面に思うまま日光を吸うていた窓さきの桐の葉がばさばさと半分ばかり落ちてしまった。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜はしんしんと更け渡り、人影絶えたるここ上野の池のほとり、サツと音して吹き来る一陣の風に、木ノ葉二片三片散りたる後は、何ものもこの寂寞を破らんとするものなし……」　まったく冷汗ものだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一陣の風が、ヒューッと物悲しげな音をたて、舗道の上を吹いてきた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一陣の風が吹來ると、雲の先頭はやゝ亂れて、右往左往に頭を振つて迷ひ出す。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち一陣の風が吹いて来て、松明がぱつと明るくなつた。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一陣の風が吹き起って、墨のような黒雲が一面にあたりをとざすや否や、うす紫の稲妻がやにわに闇を二つに裂いて、凄じく雷が鳴り出しました。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、もし、どこからともしれず、にゅっとばかりに馬の鼻面が彼の肩の上へのしかかって、その鼻口から彼の頬にふうっと一陣の風でも吹きつけないかぎり彼は自分が書きものの行の中にいるのではなくて、往来の真中にいるのだとは気がつかなかったであろう。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところがその時、さつと一陣の風が起つて、ペトゥローは肚の底からぞうつとした。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は清浄無垢なものぢやから、お前の霊魂は天国の神様のそばへ飛んでゆくことも出来ようけれど、異端者のわしの霊魂は無限地獄の業火に焼かれるばかりで、何時になつても、その火焔の消される時とてはなく、いよいよその火勢が増すばかりで、一滴の水もそそがれねば、一陣の風もそよがぬのぢや……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは勿論振りかへらずにさつさと足を早めつゞけた、湿気を孕んだ一陣の風のわたしを送るのを感じながら。",
              "citation": {
                "source": "ピアノ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一陣の風の中に餌ものを嗅ぎつけた猟犬のやうに、かすかな戦慄の伝はるのを感じた。",
              "citation": {
                "source": "金春会の「隅田川」",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
