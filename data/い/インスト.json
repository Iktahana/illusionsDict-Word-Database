          "standard": [],
          "literary": [
            {
              "text": "」　裏街を行く車窓にメインストリートの上層の華美な電飾が反映していた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "管弦楽の作曲者の重要な仕事の一つはいわゆるインストルメンテーションであって、すなわち甲乙二つのパートが並行するとして、そのいずれをいずれの楽器に割り当て受け持たせるかによって全体の効果には著しい差違を生ずるのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ちょうどアインストリ博士がロンドンにご滞在だそうだ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にインストールの厄介さときた日には、殺人的である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、インストなんか、はやらないんだから。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの道が、駅につながるんだよ」　慶一の頭のなかで、メインストリートにならぶ商店が見え、こんどこそ高志の話を信じた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この教育カリキュラムを担当する同社の笹原正隆教育訓練部長によれば、社内にはマイコンの権威は大勢いるが、会長、社長が〈生徒〉ではやりにくいだろうと配慮して、講師は日本情報研究センターの女性インストラクター二人にお願いした、という。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっかけを作ったのは、電卓の組み立てキットでちょっとした成功をつかんだニューメキシコ州アルバカーキーのＭＩＴＳ（マイクロ・インストルメンテーション・アンド・テレメトリー・システムズ）社が、起死回生を狙って送り出した新製品だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＲ・ウインストン・チャアチルは、お茶の税を撤廃して、その減収を、競馬賭金仲人の電話へ年四十｜磅の増税を課することによって、補おうと言うのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラグマティズムも、インストリュメンタリズム（道具主義）もその意味では、現実の存在の最後の拠点を、多数人の生活がそれを是とする生活そのものの中に置くのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "桐生通信坂口安吾　　　　　田舎のメインストリートから　私の住居は田舎の小都市ながらメインストリートに位している。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は毎日この町のメインストリートを散歩する。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼が実験と考えたものも可なり曖昧なものであらざるを得ず、夫は不思議にも研究用具（インストルメント）自身と対立せしめられてさえいるのである。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "真理が道具であり有用性であるという事も、結局インストルメンタリズムや、便宜的功利主義のもつ主観論を脱することは出来ぬ。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者はジェームズに於けるインストルメンタリズム（道具主義）を徹底し、後者はその人本主義（ヒューマニズム）を誇張する。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロニー・ハウスが焼失した時は大量の籤を引き受け、それにより新しい煉瓦作りの建物――いまでも昔のメインストリートにある短い商店街の先頭に建っている――が一七六一年に建設された。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "男たちが威勢のいい声援を送り、女たちが同情の呟きを交わす中、私たちは雪のカーペットを敷いた小さなメインストリートを急いで通り過ぎ、山道に突入した。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうようすは、連合チェインストア会社の社長になつても、身につくものではありません。",
              "citation": {
                "source": "青君の追跡",
                "author": "THE PURSUIT OF MR. BLUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲は歌のないインストルメンタルだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宿は坊のメインストリートから、すこし山手になっているので、家の屋根屋根が見える。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に彼は人物として第一級であった、明晰な頭脳、胆力、識見、そして堂々たる風貌、すべてが群を抜いていた（筆者の所有する資料に白描の肖像が載っているが、それは英国の前首相ウインストン・チャーチル氏に瓜二つである）。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "目尻のつり上がった紫色の縁に、ラインストーンの飾りを散らせた眼鏡を、彼女はかけている。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、空手のインストラクターとか。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "教えると言っても、一種のデモンストレーターのような、つまり、空手インストラクター兼空手モデルのような。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は写真家で、彼女は空手のインストラクター兼デモンストレーター。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホミには言ってあるよ、うちの恵子さんは空手のインストラクターなんだよ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦のあくる年には、ウインストン・チャーチルのフルトン演説によって、「鉄のカーテン」という言葉が、有名になっていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロック・グループの基本的なインストルメンテーション――電気ギター、ドラム、電気ベース――は、グループのミュージシャンにとっては、技術的な壁ともなる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガーウッド「インストルメンタル・ブルース・ギターのマスターたち」。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
