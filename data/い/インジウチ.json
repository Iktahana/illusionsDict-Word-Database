          "literary": [
            {
              "text": "わが邦に昔行われた印地打ちだ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "17　印地打ちと、成年戒と、石の洗礼と。",
              "citation": {
                "source": "漂著石神論計画",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "決死の軍に超数学的の援兵がある真実は、幼少の時、阿部川の印地打ちの勝敗を予言したほどの家康は、知って知り過ぎている、それがなお且つ、それを計りそこねたのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月四月の満月の夜を始めとし、かつては我民族の間に重く視られたかと思う五月二十八日、または中世の印地打ちの日として、記録にも残っている四月二十二日等、これから問題として注意して見たい日を加算すれば百は超えるのだが、それらは採集の今少しく進むまで、暫らくこの列記の中から省いておくこととした。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
