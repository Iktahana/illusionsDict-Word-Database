    "definitions": [
      {
        "index": 1,
        "gloss": "with people jostling against one another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
