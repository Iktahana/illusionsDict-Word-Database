        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はＴ君に貧しい慰問袋を送りました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰問袋も寄こさないで下さい。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六ヶ月分の郵便物がぼつぼつ到着しますが慰問の小包なぞこの腹では到底コナセマセン。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、内地から着いた手紙や、慰問袋を兵営から病院へ持ってきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、持って来た慰問袋を開けていると、看護長がぶら／＼病室へ這入ってきたことがある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰問袋には一ツ／＼何か異ったものが入れてあった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦友は、這入ってきた看護長を見ると、いきなり、その慰問袋から興味をなげ棄てた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二　慰問袋　壁の厚い、屋根の低い支那家屋は、内部はオンドル式になっていた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人の××ばかりでなく、キキンの郷里から送られる親爺の手紙にも、慰問袋にも××××がかくされてあるのに気づいた中隊幹部は非常にやかましくなってきた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食糧や、慰問品の受領に鉄道沿線まで一里半の道のりを出かけていた十名ばかりが、帰ってきたのだ。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　でも、慰問袋は、一人に三個ずつ分配せられた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、彼等は、もう、白布の袋の外観によって、内容を判断し得るほど、慰問袋には馴れていた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者は開けたばかりの慰問袋や、その中味や、子供の手紙にどんなことが書いてあるか、そういうことをたずねるのだった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夕方、彼等が占領地から営舎に帰ると、慰問袋と一緒に、手紙が配られてあった。",
              "citation": {
                "source": "チチハルまで",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "警備の巡査、兵士、それから新聞社、保険会社、宗教団体等の慰問隊の自動車、それから、なんの目的とも知れず流れ込むいろいろの人の行きかいを、美しい小春日が照らし出して何かお祭りでもあるのかという気もするのであった。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎座にては七月二十八、二十九、三十の三日間、出征軍人慰問劇を興行し、来遊中のフランス女優テーラー嬢も団十郎の一座と共に出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずしい慰問袋を作り、妻にそれを持たせて郵便局に行かせる。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "）私の慰問の手紙は、実に、下手くそなのである。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はやな、わいも○○興業の落語の慰問隊たらいうもんに加わって、南方へ行くことになってん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四ツ橋で南十字星を見たという〆団治の話を聴いて、君枝が〆団治らの慰問隊を見送りに行った留守中に寝床を這いだして来ていたのか、それは他吉だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのウ、失礼ですが、あなたはいつか僕らの隊へ、歌の慰問に来て下すった方ではないでしょうか」「はあ……？",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰問で聴いた歌や」　そう判った途端、赤井は何思ったかミネ子の手をひっぱって、大阪の放送局のある馬場町の方へかけ出して行った。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに一年有半の大評判で、知らない人がぞろ／＼慰問に出掛けるやうになつた。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、その当時はそんなことを夢にも考えようはずもなく、殊に一種の戦争熱に浮かされて、女のわたくし共までが、やれ恤兵とか慰問とか夢中になって騒ぎ立てている時節でしたから、負傷の軍人を見舞のためにＵの温泉場へ出かけて行くなどということを、むしろ喜んでいたくらいでした。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、実をいうと、之は、私自身が、道具や食事や給金（之は、先方では要らないというだろうが、結局、老人や病弱者への慰問の形で、やらねばなるまい）のために少からぬ金を使わねばならぬことになるのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、私ちょっと慰問に来て上げたのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平「じゃ、やはり和子様は……」葉子「はあ、母は一番はじめの慰問袋送って直きに、死なはりましてん」庄平「……そうでしたか、では僕のお礼の手紙が着いた時には……？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はやな、わいも△△興業の落語の慰問隊たらに加わって、南方へ行くことになってん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "島原征伐がこの年から三年前寛永十五年の春平定してからのち、江戸の邸に添地を賜わったり、鷹狩の鶴を下されたり、ふだん慇懃を尽くしていた将軍家のことであるから、このたびの大病を聞いて、先例の許す限りの慰問をさせたのも尤もである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "イラ痒い瞼、ひえびえとする野面の風にひえびえとしたみすぼらしい顔の中から、この遠近を嘆賞するもないもんだなぞ、云つては呉れるな人々よ、自然の与件は、何時でも生理のまゝに享受してゐる者でこそあれ、希望を持つて生きてゐるとも云へるので、其の他はすべて、謂はば野心で生きてゐるのだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
