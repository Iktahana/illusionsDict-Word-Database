[
  {
    "uuid": "17b03960-0698-570f-b8cd-eafa8a1e6f8e",
    "entry": "言い囃す",
    "reading": {
      "primary": "いいはやす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
