        "examples": {
          "standard": [
            {
              "text": "イェール大学が発表した気候変動モデルに関する最近の研究は、主要な科学雑誌に掲載された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの高校生が、イェール大学のような名門校で学ぶことを目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女はイェール大学を卒業後、金融界で著名な人物となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イェール大学で博士号を取得したその教授は、ルネサンス美術の専門家である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "世界の安全保障に関する国際会議がイェール大学で開催され、世界中から参加者を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ええ、イェール大学の学費は「かなり」高いと聞くけど、教育の質は他に類を見ないらしいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イェール大学のアーカイバには、アメリカ文学に関する重要な歴史的文書が保管されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてルースはイェール大学の最も富裕な最も業々しくて反動的な「髑髏と骨」団の団員になった。",
              "citation": {
                "source": "微妙な人間的交錯",
                "author": "――雑誌ジャーナリズムの理想性と現実性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "表１　一定金額の食品当たりのタンパク質およびエネルギー：アトウォーター（21）より再計算タンパク質の高い標準にたいする挑戦はイェール大学の生理化学教授のチッテンデンによって最終的に行われた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の実験では7人のイェール大学運動部学生のグループが毎日64グラム（標準化）のタンパク質を摂取した。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
