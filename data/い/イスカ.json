[
  {
    "uuid": "5c7c95c5-e94f-50ea-8a8e-c12f2f159bc2",
    "entry": "交喙",
    "reading": {
      "primary": "イスカ",
      "alternatives": [
        "いすか"
      ],
      "is_heteronym": false
    },
    "grammar": {
