[
  {
    "uuid": "c9453337-29b1-56a6-a7b4-62647fa7fe47",
    "entry": "至る",
    "reading": {
      "primary": "いたる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to arrive at (e.g. a decision)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長時間の議論の末、委員会は最終的な合意に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "複数の資料を比較検討し、その結果、事件の真相解明に至る確かな証拠を発見した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "記録的な猛暑により、各地で熱中症患者が数千人規模で発生する事態に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "水質調査の結果、特定の化学物質の濃度が飲料水の基準値を超えるレベルに至っていることが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経済状況の悪化により、多くの企業が倒産寸前の状態に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女はその分野における第一人者の地位に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ええ、ようやく決断に至りました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "当時の日本は、文明開化の欧米心酔時代であったので、至るところ、彼はそうした不機嫌の目に逢わされた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "耶蘇、日本の敵です』と、至るところで彼は耶蘇教を罵り、その宣教師を仇敵のごとく憎んでいる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故彼は、動物を始め植物に至るまで、すべて生物を虐めたり殺したりすることを非常に叱った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に私は、至る所にこの「鬼」の形相を見た。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）然るに島崎藤村氏だけは、今日の老年に至るまで、一貫してその魂に純のリリツクを所有して居るところの、眞の宿命的な詩人であつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村氏に於ける文學の本質は、その「若菜集」の出發から、大作「夜明け前」の今日に至る迄、一貫して本質上の「詩」であり、詩精神なのである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酒を傾けて酵母を啜るに至るべからず。",
              "citation": {
                "source": "わが愛好する言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいま友人、大隅忠太郎君から、結納ならびに華燭の典の次第に就き電報を以て至急の依頼を受けましたが、ただちに貴門を訪れ御相談申上げたく、ついては御都合よろしき日時、ならびに貴門に至る道筋の略図などをお示し下さらば幸甚に存じます、と私も異様に緊張して書き送ってやったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに抒情芸術が先だつたといふ歴史上の論証があがつたとしても、近代に至るまで、抒情芸術と称ばれてゐるものゝすべては叙事による抒情、つまり抒情慾が比較的叙事慾よりも強かつたといふに過ぎない。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの子供の嗜好は、昔から今日に至る迄、一貫して少しも變化してゐないのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には秋のような日が照り渡って、地上には麦が実り、大鎌や小鎌を持った農夫たちが、至るところの畑の中で、戦争のように忙がしく働いている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひそかに家を脱して自轉車に乘り、烈風の砂礫を突いて國定村に至る。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが即ち文化の余裕といふものであり、昔の日本の江戸や、今の仏蘭西の巴里などで、この種の閑人倶楽部が市中の至る所に設備されてるのは、文化が長い伝統によつて、余裕性を多分にもつてる証左である。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂高といわず、槍ヶ岳といわず、奥常念、大天井に至るまで、万古の雪は蒸発しないで下層から解ける雪だ、死の如く静粛に、珠の如く浄美な雪から解けた水の、純粋性の緑を有することは、言うまでもない。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りて七合目に至る、霜髪の翁、剛力の肩をも借らず、杖つきて下山するに追ひつく、郷貫を質せば関西の人なりといふ、年歯を問へば、即ち対へて曰く、当年八十四歳になります！",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、江戸時代の神社仏閣の御手洗にかけてある奉納手ぬぐいを、至るところの休み茶屋や、室で見ることである。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長、機関長、を初めとして、水夫長、火夫長、から、便所掃除人、｜石炭運び、に至るまで、彼女はその最後の活動を試みるためには、外の船と同様にそれ等の役者を、必要とするのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてイからウに至る間に唇は順に前方に突き出て行くものとする。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず余は今に至るまでこの美代に対する感謝の念は薄らがぬ。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道々も至るところで富士の嶺は望まれたが見れば眼が刺されるようなので顧ってみなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして多くは高々と枝をかざして、そこにもここにもかしこにも人を待ちうけます――時にはあまりうるさく執拗に息づまるようななやましさをして桜は私の春の至るところに待ちうけます。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の脊髄のスープと云ったような食通を無上に喜ばせる洒落た種類の料理を食べさせる一流の料理店から葱のスープを食べさせる安料理屋に至るまで、巴里の料理は値段相当のうまさを持っている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞいちばんのさいはひに至るためにいろいろのかなしみもみんなおぼしめしです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、「いき」はロココ時代に見るような「影に至るまでも一切が薔薇色の絵｛３｝」ではない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘味、意気、渋味が異性的特殊存在の様態化として直線的関係をもつごとく考え得る可能性は、この直角三角形の斜辺ならざる二辺上において、甘味より意気を経て渋味に至る運動を考えることに存している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからば茶色とはいかなる色であるかというに、赤から橙を経て黄に至る派手やかな色調が、黒味を帯びて飽和の度の減じたものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、上行して盤渉より壱越を経て平調に至る旋律にあって、実際上の壱越は理論上の高さよりもやや低いのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこの関係は、勝絶より黄鐘を経て盤渉に至るときの黄鐘にも、平調より双調を経て黄鐘に至るときの双調にも現われる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また平調より神仙を経て盤渉に至る旋律の下行運動にあっても、神仙の位置に同様の関係が見られる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「極暑九十七度九分、山々に未だ雪あるに呆れ候、一昨夕、稀なる夕映、望遠鏡にて西山一帯を眺めいたるところ、駒ヶ岳の絶巓、地蔵の頭、間の岳、農鳥の絶頂なる、各三角測量標を、歴々と発見いたし候」（七月十八日）、この時の感じは、何だか自分が観て、Ｎ君に知らせているような気がした。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to lead to (a place)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この登山道は、原生林を抜けて静かな湖に至る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長時間の交渉の末、両社は最終合意に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "警察の捜査は、予想外の証言によって急展開を遂げ、ついに事件の真相に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地図を頼りに歩き続けた結果、目的の温泉地に至ることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この新理論は、長年の研究を経て、これまで解明されていなかった現象のメカニズムに至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、やっと目標の地点に至った！これで一安心だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "過度な期待は、しばしば失望に至る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "in the extreme case of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "契約の重大な違反に至った場合、法的措置を検討せざるを得ません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "進行した病状は、最終的に生命維持装置を必要とする状態に至ることもあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "システムが過負荷により破損する限界点に至る前に、アラートを発する必要があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "累積した不満は、やがて大規模な抗議活動に至るだろうと専門家は警鐘を鳴らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経営悪化が続けば、会社は破産という最悪の事態に至る可能性があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "水資源の枯渇は、地域社会の崩壊に至りかねない深刻な問題です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もうダメだ、完全に手詰まりに至ったよ…」と彼はため息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "to come",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長引く交渉の末、両国はついに平和条約締結に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "悩みに悩んだ末、彼は会社を辞める決断に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この最新技術は、長年の研究開発を経て、ついに実用化の段階に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このまま放置すれば、取り返しのつかない事態に至るだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ふう、これでようやく、安心できるところまで至ったね」と彼女は安堵の息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その社会運動は、国民の意識改革を促し、大きな歴史的転換点に至った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "提示された証拠から、陪審は被告が有罪であるとの結論に至った。",
