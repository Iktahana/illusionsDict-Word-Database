          ],
          "literary": [
            {
              "text": "父母たちは頼み少なくなった娘は、良人に何か言い置くことがあるのかもしれないと思って座を避けた。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ麝、麝鼠、麝牛、霊猫、海狸等の体より分泌する諸香に遠く及ばねど、諸獣の胆や頑石や牡具の乾物も多少その用に充て得と言い置く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについては何か言い置く事はないか。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い置く事あるなら明日誰なり呼び出してやる。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査三名来って本泥棒の犯人を明日取調べる旨を言い置く。",
              "citation": {
                "source": "同居人荷風",
                "author": "小西茂也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かわいいおくさんをつれにおいでかい。",
              "citation": {
                "source": "ラプンツェル",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "二位殿は熱さをこらえて、枕元に、にじり寄り、「お気の確かなうちに、何かいいおくことがおありでしたら何なりとも仰せ下さい」　といった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第六巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間もね、隆二さんにあなたから誕生日のおくりものとして熱川への小休みを貰ったと云ってやったら、本当にいいおくりものを貰ってよかったとよろこんでくれました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいいおくりものでなかろう筈はないでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私への一番いいおくりものだということは、国男君でさえ万々承知というのですから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にこの暮はいい暮れになりました、本当にいいおくりものいただいて。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからいいおくれたんです」「僕は先にきみを見つけた。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山城ノ入道は、阿新丸の心ねに同情して、城中にとどめおき、密かに会わせてやろうとしたが、息子の本間三郎と強硬な一部があって、意のままにならぬうち、三郎は鎌倉の使者と日取りをきめ、ただ阿新丸がたずさえて来た黄門どのの北の方の手紙だけを当人に見せ、「いいおくことはないか」　と、処刑を申しわたした。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
