    "definitions": [
      {
        "index": 1,
        "gloss": "wild boar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "キャンプ場の近くで大きな猪に遭遇し、慌てて車の中に逃げ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわ、庭のジャガイモが猪に全部掘り返されてる！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬になると、この地域の猟師が仕留めた猪の肉を使って、牡丹鍋を作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "猪の突進力は凄まじく、一度走り出したら止まらない様子から「猪突猛進」という言葉が生まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "詳しいことは忘れたが、何でも庄屋になる人と猟師（加八という名になっている）になる人の外に、狸や猪や熊や色々の動物になる人を籤引きできめる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉門次はふと草原を切り靡けたような、路のあるのを見出して、太い短かい杖で、猪独活をあしらいながら、「熊が通った路だあ」と言った、草はよほどの重量を、載せたように、右に左に押し倒されて、その凹んだ痕が、峰の方へ、斜に切って、するすると登って行く。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮口の時は、友人画家茨木猪之吉君と、長男隼太郎を伴った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猪が仔猪をつれて来て相撲って遊ぶところです」　赤土は何度か猪の蹄に蹴鋤かれたらしく、綿のように柔かに、ほかほか暖そうであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、この辺は人里離れて、猪の遊ぶのに持って来いだ」　翁はそういって、傍の保与（寄生木）のついている山松を見上げた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは猪の仔で、生れて六七月になる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉は親の猪より軟かでうまいものです」　息子の岳神はそういって、父の祖神に食べさすように妻に命じた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は螺の腹にえび蔓の背をした形で、瓜わらべを抱え、いつの間にか、いつぞや、息子の岳神に教えられた山ふところの猪の相撲場に来ていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪の相撲場の土には親猪が蝨を落して行ったのだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "代りに親猪の怒れる顔面を翁は保与のついた山松の根方に見出した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、翁は、「命終のとき」　といって、従容とその親猪の牙にかけられて果てた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父さまは山中の猪の相撲場で、猪の仔の瓜わらべと遊び戯れているとき、猪の親に襲われ、牙にかかってお果てなされた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体の地面よりは一段高い芝生の上に小さな猪口の底を抜いて俯伏せにしたような円錐形の台を置いて、その上にあの白い綺麗なボールを載せておいて、それをあのクラブの頭でひっぱたくと一種独特の愉快な音がする。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向いている豚の尻を鞭でたたけば南へ駆け出し、北向いている野猪をひっぱたけば北へ向いて突進する。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌から言へば、君は猪のやうにゴツゴツしてゐたし、おまけに亂暴書生の如く肩を怒らし、ステツキを突いて高下駄を引きずり歩いた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は野猪のやうに椅子を振りまはして、一直線に岡本潤へ打ちかかつてきた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むくむくした毛皮の外套を豪猪のようにまんまるくなるまで着こまなければならない。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中君は、勇氣のある人ですが、これからは、猪突の小勇をつつしむにちがひないと私は信じて居ります。",
              "citation": {
                "source": "田中君に就いて",
                "author": "――田中英光著『オリムポスの果實』序",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年猪の子に旦那の家から部落中に配ってくれる団子は、その年に限って、おりくの家へだけは呉れなかった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、猪川さん、まだご存じなかったんですか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦線から退却してくると、直ちに、猪川の家へ立ちよった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪川の家は、石の重い、壁の厚い、支那式の家でありながら、壁に切りあけた窓と、四国の田舎にありそうな、石の築き塀などによって、すぐ支那人の住家とは見分けがついた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだ、これが猪川の家だっけ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、最後に、猪川幹太郎は、このドサクサ騒ざに、家も、仕事も、子供も、すっかり失ってしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われも、子供のくせに、猪口才げなことを云うじゃないか。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いのししむしゃのかぶとむしつきのあかりもつめくさのともすあかりも眼に入らずめくらめっぽに飛んで来て山猫｜馬丁につきあたりあわててひょろひょろ落ちるをやっとふみとまりいそいでかぶとをしめなおし月のあかりもつめくさのともすあかりも目に入らず飛んでもない方に飛んで行く。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、大国主神を、伯耆の国の手間の山という山の下へつれて行って、「この山には赤いいのししがいる。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからわしたちが山の上からそのいのししを追いおろすから、おまえは下にいてつかまえろ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして急いで、山の上へかけあがって、さかんにたき火をこしらえて、その火の中で、いのししのようなかっこうをしている大きな石をまっかに焼いて、「そうら、つかまえろ」と言いながら、どしんと、転がし落としました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると途中で、うしほどもあるような、大きな白いいのししが現われました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
