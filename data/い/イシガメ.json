[
  {
    "uuid": "6302f628-7140-5844-999e-b4c362a56a72",
    "entry": "石亀",
    "reading": {
      "primary": "いしがめ",
      "alternatives": [
        "イシガメ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "any turtle of the genus Mauremys (esp. the Japanese pond turtle, Mauremys japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園の池で、悠々と泳ぐ石亀の姿を見かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うちで飼ってる石亀、最近よく餌を食べるようになったんですよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "河川敷の改修工事により、在来種である石亀の生息環境が変化する懸念がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "清流の浅瀬に、甲羅を干す石亀が数匹いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "石亀は、日本の淡水域に広く生息する代表的なカメの一種です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地元の子供たちが、地域で保護されている石亀の観察会に参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "弁天様の池畔などで、ぐつたり寝そべつて甲羅を干してゐるのは、あれは、いしがめとでもいふのであらうか、絵本には時々、浦島さんが、あの石亀の背に乗つて小手をかざし、はるか竜宮を眺めてゐる絵があるやうだが、あんな亀は、海へ這入つたとたんに鹹水にむせて頓死するだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お祝言の時などの島台の、れいの蓬莱山、尉姥の身辺に鶴と一緒に侍つて、鶴は千年、亀は万年とか言はれて目出度がられてゐるのは、どうやらこの石亀のやうで、すつぽん、たいまいなどのゐる島台はあまり見かけられない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ、絵本の画伯もつい、（蓬莱も竜宮も、同じ様な場所なんだから）浦島さんの案内役も、この石亀に違ひないと思ひ込むのも無理のない事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その藤沢の宿の南側、ここから街道を切れて、石亀川の渡しを越えて片瀬へ出るのが、その当時の江の島参詣の路順であるので、その途中には開帳を当て込みの休み茶屋が幾軒も店をならべていた。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで来た以上、もちろん引っ返すわけにもいかないので、茶屋の女房が買って来てくれた血止めの薬で手当てをして、四郎兵衛とお杉はふたたび駕籠に乗って、石亀川の渡しまで急がせた。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬琴などは石亀屋地団太だの鼠川嘉治郎なんていうのを平気で使っているが、今頃使ったら物笑いの程であろう。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "変り者の絹坊は座席を滑り落ちて、靴の載るところにあいかわらず石亀のように小さくなって伏臥していた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "石亀村に於て大操練御覧有之。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、見たこともない大きな石亀です。",
              "citation": {
                "source": "ふしぎな池",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石亀が、いかだの上で、かふらをほしてゐるのです。",
              "citation": {
                "source": "ふしぎな池",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、町のお寺の池にゐる、石亀をもらふことにしました。",
              "citation": {
                "source": "ふしぎな池",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごいんきよの家の下男が自転車で、ごいんきよの手紙を持つて行つて、お寺からいくつもの石亀をもらつて来ました。",
              "citation": {
                "source": "ふしぎな池",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓の田居を　過ぎにけるらし石亀の生める卵を　くちなはが待ちわびながら　呑むとこそ聞けこういう歌を作る境地に達した人と、しんから近づいて行って、心を重ねてものを言うことの出来ぬ寂しさを思うたことであった。",
              "citation": {
                "source": "民族の感歎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう極度に整頓した生活を表現することの出来る人が、同時に作った「石亀の歌」である。",
              "citation": {
                "source": "民族の感歎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこいつは、大きさがその約十倍もあって、石亀にしても相当大きい方に比べなければならないほどだった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は石亀のようにソロソロと匍った。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、石亀のように大きかった甲虫がありましたネ。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十助は石亀のように黙っていた。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛆も藻蝦もないときには、石亀を用いた。",
              "citation": {
                "source": "石亀のこと",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "石亀は、川虫の一種である。",
              "citation": {
                "source": "石亀のこと",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな餌かと、その釣り人に見せて貰ったところ、それは石亀であった。",
              "citation": {
                "source": "石亀のこと",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "石亀は、栃木県と茨城県にまたがる那珂川の釣り人も、若鮎釣りの餌に使っているという話だ。",
              "citation": {
                "source": "石亀のこと",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川釣りをやる人も、まだ酒匂川筋では稀であって、多くは石亀（川虫）を餌にした虫釣りか、十本五銭位で買える菜種鈎という黄色い粗末な毛鈎で、浮木流しをやっているのと、職業漁師が友釣りとゴロ引きをやっていた。",
              "citation": {
                "source": "想い出",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、常に、水の面、石の上に、群を成して遊べる放生の石亀は、絶えて其の影だに無く、今争ひ捜せる人々も、目的は石亀に在りしや明なりし。",
              "citation": {
                "source": "東京市騒擾中の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "依て案るに、本草に所謂秦亀一名｜筮亀あるひは山亀といひ、俗に石亀といふ物にやあらん。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ前に、池があって、中心の石亀が、口から噴水を高くふきあげている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、碑を仆せ、石亀をのぞいて、その下を掘り起せと、狂気じみた声を発した。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の力で、碑は仆され、石亀は数百年の眠りから揺り起された。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "辨天樣の池畔などで、ぐつたり寢そべつて甲羅を干してゐるのは、あれは、いしがめとでもいふのであらうか、繪本には時々、浦島さんが、あの石龜の脊に乘つて小手をかざし、はるか龍宮を眺めてゐる繪があるやうだが、あんな龜は、海へ這入つたとたんに鹹水にむせて頓死するだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
