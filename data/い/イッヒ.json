        "examples": {
          "standard": [
            {
              "text": "ニーチェの哲学において、「イッヒ（自我）」の探求は中心的なテーマの一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "フロイトの精神分析では、イッヒ（自我）がエス（イド）とスーパーイッヒ（超自我）の調停役となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「人間は、自己のイッヒ（自己意識）を絶えず問い直す存在なのだ。」と、哲学者は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "こっちだってあるんだけどね」「ほう、こっちにもね」「こっちだって、そりゃ一つや二つじゃありませんとも」　イッヒッヒ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「イッヒッヒッヒッ」　と、夫は始めて声を出した。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般人の生活水準の低下と社会的自主性の低減は、日本のブルジョア文学の独特な伝統が、ヨーロッパのイッヒ・ロマンとはまた異った歴史性をもつ私小説について自我の啓発、探求をもとめているにかかわらず、遂に芸術の中に語るに足るだけの自我の内容と発動とを、作家生活の実質から喪失させてしまっているのであった。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って、王クローディアスに扮する、独逸人俳優ルッドイッヒ・ロンネは傍演出者を兼ねているのだし、レイアティズ役の小保内精一は、音声上役どころでないと云った訳で、よんどころなく亡霊の台詞を消し、ポローニアスの屍体を、幕切まで露わさないようにした。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああも容易く、自然の根や情愛が、運び去られてしまうものだろうか……」　と暫く莨を持ったまま、ポツネンとしていたが、その時｜喚ばれた、ルッドイッヒ・ロンネが入って来た。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピリニャーク、自分の日本印象記の中から長く読み、米川さん、変な日本文学についてを朗読し、キム氏、日本の雑誌とイッヒロマンについて話し。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪人怪語「イッヒッヒッ。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッハッハッハッ、イッヒッヒッ」「何がおかしい、この馬鹿者！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か本ひっくりかえして「イッヒビンカツレツ」と云っている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イッヒビンカツレツ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『イッヒ・コンメ・フォム・ゲビルゲ・ヘル』なんて、まるで叱られてるようなもんで。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
