          ],
          "literary": [
            {
              "text": "部屋のなかぜんたいが異次元だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身の感覚が異次元のそれへと、早くも変化している。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとたん、僕は幻想の異次元空間にひきずりこまれる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
