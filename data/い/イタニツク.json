[
  {
    "uuid": "1af88c57-c329-5e72-8294-e6146df62ee8",
    "entry": "板につく",
    "reading": {
      "primary": "いたにつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-カ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to get used to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞台での演技がすっかり板について、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "入社して半年、ようやくこの仕事も板についてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は新しいポジションでもすぐに板につき、チームの中心として活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "何年も練習を重ね、彼のギタープレイは完全に板についている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めての海外生活で戸惑うことも多かったが、最近はだいぶ板についてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新米教師だった彼も、今ではすっかり教壇に板についている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この役割を演じるうちに、そのキャラクターが自分自身に板についてきたように感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こういうことになりゃ、伝あにいのおしゃべりじょうずは板につくんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居の言葉に「芸が板につく」と云ふことがあつたと思ひます。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が茶の湯をやりだしたのは保身のため、秀吉への迎合といふ意味があつたが、やりだしてみると、秀吉などとはケタ違ひに茶の湯が板につく男だ。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モダン」とつまるに及んで、日本語となり、同時にその世相風俗も日本の板につく。",
              "citation": {
                "source": "ハイカラ考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりしているもんだから、さっきも滑って転びそうになったのよ」「床がつるつるしてますからね」と、浜田は私を弁護するように、「初めのうちは誰でも間が抜けるもんですよ、馴れると追い追い板につくようになりますけれど、………」「じゃ、あたしはどう？",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンガポールのパンパンやサルウィン河の娘がやっても板につくに相違なく、これはつまり国籍に属するものじゃなくて女の淫蕩と獣血に属するものなのだろう。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるいたにつくということです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be at home (on the stage)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "入社当初はおどおどしていた彼も、半年が過ぎて今では電話対応がすっかり板についている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いやあ、その着物姿、本当に板についていますね」と茶会の席で声をかけられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年の修業を経て、彼の握る寿司はようやく板についてきたと師匠から太鼓判を押された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最初はぎこちなかった司会進行も、回を重ねるごとに堂々とした振る舞いが板についてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "主夫として家事をこなす毎日が続き、最近ではスーパーでの特売品選びもすっかり板についている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ベテラン俳優の演技は、舞台上での何気ない所作の一つ一つまで板についていて、観客を惹きつける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
