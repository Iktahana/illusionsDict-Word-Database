          ],
          "literary": [
            {
              "text": "こういうことになりゃ、伝あにいのおしゃべりじょうずは板につくんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居の言葉に「芸が板につく」と云ふことがあつたと思ひます。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が茶の湯をやりだしたのは保身のため、秀吉への迎合といふ意味があつたが、やりだしてみると、秀吉などとはケタ違ひに茶の湯が板につく男だ。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モダン」とつまるに及んで、日本語となり、同時にその世相風俗も日本の板につく。",
              "citation": {
                "source": "ハイカラ考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりしているもんだから、さっきも滑って転びそうになったのよ」「床がつるつるしてますからね」と、浜田は私を弁護するように、「初めのうちは誰でも間が抜けるもんですよ、馴れると追い追い板につくようになりますけれど、………」「じゃ、あたしはどう？",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンガポールのパンパンやサルウィン河の娘がやっても板につくに相違なく、これはつまり国籍に属するものじゃなくて女の淫蕩と獣血に属するものなのだろう。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるいたにつくということです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
