[
  {
    "uuid": "ee824e6d-4e2f-5853-aac9-3ebdeaf08084",
    "entry": "今までにも",
    "reading": {
      "primary": "いままでにも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
