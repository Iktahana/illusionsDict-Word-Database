        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お弁当持った？ 車に気をつけてね」「はーい、行ってきます！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「それじゃあ、夜には戻るから。戸締まりよろしくね。行ってきます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「大事な会議があるんだ。気合を入れて、行ってきます！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「じゃ行ってきます。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようがす、じゃ、ひとっ走り今から呼びに行ってきますからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまにしたって、だんなほど目はきかねえや、あそこの係りの非人どもは、日本橋のさらし場にいるはずだから、じゃ、ひとっ走り行ってきますからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、ひとっ走り行ってきますからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚いね、わが国の役人どものやり方は……」記者パイク「ふうん、それが本当だとすると、頭のいい役人がいやがったもんだよ」編集長「戦争が済んだら、僕はこの件について聊かものをいいたいと考えている」記者パイク「じゃあ行ってきますよ」編集長「ああそうか。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一浴して午後一時頃出発し燕絶頂にも行ってきます。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえお父さんほんの二、三日ですよ、ちょっと行ってきますと言ってしまうのでした。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、矢代の眼を見詰め、「じゃ、行ってきますわ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今から直ぐ私も行ってきます。",
              "citation": {
                "source": "Ｐ丘の殺人事件",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わりにね、でも興津に帰れば阿母さんがいらっしゃるんだもの……」「これが一かたついたら一寸行ってきましょう、樗牛のお墓に行ってきますよキット、葉書あげましょうネ！",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、今日でお終いだから、行ってきます。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、ちょっと行ってきますよ。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを持って艇長のとこへ行ってきますから……」「だめだよ、正吉君、艇長はいまひるねをしておられる。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、行ってきます」　と、カンノ博士は、さすがに顔をかたくして、マルモ隊長以下に別れのことばをのべた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、行ってきます』と途方もないことを口走ると、わたくしが追いすがるのをふり切って、家を出ていってしまったんです。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く何処かへ行ってきます。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしい、行ってきます」　事務長は、気がるに立ち上った。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、横須賀へ行ってきます、私がそう言うつもりで少女の方を振向いたら、やっぱり微笑していた。",
              "citation": {
                "source": "篠笹の陰の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクはこれから、倉田家へピストルをさがしに行ってきます」「隠し場所が分ったのかい」「いいえ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前八時でも十時でも、買物に行ってきます、と云って家を出れば足ります。",
              "citation": {
                "source": "安吾巷談",
                "author": "天光光女史の場合",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな人の理性をなめたことをやらず、真剣に、恋愛一途に没頭し、同じ家出をやるにしても、ミーちゃんハーちゃんと同じように、買い物に行ってきますと云って家出して、つつましく結婚していれば、どれぐらい素直で、人の反感を刺戟しなかったか知れないであろう。",
              "citation": {
                "source": "安吾巷談",
                "author": "天光光女史の場合",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が捕鯨の町、鮎川へ行ってきます、というと、仙台の人たちは、クジラのサシミはうまいですよ、という。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母さん、ぼくはいい運をさがしに、もう一度おしろに行ってきます。",
              "citation": {
                "source": "ジェミイの冐険",
                "author": "片山広子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では行ってきますよ、」と彼女は云いながら、重大な用件で小石川の奥から三田まで俥を走らせるのに、宛も日常の用足しででもあるかのように、落付き払って家を出た。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「叔母さん、行ってきますよ、井上さんと。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行ってきます」　二人は手をつないで出て行った。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "土曜の夕方「ただいま」と叫んで帰って来、日曜の朝教会のミサにあずかり、一日を私の看病に過ごし、月曜の朝まだ暗いうちに「行ってきます」と元気よく出て行く。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "トレープレフ　とにかく行ってきます。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の八畳へ行って、「警察から呼びに来ましたから、行ってきます。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ともかくちょっと行ってきます。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
