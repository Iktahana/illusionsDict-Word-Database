        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「命が惜しければ、すぐにここから立ち去れ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、敵の脅し文句に「命が惜しければ言うことを聞け」と言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「命が惜しければ、この事には関わるなよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「俺の命令は絶対だ。命が惜しければ、黙って従え。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "命が惜しければ入院しなさいと言われた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それほど命が惜しければ助けて得さそう。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命が惜しければ、誰も近よってはいけない」　帆村は、そういうと、跼んで、一同のところへ引返してきた。",
              "citation": {
                "source": "鬼仏洞事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "命が惜しければ、よく言うことを聞くんだ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命が惜しければ、反抗するな」　そういう相手の言葉は、ロシア語であった。",
              "citation": {
                "source": "空中漂流一週間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、お前も、もし生命が惜しければ、二度ともうそんなことを申すな。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年前、命が惜しければ残り、出世がしたければ前線に来いと云われ、命は惜しみませんと答えてついて来たのだ。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
