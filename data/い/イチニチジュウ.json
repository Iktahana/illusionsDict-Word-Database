    "definitions": [
      {
        "index": 1,
        "gloss": "all day long",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今日は一日中雨が降っていたから、家でのんびり過ごしたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、夏休みに入ってからというもの、一日中、外で遊び回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいプロジェクトの締め切りが迫っているので、この一週間は一日中オフィスにこもりっぱなしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "休日は一日中、好きな音楽を聴きながら読書をするのが至福の時間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は試験の前日、コーヒーを片手に一日中参考書と格闘していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昨日のマラソン大会では、一日中沿道で声援を送るボランティアの方々の姿があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このシステム障害は復旧に時間がかかり、結局、一日中サービスが停止したままだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その一つの因子というのは、季節季節でその地方一帯を支配している地方的季節風と名づくべきもので、これは一日中恒同なものと考える。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　三三九頁を見ると、　フェレチ王国の人々は朝起きた時に一番先に眼に触れたものを、その一日中崇拝するという事が書いてある。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中の通話の回数が驚くなかれ千六百九十四万とある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中公園に坐りこんでゐるとき、彼等はどんなことを考へてゐるのか知ら？",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二　妻クララに一九〇二年九月十一日、巴里トゥリエ街十一番地　……私は一日中、ムウドンの庭の中の、靜かな場所に坐つてゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "札幌から出て来た友人は、上京した第一日中は東京が異常に立派に美しく見えるという。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不愉快な記憶は、一日中、とれなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪からは高く、一日中日のあたつてゐる畑だ。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声はよく透り、一日中変わってゆく渓あいの日射しのなかでよく響いた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通り筋の毛糸雑貨屋の主人はこの間まで店へ据えた毛糸の織機で一日中毛糸を織っていたが、急に死んでしまって、家族がすぐ店を畳んで国へ帰ってしまったそのあとはじきカフエーになってしまった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るもの聞くものイライラチラチラして来るので一日中、奥歯を噛みしめてジッとしていた。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから聞くと、一日中機嫌が悪くて、妻子が弱ったそうであるが、自分は極力ニコニコしている積りであった。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一日中人中で式や挨拶やで嘸窮屈疲れがしたでしょう。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中空虚な言行をしているという意味ではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「返せと言うたかテ、どこを探したらええか、さっぱり判らんがな」「判らなかったら、一日中駈けずり廻って探して来い――いやか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一日中渡辺橋のところで、坐ってるんです」「釣れるんですか」　小沢は愚にもつかぬ質問をした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一日中居ると道子が云った筈の伊部の姿はその辺に見当らなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十時が鳴る丁度その瞬間、今晩やるんだと、一日中心に誓ってきたことをやってのけよう。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみれば、おたかはうまく災難をのがれたようなものの、やはりその日一日中頭痛がするといって寝たままでいた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君は豹一を背負って、こゝは地獄の三丁目と鼻唄うたいながら一日中働いた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてみると大阪へ来ると直ぐ板屋橋の寿司屋の出前持ちになったが、耳が遠くて注文先からの電話がよく聞きとれぬから商売の邪魔だと、今朝暇を出され、一日中千日前、新世界界隈の口入屋を覗きまわって板場の口を探していたが見つからず、途方に暮れていたところだという。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖娘の姉と二人で久しい間暮していて、私達と往来する人はこの街に一人もいなかったし、私は一日中つんぼのように、誰の声をも聞かなかった。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰥暮しで暇のある蛍雪は身体の中で脂肪が燃えでもするようにフウフウ息を吐きながら、一日中炎天の下に旅行用のヘルメットを冠って植木鉢の植木を剪り嘖んだり、飼ものに凝ったり、猟奇的な蒐集物に浮身を※したりした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中に起った事柄の、どれを省略すべきか、どれを記載すべきか、その取捨の限度が、わからないのである。",
              "citation": {
                "source": "作家の像",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言えば、全校の二階、下階、どの教場からも、声一つ、咳半分響いて来ぬ、一日中、またこの正午になる一時間ほど、寂寞とするのは無い。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早く起きて、能率は、ちっともあがらないのであるが、それでも遊ぶのが、こわくて、たいてい机のまえに坐って、一日中、勉強のふりをしているのである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店もさびれて、ときたま、おかみさんが、六つになる男の子を連れて、峠のふもとの船津、吉田に買物をしに出かけて行つて、あとには娘さんひとり、遊覧の客もなし、一日中、私と娘さんと、ふたり切り、峠の上で、ひつそり暮すことがある。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あごがとがって、皺だらけの顔で一日中ヒイヒイ泣いているんだ。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、どしんとたたきのめされた気持で、その日は自転車をのり廻しながら一日中考えさせられました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までの南がわだけでもたくさんだったのに、こんなふうに東がわの地ざかいへ見あげるような三階建をつくられたので、東と南をふさがれることになり、京屋の張場はいちにちじゅう陽が当らない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "永代経",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
