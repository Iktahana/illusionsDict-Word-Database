          "literary": [
            {
              "text": "だからその時と現在との間にどんな深いけじめがあろうと、どんな遥かな隔りがあろうと、それはなんでもないことだ。",
              "citation": {
                "source": "涸沢の岩小屋のある夜のこと",
                "author": "大島亮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "素子は、自分たちの暮しと、佐々の一家の生活と、この一ヵ月は二つの間をかけもっている伸子に、きびしいけじめを要求した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
