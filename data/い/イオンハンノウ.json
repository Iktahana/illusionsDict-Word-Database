        "examples": {
          "standard": [
            {
              "text": "水溶液中では、多くの化学反応がイオン反応として進行する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "塩化銀の沈殿は、銀イオンと塩化物イオンのイオン反応によって生成する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中和反応は、酸と塩基の間で起こる代表的なイオン反応の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電池の充放電過程では、電極表面で複雑なイオン反応が繰り返し行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "有機合成化学では、特定の官能基を持つ分子間のイオン反応を利用して目的の生成物を得る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "溶液の導電率測定は、その溶液中で進行するイオン反応の程度を評価するのに役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
