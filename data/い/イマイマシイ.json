    "definitions": [
      {
        "index": 1,
        "gloss": "annoying",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ちっ、またエラーか。忌々しい……」と彼はモニターに向かって毒づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大事なプレゼンの日に限って電車が遅れるなんて、本当に忌々しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "忌々しい記憶を振り払うように、彼女は強く首を振った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライバル校に一点差で負けたあの試合のことは、今思い出しても忌々しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すると間もなく、彼の全集が出ると聞いて、喜んだことは勿論ですが、却て忌々しい気もしました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この忌々しい病気の為に、過去に僕は幾人かの友人を無くしてしまい、愛する人を意外の敵に回してしまった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父のその様子を、小初は気の毒な儚い気持ちで見送ったが、結局何か忌々しい気持になった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――鉄橋からの墜落、雪の中の歩哨、爆弾戦、忌々しいメリケン兵などが彼等の前に立ちふさがっているばかりだった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを迂濶に口外すれば宇三郎ばかりでなく、第一にわが身の上が危ういから、藤吉は忌々しいながらも我慢するよりほかはない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこれらのあまりといえば変化のなさすぎるような心の印象の後には、何か忌々しい動揺が起ろうとしているように思えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「否、可厭な風が吹いたんです……そして、其の晩、可恐い、氣味の惡い坊さんに、忌々しい鉦を叩かれましたから……」　唯吉は、思はず、乘かゝつて居た胸を引く。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忌々しいではありませんか。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりたけまあ大事にして、ものを見ないようにする方が可いっていうもんだから、ここはちょうど人通の少い処、密と目を塞いで探って来たので、ついとんだ羂に蹈込んださ、意気地はないな、忌々しい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忌々しい、可哀そうに老人をと思って癪に障ったから、おいらあな、」　活気は少年の満面に溢れて、蒼然たる暗がりの可恐しい響の中に、灯はやや一条の光を放つ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、忌々しい、めそめそ泣いてばかりいやあがる。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "平民の野良犬も多いのに、何も選好をして華族様の御手飼を殺らずともの事だ、奥様に知れようものなら、金次一生の越度とならあ、忌々しい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「首途に、くそ忌々しい事があるんだ。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高綱　　こんな世の中にうろ／＼してゐるのが、忌々しいからぢや。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之も先方から真白昼押掛けて来て、平気でお出でお出でを極めるとは、図迂図迂しい奴、忌々しい奴と、市郎は惘れを通り越して、稍勃然とした。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　忌々しいとは思うけれど、婆の云うことは確に真実である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "又蔵は忌々しいのと、一方には提重の女からいじめられる苦しさとで、だんだん強面に平助に迫るので、こちらもうるさくなって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "雖然何を見たからと謂つて、些とも興が乘らぬばかりか、其の名畫が眼に映つると、寧ろ忌々しいといふ氣が亢じて來る。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "この忌々しい病気の為に、過去に僕は幾人かの友人を無くしてしまひ、愛する人を意外の敵に廻してしまつた。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴いとは云え多寡が土細工の茶碗だ、それに俺ほどの者が心を動かしたのは何事だ、エエ忌々しい、と其の茶碗を把って、ハッシ、庭前の石へ叩きつけて粉にして終ったということがある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太閤が氏郷を忌んで、石田三成と直江兼続の言を用い、利休の弟子の瀬田｜掃部正忠に命じて毒茶を飲ませたなどと云うのは、実に忌々しい。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忌々しい、そう思わるるが厭だによって、大分気をつけているが地金はとかく出たがるものだナ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エエ糞ッ、忌々しいが云ってしまおう。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち上つた席に今更坐ることも出來ない心苦しさを感じながら、或る忌々しい感情が心の中に擴がつて行くのを私はどうする事も出來なかつた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忌々しい、とそこで大弓の株を売って、今度は安東村の空地を安く借りて、馬場を拵えて、貸馬を行ったんですな。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忌々しいなあ、道中じゃ弥次郎兵衛もこれに弱ったっけ、耐ったものではないと、密と四辺を※しますると、塵一ッ葉も目を遮らぬこの間の内に床が一つ、草を銜えた神農様の像が一軸｜懸っておりまするので、小宮山は訳が解らず、何でもこれは気を落着けるにしく事なしだと、下ッ腹へ力を入れて控えておりまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか忌々しいような気になったので、彼はそこらの小石をひろって投げつけると、鶏は羽摶きをして姿を消した。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人が災難とあきらめているので、義助もよんどころなく我慢したが、主従三人が揃いも揃ってこんな目に逢うのは、あまりに忌々しいと思った。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあの忌々しいマシュウス。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父の心が折れたんだ、それもみんなあの忌々しいハドソンのせいだ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
