[
  {
    "uuid": "b2ddc94d-65cd-5de0-b287-df42739a7d6a",
    "entry": "言い当てる",
    "reading": {
      "primary": "いいあてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
