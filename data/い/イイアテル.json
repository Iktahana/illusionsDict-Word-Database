    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to guess right",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は長年の経験から、市場の動向を正確に言い当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「きみが何を考えているか、お見通しだよ」と、友人は私の心の奥底を言い当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "探偵は、些細な証拠から事件の真相を見事に言い当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームリーダーは、開発中に生じるであろう問題を事前に言い当てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が箱の中身を言い当てたので、皆がその鋭さに驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が新作映画のヒットを言い当てたのは、これで三度目だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議で誰も気づかなかった問題点を、新入社員が的確に言い当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カンと申すと……」「たとえば名人のお医者が、小便の色を見て病人の寿命を言い当てるようなもので、私どもは掃溜の色をタッタ一目見ますると、その家の奥の奥の暮し向きまで包み隠しのないところが、ハッキリとわかりまする」「うむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれのエキスパートが品物の産地を言い当てるように、この男にはやはり特別な眼識が備わっているのかと思われた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうのことを、まさしくその通りに、美事に言い当てるものじゃないよ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰宅した私のズボンに付いたはね跡を見て、色や質感からロンドンのどこで付けたものか言い当てるほど。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "僭越だが、灰を一目見ただけで、葉巻や煙草ならどんな銘柄でも言い当てることができる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "四〇代と六〇代どちらに近いと言われても、見ただけで言い当てるのは難しいだろう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどキュヴィエが骨一本の検討から動物の全身像を正しく描けるのと同様、観察する者は、ひとつながりの出来事の一環さえ完全にわかれば、前後含めたすべての輪を狂いなく言い当てることができよう。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は八歳ばかりの子供を知っていたが、この子は『丁か半か』という勝負で言い当てるのがうまくて、みんなに褒められていた。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手に言い当てるのもある、全然見当違いのことを、それであろうと深く追究したりするのもある。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "田町には名高い占い者があって、人相も観る、墨色判断もする、人の生年月日を聴いただけでもその吉凶を言い当てる。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビルマの孫の所や名を言い当てるのは不可能でないとほめちぎっているのだ　――ぼくはそんなことは初耳ですよ。",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、谷へ来る野鳥の類なら、そのなき声をきいただけでもすぐに言い当てるほど多くの鳥の名を諳記じていて、山林の枯れ痛み、風折れ、雪折れ、あるいは枝卸しなどのことには精通していた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し疑う人があるならここから五十里｜許ある南方のＸの町へ行って巫女に遇って聞いて見れ、巫女は過去、未来、現在のことを言い当てると言った。",
              "citation": {
                "source": "薔薇と巫女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは易者が妄者の迷いを言い当てるのに良く似ているね。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こッちの気持、人間の気持をピタリと言い当てるのは、さすがに商売人である。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　持彦はやっとうまく言い当てるところに行き着いて、自分の言ったことに間違いのないことを感じた。",
              "citation": {
                "source": "花桐",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢沢　これなる奎堂先生は、帯剣の吉凶を相し、腰刀の禍福を試みて、その言い当てるところ、万に一つの誤ちもござりませぬよし。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田で八卦を置いて、高輪の犯人を言い当てるのも、洒落ているだろう」　平次はお勝手へ合図をして、一本晩酌をつけさせると、最合い煙草の煙管を八五郎に渡して、面白そうに耳を傾けました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「あとの、もう一人が臭いようだな」　八五郎の話の先を潜って、平次は言い当てるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその筆者を言い当てると、弁護士はそつけなくそれを認めた。",
              "citation": {
                "source": "村の吸血鬼",
                "author": "THE VAMPIRE OF THE VILLAGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹後守という人は妙な人で、時々前以て物を言い当てることがあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードではその音の美しさが全部そのまま記録されているとは言い難いが、少くとも眼をつぶって三分の一面だけ聴いても、――いや、ほんの二、三小節を聴いただけでも、クライスラーの音は、少しく馴れた人には言い当てることが出来るだろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "老練な客引や番頭になると、顔や服装を見ただけで、客の持ち金をほぼ正確に言い当てるという。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っているけれど、僕の名を言い当てるのが怖いのでしょう。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、八卦見ではあるまいし、見ず知らずの人間が、きょう引越しすることを、いったいまあ、どうして言い当てることができたのであろう。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを言い当てるのは簡単だ」　思わずフィールド警部補も漏らした。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女に結婚を申し込んで、もちだしたなぞをいいあてることができなかった人たちです。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫のたましいにしては、すこし変だし……」　青二には、このあやしい動物の正体を、はっきりいいあてることができなかった。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "各人各様、とはよくいったもの、馴れるに従って足の裏をみた丈で、いま入浴しているのは誰々――とハッキリいいあてることが出来るほど、夫々に特徴を持っているのです。",
              "citation": {
                "source": "足の裏",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば張は道々で水晶の珠で占いをして、この先にどんな危険があるかをいいあてるよ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
