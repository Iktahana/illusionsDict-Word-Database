[
  {
    "uuid": "1b4f6102-a817-548c-9794-ebdf93e394d3",
    "entry": "一楽",
    "reading": {
      "primary": "いちらく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
