[
  {
    "uuid": "9e4807e7-9eb2-5cb4-9df0-0ec8e6df8955",
    "entry": "板の間",
    "reading": {
      "primary": "いたのま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
