        "examples": {
          "standard": [
            {
              "text": "夫の海外赴任から帰国を待つ間、彼女は一日三秋の思いで日々を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "合格発表まであと一週間。高校生たちは一日三秋のように感じ、落ち着かない様子だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新技術の特許審査結果を待つ間、開発チームは一日三秋、進捗を気にかけていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "限定版のフィギュアが届くのを、彼は一日三秋の思いで待っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "検査結果が出るまで、家族は一日三秋の心境で、ただ時が過ぎるのを待つしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もうすぐ兄が帰ってくるのに、なぜか一日三秋だよ！」と彼女は友人に語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "戦乱の終結を待ち望む民衆の心は、まさに一日三秋の思いであった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
