    "definitions": [
      {
        "index": 1,
        "gloss": "one full game (consisting of east, south, west, and north rounds)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　と、起ち上ると、はや麻雀のパイの、得意の青の清一荘（チンイチ）の頭に浮んだ構図にせき立てられるように、「――さいなアら！",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに一個の結構な盆地で、今でこそ軽便鉄道を架ける話がないから偏鄙などというが、四隣を山川で断ち切って纏まりよろしく、しかも出端の悪くない点から見れば、武家時代においてはまことに理想的の一荘園である。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大かたは踊おぼえぬふた廻り　　　　一荘　はじめて踊に加った場合らしい。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一廻り待つ人おそき踊かな　尚白」などという句は第三者として踊の輪の廻るのを見る一例であるが、一荘の句は自ら踊の輪の中にあって、二廻りも廻っているところに特色がある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀を一荘、三時半頃揃って出かける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二夫婦で一荘、珍しく大三元を荘家でやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴、今朝の飯は抜きにして、一休庵へ行くことにし、朝から一荘。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "白川をよんで一荘やる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "けい古ザッとすませると、麻雀を一荘やり、Ｐ・Ｃ・Ｌ事務所へ行って、三百円借りる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "体があいちまったので一荘やり、それから見舞に寄る、浦野ますみは確然たる肺病らしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四友クラブで一荘やり、負ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳と出て、麻雀クラブで一荘やる、座へ帰って、松翁の「続劇壇今昔」を読み乍ら、揉ませる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くのクラブで一荘やり、ビクターへ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時から小劇場で、十六日放送の「ハリキリボーイ」を本読み、三時半頃から大丸の内で一荘やり、ケタ／＼に負ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿へ帰ると、谷幹・堀井・京宝の高井で一荘やり、軽く負けて、三時近くねる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう麻雀は止めて大いに仕事しようと言ってるとこへ、堀井と井口が来た、一荘やるかいなと、すぐ又始めちまった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時半迄、大丸の内で一荘やり、当りを見せ、公会堂へ昼と同じ会で出る（80）。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大丸の内で一荘やり、一時近くから日劇舞台けい古。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今夜もどうせ一時からだらうと、大丸の内で一荘やって、日劇楽屋にねころび、揉ませ乍らセリフを入れる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丸の内で一荘、大いに負けたが、久しぶりで混一トイ／＼の小三元をやった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿へ帰って、堀井・多和・穂積で一荘やる、珍しく勝った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネて又しても昼のメムバー来り麻雀一荘半、少し負け。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "川万へ寄り一荘やり又負けた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、からだがあくと、久し振り一荘、島村・穂積・林寛で銀座のクラブでやる、ひどく負けた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて又麻雀を、一荘のつもりが――つひに四荘やり、五時近くにねる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "千恵蔵がやらうと言ふので大文字屋へ帰って、一荘やり、あはてゝ六時半楽屋入りをする。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時頃抜けて、銀座裏の英太郎の家へ寄り一荘やり、負け、十時迎へが来てＪＯＡＫへ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹川旅館へ寄り、来阪中の田中三郎・清水千代太等と一荘やり、くたびれて二時に宿へ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネると、竹川から電話、行って一荘やり今度は勝。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一荘やって二時すぎに宿へ帰った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
