[
  {
    "uuid": "222d0da2-7d2d-5949-a3d2-8982ded36db5",
    "entry": "行ってくる",
    "reading": {
      "primary": "いってくる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "感動詞"
      ],
