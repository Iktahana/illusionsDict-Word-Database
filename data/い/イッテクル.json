    },
    "definitions": [
      {
        "index": 1,
        "gloss": "I'm off (and will be back later)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ちょっとコンビニ行ってくるね！」と、子供は元気よく玄関を飛び出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "同僚に「ランチ行ってきます！」と声をかけ、オフィスを出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人との電話で「ごめん、そろそろバイト行ってくるわ。」と告げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「図書館行ってくる。夕飯までには戻るよ。」と家族に伝えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一時間で行ってくるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから僕が一人で行ってくるからここに待って居なさい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その書を机上に閉じて終って、半盞の番茶を喫了し去ってから、　また行ってくるよ。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間で行ってくるよ」「もっと遊んでおいで。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは、これから、暑い国々へ行ってくるよ！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやならいいわ、わたしが自分で行ってくるからいいわ」　紀久子はいつもの温順さにも似合わず、狂的に叫びながら髪を振り乱してベッドから飛び下りた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな気持ちを一掃するように、これからひとつ吾助茶屋へでも行ってくるかなあ？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田様の歳祝いにでも行ってくるべ。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとで僕は博士会館へ行ってくる。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、一走り行ってくるから。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんならわたしちょっと行ってくるから、ここに待っていらっしゃい」「そうね」　なかなか片づかない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎が聞いてみると、よし子が病院の看護婦のところへ、ついでだから、ちょっと礼に行ってくるんだと言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとっ走り行ってくるから、お待ちなせえよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいら呉服橋の北町番所へ行ってくるからな」「よしきた。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "――活動へ行ってくるよ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこのＴ町の人達は、用事で市の中央に出掛けて行くのに、「Ｙへ行ってくる」と云った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どれ、俺も敵状視察と行ってくるかな。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か、内地の村に行ってくるというものがあると、同じ「国衆」のものが集ってきた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂をすませて、夕飯を食って、今夜はここに泊まるはずであったが、上原はちょっとそこまで行ってくるといって、好子を残して出たままで今に帰って来ないのをみると、自分はきっと置き去りにされたに相違ない。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はっ、では杉田は、ここで部署を守っております」「よし、しっかり頼んだぞ」「では、御無事を祈っています」「うむ、行ってくる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこれから玄庵さんのところへ行ってくるから、着物を出してくれ」　箸をおくと、すぐに着物を着かえて、半七は傘を持って表へ出ると、雨はまだ未練らしく涙を降らしていたが、だんだん剥げてくる雲のあいだからは薄い日のひかりが柔かに流れ出して来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょいと出てくるから着物を出してくれ」「これから何処へ出かけるの」「熊のところまで行ってくる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様は解剖室で助手に命じて胃腸を切り出させ、一寸自分の室へ行ってくるといって、そいつをもって帰ってくる。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは僕はこれから大学へ行ってくるから、今言った方面を宜しく頼むよ」二　死体解剖の結果、致命傷は、背部の刺創で、右肺が深く傷つけられて居たために、内出血を起して死んだものとわかった。",
              "citation": {
                "source": "呪われの家",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日になると、お絹は昼ごろ髪を結いに行って、帰ってくると、珍らしくおひろの鏡台に向かっていたが、おひろもお湯に行ってくると、自分の意匠でハイカラに結いあげるつもりで、抱えの歌子に手伝わせながら、丹念に工夫を凝らしていたが、気に入らなかったらしく、しばらくするとまた別の女優｜髷に結いなおしていた。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「ほんとの自分」として最初に行ってくるのが、じぶんの属する人種と国籍にいまさらのように気のつくこと。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ行ってくるよ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は近いうちに、あの骨壺を持って、汽車に乗り郷里の広島まで行ってくるつもりだった。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "９「私、ヤマギシカイのトッコーに行ってくるわ」　電話工事の仕事を始めてから最初の春を迎えた一九七三（昭和四十八）年の四月、ヨーコが突然言った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーシュはぼんやりしてしばらくゆうべのこわれたガラスからはいってくる風を吸っていましたが、町へ出て行くまで睡って元気をとり戻そうと急いでねどこへもぐり込みました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to go (and then come back)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "来週、京都へ桜を見に行ってくる予定を立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "壊れたパソコンを修理に持っていってくることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ちょっと向こうの店までパンを買ってきてくれる？と頼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引っ越しの手伝いに実家へ行ってくるんだ、と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
