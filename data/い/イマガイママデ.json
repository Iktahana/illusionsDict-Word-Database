    "definitions": [
      {
        "index": 1,
        "gloss": "till just now",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今が今まで、まさか彼が犯人だとは夢にも思わなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今が今まで寝てたの？ もうお昼過ぎだよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "さっきまで晴れていたのに、今が今まで降っていなかった雨が急に激しくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこへ来ると私はいつも今が今まで私の心を占めていた煮え切らない考えを振るい落としてしまったように感じるのだ。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外でもない、貴女の地位は罪を隠すことが出来るので、人殺をして今が今まで、賢夫人の名を保っていたのだ、それ其がごく宜しくない。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、自宅の敷居を跨いでから今が今まで出来ることなら破綻も小さい範囲にとどめ、自他共になるべく手負い人を出さないことにして先へ生活を流して行き度いと心がけていたのですけれど、さすが半月あまり吹き曝されて来た山河の広い風は、わたくしの心の戸障子を吹き外ずさしたものと見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作は今が今まで、これほど解ってる人で、きっぱりとした決断力のある人とは思わなかった。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事とはちっとも知らずに、今が今まで、祝福された、輝くようなあなたを迎えられるとばかり思っていたんです。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今が今まで我家の将来でも考へて、胸が塞つてゐたのであらう。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今が今まで我家の將來でも考へて、胸が塞つてゐたのであらう。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今が今まで、今日の君との話においてさへさういふ君をのぞむわしの氣持がものを云つてゐた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉村はとらへられた當初から今が今まで事柄の性質をきはめて簡單に考へてゐた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうさ、今が今まで一緒に行く気でいたんだもの」「又この次のとき行くさ。",
              "citation": {
                "source": "一隅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面にある尖ったアーチ風の飾、高い壁、今が今まで花輪を飾った寝棺がその前に置かれてあった質素な説教台のみが残った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今が今まで見たこともない製材工場へやって来て、巨大な、精緻な機械が、梁みたいに大きな木材を片はじからパンのように截って廻っているのを目撃したら、誰しも感歎する。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今が今までそう言っていたじゃありませんか」と一向平気なものであった。",
              "citation": {
                "source": "イエスキリストの友誼",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と思つたら、すんでの事に、おれは吹き出す所だつたが、その胡麻の蠅と今が今まで、一しよに酒を飲んでゐたと思や、忌々しくもなつて来ての、あの野郎の手が胴巻の結び目をほどきにかかりやがると、いきなり逆にひつ掴めえて、捻り上げたと思ひねえ。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "『毎日々々、用にばかり追はれてゐて、読む事も何も出来るもんですか、あなたとは違ひますよ』　今が今まで考へてゐた、谷に対する感情をそのまゝむき出しに、弾き返すやうに云つて逸子は口を一文字に引き結んで黙つた。",
              "citation": {
                "source": "惑ひ",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の住居っている地理上の関係から、常に本郷三田間を連絡する電車にばかり乗っていたため、巣鴨方面から水道橋を通って同じく三田に続く線路の存在に、今が今まで気がつかずにいた自己の迂闊を深く後悔した。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "男らしく罪に伏したまえ」　子供、子供と今が今まで高をくくりし武男に十二分に裏をかかれて、一｜腔の憤怨焔のごとく燃え起こりたる千々岩は、切れよと唇をかみぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちやうど今が今まで不思議な夢のなかにゐた、さういふ思ひがするのであつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう舞台で倒れたまま、今が今まで、楽屋で寝てえたんじゃないか。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「日本橋は人形町、森田屋という国産問屋、それが私の隠れ家でした」「人形町の森田屋といえば、江戸でも一流の国産問屋だが、それがお前の隠れ家だとは、今が今まで知らなかった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃は復た保護貿易主義らしいものを唱へて居るが、元來自由貿易策は英國の國是ともいふべき位のもので、自由黨でも保守黨でも此の政策には今が今まで指一本も差しかねたものであるが、彼れが大膽にも之れを變更しようと試みるのは、全く時代精神の傾向を見拔いて居るからだ。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃は復た保護貿易主義らしいものを唱へて居るが、元来自由貿易策は英国の国是ともいふべき位のもので、自由党でも保守党でも此の政策には今が今まで指一本も差しかねたものであるが、彼れが大胆にも之れを変更しようと試みるのは、全く時代精神の傾向を見抜いて居るからだ。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は今が今まで暗い所へ行くよりほかに用のない身と覚悟していたんだから、藪から棒に働く了簡はないかねと聞かれた時には、何と答えて善いか、さっぱり訳が分らずに、空脛を突っ張ったまま、馬鹿見たような口を開けて、ぼんやり相手を眺めていた。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は今が今まで死ぬ気でいた。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "また自分の未熟なところを発表するようだが、実を云うと汽車賃の事は今が今まで自分の考えには毫も上らなかったのである。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この牛小屋で一夜を明す事が、それほどの慰藉を自分に与えようとは、牛小屋を見た今が今まで、とんと気がつかなかった。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は満洲にいる安井の消息を、家主たる坂井の口を通して知ろうとは、今が今まで予期していなかった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は旨うござります」「随分豪傑ね」　下等な書生のうちには猫を食うような野蛮人がある由はかねて伝聞したが、吾輩が平生｜眷顧を辱うする多々良君その人もまたこの同類ならんとは今が今まで夢にも知らなかった。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と言つたらいゝか其にほひは、今が今まで吸つて来た外の空気とは、まるきり、異つてゐた。",
              "citation": {
                "source": "トラピスト天使園の童貞",
                "author": "三木露風",
                "note": "青空文庫"
              }
            },
            {
              "text": "糟谷はいまがいままできょうの土曜日ということを忘れておったのだ。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
