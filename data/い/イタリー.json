        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "来年の夏は、友人と一緒にイタリーを旅行する計画を立てています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このレストランでは、本場のイタリー料理を味わうことができます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新の経済指標によると、イタリー経済は緩やかな回復基調にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ルネサンス期の芸術は、特にイタリーで花開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女はイタリー製の革製品を愛用しており、その品質は抜群だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わぁ、この絵、すごく素敵！やっぱりイタリーって芸術の国だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イタリーとフランスは、地中海政策で連携を深めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "スペインや、イタリーでは、ナポレオンの方を向いて、政界が退進した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムッシュウ・ドュフランは呆れた顔をして夕暮の明るいイタリー街へ出た。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、桃の肉が溶けているイタリーのヴェルモットはありませんかしら」　と誂えて置いて、トオクを冠った女客がホールの鏡壁の七面へ映る七人の自分に対して好き嫌いをつけている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧巴里の遺物　オペラの辻を中心に、左右へ展開する大通とイタリー街のキャフェたちは、朝の掃除をしまって撒いた赭砂の一掴みを椅子やテーブルの足元に残している。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一番　イタリー街の朝のキャフェの一つのテーブルにぐったり肱を落した絹襟巻の紳士は、マデレン寺院を中心に直径半マイルほどの円囲内に地潜っている賭博宿の一つから出て来たものだ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンチングを横っちょにかむり、何か腹掛けのようなものを胸に当てたアイスクリーム屋のイタリー人が、いつか焼栗売りに変っている。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピタゴラスはイタリーで長い間地下室に籠っていた後に痩せ衰えて骸骨のようになって出て来た。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太利女の堅気な臭にふと眼が覚めると廊下でフランス人の車掌とイタリー人の官憲とが僕を指して僕のワイシャツに僕のフランスの港の生活が絵のように書いてあると云ってわらっているのだ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のイタリーとエチオピアの戦争ってものは、元来イギリスの資本家筋が欧州の勢力の平衡を破り、エチオピアの利権を掴みたいばっかりに巧みに双方を煽動して始めさせたものですが、そいつがマンマと首尾よくイギリスの都合の宜い解決しちゃたまりません。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも先にイギリスとイタリーとが戦端を開きさえすればいいのですから……」「そんなに訳なく戦争を始めさせることが出来ますかしら」「なんでもないことです。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際スエズにいるイギリスの軍艦のドレでもいいから一艘、爆破さえすれば、直ぐにイタリーのせいだと思って戦争を始めます。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリー名物の傘松は実を採られ防風林に使はれる。",
              "citation": {
                "source": "女性と庭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　白にレモン色の模様をとった屋台車を置いてアイスクリーム売りのイタリー人が燕のひるがえるのを眺めていた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "タクシーでオペラの辻まで乗りつけて、そこからイタリー街へ寄った、とあるキャフェで軽い昼食を摂りながら娘に都大路の祭りの賑いを見せていると、新吉はいろ／＼のことが眼の前の情景にもつれて頭に湧いた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "角のカフェ・ド・ラ・ペイとこっちのイタリー街の角との間は小広く引込んだ道になっていて、其の突当りがグランド・オペラだが此所からは見えない。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "にわかに弾いたように見ひらいた彼の瞳孔には生気の盛り上るイタリー街の男女の群の揉み合う光景が華々しく映った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかロシヤでも、よゆうの少い沿海州の市民たちでさえも、全力をあげて日本を救えとさけび、フランス、イタリー、メキシコ、オーストラリヤでは、日をきめて興行物一さいをさしひかえ各戸に半旗を上げて、日本の不幸に同情を表し、義えん金を集めました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（８）Niccolo Machiavelli（一四六九―一五二七）――マキアヴェリズムでよく知られているイタリーの政治家、著作家。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "（15）Tammaso Campanella（一五六八―一六三九）――イタリーの僧侶で哲学者。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーバー海峡では体が宙を飛び、ウラル山やイタリーでは胸のすく程晴々しい喜びが雲のやうに湧いた。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人に向つて――」　山崎の仕事といふのは、半年程前に彼に伴れられて始めて日本に来たイタリー人である細君の気嫌を取ることが主だつた。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の香が丁子の様だからイタリーでジロフリエル、英国で中世ジロフル、共に丁子花の義だ。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリーの百姓、これを熱愛の象とし、彼得尊者特に好むとて、その忌日（六月廿九日）をカーネーション日と称ふ。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がフランス、イタリーを放浪して帰つても僕には何の誡められることもないので、退屈でならない、君だつて僕から誡められるようなことはなからう。",
              "citation": {
                "source": "思ひ出した事（松竹座）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリーなどの味もしてゐる。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはイタリー人がマカロニーをいかにして食うかという講義を聞いた」と言いながら、そばへ寄って来て三四郎の肩をたたいた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーキュ　さゝ、足下はイタリーで誰れにも負を取らぬ易怒男ぢゃ、直に怒るやうに仕向けられる、仕向けらるれば直怒る。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリーの先端、メッシナ海峡にさしかかって、左岸にシシリイ島のメッシナ、右岸にレジア、門司、下関という距離だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に堂々たるイタリーの行進と拍手湧くが如きその後だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の女　　第二の女　　第三の女　　非番の老近侍　　帝の供人同宮人数多　　法王の供人数多及び弟子達　　イタリー、サレルノの農夫の老夫婦　　人民数多、及び不信心な遊び者　　　　第一幕　　　　　第一場　　　　場所　　ヘンリー王の城内の裏手景　近侍達の住んで居る長屋体の建物の中央にある広場。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
