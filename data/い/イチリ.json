  },
  {
    "uuid": "e7357f64-01b8-57cb-81dd-29c2c5c82616",
    "entry": "一里",
    "reading": {
      "primary": "いちり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "2.44 miles",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "かつての街道沿いには、今も一里ごとに土を盛り上げて松を植えた一里塚が残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一里や二里の距離なら、車を使わずに自分の足で歩くのが昔の人の当たり前だったんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「もう一里、あと一里だけ歩こう」と自分を叱咤しながら、重い足を前に進めて峠を越えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "郷里へ引上げると間もなく次姉は市から一里くらい西のＡ村に嫁入りをしたので、あとは全く静かな淋しい家庭であった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それだけにまた、自分にとっては三十余年前の冬のある曇り日のこの珍しい体験が、過去の想い出の中に聳え立った一里塚のように顕著な印象を止めているものと思われる。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ほとんど一里も先と思はれるほどの遠方、幽潭の底を覗いた時のやうな何やら朦朧と烟つてたゆたうてゐるあたりに、小さな純白の水中花みたいなものが見える。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "両山脈の相対する間隔は、直径約一里もあろうか、間の岳の頂までは、この河原から一里半で達せられる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶頂から山越しに向へ一里半も下りると、中股というへ出られる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺はことし六十五であるが、穂高山の主と言われるくらいな山男で、何でも二十五、六歳のころ、旧の師走であったが、三人連れで、この温泉の上まで、猟にやって来たとき、雪崩れに押し流されて、一里も下まで落っこち、左の脚を折ったということで、もし自分一人であったら、到底命は助からなかったろうと、物語った。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし谷や盆地のは夏になると大概解けてしまうが、崖の雪は盛夏でも日本アルプスのは、半里から一里位の長さで繋がっていることがある。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンクリートの橋があつて、そこで県道に出て、そこから私たちの家まで、約一里あつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "関の小まんが米かす音は一里聞えて二里響く。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大長柵へは一里に遠いッて云いましたねイ」「そうです、一里半には近いそうだが、もう半分の余来ましたろうよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限に対しては一里も千里も価値は大して変らない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥の孝吉は一日に二度ずつ、一里ばかり向うの町へ氷を取りに自転車で走った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復一里もあるその部落へその女は負い籠を背負って行ったそうだが、結果がどうなったかは帰って来ても喋らない。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏は、次第に遠く、一里も、二里も向うの方まで、雪の上におりながら逃げて行った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村の教会は麹町区ですから、一里の道のりは確かにあります。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一里の間、暗い山の手の道をたどって来たからでしょう。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村も同じ心、後になり先になり、二人で歩いていると、時々は路傍に腰を下ろして鉛筆の写生を試み、彼が起たずば我も起たず、我筆をやめずんば彼もやめないという風で、思わず時が経ち、驚ろいて二人とも、次の一里を駆足で飛んだこともあった。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、上り一里、下り一里半の山を越して遠くへ行った。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが弾丸は、悉く、一里もさきの空へ向ってとび上った。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田たちの中隊は、※昂鉄道の沿線から、約一里半距った支那部落に屯していた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食糧や、慰問品の受領に鉄道沿線まで一里半の道のりを出かけていた十名ばかりが、帰ってきたのだ。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、本隊から約一里前方へ出て行くのである。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一里の距離は、彼等に、本隊への依頼心を失わせてしまった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはもう峠を一つ越えればすぐ家でしたし、一里もないのでしたからそれに天気も少しは曇ったってみちはまっすぐにつゞいてゐるのでしたから何でもないと一郎も思ひました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫だはんて、なあにあど一里も無ぃも。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い幌のなかの乗客の眼がみな一様に前方を見詰めている事や、泥除け、それからステップの上へまで溢れた荷物を麻繩が車体へ縛りつけている恰好や――そんな一種の物ものしい特徴で、彼らが今から上り三里下り三里の峠を踰えて半島の南端の港へ十一里の道をゆく自動車であることが一目で知れるのであった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州白石の城下より一里半南に、才川と云ふ駅あり。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが肉体いちぶいちりん動かさず、すべて言葉で、おかゆ一口一口、銀の匙もて啜らせ、あつものに浮べる青い三つ葉すくって差しあげ、すべてこれ、わが寝そべって天井ながめながらの巧言令色、友人は、ありがとうと心からの謝辞、ただちにグルウプ間に美談として語りつがれて、うるさきことのみ多かった。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤いちりめんのひもの両はしに、小さな銀の鈴をつけて、それをその糸へつるしました。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お高祖頭巾はもとより、着物も羽織もどっしりと、目方の重いちりめんでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
