[
  {
    "uuid": "b16ab6d7-6376-5727-95a6-aecc2b2d4cfd",
    "entry": "一利",
    "reading": {
      "primary": "いちり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
