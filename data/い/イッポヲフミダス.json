        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいスキルを学ぶために、ついに一歩を踏み出す決心をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このアイデア、本当に面白いと思うんだ。よし、明日からプロジェクトに一歩を踏み出そう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "起業は大きな挑戦だが、彼女は夢の実現に向けて一歩を踏み出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年温めていた計画を実行に移すため、彼はついに第一歩を踏み出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
