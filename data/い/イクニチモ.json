          ],
          "literary": [
            {
              "text": "一歩門を出さへすれば、つい其處の路地にでも川岸にでも電車停留場にでも、兎に角うちの庭とは比較にならない程いゝ題材が、勿體ないやうに無雜作に、顧みられずにころがつて居る、わざわざ旅費を出して幾日も汽車を乘り※す必要などはないやうに思はれる。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾日も喪心者のようになって彷徨したと云っている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて私の或る知人が、シベリヤ鉄道の旅行について話したことは、あの満目｜荒寥たる無人の曠野を、汽車で幾日も幾日も走った後、漸く停車した沿線の一小駅が、世にも賑わしく繁華な都会に見えるということだった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾日も十分な食事が取れないために乳呑兒をかかへながら妻は乳が涸れるほどの非慘さだつた。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月になってから雨天や曇天がしばらく続いて涼み台も片隅の戸袋に立てかけられたままに幾日も経った。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しそれは一時のことで、お蝶の姿が幾日もみえないと、彼女は姫にあわせろと云って又狂い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは入り込んだ町で、昼間でも人通りは少なく、魚の腹綿や鼠の死骸は幾日も位置を動かなかった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでから幾日も経ち、内臓なども乾きついてしまった蠅がよく埃にまみれて転がっていることがあるが、そんなやつがまたのこのこと生き返って来て遊んでいる。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか英国人の宣教師の細君が旧城跡の公園でテントを張って幾日も写生していた事があった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "総入れ歯の準備として、生き残った若干の歯を一度に抜いてしまったそのあとで顔じゅうふくれ上がって幾日も呻吟をつづけたのだそうである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地形測量をする測量班員が深山幽谷をさまようて幾日も人間のにおいをかがずにいて、やっとどこかの三角点の櫓にたどりつくと、なんとなくうれしさとなつかしさに胸をおどらすという話である。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ旅費を出して幾日も汽車を乗り回す必要などはないように思われる。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "角の立つ様な隆鼻を中心にして、なかだかな、おとがいの張った男らしい顔の、怜悧相な額には、油もつけず幾日も梳らない為に、煤気を帯びた様な黒い、たっぷりした散髪が掩いかぶさって居る為に思いきって切れ長なま瞼の底に、濃情と憂愁とを交ぜ湛えた様な両眼の色がいやが上にも奥深く見えるのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな苦しい、緊張つた、いらだたしい生活が、幾日も幾日もつづいたとき、男は唸くやうになつて、女の膝に身をなげかけた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雪は其後幾日も降続いて、町も村も皆｜埋められた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "膏薬を剥がして眼を洗はせたが、熱い煉薬が眼に沁みたので、善吉はその後幾日も眼医者に通はねばならなかつた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、臨月であつたのでもあらうが、已に土の下にうづめられた死骸が赤児を生んで、その赤児が幾日も無事に生きてゐたのは、一種の不思議として人々をおどろかしたのである。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃はまだ旧暦の秋もおいおいに暮れかかって、深川には時雨めいた空が幾日もつづいた。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まあ話してみよう……　……お正月の松がとれてから未だ幾日も過ぎない頃であった。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾日もこんなところにいて鬱々して来たから。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、そうしたまま、幾日も幾晩もすぎていったのですもの。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こうして、幾日も幾日も、すぎました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは、おも苦しく悲しい日が、幾日も幾日もつづきました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼が目を覺した時、不幸な、忘れられた槽の中で、幾日も幾日も、おそろしい飢饑を忍ばねばならなかつた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたにあひ、あなたにわかれ、おなじ日のいくにちもつづくとき、わたしはかなしみにしづむやうになりました。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡す限りひろびろとした荒野の中や、いつ通りぬけられるかわからない森の中などに、いくにちも迷いこんだり、けわしい山のすそを遠くまわったり、雨が降って旅ができなかったり、いろんなことがあるうえに、夜はいつも馬車の中に寝なければなりませんでした。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それが、いくにちもいくにちもふりつづけたら、まあせかいぢうはねこだらけ、いぬだらけ、ねずみだらけになるでせうね。",
              "citation": {
                "source": "もしも、あめのかはりに",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
