[
  {
    "uuid": "34bcd435-20c4-54e4-b4b0-0803736e7826",
    "entry": "居丈高",
    "reading": {
      "primary": "いたけだか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
