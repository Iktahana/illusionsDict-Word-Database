          ],
          "literary": [
            {
              "text": "しかし灸の場合には事がらが精神的ばかりでなくともかくも生理的な生き身の一部に明白な物理的化学的な刺激を直接密接に与えるのであるから、きくきかぬが生理的に実証の審判にかけられうるわけだと思われる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "説明解説というものくらい生き身のものから匂いも香も振り捨て、物事を薬品臭く押花に乾燥してしまうものはありません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、いぶかしいのは生き身もろとも、共焼きにしたその青焼き人形です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "松魚にしてもこんな生きのいい生き身はありゃしねえやい！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが歪んだ人間の使いかたであるからと云って、その歪みを生き身にうけて、云って見れば自分たちの肉体で歴史の歪みをためてゆかなければならない私たち現代の女が、歪みのままに自分の気持を萎えさせて、どうせ、と云ってしまったら、どこから自分たちの成長の可能がもたらされよう。",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、すぐ、生き身でない死者の非情さが、富岡の手を払ひのけた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風邪をひいたそうだ、生き身だからね――」「風邪？",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き身を捨てた気持ち、分ったわ。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい病気でも、生き身だから、ふしぎはない。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦死の公報があり、遺骨も到着し、葬式も済まされ、既に仏さまとなり、戸籍面から抹殺されてる者が、終戦後、ひょっこり生き身で帰って来た、そういう話が幾つも伝えられていた。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の生き身が常に變化してゐるやうに、ほうむずは、生きて移つてゐる。",
              "citation": {
                "source": "人間惡の創造",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き身の人間の男と女とを、贄釜の中へたたっ込まなけりゃアならねえ！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "口を結び、眼を見開き、逆賊の行為を怒られるがように、義博の顔をひたと見詰め、御首級は生き身さながらであり、今にも叱咤の御声が、迸り出るかに拝された。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まことこの時東の空が、薔薇色の光を産み出したが、その光に照らされた、大塔宮様の御顔は、依然として生き身さながらであったが、見ひらかれておわした御眼は閉ざされ、食いしばっていられた御唇は、優しく穏やかにむすばれていた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書館の中に生きることは、この「形」の発展の形成を、生き身をもって生きることにほかならない。",
              "citation": {
                "source": "図書館に生きる道",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "不生不滅、実報寂光の生き身をかたどり、天皇自ら磨かれたという金銅十六丈の廬遮那仏も首が焼け落ちて大地に転がり、身体は熱に鎔けて醜い青銅の堆積とはなった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き身の人間がこんなに斬りさいなまれ乍ら、默つて居るわけはねエ、いくら柳原でも、家もあれば人も通る」　平次は早くも事件の祕密に觸れて行くのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは生き身へ墨を入れたのとは違うように思うが」「？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き身に入墨したのは、墨が流れるから、あんな具合に砂目に入るものじゃない――あれはお前」「――」　八五郎はゴクリと固唾を呑みました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ光太郎はこの少女の若すぎる生き身を感じるときに、智恵子とたった二人きりでいたことに気づいて、この少女をみるはればれしさにある抗議を自身の中に感じた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き身の人間がこんなに斬りさいなまれながら、黙っているわけはねエ、いくら柳原でも、家もあれば人も通る」　平次は早くも事件の秘密に触れて行くのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は女記者、それから女優、近頃ではデパートで、万人に生き身をさらすマネキンガールまでやって居るという噂でした。",
              "citation": {
                "source": "悪魔の顔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾年も彼女はその神秘な生き身を、全ヨーロッパの運命の廻転軸たらしめたのである。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生き身を、こんなところにとじ込められ、正気なものを気違いあつかいにされてどうして生きていられよう。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き身のまま、神になって行くような気がして来た。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは生き身の天使でございますよ……人間の世界へ天降りましたんで、……でも、おわかりになりますかしら……」「ほら、あんなに体じゅう震わせて、まるで痙攣でも起こしているようだわ」とワルワーラは腹立たしげにことばを続けた。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、いまじたんだを踏みながら、わたくしのことを道化と言った娘も、やはり生き身の天使なんでございまして、わたくしのことを道化呼ばわりしたのも、もっとも至極なんでございますよ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "光明を放つ生き身の謎――私は不思議を明らめるように、そのままそこらを歩き廻った。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを料りながら、生き身を釣針につける。",
              "citation": {
                "source": "瀬戸内の小魚たち",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの嘴で丹念に、這奴我が胸、我が腹の毛を殘りなく※り取つて、赤裸にした處を、いきみをくれて、ぬぺらと出して、葉隱れに……へたばる人間をぎろりと睨んで、噴飯す由。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
