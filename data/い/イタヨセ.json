    "definitions": [
      {
        "index": 1,
        "gloss": "Itayose (trading method used by Japanese exchanges)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
