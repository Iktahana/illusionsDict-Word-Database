        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悲壮な感じにも衝たれたが、また、自分が無謀なその企てに捲き込まれる嫌な気持ちもあった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は告げ口した婆さんにも麻川氏にも何だか嫌な気持ちがしたが「あのお客さんあんまり大声で話したててたからね」と云ったあと、いくらか麻川氏に気の毒な感じもした。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は不機嫌な気持ちで家の中に入った。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも嫌な気持ちがなさるでしょう。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "町巾が其処だけ広がっているのが妙に嫌な気持ちにさせる。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の中に嘔き気がたまってくるようで、惨めな上に嫌な気持ちだ。",
              "citation": {
                "source": "復讐",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉が、わたくしたちの頭に沁みこみ、わたくしたちの身体を縛りつけるようで、じつに嫌な気持ちでした。",
              "citation": {
                "source": "花子の陳述",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌な気持ちというだけでなく、どこか心の隅に現実のことのように引っかかってきました。",
              "citation": {
                "source": "花子の陳述",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不吉な上に嫌な気持ちだった。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも云えない嫌な気持ちになった。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその嫌な気持ちを追い払うために、ただ静子のことばかりを考えた。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身倦怠、頭痛、悪心、嘔吐、眩暈、脱力などという嫌な気持ちだ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ、向きあって話をするなんて、まっぴらだったが、このごろは、二人っきりで鼻をつきあわしていても、そんなに嫌な気持ちはしない。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "再びウサギ狩りごっこの紙片を置き――橇の上の防水シートに包まれていた予備の紙束を使った際、何とも言えぬ嫌な気持ちになった――我々は陽の射す世界を後にしたのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
