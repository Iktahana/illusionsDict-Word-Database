        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "磯山に、暫し岩根のまつ程に、暫し岩根のまつ程に、誰が夜舟とは白波に、楫音ばかり鳴門の、浦靜かなる今宵かな、浦靜かなる今宵かな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯山に、暫し岩根のまつ程に、暫し岩根のまつ程に、誰が夜舟とは白波に、楫音ばかり鳴門の、浦静かなる今宵かな、浦静かなる今宵かな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏冠や、猛猛し眼の稜稜、尾羽、翼、はららぎぬ、はたはた、ああ、はたはた、岩根の、白羽蟻の吹雪と舞ふ柱を。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "足一騰宮は、行宮と　青の岩根に一柱坐す。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕃童は母をうしろに、敢て立つ、岩根｜蹴放つ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "足一騰宮は、行宮と青の岩根に一柱坐す。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）思へ、天業恢弘の黎明、鎭みに鎭む底つ岩根の上に宮柱太しき立てた橿原の高御座を、人皇第一代｜神倭磐余彦の天皇を、ああ、大和は國のまほろば、とりよろふ青垣、鵄は舞ひ、朗かにおほらかに草も木も言祝ぎ謳つた。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青き焔の如き波に洗はれたる低き岩根には、紅殼の毛星族（クリノイデア）いと繁く着きたるが、その紅の色は水を被りて愈※紅に、岩石の波に觸れて血を流せるかと疑はる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "山に生れた鬼子であるから、岩根を踏みはずしたり滝壺へ吸いこまれたりする気づかいがないのであった。",
              "citation": {
                "source": "魚服記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五葉の枝につけたのは、風に散る紅葉は軽し春の色を岩根の松にかけてこそ見め　という夫人の歌であった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "祠は神武天皇の御世にはじまり、底つ岩根に宮柱ふとしきたち、高天原に千木高知り、萬古儼として威靈を留む。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ高天の大み蔭、笑聲どよむ天人の美き歡喜のしたたりが、夜な夜な峰に雨ふりて、岩根けはしき谿間より、落ちつどひてや、白金の眞澄の色の吉野川、汝も時世の先達のつとめを分つ友となれ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂寞大海の礼拝して、天津日に捧ぐる香は、浄まはる潮のにほひ、轟く波凝、動がぬ岩根、靡く藻よ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂寞大海の禮拜して、天津日に捧ぐる香は、淨まはる潮のにほひ、轟く波凝、動がぬ岩根、靡く藻よ、黒金の船の舳先よ、岬代赭色に、獅子の蹈留れる如く、足を延べたるこゝ、入海のひたおもて、うちひさす都のまちは、煩悶の壁に惱めど、鏡なす白川は蜘手に流れ、風のみひとり、たまさぐる、洞穴口の花の錦や。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、岩根の一所に、人一人ようやくはいれるくらいの、小さい岩穴が開いていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、富士の底の岩根を数里に渡って刳り抜いたところの、天工自然の洞窟なのである。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の岩根を貫き流れる、名のない大河は名のないように、どこへ向かって流れるものか、今日も尚解らないのであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若葉さす野辺の小松をひきつれてもとの岩根を祈る今日かな　こう大人びた御｜挨拶をした。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たが世にか種は蒔きしと人問はばいかが岩根の松は答へん　かわいそうですよ」　ともそっとお言いになったが、宮はお返辞もあそばさずにひれ伏しておしまいになった。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "また奥に、珍しく承った芽ばえの二葉を、私｜風情が関心を持つとは申されませんが、命あらばそれとも見まし人知れず岩根にとめし松の生ひ末　よく書き終えることもできなかったような乱れた文字でなった手紙であって、上には侍従の君へと書いてあった。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女院、さて如何にやと仰せければ、大納言佐の局涙を押さへて、岩根踏み誰かは訪はん楢の葉の戦ぐは鹿の渡るなりけり　女院哀れに思召して、此歌を窓の小障子に遊ばし留めさせおはしますとある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧はおち、鷲はとび、岩根の淵の魚をとらふ。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは、昨日無駄に歩いた岩根や草やぶを踏みつけて歩いた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝるとき、湿りたる岩根を踏めばあゝ、わが出｜生の記憶甦へる。",
              "citation": {
                "source": "無題",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩根　木根立　物言ひいでむおなじく、「ある時」と題した作物である。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩根・木根立物言ふ時代は、日神隠れ給ひ、草木に到るまで妖言を発した。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　岩根・木根・草のかき葉我々の国の文学芸術は、世界の文学芸術がさうであつたやうに、最初から文学芸術ではなかつた。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからはかうして部屋に籠つて煖炉のそばにゐるのが一等好いわね、あなたは幸福だわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな女の子がほしいわねえ」と妻がいつにない事を言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ偉いわねえ」「おら貰うべえ」四郎は得意な顔つきをした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
