        "examples": {
          "standard": [
            {
              "text": "明日の会議について、参加者間で事前に時間を言い合わせる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「来週のピクニック、場所と集合時間を前もって言い合わせておこうよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事件の共犯者たちは、警察の取り調べに対し、互いに供述内容を言い合わせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新製品のプロモーション戦略について、マーケティング部と営業部で事前に担当範囲を言い合わせておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うん、その件はもう○○さんと言い合わせてあるから大丈夫だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家族旅行の計画は、子供たちの希望をいくつか聞きながら、両親が事前に言い合わせて進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
