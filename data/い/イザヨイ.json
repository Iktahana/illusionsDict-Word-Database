[
  {
    "uuid": "36022bbe-2f2b-5d1e-abd7-796592e97636",
    "entry": "十六夜",
    "reading": {
      "primary": "いざよい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sixteen-day-old moon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "十五夜の明かりが過ぎ去り、空には十六夜の月が静かに昇る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "縁側に腰掛け、秋風に吹かれながら十六夜の月を眺める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "文学作品には、十六夜の月を題材にした詩歌が数多く残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ああ、今日は十六夜か。月の出が少し遅いな。」と、祖父が呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水面に映る十六夜の月が、ゆらゆらと幻想的な光を放っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い寺の瓦屋根を、十六夜の淡い光が優しく照らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜が更けるにつれて、雲間から十六夜が顔を出し、あたりを明るくした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "漁舟江心に向かいてこぎ出せば欸乃風に漂うて白砂の上に黒き鳥の群れ居るなどは『十六夜日記』そのままなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧暦｜十六夜の月が赤く森から出る。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たまたま逢ふに切れよとは、仏姿にあり乍ら、お前は鬼か清心様」という歎きは十六夜ひとりの歎きではないであろう。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また例えば、清元の「十六夜清心」のうちの「梅見帰りの船の唄、忍ぶなら忍ぶなら、闇の夜は置かしやんせ」のところも同様の形をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は二十六日ぢゃ、来月二十六日はみなの衆も存知の通り、二十六夜待ちぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月二十六夜ならば、このお光に疾翔大力さまを拝み申すぢゃなれど、今宵とて又拝み申さぬことでない、みなの衆、ようくまごゝろを以て仰ぎ奉るぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二十六夜の金いろの鎌の形のお月さまが、しづかにお登りになりました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞその澄み切った桔梗いろの空にさっきの黄金いろの二十六夜のお月さまが、しづかにかかってゐるばかりでした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は二十六日じゃ、来月二十六日はみなの衆も存知の通り、二十六夜待ちじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月二十六夜ならば、このお光に疾翔大力さまを拝み申すじゃなれど、今宵とて又拝み申さぬことでない、みなの衆、ようくまごころを以て仰ぎ奉るじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二十六夜の金いろの鎌の形のお月さまが、しずかにお登りになりました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその澄み切った桔梗いろの空にさっきの黄金いろの二十六夜のお月さまが、しずかにかかっているばかりでした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日――十六夜にも、また晩方強震があつた――おびえながら、この記をつゞる。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌穴の底も極めたければ、滝の裏も覗きたし、何か前世の因縁で、めぐり逢う事もあろうか、と奥山の庚申塚に一人立って、二十六夜の月の出を待った事さえあるんです。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴物停止は歌舞音曲のたぐいを禁ずるに過ぎないのであるが、それに伴って多人数の集合すること、遊楽めいたこと等は、すべて遠慮するのが其の時代の習慣であったので、さし当り七月二十六夜の月待ちには高台や海岸に群集する者もなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "」第十六夜「わたしはひとりのプルチネッラを知っています」と、月が言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十六夜「きのうの夜明けのことでした」これは月自身が言った言葉です。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度仲秋の十六夜の後一日である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六夜の夜半でござった。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「楓どの、あの月を見やれ、綺麗な月ではござらぬか」「ほんに、十六夜の月はおぼろに鈴鹿山……」　と、楓がうっとりと歌いかけると、佐助は何思ったか急にそわそわして、「鹿の子まだらのアバタの穴を……」　照らしているのじゃと下の句を言いざまに、さらばじゃとはや駈け出してしまった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は七月の二十六夜、八月の十五夜、九月の十三夜について、皆一つずつの怪談を知っている。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、第一は二十六夜――これは或る落語家から聞いた話だが、なんでも明治八、九年頃のことだそうだ。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜は二十六夜さまだというから、おまえさんも拝みに行っちゃあどうだえ。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は旧暦の七月二十六夜だ。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "話には聞いているが、まだ一度も拝みに出たことはないので、自分も商売柄、二十六夜｜待というのはどんなものか、なにかの参考のために見て置くのもよかろうと思ったので、涼みがてらに宵から出かけた。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六夜の月の出るのは夜半にきまっているが、彼と同じような涼みがてらの人がたくさん出るので、どこの高台も宵から賑わっていた。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芹川さんのお家は、私の家の、すぐ向いで、ご存じでしょうかしら、華月堂というお菓子屋がございましたでしょう、ええ、いまでも昔のまま繁昌して居ります、いざよい最中といって、栗のはいった餡の最中を、昔から自慢にいたして売って居ります。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下から見ると、つめたく露を置いた甍や、丹塗りのはげた欄干に、傾きかかった月の光が、いざよいながら、残っている。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は十五夜でしょう、今夜は十六日ですからね、いざよいのお月様をいただいて、あたしの拙い琵琶を神様へ奉納をして上げたいと思って、さいぜんからそのことを考えて来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はいざよいですからね」　ところがこの十五騎の蹄の音がやむと暫くたって、府中の町がひっくり返るような騒ぎになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
