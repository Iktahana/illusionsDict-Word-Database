        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議で自分のミスを指摘された際、彼は機転を利かせた言い抜けでその場を切り抜けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "証拠が固められているにも関わらず、被疑者は巧みな言い抜けを繰り返し、捜査を撹乱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今回はちょっと体調が優れなくて」という言い抜けは、約束を破る際の常套句になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国民からの厳しい追及に対し、政治家は具体的な政策論ではなく、言葉の言い抜けに終始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、締め切りに遅れた理由を説明するのではなく、部下のせいにするという言い抜けを試みた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「だって、他に選択肢がなかったんだ」という彼の言い抜けは、誰にも納得されなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その弁護士は、被告人の無罪を主張するために、あらゆる角度から言い抜けの筋道を探った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "怠惰ほど、いろいろ言い抜けのできる悪徳も、少い。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、のらくら者の言い抜けである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、今さら卑怯に言い抜けようとして、おれには確かな証人があるぞ」「そのような喚讒を誰が言うた」「おお、玉藻が言うた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、夫人の言い抜けの巧妙なことを知っている警察は、もう少し周囲から証拠固めをした上でと、捕縛を※躇しているうちに、一九〇九年四月二十八日の夜、ガンネス農園に怪火が起って、家も夫人も綺麗に焼けて終った。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うでうまく言い抜けられるような手段で、おれの顔を汚すのを抛っておく、樗蒲一はない。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、燈火はカンカンとかがやいていることであるし、喫みかけた煙管はそこに抛り出してあるのであるし、その煙草の吸殻の煙ものんのんと立ちのぼっているのであるから、外から見ても、内から見ても、人がいないとは言い抜けられない有様であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実に、彼女の成功は、英雄ならばけっして持ってはならぬすべての性質――言い抜け上手、瓢箪鯰、不決断、狐疑、吝嗇などのおかげなのである。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い抜けは無用だぞ、よいか！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "証拠呼ばわりをして言い抜けをしようなどとは、いよいよ以て図々しい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "市中騒動の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "親友だからって相談をする必要はないだろうと思うんだ」「それが言い抜けってものだ」　と吉川君が極めつけた。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう言い抜けの道があればこそ、君はさっきから、少しも不安を感じなかったのだ。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、あいつのもう一人の息子はキューバで黒人女と罪作りな生活をしていると言い抜けて、新聞ネタに出せるものなら出してみろってさ。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には容易に指摘することができ、かつ容易には言い抜けることのできないものがある。",
              "citation": {
                "source": "ファシズムとは何か",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しい言い抜けを」「いや、いや。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには深い仔細のあること」「言い抜けは無用だ、公辺にはもう真相は知れている」「そもそも、その真相とは、劉高の拵え事です。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば、すべてこの新吉が一存でしたこととして、万一の時にも、お店にはかかわりないように言い抜けまする」「万事お前に任せておきましょう」「ありがとう存じます。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "足で頭をなでてやったまでのことだ」「ば、ばかな言い抜けを。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い抜けらしい苦渋は見えぬせいか、道誉も左近も「……では」と、得心の色をなごませて、やっとその場は事なきをえたものだった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何で、無断上洛にございましょうや」「それや言い抜けぞ。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉の裁きに屈せず、貴公はあくまで言い抜けろ。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日まで彼女は、捕縛された場合の一つのいいぬけを持っていた。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "網と釣道具のほか、パラン（山刀）が一梃とアカ汲みの桶だけですけれども、こんなところにインドネシアが二人もマゴマゴしているわけはないから、捕まれば、いいぬけはできませんのです。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんといいぬけができるようになっている。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ああ、なんといううまいいいぬけでしょう。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただで松明をやるはずがない」「いいえ、なんにももらいなんかしやしません」「まだいいぬけをしやがるか！",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
