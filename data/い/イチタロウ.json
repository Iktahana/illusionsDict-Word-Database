        "examples": {
          "standard": [
            {
              "text": "縦書きのビジネス文書を作成する際には、一太郎の機能が非常に役立ちます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い官公庁の書類は、今でも一太郎形式で作成されているケースが散見されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このデータ、一太郎で開くとレイアウトが崩れるんだよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本語の文書作成においては、一太郎独自の表現機能がいまだに根強い人気を誇ります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パソコン教室では、基本的な操作を学ぶために一太郎のテキストがよく使われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一太郎の最新バージョンでは、クラウド連携がさらに強化され、利便性が向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まさか、まだ一太郎で企画書作ってる人がいるとは思わなかったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
