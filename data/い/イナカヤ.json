    "definitions": [
      {
        "index": 1,
        "gloss": "farm house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏休みは、祖父母の田舎家で過ごすのが恒例だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い田舎家を改装して、カフェとしてオープンしたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "静かな田舎家で、読書三昧の日々を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "茅葺き屋根の田舎家は、日本の原風景を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この句を読むと、田舎の閑寂な空気や、夏の真昼の静寂さや、ひっそりとした田舎家の室内や、その部屋の窓から見晴しになってるところの、広茫たる一面の麦畑や、またその麦畑が、上風に吹かれて浪のように動いている有様やが、詩の縹渺するイメージの影で浮き出して来る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗壁の田舎家の奥座敷で主人と中老の男の盃の献酬がはじまる。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の落葉のままが風雅なら、どんな田舎家にも千家茶道宗家の看板は掲けられましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と笑って、一つ一つ、山、森、岩の形を顕わす頃から、音もせず、霧雨になって、遠近に、まばらな田舎家の軒とともに煙りつつ、仙台に着いた時分に雨はあがった。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤けた梁や柱に黒光りがするくらい年代のある田舎家の座敷を、そっくりそのまま持ち込まれた茶座敷には、囲炉裏もあり、行灯もあった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻んだ菜や、水を与えられると、籠の目を透くレモン色の小さい姿が激しく動くのが見え、田舎家の午前の無言の静けさは銀の蚤でも螫すように急に品よく可愛らしくざわめき立ちました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流めての方にて折れ、こなたの陸膝がしらの如く出でたるところに田舎家二、三軒ありて、真黒なる粉ひき車の輪｜中空に聳え、ゆん手には水に枕みてつき出したる高殿の一間あり。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れめての方にて折れ、こなたの陸膝がしらのごとくいでたるところに田舎家二三軒ありて、真黒なる粉ひき車の輪｜中空にそびえ、ゆん手には水にのぞみてつきだしたる高殿の一間あり。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎家に猫はめずらしくないが、その猫は不思議に大きく、普通の犬ぐらいに見えるので、友蔵も眼をひからせた。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗末な泥土塗りの田舎家もイタリアと思えばおもしろかった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんな風にして、私たちはこの田舎家で、思う存分幸福に暮していたんです。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち我々の馬車の両側には、英国の特有の田園が展開し、方々に散在している田舎家は、今日の殷盛な人口を思わせ、またあっちにもこっちにも、大きな四角な塔の教会が、平原の地平線の上に屹立し、緑の濃い風景、――と、昔の東部アングリアの、光栄と殷盛を想わしめるものであった。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは七、八軒さきの小さい茅葺屋根の田舎家で、強い風には吹き倒されそうに傾きかかっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面を広く取つてその中に風流な田舎家を造るです。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの魂がもとのからだに戻った時に、小坂部は小さい田舎家の奥に寝かされていることを発見した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿　今日野道をぶらついていると、一軒の田舎家の裏口に出た。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿と云うのが小さい田舎家で気味の悪い宿でした。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高いところへ昇って見渡すと、遠い村落に烟りのあがるのが見えたので、急いでそこへたずねて行くと、一軒の田舎家が見いだされました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸に繋がれた一艘の船には、長い間田舎家の茶の間に据ゑられた長火鉢だの、茶箪笥だのがそのまゝ積まれてあつた。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は驚いて、慌てて、寝衣の儘、前の雨戸を烈しく蹴つたが、幸にも閾の溝が浅い田舎家の戸は忽地外れて、自分は一簇の黒煙と共に戸外へと押し出された。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんもり繁つた雑木林のなかから、田舎家の白壁が見えて、夕日が明るくそれに射つてゐて、いかにも気持の好い画だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の実10・１（夕）　秋も丁度半ばで、田舎家の軒に柿の実が紅く色づくやうになつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんもりとした其の枝を通して、段々下りの谿底に、蹲踞むだやうな寺の建物が見え、其の屋根を見渡しに、ずつと向うの山根に小ぽけな田舎家が零れたやうに散ばつてゐて、那様土地にも人が住むでゐるのかと思はしめる。",
              "citation": {
                "source": "茸の香",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い田舎家の奥に閉じ籠って、あまり外へ出たことのない母親は、近所の女房連の集まっている井戸端へ出て行くのが、何より厭であった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼろげに目に残っている田舎家の様子や、幼時の自分の姿が懐かしげに思い出された。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその石垣の上からしばらく自分の宿とする田舎家までも見ることは出来なかったまでも、耕地の多い対岸の傾斜に並ぶ仏蘭西の田舎らしい赤瓦の屋根を望むことは出来た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心で、岸本は田舎家の裏にある野菜畠へ行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "後のは森を背景にした牧場のさまで、遠く森の間に一軒の田舎家も見えた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は牧野と一緒に入口の石階を上って田舎家らしい楼梯の欄に添いながら二階の方へ行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくのいなかや　奧多摩の山峽部落には、古く手斧ケヅリの柱や長押をとゞめてゐる舊家が、つい戰前頃までは、ずゐぶんあつたものだといふ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
