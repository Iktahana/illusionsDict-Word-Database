[
  {
    "uuid": "8750bcff-8f2a-584a-820e-5b552175d26d",
    "entry": "厳つい",
    "reading": {
      "primary": "いかつい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
