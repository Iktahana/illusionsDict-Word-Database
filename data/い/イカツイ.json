    "definitions": [
      {
        "index": 1,
        "gloss": "stern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は見た目こそ厳ついが、実際は非常に温厚で涙もろい性格だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その四輪駆動車は、大きなバンパーと厳ついタイヤを装備しており、いかにも悪路に強そうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんな厳つい顔をしていないで、もう少しリラックスしてよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職人が使い込んだ厳つい工具が、作業台の上に整然と並べられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統的な日本家屋の、瓦屋根に厳つい鬼瓦が据えられた佇まいに圧倒される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重厚で厳つい革ジャンを羽織り、彼は大型バイクに跨った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "警備にあたっていた大柄な男たちの、厳つい装備が物々しい雰囲気を醸し出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　と弁護士の方も軽く会釈したが、彼は五十五六の年輩の、硬い口髯も頭髪も三分通り銀灰色で、骨格のがっちりした厳つい紳士であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつかり趣が変つて今までの強ひて澄み入らうとした厳つい不自然さが無くなつて来たやうに思へた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それよりも厳ついかも知れぬ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗演禅師は厳つい眼つきで皆を見下した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわざと蟹のやうな厳つい顔をした。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "カアテンとかテイブルセンタアとか、童話趣味の装飾も彼女らしい好みであったが、奥の一部屋だけは、不釣合いに厳つい床や袋｜戸棚などちょっと擬ったところがあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "年のころは五十四、五で、ブリアン型の髭さえなければ、余程｜厳つい顔立であろうが、その半ば口を開いた死相を見ると、ただただ安らかな眠という外にない。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年のころは五十四、五で、ブリアン型の髭さえなければ、余程厳つい顔立であろうが、その半ば口を開いた死相を見ると、ただただ安らかな眠という外にない。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "使女Ａ　真鍮に銀の鋲を打った冑、金襴で錏がわりに装飾った投頭巾、輪頭形の冑の頂上に、雄猛子の鬚をつけた厳つい冠もの、そのような冠ものを冠った方は数多く見えましたが、桂の冠をかむった方は一人もお見えなされは致しませぬ。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて片側に厳つい建築の立ち並んだ辺りも通り過ぎて尚も暫く歩いたかと思ふと、さういふ建物に挟まれた一つの道へにはかに曲つた。",
              "citation": {
                "source": "群集の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日頃｜厳つい偃松の枝や荒い山上の風にのみ撫でられ晒されて、骨の髄までサラサラに荒け切った体には、斯うした溢れるような柔い色彩の感じは、最も懐しい者の一である。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の高い樫の椅子が、厳つい背をこちらへ向けて、掛けた人の姿はその蔭にかくれて見えぬ。",
              "citation": {
                "source": "ジェイン・グレイ遺文",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まず乾雲丸のことをフッツリお忘れなすって、それからその厳つい大小をさらりと捨てて、あたまも小粋に取りあげてさっぱりした縞物か何かでおもしろおかしく……」「ぶるる、馬鹿ッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とんちんかん、おおよそかくのごとく、口をきくたびに意思の疎通を欠く恐れがあるし、江戸では見かけたこともない厳つい浅黄うらばかりがワイワイくっついているので、小突かれた日にぁ生命があぶない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "御紋は丸に二つ引、御腰の物の拵えも、大変御粗末でしたが、御人柄は立派で、少し厳つい方でございました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "老商人は厳つい眼つきで前を見つめながら無言のまま二人の向いに坐って、ときどき不賛成らしく口をもぐ／＼させていた。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは彼女が我を折ったのだと思ったから、自分は妻の烈しい非難に釣り出されて、つい心にもないことを口に出したのだ、といおうとしますと、妻は相も変らず厳つい、恐ろしく疲れたような顔つきをして、わたしはそんないいわけを聞きに来たのではない。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチェリーナはうれわしげな、とはいえ厳つい目つきで夫を見つめていたが、その目からは涙が流れるのであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち十数人の厳つい男らがトリタイアに襲いかかり、連れ去られ、必死に戦うも、むなしかった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅い岩壁も、厳つい樹木も、たちまち柔か味をおびて浮動する。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鑓の雪形も今日はハッキリ見えるし、乗鞍の種蒔き爺さん（これも今度初めて知った雪形、後出）も出ているし、この厳つい雪の列峯が、麓の里と見えない糸でつながれているような気がして、かつて幾度か見た景色を、まったく新たな感銘をもって、改めて見直すのであった。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するともう案内もなく上がって来た萱乃の父なる人は、厳つい顔を硬ばらしてそこに突っ立ちながら、若い男女を見下ろして、さも忌々しげに、「恥さらしめっ」と、唾でも吐きかけたいように睨めつけた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひげを剃った厳つい顔はウィルキンソン警部だった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、日頃いかつい軍曹の眼に感激の涙さへ幽かに染んでゐるのを見てとると、それに何とない哀れつぽさを感じて次から次へと俯向いてしまつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊長は、軍刀のつばのところへ左手をやって、いかつい眼で、集って来る百姓達を睨めまわしていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊長は、通訳からその意味をきくと、じろりと、いかつい眼で暫らくその男を睨みつけた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小川は、なお、一と時、いかつい眼つきで源作を見つめ、それから怒っているようにぷいと助役の方へ向き直った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋をはいた足のいかつい線も打ちこわしである。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のいかつい肩に陽の光がしきりに降り注いだ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い煉瓦の建物のある街角に立っていた肩のいかつい蒼白い顔をした青年が、私の腕を素早くとらえた。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
