[
  {
    "uuid": "635a9bba-a503-5c1d-9cb6-4488866e2e1b",
    "entry": "家を継ぐ",
    "reading": {
      "primary": "いえをつぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
