    "definitions": [
      {
        "index": 1,
        "gloss": "flowers of sulfur",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "皮膚疾患の治療薬として、古くから硫黄華を配合した軟膏が用いられてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "有機栽培の畑では、化学農薬の代わりに硫黄華を散布して病害を予防することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "薬局で手に入れた硫黄泉の入浴剤には、微量の硫黄華が含まれていると説明された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "火山活動が活発な地域では、噴気孔の周辺に硫黄華が結晶となって付着しているのが見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゴムの加硫工程において、硫黄華は弾力性を向上させるために不可欠な添加物である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い文献には、様々な民間療法で消毒や殺菌目的のために硫黄華が使われた記録がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学の実験では、高純度の硫黄華を昇華精製し、その物理的性質を詳細に分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今日｜実習が済んでから農舎の前に立ってグラジオラスの球根の旱してあるのを見ていたら武田先生も鶏小屋の消毒だか済んで硫黄華をずぼんへいっぱいつけて来られた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫黄華を水銀に混じて煉ると硫化水銀になるが、これは黒色である。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に亜鉛、水銀の種々な化合物、甘汞（塩化第一水銀）、硫黄華を見つけ、彼は鉄やアンチモンの製剤を使うことを強く奨励した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私自身も郵便を投函する必要のあるとき自動車の運転手に「郵便函があったら留めてくれ」といおうか「ポストがあったらストップしてくれ」といおうか、どっちがよくわかるだろうかと咄嗟に迷うことがある。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それから道の程を経て、京橋辺の道具屋に行くと、偶然といおうか天の引合せといおうか、たしかに前の鐙と同じ鐙が片方あった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "素質と言おうか、本能といおうか、ただただ不思議である。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽどそういおうかと思ったけれど、先生だというから、また、そんなことで悪く取って、お前が憎まれでもしちゃなるまいと思って、黙っていました。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱ぎ捨てられたレヴューガールの衣裳のようだといおうか、それとも、ハンドバッグの中の使い残りの棒紅のようだといおうか。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた、あたしの亡くなった弟とそっくりなんですもの……とそういおうかしら――）　青年とても、屹度彼女に恋しているのに違いありません。",
              "citation": {
                "source": "恋",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば有則の曲線の場合でいおうか。",
              "citation": {
                "source": "ねじくり博士",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、幸といおうか、彼の蘇格蘭の領地と公園小路の古い邸とは彼のものとしてあまりに有名で、非実用的なのが障りで融通に対する利用性を欠いていた為め彼が容易に現金に換えようとする重宝には役立たなかった。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、や、天から降ったか、地から湧いたか」　と、入道が叫ぶと、その男は、揚幕を引いて花道へ出た役者のような、気取った口調で、「流れ星のように、天から降ったといおうか。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕈のように、地から湧いたといおうか。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、第一手に端の歩を突くのは、まるで滅茶苦茶で、乱暴といおうか、気が狂ったといおうか、果して相手の木村八段（現在の名人）は手抜きをした。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと、普通の人間に出来る芸当ではないと、その図々しいといおうか。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞しいといおうか、人並みはずれた実行力におれは惚れこんだのだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日　復員列車といおうか、買い出し列車といおうか、汽車は震災当時の避難列車を思わせるような混み方であった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議といおうか、偶然といおうか、さきに木の上に投げ落されたときに、その片目を大きい枝の折れて尖っているところに貫かれたので、そればかりは骨となっても元のところにかかっているのであった。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に霊験アラタカといおうか現金と形容しようか。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど同じ日に一足後れて、お夏さんを娶ろうという、山の井医学士の親類が、どんな品行だか、内聞、というので、お夏さんの歌の師匠の、根岸の鴨川の処へ出向いたのが間違の因です……　今までそこにふンぞり反って、暴れていた床屋の職人が、その人の使者だというお夏さんを、たとい親だって好くいおうか。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆくまいというは道徳心の省作で、行きたい行きたいとするのは性欲の省作とでもいおうか。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂わば、私は、押しかけ、………なんというのかしら、押しかけ女房といってもいけないし、押しかけ愛人、とでもいおうかしら、そんなものなのですから、Ｍ・Ｃのほうでどうしても、いやだといったら、それっきり。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは比べものにならぬ程｜凡下の功利主義より高尚だといおうか。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看守と囚人とを別々に見れば、共に気の毒なる境遇の人々であるが、さてこの二人種の関係を考えてみれば、滑稽といおうか、馬鹿馬鹿しいといおうか、更にこれを悲惨といおうか、予はこれを評するに言葉を知らぬ。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
