    "definitions": [
      {
        "index": 1,
        "gloss": "to be smart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の才能をいかして、プロジェクトリーダーに任命した。",
              "source": "幻辞"
            },
            {
              "text": "今までの経験をいかして、新しいビジネスを立ち上げた。",
              "source": "幻辞"
            },
            {
              "text": "医学の知識をいかして、地域の健康診断を企画した。",
              "source": "幻辞"
            },
            {
              "text": "美術の才能をいかして、地元の景観改善に参加している。",
              "source": "幻辞"
            },
            {
              "text": "IT スキルをいかして、小企業のデジタル化を支援している。",
              "source": "幻辞"
            },
            {
              "text": "言語能力をいかして、国際交流のコーディネーターになった。",
              "source": "幻辞"
            },
            {
              "text": "心理学の知識をいかして、カウンセリングサービスを開始した。",
              "source": "幻辞"
            },
            {
              "text": "農業経験をいかして、都市農業推進の講師をしている。",
              "source": "幻辞"
            },
            {
              "text": "料理の腕をいかして、料理教室を開業した。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの経験をいかして、青少年のコーチをしている。",
              "source": "幻辞"
            },
            {
              "text": "建築知識をいかして、福祉施設の改善に関わった。",
              "source": "幻辞"
            },
            {
              "text": "営業経験をいかして、営業研修プログラムを開発した。",
              "source": "幻辞"
            },
            {
              "text": "環境学の専門知識をいかして、企業の CSR 活動をサポートしている。",
              "source": "幻辞"
            },
            {
              "text": "音楽教育の経験をいかして、児童音楽療法を推進している。",
              "source": "幻辞"
            },
            {
              "text": "マネジメント能力をいかして、複数の部門を統括している。",
              "source": "幻辞"
            },
            {
              "text": "著述技法をいかして、企業のコミュニケーション戦略を手掛けている。",
              "source": "幻辞"
            },
            {
              "text": "研究経験をいかして、新製品開発の監督役を務めている。",
              "source": "幻辞"
            },
            {
              "text": "言語教育の工夫をいかして、大学の講座内容を改革した。",
              "source": "幻辞"
            },
            {
              "text": "社交スキルをいかして、企業間の連携プロジェクトをまとめている。",
              "source": "幻辞"
            },
            {
              "text": "長年の職人技をいかして、若手職人の育成に当たっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「けさ、とても固いするめを食ったものだから」わざと押し潰しているような低いかすれた声であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一本立ちになるが早いかすぐに自分の創作に取りかかる。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、聞こえないくらいかすかに鼻の中でいって、小さい太郎はいけがきをはなれました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその夜、うすいかすみのように僕の心を包んだ一片の哀情は、年とともに濃くなって、今はただその時の僕の心持ちを思い起こしてさえ堪えがたい、深い、静かな、やる瀬のない悲哀を覚えるのである。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまるで細いかすれた声で、「さよなら。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから木や草のからだの中で月光いろにふるい、青白いかすかな脈をうちます。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き覚えのある疳高いかすれ声に、おやっと、暗がりにすかして見ると、果して、弟の伝三郎であった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世は遷り人は代るが、人間の食意地は変らない」「食ものぐらい正直なものはない、うまいかまずいかすぐ判る」「うまさということは神秘だ」――それは人間の他の本能とその対象物との間の魅力に就てもいえることなのだが、鼈四郎がいうとき特にこの一味だけがそれであるように受取らせる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けさ、とても固いするめを食つたものだから、」わざと押し潰してゐるやうな低いかすれた聲であつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金平は、よんべから腹がいとうてのオ、ねておるだで、今日はいっしょに遊べんぜエ」「ふウん」と聞こえないくらいかすかに鼻の中でいって、小さい太郎はいけがきをはなれました。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」如來の聲はひくいかすれ聲であつた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの豊原の若い歌人たちとも、また一生に二度と逢えるか逢えないかすらもわからないのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』少女は、窓の硝子に熱いかすかな汗のにじんでいる額を押しつけて、裏の垣根に咲いている赤い豆のはなを見た。",
              "citation": {
                "source": "咲いてゆく花",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々薄くなつてゆく脇の下の着物の地を默つて見てゐるのは、お葉にとつては淋しい言ひ樣のないかすかな絶望であつた。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼にはたへず赤ん坊の糸のやうな、細いかすかな泣き声が耳についてはなれなかった。",
              "citation": {
                "source": "かなしみの日より",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃれにならない悪筆に加え、下敷きにしたやすりにうまく引っかけて字画を出していくこつがなかなかつかめなかった私は、読むに耐えないかすれた紙面を作って顰蹙を買いました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだね、うまい菓子があるかね」「みんな、うまいかすだわね」菓子屋のねえさんは、東北弁まる出しで答えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもならば頭を枕につけるが早いかすぐ鼾になる人が、いつまでも静かにしていて、しげしげと厠に立った。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、軽いかすかな叫び声を立てた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、美奈子の見附けたその白いかすかな雲の一片を除いた外は、空はほがらかに何処までも晴れ続いていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その間に大尉は初めは少しも気がつかなかった苦いかすが、中尉との交情の中にあることを見出したのである。",
              "citation": {
                "source": "ゼラール中尉",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずこれらの分類は形式に属する分類であるから、専門として独立する価値があるかないかすでに疑問である。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その言葉が終るか、終らないかするうちに、不昧は早口に、「もはやおよろしいでしょうか。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは既にじゅうぶん承知のことと思うが――」「だが、こんな重要問題の場合は――」「重要であるかないかすら諸君は知ることを許されていないはずだ。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の頬に薄いかすり疵のあとがあるのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一種の遠いかすかなるとどろき、仔細に聞けばなるほど砲声だ。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃアそうさ、いかすためさ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、美奈子の見附けたその白いかすかな雲の一片を除いた外は、空はほがらかに何処までも晴れ続いてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごく冥想的な低いかすれながら美くしい声で目をつぶってうたい出す、少し調子の後れ加減になるほどゆるく。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
