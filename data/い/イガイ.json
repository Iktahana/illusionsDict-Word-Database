  {
    "uuid": "135d5a46-95b7-53a6-a32c-af7342daacf3",
    "entry": "貽貝",
    "reading": {
      "primary": "いがい",
      "alternatives": [
        "イガイ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
