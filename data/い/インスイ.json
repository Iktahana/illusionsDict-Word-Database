    "definitions": [
      {
        "index": 1,
        "gloss": "(act of) drinking water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
