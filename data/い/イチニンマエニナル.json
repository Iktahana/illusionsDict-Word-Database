    "definitions": [
      {
        "index": 1,
        "gloss": "to come of age",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大学を卒業したら、親元を離れて一人前になるつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の修行を経て、ようやく彼は寿司職人として一人前になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプロジェクトを成功させたら、ようやく私もこの部署で一人前と認められるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もう子どもじゃないんだから、自分のことは自分でやって一人前になりなさい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はまだ若いが、仕事ぶりはもうすっかり一人前だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新米の営業マンだった彼も、今では顧客を一人で担当する一人前になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "弟も今年で成人し、そろそろ社会の一員として一人前になってもらいたいものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "まあ女というものは良人のよい指導を得て一人前になるものなのですから、あながち早過ぎるお話とも何とも私は申されません。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のところはただ年老つて知らぬ間にだいぶ弱つた親父の手助けをする、これからではずゐぶん困難だらうが、何とかして百姓仕事を一人前になるまで習つて行く、それだけが目的ですね。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし恭一君はまだ子供なので、恭一君の一人前になるまで、老父が仲継ぎするよりなかった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人前になるまでを自分が見てやることもできない」　と、院が仰せられたことをお思いになって、憐みを深くかけておいでになるのである。",
              "citation": {
                "source": "源氏物語",
                "author": "匂宮",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼の子供は一人前になると番人の雉を噛み殺した上、たちまち鬼が島へ逐電した。",
              "citation": {
                "source": "桃太郎",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貧乏のせいか何んだか、その平一郎の一人前になる日に会われないような気がしきりにしましてね」「そんなこと、小母さん！",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、子供がもう一つ先に、十五を境にして元服の式があり、これがすむと一人前になる。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供から一人前になるときに、特殊な冠をかぶる時代があった。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が一人前になるため、成人式を行のうたのが、形式だけになって、近代まで元服として遺っていた。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "性交は夫婦でなくてもできるが、子どもを育てるということは人間のように愛が進化し、また子どもが一人前になるのに世話のやける境涯では、夫婦生活でなくては不都合だ。",
              "citation": {
                "source": "愛の問題（夫婦愛）",
                "author": "――生命の法に随う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五羽の掌で一人前になるから沢山ないと用いられんが何一つ捨てる処はない。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼らは利巧のやうでも子供だと言はれ、まだツギの当らぬ着物が、要するに之からの一足毎に破れて、ツギハギだらけになつたときに一人前になるだらうと考へられてゐるのである。",
              "citation": {
                "source": "わが血を追ふ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実用品の職人になるにも、一人前になるまでには、まだまだ前途甚だ遠い。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "集つた顏は、あれやこれやの關係の親類縁者達で、よくあるやうに老衰の境に入つた獨身の婦人、若々しい花の盛りのいとこ達、一人前になるかならぬかの若者たち、そして朗かな眸をした寄宿舍學校のおきやんのお孃さん方が寄つてゐた。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰り返し繰り返しやるから、口がほぐれて落語家が一人前になるんだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とにかく、二人とも、これで一人前になるんだ。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らがその発育中にいじけ、一人前になるのに長い年月を要することは、田舎の久しく住んでいるものの認めざるを得ないことである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時一般農家の子弟が一人前になるための元服の儀式は、十五歳のときときまっており、これを境に一人前の若い衆になったという精神的な自覚を与えられたものである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が大きくなって一人前になると舟を造ってやる。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こごとをいわれ、重音、片言、かなづかいを直してもらって初めて、はなしに無駄がなくなり、一人前になるのである。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は、一人前になるまでになんて長いあいだぐずぐずしていたんだろう！",
              "citation": {
                "source": "判決",
                "author": "DAS URTEIL",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人前になる迄にはたっぷり今年一杯はかかりますね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "名作展をみても今日の大家の初期の作品が良くて、現在どんなに芸術家としては生き恥をさらしているかと云うことを感じさせるものが少くなかった由、人間が一人前になる迄には実際、水をくぐり、火をくぐりですね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りの場合はト、一軒置いて隣りの場合は一ト、筋向いの場合はスム、路地の中に入る場合はロ入り、こんな工合に符号をつけていくのである、もっとも順路帳を見ながら配るのは、新米が配達に慣れるまでの、わずかな期間である、一人前になると、どんな新しい区域でも、一日配れば、あとはそらで配れるようになる。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だからたとえ鬼小島弥太郎のような習性でも、しばらくその中に棲息をゆるされ、また一人前になるまでは、「困り者」　の代名詞となるほどでも、朋友から上役まで、「いつか、何かのときには、お役に立とう」　と、その短を扶け合っていてくれるという風だったのである。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五は昔から男が一人前になる年であったが、若い衆の資格が追い追いとむつかしくなっても、実際はまだ何年間かの準備期間が必要であった。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
