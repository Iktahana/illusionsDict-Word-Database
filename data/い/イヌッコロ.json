        "examples": {
          "standard": [
            {
              "text": "「ああ、この犬っころめ！またソファーを引っ掻きやがって！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜中に吠え続ける犬っころのせいで、近所迷惑になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "まったく、言うことを聞かない犬っころだ。何度言ったらわかるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
