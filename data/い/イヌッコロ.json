          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "まだ小さい犬っころが、庭を元気いっぱいに走り回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園でリードをつけた犬っころが、飼い主の後ろをちょこちょこ歩いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい犬っころが家族に加わって、家の中が明るくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「いい若けえ者が酒屋の御用じゃああるめえし、犬っころを相手に日向ぼっこは面白くねえぜ」　半七の顔をみて、徳次という船頭は笑いながら挨拶した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "のそのそと、どこをほつき歩いていたんだッ」「ちぇッ、犬っころじゃあるめえし、のそのそほつき歩いているはねえでがしょう！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七　そのほかに牡の犬っころは何匹飼ってありますね。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七　はは、犬っころじゃあ判るめえ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犬っころが何匹いるんだよ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい犬っころ十二匹をみんなここへ引っ張り出してください。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）むむ、これで犬っころが皆んな鼻を揃えたわけですね。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがさっきから犬っころと云ったのも無理はあるめえ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この辺の邸は、どこも逃げてしまって、なかには犬っころがいるだけだ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三枚同じように罪なさそうな犬っころだの小鳥だのの色刷絵がある。",
              "citation": {
                "source": "『キング』で得をするのは誰か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬っころ見たいに――」　瑛子はいかにも大きい娘を話相手としている調子で高輪の井上の悶着の話をしたりした。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地を張っている俺方の母親も分らず屋だが、犬っころみたいにお前を連れ帰ったお父さんも少し短気すぎる。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして到頭隣りのリンゴをもぐ様な心持になって起き上って、廊下へ一歩出ると、あんまり真暗闇だったのと、これから取り掛ろうとする大冒険の緊張で、犬っころの様な身震いをした。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがフォン・コーレンにとっては、人間なんて犬っころや虫けらも同然、彼の生活の目的物たるには小さ過ぎるんだ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏羽織の肩も裾もぐっしょりと濡らして、まるで川へはまった犬っころのようなみじめな風態だった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げる間も何にもねえはずだが、犬っころ一匹飛出さないから不思議だろう」「手前が間抜けなんだよ、急いで行けッ」「息が切れてかなわねえ」「死体はそのままにしておいたのか」　駆けながらも平次は、出来るだけガラッ八の口から要領を引出して、事情の外形をはっきりさせようとする様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "朱塗の筐",
                "note": "青空文庫"
              }
            },
            {
              "text": "戌刻過ぎに通る者は、按摩も夜泣き蕎麦も、犬っころ一匹も逃さない厳重さでしたが、祈祷所から出た者も祈祷所へ入った者も一人もなく、極めて平穏な春の夜は、うらうらと明けてしまったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上夜露に打たれると、人間のカキ餅が出来そうだ」　ガラッ八は表の草叢の中から飛び出して、忠実な犬っころのように駆けて来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大盗懺悔",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静、羽織を出しな」「有難い」　八五郎はすっかり有頂天になって、平次の先に立って犬っころのように雪道を飛びました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪の中の一軒家のように、犬っころ一匹｜側へ寄った足跡もねエ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "亥刻半（十一時）少し廻った頃で、たいそうな機嫌でしたよ」「それから誰も出たものはないのか」「犬っころ一匹出ません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "懐ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "針が落ちたほどの足音を聞き付けて、お前を犬っころ投げにして逃げた曲者じゃないか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "庚申横町",
                "note": "青空文庫"
              }
            },
            {
              "text": "路地の中には犬っころ一匹居る様子もなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ」　犬っころのように投り出された千之助、漸く起上がろうとすると、後ろから喉笛へサッと投げかけた縄。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "地獄から来た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「親分、あてが外れましたね」　ガラッ八、犬っころのようにその後に従います。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八五郎の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「曲者ッ」　続いて飛出す八五郎、一気に闇の庭へ、跣足で飛降りましたが、四方は塗り潰したような大吹雪で、黒い犬っころ一匹見付かりません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい時から一座に育って、恋というにしてはあまりに親し過ぎる二人は、手を取り合って心ゆくばかり話すか、それとも、二匹の犬っころのように、存分に喧嘩でもし度いような、悩ましい衝動をどうすることも出来ませんでした。",
              "citation": {
                "source": "裸身の女仙",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬っころのように、無我な幸福で躍り廻り、跳ね廻る子供に取巻かれながら、散歩する夫人の姿を見ると、正隆は一種表現し難い愛惜を感じずにはいられなかった。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでヒステリィを起した犬っころのような――痛いのは自分だけだと思いあがった所から来るセンチメンタリズム――欣二　ああ、犬っころだよ。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
