    },
    "definitions": [
      {
        "index": 1,
        "gloss": "about this time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この時期、桜が満開になるはずなので、今頃は賑わっているだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "朝の通勤ラッシュ時なので、今頃、駅は大変混雑しているだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう夜も遅いのに、今頃になって勉強を始めるなんて、どうしたの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは今頃、学校で運動会の練習に励んでいる頃だろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「祖母さんは今頃時分ヤツと御飯ね。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親父は今頃雑誌でも読んでるのだらう」などゝ思つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正九年頃の或る雜誌に、今頃ニイチェを論ずるのは流行遲れで古臭いが云々と書いてあつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなければ今頃こんな消極的な俗吏になって、毎日同じような消極的な仕事を不思議とも思わずやっている筈はないかも知れぬ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この灰の行くところ、峠を越え里に出て、今頃は高原の人々に、手を額に加えて仰ぎ視させているであろう。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも二十年前に時の政府が奮発して若干の設備を施しそうして今日まで根気よく観測を続けて来ていたのであったら、今頃までにはもうどうにか曲りなりにでも解決がついていたのではないかと想像される。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃、娘はどうしているだろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏中ぽつりぽつり咲いていたカンナが、今頃になって一時に満開の壮観を呈している。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この有難い設備と習慣とがなかったら東京市民の顔は今頃どんなものに変化しているだろう。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくこれらの店の人にとって、今頃石油ランプの事などを顧客に聞かれるのは、とうの昔に死んだ祖父の事を、戸籍調べの巡査に聞かれるような気でもする事だろう。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃『徒然草』でもあるまい」と云うが、そういう諸君の現在していることの予報がその『徒然草』にちゃんと明記してあるのである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、七五郎だね」　「あッ、おッ母ァ」　「七五郎、今頃まで何処をウロウロしてたんだい。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉が、Ｔ「拙者、強い方を　叩き斬る」　面喰って居る旗本を尻目に大吉尚も、Ｔ「貴殿が御強よう　厶ったら、今頃　貴殿の其の首は　まさか胴には……」　「着いちゃいまいテ」と大笑する。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "せせら笑って、なりひらが、Ｔ「その七兵衛今頃は拙者の相棒の為」　エッ、と主膳。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳が、Ｔ「なりひら小僧奴今頃は」　と言った時、Ｔ「今頃は雲霧主膳の後ろに居る」　えッ、と振り返る主膳と侍。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕はバルチックの軍艦に結婚を申込む、アンナ・ニコロ、今頃はモスクワの政治委員もアンナ・スラビナも昼寝をむさぼってる時間なのです。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年もちやうど今頃二十日ばかり床に就いてゐた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年兵達は、既に内地へ帰ってから、何をするか、入営前にいた娘は今頃どうしているだろう？",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰還した同年兵は、今頃、敦賀へついているだろうか。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだ、あたりまえなら、今頃、あの橇で辷っている時分だ！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「内地に居りゃ、今頃、野良から鍬をかついで帰りよる時分だぜ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の中隊が、橇でなく徒歩でやって来ていたならば、彼も、今頃、どこで自分の骨を見も知らぬ犬にしゃぶられているか分らないのだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "入歯を、発明し、改良して来た西洋人が、もしわれわれと同じ食物を食って生きているのだったら、そうしたら、餅を食っても、飴を食っても、故障の起らないような入歯が、今頃は出来ているのではあるまいか。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだとしてそれを今頃気が付いたとすれば、なるほどこれは頭の悪い証拠になるかもしれない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今頃、電報が来たが。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、今頃、とし子が居たならば！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今頃、しゃばへ出りゃ、お日さんが照ってるんだなア。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ今頃は無鉄砲な羽虫が沢山集ってぶっつかったりよろけたりしてゐるのだ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの爺さんは、いまごろはきつとひどく落膽して、山に柴刈りに行く氣力も何も無くなつてゐるでせうから、私たちはその代りに柴刈りに行つてあげませうよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
