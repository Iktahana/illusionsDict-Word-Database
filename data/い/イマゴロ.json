[
  {
    "uuid": "cae927d0-3bc0-5828-b79e-b35d0ba881a8",
    "entry": "今頃",
    "reading": {
      "primary": "いまごろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
