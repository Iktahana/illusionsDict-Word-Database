        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "焼きたての餅を醤油にくぐらせ、パリッとした海苔を巻いて磯辺餅を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "お正月に余った切り餅は、磯辺餅やきなこ餅にして少しずつ消費していくのが我が家の定番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "縁日の屋台から漂ってくる焦げた醤油の香りに誘われ、つい熱々の磯辺餅を買い求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "磯辺餅の美味しさは海苔の風味に大きく左右されるため、なるべく上質で香りの良いものを使いたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ストーブの上に置いた網でこんがりと餅を焼き、少し砂糖を加えた甘辛いタレを絡めて手軽な磯辺餅をおやつにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
