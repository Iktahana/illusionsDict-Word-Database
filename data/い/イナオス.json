        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "破損したブロンズ像を、専門家が丁寧に鋳直す作業を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度失敗した部品も、溶かして鋳直せば再利用できる場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古くなった鐘を鋳直して、新しい音色を持つ鐘を作り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は私自身を複雑化し、一すじ縄で行かぬ人間に鋳直することで外界と順応することをせずに、外界を純一無雑につくり直すことで、私と一致せしめようと試みているものだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近の人間学的な倫理学の方向が、この社会幸福主義を性質的に高め、浄化させんがために、一方では人格主義の、いわゆる人格の意味を、個人主義的な桎梏から解放して、これは社会的人間に鋳直すことにより、人格主義と社会幸福主義とを、本質的に止揚して調和せしめんとする傾向を帯び来たったことに注意すべきである。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその結果は、あやうく成功すれば人間を「利潤対象としての大衆」いわゆるミーチャン、ハーチャン型として鋳直すことが出来るかもしれない危機的現象が内在することを注意すべきである。",
              "citation": {
                "source": "現代美学の危機と映画理論",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に私は自分を鋳直すことができたつもりであった。",
              "citation": {
                "source": "転向",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋳直すことができなかったからである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは最も反発的な魂をも鋳直す。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤はまだ両肌脱いだまま鏡台の前に坐って、髪を結いなおすかどうかしていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年たちの熱中ぶりに手を焼いたＣＣＣは、もともと弱みを残しているＰＤＰ―10のシステムを徹底的に洗いなおすために、逆に彼らを利用することを考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈結局は何だったんだろう〉　成功のレールに乗ってひた走りはじめたＰＣ―８００１を前に、松本は自分自身をマイクロコンピューターに向かわせたものはなんだったのかを、繰り返し問いなおすようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっと起きて髪を結いなおす。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また買いなおすと、三十円ぐらいかかる。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹に力のない奴と思いなおす。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、また思いなおすと、彼らは、どのくらい女に思われていたか、私よりは深く思われていたか、そうでなかったか、わからぬにしても写真を仏壇に祀られるようになったのでは、結局この私よりもあの男たちは不幸な人間であった。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と　あわてて　いいなおす　ダッチェス。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとすぐ、そうじゃない、前のほうがいいと思いなおす。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今死んじゃあいられないわ」と思いなおすのが常であった。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは、かえってからマツがなかなかアクティヴなので、すっかり夜具干しして、風呂敷につつんでしまって、きょうはマツ縫いなおす分のほどきものをして居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろそういう話、何度でもくりかえしてききそうになって、ああもう四度目ぐらいだ、やめとこう、と思いなおす次第です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとにそこに住んでいるのかどうかということは、中野さんが語ってくれたことと付き合わせて言いなおすと、鮫島さんのお姉さんはいまも生きてるのかどうか、ということになります」　口へ運ぼうとしていたドゥミタスを、玲子は受け皿に戻した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒人のヒットを白人がうたいなおす作業は、この頃、さかんにおこなわれた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "オートメーション参加者とでも言いなおすべきで、このオートメーションがじつは、アメリカ資本主義社会のなかで、皮肉な結果を生みつつある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
