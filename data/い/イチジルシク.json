[
  {
    "uuid": "0b6bfd68-25d9-56dc-89e2-964763a94232",
    "entry": "著しく",
    "reading": {
      "primary": "いちじるしく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
