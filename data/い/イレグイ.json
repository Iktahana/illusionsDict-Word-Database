        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから入れ食いの連続だ。",
              "citation": {
                "source": "那珂川の鱸釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひととき、「入れ食いの手水鉢」のように釣れる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "針が合ったのか、それこそ入れ食いで釣れる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大師沖にて海水浴場寄り一ヒロぐらいの浅場で、大型ばかりいっとき入れ食い。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまさか三本使う人があるが、入れ食いといって魚の食いが立ってくると、かえって不利の場合が多い。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この羽根板仕かけで投げ込むと、それこそ入れ食い、いやタコは食うのではない。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はアジ道具のビシを入れると、これがまた入れ食いである。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
