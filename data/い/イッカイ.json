        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は昇進試験に合格し、一階級特進となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
