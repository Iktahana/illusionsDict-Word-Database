          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あ、今さっき、ポストに郵便物が届いていましたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「すみません、今さっきまで別の電話に出ていました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、本当？今さっき、駅前で○○さんに会ったんだ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今さっき、コーヒーを淹れたばかりなので、熱々ですよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今さっきまで憲兵隊で同じ机に向って坐っとったんだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さっき出かけたばかりの橇がひっかえしてきたらしい。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さっきほかの者が来てすっかり持って行っちゃったんだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、今さっきまで、松木と武石とが立っていた窓の下へ少佐は歩みよった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "張宗昌が、今さっき城をあけて逃げ出してしまったんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兵士は命令を待っている間に、今さっき百姓小屋で取ってきた獲物を、今度はお互いに、口でだまして奪い合った。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイ今さっき……十時頃お出でになった。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今さっき、お前妊娠しているのと違うか――ちゅうておききどした」「叔母さんが……」　お雪はうなずいた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昼寝をかなりしたし、叔母さんの言葉や、麻川氏の今さっきの言葉や態度も気になって寝られ無い。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このくらやみでしたから、兄貴の目じゃわからねえのがあたりめえですが、今さっきそこまで帰ってきましたら、あそこのかきねのそばをこちらへ、六十ぐれえの変なおやじが、人形をだいじそうにかかえながら、素はだしでふらふらとやって来ましたんでね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今さっきね、盲目の人が尺八を吹いて来たのですよ、黙って聴いていると、僕たちはみんな吸い込まれるように寂しくなってね、僕、とうとう泣いてしまったのですよ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は……あのお言葉を聞きました時に……それではもう……私の身の上はもとより……ツイ今さっき私の身の上に起った……前代未聞の怪事件までも御存じなのかと思って、胸に釘を打たれたように思ったのですが……私は、お言葉の通りの大馬鹿野郎の大間抜けだったのですから……」「アハハハハ。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌にはツイ私が今さっきまで着ていたのとおんなじ白木綿の患者服を着て、胸にかけた白毛布の上に、新しい繃帯で包んだ左右の手を、行儀よく重ね合わせているところを見ると、今朝早くから壁をたたいたり呼びかけたりして、私を悩まし苦しめたのは、たしかにこの少女であったろう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからもっと話を進めるんだが、その前に、今さっき読んだ呉一郎の前後二回の発作については、もう何も疑問の点は残っていないかい」「あります」　と私は鸚鵡返しに返事をした。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと今さっき水蒸汽で引上げて行きやがった。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は大連からツイ今さっき無線電信が這入りましたのでね……この珈琲茶碗の内側に電文が暗号で書いてあります。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイ今さっきの夕方の幕間に妾をあの五階の息つき場へ呼んでね。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当銀座の地理には明るいつもりでいた私も、今日、今さっきはじめて此処を見付けたばかりなのである。",
              "citation": {
                "source": "白金神経の少女",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若僧のものいえる間ようよう上手に進み行きついに肩を並べつつ）今さっき本門の傍で呻いていると思ったが、いつのまにか上って来たのだな。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さっきまで自分であんなに軍隊の罪悪を罵倒しながら、それを軽蔑しきっていた哲学の学生が、僅か三年間の習慣であるにもかかわらず、彼自身の手は、彼のこころを裏切って、その中尉に向って敬礼がしたくてたまらなくなってくるこの愚劣を、どうしようもないのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さっき、知合の家へあそびに行き、その庭に一ぱいあふれるように咲いていたスイートピーをすきなだけきらせてもらい、その帰りである。",
              "citation": {
                "source": "四年のあいだのこと",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、つい今さっき、ビレラフォンが下から眺めて、随分気持のよさそうなところだなあと思っていたのでしたが。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、あいつの後妻ときたら、君も今さっきごらんのとおりの、才色兼備の女性だが、その女までが、すでに老境に入ったあいつの嫁になって、あったら若さと、美貌と、自由と、輝きを、ささげてしまったのだ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしゃ戦争以外に恐ろしいものはありません」「でも、今さっき、この草原を荒したり、あの鐘楼を大砲で撃ったりしようと思ったじゃないか」「ありゃ、言うにゃ言いましたけれど、ほかのことを言ってもよかったんです」「気をつけたほうがいいよ、ロベエル、人が聞いてるからね。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、あんた、今さっき気が附いたんだから、なんとも早や。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった今さっきも、この絵を、モリソウの奥さんなど、綺麗だって、そりゃあなた――ヴィン　モリソウさんは、ありゃ君、絵は描くが、結局は金持の奥さんで、僕らの行き方とは違う。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜと申しますと、あの人はあなたがお受けになった侮辱を聞き、あなたの不仕合わせな境遇も何もかも聞いたので、たった今、……ほんの今さっき……この扶助金をあの人の名であなたにお届けするようにと、僕にお頼みなすったからです、……もっとも全くあの人ひとりの名で、あの人を捨てたドミトリイの名ではありません。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さっき彼がドゥーニャに向かって、自分は悪い風評があるにもかかわらず彼女をめとろうと決心したのだと、悲痛な語調でほのめかしたのは、あくまでまじめな気持で言ったのであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二十五「やあ、えろう分りにくいとこやなあ」と、夫は格子のとこに立ってて、実は今さっき、伊勢の四日市い帰る人あって湊町の駅まで送って行って、戻りしなに心斎橋筋散歩してたら、光子さんのいなさるとこ確かこの辺やったなあ、きっとお前も来てるやろ思たのんで、急に訪ンねる気イになった。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いまさっき、アタゴ山のサイレンが鳴ったよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
