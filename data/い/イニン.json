        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新プロジェクトの推進は、部長から課長に全面的に委任された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "裁判での弁護を弁護士に委任する手続きを進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顧客からの問い合わせ対応を、新しく入った担当者に委任した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「――君に委任された僕のセンジュアス以外のものの委托品あずかり所なのだ。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、今から三四｜時間の後には、目的のコロンボ市の附近に降下して、櫻木大佐より委任されたる、此度の大役をも首尾よく果す事が出來るであらうと、互に喜悦の眉を展く時しも、又々一大異變が起つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑地はずいぶん広い、とても全部へは手が届かないし、またそうする必要もない、その三分の二は雑草に委任、いや失地回復させてある。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "委任統治のテニヤン、ヤップ、パラオ、サイパンはもちろん、時々は赤道直下のオーシャン付近からオーストラリヤ近くまでも延しますが、もちろん冒険ですから、運が悪いとやられてしまいます。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでね、ひとり息子の鶴田君の嫁は、何とかして先生に、僕の事だよ先生というのは、その先生に捜してもらいたいと、本当だよ、つまり僕はその全権を委任されているような次第なのだ。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメット帽は、委任統治領では官吏だけのかぶるものになつてゐるらしい。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメット帽は、委任統治領では官吏だけのかぶるものになっているらしい。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど女房と子供が、実家の餅搗の加勢に行とるけに、この店をば慾しがっとる奴の処へ行て委任状と引換えに五十両貰うて来た。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは江戸城明け渡しの因縁に依って、それを逆に行こうと云うわけであったが、勝が「全権を余に委任する上は、西郷の意を容れなければいけない。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "究竟あの方もその件から諭旨免官のやうな事にお成なすつて、又東京へお還りにならなければ為方が無いので、彼方を引払ふのに就いて、向坂から話が御座いまして、宅の方へ始は委任して参つたので御座いましたけれど、丁度去年の秋頃から全然此方へ引継いで了ふやうな都合に致しましたの。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件落着後清廷が目覚めて改革を行わんとするや、川島は粛親王府に厚聘されて警務学堂を創設し、毎期四百名の学生を養うて清国警察を補充し、啻に学堂教務を統ぶるのみならず学堂出身者の任命の詮衡及び進退｜黜陟等総てを委任するという重い権限で監督に任じた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで三人がぜんぜん翻訳権を与次郎に委任することにした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然者、去明治十一年六月七日、再造新富座開業之節、貴下ニ於テ在東京外国人ヲ御招待、且御厚遇｜被下候儀ヲ同国人ニテ深ク礼謝致シ候段ヲ申述ベ、且又該時種々御親切｜被成下候寸報迄、此引幕壱帳ヲ宜シク御受納｜被下度御願申上候｜様、拙者共ヘ委任相成候間、別紙此幕ヘ出金致シ候人々ノ名前目録モ相添、此段申進候。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃では、小田さんは、自分の受け持ちの事件はことごとく、俊夫君に委任されることになりました。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は趣味に関する妹の教育を、凡て代助に委任した如くに見えた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所には皇室の紋章が勿体らしくほり込まれ、役人共は天皇の「委任」によって、労働者・農民を抑圧するのである。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして家のあと始末を万事任せるとの委任状をくれと言う。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず保子にある条件を委任して、三保に行って貰い、調べることは調べ、処理すべきことはみんなと相談して処理すること。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、印鑑届および委任状を書くことのお願いをする筈だ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時まだ着かないという委任状はその後どうなったろう。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとあの一葉の委任状だ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のことは、僕がいろいろな事情があるのだから是非会わしてくれと、少々理屈を言いかけたら、ついに僕の返事を聞かないで行ってしまったから、看守長は足下に何と言ったか知らんが、ともかく売ることにきめてあるのだし、それに委任状にも印を押して置いたから、いいように取りはからったことと思う。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうその委任状に印をおして置いたが、もう事はすんでいるのだろうね。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だから今日の文化動員・思想動員・は、半官憲的勢力に委任されざるを得ないのである。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "折を見て、連合国側にちょいと参加して、南洋の旧ドイツ領の委任統治地を稼いだし、青島に日本名で町名をつけることに成功したりした。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "党の委任に従って、党の出版物の委任に従って、我々は多くの任務も果した。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから老婆に向って、市に誰か代人なり、または知合いで、登記の手続やその他必要なことを全部委任することの出来る人はないかと聞き糺した。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでチチコフはその人に宛てて委任状を書いてくれと頼んで、余計な手数をはぶくために、自分で文案を考えたりしたほどであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまってしまって、　ホテルの　しはいにんに　そうだんしてみると、　ありがたいことに　じぶんの　むすこが　かよっている　がっこうの　せんせいの　おうちを　おしえてくれまして。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただのやといにんだよ。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
