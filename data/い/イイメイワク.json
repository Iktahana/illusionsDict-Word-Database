          ],
          "literary": [
            {
              "text": "』『自然こそいい迷惑だ、』と自分は笑った。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "クローヂヤスさまこそ、いい迷惑だ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹後の人こそ、いい迷惑である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい迷惑じゃねえか」　高志のほうは、いつものように、完璧に均整のとれたノットだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたさもしい心の持主である上に、身体までが病毒に汚されて居たのですから、加藤家こそいい迷惑です。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師にとっては或は尊い飯櫃かも知れませんが、患者こそいい迷惑です。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "六尺の深さならまだしもであるが、友達が親切にも九尺でなければならぬというので、九尺に掘って呉れたのはいい迷惑だ。",
              "citation": {
                "source": "死後",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしなもんで、一人が死ぬと『吾れも、吾れも』とそこで死にたがるもんでな、轢くこっちはいい迷惑よ、嫌な思いをしなけりゃならねェし。",
              "citation": {
                "source": "鉄路",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、寃罪に伏した事になるのだから、僕もいい迷惑さ。",
              "citation": {
                "source": "創作",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に云わせると、それが卑怯だと思うのですな、自分の失敗を天にかずける――天こそいい迷惑です。",
              "citation": {
                "source": "英雄の器",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイが困ったようにうけ答えしていたら、わきで爪をこすっていたとよ子が、「ふふふ、サイちゃんばっかりいい迷惑だわね。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋人こそいい迷惑だ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はあんまり馬鹿気ているから、少し腹を立てて見たのさ」「僕に対してかい」「だってほかに対するものがないから仕方がないさ」「いい迷惑だ。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊隆はいい迷惑である。",
              "citation": {
                "source": "文鳥",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "連こそいい迷惑だ」「君のようにむちゃに飛び出されても相手は迷惑だ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "感染したものこそいい迷惑である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田にでもやるかな」「黒田こそいい迷惑だ」「そんなにおかしいかな」「おかしかないが、身体に合わないでさあ」「そうか、それじゃやっぱりおかしいだろう」「ええ、つまるところおかしいです」「ハハハハ時に糸にも話したかい」「試験の事ですか」「ああ」「まだ話さないです」「まだ話さない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはイタズラ者が、わざと道庵の筆蹟を真似て書いて、あとを晦まそうとした手段であることは明らかだけれど、それがために、いい迷惑を蒙ったのは道庵先生であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いかん、いかん……君は悪いことをしたつもりはなかろうが、その飛ばっちりが悉くわれわれの身にかかって、いい迷惑をしてしまったよ」　仏頂寺がいう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けちけちするない――早く出さねえか――正直に銭を払ってる此輩アいい迷惑だ。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き手にとってはいい迷惑で。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金魚の死んだ者に、東照宮様の神意があるというんだが、ナアニ、これと思うやつのまえに、前もって湯の鉢をすえとくんだから、金魚こそいい迷惑だ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみさんは主人が怒るたんびに八っちゃんを泣かして小遣になるかも知れんが、八っちゃんこそいい迷惑だ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい迷惑ね」「なあに品物が戻るのよ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鰭の鮨売こそ、いい迷惑」",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "小鰭の鮨",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい迷惑をかけてくれたわ」　久我は本を閉じて、のっそりと机から立ちあがってくると茶碗をひきよせながら、「衣裳を借りに来たからって、それが犯人だとは限らない。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "理論自身が初めから混迷しているために判らないのを、理論ではもはや解決がつかないものだと考えて、それでは実践に訴えろと云うような場合が能く見受けられるが、そういう無能な理論のお守りをしなければならない実践こそいい迷惑である。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体教授が土地の隔った二つ以上の大学に兼任する程人を愚弄したことはないので、学生こそいい迷惑だろう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "惑乱、紊乱、攪乱という風に、うまく別々で而も似たような乱し方が並べられているが、そういう対句めいた作文で処罰される人間こそいい迷惑だ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、あのつづらの中には、かりに掠奪された女がいるのか――その女こそいい迷惑だ、と兵馬が笑止がりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
