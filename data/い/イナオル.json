[
  {
    "uuid": "910ac871-3757-5e74-b97f-62b2190042fb",
    "entry": "居直る",
    "reading": {
      "primary": "いなおる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
