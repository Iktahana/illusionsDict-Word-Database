        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "晩御飯のおかずに、バター醤油で炒めたイカ下足が食卓に並んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "居酒屋でビールを頼むと、必ずと言っていいほどイカ下足の唐揚げが出てくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今日の特売品、イカ下足がたくさん入っていてお買い得だったわ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新鮮なイカからは、刺身だけでなく、旨味の強いイカ下足も取れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初めて食べたイカ下足の天ぷらが、予想外に美味しくて驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "おでんの具材として、イカ下足を使うと独特の食感と風味が加わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "漁港では、水揚げされたイカから下足部分だけを丁寧に切り分け、出荷の準備を進める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
