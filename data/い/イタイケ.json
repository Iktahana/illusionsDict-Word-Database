[
  {
    "uuid": "bd36a29d-f287-5515-915e-d8523f00402c",
    "entry": "幼気",
    "reading": {
      "primary": "いたいけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
