[
  {
    "uuid": "4c15381f-a5e7-52d1-a72a-8d8bbbe7fa9e",
    "entry": "行き会う",
    "reading": {
      "primary": "いきあう",
      "alternatives": [
        "ゆきあう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to meet someone by chance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「まさかこんなところで、学生時代の友人に『行き会う』なんて！」と、彼女は驚きを隠さなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "海外出張で立ち寄ったカフェで、偶然、取引先の担当者と『行き会う』ことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "災害支援のため被災地に入ったボランティアが、そこで偶然、旧知の人物と『行き会う』という出来事があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末、人通りの少ない美術館の片隅で、趣味の合う長年の知人と『行き会う』とは、運命を感じずにはいられなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "毎朝通る道すがら、いつもは顔を合わせないはずの近所の住人と『行き会う』ことが増えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの頃お世話になった恩師に、まさか、もう一度『行き会う』ことができるとは夢にも思わなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それでともかくも、全く顧慮なしにいつでも来かかった最初の電車に飛び乗る人にとっては、すいたのにうまく行き会う機会が少なくて、込んだのに乗る機会が著しく多い。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽井沢の町や新軽井沢の林間を歩いていて行き会う都人士は、みんななんとなく新軽井沢らしい顔と服装とをしている。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚吉は人糞をあげに行って、どうかすると、工場通いをしている人達に行き会うことがあった。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩行者は、こうして人に行き会うたびに、心を疲らせた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "香東川の堤で、早馬に二度も行き会うたぞ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして時々視線が行き会うと、妙にそれを避けるような様子があった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉取りの子供たちに行き会うただけであった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来で行き会う時だけ、「好い御天気で」などと声をかけるくらいの間柄に過ぎなかったらしく思われる。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "往還で行き会う荷馬も、大方は、用事をすませれば、町方へ帰るものか、又は、村から村へと行きずりの馬である。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘糟が国に残して置いた妻室が夢に忠綱が極楽往生をとげたという告げを聞いて驚いて国から飛脚をたてたが、京都からの使者と途中で行き会うて忠綱が戦場最期の有様を物語ったということである。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇都宮弥三郎頼綱が家の子郎党を従えて、済々として武蔵国を通ると、熊谷の入道直実に行き会うた。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮れがたの道で行き会う人ごとに聞くものはそのあいさつです。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き会う人ごとに、なんだか踏みつけそうな気がして、私は、「退け！",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は痩せて器量も落ちたので、往来で行き会う人々ももはや以前のように彼女をしげしげと見たり、にっこり笑いかけたりはしなかった。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き会う人々はその顔をつくづく眺めて、思わずうれしくなってこう話しかける。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶくぶくに肥った赭ら顔の彼がじゃらじゃら小鈴のついた｜三頭立てに乗って、これもぶくぶくに肥って赤ら顔のパンテレイモンが肉ひだのついた頸根っこを見せて馭者台に坐り込み、両の腕をまるで木で作りつけたようにまっすぐ前へ突き出して、行き会う通行人に『右へ寄れよお！",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "とちゅうで行き会う人はふり返って、わたしたちの姿が見た。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き会う巡査もふり向いてわたしたちを見送った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝同じ町筋で行き会う新聞配達や牛乳屋が会釈をするようになったのも考えものだ。",
              "citation": {
                "source": "朝起の人達",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫の死に行き会うた人は、人間の死の最悪の時期を経験しているから、いかなる悲しみもそれ以上に参ることはあるまいからだ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "二週間くらいの交替勤務らしく最初に会った医師には、とうとう行き会うことがなかった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きくパン・ポルの湾を見下ろす断崖の斜面の草地、そこで行き会うヤンとゴオド。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "登城する騎馬の侍だの、駕籠の列にも意地わるくよく行き会う。",
              "citation": {
                "source": "柳生月影抄",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また馬といえば、何マイル行っても種馬にばかり行き会うのであった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はある内部の必然な要求にかられて、ほとんど無意識に行き会うものごとを、さも骨が折れるといった様子で注視し始めた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は行き会うすべての人が忌まわしかった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの者は、めったに顔を明るみにさらすことをしないので、往来で普通行き会うような人のうちにはいなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は廊下や階段でジョンドレット一家の者に行き会うことは、一度ならずあったはずであるが、彼にとって彼らは皆単に影絵にすぎなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は思い出した、それは実際囚人らが運ばれるのであること、この回り道はフォンテーヌブローの大道ではいつ国王に行き会うかわからないのを避けるために昔から取られてる慣例であること、三十五年前には自分もまたこの市門を通って行ったのであることを。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "総理ジョンソン博士は占部牧師から特に頼まれている関係上、校庭で行き会うと、「河原さん、一寸待て」　と呼ぶ。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
