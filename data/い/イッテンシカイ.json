          ],
          "literary": [
            {
              "text": "大江戸にては早くより天下無双の美味となりしは、水土よろしきゆえに最上のうなぎ出来て、三大都会にすぐれたる調理人群居すれば、一天四海に比類あるべからず、われ六、七歳のころより好み食いて、八十歳までも無病なるはこの霊薬の効験にして、草根木皮のおよぶ所にあらず。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "国学者の斎藤彦麿翁はその著「神代余波」のうちに、盛んに蒲焼の美味を説いて、「一天四海に比類あるべからず」と云い、「われ六、七歳のころより好みくひて、八十歳まで無病なるはこの霊薬の効験にして、草根木皮のおよぶ所にあらず」とも云っている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどの霊薬かどうかは知らないが、「一天四海に比類あるべからず」だけは私も同感である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大江戸にては早くより天下無双の美味となりしは、水土よろしきゆゑに最上のうなぎ出来て、三大都会にすぐれたる調理人群居すれば、一天四海に比類あるべからず、われ六七歳のころより好み食ひて、八十歳までも無病なるはこの霊薬の効験にして、草根木皮のおよぶ所にあらず。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天四海皆帰妙法は夢となります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人二人三人百人千人と次第に唱え伝えて、遂に一天四海皆帰妙法の理想を実現すべく力説した日蓮聖人も、信仰の統一は結局、前代未聞の大闘争によってのみ実現することを予言している。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か数十年の短い年月で一天四海皆帰妙法は可能であろうか。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "只雑誌「明星」の読者を除ける一天四海の恒河沙人は必しも仮名遣改定案の愚挙たるを知れりと言ふべからず。",
              "citation": {
                "source": "文部省の仮名遣改定案について",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天四海の太鼓の音らしいのも聞える。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "真人の忠節によつて奥州の結縁を尽くし、爾より以降一天四海次第に結縁するなり。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、悲痛な面持ちで一天四海は法華の法だよ、てけれっつのぱあ　――もう一度、高座のまんなかへ帰る。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天四海、盆業渡世にねえ作法だ、ねえのを承知でお騒がせしましたこのおいら、逃げも隠れもするこっちゃござんせんといいてえが、今夜のところあ逃がして貰いてえのだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘安四年十月十三日、博多湾へ蒙古の船が押し寄せてきたときに、日蓮さまが波へ、「南無妙法蓮華経　一天四海皆既妙法」　と書いたら、急に神風が吹いて、蒙古の船が転覆してしまって、「モーコネーようにした」　という。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天四海、盆業渡世にねえ作法だ、ねえのを承知でお騒がせしましたこのおいら、逃げも隠れもするこっちゃござんせんと言いてえが、今夜のところあ逃がしてもらいてえのだ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに「一天四海」の石碑がある、その台石の上へ、よろけかかって腰を落しながら、「奸賊、新撰組！",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
