    "definitions": [
      {
        "index": 1,
        "gloss": "one house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山間に一宇の草庵をむすび、俗世を離れて風雅な余生を送る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "度重なる火災に見舞われ、往時の伽藍で現存するのはこの観音堂一宇のみである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ようやく故郷に一宇を構えることができました」と、彼は亡き両親の墓前に報告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "広大な敷地の一角に、賓客を招くための茶室として一宇を建立する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "吹き荒れる吹雪の合間に、遠く一宇の灯火を認めて安堵の吐息を漏らす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大震災の津波は、高台にひっそりと立つ一宇の祠を残して、全てを押し流していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まさか、これほど立派な一宇を独力で築き上げるとは」と、訪れた友人は驚きの声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "元禄の頃の陸奥千鳥には――木川村入口に鐙摺の岩あり、一騎立の細道なり、少し行きて右の方に寺あり、小高き所、堂一宇、次信、忠信の両妻、軍立の姿にて相双び立つ。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり、唯、単に、一宇の門のみ、生首に灯さで、淋しく暗かりしを、怪しといふ者候ひしが、さる人は皆人の心も、ことのやうをも知らざるにて候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "加州金沢市｜古寺町に両隣無き一宇の大廈は、松山｜某が、英、漢、数学の塾舎となれり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巉岩少しく凹む所樹木繁る中に一宇あるをみる。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨は人家ありけるよと打喜び、山｜岨の道なき処を転ぶが如く走り降り、やゝ黄ばみたる麦畑を迂回りつゝ近付き見るに、これなむ一宇の寺院にして、山門は無けれど杉森の蔭に鐘楼あり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく、さしもにお美事なお住居をお建て換えになりまして一宇のお寺を建立なされ、無明山満月寺と寺号をお附けになりました。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺内に一宇を建て総見院と呼んだ。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥か突当り――崖を左へ避けた離れ座敷、確か一宇別になって根太の高いのがありました、……そこの障子が、薄い色硝子を嵌めたように、ぼうとこう鶏卵色になった、灯を点けたものらしい。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "元禄の頃の陸奥千鳥には――木川村入口に鐙摺の岩あり、一騎｜立の細道なり、少し行きて右の方に寺あり、小高き所、堂｜一宇、継信、忠信の両妻、軍立の姿にて相双び立つ。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "崛起せる丘上、千年の老杉森々として、神さび立てる一宇の古龕、神鈴音なく、樓門の矢大臣も寂しげなり。",
              "citation": {
                "source": "北總の十六島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうの山の頂きに何かの建物があるのを見つけて、ともかくもそこまで辿り着くと、そこらは人跡の絶えたところで、いつの代に建てたか判らないような、頽れかかった一宇の古い廟がありました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "剪燈新話",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奥庭に張り出して、一宇の建物が立っていた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところ、よく世間で「八｜紘一宇」「世界一家」（世界じゅうの人たちが一家族のごとく相｜倚り相｜扶けてゆくこと）という言葉が用いられましたが、八紘というのは四方八方です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし八紘一宇の御精神を拝すれば、天皇が東亜連盟の盟主、世界の天皇と仰がれるに至っても日本国は盟主ではありません。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで真の世界の統一、即ち八紘一宇が初めて実現するであろうと考える次第であります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし最終戦争は、どこまでも統一に入るための荒仕事であって、八紘一宇の発展と完成は武力によらず、正しい平和的手段によるべきである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "八紘一宇とは戦争絶滅の姿である。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "口に八紘一宇を唱え心に戦争の不滅を信ずるものがあるならば、真に憐むべき矛盾である。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本主義が勃興し、日本国体の神聖が強調される今日、未だに真に八紘一宇の大理想を信仰し得ないものが少なくないのは誠に痛嘆に堪えない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　最終戦争は人類歴史の最大関節であり、それによって世界統一即ち八紘一宇実現の第一歩に入るのである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし真に第一歩であって、八紘一宇の完成はそれからの人類の永い精進によらねばならない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にわれらは数十年後に近迫し来たった最終戦争が、世界の維新即ち八紘一宇への関門突破であると信ずる。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし八紘一宇の大理想必成を信ずるわれらは絶対の大安心に立って、現実は自然の順序よき発展によるべきことを忘れず、最も着実な実行を期するものである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手に出れば相手はつけあがるなどと恐れる人々は、八紘一宇を口にする資格がない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん初期には幾多の余震をまぬがれないであろうが、文明の進歩は案外早くその安定を得て、武力をもって国家間に行なわれた闘争心は、人類の新しい総合的大文明建設の原動力に転換せられ、八紘一宇の完成に邁進するであろう。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に最終戦争終了後、即ち八紘一宇の建設期に入れば、人々の自由は更に高度に尊重され、全人類一致精進の中にも、各人は精錬された自由の精神を以て、自主的に良心的にその全能力を発揮するような社会状態となるであろう。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "八紘一宇の大理想達成に対する国民不動の信仰が、いかなる困難をも必ず克服する。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "予言を批難しようとする科学万能の現代人は、「天壌無窮」「八紘一宇」の大予言を、いかに拝しているのか。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類文化の目標である八紘一宇の御理想に基づき、政治的には全世界が天皇を中心とする一国家となる事は疑いを許さぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧たちの訴えを静かに瞑目して聴いていた住持三要は、いちいちうなずいていましたが最後に、「判った。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
