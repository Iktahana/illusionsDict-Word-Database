        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "岩室がぽっかり袋のように広くなったところもある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその時なんという事なしに矛盾不調和を感ずる一方では、またつめたい薄暗い岩室の中にそよそよと一陣の春風が吹き、一道の日光がさし込んだような心持ちもあった事を自白しなければならない。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "城内から出た時は小姓の岩室長門守、長谷川橋介、佐脇藤八、山口飛騨守、賀藤弥三郎の五騎に過ぎない。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴海の方面へ屯して居た佐々政次、千秋｜季忠、前田利家、岩室｜重休等は信長が丹下から善照寺に進むのを見て三百余人を率いて鳴海方面の今川勢にかけ合ったが衆寡敵せずして、政次、重休、季忠以下五十余名が戦死した。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに岩室といふあたりから佳くなつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに岩室というあたりから佳くなった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぶきが舞い込み、しずくが落ちる、あの滝の裏の岩室の中で、五年もの間苦しまれた、お祖父様のことを思いますとねえ」「そうしてそこで私達も、幾月かくらしたではございませんか」「それが私達をかえてくれました。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん深く入って行って、まっくらな林の中の、岩ばかりのでこぼこした道をよじて行きますと、やがて大きな岩室の前に出ました。",
              "citation": {
                "source": "大江山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴は間口七｜尺五｜寸に、奧行八｜尺の、高さ四｜尺、長方形の岩室で、それに柄を附けた樣に入口の道がある。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "お穴樣の探檢",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、部屋とはいえ、むしろ岩室と呼ぶほうが似つかわしいであろう。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は漸く山上の高寒を肌に感じながら、一分も早く今夜宿る無人の岩室に辿り着くべく、懸命に急角度の斜面を登つて行つた。",
              "citation": {
                "source": "槍ヶ嶽紀行",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければ支流の片品川の吹割の滝の下流、岩室付近である。",
              "citation": {
                "source": "水と骨",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩室の娘たち　毒消し部落は角田山の海寄りであるが、角田と弥彦をとりまく平野側には蟻のはいでる隙もなく新潟芸者の産地がギッシリたてこんでいるのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代表的なのが岩室と地蔵堂だ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "地蔵堂の方は町であるが、岩室は村だ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は「岩室のタンボ芸者」という言葉があった。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和のはじめごろまで、この岩室から半玉ででた娘の中で美しいのが新潟へよばれて一流の芸者になり、その中からまた新橋の一流がでるというように、ここは美人芸者の産地として名高かったのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日から掛けて明日一杯、おめでたいことがあるのでの、お殿様からお酒を振る舞われ早くお暇さえ出たというものさ」　云い云い彼は岩室の中の二間しかない家の中へ機嫌よくノッソリと上がって行った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "売店なんかもやっていないだろうし、生憎だったね」　久美子が弱ったような顔をしてみせると、そのひとはむやみに同情して、この辺には宿屋なんかないから、大室山の岩室ホテルへでも行くほかはなかろうと、おしえてくれた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "）キプロスの荒き岩室に、海の神にも塞がれず、8360地震の神にも崩されず、常世の風に吹かれつゝ、上れる代に変らぬ、静かに覚れる、楽しき心を持ちて、われ等キプリスの車を蔵め持たり。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇しき事多き岩室を称へむ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "並びたる数箇の岩室に倚せ掛け、生きたる草木もて数軒の家を編み成せり。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "確か七合目あたりで午飯を食ったように覚えているが、其頃の岩室は極めて粗末なもので、這入口は石で取かこまれていて、其中に這入ると蓆が敷いてあって、其奥に一人の人が居て手桶に汲んだ水が置いてある他に、竈や、鍋や釜などが置いてあった。",
              "citation": {
                "source": "富士登山",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩室の中でも頂上に次では此の七合目あたりがいいのだと聞いて居ったが、それですらがこんな質素なものであった。",
              "citation": {
                "source": "富士登山",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も地中に掘り込んだ岩窟であるから非常に発達したという今日でも尚お大した変化はないかも知れぬが、その岩室の低い天井からランプを釣り下げて、其暗い灯かげに無愛想な顔をして一人の男が坐っていた光景は余りいい心持のものではなかった。",
              "citation": {
                "source": "富士登山",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ等は強力に持たせて行った米を此の岩室で炊いて、携えて行った鑵詰類を菜にして午飯を食ったのであった。",
              "citation": {
                "source": "富士登山",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "只寒さは、それ以来著しく強くなったので、銀明水の辺も急いで過ぎ去ってしまって、頂上の岩室に辿りついた。",
              "citation": {
                "source": "富士登山",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴球君だけが肥大の躯を持て除して七合目か八合目かの岩室に止まった。",
              "citation": {
                "source": "富士登山",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上の岩室は数が多い許りで、其｜※末さは七合目等のものと似たり寄ったりであった。",
              "citation": {
                "source": "富士登山",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行中の二三人がもういびきをかいて寝ている時分に、私は急に大便を催したので岩室を出て外｜廁に行った。",
              "citation": {
                "source": "富士登山",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
