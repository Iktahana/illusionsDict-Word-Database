          "literary": [
            {
              "text": "兄は一度引受けたことを飽くまでも守り通す性質で、人一倍体面を重んずる人で、おまけにこの事は娘の生涯にも関ることであるから。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "人一倍体の逞しいＳは珍しい日の光を浴びたまま、幅の狭い舷梯を下って行った。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
