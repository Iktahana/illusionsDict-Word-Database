          "literary": [
            {
              "text": "私ノスケッチデハ私ノ感ジガドウモ出ナイデコマリマス。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之アいよいよ警察の仕事になって来たわい」　　　　　　　　　　鳶色の洋服　所轄警察署から小浜信造宛に、スグオイデコウ　という電報が打たれた。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オウバツネコキトクオイデコフ」フジモト　大庭常子のアパアトでは、上を下への騒ぎでした。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お江戸の方角に、居るはずじゃけんどなあ」「わからん」「オキヨウキトク「スグオイデコウ」五ロウ」――こういう電報が来たのは、金五郎とマンとが、久しぶりに、のどかなさしむかいで、そんなとぼけた会話をとりかわしているときであった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
