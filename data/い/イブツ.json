    "definitions": [
      {
        "index": 1,
        "gloss": "foreign substance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食事中に、スープの中に小さな異物を見つけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "目に異物が入ったようなゴロゴロとした不快感が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工場では製品に異物が混入しないよう、厳重な管理がされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "よもあらじとは思へど、唯そのものゝやうに懐かしく、恋しきにも珍らしきにも涙のみこぼれて、この虫がやうに、よし異物なりとも声かたち同じかるべき人の、唯今こゝに立出で来たらばいかならん。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶因狂疾成殊類　　災患相仍不可逃今日爪牙誰敢敵　　當時聲跡共相高我爲異物蓬茅下　　君已乘※氣勢豪此夕溪山對明月　　不成長嘯但成※　時に、殘月、光冷やかに、白露は地に滋く、樹間を渡る冷風は既に曉の近きを告げてゐた。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶因狂疾成殊類　災患相仍不可逃　　　今日爪牙誰敢敵　当時声跡共相高　　　我為異物蓬茅下　君已乗※気勢豪　　　此夕渓山対明月　不成長嘯但成※　時に、残月、光｜冷やかに、白露は地に滋く、樹間を渡る冷風は既に暁の近きを告げていた。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時幾日にどこでこういう事に出会ったとか、何という書物の中にどういう事があったとか、そういう直接体験の正直な証言の中に、現在の例と同じような過程で途方もないところから紛れ込んだ異物が少しもはいっていないという断定は、神様でないかぎりだれにもできそうにない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『嬉遊笑覧』九にいわく「『談往』に馮相詮という少年の事をいって『異物志』にいわく霊狸一体自ら陰陽を為す、故に能く人に媚ぶ皆天地不正の気云々」。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからダニール・ウィルソンいわく、新世界へ欧人移り入りて旧世界でかつて見ざる格別の異物を睹た時、その鳴き声を擬て名を付けた例多し。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほど昔ギリシア中でテッサリアの山民のみ騎馬を善くした時、他の諸民これを半人半馬の異物と思うた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから考えて、母の血を銭に塗り子の血を別の銭に塗り、いずれか一方を留め他の一方を使うと相慕い帰るというが高誘、葛洪等の説だが、『異物志』には、この虫雌雄相離れず、法を以てこれを制し雌雄の血を銭に塗って昼間物を買うと夜になって帰り来るとある。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱の家には猴を飼ってありましたが、厩の者が夜なかに起きて馬に秣をやりに行くと、そこに異物を見ました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、脳髄の中にその黒い異物である斑点が交っていれば、脳髄の働きを害するにちがいない。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ古賀であつたから、その夜すこしぐらゐの異物感を目のなかに感じたとしても大したことにはおもはなかつたのである。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ふに其の生れて世に在るや、沖天の雄志躍々として禁ふる能はず、天下を擧げて之に與ふるも心慊焉たらざりしものも、一旦｜魂絶えて身異物とならば、苔塔墓陰、盈尺の地を守つて寂然として聲なし、人生の空然たる、哀しむべきの至ならずや。",
              "citation": {
                "source": "人生終に奈何",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南方異物志」に、本当のろくろ首の項の上には、いつでも一種の赤い文字が見られると書いてある。",
              "citation": {
                "source": "ろくろ首",
                "author": "ROKURO-KUBI",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは水ではげたのではなく、何か異物、たとえば他の薬品を塗りつけたことが想像されます。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "したが、遠い遠い昔の物語や、＊ザポロージェ人の遠征、波蘭人の話、さては＊ポドゥコーワだの、＊ポルトラ・コジューハだの、＊サガイダーチヌイだのの武勇談、さういつた風な昔語りよりは、どちらかと言へば、何かかう、古めかしい怪異物語の方にわたしたちはずつと牽きつけられたものぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほやうにふるまつてはゐても、富岡達日本人のすべては、此の土地では、小さい異物に過ぎないのだ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、三十幾つか取り出されて、現在は屍蝋室の硝子盤の中に貯蔵されているのですがなかには膜が、相当強靭なものもあるのですよ」「なるほど」　と法水も頷いたが、「全く腹腔内の異物が、こんな所に散乱しているなんて、実に薄気味悪い話です。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年少の友だつた田能村竹田の、「収蔵せる法書、名画、金石、彝鼎、及び夷蛮より出づる所の異物奇品｜棟宇に充積す」と言つたのも必しも誇張ではなかつたであらう。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯彼に在つては、異物崇拝の対象なる族霊（とうてむ）の像を柄頭につけるが、桙の方には其がない。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヨは恐らく、自分の不安定な映像を、或る瞬間に異物と感ずるのであろう。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの蠅を捕獲して、六本の脚と一個の口吻とに異物が附着しているかいないかを、顕微鏡の下に調べる。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "葢し君の性は駿敏、僕は則ち儒緩、君の體は彊健、僕は即ち羸弱、窃に以爲らく、一朝君に先だち、化して異物とならば、身後の事、應さに君の經紀に頼るべしと。",
              "citation": {
                "source": "祭原教授文",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その異物はたいへん小さい白い点であって、正体はまだ何物とも分らなかったけれど、とにかく今から五十四日前に突然現われた物であって、それは以前には決して見当らなかったものであった。",
              "citation": {
                "source": "月世界探険記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うたても花やかなる哉とて、「異物は喰はで、仏の御｜撤下物をのみ喰ふが、いと貴き事かな」と云ふ気色を見て、「何どか異物も食べざらん、それが候はねばこそ取り申し侍れ」と云へば、菓物、広き餅などを物に取り入れて取らせたるに、むげに中善くなりて、万の事を語る。",
              "citation": {
                "source": "濫僧考補遺",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷を洗い、異物を取り除き、整形縫合し、薬をつけて、繃帯を巻き上げるまでには、一人の患者にずいぶん時間をとられる。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸老｜已ニ異物トナリ二公モマタ逝ケリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "また李時珍が曹叔雅の『異物志』を引き「芭蕉。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨はこいつ、もつたいぶつてね、他にある、なんて言ふんだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで奈良のだいぶつさまにさんけいするみんなの絵のようだと一郎はおもいました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで奈良のだいぶつさまにさんけいするみんなの絵のやうだと一郎はおもひました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
