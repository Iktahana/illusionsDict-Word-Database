[
  {
    "uuid": "529f0ce0-e076-5419-bae3-6c6da072c65d",
    "entry": "一宿",
    "reading": {
      "primary": "いっしゅく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "staying one night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅の途中で、親切な村人に一宿を乞うた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今夜はぜひ、我が家で一宿していってください」と主人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "武士は、見知らぬ土地で一宿の恩義を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」　其処へ、突掛けに　紺がすりの汗ばんだ道中を持って行くと、「はい、お旅籠は上中下と三段にございますがな、最下等にいたしましても……」　何うして、こんな旅籠へ一宿出来よう、服装を見ての口上に違いないから。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一宿りして、こゝを、又こゝから立つて、大雪の中を敦賀へ越した事もある。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坦坦翁、生平実に坦坦、文章学術を以て太祖に仕え、礼儀の制、選挙の法を定むるの議に与りて定むる所多く、帝の洪範の注成るや、命を承けて序を為り、勅修の書、省躬録、書伝会要、礼制集要等の編撰総裁となり、居然たる一宿儒を以て、朝野の重んずるところたり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が一宿を頼んだときにも、彼は初めの親切にひきかえてすこぶる迷惑そうな顔をみせた。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　一宿の礼をあつく述べて叔父は草鞋の緒をむすぶと、僧はすすきを掻きわけて、道のあるところまで送って来た。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて信心する養安寺村の蛇王権現にお詣りをして、帰りに北の幸谷なるお千代の里へ廻り、晩くなれば里に一宿してくるというに、お千代の計らいがあるのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の元和年中、許州の趙季和という旅客が都へ行く途中、ここに一宿した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の煙草の火のおかげで、私は煙草を一服吸う事が出来るのだもの、謂わば一宿一飯の恩人と同様である。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一宿一飯の恩義などという固苦しい道徳に悪くこだわって、やり切れなくなり、逆にやけくそに破廉恥ばかり働く類である。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日、午後箱館に至りキトに一宿す。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "操曰く、そこの林中にわが父と兄弟のごとく交わった呂伯奢の家あり、今夜一宿しようと。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹操は過ぎた事は仕方がない、早く遁りょうと馬に乗って二里ほど逃げ伸びると、呂伯奢驢に騎し酒果携えて来り、二人の忙ぎ走るを怪しみ何故早く去るぞ我家に豕一匹を用意した、是非一宿せよというを曹操たちまち刺し殺した。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）姫路に一宿せし時宿主に問ふに成程城中に左樣の事も侍べり、此所にてハッテンドウと申す。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨風は舊遊の夢の名殘やしのばれけむ、これより土浦にもどりて一宿せむと言ひ出でたれど、余は那珂川を下りて大洗に一宿する方が、紀行の種も多くなりて面白かるべしと云ふ程に、崖下の汽笛頻に客を呼ぶ。",
              "citation": {
                "source": "水戸觀梅",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年大雪山に登るもの百人内外、忠別川を溯りて松山温泉に一宿し、次の日姿見の池の畔に野宿し、その次の日旭岳に登るだけにて、引返して松山温泉に再宿するなりと、嘉助氏いえり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "祠家に一宿して、夜、猿鹿の和鳴するを聞くも興あらむと思ひしかど、宿らんとする賽者多く、雜沓甚しきに辟易して、せめて鮎川の漁家なりともと思ひしが、幸なる哉、石ノ卷鹽釜行きの汽船、午前四時にこゝを發すと聞き、之にのることにさだめぬ。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは折入つて一宿の許しを請うた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処では秩父四百竃の草分と呼ばれてゐる旧家に頼んで一宿さして貰うた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の旅なら、むろんここで一宿していい刻限であるが、追えど走れど、行徳助宗とおぼしき姿も影も見えないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれはどこぞへ一宿せねばならぬ旅の身じゃ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍　蓋平に一宿した時である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中、役人は古い廟に一宿すると、その夜のあいだにかの三千金を何者にか奪われた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、捕盗の役人を送って行って、駅舎に一宿した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "津はいかにも城下らしいおちついた都会であつた、梅川屋といふのに泊る、一宿二飯で三十四銭！",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつそく街へ、Ｋ店で少々借りて湯田へ、例のＳ屋に泊る、一宿二飯で四十六銭。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏通寺（許山一宿）・あけはなつや満山のみどり　水音の若竹のそよがず・山のみどりのふか／″＼雲がながれつゝ・塔をかすめてながるゝ雲のちぎれては・ほんにお山はしづかなふくろう四月三日　曇――晴れさうな、尾ノ道にて。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
