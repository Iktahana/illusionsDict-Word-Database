    "definitions": [
      {
        "index": 1,
        "gloss": "house mosquito (genus Culex)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
