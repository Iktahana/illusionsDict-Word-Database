        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「どうぞ、こちらの椅子にお掛けになってお待ちください」と受付の女性に案内された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長時間のデスクワークによる腰痛を軽減するため、人間工学に基づいて設計された高機能な椅子を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は手際よくパイプ椅子を並べ、わずか三十分で講演会の会場設営を完了させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このアンティークの椅子は、座面の布を張り替えながら祖父の代から三代にわたって受け継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よいしょ」と重い腰を上げ、彼は窓際の椅子から立ち上がって来客を迎えに出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "次期社長の椅子を巡り、役員たちの間では水面下で激しい主導権争いが繰り広げられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フローリングが傷つくのを防ぐため、椅子の脚の裏にフェルト状の保護材を貼り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "うすやみ萩原朔太郎うすやみに光れる皿あり皿の底に蟲かくれ居て啜り鳴く晝はさびしく居間にひそみて鉛筆の心をけづるに疲れ夜は酒場の椅子にもたれて想ひにひたせる我が身の上こそ悲しけれ",
              "citation": {
                "source": "うすやみ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その混乱をなんとか見究めようとして色々に考へても、それは自分で椅子に乗つて自分で椅子を動かさうといふのと同様、努力すれば努力する程拙いこととなるのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は前夜の飲過ごしでぐつたりして、少し卓子の割合には高過ぎる椅子に腰掛けて、煙草を喫つたり本を読みかけてみたり、と、急に思ひ出して此の日頃方々で受取つた名刺の整理をしたり、――要するに何の野心もなく、その日第一回の食事を済ましたばかりのところであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああ」と私は、椅子から起つて、欠伸をした。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく暑中休暇にはいり、東京から二百里はなれた本州の北端の山の中にある私の生家にかえって、一日一日、庭の栗の木のしたで籐椅子にねそべり、煙草を七十本ずつ吸ってぼんやりくらしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは程よく背を圧する椅子とその背とのやうな関係であつたのである。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は珈琲店の椅子で酒を飲み、大衆と共に「あなたと呼べば」を唄つた後で、自ら自分の髪の毛をむしりながら、自分に向つて「この大馬鹿野郎奴」と叫ぶのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなれば追はるる如く歳暮の忙がしき街を憂ひ迷ひて晝もなほ酒場の椅子に醉はむとするぞ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日宅の女中が近所の小母さん達二、三人と垣根から隣を透見しながら、何かひそひそ話しては忍び笑いに笑いこけているので、自分も好奇心に駆られてちょっと覗いてみると、隣の裏庭には椅子を持出してそれに楠さんが腰をかけている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその日人生に、　　椅子を失くした。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな頭、長い裳裾、椅子は一つもないのです。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際の籐椅子に腰かけて、正面に聳える六百山と霞沢山とが曇天の夕空の光に照されて映し出した色彩の盛観に見惚れてゐた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其爲に階上階下の部屋といふ部屋は一杯で廊下の籐椅子に迄もはみ出してゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子に腰かけている両足の蹠を下から木槌で急速に乱打するように感じた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際の籐椅子に腰かけて、正面に聳える六百山と霞沢山とが曇天の夕空の光に照らされて映し出した色彩の盛観に見惚れていた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の智慧　ある人の飼猫は主人の居室で椅子の上に登って呼鈴のボタンを押しボーイを呼出す癖があった。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "では真向きの全身――椅子を直すふりして女客は立ち上った。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　並木の有料椅子のランデヴウ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧巴里の遺物　オペラの辻を中心に、左右へ展開する大通とイタリー街のキャフェたちは、朝の掃除をしまって撒いた赭砂の一掴みを椅子やテーブルの足元に残している。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と言って椅子の背へもたれてしまいました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈悲深い男は、家外の寒さを思い遣り乍ら室内のストーヴの火に暖を採り、椅子にふかふかと身を埋めて静に読書して居りました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚木は自分ながら壮躯と思われる身体に、麻布のブルーズを着て、頭を鏝で縮らし、椅子に斜に倚って、煙草を燻ゆらしている自分の姿を、柱かけの鏡の中に見て、前とは別人のように思い、また若き発明家に相応わしいものに自分ながら思った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下｜越しの部屋から椅子直しのマギイ婆さんがやって来た。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が好んで落ちつく長椅子の隅――罠はそこだ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "整然として椅子を引いて、眼平らにこっちを見る。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく人の途絶えたときに、仏になった老人の未亡人が椅子に腰かけて看護に疲れたからだを休めていた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと彼の椅子が出来ると間もなく、チューリヒの大学の方で理論物理学の助教授として招聘した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば「石」という語と「椅子」という語は、我々はこれを聴いて確かに別の語だということがはっきり判る。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびよりかへれる巡禮のうた萩原朔太郎いすらへるよりかへり　われはゆきのうへにたちぬ",
              "citation": {
                "source": "たびよりかへれる巡禮のうた",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日経よむと墓を弔いするで、よろこぶの生きるです』『あなた、ほかの世、坊さんと生れて下さい』『ああ、私願うです』　人間よりも、虫や鳥の方が幸福だと言ったヘルンは、人生について、悲哀の外の何物をも知らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "post",
