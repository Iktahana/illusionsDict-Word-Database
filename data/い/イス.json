    },
    "definitions": [
      {
        "index": 1,
        "gloss": "swords (suit)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の配られた手札には、イスのカードが三枚含まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このトリックテイキングゲームでは、イスが最も強いスートだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "トランプゲーム中に、彼はしきりにイスのカードを集めようとしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最終ラウンドで、彼女は自信満々にイスのクイーンを出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "タロット占いにおいて、イスのカードはしばしば困難や知的な挑戦を象徴する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ブリッジのプレイ中、彼はパートナーにイスへのリードを指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "昼間は毎日暑く、今産院にゐる娘は「ブーラ、ブーラ、ブーラブラ」といふ象といふ題の児童唱歌をオルガンで歌ひ、姉娘は夜になるとパウリスタに連れてつてアイスクリームを食べさせてくれた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神は貴族とエゴイストとを罰するために彼等の心から愛憐の芽生をぬき去つた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あの偉大なるトルストイを始めとして、世の多くの貴族と生れながらのエゴイストとが、悩み苦しみて求めるものは、実にこの「生えざる」苗を求めんとして嘆き訴ふる悲しみの声に外ならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "（しかし朝はウイスキイを用い、ビフテキも好んで食った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて始めて両親を離れ、飛び立つ思ひなり、その秋の暮、寒い夜に丸太町橋際の古本屋で「ダダイスト新吉の詩」を読む。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイスクリームでも取つてこいつてねーやにお言ひ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイスクリームを貰つたかい。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍなんて、兎に角今の中学校なんかが猫のやうな善良さで押し通せる奴つたら、延膸が大脳の割合に発達してゐないで、大脳が一通り悪い意味のエゴイスチックな発達をした奴だ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後二十年たってドイツのエナでツァイスの工場を見学したとき、紫外線顕微鏡でこの同じ珪藻の見事な像を蛍光板の上に示されたとき、この幼い記憶が突然甦って来るのを感じたのであった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの話は、柳家小さんの落語のごとく、クライスラーのクロイツェルソナタのごとく実に何度となく同じ聴衆の前に繰返されて、そうしてその度ごとに新しくその聴衆を喜ばしたものである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに人間の本然のすがたを見せ、はたまた嚴酷なるダンデイスムを感じさせるものをのみ指して言ふのであらう。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装はスイスから取り寄せた品で、羽をはさんだ帽をかぶり、ピッケルを手にして考えているようなポーズをしたものであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルプスの美を、知覚的に讃美したのは、スイスの農夫でなくて、旅人であった如くに、富土山もそうであった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ひどい搾取下にある島民たちで生活されているが、見たところは、パラダイスであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々と六かしい、しかもたいていはエゴイスティックな理窟を並べてはいるようであるが、結局は、当り前分り切った年賀状の効能を五十の坂を越えてから始めてやっと気のつくようになったのであるらしい。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れも矢張り宿屋へ蓄音機を持ち込み、宿屋で東京音頭を踊るタイプの、無邪氣で善良で、人に迷惑をかけるのを人情の厚い證據とするアルトルイスト日本國民のすることである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し不人情でエゴイストの自分等のやうなものには迷惑なのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイスあたりの山のホテルを想わせるような帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルという宿屋に泊った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高いオペラの空気窓から「タイスの」唄が炭酸｜瓦斯にまみれて浮き出ている。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンチングを横っちょにかむり、何か腹掛けのようなものを胸に当てたアイスクリーム屋のイタリー人が、いつか焼栗売りに変っている。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリームの寒帯から早く焼栗屋の熱帯へ……は、いらはい、いらはい。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ神のみ名によるエゴイストだと、君はもう一遍、云って呉れ。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと外へ出て見るとそこは上野公園のような処で、自動車やボーイスカウツが群集している。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何たべる」「何にしよう」……「御飯だの、おかずだの別々にたべるの面倒くさいわ、チキンライスにしましょう」。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このチキンライスの話と輪飾りの話には現代思潮の反映がある。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "steak はアイスランディックの steik と親類らしいが「ひたきのおきな」の「ひたき」を「したき」となまると似て来るからおもしろい。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "anger はアイスランドの 〔a&ngr〕 やＬの angor などのような「憂苦」を意味する言葉と関係があるそうで、一方ではまたスウェーデンの「悔恨」を意味する 〔a&nger〕 に通ずる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロレンツのごとき優れた老大家は疾くからこの問題に手を附けて、色々な矛盾の痛みを局部的の手術で治療しようとして骨折っている間に、この若い無名の学者はスイスの特許局の一隅にかくれて、もっともっと根本的な大手術を考えていた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく彼はチューリヒのポリテキニクムへ入学して数学と物理学を修める目的でスイスへやって来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇一年、スイス滞在五年の後にチューリヒの公民権を得てやっと公職に就く資格が出来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
