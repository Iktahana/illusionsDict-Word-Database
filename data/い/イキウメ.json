        "examples": {
          "standard": [
            {
              "text": "遺体は、犯人によって裏山に生き埋めにされていたことが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古代では、罪人に対する最も苛烈な刑罰の一つとして生き埋めが用いられた記録がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "恐怖映画では、主人公が暗闇の中、土に生き埋めにされる恐怖に直面する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "衝撃的なニュースで、大規模な土砂崩れに巻き込まれ、生き埋め状態となった作業員の救出活動が続けられていることを報じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、敵から逃れるために偶然見つけた地下壕に隠れたが、入口が塞がれ、生き埋め寸前の状況に陥った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、そんな残虐な方法で……。生き埋めなんて、想像するだけで恐ろしいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "十　生き埋め　丘の大麦は暑い頃になつて熟れる。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはそこへ、この「昼とんびに違ひない坊主」を、生き埋めにしてしまふといふのであつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしがこの盗人を生き埋めにせよと命ずるのだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊さんを生き埋めにするといふことをきいて、飛んで来ましただ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰る途で吉三郎さんが、「それにしても良寛さんは、生き埋めにされるといふのに、どうして一言もいひわけを仰有らなかつたのです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくの山崩れには、十三人が一度に生き埋めになった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこへ穴を掘って、その中へまっすぐに立たせたまま、生き埋めに埋めておしまいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は崖くずれに押し潰されて生き埋めとなったのである。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察に訴えてその取調べをうけると、生き埋めになった男は、女房殺しの森川権七とわかった。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日つづきの風雨に地面の土がゆるんで、あたかも源右衛門の上に落ちかかったらしく、彼はそのまま生き埋めの最期を遂げたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず第一は練塀小路の妙見堂、つづいては柳原のひげすり閻魔、それから湯島坂下の三ツ又稲荷、少しく飛びまして本所四ツ目の生き埋め行者、つづいては日本橋｜本銀町の白旗｜金神なぞ五カ所がまず名の知れたところでござります」「よく教えてくれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおかた、今夜は本銀町の白旗金神か、本所四ツ目の生き埋め行者のほうへでも、同じ仲間が人を替え手を替えてのろい参りにいったろうよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした早く、生き埋め行者と白旗金神と両方をこっそり調べにいってきな」　いうにゃ及ぶとばかり急ぐほどに、しとしと霧のような秋時雨です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "白旗金神のほうはおるすでしたがね、やっぱりゆうべ本所四ツ目の生き埋め行者へ出たんですよ」「やられていたか」「いた段じゃねえ、ほこらの前にね、はかまをはいて大小さしたわけえ侍が、同じようにのど笛をえぐられてのけぞっていたんですよ」「わら人形も見つけてきたか」「そいつをのがしてなるもんですかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつも少しあわを吹いたところへ、けさのこの生き埋め行者の一件が耳にはいったんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべだってもあれほど四方八方へ網を張っておいて、生き埋め行者に迷って出た下手人を見のがすんだからな、そうと事が決まりゃ、おいらは今夜も湯島の三ツ又稲荷だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "お城普請やお屋敷なんぞを造らえる時に、秘密の抜け穴や秘密仕掛けの部屋をこっそり造らえて、愈々出来上がってしまうと外への秘密が洩れちゃならねえというんで、工作人夫を生き埋めにしたり、バッサリ首を刎ねたりするってことを聞いておりますんでね。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "住いの庭にある生き埋めの井戸というのがそれです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論この住いは、篠原梅甫が今の妻女の小芳を吉原から身請したとき、場所が閑静なのと、構えの洒落ている割に値が安かったところから買い取ったものだが、安いというのも実はその生き埋めの井戸というあまりぞッとしない景物があったからのことでした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き埋めの井戸の上のあの繁みなのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこの生き埋めの井戸というのがあるのを幸い、脅しつけろ、と腰本様がおっしゃりましたゆえ、変化の真似をしたのでござります……」「たわけものめがッ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、もし僕たちがもう少し前へ進んでいたらば、今ごろは生き埋めになっていたでしょう。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き埋めにされるのもあった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
