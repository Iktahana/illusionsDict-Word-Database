    "definitions": [
      {
        "index": 1,
        "gloss": "century",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この老舗旅館は創業から一世紀もの間、変わらぬおもてなしの心を守り続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "産業革命から約一世紀が経過し、人類の生活様式は根底から覆された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地下鉄のトンネル掘削中に、一世紀以上前の地層から当時の生活雑器が発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一世紀も前の話をされても困るよ」と、彼は古い文献を閉じて苦笑した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、日本人の日常生活がだんだん西洋人のに近くなって一世紀二世紀と経つうちには髪の色もだんだん明るくなって行かないとも限らないであろう。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一世紀以前の科学者に事実であった事がらが今では事実でなくなった例はいくらもある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はだれかの物理学史を読んでいるうちに、耶蘇紀元前一世紀のころローマの詩人哲学者ルクレチウス（紀元前九八―五四）が、暗室にさし入る日光の中に舞踊する微塵の混乱状態を例示して物質元子（１）の無秩序運動を説明したという記事に逢着して驚嘆の念に打たれたことがあった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九世紀二十世紀を予言した彼がどうしてきたるべき第二十一世紀を予言していないと保証する事ができようか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし不幸にして二十世紀の民衆の大多数は紀元前一世紀の大多数と比較してこの点いくらも進歩していない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし自然の歴史が繰り返すとすれば二十世紀の終わりか二十一世紀の初めごろまでにはもう一度関東大地震が襲来するはずである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しさを知らない大陸のいろいろな思想が、一時ははやっても、一世紀たたないうちに同化されて同じ夕顔棚の下涼みをするようになりはしないかという気がする。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッシリアのものはわずかに極東日本にその遠い子孫を残すに過ぎないと思われていたが、同じようなものが東トルキスタンで発見されたそうである（紀元一世紀ごろのもの）。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど一世紀以前、日本の片隅に於て活版術を実用化せしもの既にありといっても過言で無い。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃、孔子老子の二聖は歿して、約一世紀半ほどの距てはあるがいわゆる「学」と称えられるものは後嗣の学徒によって体系を整えて来はじめ、それと伍して幾つもの学派が並び起った。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モントリシヤは紀元十一世紀頃に既にフランス第一の都として有名だったそうです。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝に平氏あり、夕に源氏あり、飄忽として去り、飄忽として来る、一潮山を噬んで一世紀没し、一潮退き尽きて他世紀来る、歴史の載するところ一潮毎に葉数を減じ、古苔蒸し尽して英雄の遺魂日に月に寒し。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………………………………………………　これは三千年前の神の裁判の判決でありますが、これを二十一世紀の今日に於ける鼻の表現の実際に徴して見ると、どんな事になるでありましょうか。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏物語は、欧洲に於ける写実小説の元祖であるボッカチオの「十日物語」よりも、尚ほ三百五十年前に書かれて居り、支那小説「水滸伝」よりも、一世紀先に書かれてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（17）『宗教裁判法』（18）Pomponius Mela ――スペインで生れた一世紀ごろのローマの地理学者。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一世紀の電脳キッズはＴＲＯＮを笑うものを笑う「二十四時間世話焼きマシンと書かれたタマゴからは鬼がでるのか蛇がでるのか」　前項のオレからこの場のオレに託されたのは、果たしてこのタマゴから何がでてくるのかとの問いである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまある本のかたちは遠く紀元一世紀の中国における紙の発明にはじまる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯一世紀前、かの大ナポレオンは、世界をその飽くなき欲望の餌食たらしめんとした。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私人生産業限度内ノ事業ニ於テ將來半世紀一世紀間ハ現代ノ如キ腐敗破綻ヲ來ス怖アル者ト推定スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに就いては小説的の閲歴があるのさ、情夫ぢやない、亭主がある、此奴が君、我々の一世紀｜前に鳴した高利貸で、赤樫権三郎と云つては、いや無法な強慾で、加ふるに大々的｜※物と来てゐるのだ」「成程！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前ローマ人は、半男女を不祥とし、生まれ次第海に投げ込んだが、後西暦一世紀には、半男女を、尤物の頂上として求め愛した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマでは紀元前一世紀、文学奨励で著名だったマエケナスが驢児を饌用し初めた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "例せばスコットランドでは十一世紀に、マルコルム三世、この風を発せしが、仏国などでは股権とて十七世紀まで幾分存した。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から一世紀前の動物学者は、こんな風に考へたでもあらう。",
              "citation": {
                "source": "文学の本質について（一）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きると、それでも、わずかな時間の睡眠のために、昨夜の出来事が、まるで一世紀も前の出来事だったような気がして、少しきまりがわるくさえなりました。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　日本の文明が、多くの点において、西洋に半世紀ないし一世紀おくれているという事実、近代小説の発達においてもほぼ同じくらいおくれているという事実を考えると、日本に、探偵小説と名づくべき作品がほとんどなく、探偵小説の作家がまだほとんど現れないということは当然のことのように思われる。",
              "citation": {
                "source": "日本の近代的探偵小説",
                "author": "――特に江戸川乱歩氏に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに十一世紀の中葉この聖地はトルコ族の一派セルジュウク人によって占領され、聖廟は荒らされ、遺跡は蹂躪され、巡礼は掠奪迫害され、土地在住のキリスト教徒は殺戮される迄に至った。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前なんぞの出發點は今から一世紀も前にすでに試驗ずみなんだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
