[
  {
    "uuid": "1f6d87f1-984c-5b99-9cd5-4042090962f6",
    "entry": "安んぞ",
    "reading": {
      "primary": "いずくんぞ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
