        "examples": {
          "standard": [
            {
              "text": "小学校で習った「因幡の白兎」の話は、今でも鮮明に覚えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "騙された白兎が、サメの皮で剥がされてしまったという、因幡の白兎の悲しい結末。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現代でも、因幡の白兎は鳥取県のシンボルとして親しまれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "其頃母からおちごという牛若丸のような髷にいつも結ってもらって友禅の被布をきておとぎ文庫の因幡の白兎や、松山鏡を読みふけり乍ら盆の蜜柑をしきりに飽食する少女だった私は、南国というものによほど縁があると見え、嫁して二十五年余り、小倉の町にすみ馴れて年毎に柑橘の花をめでるのである。",
              "citation": {
                "source": "朱欒の花のさく頃",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが因幡の白兎というものです。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
