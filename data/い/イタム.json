      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to hurt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最近、気圧の変化で頭が痛む日が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "食べ過ぎて胃が痛むので、消化の良いものを食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "加齢とともに、腰のあたりが鈍く痛むようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "サッカーの試合で負った膝の怪我は、今でも時々痛む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、昨日遅くまで仕事したから、肩が痛むよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫？どこか痛む？」と彼女は心配そうに尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "触診の結果、肋骨にひびが入っている可能性があり、押すと痛むという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その底がどれほど深いかその奥に何があるかいくら眼をこすってのぞいてもなんにも見えずたゞ眼がしんしんと痛むのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その高い襠で擦れた内股にひびが切れて、風呂に入るとこれにひどくしみて痛むのもつらかった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別にかわったことはないがだんだん躰が疲れてゆく　腰の痛背のいたみ少しでもさわるとたまらなく痛む。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんだ石松」　「七五郎、しばらく、かくまって呉れ……吉兵衛の奴、卑怯にも欺し討ちにしやがった……俺の帰って来た事を何処で聞きやがったか、あの野郎……」　お民、　「お前さん、二階が……」　「そうだ、石松、二階に隠れてろ……石松、痛むか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車に揺られて、節々が痛む上に、半分寐惚けて、停車場に降りた。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は首をすくめて痛む足を引き摺りながら厭や厭や歩き續けてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてガドルフは自分の熱って痛む頭の奥の、青黝い斜面の上に、すこしも動かずかがやいて立つ、もう一むれの貝細工の百合を、もっとはっきり見ておりました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　二人はわらじを解いてそれからほこりでいっぱいになった巻脚絆をたたいて巻き俄かに痛む膝をまげるようにして下駄をもって泉に行った。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その底がどれほど深いかその奥に何があるかいくら眼をこすってのぞいてもなんにも見えずただ眼がしんしんと痛むのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢夫ぐらゐの髪のちゞれた子が列の中に居ましたがあんまり足が痛むと見えてたうとうよろよろつまづきました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一晩睡らないで、頭のしんしん痛む豚に、又もや厭な会話を聞かせたのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "脾腹が痛む、そして高い熱が出る。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時までは、殆ど自分で何をするかに心着いて居ないよう、無意識の間にして居たらしいが、フト目を留めて、俯向いて、じっと見て、又｜梢を仰いで、「与吉さんのいうようじゃあ、まあ、嘸この葉も痛むこッたろうねえ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（何故だろう、これは鋸で挽く所為だ、）と考えて、柳の葉が痛むといったお品の言が胸に浮ぶと、又木屑が胸にかかった。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして魚ばかりではない、柳の葉も食切ると痛むのだ、）と思い思い、又この偉大なる樟の殆ど神聖に感じらるるばかりな巨材を仰ぐ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は一しきり大に急になりかつまた窄くなったので、胸を突くような感じがして、晩成先生は遂に左の手こそは傘をつかまえているが、右の手は痛むのも汚れるのも厭ってなどいられないから、一歩一歩に地面を探るようにして、まるで四足獣が三｜足で歩くような体になって歩いた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の五体でもけがをするとそこが痛む。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "動くとひどく痛むからしかたなくじっとしている。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある年の暮れから正月へかけてひどく歯が痛むのを我慢して火燵にあたりながらベルグソンを読んだことがある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかが少しきつく当たって痛むような場合に、その場所を捜し見つけ出してそこを木賊でちょっとこするとそれだけでもう痛みを感じなくなる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小浅間への登りは思いのほか楽ではあったが、それでも中腹までひといきに登ったら呼吸が苦しくなり、妙に下腹が引きつって、おまけに前頭部が時々ずきずき痛むような気がしたので、しばらく道ばたに腰をおろして休息した。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人は、痛む脚をひきずって病院へ行き手当を受けた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その底がどれほど深いか、その奥に何があるか、いくら眼をこすってのぞいてもなんにも見えず、ただ眼がしんしんと痛むのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私は全体何をたずねてこんな気圏の上の方、きんきん痛む空気の中をあるいているのか。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その底がどれほど深いか、その奧に何があるか、いくら眼をこすつてのぞいてもなんにも見えず、ただ眼がしんしんと痛むのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故母上さんは一所に出なかったのだろう、君知らんかね」と一人の男が言うと、一人「頭が痛むとか言っていたっけ」というや三人急に何か小さな声で囁き合ったが、同時にどっと笑い、一人が「ヨイショー」と叫けんで手を拍った。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい死んだであろうと思われていたむすこが無事に帰ったとか、それほどでなくとも、心配していた子供の入学試験がうまく通ったというのでもやはり緊張のゆるむ瞬間に涙が出るのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで小鳥もチッチッと啼き、かれ草のところどころにやさしく咲いたむらさきいろのかたくりの花もゆれました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い犬の鼻づらが、水を出て浮いたむこうへ、銑さんが艪をおしておいでだった。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで小鳥もチツチツと啼き、かれ草のところどころにやさしく咲いたむらさきいろのかたくりの花もゆれました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be injured",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "激しいタックルを受けた選手は、膝を痛めてしばらくプレーできないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "階段から転落した際、足首を痛めたらしく、歩くのも困難な様子だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "重い箱を無理な体勢で持ち上げた結果、腰を痛めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供が転んでできた打撲痕が、押すとひどく痛んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわっ、腕を痛めた！試合に出られないかも。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長期間、無理な姿勢で作業を続けたため、肩の腱を痛めてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ドアに指を挟んでしまい、しばらくズキズキと痛んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
