[
  {
    "uuid": "61a7111c-d910-53db-a2b5-5f0e8cdd781d",
    "entry": "痛む",
    "reading": {
      "primary": "いたむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
