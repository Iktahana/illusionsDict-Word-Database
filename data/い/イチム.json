          ],
          "literary": [
            {
              "text": "好事の人の就て汲む者の如き、終に往時の一夢たらんのみ。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、いつか「環魚洞風景」といふ私小説の中で、唖子ノ一夢ヲ得ルガ如ク云々の諺を、そんな風に曲げて異人娘に答へた事がある。",
              "citation": {
                "source": "大正十五年の文壇及び劇団に就て語る",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖子の妻　いつか予は汝に、自らを唖子に喩えて、その一夢云々と云つたことがあるが、同じ言葉を予は先日某誌に寄せた。",
              "citation": {
                "source": "消息抄（近頃書いた或る私の手紙から。）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "荘内に在るに及んで左右その人を非るを見、詩を賦して以て自ら悲しむ、三十一年一夢のごとく、醒め来る荘内破簾の中の句あり、聞く者これを怜れむ〉。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が異數に婦女子の情味を知つたのも果敢ない少年の一夢に過ぎませんでした」　自分は佐治君に引き入れられるやうに感じた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界統一夢双六が一同の並むだ視線の前に朝日の如くにひろげられた。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これむかし落ちたる錢の痕の、年を經て大くなりたるなりといふに、覺えず噴飯せしは、早や已に十年前の一夢となりぬ。",
              "citation": {
                "source": "杉田の一夜",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖子ノ一夢ヲ得ルガ如ク、只自ラ知ルヲ許ス――そんなウロ覚えの怪し気な古語を私は、偶然思ひ出したのだが、さう云つて馬鹿気た見得を切つた刹那に不図私は、妙な寂しさに駆られて、沈黙の洞窟に吸ひ込まれた。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "租税を納むる者が郡区役所の小役人に叱られしはまさに昔日の一夢ならんとす。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑町の比良野氏では房之助が、実父｜稲葉一夢斎と共に骨董店を開いた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夢斎は丹下が老後の名である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夢已八年、又賦七絶。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "○平野秀吉氏の唐詩選全釈には、「後、張継、再び此に来り、重泊楓橋と題して、白髪重来一夢中、青山不改旧時容、烏啼月落江村寺、欹枕猶聴夜半鐘と詠じたが、詩品も劣り、且つ全唐詩にも載せざるを見れば、或は後人の偽作か」としてある（簡野道明氏著『唐詩選詳説』にも之と同じことが書いてある）。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ孫仲益の楓橋寺を過ぎる詩を読むに、云ふ、白首重来一夢中、青山不改旧時容、烏啼月落橋辺寺、欹枕猶聞夜半鐘と。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれもこれも、過ぎ去つた一夢であらうか……。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "止ぬるかな、止ぬるかな、革命の健児一たび逝きて、遂に豎子をして英雄の名を成さしむるや、今や七百星霜一夢の間に去りて、義仲寺畔の孤墳、蕭然として独り落暉に対す。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治卅三年正月、故郷仙臺にある第二高等學校に仕官し、卅四年海外漫遊に出かけ、卅七年秋、日露戰役の最中歸朝し、翌年再び二高に就職して爾來三十餘年、既往は眞に一夢のやうに感ずる。",
              "citation": {
                "source": "新詩發生時代の思ひ出",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れ來し邦を、とも人を、隔てゝ遠き離れじま都の春の一夢を磯のあらしにさまさせて氣は世を葢ほふますらをはいまはの床に眠るかな。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木路の散歩、楽しい買物、映画見物、喫茶店、それらのことは、恋人同士の特権のように思われがちだけれども、私はあべこべに、浮気心、仇心の一興、また、一夢というようなものにすぎないと考える。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "既往を思えば翁も一夢の感があろう。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣く子と地頭には勝てないと思いきわめ、三匹の猿になる修練に何十年心をうちこむ修養を要したにしても、まさしくその一生は一酔一夢というような楽チンきわまるものである。",
              "citation": {
                "source": "風流",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流とは一生を一酔一夢に空費するための手のこんだパズルのようなものでもある。",
              "citation": {
                "source": "風流",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流を一酔一夢の遊びと解し、わが一生を茶番と解して世を終るのは、われ一人の勝手な生き方、それも結構であろう。",
              "citation": {
                "source": "風流",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈下木村芥舟の黄梁一夢をよむ。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田文学創刊当時の事を語合ひて十年一夢の歎をなす。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔烏影トシテ往事空シ／暁鐘声断チテ已ニ春風／残眠未ダ覚メズシテ僧窓白ク／二十三年一夢ノ中〕の作が載っている。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢詩風に云へば、三十八年唯一夢。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "寸時も早くこの川越をあとに、南のお役宅へ駆込願いをいたすべしと、日頃信ずる豊川様の夢知らせ、醒むれば是なむ南柯の一夢でございます」　なんとも言えないその調子のよさ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして、一夢さめきたれば全部分活動するをもって、一部分の想像の全く謬見なるを知るに至る。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
