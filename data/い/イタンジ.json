        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は業界の「異端児」と呼ばれ、常に新しい技術に挑戦し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その若手建築家は、既存の概念を打ち破る「異端児」として注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かつては「異端児」扱いされた彼の理論も、今では多くの研究者に支持されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "組織の中で「異端児」として孤立することもあったが、彼の信念は揺るがなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「彼はまさに『異端児』だよ。誰も考えつかないようなアイデアを出してくるからね」と、同僚は彼の創造性を評価した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術界の「異端児」と評される彼女の作品は、常に物議を醸してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "保守的な村で育った彼は、東京へ出て「異端児」として自由な生き方を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その政治家は、党内では「異端児」的な発言が多いものの、一般市民からは熱い支持を得ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "マイクロコンピューターとは、部分としての集積回路と全体としてのコンピューターの境界に生まれた異端児である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "部分でありながら完結した全体性を持つこの異端児は、半導体屋のセンスからすればわけの分からないゲテ物に見える。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "草鞋を穿いたんじゃありますめえか」　松吉の報告によると、その古着屋も師匠の家もみな平屋の狭い間取りで、どこにも隠れているような場所がありそうもない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕下らなく遊んでいたんじゃない、学校の復習や宿題なんかしていたんだけれど。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりついたんじゃないよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンタゴンなんか相手にしていたんじゃなあ……柿江なんぞも、田舎新聞にひとりよがりな投書ぐらい載せてもらって得意になっていないで、ちっと眼を高所大所に向けてみろ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お孝は、ずっと来て、年上の女の落着いた声を沈めて、「どうおしなの、お前さんもう寝ていたんじゃないのかい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へい、引掻いたんじゃありませんか。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　馴々しくいうと、急に胸を反らして、すッきりとした耳許を見せながら、顔を反向けて俯向いたが、そのまま身体の平均を保つように、片足をうしろへ引いて、立直って、「否、寝ていたんじゃなかったんですけども、貴下のお姿を拝みますと、急に心持が悪くなって、それから寝たんです。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水はごくいい湧水にかぎる、それも新鮮な処にかぎる、すこし置いたんじゃもうバクテリアが入るからね、空気は高山や森のだけ吸い給え、町のはだめだ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局こんな間接のことまで論じていたんじゃきりがない、ただわれわれはまっすぐにどうもいけないと思うことをしないだけだ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「隆くない、ほほほ、ちょっと撮んでやろうかしら、なんと思って上から顔を視ると、睡っていたんじゃないんです。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、死体に成ってから、貴方のお胸に縋着いたんじゃありませんか、海の中で、」　と膝を寄せる、褄が流れて、婦は巽の手を取った。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その男のだね、名刺に、用のありそうな人物が、何となく、立っていたんじゃないかとも思ったよ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "内で熟としていたんじゃ、たとい曳くにしろ、車も曳けない理窟ですから、何がなし、戸外へ出て、足駄｜穿きで駈け歩行くしだらだけれど、さて出ようとすると、気になるから、上り框へ腰をかけて、片足履物をぶら下げながら、母さん、お米は？",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしが、今朝わざと取り更えて置いたんじゃありませんか。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンミイは時計の針をやたらに、廻して置いたんじゃないかい？",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第一あんな人がついていたんじゃ、いくら儲かったって追い着きませんよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたを愛していたんじゃないわ。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちいち真実を吐露し合っていたんじゃ、やり切れない。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子もぬがずに、ただ、はったと睨んでいたんじゃ、ふつうだったら、まず交番に引渡されるところだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、このままの関係でいたんじゃ、まずい。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田さんの言う事なんかを、いちいちはいはいと聞いていたんじゃ、そのうち本当の肺病になってしまいますよ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外、僕の話に耳をすましていたんじゃないですか？",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋行させる費用に、と云って積立ててあった兄さんの分は、とうの昔無くなって、三度目の時には皆私たち妹の分にまで、手がついたんじゃありませんか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も裸体が渋紙に包まれていたんじゃ、氏素性あろうとは思わぬはず。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の事なんか書いたんじゃ無かったのよ。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふんどし一つで、金言を吐いていたんじゃ、まるで何かみたいだ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸を割ってみせたいくらい、まっとうな愛情持っていたって、ただ、それだけで、だまっていたんじゃ、それは傲慢だ、いい気なもんだ、ひとりよがりだ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
