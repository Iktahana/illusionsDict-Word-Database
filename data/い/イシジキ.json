[
  {
    "uuid": "0839f6c8-9f07-5926-8ed6-3a2364f83516",
    "entry": "石敷",
    "reading": {
      "primary": "いしじき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
