        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "歯朶が生い囲んでいる入口の辺を過ぎると、岩窟の岩肌が灯に照し出された。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅な松明の灯に照し出される岩肌は、穴の屈曲に従って　拗けた瘤をつけ　波打つ襞を重ねる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄武岩の柱がごつごつした岩肌に並ぶ様は、石化した怪物か何かの肋骨のようだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄みとほつた水はゆたかに温むで、蹠に感じる岩肌が温泉の底のやうであつた。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑っこく、水で洗われた岩肌や、岩肌に生えた苔や、凹みに生えた菖蒲に似た草だのは、一本のハッパで、跡も片もなくなって、その後には、有史以来初めて光線を見るのであるかもしれない、地殻の内皮の一部分が、ザクザクになって、ひっくりかえる。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームのすぐ裏まで押し迫っている岩肌へ吹きつける風が、また巻き返って構内の柱を鳴らせていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の間がくれに見える谿谷は、青苔のはえた岩石で、そのなめらかな岩肌が川床となっている。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩肌の上を流れおちる水は、清冽だが、殆んど音を立てない。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十和田湖の水をおとす奥入瀬の谿谷は、急湍奇岩で人を魅惑するが、ここのささやかな谷川は、それが木の間がくれに隠見するだけに猶更、そして岩肌の上を音もなくすべり落ちるだけに猶更、人の眼を惹き心を惹く。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄白斎は、焚火をしたため、黒く焼けている岩肌を眺めていたが「和田、この岩の形は？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケンはそろり、そろりと岩肌をつたわって穴をさがしているに違いない。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水にぬれた衣服を通して冷い岩肌の冷気がきゅうっと五体を緊張させた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダビットが頭の上の岩肌に耳をつけると、声はよけいにはっきりした。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕信号をしてみます」　玉太郎が岩のかけらをとりあげて、頭の上の岩肌をコツコツとたたきはじめた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが岩肌にはねかえって、ガンガン大きくこだました。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、フランソア、ラルサン、来てくれ、ちょっと手をかしてくれ」　モレロは岩肌をたたいた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "音は岩の洞窟の中をはしりまわり、あちらこちらの岩肌にはねかえり、ぶつかりあいしてだんだんと大きくなっていった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側に見上げるような高さから同じような形の岩壁が何十と重なり合って岩角を畳み合せてるのが、岩肌は黒に黄色味を見せ、角々に雪を持って、壮観限りないものだった。",
              "citation": {
                "source": "吹雪のユンクフラウ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半島の山には、針葉樹が多く、闊葉樹は紅葉し、代赭色の岩肌が絶壁の中に散見される。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は黒百合山といふ名前に似ない岩肌のゴツ／＼した山へ登つてみました。",
              "citation": {
                "source": "淫者山へ乗りこむ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "苔もむしていたし、風化をうけて岩肌はすすけたようになっていた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日がちり／″＼に縮まつて、波も沈んだ色に見え出す頃、金白礁の薄雪のかゝつた様な岩肌が、かつきりと、目の前に浮んで来た。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は、岩肌を絞つて垂れてゐる。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "した　した　水は岩肌を絞つて垂れてゐる。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は、岩肌を絞って垂れている。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は山の岩肌、一方は谷だ。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
