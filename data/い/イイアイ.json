[
  {
    "uuid": "2c75b6d3-2536-597a-8ce6-222c03f76ea3",
    "entry": "言い合い",
    "reading": {
      "primary": "いいあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
