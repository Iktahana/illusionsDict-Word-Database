[
  {
    "uuid": "984c9823-cfa0-58bc-9dd8-34a20ca09893",
    "entry": "言うなり",
    "reading": {
      "primary": "いうなり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "doing as one is told",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「いつまでも親の言うなりになっていないで、自分の進路は自分で決めなさい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "多額の資金援助を受けている手前、スポンサーの言うなりにならざるを得ないのが現状だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいつは常に上司の言うなりだから、彼に改善案を相談しても無駄だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はまるで糸で操られる人形のように、相手の言うなりに動かされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "弱みを握られた男は、犯人の言うなりに指定された場所へ現金を運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんなわがままな恋人の言うなりになっていて、君は心身ともに疲弊しないのかい？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国王の言うなりに動く御用聞きのような議会では、真の民主主義は機能しない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それからは何もかも他の言うなりになって、霜月｜半に祝儀をしたけれど、民子の心持がほんとうの承知でないから、向うでもいくらかいや気になり、民子は身持になったが、六月でおりてしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと、コップでは面倒臭いですから、そのジョッキで……」　と言うなり七合入のジョッキで立て続けに息も吐かせない。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪忍して頂戴」　と言うなりに空気銃を投げ出して逃げて行きました。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかおおぜいで先生を引っぱって浅草へ行ってルナパークのメリーゴーラウンドに乗せたこともあったが、いかにも迷惑そうではあったが若い者の言うなりになって木馬にのっかってぐるぐる回っていた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで天才が子供の言うなりになって、この珍しい寺院の装飾をしたのではないかと思われます。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、その子は、二度と、ちゃんとした人間にはなれないし、いつまでも雪の女王の言うなりに、なっていなければならないんだよ！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえさんと踊ったら、さぞかしすてきでしょうよ」　ソフィーは、こう言うなり、くるりと背中を向けてしまいました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんちくしょう、早く言え」　と言うなり坊さんを押えつけて鉈をふり上げました。",
              "citation": {
                "source": "ツクツク法師",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とばかりありて、仮花道に乱れ敷き、支え懸けたる、見物の男女が袖肱の込合うたる中をば、飛び、飛び、小走に女の童一人、しのぶと言うなり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに沢山要るものは、自分たちでお金を出して、しまに買って来て貰ってお使いなさいよ」　すると、連中は「へい／＼」と頭を掻く真似なぞして母の言うなり通りにします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるで化物屋敷か、手品師の謎の箱みたいじゃないの」　わたくしはそう言うなり、手に取上げた包入りの丁字帯をいやというほど勢込めて縁側に投げつけました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしい性質の青年は、実家の言うなりに思い諦めたらしく、受験をかこつけに東京へ出て、それきり帰らなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいっそ好かろうと、京子の言うなりに寝床へ入れてやることにした。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言うなり、すらりと水の下へもぐってしまいました。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言うなり、さっさとそこを出ていってしまいました。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、どうぞ」　許宣は白娘子の言うなりに盃を手にしていたが、ふと気が注くとひどく長座したように思いだした。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし何かのことで疑われるといけませんから、これを持っていらっしゃい、証拠になりますから」　興哥は慶娘の言うなりになって、釵を持って舟をあがった。",
              "citation": {
                "source": "金鳳釵記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜陽は自分の頭では何も考えられないので、彼の言うなりになって室の中へ入った。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　正勝はそう言うなり紀久子の肩に手をかけて、足を上げ手を振りながら踊りだした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言うなりに、こめかみの処へ頭痛膏を貼った顔を掉って、年増が真先に飛込むと、たちまち、崩れたように列が乱れて、ばらばらと女連が茶店へ駆寄る。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も男らしい固い人と思い込んで、何もかも言うなりになってしまったんです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一から十まで新高さんの言うなりになって遣ったの。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言うなり、清子の膝に泣伏した。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいお客様だわ、あの人にも札をあげなくちゃ」と言うなり、ひらりと椅子から飛び下りて、わたしのフロックの袖の折返しをつかまえると、――「さあ、いらっしゃいってば」と言った。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｐのおじさん、僕ちょっと外出して検べてきますから、ここに待っていてください」　こう言うなり俊夫君は、私たちを残して、さっさと出かけてゆきました。",
              "citation": {
                "source": "自殺か他殺か",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆やは小山の家に出入の者でひどくおげんの気に入っていたが、金銭上のことになるとそうそうおげんの言うなりにも成っていなかった。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして女の人の封建時代の立場と申しますものはどういうものかといえば、それは全く男の人の言うなりであった。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、この子の好いことには、袖子の言うなりになった。",
              "citation": {
                "source": "伸び支度",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでも子供で、自分の言うなりに、自由になるもののように……　ある朝、お初は台所の流しもとに働いていた。",
              "citation": {
                "source": "伸び支度",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ人民の自治を説きもって立法の一人に私定すべからざるゆえんを言うなり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
