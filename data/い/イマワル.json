    "definitions": [
      {
        "index": 1,
        "gloss": "to sit in a circle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちは、おもちゃを取り囲んで楽しそうに居回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "村人たちは、焚き火を囲んで物語を語り合いながら居回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の参加者は、円卓を囲んで意見交換のために居回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "雑貨店の内儀に緒を見せて貰いながら、母は、「藤よ、そんなに店の物をいらいまわるな。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御主人は、ジャンパーなど召して、何やらいさましい恰好で玄関に出て来られたが、いままで縁の下に蓆を敷いて居られたのだそうで、「どうも、縁の下を這いまわるのは敵前上陸に劣らぬ苦しみです。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには、四五匹の青大将が畳のうえを這いまわる。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラスがあるから」　と言いましたが、虻はもう夢中になって、「どこですか、どこですか」　と狂いまわるばかりです。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる少しすぎたころ、だしぬけに黒雲が東北の空の隅からむくむくあらわれ二三度またたいているうちにもうはや三島は薄暗くなってしまい、水気をふくんだ重たい風が地を這いまわるとそれが合図とみえて大粒の水滴が天からぽたぽたこぼれ落ち、やがてこらえかねたかひと思いに大雨となった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコニハ自然の約束があるから即ち一定の有様をなして、左り巻なら左り巻、右巻ならば右巻でちゃんと螺旋をなして這いまわるのだ。",
              "citation": {
                "source": "ねじくり博士",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると不思議にも、今まで恐怖という事を知らなかった名探偵が、極度にその極悪犯人を恐れるらしく、秘術を尽して逃げ惑うのを、犯人が又、それ以上の秘術を尽して逐いまわる。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "フットライトの中に浮き出してあでやかに笑いまわる舞姫の鼻の表現のわびしさは、絶対に拭い除ける事の出来ないものでしょうか。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これという実も花も持たぬままに、潤いを求めて地を這いまわる蘚苔のようなもの、又は風に任する浮草式生活の気楽さに囚われている者に到っては殊に夥しいのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかは、めくらかいざりかどちらかでしたから、両手ではいまわるか、指の腐れおちた手をあわせていました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――たぶん、水車の輪のぎいぎいまわる音を連想したからであったろう。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国の河童は真っ黒に塗った尻の右と左に金紙や銀紙を丸く貼りつけて、大きい眼玉と見せかけ、その尻を無造作に観客の方へむけて、四つン這いに這いまわるのを一つの芸当としている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが三日四日を過ぎると更に怪しい症状を表わして来て、病人はうつむいて両足を長くのばし、両手を腰の方へ長く垂れて、さながら魚の泳ぐような、蛇の蜿くるような奇怪な形をして這いまわる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて家じゅうを這いまわるのでもない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼを追いまわる子供の黐竿も見えた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつれて私の心臓と肺臓が、涯てしもない虚空の中で互い違いに波打って狂いまわる恐ろしさに、声も立てられないような気持になって行きました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一朝事があれば、彼もしくは彼女は畜生のように、又は餓鬼のように昏迷して地面を這いまわる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、ぬらぬらしたものが、彼の皮膚の上に匍いまわるような気がした。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "大力に打たれた兼輔は悲しい声をあげて、子供につかまれた子猫のように、相手の膝の下をくぐって逃げようと這いまわるのを、実雅は足をあげて鞠のように蹴倒した。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、すぐ艦隊の司令官からへんじがあって、スパイ国のせいばつよりも、「地底戦車」を発明した、きょうだいの父親が、いまわる者どもにひどい目にあっているから、二人をつれてすぐこっちへかえってくるようにと命令が出ました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に二、三日まえにも鎌を持ち出して、これから小女郎狐を退治にゆくと狂いまわるのを、大勢がようように抱き止めたというのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この「去るに臨みて」の万感こもごもは、ぼうっと赤い東京の夜ぞらとともにすぐ消えて、かわりに私は、そこに世界地図の上を這いまわる二足の靴を想像する。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると牛は、びっくり猛り立って闇黒を飛び出し、その飛び出したところに明光と喚声が待ちかまえているので、この俄かの光線・色彩・群集・音響に一そう驚愕し、首に養牧者の勲章を飾ったまま、「黒い小山」のように狂いまわる。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○桑の尺とり虫が出始め、道ばたに青草がしげり出し、くもが這いまわる。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして野良猫が残肴を漁るように、爛れた神経の尖端で腐肉の中を吸いまわる。",
              "citation": {
                "source": "赤い壺",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い冷たいものが身内を這いまわるようで、それはすぐにも彼を押し倒そうとしていた。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "日はとっぷり暮れたが、「水をくれ、水をくれ」と狂いまわる声があちこちできこえ、河原にとり残されている人々の騒ぎはだんだん烈しくなって来るようであった。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミミズの匍いまわる金網の中に、すくんだような眼いろをしている仔鴉を見ながら清子は良人を思い出した。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
