    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "職場から帰ったら、もう家の人たちは寝ていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "急な出張が決まって、家の人に連絡を入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は家の人とドライブに出かける予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの、家の人いますか？」と来客が尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "病気で寝込んでいる間、家の人にずいぶん迷惑をかけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は家の人に相談してから、転職を決めたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "実家に帰省すると、家の人みんなが温かく迎えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害時は、まず家の人と安否確認をするのが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今日「俳人」と称されてる専門家の人々は、決してこの種の俳句を認めず、全くその詩趣を理解していない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に交際家の人間というものは、しゃべることそれ自身に興味をもってる人間である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "當選などは、思ひも寄らぬことで、家内にも、また家内の實家の人たちにも、「こんど、國民新聞で短篇小説のコンクールがあつて、私も書くのだが、まあ、おしまひから二、三番のところ、と思つてゐて下さい。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の賣上げが、どのやうに一家の人々に分配され、一喜一憂が繰り返されることか。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてみるとかなりひどいゆれ方で居間の唐紙がすっかり倒れ、猫が驚いて庭へ飛出したが、我家の人々は飛出さなかった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "界隈の昇華した名家々々の流れを相互に婚姻を交えている間に、家の人間に土より生い立てる本能の慾望を欠き、夢以外に食慾が持てない咀嚼力の精神になってしまったのも原因の一つであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の人達にきっと何とか言われる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の人達は今夕飯最中で盛んに話が湧いているらしい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がＥ子の家の前を通るのは、もしＥ子や家の人がこれを知ったら、Ｄに変に気をまわすかも知れない。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　文学のことは年齢によってのみはかることは出来ないが、しかし、文学がその作家の置かれた環境と切り離して考えられない関係がある限り、環境は時間によって変化するので年齢はその作家の人間にも、またその作家の作り出す文学にも変化を与えるのは否まれないように思われる。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺は地震の害もかなりひどくて人死にも相応にあったというから、ここの家の人々にもどういう怪我がなかったとも限らないと思った。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともやっぱりこの家の人たちが帰って来たのだろうか。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を配達先へ届けると同時に産気づいて、運送屋や家の人が気を揉むうちに、安やすと仔牛は産まれた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の近くまで来ると、隣家の人が峻の顔を見た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば先生のところから帰って来て後は直ぐ遊ぶことが出来るのですから、家の人達のまだ寝ているのも何も構うことは無しに、聞えよがしに復読しました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しそれも唯机に対って声さえ立てて居れば宜いので、毎日のことゆえ文句も口癖に覚えて悉皆暗誦して仕舞って居るものですから、本は初めの方を二枚か三枚開いたのみで後は少しも眼を書物に注がず、口から出任せに家の人に聞えよがしに声高らかに朗々と読んで居るのです。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある年、山がまだ雪でまっ白く野原には新らしい草も芽を出さない時、虔十はいきなり田打ちをしてゐた家の人達の前に走って来て云ひました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝはこの向ふの家の地面なのですが家の人たちが一向かまはないで子供らの集まるまゝにして置くものですから、まるで学校の附属の運動場のやうになってしまひましたが実はさうではありません。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある年、山がまだ雪でまっ白く野原には新らしい草も芽を出さない時、虔十はいきなり田打ちをしていた家の人｜達の前に走って来て云いました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはこの向うの家の地面なのですが家の人たちが一向かまわないで子供らの集まるままにして置くものですから、まるで学校の附属の運動場のようになってしまいましたが実はそうではありません。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この猫は鼠を一匹も捕らぬくせに泥棒猫で、近所から嫌われていましたが、「ニャーニャーゴロゴロ」とおべっかを使うのが上手なので、この家の人に可愛がられていました。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもちゃんと戸が締まっている戸棚の中のものがなくなりますので、この家の人は女中さんを呼び出して「お前が食べるのだろう。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この騒ぎに驚いて家の人が馳けつけてみますと、初めて猫が泥棒をしていた事がわかりました。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、自分の学生時代に世話になった銀座のある商店の養子になっていた人から聞いた話によると、その実家というのが牛込の喜久井町で、そのすぐ裏隣りとかに夏目という家があった、幼い時のことだから、その夏目家の人については何の記憶もないがその家居のさまなどは夢のように想い出されるとのことであった。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時過ぎまでは食事もできないで、晩食後の片づけに小皿一つ粗※をしまいと血眼になっている時、奥では一家の人たちが何んの苦労もなく寄り合って、ばか騒ぎと思われるほどに笑い興じているのを聞かなければならぬ妬ましさ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに旦那とはうらはらに、上品で、感情の強い人で、家の人たちには何んとなく憚られているらしかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は嘗て、墺国の首都ウィーンで、体育家の人気者ホーエンスタインという人に面会しまして、親しく氏の自然運動科学の実地を見せて貰いました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、前に、人間の世界で驕ったものは、かならず貧しい家に生れさせられ、前の世界で働いた者は、必ず富んだ家の人として生れさせられるのだ、それが因縁という、神様が人間にお与えになる正しい賞罰なのだ。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ氏の普請場に家の人は見えなかったので、挨拶もせずに帰った。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "随って彼の性質も愈よ僻んで来て、仕事を怠ける、喧嘩をする、酒を飲む、甲から乙へと堕落して、果は第二の親とも云うべき角川一家の人々からも見放される様になった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
