[
  {
    "uuid": "a0244d2b-89cf-508d-b46f-9ba7023c008e",
    "entry": "家の人",
    "reading": {
      "primary": "いえのひと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
