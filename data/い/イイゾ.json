          ],
          "literary": [
            {
              "text": "調子がいいぞ、とにやにやしてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面倒くさい靴下はポケットへ押し込め、ポケットがふくれて気持ちがいいぞ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きらずだ、繋ぐ、見得がいいぞ、吉左右！",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むりしないほうがいいぞ。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬一匹飼って置くといいぞ。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏切番はいいぞ、父！",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爺つあん、今日は、午めえは草刈っさ行かねってもいいぞ。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえのすきなときだけ、うたってくれればいいぞ。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが今夜話したことは誰にも吹聴しない方がいいぞ」と、Ｋのおじさんは話の終りにこう付け加えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京ちやんは運がいいぞ。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ重大な事件だから、すぐに係りの検事から審問がある筈だが、なまじっか偽を申し立てぬがいいぞ。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、最後に忠告しとくが、これからは、これに懲りて、自分の生活の保障もたたんうちに、恋だとか愛だとかいう人並みな考えを起こすのはよしたがいいぞ。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばれると、ききがいいぞ」　ぎゅっとぞうさもなく押えたやつを伝六に渡しておいて、すばやく手、口、ともにすすぎ清めると、懐紙を口にくわえながら、白布を解きほどきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "まごまごしてりゃ、おらがはあんまりじょうずじゃねえが、だんなの草香流はききがいいぞ」　ぱんぱんとかみつくようなすさまじいけんまくに、肝をつぶしたのは子をとられたふたりの新造たちでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメラを意識していいぞ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいぞ、かけてくれ、という高志の合図にしたがって、慶一は黙々と湯をかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャーベット食うなら、早いとこ片づけたほうがいいぞ」　メロンを矢印にして、高志が南西の空を示した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、帰っていいぞ」　そうしたいのはやまやまだが、どうせなら、令子の組がくるまで待ちたい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、ホコリかぶってる」「聴かねえほうがいいぞ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "起床の時間です」　いいぞ、ワラ、という声と、学校の手先は死ね、てめえの声をきくと発作が起きる、といった罵声が、暗いサロンを飛びかう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっ、この部屋は異常に寝起きがいいぞ、とヤジ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつでいけるところなら、どこだっていいぞ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の朝、お前は出ていいぞ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァレンタイン、さっきの話をよーく、心にとめておいた方がいいぞ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一報は、簡潔なのがいいぞ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見てしまったら、あとは帰ってもいいぞ」　高木を追払ってしまうと、余は、事務所の入口に、内側から鍵をかけた。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして杉田の耳許に口をつけると、「おい杉田、万一お前が捕らえられるようなことがあったら、そのときは官姓名をはっきり名乗ったがいいぞ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく高い所がいいぞ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
