        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "多くの文化では、一夫一婦が結婚制度の基盤となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの鳥の種は、生涯を通して一夫一婦を守り、子育てをするそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一夫一婦であることは、夫婦間の信頼関係を築く上で重要だと彼は考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代社会における一夫一婦の形も、時代と共に変化していくのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "男子ノ姦通罪ヲ罰スルコトハ第一ニ一夫一婦タル國民道徳ノ大本ヲ明カニスルガタメナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ一夫一婦制ノ勵行ハ彼ノ自由戀愛論ノ直譯革命家ト人生ノ理解ヲ根本ヨリ異ニセルモノナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "之レヲ途方モナキ一夫一婦制ニ對スル反逆ト考フルハ、恰モ政治的特權者ニ向ツテ叫バレタル政治ノ自由ヲ平等ナル國民間ニ脱線セシメテ、相犯サザル各自ノ自由ヲ蹂躙スルコトモ等シク政治ノ自由ナリト云フ低能者ノ昏迷ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "國民平等ノ自由ガ特權ニ非ル如ク、一夫一婦制ハ何等ノ特權ニ非ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夫一婦制ハ妻ノ戀愛ヲ自由ナラシメンガ爲メニ夫ノ濫用セントスル戀愛ノ自由ヲ拘束セントスルナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ一夫一婦制ハ理想的自由戀愛論ノ徹底シタル境地ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "但シ有婦ノ男子ガ淫ヲ買フハ明カニ一夫一婦ノ大本ヲ紊ル者ナルヲ以テ別個ノ意味ニ於テ加罰スル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "式を挙げるに福沢先生を証人に立てて外国風に契約を交換す結婚の新例を開き、明治五、六年頃に一夫一婦論を説いて婦人の権利を主張したほどのフェミニストであったから、身文教の首班に座するや先ず根本的に改造を企てたのは女子教育であった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この思ひがけぬ出來事のために、彼等はまた一夫一婦の平和な生活に還る事が出來た。",
              "citation": {
                "source": "白い雌鷄の行方",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟における新しい内容での一夫一婦制の確立は、男女の日常生活に作用する社会関係全体が、彼ら自身の犠牲多い積年の努力で健康な土台の上に組み直されて始めて、現実の可能となったのであった。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "持参金つきの商略的結婚制度に、外見上の一夫一婦制に、大きな虚偽を見出している。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君には、排他的の厳重な一夫一婦という、一種の理想があった。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊子は、当時の進歩的な人々のものの考えかたに従って男女平等論や一夫一婦論や女子教育論、あるいは政局批判に熱弁をふるったわけであったが、彼女の政治的見解というものははたしてどこまで深くその身についていただろうか。",
              "citation": {
                "source": "女性の歴史の七十四年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の自主的なこれらの動きは、一八七二年の人身売買禁止法、男子に等しい義務教育令の制定や、福沢諭吉の一夫一婦論、廃娼論とならんで、森有礼が『明六雑誌』に「妻妾論」を書いて当時のいわゆる「権妻」の風習に反対したことにも通じている。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夫一婦とは、その瞬間に於いてのみ眞理である。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうは私はまだ当分気楽にあなたとだけ暮らして行きたかったのだけれど」　などと宮は言っておいでになったが、一夫一婦であるのを原則とし正当とも見られている普通の人の間にあっては、良人が新しい結婚をした場合に、その前からの妻をだれも憐むことになっているが、高い貴族をその道徳で縛ろうとはだれもしない。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "シテ見ると一夫一婦の説も隠然の中には随分勢力のあるもので、就ては今の世に多妻の悪弊を除て文明風にするなんと論ずるは野暮だと云うような説があるけれども、畢竟負借みの苦しい遁げ口上で取るに足らない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夫一婦終身同室、相敬愛して、互いに独立自尊を犯さゞるは、人倫の始なり。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十条　一夫一婦の間に生るゝ子女は、其父母の他に父母なく、其子女の他に子女なし。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夫一婦主義を意識して実行しているのでも、『女大学』に教えてあるような旧道徳に圧抑せられているのでもない。",
              "citation": {
                "source": "私の貞操観",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、将来は教養ある男子が殖えるに従って、自己の純潔を貴ぶため、家庭の平和を欲するため、放縦な性欲を自制して一夫一婦主義を女子と同じく尊重し実践するようになるであろうか。",
              "citation": {
                "source": "私の貞操観",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスにおいて、ミルトンの一夫一婦　純潔な家庭を称揚したパラダイス　ロストフランスの人々も家庭というものの幸福のために坊主の追放を考えた。",
              "citation": {
                "source": "バルザック",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夫一婦の大礼もあげ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天然と生命との機微を無視するキリスト教的、人道主義は、簡単に、一夫一婦の厳守を強制するのみで、その無理に気がつかない。",
              "citation": {
                "source": "愛の問題（夫婦愛）",
                "author": "――生命の法に随う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も一夫一婦ということを考えたのでありますが、そういうように無難にやっている。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるひは又、一夫一婦制といふものに対する我々の事実上の反逆にも拘らず、我々の頭の中の生活は常識的な見解を捨てきるだけの決断がつかない。",
              "citation": {
                "source": "悲願に就て",
                "author": "――「文芸」の作品批評に関聯して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一説によれば、もし基督教があくまで一夫一婦の掟を強ひなければ、信長も切支丹になつたであらうと言はれてゐる。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊臣秀吉ですら或る時神父に向つて、殿中の侍女のうちで切支丹を奉じる者の操行端正なことを賞讃したあげく、もし一夫一婦の掟をもうすこし緩めてくれゝば自分も切支丹になつてもいゝと公言した。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長自身は一夫一婦に辟易したが、伴天連入満が清貧童貞に甘んじて厳しい掟に順ひ苟も私利のためには計らぬ様を賞美した。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
