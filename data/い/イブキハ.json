        "examples": {
          "standard": [
            {
              "text": "政局の鍵を握るのは、伊吹派の動向だと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の新聞には、伊吹派の新たな政策提言が大きく報じられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "次の党首選に向けて、伊吹派は水面下で動きを活発化させている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "浦上　いや、そんな事よりも、つまりだな、人民戦線風の考え方では、もう既に時勢のホントのいぶきは掴めない事は事実ですね。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、けだかいささやきにも似て、いかにもやわらかくまた意味ふかく、こめかみや耳のあたりにまつわるこのいぶきは、どこからきて、どこに源をもっているのであろう。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
