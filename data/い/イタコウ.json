        "examples": {
          "standard": [
            {
              "text": "映画の登場人物が「あのイタ公が邪魔だ」と吐き捨てるように言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かつては、イタリア人を侮蔑する意味で「イタ公」という言葉が使われることがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「昔の不良はよく『イタ公』とか『チョン』とか言って差別してたな」と老人が呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は口癖のように「イタ公は信用できない」と繰り返していたが、それは偏見に満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ではそこのイタ公ども(*10)は何かその意味を知っているか？",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
