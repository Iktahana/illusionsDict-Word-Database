[
  {
    "uuid": "e904e3d3-331a-570e-912f-f93afd6093ad",
    "entry": "言い分",
    "reading": {
      "primary": "いいぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
