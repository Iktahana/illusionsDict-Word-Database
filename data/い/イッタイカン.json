        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ライブ会場は、観客の歌声で不思議な一体感に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "同じ目標に向かって努力することで、チームに一体感が生まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "文化祭の準備を通して、クラスメイトとの間に強い一体感が芽生えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "――「守夫君の心持が解らんのだよ、折角ローラさんがやつて来たといふ場合に、何を一体感違ひしてゐるんだらう、困つたなあ！",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お互に「話せばわかる」日本人の信頼感を、更に、「話さなくてもわかる」一体感にまで高める努力をしつづけた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然のなかにいる自分が、自然を構成するあらゆる要素との一体感を増幅させるために工夫した、見事な遊びだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "上体と腕の動きに、無理のない一体感があった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの段階では、車体との一体感と急制動を、ぼくにできるかぎり徹底的に教えこんでいる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
