          ],
          "literary": [
            {
              "text": "山の神女が市神であつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其山の神祭りも、市神祭りの夷講も、十月にとり越されて居る。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が、市神・山の神の祭りと共に、繰り上げられて、十月の内に行はれる様になつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の引出物に、漁猟・廻船・出納・売買の支配を附与せられ、それにより、市町｜商い所に市神として祀ることになったというのは、もう久しい以前から普及していた俗説であったかと思われる。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
