        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「今年は特に賑わっていますね、市神様のお祭り。」と、露店のおばあさんが嬉しそうに話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "かつて賑わった宿場町では、市神を祀ることが商売繁盛の願いと結びついていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域住民の長年の努力により、忘れられかけていた市神信仰が近年再び注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝承によれば、市神は市場の守護神であり、盗難や火災から商人を守るとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "町おこしの一環として、廃れた商店街に新たに市神を祀る祠が建立された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、こんなところで市神様にお目にかかれるとは！」と、古都を訪れた観光客は驚きを隠せなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "山の神女が市神であつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其山の神祭りも、市神祭りの夷講も、十月にとり越されて居る。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が、市神・山の神の祭りと共に、繰り上げられて、十月の内に行はれる様になつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の引出物に、漁猟・廻船・出納・売買の支配を附与せられ、それにより、市町｜商い所に市神として祀ることになったというのは、もう久しい以前から普及していた俗説であったかと思われる。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
