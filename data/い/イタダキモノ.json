    "definitions": [
      {
        "index": 1,
        "gloss": "present (that one has received)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "頂き物の菓子パンを、仕事の合間に同僚と分ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これ、頂き物なんですけど、たくさんあるのでお裾分けです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "頂き物が重なってしまい、賞味期限内に食べきれるか心配だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつも素敵な頂き物をありがとうございます。家族で美味しくいただきます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "珍しい頂き物をしたので、今夜は少し奮発して良いお酒を開けよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "頂き物の包みを丁寧に解き、送り主の心遣いに感謝する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「頂き物ばかりで恐縮ですが、ありがたく頂戴いたします」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――目にはやにが浮き、ほおは青やせにやせこけて深いしわがみぞのように走り、三度三度のいただきものも事欠いているのではないかと思われるような、しょぼしょぼとした老人でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘヘツ、肺病の罰あたりめが、結構ないただきものを殘して捨ててけつかる。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へへッ、肺病の罰あたりめが、結構ないただきものを残して捨ててけつかる。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに椎茸（イヨ産）、にんじん、はす（奥山さんからのいただきもの）を入れる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちもいただきものですがね。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに、ひとさまから戴いたのもあるが、いただきものは、ともかくとして、自分で作ったのは、どれも気に入らない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
