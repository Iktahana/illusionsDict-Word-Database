          ],
          "literary": [
            {
              "text": "――目にはやにが浮き、ほおは青やせにやせこけて深いしわがみぞのように走り、三度三度のいただきものも事欠いているのではないかと思われるような、しょぼしょぼとした老人でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘヘツ、肺病の罰あたりめが、結構ないただきものを殘して捨ててけつかる。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へへッ、肺病の罰あたりめが、結構ないただきものを残して捨ててけつかる。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに椎茸（イヨ産）、にんじん、はす（奥山さんからのいただきもの）を入れる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちもいただきものですがね。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに、ひとさまから戴いたのもあるが、いただきものは、ともかくとして、自分で作ったのは、どれも気に入らない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
