    "definitions": [
      {
        "index": 1,
        "gloss": "gradually",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "事故で負った大怪我も、懸命なリハビリによって一日一日と快方に向かっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "震災からの復興はまだ道半ばだが、町は一日一日と元の姿を取り戻しつつある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "幼い息子の成長は目覚ましく、一日一日の変化を見守るのが何よりの楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "目標達成までの道のりは遠いが、焦らずに一日一日の努力を積み重ねていくことが成功への鍵だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "大切なペットが老いていくのは悲しいが、一日一日を大切に、最後まで愛情を注ぎたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "師匠の元で、プロの陶芸家になるために一日一日、地道な修行を積んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "山頂に近づくにつれ、一日一日と寒さが増していくのを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ゆっくりかまえて、一日一日を、せめて悔いなく送りたまえ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日一日をいっぱいに生きている」　それ以後、私は馬場へ肉親のように馴れて甘えて、生れてはじめて友だちを得たような気さえしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく暑中休暇にはいり、東京から二百里はなれた本州の北端の山の中にある私の生家にかえって、一日一日、庭の栗の木のしたで籐椅子にねそべり、煙草を七十本ずつ吸ってぼんやりくらしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日一日だけが、とても大切になりました。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの私にとって、一日一日の努力が、全生涯の努力であります。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活は破産し切つて、ただしようことのない生存の一日一日が続き、如何なる行為らしい行為も最早見られないとしても猶、『無償の行為』は在つて存するのである。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの私にとつて、一日一日の努力が、全生涯の努力であります。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の気のせいででもあるか、民子は十三日の夜からは一日一日とやつれてきて、この日のいたいたしさ、僕は泣かずには居られなかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一日一日緑の深くなつてくるその葉を數へたり、處處に酢貝のやうな瘤のあるその枝振を眼をつぶつても覺えてゐられる程見詰めてゐたりした。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それでもそんな事を續けて行く内に、私の足元は一日一日と固まつて行つた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日一日が彼を引き摺っていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇的映画などは一日一日に古くなっても、ニュース映画は日に日に新たに、永久に若き生命を保つであろうと思われる。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチの皮膚病は一日一日ひどくなっていって、私の皮膚も、なんだか、しきりに痒くなってきた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにかなろうと一日一日を迎えてそのまま送っていって暮しているのであるが、それでも、なんとしても、どうにもならなくなってしまう場合がある。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは水を呑んだりしてごまかしてゐたけれども一日一日それが烈しくなってきてもう居ても立ってもゐられなくなった。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日から自分は平時の通り授業もし改築事務も執り、表面は以前と少しも変らなかった、母からもまた何とも言って来ず、自分も母に手紙で迫る事すら放棄して了い、一日一日と無事に過ぎゆいた。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の事は忘れ明日の事を思わず、一日一日をみだらなる楽しみ、片時の慰みに暮らす人のさまにも似たりとは青年がこの町を評する言葉にぞある。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして著者とともに貴重な残り少ない生の一日一日を迎えるのである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月日は経ったけれども、小学校で少しばかり習い覚えた文字すら忘れがちになるのに、そこのお嬢さんたちが裕かに勉強して、一日一日と物識りになり、美しくなっていくのを、黙って見ていなければならぬ恨めしさ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はある百姓の軒下、明日は木陰にくち果てた水車の上というようにどこという事もなく宿を定めて南へ南へとかけりましたけれども、容易に暖かい所には出ず、気候は一日一日と寒くなって、大すきな葦の言った事がいまさらに身にしみました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙は一日一日と薄らいで来て、月を越えた十二月のはじめには僅かばかりの噴上げ方となった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実巴里は一日一日と子どもに染み込んで行った。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が法律を学んで、その蝋を噛むやうな学理に頭を作つて、物質の姿をのみ追つて、心霊の影を外に見た結果、俺は一日一日の生活を作ることを知つて居る丈のものとなつてしまつた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした日蔭者の気楽さに馴れてしまうと、今更何をしようという野心もなく、それかと言って自分の愚かさを自嘲するほどの感情の熾烈さもなく、女子供を相手にして一日一日と生命を刻んでいるのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、一日一日、生きていくことが、とっても楽しいわ！",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "このふたりも、一日一日が、とっても楽しそうでした。",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "――かれらの生活をみて、これは飼殺しだと思ったこともあるが、いま妻をもち、小さいながら自分たちの店をもって、いちにちいちにち生きてゆくということの、息苦しい困難さにぶつかってみると、改めて寄場で聞いた言葉の意味がわかるように思えた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "every day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「一日一日と、窓の外の景色が秋色に染まっていくのが分かります」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一日一日、できることが増えていく子供の姿を見るのは、親として何よりの喜びです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「入院生活は長かったですが、一日一日、確実に体が動くようになっていくのを実感しました」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一日一日を懸命に生きる被災地の方々の姿に、こちらが逆に勇気づけられる思いです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一日一日と納期が迫ってくるプレッシャーの中で、チームの結束力が試されています」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一日一日、少しずつでも技術を磨き続けてきたことが、今日の逆転勝利に繋がりました」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一日一日と暖かくなっていくのを感じると、ようやく長い冬が終わったのだとホッとします」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一日一日、新しい環境に慣れていく自分を、どこか客観的に眺めているような不思議な感覚があります」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
