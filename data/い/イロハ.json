[
  {
    "uuid": "140ea572-a02c-5524-acf6-4a8455dfb6c6",
    "entry": "伊呂波",
    "reading": {
      "primary": "いろは",
      "alternatives": [
        "イロハ"
      ],
      "is_heteronym": false
    },
    "grammar": {
