[
  {
    "uuid": "5e210b65-bad6-5229-9df7-93b41ab7b982",
    "entry": "言い換える",
    "reading": {
      "primary": "いいかえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
