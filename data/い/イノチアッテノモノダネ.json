    "definitions": [
      {
        "index": 1,
        "gloss": "while there is life, there is hope",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「たとえ困難でも、命あっての物種だよ。諦めるな！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "絶体絶命の状況でも、「命あっての物種」と信じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、この言葉を胸に、病と闘い続けた。「命あっての物種」だ、と。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大丈夫、君ならできる。命あっての物種だからね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それを主人はちらと見て、『何を言っても命あっての物種だ、』と大きな声で独言を初めた、『どうせ自分から死ぬるてエなアよくよくだろうが死んじまえば命がねえからなア。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『命あっての物種だてエ事よ、そうじゃアねえか、まアまア今夜なんか死神に取っ付かれそうな晩だから、早く帰ってよく気を落ち着けて考えるんだなア。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "命あっての物種ぢやのう。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけども、借りた本人は生きているかも死んだかも知らねえんでね、すったもんだをやっていたら、せがれの直筆だという借用証書をつきつけやがって、あげくの果てに、とうとうだんびらをひねくりまわしゃがったんで、命あっての物種と、みすみす千両かたり取られたとこういうんですがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命あっての物種だ。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猛火の中の私たち",
                "note": "青空文庫"
              }
            },
            {
              "text": "命あっての物種だ」と駒越左内も臆病風。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命あっての物種という恰好で、横の手術室の扉の方へ逃げ出そうとしたが、患者はヒンガラ眼のまま気が付いたらしく、片手をあげて制し止めたので、それも出来なくなった。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　左は言え、私は決して長寿を嫌って、無用・無益とするのではない、命あっての物種である、其生涯が満足な幸福な生涯ならば、無論長い程可いのである、且つ大なる人格の光を千載に放ち、偉大なる事業の沢を万人に被らすに至るには、長年月を要することが多いのは言う迄もない。",
              "citation": {
                "source": "死生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "命あっての物種である。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、命あっての物種だ」と、弱音を吹くと、タヌは、情けなそうにコン吉をみつめてから、「君の真綿のチョッキには、金比羅様のお札が縫い込んであるそうだから、たいていの弾丸なんかとおりはしないでしょう」と、無情ないことをいう。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……生命あっての物種だ、どうか山登りだけは思いとどまってくれたまえ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命あっての物種というどたん場に遭遇しては、遺骨強盗もへちまもあったものではなかった。",
              "citation": {
                "source": "撥陵遠征隊",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、高橋判官のひきいる面々は、それぞれ、国々から狩り集めた駆武者であったから、命あっての物種と、戦わぬ先から逃げ腰で、戦のさなかになると続々と退却するので、しまいには、判官の囲りの味方は殆どいなくなってしまった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "命あっての物種、というその命をじかに脅かされることであるから、生命保存のために、人々の全努力が、瞬間の命を守るたたかいに集注される。",
              "citation": {
                "source": "戦争はわたしたちからすべてを奪う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "命あっての物種じゃから、かならず、夫人の頼子さんといっしょにそとへ出て、あの屋敷で夜をおくってはなりませぬぞ。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "清兵一　命あっての物種、看護もこれまで、一刻も早く逃げねば！",
              "citation": {
                "source": "戦争",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "「命あっての物種だろうではないか。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
