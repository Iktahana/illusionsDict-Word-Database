[
  {
    "uuid": "50645cd7-3c81-5008-a2af-cffc4ad47925",
    "entry": "行きがかり",
    "reading": {
      "primary": "いきがかり",
      "alternatives": [
        "ゆきがかり"
      ],
      "is_heteronym": false
    },
    "grammar": {
