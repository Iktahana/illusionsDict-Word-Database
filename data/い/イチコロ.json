[
  {
    "uuid": "48d48489-d5bc-567a-a218-cffea2620e42",
    "entry": "一ころ",
    "reading": {
      "primary": "イチコロ",
      "alternatives": [
        "いちころ"
      ],
      "is_heteronym": false
