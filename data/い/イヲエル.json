[
  {
    "uuid": "e2de7b92-801f-58a3-8273-c89a0f09a19e",
    "entry": "意を得る",
    "reading": {
      "primary": "いをえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
