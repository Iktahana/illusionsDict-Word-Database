          ],
          "literary": [
            {
              "text": "わたくしは、どんぶり持って豆腐いっちょう買いに行くのが、一ばんつらかった。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二、三日、何処どん居んなはったじゃい、いっちょんわからんじゃったたい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が付くと、三造の前の真白な瀬戸物皿の上に、いつの間に来たのか、それこそ眼の覚めるほど鮮やかな翠色をしたすいっちょが一匹ちょこんと止って、静かに触角を動かしている。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すいっちょは夙うに何処かへいなくなっている。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、海水パンツいっちょうに革靴の男がなぎなたの試合会場を飛び回って審判でもやってれば、そりゃタケシ軍団の世界だろうよ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンツいっちょうの大魔神が、ノド渇いたな、と室内に入っていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、ゴルドン兵曹だといっていましたよ、飛行班の……」「ばか、何をいっちょる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういわれると、ちょんさんはくやしがって、負けずに弟の名前を呼んで、からかい返してやろうとしましたが、「ちょうにん、ちょうにん、ちょうじゅうろう、まんまる入道、ひら入道、せいたか入道、へいがのこ、いっちょうぎりの、ちょうぎりの。",
              "citation": {
                "source": "長い名",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とすぐやられますが、弟の方は、「まんまる入道、ひら入道、せいたか入道、へいがのこ、いっちょうぎりの、ちょうぎりの。",
              "citation": {
                "source": "長い名",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この長者とおなじ村に、これはまた持っているものといっては、ふるいすきとくわとかまがいっちょうずつあるばかりという、たいへん貧乏なお百姓の夫婦がありました。",
              "citation": {
                "source": "たにしの出世",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "食うちょらな動けんがの」「ほんでも、昨夜な、便所へはいっちょったら、おじさんが、おばさんに、俥も持って行かせ、俺はこのまま死んだ方がまし、云うてな、泣きよんなはった」「ほうかや！",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸にも、水にも、いっちょうらですぜ。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "フックから　つるせば　あなぐまトミーの　頭上で　バケツが　ぶらんぶらん、　まどごしに　ひもで　あやつると　いっちょ　シャワーの　できあがり　というわけです。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉利支丹しか乗せぬそうじゃけん、いっちょう吉利支丹にならな、いかんばな」「いや、それでござりますが」　吉之丞は、かたちだけの信徒になっても、吉利支丹の行儀もしらず、十の掟を保つことなどは思いもよらない。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（パッと立ってマントルピースの上にのせてあったダイスの壺を持って来て、須永の前にドンと坐り）こんだ、これでいっちょう！",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（ジロリジロリと、立っている私の足の方から頭の方へ眼で撫でまわして）ならば、いっちょう、手を振って見ますかね？",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三平答えず）ハハ、いいさ、いっちょう行こう。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その中に、忘れもしねえ、海後｜磋磯之介と、旦那の名も、十七名のうちに、立派に載っていたと思ったが、どうして今日まで御無事に……」「これっ、おい、何をいっちょるか、何を……」　旗岡巡査は、まるで、持っている棒みたいな表情で、「わしには、何のことか、わけが分らんが……」「……へえ？",
              "citation": {
                "source": "旗岡巡査",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いっちょうぶったたけや、坊や。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いっちょ懸命に駆け出しといでよ！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの軒に吊った籠で鳴くのか、すいっちょが澄んだ声を張って鳴き続けていた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら、オヤジのを、いっちょ、聞かせてくれえ」　城三次が、棚の下段からあおむいて声をかけた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「原田君、いっちょ、行こか？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、お父さんが、いっちょ、ゴンゾ踊りを見せてやろ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういっちょ馴染みの銀貨でいくか。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい番僧、いっちょうやってくれい」　ところへ、騒ぎを聞きつけて、監寺、提点、蔵主、浴主などの役僧などから、工事場の諸職まで、まっ黒になって様子を見にきた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
