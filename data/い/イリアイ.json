[
  {
    "uuid": "385146a9-397c-53f9-a8cc-d8ffc6969101",
    "entry": "入相",
    "reading": {
      "primary": "いりあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
