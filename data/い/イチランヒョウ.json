          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「冷蔵庫の扉に中身の一覧表を貼っておけば、うっかり同じものを買わずに済むんじゃない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複雑な料金プランを一目で見比べられる一覧表を作成し、商談をスムーズに進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "避難所の壁には安否が確認された人たちの一覧表が掲示され、多くの人が食い入るように見つめていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」と言つてＮ君は或る本をひらいて私に見せたが、そのペエジには次のやうな、津軽凶作の年表とでもいふべき不吉な一覧表が載つてゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際電話をかけるたびに「あそこの国番号は何番だ」とわめき散らす必要ももはやなく、静かにカントリー・コードの一覧表のウインドウを一つ開けば良いではないか、と考えたのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の菜の当てッこをしたり、昼の菜の一覧表をつくったり、そんなことも消閑の一策になっている。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学年度とお名前をうかがいます」　そういって、受付の女子が、手もとの一覧表に目を落とした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近世戦争進化景況一覧表」（一二一頁参照）はそのときに作られたのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時点でできることを一覧表にまとめておき、その中から選ぶ形をとることで、交流はスムースなものになると期待できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした理想に近づくために、ＩＴＯＳには、ディスプレイに表示されるコンピューターからの問いかけに「はい」か「いいえ」で答え、処理の内容や手順を一覧表にしたメニューから選んでいくだけで、プログラムを作ったり処理を行ったりできる環境が盛り込まれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに巻末の一覧表には主人公たる僕は勿論、作中の人物の本名仮名をずらりと並べろと云ふのである。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして戸棚の出外れの窓際に歩み寄ると、そこいらに貼り並べて在る写真だの、一覧表みたようなものを見まわしながら、引続いて若林博士の説明を求めて行った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、個々の出来事からでも、共通した因数を知ることが出来たとしたら、どうだろう」と二人の顔をサッと掠めた、驚愕の色に流眄をくれて、「ところで君は、この事件の疑問一覧表を作ってくれたはずだったね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、支倉君の書いた疑問一覧表を基礎にして、あの薄気味悪い｜赤い眼の視差を計算してゆくことにしよう」と法水の眼の光が消えて、卓上のノートを開きそれを読みはじめた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病的な、しかもこれほど公式的な符号が、事実偶然にそろうものだろうか」　その一事は、かつて検事が、疑問一覧表の中に加えたほどで、磅※と本体を隔てている捕捉し難い霧のようなものだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解剖の結果、胃の中にあった食物の一覧表は出来ていますね」　検事が、もう一度発言した。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その胃内容物一覧表は、長谷戸検事の手に渡って、拡げられた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "留学生の志望学科といふ一覧表によると、警察制度、水産商業、紡績、工業、機械工業、鉱山業、土木、医学、歯科、体育、航空学等がそれぞれ、二乃至十三といふ数を占め、演劇史、美術、文学が、何れも一名づゝある。",
              "citation": {
                "source": "三保寮を訪ふ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは、あの日以来吉蔵の店では冷蔵庫へ入れる氷を五貫目ずつ余計使っている事実、一つは、あの日を境にして失踪した者の一覧表の中から、山名国太郎という大学生がお由に似た年頃の婦人を自室に引き入れている所を一二度見た者があるという報告であった。",
              "citation": {
                "source": "白蛇の死",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "趣を変へて明治十二年二月版「講談浄瑠璃落語定席一覧表」と云ふ番附を取出して見たが、此も亦、徒労だつた。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはざつとした、収支一覧表です。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "公開作品一覧表には、あまり文学に馴染みのなかった野口でさえ知っている作家の名前が並んでいた。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "申告すべき退蔵物資の十六種目一覧表も載った。",
              "citation": {
                "source": "モラトリアム質疑",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹製品の一覧表を見ることが出来たらば、西洋人はたしかに一驚を喫するであろう。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは東京、尾張間の停止所の一覧表で、只の丸は飲食店、半黒の丸は休み場所、黒丸は旅人が「食い且つ眠り得る」場所を示している。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "会議が終る迄に、生徒達は五十六の器械をつくり、それ等を、それ等の構造に要した材料の一覧表と共に、演壇上に陳列した。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一覧表の一人に会いたいのです。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼はさも満足そうに、この町会割当額一覧表を眺めつつ説明したが、世帯数はおそらく三百以上あったのではなかったのではなかろうか。",
              "citation": {
                "source": "乱歩分析",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、この方が、より公正であって、より理論的な方法にちがいなく、しかも乱歩は、自分でそのやっかいな計算をやって一覧表を作成した。",
              "citation": {
                "source": "乱歩分析",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソ連人文通者によると、最近起きた政治的な出来事を一覧表にしているソ連の年報から、この条約の件が消されつつあるらしい。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紳士方の一覧表をあとで提出しましょう」「でかした。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが一覧表は必要ない。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
