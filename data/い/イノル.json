    "definitions": [
      {
        "index": 1,
        "gloss": "to pray",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供の安全を願って、毎晩神棚に祈る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験前には必ず神社でお参りして、合格を祈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦争が早く終わるようにと、世界中の人々が祈っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "入院、といふことも考へましたが、それでも、やはり心の奧底で、かの高價な「二個のズルフオンアミド基」を有する世界的な新藥を、たのみにしてゐるところが在るらしく、そのうち卓效を奏するであらうと、身動きもならず靜かに横臥して、天に祈る氣持でありました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、み空はたかく、吹く風はこまやかに　　――祈るよりほか、わたくしに、すべはなかつた……寒い夜の自我像きらびやかでもないけれどこの一本の手綱をはなさずこの陰暗の地域を過ぎる！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時は「あなた、かくしているでしょう、きっとそうだ、あなたそうでしょう」とうるさく聞きながら、余の顔色を読もうとする、その祈るような気づかわしげな目づかいを見るのが苦しいから「ばかな、そんな事はないと言ったらない」と邪慳な返事で打ち消してやる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年が祈るやうにさう答へました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ生来の不文のために我学界に礼を失するがごとき点があるかもしれないが、これについては単えに読者の寛容を祈る次第である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者の寛容を祈る外はない。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何時までも安心したりおさまったりする事なしに、何時までも迷って煩悶して進んで行く事を祈るものである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うままを備忘までに書いてみた、名前を挙げた画家達に礼を失するような事がありはしないかと思うが、素人の妄言として寛容を祈る。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵いと高き梢にありて、ちいさなる卵ら光り、あふげば小鳥の巣は光り、いまはや罪びとの祈るときなる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海水旅館赤松の林をこえて、くらきおほなみはとほく光つてゐた、このさびしき越後の海岸、しばしはなにを祈るこころぞ、ひとり夕餉ををはりて、海水旅館の居間に灯を点ず。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからも君はこの道を行かれるやうに祈ると書いてあつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まがりくねつて犬のやうに病んだ心と、人間のもつとも深い罪や科やに対して彼は自らを祈るに先立つて、その祈りを犯されることを厭うた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりでゐることを、ひとりで祈ることを、ひとりで苦しみ考へることを、ああ、その間にも彼の疾患は辛い辛い痛みを加へた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急速なるＦ・Ｏ）　＝（Ｆ・Ｉ）柳島の妙見には――　恋人の無事なる事、神かけて祈るお光の姿がある。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は昨夜からの涙の滲んだ絹のハンカチを香港の朝の風景に飜えして、　――妾達は陳独秀の健康を祈るのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず神に對して祈る聲は持つてゐても、人に對しては聲を鎖してゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海峽の霧の夜に朧ろな月が差し入る時、または靜かな秋の夜にポプラのわくら葉がかさこそと散るのを聞く時、彼等は密かに床の上にぬかづいて、心から神に祈るのであらう。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえて読者の叱正を祈る次第である。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢明なる読者の寛容を祈る。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいはひにして、大過無き出發となつてくれたらよいと、いまはそれを祈るばかりである。",
              "citation": {
                "source": "『パンドラの匣』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらばとみちを横ぎりて、　　　束せし廐肥の幾十つら、祈るがごとき月しろに、　　　　朽ちしとぼそをうかゞひぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあみんな、祈るのだぞ、まっすぐに立て。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青年が祈るようにそう答えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその頃の人だから、神仏に祈願を籠めたのであるが、観音か何かに祈るというなら普門品の誓によって好い子を授けられそうなところを、勝元は妙なところへ願を掛けた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはやはり人間、というよりむしろ私の言語の不完全のせいだとして読者の寛容を祈る事とする。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行進　（五）　セットの終ったころ、田島は、そっとまた美容室にはいって来て、一すんくらいの厚さの紙幣のたばを、美容師の白い上衣のポケットに滑りこませ、ほとんど祈るような気持で、「グッド・バイ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいちばんのさいわいに至るためにいろいろのかなしみもみんなおぼしめしです」　青年が祈るようにそう答えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の大尉はこちらで、その姿勢を直すはねの音から、そのマジエルを祈る声まですっかり聴いて居りました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空もいんいん、地もいんいん、肢體に青き血ながれ、するどくしたたり、電光したたり、身肉ちぎれやぶれむとす、いま裸形を恥ぢず、十字架のうへ、齒がみをなしてわれいのる。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は自ら安んずることができないので、「俺の三十年の清徳も、おまえのために累わされてしまったのだ、この世の中に生きていて、徒らに女に養われるということは、ほんとうに、すこしも男らしくないことだ、人は皆富をいのるけれども、俺はただ貧をいのるのだ」　と言った。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
