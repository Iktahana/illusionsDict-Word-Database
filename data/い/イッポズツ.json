        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "険しい山道だったが、焦らず一歩ずつ確実に登り続けることで、ついに頂上にたどり着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "リハビリは痛みを伴う辛いものだったが、彼は諦めずに一歩ずつ歩行訓練を重ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "どんなに壮大な夢であっても、毎日の小さな努力を一歩ずつ積み重ねていくしかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そう呑気な旅でもないから一歩ずつでも無駄足はしたくない。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩は一歩ずつ、闇が薄れた。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂利だらけの道の上で一歩ずつ、じゃり、じゃりと音がするのが聞こえてくる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも言えない、と書いている下から、背負い重りのする荷は一歩ずつ重量が掛る、草臥はする、汗にはなる。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初は手写本を完全になぞり、そこからやがて量産性という技術の本質に沿って、本は一歩ずつ変わりはじめます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして単細胞物の発生より進化また進化の幾億万年を経て、一重また一階の過程に整然たる秩序の道を一歩ずつ踏み上りて、遂に人類の発生となったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "始終一歩ずつ上手を行くような事務長が一種の憎しみをもってながめやられた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間としての感覚を失い、一歩ずつ機械に近づいていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい亀の歩みでも、牛の歩みでも、歩一歩ずつ進んでいるには相違ないと云うことだけは信じている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "連合軍と戦った独逸とおなじように、新富座は内部における経済上の苦痛から、興行上では殆んど同等の成績を収めながらも、一歩ずつその強敵に圧迫されるような悲運にかたむいて来た。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "云い換えると、斬ると云う働きが一歩進むごとに、殺すと云う目的が一歩ずつ達せられるので、斬り了った時に目的は終局に帰するのだからして、斬るのと殺すのはそう差違はありません。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ここに提出されているいくつかの問題を、事実上私たちの発意と、集結された民主力とで、一歩ずつ解決に押しすすめてゆく、その一足が、私たちの眼路はるかに、広々とした民主日本、封建から解かれ、美しく頭をもたげた日本女性の立ち姿を予約しているのである。",
              "citation": {
                "source": "合図の旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "複雑に複雑を極めた箇性の内面の力が、圏境や過去の経験に打たれ、押し返し、揉み合って一歩ずつ、一歩ずつ今日まで歩み進んで来たのが、今日のその人でありその人の生活であるのだ。",
              "citation": {
                "source": "概念と心其もの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は四つ並んだ幻の墓の方へ否でも応でも一歩ずつ近づいて行くの外はなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "切手のねだんは、いつも物価の値上りの一歩ずつあとを追ってたかくなった。",
              "citation": {
                "source": "郵便切手",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの人々は、一歩ずつより合理的な生産の関係に入ろうとし、憲法が明記している基本的人権を実現させようと努力している。",
              "citation": {
                "source": "文化生産者としての自覚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も不思議はありやしないよ」「そうか、そんなことだつたのか」「然しね、林田の奴、いちいち僕に一歩ずつ先へ廻りやがる。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、裾野へ下りようとするには一歩ずつ歩かなければならなかった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい額の髪、きれいな顔つきも、全く子供のように見えて非常に可憐なのを御覧になると、なぜこんなふうにさせてしまったかと後悔の念のつくられることで、罪に一歩ずつ近づく気があそばされるので、几帳だけを中の隔てには立てて、しかもうといふうには見せぬように院はしておいでになるのである。",
              "citation": {
                "source": "源氏物語",
                "author": "横笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "与平は一歩ずつゆるく川底にはいってゆきながら、眼をすえて水の上を眺めていた。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉は煉瓦埃りのくっついたままのズボンで列の後にくっついて、辛棒づよく一歩ずつ動き、先ず勘定台で十二カペイキ払って受取の札を貰い、今度はパンをうけとるために続いてる列に立った。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も若いと云いながら死に向って一歩ずつ進んで居ることはうたがいない。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてその変化のありさまを見ると、変わるごとに一歩ずつ小さくなり、堕落する順序が現れている。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一筋の運命よりほかに、自分を支配するものがないかのごとく、幾万の黒い頭が申し合せたように歩調を揃えて一歩ずつ前へ進んで行く。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして考えれば考えるほど一歩ずつ迷宮の奥に引き込まれるような面白味を感じた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、たまらなくなって、一歩ずつだんだん裏の戸口に近づいた。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵の夜光時計が二分を刻むごとに、彼は一歩ずつ左へ体をうつし、前と同じような恰好で蛍光板をのぞきこむのでありました。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
