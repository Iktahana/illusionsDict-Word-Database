[
  {
    "uuid": "a150f1d7-2313-56b9-a9a6-0468f5c1167a",
    "entry": "一旦",
    "reading": {
      "primary": "いったん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
