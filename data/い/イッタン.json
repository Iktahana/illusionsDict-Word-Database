    "definitions": [
      {
        "index": 1,
        "gloss": "once",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は一旦寝てしまうと、朝まで何があっても起きない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この機械は、一旦動き出すと、緊急停止ボタン以外では止められない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は一旦決めたことは、絶対に曲げない頑固なところがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "一旦あの店のケーキの味を知ってしまうと、他では満足できなくなるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "その習慣がつかない中は、忌わしく煩わしいものであるが、一旦既に習慣がついた以上は、それなしに生活ができないほど、日常的必要なものになってしまう。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根曲り竹も、楊の根も、樅の肌も、はた長くしな垂れるサルオガセも、その柔嫩の手に、一旦は、撫でられぬものはない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気だの、日光だの、水などと云ふものは、そいつがふんだんにある場合には、些も不自由を感じないし、従つて有難味も分らないものだが、一旦、無いとなると、さあ事だ。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査と駅員に守られて一旦乗船したが出船間際に連れ下ろされて行った。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は僕の如き藝術的無能力者と素質を異にし、いやしくも一旦志ざした所へ向つて、努力貫通せねば止まない男で意志と精力の權化である。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一旦それが解れば、始めに見た異常の景色や事物やは、何でもない平常通りの、見慣れた詰らない物に変ってしまう。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦民衆によつて閑却された詩は、更にまた彼等の生活にまで帰つて来た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、すっかり堰いてしまっては、上から落ちて来る水が両方の岸へ溢れ出しますから、堰は低く出来ていて、水はそれを越して神田川へ落ち込むようになっているが、なにしろあれだけの長い川が一旦ここで堰かれて落ちるのですから、水の音は夜も昼もはげしいので、あの辺を俗にどんどんと云っていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に詮議のしようもないので、お徳は気が済まないながらも一旦は空しく引き揚げるのほかはなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "富蔵は一旦気絶したが、川春の店の者が見つけて内へ連れ込んで、水や薬を飲ませると、すぐに息をふき返して、何事もなく済んでしまったのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屋の亭主こそ実に迷惑で、それがために思いもよらない災難をうけて、一旦は召し捕られたり、その後もたびたび番所へ呼び出されたり、どうもひどい目に逢いましたが、右の事情が判って無事に済みました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡取りの娘であるからそちらへ差し上げるわけには行かないと、歌女寿はわざと焦らすように一旦ことわると、相手はいよいよ乗り出して来て、いわゆる囲い者として毎月相当の手当てをやる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の送葬のときに私も町内の附き合いで行ってやったから、よく知っています」「むむ、妙信寺か」　源次に別れて、半七は御成道の大通りへ一旦出て行ったが、また何か思いついて、急に引っ返して広徳寺前へ足をむけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が無事に済んだから好いようなものの、一旦こっちへ引き渡した以上、もし重い科人になったらもう取り返しは付きませんや。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が一旦他家へ嫁入りをした以上は、むやみに離縁なぞすべきものでも無し、されるべき筈のものでもない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女もひどく困ったらしい顔をしていたが、悪くすると古池へ身でも投げそうなお蝶の決心に動かされたらしく、十日目の夕方には、とうとう一旦は帰れという許可をあたえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "小判の顔をみてお亀も一旦は喜んだものの、よくよく考えてみると彼女もなんだか不安になって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして娘があれほど忌がっているものを、あんまり可哀そうでもございますから、一旦は断わりましたんですけれど、相手の方はなかなか承知しないんでございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだ、それだ」　二人は手筈をしめし合わせて一旦別れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "式部はすぐに起ちあがって、神前に一旦供えたかの白木の箱を取りおろしてしずかにその蓋をあけると、かれの顔色がにわかに変った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼等は、人民に向って云う、――一旦、お前達の上にいる人々の思う通りの勝利が得られた暁には、あらゆる暴政は魔術にかかったように影を消してしまって、地上に平和が来るのだ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、一旦恥辱を蒙って、吾々同胞の面汚をしていながら、洒亜つくで帰って来て、感状を頂きは何という心得だ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だって一旦汚した身体ですから、そりゃおっしゃらないでも、私の方で気が怯けます。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の為だって、何だって、一旦他の人に身をお任せだもの、道理だよ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも私の頭が一旦、煙突の問題を離れると、彼女の裏面の秘密に関する私の調査がグングン進捗し始めたのは重ね重ねの不思議であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえいえ決してそのような……両親が申しまするには一旦、蔵元屋とお約束が出来て、結納までも取交いた上は、斬られたお熊さんは我家の娘も同様。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦、お輿入が済みました暁には、私から何もかも貴方の御両親に打明けまして、蔵元屋の蹄係にかからぬよう、襟半様の暖簾に傷の付かぬよう、又は黒田五十五万石の御納戸に障らぬよう、忠告を申上る覚悟でおりました。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然しね、お正さん、貴女も一旦嫁いだからには惑わないで一生を送った方が可しいと僕は思います。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の一家がいったん東京へ移ってから再び郷里に帰った頃は重兵衛さんの家は宅のすぐ東隣の邸に移っていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、設計では挿すことになっていたのを、つい挿すのを忘れたのか、手を省いて略したのか、それともいったん挿してあったのを盗人か悪戯な子供が抜き去ったか、いずれかであろうと思われた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "for a short time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
