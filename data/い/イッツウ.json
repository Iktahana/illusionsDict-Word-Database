        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "配牌から索子の一通が見えていたので、積極的に集めていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あと一枚で一通が完成するというところで、他の人に上がられてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
