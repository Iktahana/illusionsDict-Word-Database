    "definitions": [
      {
        "index": 1,
        "gloss": "attitude to life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の不屈の生き様は、多くの若者に勇気を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんな逆境にあっても、彼女は自分らしい生き様を貫いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦後の混乱期を生き抜いた人々の生き様には、学ぶべきものが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「お前の生き様、見せてもらったぜ。大したもんだ。」と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の描く登場人物たちは、それぞれ異なる生き様を抱え、深く心を揺さぶる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誰もが納得するような立派な生き様でなくとも、自分自身が納得できる生き方をしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "時代と共に人々の価値観が変化しても、真摯な生き様は常に尊ばれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私共が一旦病気になって生き様と云う願望が激しく燃え上った時ほど医者の奴隷になる事はない。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一昨年の病気以来深くその生き様とする願望の忍耐強さ従順さを感じて居る。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にでも其人｜相応の生き様があり、また其人相応の死に様があります。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは誤まられた組織の上に正しく人生を生き様とする者の余儀なくされた闘であり必然の帰結である",
              "citation": {
                "source": "馬鈴薯階級の詩",
                "author": "中島葉那子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、今までの生き様でこんな驚くべき犠牲をするのだろうし、メアリに親しみを見つけたせいだろう。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き様を絶対に知られたくない。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
