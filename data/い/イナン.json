        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この境界線「以南」の地域は、すべて我々の管轄下にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地図上で、この地点「以南」の地名を確認してみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「以南」の島々は、温暖な気候で知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "観測データによると、この監視ライン「以南」で異常な信号が検出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "氷点に相当する等温線が大陸をほぼ東西に横断してその以北は雪、以南は雨が降っている、その雨と雪の境界に沿うて帯状をなした区域が凍雨や雨氷に見舞われている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この零度等温線とほぼ並行して風の境界線があり、その以北は北がかった風、以南では南風が吹いている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汐留堀以南は品川に至るまでの間たゞ一の○赤羽川あるのみ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて永代橋以南の深川寄りの方を記せば、熊井町より大島町に沿ひて越中島の北の方を、富岡門前町と並行して木場に至り、またその南の方を東して遠く洲崎の遊廓に達するの一渠あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんの以南は栄蔵に学問をさせ智識をつけて、名主の職をつがせねばならないと考へた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「以南さんが、――お前さんのお父さんが驚くぢやらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんの以南さんが、京都に出てゐることを、前から知つてゐた良寛さんは、お父さんからの便りではあるまいかと思つて開いて見た。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "良寛さんは手短かに、手紙を送つて貰つたことや、父の以南が懇意にして頂いたことなどを感謝した。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんたうに以南さんはお気の毒でした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが以南さんのかたみです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は以南さんは、桂川に身を投げてなくなられたのです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「以南さんは、ほんたうに一風変つた方でした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ちやうどあなたのお父上の以南さんも、銭湯に来てをられたさうです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と以南さんがきかれました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると以南さんは気軽に『さうですか、ではお供しませうかな。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが銭湯を出ると、そのまま以南さんは家へは帰らず、暁臺先生の宿へ来られ、翌朝一緒に旅立つたのださうです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもは、あとからそのお話をうかがつて、全く以南さんは変つたお方だと思ひました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "父、以南の胸の奥底には、はげしい勤皇の志がいつも燃えてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以南さんは良寛さんに、よく覚えておけといふやうに、力をこめて何度もこの話をきかせてくれた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの竹内運平氏は「青森県通史」に於いて、この辺以南は、昔からの津軽領ではなく、秋田領であつたのを、慶長八年に隣藩佐竹氏と談合の上、これを津軽領に編入したといふやうな記録もあると言つてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟雨六十二翁は与板の人、蓋し良寛の父以南の実家新木氏の子孫なる由。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度ヲ基點トシテ已ニ阿富汗ニ及ビ波斯ニ及ビタル彼ガ中央亞細亞ニ進出スルハ論ナク、極東海上ノ基點香港ト相應シテ中部支那以南ノ割取ヲ考ヘ始メタルハ明白ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "周知ノ如ク英獨協商ハ香港ヲ根據トセル英國ト青島ヲ根據トセル獨逸トガ、支那分割ノ亞佛利加大陸ノ如ク實現スベキコトヲ確信シテ、北支那ヲ獨逸ニ中央支那以南ヲ英國ニ妥協シタル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "英國ハ英獨協商ノ相手方ヲ日本ニ代ヘタルガ故ニ、今ヤ該協商ノ目的タリシ中部支那以南ノ領有ヲ現實ナラシメントシテ茲ニ青海四川甘肅ヲ包有セル西藏濁立ノ要求トナリテ現レタルナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の陳蔵器説に風狸｜※州以南に生じ、兎に似て短く、高樹上に棲息し、風を候うて吹かれて他樹に至りその果を食う。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが邦でも熊野地方で古来牛を神物とし藤白王子以南は牛を放ち飼いにした。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "吝ったれた兄哥　魚市場のすぐうしろにある、無線電信のポールを秋空高く仰いだ向う岸の築地三丁目以南、起生橋を中心としてベタ一面に並んだ店は、いかさま彼ら兄い連の御蔭で繁昌しているものと見えた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本内地でも中部以南の山野にいくらも自生しているものだよ。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "生女眞は騎射が非常に上手で、地が方千餘里、戸數が十餘萬あり、それが皆山谷の間に住居してゐると云はれてゐるが、曷蘇館といふのは契丹に歸化した所の女眞人であるけれども、其生活の爲方はやはり生女眞と同樣であつて、遼陽以南の土地に遷されてからも、依然として山谷に住居して居つたらしい。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "又當時奴國、不彌國以南にして道里明白ならば、宜しく其の數を記すべきに、單に其の行程を日數にて計り、里數を擧げざるを見れば、此間の道里を一萬二千餘里の中より精確に控除して計算せんことは、杓子定規に近きの嫌あり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
