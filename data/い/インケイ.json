        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一昨年（大正五年）十二月の『風俗』に、林若樹君が「不思議な薬品」てふ一文を出し、本邦現存最古の医書｜丹波康頼の『医心方』から引き陳ねた奇薬の名の内に、馬乳、白馬茎、狐と狗の陰茎あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙者の陰茎、僅に此の如し』とかきて山陽に贈る。",
              "citation": {
                "source": "八宝飯",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供となると、五歳以上の男児で上下着した者は一人前の武士と見なされていたが、それ以下の男児は、男たる事を証明するために、関の役人の前で前をまくって陰茎を示したものである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、熊の陰茎には骨が入っていることです。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "平素は、鉄筋と共に陰茎を下腹のなかへ入れて置きます。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊の陰茎で想いだしたのですが、犬の陰茎にも筋金が入っています。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の親戚である狸の陰茎にも筋金が入っております。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体、犬科の動物の陰茎には筋金が入っているものです。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐は随分夫婦仲がよい動物ですが、この陰茎には骨が入っておりません。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫も虎も、その陰茎には筋金が入っていません。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀頭は包皮で包まれているが、陰茎も、睾丸も大きくなった。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、性欲を催すと、私の意志とは全く関係なく、私の陰茎はその現象を呈する。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者は私の陰茎をつまみ、包皮をむく。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "静海、刀をおろし、陰茎の脇、ふぐりの右の方を五六寸も截割りたりとか。",
              "citation": {
                "source": "玉取物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしくは陰茎、とあり。",
              "citation": {
                "source": "戦争はわたしたちからすべてを奪う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして股間の陰茎を白日の下に露出し、しかも身を反らしてそれを赤黒い巨大なものに怒らしてみせながら、『僧の物三尺。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰茎と睾丸は包にくるんで恥丘の近くで一刀のもとに切断し、傷口に１掴みの止血粉末を押し付ける。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先ず陰茎に感染し、やがて全身に広がる」と。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
