[
  {
    "uuid": "db60103c-192d-5fc3-a607-ddd163b941f7",
    "entry": "意味不",
    "reading": {
      "primary": "いみふ",
      "alternatives": [
        "イミフ"
      ],
      "is_heteronym": false
    },
    "grammar": {
