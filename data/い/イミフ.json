    },
    "definitions": [
      {
        "index": 1,
        "gloss": "of uncertain meaning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」私は意味不明の事を言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子誕生の喜びも束の間、いまはラプンツェルの意味不明の衰弱に、魂も動転し、夜も眠れず、ただ、うろうろ病床のまわりを、まごついているのです。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは絶えずいろいろな観念が創造され、いろいろな言語が使用されるにかかわらず、一も意味のはっきりとした解釈がなく、定義の確立した観念も出来ない中に、次から次へと流行が変って行き、空しく取り散らされた多くの言語が、無意味不可解の闇の中で、永く幽霊のように迷っている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま読みかえし、私自身にさえ、意味不明の箇所が、それらの作品には散見されるのである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "意味不明の文章が散見されるということだけでも、私は大いに恥じなければいけない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章は意味不明のくだらないことで、ああ、まったく、こうなることを恐れてたのに！",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "デヴォンシアに来てまだ数時間にしかならないのに、これほど素晴らしい滑り出しを見せた調査に見切りを付けるなんて、さっぱり意味不明だった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（此原詞は“Here's goodly gear.”此意味不分明。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによりますと、今しがた、本島内から意味不明の怪電波を発射したものがあったそうです。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "託宣の歌は、どこかに意味不徹底の語があつたり、おほまかなしらべの内に、人を寛けさと憑しさに導く気分性がある。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それほどまでにはつきり云へる人間が、どうしてまた不良少年なんて云ふ奴等に威嚇かされた位でそんな馬鹿なことをしたのかなあ……」私は斯う獨り言のやうに云つたが、涙がにじんで來るのを覺えて、警官たちの顏を見※したが、警官たちの目にもやはり一瞬間意味不明の異樣な閃めきが傳はつたやうに感じられた。",
              "citation": {
                "source": "不良兒",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が今日も尚多くの場合意味不明な訓読法の一つとして、漢文の訳読に残つた転の字の訓なのである。",
              "citation": {
                "source": "言語の用語例の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝船に書き添へた意味不明の廻文歌「ながき夜のとおの眠りの皆目覚め……」は一種の呪文である。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう見方も単に甚しく文学的な歴史観にすぎないのであるが、この地方ではこの意味不明の言葉も後世になって強いて日本語と結びつけようと試みられたことが多くその原形が甚だそこなわれたらしいのは残念だ。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の古老が採集したこの地の神楽歌の刷り物をもらってきたが、意味不明の言葉は土地土地で銘々勝手に変えてしまったような部分も多く原形の見当もつかないし、どれが正しいかも分らないと云う話であった。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、この意味不明の言葉が彼ら本来の言葉ではないかということは私の想像にすぎないのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "米友もまたぜひなくお角の面と坂とを見比べて、意味不分明に立ちつくしていました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、口々にたずねると、モンド公爵は、意味不明瞭な微かな微笑をもらしながら、「あはあ、ちょっと散歩」と、軽くうなずいてみせた。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前述拙著『牧野日本植物図鑑』せんじがんぴの文末「せんじゅハ其意味不明ナリ」を取り消し、今これを「野州日光山ノ中禅寺湖畔ナル千手崎ニ産スルヨリ云ヘリ」と訂正する。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて意味不明であつたが、ときどき「天國、天國！",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなりの距離を街路の「パンツ」（＊意味不明）から家に運ばれていた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうち13人は破壊的な熱（＊意味不明）によって途中で死亡し、その他の98人はマルセイユの検疫・軍病院に収容された。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は、当日あの塀をへだてて行なはれた半ば以上は意味不明の猛烈な悪口の交換や、河合の家の二階での出来事や、それに先だつ同じ性質の事件のことや、あの女中の一件やを、次々に思ひうかべ、反芻しながら、ああこれが天罰なのだと、身もだえした。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文章は意味不明なのであるが、実はこれは字謎であったのである。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "空たり間たり天然居士噫」と意味不明な語を連ねているところへ例のごとく迷亭が這入って来る。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "基房が事件に関わりのあるのは当然として、他の人々は、全く無実な意味不明の免官であり、追放であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はもうこれで失敬する」　と意味不明瞭なことを口走ると、そそくさと演壇を駆降り人垣を押分けて出て行ってしまった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本六十六国の国号が、大部分は意味不明になったのも、原因はあるいはそれであったかも知れぬ。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "地名の大多数がすでにその持主にすら、意味不明になっているという奇なる現象の他に、なお一つの日本の特色は地名が際限もなく豊富なことである。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんやその頃となるともう大部分の地名が、実は意味不可解になっていたのである。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
