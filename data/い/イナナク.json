        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "突然の雷鳴に、馬は驚いて激しく嘶いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "鞭を振るう騎手に応え、馬は闘志を燃やして嘶いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "荒野を駆ける馬の群れが、自由を謳歌するように一斉に嘶いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」十「とてもこの疲れようでは、坂を上るわけには行くまいと思ったが、ふと前途に、ヒイインと馬の嘶くのが谺して聞えた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背戸と思うあたりで再び馬の嘶く声。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその時、四五十歩を隔てた、夜店の賑かな中を、背後の方で、一声高く、馬の嘶くのが、往来の跫音を圧して近々と響いた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "處へ、忽ち、門外、から／＼と車の音、ヒヽンと馬の嘶く聲。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、ホテルは寂然として、遠くで馬の嘶くのが聞える。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿部街道を戻り馬が、遥に、ヒイインと嘶く声。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か黒山のような物に打付かって、斛斗を打って仰様に転ぶと、滝のような雨の中に、ひひんと馬の嘶く声。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」第十「到底も此の疲れやうでは、坂を上るわけには行くまいと思つたが、ふと前途に、ヒイヽンと馬の嘶くのが谺して聞えた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背戸と思ふあたりで再び馬の嘶く声。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときに、馬は嘶く、しらしらと、火の※の無花果に。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、絹川の土手にとりついた比には、※な樺色に燃えていた西の空が燻ったようになって、上流の方は微すらした霧がかかりどこかで馬の嘶く声がしていた。",
              "citation": {
                "source": "累物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　ろくろく睡りもせずに夜の明けるのを待ちかねていた新一は、往来で馬の嘶く声や人の話声がしだすと寝床を出て庖厨の戸を開けた。",
              "citation": {
                "source": "狐の手帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵は物言わず馬は舌を縛して嘶くを得ざらしめた。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の嘶く声と人声が家の周囲に湧きたって聞えた。",
              "citation": {
                "source": "胡氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妙なものを差し上げるようですが、ここの風の吹いた時に、あなたのそばで嘶くようにと思うからですよ」　と言った。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "精しい古語彙が眼前にないから確言は出来ぬが、独語にプファールデン（嘶く）てふ動詞があったと憶う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥か後に藤原広嗣が宰府で一声に七度嘶くを聞き尋ね、高直で買い取った馬は初め四の杭に登り立ち、数日後には四足を縮めて一の杭に立ち、よく主人を乗せ走りて毎日午前は筑紫午後は都で勤務せしめ、時の間に千五百里通うたという（『松浦廟宮本縁起』と『古今著聞集』第三十）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいわく小屋に小馬を入れ戸を闔して内に横を抜き嘶くと、近所の驢が来て鼻で懸金を揚げ小馬と二匹伴れて遊びに往った体、まるで花魁と遊客の懸落のようだったと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔神がここへ乗り捨てた馬が故郷を恋うて顧み嘶くのだそうで、その姿を見て農家が農事を候う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから注意して窺っていると、毎晩ではないが、三日に一度か五日に一度ぐらいずつは、家々の飼馬が一度に狂い立って嘶くのである。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも牛と馬との啼き声をひとつにしたように響き渡って、それが二、三度も高く嘶くと、家々に繋がれているたくさんの馬はそれに応えるのか、あるいはそれを恐れるのか、一度に嘶いて狂い騒ぐのである。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "続けて啼けば、その声をしるべに尋ね寄ることも出来るのであるが、その嘶くような吠えるような声は、最初から終りまで僅かに三声か四声である。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて嘶くのか、吠えるのか、唸るのか、得体のわからない一種の叫びが闇をゆするように高くひびいた。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで背の上の主人共々、心地よげに水を浴びていた黒鹿毛が、突然高くふた声三声｜嘶くと、背に若者を乗せたまま、抑え切れぬ感興をでも覚えたかのように、さッと岸辺に躍り上がりながら、今し街道を東へ駈けぬけようとしている旅の二騎目ざして、まっしぐらに挑みかかりました。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）　今の思想界に於ける創造的勢力　つら／＼今の思想界を見廻せば、創造的勢力は未だ其の弦を張つて箭を交ふに至らず、却つて過去の勢力と、外来の勢力とが、勢を較して、陣前馬｜頻りに嘶くの声を聞く、戦士の意気甚だ昂揚して、而して民衆は就く所を失へるが如き観なきにあらず。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇める駒の嘶くと思へば夢はふと覺めぬ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇める駒の嘶くと思へば夢はふと覚めぬ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "頻と耳を振って、露深い秋草を踏散して、嘶く声の男らしさ。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庭でいななく馬、蹄の音、それから人の叫び聲。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬高くいななくを聞きぬ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
