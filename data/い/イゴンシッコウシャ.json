        "examples": {
          "standard": [
            {
              "text": "遺言書には、弁護士が遺言執行者として指定されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遺言執行者は、被相続人の財産の管理と処分を行う権限を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私が遺言執行者を務めさせていただきます。」と、彼は厳かに引き受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遺言執行者が選任されたことで、相続手続きは滞りなく進行した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "未成年者は、遺言執行者になることができないと法律で定められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "故人の遺志を尊重し、遺言執行者は遺産の分割協議に立ち会った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "言うなれば」「『ウィリアムズ遺言執行者』ですか」　カーバー所長が、やや躊躇して、「ちがう。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
