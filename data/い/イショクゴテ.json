    "definitions": [
      {
        "index": 1,
        "gloss": "small shovel or trowel used in gardening",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "苗をポットからプランターに移す際、根を傷めないよう移植ごてで丁寧に土を掬い上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、その移植ごてを使って、パンジーの苗を等間隔に植えてごらん」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "園芸用品店には、軽量なプラスチック製から耐久性の高いステンレス製まで、多種多様な移植ごてが揃っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "使い終わった移植ごては、水洗いで土を落とした後にしっかりと乾かすのが長持ちさせるコツだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狭い場所やプランターでの細かな作業には、小回りの利く細身の移植ごてが重宝する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわあ、この移植ごて、人間工学に基づいた設計のおかげで全然手が疲れないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "頑固な雑草を抜くときは、移植ごての先を土に深く差し込み、根元から一気に掘り起こすとよい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
