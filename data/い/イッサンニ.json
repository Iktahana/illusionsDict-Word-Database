[
  {
    "uuid": "f4f37bae-1be4-5bc9-a1b2-2321ff9cfd0c",
    "entry": "一散に",
    "reading": {
      "primary": "いっさんに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
