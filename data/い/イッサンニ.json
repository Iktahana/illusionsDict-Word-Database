    },
    "definitions": [
      {
        "index": 1,
        "gloss": "at top speed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "飼い主の姿が見えると、犬は一散に駆け寄ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゴールめがけて選手たちは一散に走り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "授業の終了を告げるチャイムが鳴ると、子供たちは一散に校庭へ飛び出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして急に背中を向けると、そのまま一散に逃げてしまつた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はかかえていた女の帯を池へ投げ込んで、暗い夜路を一散に逃げ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蝶は狐が落ちた人のようにぼんやりと突っ立っていたが、急にまた何だか怖くなって一散にかけ出して、家へ駈け込んで母の顔を見るまでは、彼女もまだ半分は夢のような心持であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "」音は続き、それからバァッと表の方が鳴って何か石ころのやうなものが一散に降って来たやうすです。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず飛上って総身を震いながらこの大枝の下を一散にかけぬけて、走りながらまず心覚えの奴だけは夢中でもぎ取った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻抜けのように立っていた、私が魂は身に戻った、そなたを拝むと斉しく、杖をかい込み、小笠を傾け、踵を返すと慌しく一散に駈け下りたが、里に着いた時分に山は驟雨、親仁が婦人に齎らした鯉もこのために活きて孤家に着いたろうと思う大雨であった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」音は続き、それからバァッと表の方が鳴って何か石ころのようなものが一散に降って来たようすです。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから炭坑のトロ道が作る黒い投影の中を一散に走って、直方駅構内の貨物車の間を影のようにスリ抜けて、ほど近い日吉町の日吉旅館の裏手に来た青年は、素早く前後を見まわして、警戒のないのを見定めてから蔦蔓の一パイに茂り絡んだ煉瓦塀をヒラリと飛越えた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ありや、と威勢よく頭突に屈んで、鼻息をふツと吹き、一散に黒く成つてがら／＼と月夜を駈出す。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」　一散に遁げもならず、立停まった渠は、馬の尾に油を塗って置いて、鷲掴みの掌を辷り抜けなんだを口惜く思ったろう。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂山を慌しく一文字に駈けて、こなたが近いた時、どうしたのか、脱ぎ捨てた袴、着物、脚絆、海草の乾びた状の、あらゆる記念と一緒に、太鼓も泥草鞋も一まとめに引かかえて、大きな渠は、砂煙を上げて町の方へ一散に遁げたのである。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、北守将軍｜仙人となる　さてソンバーユー将軍は、ポー先生の玄関を、光のやうに飛び出して、となりのリンプー病院を、はやてのごとく通り過ぎ、次のリンパー病院を、斜めに見ながらもう一散に、さつきの坂をかけ下りる。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時こそ三十六計の奥の手を出して一散に駆け出し、危うく吾妻川の河底へ生埋めになる急場を辛くも通り過ぎ、四人相顧みて工夫の猛悪なるに驚ろく。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾等が其家に近づいた時、日出雄少年を肩にした武村兵曹は一散に走つて行つて、快活な聲で叫んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、私の膝から跳つて、犬の首輪に手をかけて、一散に磯打つ浪の方へ走り出した。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はいくつもの沼ばたけをどんどんどんどんうしろへ送りながら、もう一散に走りました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車は列になって山のすそを一散にサンムトリの市に走りました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一散に駈けて来て、黙って小屋の前を通ろうとする。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに分秒電火の働き、一散に下階へ駈下りて、先刻忍びし勝手口より、衝と門内に遁れ出づれば、米利堅産種の巨犬一頭、泰助の姿を見て、凄まじく吠え出せり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は一散に引返して、垣を潜りて出でたる外には、提灯提げて彳む女。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ときめつけられて詮方なく一散に駈け出し、口の裡で、「御自分が独身だと思って、ちとお焼芋の方だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……後で知れたがそれは一散に遁げた、と言う。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と云う声がうしろへ、ぱっと吹飛ばされる風に向って、砂塵の中へ、や、躍込むようにして一散に駈けて返った。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞食同様の男に二十銭札はちと多過ぎると思ったが、いわるるままに札を掴んでその店先へ駈けて行き、男の前に置くや否や一散に駈出して来た。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は勝つに乗って、続けさまに燐寸を擦ると、敵は既う此方を向く勇気が失せたらしく、頭を回らして一散に逃げ出した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてボンド街で二輪馬車を拾うと、夜更けの街を一散に疾駆させた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸子は裏木戸を開けて、僕の隠れている松林へ向って一散に走って来た。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "落着いて歩いてゐられなくツて、とう／＼すたこら駈出して、一散に走ツて行くと、幾ら行ツても村道へ出ない。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木の路を一散に走って行ったので、そこの街角を注意深く曲って眺めた時、私はそんなに骨を折る程でもなく、姉の一きわ目立ってみじめな痩せた肩をば、見出すことが出来た。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり妹は、くるりとこちらに向き直って一散に駈けた。",
              "citation": {
                "source": "律子と貞子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
