    "definitions": [
      {
        "index": 1,
        "gloss": "(flash of) lightning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
