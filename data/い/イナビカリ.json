        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遠くの山並みを一瞬白く照らし出す稲光に、夏の訪れを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の激しい稲光に、子供たちは「わあっ！」と声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雷鳴の直前に走る稲光は、自然の驚異を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "稲光が二｜度ばかり、かすかに白くひらめきました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時としては天の真上で稲光がしてやはり音の聞えぬ事がある、これはブラシ放電と名づける現象で、この時の光の色を分析してみると普通の電光とちがう事が分る。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南のずうっと向ふの方は、白い雲か霧かがかかり、稲光りが月あかりの中をたびたび白く渡ります。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その稲光りのそらぞらしい明りの中で、ガドルフは巨きなまっ黒な家が、道の左側に建っているのを見ました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ突きあたりの大きな室は、たしか階段室らしく、射し込む稲光りが見せたのでした。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その稲光りの硝子窓から、たしかに何か白いものが五つか六つ、だまってこっちをのぞいていました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして全くその通り稲光りがまた新らしく落ちて来たときその気の毒ないちばん丈の高い花が、あまりの白い興奮に、とうとう自分を傷つけて、きらきら顫うしのぶぐさの上に、だまって横わるのを見たのです。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大音あげ、追掛しが忽ちに雲起り、真闇になり、大雨降出し、稲光烈しく、大風吹くが如くなる音して座頭はいづくに行しやらむ――と言ふのである。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲光が二度ばかり、かすかに白くひらめきました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲光りが二度ばかり、かすかに白くひらめきました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南のずうっと向うの方は、白い雲か霧かがかかり、稲光りが月あかりの中をたびたび白く渡ります。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが貴方、着物も顔も手足も、稲光を浴びたように、蒼然で判然と見えました。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまに我や旅行き、行きなづみ振りさけ見れば、妻と来てつつしみ仰げば、あなかしこ照る日もわかず、暮れゆけば雲巻き蔽ひ、霹靂はためくさへに、稲光｜青の火柱、火ばしらの飛ぶ火のただち、また、とどろ雹ぞ飛びたる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまに我や旅行き、行きなづみ振さけ見れば、妻と来てつつしみ仰げば、あなかしこ照る日もわかず、暮れゆけば雲巻き蔽ひ、霹靂はためくさへに、稲光｜青の火柱、火ばしらの飛ぶ火のただち、また、とどろ雹ぞ飛びたる。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうしきりなし稲光がして、かみなりがごろごろ、ひと晩じゅうやめないつもりらしく、鳴りつづけました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、人魚のむすめは、へいきで、ちかちか光る氷の山の上に腰をのせたまま、かがやく海の上に、いなづま形に射かける稲光の青い色をながめていました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんな話を聞いてゐても村瀬は、話してゐる人達は話すそばから忘れてゐるやうな恬淡さなのに、それらの一言毎にジクザクな稲光りで胸を打たれるやうな痛さを覚えたりするのであつた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "折も折、稲光りがぴかぴか光ってそれは幽霊のようにおののいて見えた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "六｜人の武士が縁側に上がって待っていますと、やがて雷や稲光がしきりに起こって、大風のうなるような音がしはじめました。",
              "citation": {
                "source": "大江山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "にわかにひどい大あらしになって、稲光がぴかぴか光って、ごろごろ雷が鳴り出しました。",
              "citation": {
                "source": "瘤とり",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき西の空で白いような稲光りがしています。",
              "citation": {
                "source": "蛙",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき西の空で白いやうな稲光りがしてゐます。",
              "citation": {
                "source": "蛙",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちあがって雨戸を開けると、遠くで時々稲光りがしている。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーテンのない窓は、時々稲光りで明るく、ざあつと板戸や硝子に吹きつける雨が、波のやうな音をたてた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に眼からちょっと稲光りがさした。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖の空を裂いていた稲光がだんだん激しくなり、海の底を割ってくるような雷鳴が窓ガラスをびりびり震わせた。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の中でぴかりと、稲光が光った。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮どきなど、南の方でしきりなしに稲光りがする。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなびかりは、まるでこんな憐れな旅のものなどを漂白してしまいそう、並木の青い葉がむしゃくしゃにむしられて、雨のつぶと一緒に堅いみちを叩き、枝までがガリガリ引き裂かれて降りかかりました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石と石とを空でぶっつけ合せてぐらぐらする紫のいなびかりを起せ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
