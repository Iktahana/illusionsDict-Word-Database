    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unable to stay (on)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自分の不用意な発言で場の空気が凍りつき、その場にいるのが居た堪らなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "懸命に努力した部下が報われない結果に終わり、上司として居た堪らない思いがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事故のニュース映像を見て、犠牲者の遺族の心中を察すると居た堪らない気持ちになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分が招いたミスで周囲に多大な迷惑をかけてしまい、申し訳なさで居た堪らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんなに大勢の前で叱責されている彼を見ていたら、こっちまで居た堪らなくなって席を立ったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "盛大な送別会を開いてもらったが、不本意な形で去る身としてはかえって居た堪らなさを感じてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "満員電車の中で赤ん坊が泣き止まず、周囲の視線を過剰に気にする母親の姿は、見ていて居た堪らないものがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "とても、いたたまらない気がするのである。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "圧迫が刻一刻と加わって来て、いたたまらない気持である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台で、私の着ている青い衣裳を、ずたずた千切り裂きたいほど、不安で、いたたまらない思いでございました。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「………」僕はいたたまらないで二階を下りて来た。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "市九郎は、二人を殺してしまうと、急に人を殺した恐怖を感じて、一刻もいたたまらないように思った。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まてっ」　いたたまらないように立ちあがると、荒々しい足音を残し乍ら、新兵衛もあとを追っていった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたたまらないもののごとくこそこそと逃げていったあばたの敬四郎のうしろ姿を笑止げに見送りながら、そのいましめをぷっきりほどいてやると、物静かにいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもうここにもいたたまらない。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんな空想が、ふと頭の中に、一｜片の雲のごとく浮かぶと、急にいたたまらないようにさびしくなりました。",
              "citation": {
                "source": "青い星の国へ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見たとき、さすがに、ぼくは、世間には、こんな生活もあるのかと考えられて、なんとなくいたたまらない気持ちがしました。",
              "citation": {
                "source": "緑色の時計",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう呼吸が塞りそうで、たった一ン日もいたたまらない気がしだしたのだった。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "金三郎も万和の家内と一緒に寺へ行きましたが、どうにも涙が出ていたたまらない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "金鳳釵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらその女いたたまらないで東京へ働きに出たのですが、身重になっていることが段々わかって来て、今かえっているのだそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はなお座にいたたまらない気がして、ふいと起って台所へゆき御飯蒸の蓋を取り、芋に箸を突きさしてみたが、まだ固い。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
