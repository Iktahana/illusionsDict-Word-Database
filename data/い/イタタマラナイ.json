    "entry": "居た堪らない",
    "reading": {
      "primary": "いたたまらない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
      "ctype": null,
