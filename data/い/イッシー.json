        "examples": {
          "standard": [
            {
              "text": "鹿児島県の池田湖には、イッシーというUMAがいると噂されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、イッシーの目撃談を聞いて目を輝かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねえ、お父さん、本当にイッシーって湖にいるの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」驢馬屋に賃金をきめて、彼らはヴァンヴとイッシーとの道から戻ってきた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがイッシーでおもしろいことがあった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリーにいるエークスのクーグールド派の者らは当時、イッシーの野原の、そこいらにたくさんある廃れたる石坑の一つの中で集合を催していた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
