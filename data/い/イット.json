              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしよく解った後では、全く子供のように正直一途で、子供のように純情無比の人であったと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきのことばと言へ、今の笑ひ声と言ひ明らかに自分を侮辱してると彼は一途に思ひつめた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬はかくて痩せ細り夏に雨を得て肉附くことを繰返しながら、瞳は一途にあえかなるものに向って求めているのだと土民はいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら何度やっても同じことなのだ」　仕事であれ、男女の間柄であれ、混り気のない没頭した一途な姿を見たいと思う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一途に悔いていればいい。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "お徳は自分の亭主の云うことを一途に信じて、為さんも夜釣りの仲間であると申し立てているものの、実はふたりが連れ立って出るところを一度も見たことはないのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂吉どのも、たゞ一途に聴聞の志ぢゃげなで、これからさっそく講ずるといたさう。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂吉どのも、ただ一途に聴聞の志じゃげなで、これからさっそく講ずるといたそう。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橘屋の娘の慧鶴に対する恋は、ただ縋りつきたい、いのちを引立てて貰いたい、一途であった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えることは悟りということ、不滅の肉身を獲ること、この一途だった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどうしても決心を新にして少しでも繋縛の気のあるところは早速に避け退き、ひたすら求道の一途に奔らねばならない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は折角、寝ても覚めても思索一途に嵌り込めるようになった心境の鍛錬を俗人との世間咄しに乱されてしまうのは惜しくて堪らなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲望を整頓し心を端然と正して一途に自分の方向に行かなければならないことはもちろんでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら何度やっても同じことなのだ」　仕事であれ、男女の間柄であれ、湿り気のない没頭した一途な姿を見たいと思う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一途中相果てたなれば、金子はそのままそちに遣わす。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあ、こいつはきっと泥棒だ、そうでなければにせ金使い、しかし何でもかまわない、万一途中相果てたなれば、金はごろりとこっちのものと、六平はひとりで考えて、それからほくほくするのを無理にかくして申しました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとひ膚身は汚さずとも、夫の目に觸れた、と云ひ、恥しいのと、口惜いのと、淺ましいので、かツと一途に取逆上せて、お艷は其の日、兩親たち、夫のまだ歸らぬ内に、扱帶にさがつて、袖はしぼんだ。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後の事情から考えると、一途に駈落ちとも決められず、さりとて怪談も疑わしく、みんなもその判断に迷ってしまったのです。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "平助と又蔵は無論にその不調法をきびしく叱られたが、主人は物の分かった人であるので、この不調法の家来どもに対して一途にひどい成敗を加えようとはしなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠義一途の用人は、きのう中にすこしは何かの手がかりは付いたかと問い合わせに来たのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――小郷が殺された時間には、鶴雄はおれと一緒に歩いていたのだ」　小田はこのことに気がつかず、一途に鶴雄が犯人ではないかと、疑っていた自分の間抜けさ加減に苦笑した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは……」　信ずるのかと言われてみると、一途に信じこんでいたことが分る。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇蹟はあらわれず、勝とうと思えば勝てた筈だという彼のいいわけも和尚の大人気ない毒舌にかゝって一笑に附されてしまうと、一途に残念がった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んど天上なるものへの思慕の如く一途に汚れなきこの恋の精進を、みにくい悪魔の誘惑に邪げられることが堪えられなかった。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに一途だった人間の愛情がそう簡単に亡びてしまうわけはないのだからね。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一旦兄さんがつまらない心を起して返り討ちにあつてから、落魄の一途を辿りはじめた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう一途に思ひつめては事を仕損じますぢや。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう一途にいふもんでない。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "画は彼が最得意とするところで、ひょっとしたら、これ一途に身を立てて行こうかとさえ思うときがあった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の學校ぎらひはその頃になつて、いつそうひどかつたのであるが、何かに追はれてゐる私は、それでも一途に勉強してゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
