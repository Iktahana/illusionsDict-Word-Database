            }
          ],
          "literary": [
            {
              "text": "ようござんすかい、くれぐれもいっておきますが、二兎を追う者は一兎を得ずだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に可哀想だ……」南西太平洋軍総司令官「二兎を追う者は一兎をも得ずだ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二兎を追へば一兎をも得ずで兩方とも半噛りになつてしまふ。",
              "citation": {
                "source": "貝殼追放",
                "author": "愚者の鼻息",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の事情から推して、この上、君と子供とを身辺において、しかも研究に没頭することは、二兎を追うて一兎を得ざる結果になるおそれが十分にあります。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二兎を追うものは一兎をも得ずの諺の如く沢山の支店を持つ人の例をみましても、多くは不結果に終るようであります。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりロシアのことわざでいう『二兎を逐うものは一兎をも得ず』というあれですな。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "両兎を追うもの一兎を得ず、逸早く、金吾はきびすを巡らして前の所へ戻って来ましたが、もうその時は万太郎の方も、優形の覆面を取逃がして、地団駄を踏んでいるあとでありました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛ぶんだぞ霧の中をきいっとふっとんでやるんだなどと頭の奥で叫んでゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶次郎がぽいっとおじぎをしましたから私もしました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお松は五ツにもなった自分を一日おぶって歩いて、何から何まで出来るだけの世話をすると、其頃もう随分ないたずら盛りな自分が、じいっとしてお松におぶされ、お松のするままになっていたそうである。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供はおいしいと云うのが、きまり悪いので、ただ、にいっと笑って、母の顔を見上げた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいっと向うを見て、真直に立っていろ、と云ったのであった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらにいた看護卒も軍医の言葉を疑うものゝのようにじいっとしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のキタないところはまるで棚にあげて人が集って話をして居っても、あんまり口を出さずに、じいっとうしろの方から、人のアラをさがして見て居るような奴だ。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤牛は、じいっと鞍を背負って子供を見守るように立っていた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、じいっと、窓を見上げていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ばあさんは、じいっと船方を注視して話をきいた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び中隊長は、じいっとその男を睨みつけた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がじいっと耳を澄ますと、納屋で蓆や空俵を置き換えている気配がした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうほんとうにだめなやつだ、はなしにもなんにもなったもんじゃない、と私がぷいっと歩き出そうとしたときでした。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一言も云わないでじいっと立って居ったのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　畜産の教師は鋭い目で、もう一遍じいっと豚を見てから、それから室を出て行った。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はながい間じいっと眼を放さずにその窓を見ているのです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄の鶴が向うの方で立ち止まって長い鉄の頸をねじ向けてじいっと私の顔を見つめていた。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "衰弱には、いっとうええ。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雪童子はわらいながら、手にもっていたやどりぎの枝を、ぷいっとこどもになげつけました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男はあんまり困ってしまって、もう呑んで遁げてしまおうとおもって、いきなりぷいっとその薬をのみました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで小さな柏の木が、一本ひょいっと環のなかから飛びだして大王に礼をしました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながら、野鼠はぷいっと行ってしまったのでした。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』なんて遠くから呼びますのに、それが頬白で自分よりもひはのことをよく思ってゐると考へて、憤ってぷいっと横へ外れたりするのでした。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
