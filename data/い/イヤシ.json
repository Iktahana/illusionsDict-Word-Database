    "definitions": [
      {
        "index": 1,
        "gloss": "healing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それよりも、おとなしく『合意雇止め』にしてやるから、ボーレンで一ヵ月も休んで、傷を癒してから後の事は、又俺でも世話をしてやるからな。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命もどうかと気遣われたが幸いに快癒したので今度は Rev. G. T. Warner の学校に入ってそこで四年間の修業をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに治癒したが、急に年を取ったように見えた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び負傷すると、またそれを癒して、又追いかえすだろう。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふくろの病気は唯一度の祈祷で平癒したのに、息子の病気、しかも差し当ってはどうということもない病気が、幾日の祈祷を頼んでも去らないのはどういうわけであろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しばらくしてとうとう「そいじゃ、癒してあげよう」と言った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その恢復力を医者が取出してそれを使って病気を癒してくれます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "虐殺にして腹癒して、そうして下枝の傍に高田の死骸を僵して置く。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ままよ、癪の虫を揉殺して立処に癒してやる、まんざら嘘でもないようだ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊廟の土の瘧を落し、秘符の威徳の鬼を追うよう、たちどころに坊主の虫歯を癒したはさることながら、路々も悪臭さの消えないばかりか、口中の臭気は、次第に持つ手を伝って、袖にも移りそうに思われる。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、明日子は石油が結核に効くなどとは医学的に説明されていない以上、迷信に過ぎないと轡川に反撥したので、ぼくは明日子が医者の妻であったことを思い出して、仲々面白いと見ていると、轡川は女中に婦人雑誌を持って来さし、「石油で結核を癒した実話」の載っている頁をぼくらに見せた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五里霧中で、そうして時たま、虎の尾を踏む失敗をして、ひどい痛手を負い、それがまた、男性から受ける笞とちがって、内出血みたいに極度に不快に内攻して、なかなか治癒し難い傷でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "癒し難い寂しい気持ちが、私の心を占める。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちからいつても早く夫の性分のマニアを癒して、家庭的の常識人になつて貰ふことは一家の浮沈にも係る大事であつた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貪食を爲しては胃病を患ひ、藥力を假りて病を癒しては、復貪食して病みつゝ、永く自己の胃弱を歎じて恨むが如き人も世には甚だ少くは無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ人共に、何をもってしても癒し難い無限に続く人生の哀音なるものが僕の弛緩した精神の鎧の合せ目から浸み込むためか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お京さんはよく迷う女だ、斯ういう軒並を見せたら歯を癒して貰いに歯医者へ寄ってから練習所へ行こうかダンスの練習をすましてから歯医者にしようか。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かもめ――ドーヴィルから適当な距離のオンフルール海岸は、ドーヴィル賭博人の敗北の深傷や遊楽者達の激しい日夜の享楽から受ける炎症を癒しに行く静涼な土地だ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆が死ねば順平は行きどころが無いゆえ継母のいる家へ帰らねばならず、今にして寝小便を癒して置かねば所詮いじめられる。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、眠れたことより、あれほど怖れていた注射が自分で出来て、しかも針の痛さも案外すくなかったことの方がうれしく、その後｜脚気になった時もメタボリンを打って自分で癒してしまった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、眠れたことより、あれほど怖れていた注射が自分で出来て、しかも針の痛さも案外すくなかったことの方がうれしく、その後脚気になった時もメタボリンを打って自分で癒してしまった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずその悪い病気を癒してしまった上でなければ、どうにもならない。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　僕はその夕がた、あたまの労れを癒しに、井筒屋へ行った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は、前川氏を意地悪く、真綿で首を締めるような苛め方をして、つまり精神的にサジズムによって、その不満を癒しているような傾向があった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「病気だよ、お前さん、病気だから、そんなことを云ふんだよ、早く病気を癒しておくれ、」「まだ、そんなことを云ふか、この怪物、殺してしまうぞ、」　一層殺して貰ふた方が好い死んでしまへばこんな苦しいこともない。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殺されても好いよ、私は殺されても好いが、お前さんの病気が心配だ、早く癒しておくれよ、お金は私がどうでもする、」「この怪物、本当に殺してしまふぞ、」　男はまた飛び起きてしまつた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやしくもその詩興を損い、趣味を害するようなものは――人でも、家具でも、物音でも――絶対にその家庭に入れなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人の如きは、古來から象形文字を使用し、言語が文字に書かれた場合の、視覺上の表象效果を重視したが、しかもその支那人でさへ、發音の場合は韻の四聲法を嚴重にし、異語同音の混錯を避け、いやしくも耳で聽いて語義の解らないやうな不便な國語は、決して使用しなかつたのである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとこのお爺さんの人品骨柄は、いやしく無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どだい、男らしくないぢやないか、と子供でも、また大人でも、いやしくも正義にあこがれてゐる人間ならば、誰でもこれに就いてはいささか不快の情を覺えるのではあるまいか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
