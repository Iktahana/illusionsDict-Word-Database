    "definitions": [
      {
        "index": 1,
        "gloss": "snoring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "隣の部屋から、大きないびきが聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は疲れているのか、いびきがひどかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "いびき防止のグッズを試してみることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」などと、ひどくはしやいで、そのうちに、すうすう小さい鼾をかいて寢てしまつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの、この、男らしさには、まゐらぬ女もあるまいて、ああ、食つた、眠くなつた、どれ一眠り、などと全く氣をゆるしてわがままいつぱいに振舞ひ、ぐうぐう大鼾を掻いて寢てしまつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一人連れていてその癖、網棚から首なんぞ吊るしやがって、横柄な顔をして大鼾で寝てやがる。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍で寝ている酒気を帯びた父の鼾が喉にからまって苦しそうだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べちらされたトーストと玉子の殻と、鼾をかいて寝ている彼女の黄色い鼻がオレンヂ色に染められていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は相かわらず鼾をかいて寝ているマリが、時々うるさそうに鼾をかくのをみた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、大切なところで彼女は東洋の霊のような鼾をかいて寝てしまうのだが、私は彼女の肉体に金羊毛酒場の女としてふさわしくないところがあるのに気付くのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然障子があいたやうな氣がしたかと思ふと紋着羽織に袴をつけた抱月さんが、例の朝鮮髭をはやした頬のこけた、思索家的な奧深い光を持つ細い眼をした顏を靜かにその間から現して、どう云ふ譯だか何の詞もなく、蒲團の袖に鼾つくやうにして丁寧に頭をさげた。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気持の鼾が、かすかにもれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の鼾声や、犬の吠えるのがきこえる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒磯――　左斜の其の茶の外套氏の鼾にも黒気が立つた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "純次はすぐ鼾になっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をさましてみると、母は背面向きになってはいるが、自分のすぐ側に、安らかな鼾を小さくかきながら寝入っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまさかに木の葉の落ちる音と、遠い川音とのほかには、純次の鼾がいぎたなく聞こえるばかりだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎が有難い事を云ったってかんかん虫手合いは鼾をかくばかりで全然補足になら無えってんで、工場長開けた事を思いつきやがった、女ならよかろうてんだとよ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話柄が途切れて閑とすると、暑さが身に沁みて、かんかん日のあたる胴の間に、折り重なっていぎたなく寝そべった労働者の鼾が聞こえた。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸棚の側には哲が小掻巻にくるまつて、小さな鼾をかいて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "登三はをかしな調子でねんねこ唄のやうな鼻唄を歌つてゐたが、がり／＼と虻の刺したあとを掻きながら、これもやがて鼾になつてしまつた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたはきっと何とかなるよ」　それから世間で聞いて来た面白い話や、とても景気のいい私たちの未来の空想話をして、床に入ると思うと、いい気持ちそうに直ぐに鼾をかきました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで気の付いたことは船客中一人、慧鶴だけが騒ぎを知らずにまだ眠りつづけて大｜鼾を掻いていたことだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂から上がり、姿見に向かい三人相顧みて、「随分黒くなったなあ」　この夜、吉岡髯将軍ビール二杯呑んだところが早速酔っ払ってしまい、自分から注文した名物の羊羹が来たのも知らずに、鼾声雷のごとくグーグームニャムニャ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の疲もあり、蒸々する晩でもあり、不寝番の控室てはとろとろと仮寝の鼾も出ようと云ふ真夜中に、けたゝましいもの音、やにはに飛出した囚人。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と他愛の無きこといい寝入に前後も知らず早や鼾。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は走る、口は辷る、凪はよし、大話しをし草臥れ、嘉吉めは胴の間の横木を枕に、踏反返って、ぐうぐう高鼾になったげにござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地虫のような鼾を立てつつ、大崩壊に差懸ると、海が変って、太平洋を煽る風に、提灯の蝋が倒れて、めらめらと燃えついた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、そんな時刻、そこには鼠は走り廻っても、猫の子一匹もいない筈だのに、時ならぬ、場違いの鼾が聴えて来たとすれば、もはや無意味ではあるまい。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼾は公演場の休憩室の隅にあるソファから聴えていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすかな鼾の声さえ聞える。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔うて戻つて熟睡、大鼾であたりをなやましたらしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りに言葉｜訛り奇妙なる二人連れの饒舌もいびきの音に変って、向うのせなあが追分を歌い始むれば甲板に誰れの持て来たものか轡虫の鳴き出したるなど面白し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
