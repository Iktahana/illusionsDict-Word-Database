    "definitions": [
      {
        "index": 1,
        "gloss": "an inch ahead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "濃霧のせいで車のハイビームを点けても、一寸先すら見えない状況だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、一寸先で誰か転んだぞ！足元が暗いから気をつけろ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒から離れた山奥の夜道は、一寸先も分からないほどの静寂と闇に包まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "沖で暴風でも吃ッた時には、一寸先は闇だ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間にも恐らく眼に見えない運命の頸環が附いているのであろうが、人も知らず、我も知らず、いわゆる「一寸先は闇」の世を、何れも面白そうに飛び廻っているのである。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に川中島は前夜細雨があったためか、一寸先もわからぬ濃霧である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に濃霧（川中島の名物）が深く立ちこめて一寸先もみえない。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は曇天で一寸先も見えぬ闇黒は全部を蔽うて居た。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしその意味に従えば、……一寸先へも出られぬのである。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸先は闇の心地で、殆んど夢路たどる思ひである。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸先も見えなくなつたのです。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子窓から、霧の戸外を覗いて見ると、一寸先も見えない。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車を待つ餘裕あるにつれて、傘を買ふか、買ふまいかと思案し、遂に買ふと決心して、番傘を買ひたるが、果敢なや、人間の智慧の一寸先は闇、馬車未だ沼田に著かざる前に、天氣は快晴となりたり。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくみはそれから少し歩いて賑やかな通りへ出て、勝手で使ふ胡椒や、自分の白粉下のクリームや、針や絹糸なぞの買物をして、序に一寸先まで行つて乗換へのない電車に乗つた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼はお君を一寸先きに行って貰って、服のポケットを全部調べた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の眼覚めた時には、既に炎々たる火が全室に満ち渡つて、黒煙が一寸先も見えぬ程に這つて居た。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、　　　卯の花の絶間敲かん闇の門　　　　　　　去来　闇夜に人の門を叩かんとするに、一寸先は闇うしていづくを門とも定めがたし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間というものは、どんなに偉くても一寸先も見えるものではない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辺りを見まわしてみたが、もう真暗で、一寸先きも見えないくらいである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだそのころは春だったが、二人の気持ちの初めて通じ合ったのは夜のその森の中のことで、それまでは矢代は千鶴子に物いうにも久慈に気兼ねを要したのに、真暗な森の中の道に迷ったのが二人の縁の初めとなり、一寸先も見えぬ闇の中を二人は手を引き合いつつ、湖のボートの傍まで出たのである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸先も見えないやうな、暗い谷添ひのレールを、カンテラの灯が、すいすいと流れて行く。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の運命一寸先だよ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台監督兼主役の吾輩からして一寸先は真暗闇だ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "余寒の氷が去りやらぬ二月半の夜更け、空はカラリと晴れて蒼白い星が所在なげに瞬いていたが、物蔭は一寸先も見えない闇だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「所が杉江さん、人の世の回り舞台なんてものは、全く一寸先が判らないものでね。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は明けたが濃霧が煙幕のごとくとざして、一寸先も見えない、むろん陸地の影など、見分くべくもない。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸先きへ行くのが淋しい氣がする。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸先は闇、見えるものは生きてゐる自分の肉体だけであつてみれば、その肉体にまつはりつく一ヶ年の垢を眺めて見るのは、めでたくも切ない気持に相違なからう。",
              "citation": {
                "source": "一九三六年回顧",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸先も見えない闇であった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と言つても一寸先も見えない暗夜で、畑の小径は平常無事に通れたことが不思議なぐらゐデコボコである。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "と※子が止めても、「だめよ、一寸先生の所へ来た次手によったんですもの。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、世の中は一寸先は闇である。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
