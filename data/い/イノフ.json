[
  {
    "uuid": "0a9730bd-b64b-5c2e-873b-a3dfc8685d4d",
    "entry": "胃の腑",
    "reading": {
      "primary": "いのふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
