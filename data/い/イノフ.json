    "definitions": [
      {
        "index": 1,
        "gloss": "stomach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "激辛カレーを一口食べた瞬間、熱い塊が食道を通り抜け、胃の腑に落ちていくのがはっきりと分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年の苦労が報われたという知らせを聞き、ようやく胃の腑のあたりに溜まっていた重苦しさが消えていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は冷えたビールを一気に流し込み、「ああ、胃の腑に染み渡るなあ」と満足げに独り言を漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして選択してる内には自分で自分の胃の腑を洗濯してしまうことになるんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間ばかり外米混入の飯を食いつづけた後、一日だけまぜものなしの内地米に戻ると、はじめて本当に身につくものを食った感じで、その身につくものが快よく胃の腑から直ちに血管にめぐって行くようで、子供らは、なんばいもなんばいも茶碗を出すのである。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃の腑の適当な充血と消化液の分泌、それから眼底網膜に映ずる適当な光像の刺激の系列、そんなものの複合作用から生じた一種特別な刺激が大脳に伝わって、そこでこうした特殊の幻覚を起こすのではないかと想像される。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「胃の腑」と「詩」との間にはまだだれも知らないような複雑微妙の多様な関係がかくされているのではないかと思われる。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃の腑はまたこの店の古典味をまで味うとする。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "差当り、出家の物語について、何んの思慮もなく、批評も出来ず、感想も陳べられなかったので、言われた事、話されただけを、不残鵜呑みにして、天窓から詰込んで、胸が膨れるまでになったから、独り静に歩行きながら、消化して胃の腑に落ちつけようと思ったから。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺と胃の腑は同じでない。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "クねずみはだんだん四方の足から食われて行って、とうとうおしまいに四ひきの子猫は、クねずみの胃の腑のところで頭をコツンとぶっつけました。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼酎と胡瓜は尽く吐き出したが、同時に食った牛肉は不思議にも出て参らず、胃の腑もなかなか都合好く出来たものかな。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は胃の腑も強壯な筈だから、ウンと堪能するさ。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "況して其の筋肉を原形のまゝで、筋肉と混同になツて、白い骨を見たり、動脈を見たり靜脈を見たり、また胃の腑の實體や膓のうじや／＼したところを見ては、奈何に氣強い者でも一種嫌惡の情に打たれずに居られない。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肉は決して胃の腑の要求ばかりじやない。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵粮は嫌でも他から仰がなければならぬのであるから、大概の者は頭と腕だけが膨大になつて、胃の腑が萎縮する。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しおかづは手輕だ、葡萄豆と紫蘇卷と燒海苔と鹿菜と蜊貝のお汁………品は多いが、一ツとして胃の腑の充たすに足りるやうな物はない。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "雖然周三は、其れにすら何等の不滿を感ぜず、舌と胃の腑の欲望を充すよりも、寧ろ胸に饒かな興趣の湧くのを以つて滿足した。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "処女マリアの彫像の眼は駝鳥の胃の腑を剖いて取ったという自然のダイヤがいれてあった。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貪食家の皇帝は、満腹のために食事がそれ以上喰べられなくなるのを嘆いて、満腹すれば独得の方法で自ら嘔吐し、胃の腑を空にして再び食卓に向ったというのだ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも――胃の腑はからになっていましたし、からだも疲れきっていました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、人を生かすために、人を殺さねば出来ない六神丸のように、又一人も残らずのプロレタリアがそうであるように、自分の胃の腑を膨らすために、腕や生殖器や神経までも噛み取ったのだ。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "空っぽの胃の腑に一本の酒が、まるで吹きつけるように、浸み込み、それで一層食慾を刺戟された、若い衆たちは、驚くほど馬食して、それが済むと、もう眠くなるのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は、われ等及その家族の胃の腑と腸とを切開除去した後にするがいい。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃の腑へ届く食物は、そのまま直ちに消化されて、血管を少女のような元気さと華やかさとで駆け回るように感じられた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがなんといふ青草の精気はつらつとしてゐることか私は草の食事をしてゐるのを見たことがないのに私の住ま居の一隅にいつのまにか歩いてきてゐるのだ胃の腑のないものがどうしてあんなに健康であらう。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷のように冷えきった水が喉もとを静かに流れ下って胃の腑に広がるまではっきりと感じられた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒も飲まないのだけれども、酔後の水と同様に、胃の腑に味覚ができて舌の知らない味を味わい得たと思うほど快く感じた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は胃の腑をつかまれたような気がした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　胃の腑の中に、熱燗の酒がジリジリとしみこんで行くことを考えると、日焼けした百姓ののどがガツガツした。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人のはだかん坊は、ずぼりずぼりと水の中にすべりこみ、たらいのふちにつかまりました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし着いてみるとそこは、来合わせたお巡りたちが抑えていたので、知らず突っ込んだ私は、手の負えない酔っぱらいのふりをして疑われないようにするので精一杯でした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "使いのふたりがかわりがわりに話すところをまとめると、こうである。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
