[
  {
    "uuid": "92de7b65-876f-5e79-885d-c1ac49dea3df",
    "entry": "行き過ぎる",
    "reading": {
      "primary": "いきすぎる",
      "alternatives": [
        "ゆきすぎる"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to go too far",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の冗談はいつも行き過ぎて、周りを不快にさせることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ダイエットも行き過ぎると健康を害する恐れがあるため、注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電車の車窓から景色に見とれているうちに、目的の駅を行き過ぎてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境保護のための規制も、行き過ぎると経済活動を停滞させる要因となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の将来を案じるあまり、教育に行き過ぎた干渉をしてしまう親もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ちょっと、そこまで行き過ぎだよ！もう少し冷静になろうよ」と友人をたしなめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スピードを出しすぎてカーブを曲がりきれず、コースを行き過ぎて肝を冷やした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "知ってる顔と見えて、案内者は薄明りに、二言三言挨拶をして行き過ぎる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "褄は花の如く開かねば趣ないといふ廃頽的の江戸趣味も困るが、この理由をもつて、だからこそ和服も行灯式のスカートにせよといふ改良論者はまた行き過ぎる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりとした暗い町を今人間の形をした苦悶が火照って行き過ぎるのではないか。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の端の崖下は電車線路になっていて、ときどき轟々と電車の行き過ぎる音だけが聞える。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見たか」そんな気持で堯は行き過ぎる人びとを振り返った。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見て行き過ぎると、甲が、「今あの店にいたのは大友君じゃアなかッたか？",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方では私が叔母の家の者であり、学校の先生ということで遇うたびに礼をして行き過ぎるのでございます、田舎の娘に似わない色の白い、眼のはっきりとした女で、身体つきよくおさよに似てすらりとしていました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい方は八ツばかり、上は十三―四と見えたが、すぐに久能谷の出口を突切り、紅白の牡丹の花、はっと俤に立つばかり、ひらりと前を行き過ぎる。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同はその教えられた通りにまたもや一里半ほど進むと、今度は頬被りの馬士がドウドウと馬を曳いてやって来たので、もう雲巌寺も間近だろうと胸算用をしながら、「お寺へは何里だね」と軽く訊ねると、「そうさね、二里半もあろうか」といい捨てて行き過ぎる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝の山に入りながらではないが、我が荷物ながらオイ遣せと持出す訳にも行かず、知らぬ顔に一、二町スタスタ行き過ぎると、忽ち背後からオーイオーイと呼ぶ者がある。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを行き過ぎると、更に広い場所へ出た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　宮子は急に立ち停って、橋の欄干に凭れる真似をしながら、鶴雄の行き過ぎるのを待った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、義雄が默つて行き過ぎるのを待つて逃げるやうにばた／＼と臺どころの方へ行つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の山を黙々として歩いてゐた省三は、不忍の弁天と向き合つた石段をおり、ちやうど動坂の方へ行かうとする電車の行き過ぎるのを待つて、電車路をのつそりと横切り弁天の方へと行きかけた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、左斜にそれて女を追い越したが、女と親しみがなくなるような気がするので、足を遅くして女の行き過ぎるのを待って歩いた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の身體の具合もあるので今度は途中誰にも逢はないで行き過ぎるつもりで出て來たのだが、サテ、實際その人の土地に入り込んで見ると一寸でも逢つてゆきたい。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそれからどうしようかと考えながら、ともかくも久保町の通りを行き過ぎると、荒物屋の前に道具をおろして手桶の箍をかけ換えている職人の姿が眼についた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、あすこに照之助が拝んでいてよ」　娘たちは若い役者を幾たびか見返りながら行き過ぎるのを、半七は追いかけて小声で訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに気丈の者が「おれを呼ぶのは誰だ」と大きい声で訊き返すこともあるが、それに対して何んの答えもないので、そのままにして行き過ぎると、又もや悲しい声で呼びかける。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙臺の市へ行くのであらうと思ふ荷馬車が繭を山のやうに積んで二臺三臺と埃を立てゝ行き過ぎる。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "方向は好いが、行き過ぎるということもある。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、そのまゝ椅子に凍り付いたように、身体を小さくしながら、息を潜めて、母達が行き過ぎるのを待っていようと思った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お梶ちょっと目礼して行き過ぎる。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "桔梗色に澄み切ったままでもよいが、ときおり白雲の一つ二つが、掠めたように静かに行き過ぎるのも悪くはない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえ、どうもおやかましゅうござんした」　行き過ぎるや同時に、退屈男の双のまなこは、キラリ冴え渡りました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある唐物屋の中からは、私の嫌ひなものゝ一つである蓄音機の浪花節が、いやに不自然な聲を出して人足をとめようとしてゐましたが、誰もちよいと振りかへつたまゝでそゝくさ行き過ぎるのが、「もうぢきに冬が來るぞ、ぐづ／＼してはゐられやしない。",
              "citation": {
                "source": "冬を迎へようとして",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体、お前はソヴェトびいきすぎるよ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり、うまくいきすぎると思うわ。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to go to extremes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その法律は、本来の目的から行き過ぎていると批判されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の批判は、相手の立場を考慮せず行き過ぎている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "AI技術の進化は、倫理的な問題を無視して行き過ぎているのではないか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の心配は、些細なことにも行き過ぎており、周囲を疲弊させている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その店のセールは、過度な値下げ競争が行き過ぎている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政治家の失言は、国民感情を逆なでするほど行き過ぎた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いや、それはちょっと行き過ぎじゃない？」と友人は、彼の意見に苦笑いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
