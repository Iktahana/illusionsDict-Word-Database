        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "防波堤に打ち寄せる波が、強い磯の香りを運んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ああ、磯の香りだ」と、彼は大きく息を吸い込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "食卓には、磯の香りが食欲をそそる新鮮な魚介が並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "朝市で買ったばかりのワカメからは、まだ磯の香りが立ち込めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠くで汽笛が聞こえ、潮風と共に磯の香りが部屋を満たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は目を閉じ、磯の香りと潮騒に耳を傾けながら、故郷を懐かしんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この店の一番人気は、磯の香りが凝縮されたアオサの味噌汁だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "立待岬から汐首の岬まで、諸手を擴げて海を抱いた七里の砂濱には、荒々しい磯の香りが、何｜憚らず北國の強い空氣に漲つて居る。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "立待崎から汐首の岬まで、諸手を拡げて海を抱いた七里の砂浜には、荒々しい磯の香りが、何｜憚らず北国の強い空気に漲ツて居る。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごく平凡な貝であるが、さっと蒸しただけであるから、非常に軟かく、また磯の香りが強くて、われわれには郷愁をさそう味である。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉は適当にしまっていて、海藻から出る塩味と磯の香りとが、まことに結構である。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが磯の香りと感ずるものが、彼らには生臭いらしい。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "罐詰と冷凍食品ばかり食べている連中には、磯の香りは生臭いのであろう。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小屋なども百年を数える古い建前であって、磯の香りや木の臭気でむしむしと鼻を撲つのでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "間の山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
