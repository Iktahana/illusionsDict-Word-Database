    "definitions": [
      {
        "index": 1,
        "gloss": "going back and forth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このプロジェクトでは、一日中社内外を行って来いするような状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末の旅行は、移動が行って来いで、かなり疲労が溜まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、夏休みに毎日プールを行って来いしていたのが懐かしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議と打ち合わせで、オフィスと取引先を行って来いする日々が続く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "清水へ行きたきゃ行って来い。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か他の奴を選ンでやっておくんなせえまし」　大瀬の半五郎が次郎長に、　「親分」　「何ンだ、半五郎」　「親分が石松に使えに行って来いと仰しゃるから、俺ァ隣へ釘抜きでも借りに行くのかと思って居たら、金毘羅様迄行くんじゃ石松が可哀そうだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争に行く息子を親が新橋まで見送って、「達者で気をつけて無事で行って来い！",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "指の傷が癒ったので、天理様へ御礼に行って来いと母に言われ、近所の人に連れられて、そのお礼も済ませて来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「七兵衛、早く駐在所へ行って来い。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が帰るまで残して置いてやるから行って来い。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「元気で行って来いよ。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお礼に貴様は今から町へお使いに行って来い。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……直ぐに行って来い」「ハイ……」　弟は柔順にうなずいた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、暗くならないうちに、早く行って来い。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……んだら、※さ行って来い。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄八、ここには構わずに早く行って来い。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきん　ああ行って来い！",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（甚兵衛に）さあ、しゃんとして行って来い。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父「アア又眠くなった、医者が眠れるだけ眠れと云うから、幾分か好い兆候と見える、話は此の後に幾等もする時が有るから巴里へ行くなら早く行って来い」といい褥の上に身を横たえた。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいからそれは置いて行って来い。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎迎えに行って来い」「いや」と云ったのは譜代の筆頭、馬場美濃守信勝であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、この鍵を持っていってマヴラに渡すのじゃ、彼女に倉へ行って来いってな。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま行って来いよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち際の気の散る様を抑えながら千鶴子は、「あたし兄さんから、フロウレンスへ行って来いと云われたんだけど、とうとう行けなかったわ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……行って来い……。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は父もそこに行っているであろうから、私にも行くなら行って来いと、祖母がいったので、下役の三好という家の子供と若党も連れて一緒に行った。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝、御迎って何だい」と聞くと、勝は恐縮の態度で、「奥様が車を持って、迎に行って来いって、御仰いました」「何か急用でも出来たのかい」　勝は固より何事も知らなかった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この和歌山市から和歌の浦までちょっと使いに行って来いと言われた時に、出来得るなら誰しも御免蒙りたい。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "がこの道楽気の増長した時に幸に行って来いという命令が下ればちょうど好いが、まあたいていはそう旨くは行かない。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って来い」長造がキッパリ云った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、お前たち二人でこれからすぐに、電灯会社へいってこい。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがきっかけで、誰か「ドラ鈴」になってはいってこい、俺がマダムになって、例のところを一芝居うとうというのである。",
              "citation": {
                "source": "田舎者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあ正吉、酒を買いにいってこい。",
              "citation": {
                "source": "幸福のはさみ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佐吉や、お酒を買いにいってこい。",
              "citation": {
                "source": "酔っぱらい星",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
