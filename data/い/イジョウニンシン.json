        "examples": {
          "standard": [
            {
              "text": "検査の結果、胞状奇胎による異常妊娠の疑いがあることが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「激しい腹痛や不正出血がある場合は、異常妊娠の可能性も考えて早めに受診してください」と医師に告げられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子宮外妊娠は代表的な異常妊娠の一つであり、放置すると母体に大きな危険が及ぶこともある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "異常妊娠と診断され、母体の安全を最優先に考慮して緊急手術が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "異常妊娠による流産という辛い経験を乗り越え、彼女は再び前を向こうとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "妊娠初期の定期健診を欠かさないことが、異常妊娠の早期発見と適切な処置に繋がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "原因は異常妊娠だったらしい、二日二た晩の出血で、医師が治療法に迷っているうちに死んでしまった、ということであった。",
              "citation": {
                "source": "榎物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
