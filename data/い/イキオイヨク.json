[
  {
    "uuid": "2650b14d-aa0e-5ba7-9b5d-13ea21147579",
    "entry": "勢いよく",
    "reading": {
      "primary": "いきおいよく",
      "alternatives": [
        "いきよいよく"
      ],
      "is_heteronym": false
    },
    "grammar": {
