        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第一線に於いて、戦って居られる諸君。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井伏氏のことだから、きつと私などの氣のつかぬ、こまかいこまかいことを發見して居られるにちがひない。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、どうして居られるか。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そればかりを気にして居られる。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども山崎氏は、不思議にも、いま、成功して居られる様子であります。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と話をして居る間だけは、何も考えずに、愉快で居られるからである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "齋藤常次郎氏は、いま、たはむれに書畫骨董をあきなつて居られる由であるが、そのひとがら、その前半生、明治初年に沒したる大通中の大通細木香以を思はせる態の灑脱の趣があるのである。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "細木香以に就いては、森鴎外くはしくこれを述べて居る故、われら小倉袴のぶんを以てかれこれ言ふべきではないが、通人とは、世人が考へて居られる如き、藝者末社をひきつれ、自らを何のや主人と稱して長唄の稽古にいそしみ、その巷に於いて兄さん兄さんと呼ばれて居る樣の、そんなふざけたものではないやうである。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつたい、あなた、陸の世界の無數の河川が晝夜をわかたず、海にそそぎ込んでも、それでも海の水が増しもせず減りもせず、いつも同じ量をちやんと保つて居られるのは、どういふわけか、考へてみた事がありますか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうおなかが空くと、もうとても、眠つて居られるものぢやない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども山崎氏は、不思議にも、いま、成功して居られる樣子であります。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ星太宰治　自分と同年同月同日に生れたひとに對して、無關心で居られるものであらうか。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は明治四十二年の六月十九日に生れたのであるが、この「鱒」といふ雜誌の編輯をして居られる宮崎讓氏も亦、明治四十二年の六月十九日に生れたといふ。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其のおかげで吾々は枕を高くして眠つて居られる。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭料理などと、洒落れて居られる家は少いのじゃ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が見えて居たら居られるでしょう」「ほんとに政夫さんの御厄介ですね……そんなにだだを言っては済まないから、ここで待ちましょう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし有明氏の夫人が※花の指南を職として居られるからである。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇から絶縁し、遠く田舍にかくれてゐて、しかも絶えずかうした無禮者の闖入を受け、耐へがたき屈辱を無言に忍んで居られる蒲原氏を考へると、僕は鬱憤の押へがたい憤怒を感ずる。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若侍が、Ｔ「日下部先生お出で　と知って、よう出て　来ぬとは大吉も　案外情けない奴」　と言えば、　進藤が、Ｔ「と思って居られる　から、御貴殿は　未だ若い」　若いと言われて若侍訝しそう。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女気なし、縦にも横にも自由に居られる。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父様はその翌年お歿くなりになられ、今では私の家の客間の壁の大きな御写真のなかに、おはいりになって居られるのでございますが、私はこの御写真を見るたびごとに、あの晩のお相撲のことを必ず思い出すのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い長い廊下の片隅に、白くしょんぼり蹲くまって、かなり遠くから見たのでございますから、ふいるむのように小さく、けれども確かに、確かに、姉様と今晩の御婿様とがお寝になって居られるお部屋を覗いているのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもいま、そのかた、百花楼に居られるって。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは何でも朝鮮の京城とやらに居られるようでございます。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那さまは、三田の義塾を出た綺麗なおかたでして、いま朝鮮の京城で、なんとかいう可成り大きな新聞社を経営して居られるとかいう話でございます。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と不機嫌そうに言い、しばらく考えて居られる御様子で、「しかし、それは初耳だった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お隣りの奥さんだって、戦争の事を思わぬわけではなかったろうけれど、それよりも隣組長の重い責任に緊張して居られるのにちがいない。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「樺の木さん、お早う、そちらに居られるのは土神ですね。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが唯だ源因結果の理法に過ないと数学の式に対するような冷かな心持で居られるものでしょうか。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は、横柄に収まりかえっていられる筈の、船長室にはいなくて、サロンデッキにいた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
