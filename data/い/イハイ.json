    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist mortuary tablet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仏壇には、亡くなった祖父の位牌が大切に祀られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お盆の時期には、家族みんなで位牌に向かって手を合わせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しく位牌を作るにあたり、文字の彫刻を依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こう心を定めてから、気持はだいぶ楽になりました」　だから一時｜拵えた四郎の位牌も何もかも捨ててしまって、折につけ四郎の消息を探ることにしていると、お蘭老女は語った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝家の内部　位牌の前に泣き崩れた雪枝。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の位牌の前に喉突いて倒れて居る雪枝。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とづいと立つと、逆屏風――たしか葛の葉の風に乱れた絵の、――端を引いて、壇の位牌の背後を、次の室の襖との狭い間を、枕の方へ導きながら、「困りました。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかといって棺桶や位牌のごとく生活の決算時の入用でもない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴吉は箸をつける前に立上つて、仏壇の前に行つて、小つぽけな白木の位牌に形ばかりの御辞儀をすると、しんみりとした淋しい気持になつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけに仏壇に行つて、灯心を代へて、位牌に一寸御辞儀をした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺の後ろには位牌を持つた跛足の哲が、力三とお末とのはき古した足駄をはいて、ひよこり／＼と高くなり低くなりして歩いて行くのがよく見えた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……雛に供えたのを放生会、汐入の川へ流しに来たので、雛は姉から預かったのを祭っている……先祖の位牌は、妹が一人あって、それが斉眉く、と言ったんだね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私がとにかく、今の学校を卒業すると、妹には代々の位牌を、私にはその一組の雛と、人形を記念に残して観音様の巡礼に、身は亡きものと思っておくれ、――妹に――達者でおくらし、――私に、晋さん御機嫌よう――　妹には夫がある。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂の中は人間の黒山が崩れるばかり、潮が湧いたようになってごッた返す中を、仏様を振廻しちゃあ後へ後へと退って、位牌堂へ飛込んで、そこからお前壁の隅ン処を突き破って、墓原へ出て田圃へ逃げたぜ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、なまじっか、御先祖のお位牌へも面目、と思いなすっただけに、消した蝋燭にも恥かしい。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニ、お位牌の前だって、貴方もねえ、死んだ夫は近視でした。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一この塔婆だって、束にして、麁朶、枯葉と一所に、位牌堂うらの壁際に突込んであったなかから、（信女）をあてに引抜いて来たッてね、下足の若い衆が言っていました。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、やつと佛壇へ納めたばかりの位牌を、内中で、此ばかりは金色に、キラリと風呂敷に包む時、毛布を撥ねてむつくり起上つた――下宿を燒かれた避難者の濱野君が、「逃げると極めたら落着きませう。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村越　仏壇がまだ調いません、位牌だけを。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "欣弥　ええ、とにかく、まあ、母に逢って下さい、お位牌に逢っておくれ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（位牌を捧げ、台に据う。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）白糸　（衣紋を直し、しめやかに手を支う）お初に……（おなじく声を曇らしながら、また、同じように涙ぐみて、うしろについ居る撫子を見て、ツツと位牌を取り、胸にしかと抱いて、居直って）お姑様、おっかさん、たとい欣さんには見棄てられても、貴女にばかりは抱ついて甘えてみとうござんした。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お位牌を抱けば本望です。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その親たちの位牌を、……上野の展覧会の今最中、故郷の寺の位牌堂から移して来たのが、あの、大な革鞄の中に据えてあります。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お位牌も、この姐さんに、どうぞお力をお添え下さい。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自棄まぎれに飛出したんで、両親には勘当はされても、位牌に面目のあるような男じゃない。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（思わずそのつつみに手を掛く）俺の位牌でも買や可いのに。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔦　まあ、お位牌はちゃんと飾って、貴方のおふた親に、お気に入らないかも知れないけれど、私ゃ、私ばかりは嫁の気で、届かぬながら、朝晩おもりをしていますわ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――位牌と云うのは俺の位牌だ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配そうに煙管を支いて、考えると見ればお菜の献立、味噌漉で豆腐を買う後姿を見るにつけ、位牌の前へお茶湯して、合せる手を見るにつけ、咽喉を切っても、胸を裂いても、唇を破っても、分れてくれとは言えなかった。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと颱風と名のつく程度のものまでも入れれば中部日本を通るものだけでも年に一つや二つくらいはいつでも数えられるであろう。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとみんなのほんたうのさいはいをさがしに行く。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし東京にあの風が吹かなかったら、もし東京の街の泥と塵がなかったら、そして電車の数を増すか、あるいはいっその事に全部無くしてしまったら、それだけでも東京市民の顔は幾分か柔らかく快いものになりはしまいかと思われる。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
