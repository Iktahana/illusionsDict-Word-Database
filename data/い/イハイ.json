[
  {
    "uuid": "7fa2ebd8-bab4-536f-a2af-22cbab06f8e3",
    "entry": "位牌",
    "reading": {
      "primary": "いはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
