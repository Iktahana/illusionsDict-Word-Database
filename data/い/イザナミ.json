        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日本神話において、伊邪那美命は伊邪那岐命と共に国土を生み出したとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "火の神を生んで命を落とした伊邪那美が黄泉の國へ去る物語は、日本人の死生観に大きな影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "出雲神話では、黄泉の主となった伊邪那美の存在が、國の成り立ちと深く結びついている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まさに、伊邪那美の神話は、創造と破壊という相克する力の象徴と言えるだろう。」と、ある宗教学者は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古事記や日本書紀に記された伊邪那美の物語は、日本の文化的アイデンティティの根幹をなす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代美術の分野では、伊邪那美の姿をモチーフにした、生命の循環を表現する作品が発表されることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "父の御神詔りたまへば、伊邪那美よ、僕が母、妣坐せば、根の堅洲國、僕は戀し、罷りゆかずば、ただ哭くと泣く。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊邪那岐命、伊邪那美命と天の御柱をめぐりてみあひませしときに、伊邪那美命まづ、あなにやし愛男をとのりたまひて、くみどに興してうみたまへる御子のふさはしからざりしも、たゞごとにはあらざりけり。",
              "citation": {
                "source": "日月喩",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ獨り空に殘りし霞かな　女體山の上には、伊邪那美命を祭り、男體山の上には伊邪那岐命を祭る。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから千曳きの考証としては、この筆者のいわく、千曳とは凡そ大なる石を云へり、古事記に最後其妹伊邪那美命身自追来焉爾千曳石引塞其黄泉比良坂云々。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "我國の最初の母なる神、造物神、その伊邪那美の神の永遠に眠れる墳墓の地とは伯耆と出雲の國境にあるといひ傳へられるところから、さういふ想像が生れて來たのか。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "比婆山の位置もはつきりしないとは聞くが、もしそんなところまで行くことが出來て、あの伊邪那美の神の墳墓の地を見たらばとも思つて來た。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古史成文』は、凡ての源泉徴証を、比較綜合して、記して曰く、爾に神伊邪那岐、伊邪那美命、妹妖二柱嫁き給いて、国の八十国、島の八十島を生み竟え、八百万の神を生給い、亦た悉く万物を生給う。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "神次に妹活杙神、次に意富斗能地神、次に妹｜大斗乃弁神、次に母陀琉神、次に妹阿夜訶志古泥神、次に伊邪那美神。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の件国常立神より以下、伊邪那美神まで、併せて神七代と称すと。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊邪那美神は、火神を生みませるに因て、遂に神避ましぬ。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に其妹伊邪那美命を相見まく欲して、黄泉国に追い出でましき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾に伊邪那美命の答給わく、悔しきかも、速く来まさずて、吾は黄泉戸喫しつ。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に伊邪那岐命見｜畏みて、逃げ返り坐す時に、其妹伊邪那美命、吾に辱見せ給いつと申し給いて、やがて泉津醜女を遣わして、追わしめき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、其妹伊邪那美命、身自ら追い来ましき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち千引石を其黄泉比良坂に引塞えて、其｜石を中に置きて、相｜対立して、事戸を渡す時に、伊邪那美命申し給わく、愛しき我が那勢の命、かくし給わば、汝の国の人草、一日に千頭絞り殺さなと申し給いき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊邪那美神は、はじめて死せし神にして、男神の上界の主たるに対して、下界の主となれり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古事記』に曰く、是に伊邪那岐命、見かしこみて逃げ返ります時に、其｜妹伊邪那美命、吾に辱見せ給いつと申給いて、即ち予母都志許売を遣して追わしめき。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の騒ぎには、通船会社の船長が三人謝罪の為にやって来て、問題は屡々国体観念に及ぶし、遂には哀れにも、「伊邪那岐、伊邪那美」両｜尊までが引合いに出されると云う結果を見るに至った。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯耆の名は、箒だろうというのは俗説で、古事記の伊邪那美命のことに因んで、　母君の国　と呼んだのが、自然｜訛ってきたものとか。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまるところ、その滝壺の底にはイザナギ、イザナミの尊以来、沈澱している砂金が、計算してみると四百億円ぐらいは在るらしい……というのだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉集以前の古事記や日本書紀の中で、最初に描かれた女性であるイザナミノミコトは、古事記を編纂させた人は女帝であったにもかかわらず、それを書いた博士たちの儒教風な観念によって、男尊女卑の立場においてかかれている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうも恋愛だけはイザナギイザナミの昔以来余り変らないように思いますが。",
              "citation": {
                "source": "或恋愛小説",
                "author": "――或は「恋愛は至上なり」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此中に知られてゐる字は唯の二字であるが、直覺的に是はイザナギ、イザナミであらうと云ふことに想達する。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　イザナギ、イザナミの二神が、萬物を生み出す親となつた。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　幽と顯とに以下、イザナギ、イザナミ二神の事蹟。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "イザナミの神の行つている黄泉の國である地下の堅い土の世界。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "イザナギ、イザナミの生んだ子の中にあつた。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "イザナミの命の黄泉訪問の神話にもこれがあつた。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからして天と地とがはじめて別になつて、アメノミナカヌシの神、タカミムスビの神、カムムスビの神が、すべてを作り出す最初の神となり、そこで男女の兩性がはつきりして、イザナギの神、イザナミの神が、萬物を生み出す親となりました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "和銅五年正月二十八日正五位の上勳五等　太の朝臣安萬侶一、イザナギの命とイザナミの命天地のはじめ――世界のはじめにまず神々の出現したことを説く。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
