          ],
          "literary": [
            {
              "text": "或る意味に於て、すべての人間はアイデアリストである。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しく言えば、詩人とはイデアリストで、生活の幻想を追い、不断に夢を持つところの人間夢想家。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "形而上学にてアイデアリスト（唯心論者）といふものは、文芸上にてアイデアリスト（理想家）といふところの者とは全く別物なり。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロマンチック・アイデアリストとしての馬琴の一端は、之を以て窺ひ知るを得んか。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしくこれはイデアリストの型であろう。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者を私はイデアリストと呼び、後者を私はフマニストと名づける。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いやしくもよき生活を生きんとするものは必ずイデアリストかフマニストかのいずれかでなければならないと思う。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはイデアリストの空なる望みにすぎないのであろうか。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし思えばそれはイデアリストの同情すべき弱点である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだしイデアリストにとっては実生活があまりに貧弱なるがゆえに、自己の内面に宿る偉大なる感情を盛る材料がない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる過失は心の純なイデアリストがかえってしばしば犯すものである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "学業に勉励せぬ、イデアリストでない学生に恋愛を説く如きは私には何の興味もないことである。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "イデアリストの青年にあっては、学への愛も恋への熱もともに熾烈でなくてはならぬ。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実主義者が恋愛は性慾と生殖作用の上部構造にすぎないといっても、精神的憧憬の深いイデアリストは恋愛が性慾をこえた側面を持ち、むしろそのこえんとする悩みにこそ、恋愛の秘義があると主張してやまないであろう。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に多くのイデアリストの憧憬に満ちたる青年が、このことからたちまち壮年の世俗的リアリズムに転落したことであろうか。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなるイデアリストの詩人、思想家も、彼が童貞を失った後にそれ以前のような至醇なる恋愛賛美が書けるはずはない。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに私の上来のいましめはイデアリストに現実的心得を説くよりも、むしろリアリストに理想的純情を鼓吹することをもって主眼としてきたものだけに、現実生活においてなるべく傷を受けないように損をしないようにという忠告は乏しいのだ。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際イデアリストの道は危険の道であり、私自身恋愛のために学生時代にひどい傷をつくって、学業も半ばに捨て、一生つづく病気を背負ったような始末である。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで認識論上博士はイデアリストでもなければマテリアリストでもなくて、云わばマテリオ・イデアリストという折衷主義者として現われる。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
