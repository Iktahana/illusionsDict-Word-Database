    "definitions": [
      {
        "index": 1,
        "gloss": "skipping stones (on a body of water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちは川原で石飛ばしをして遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "久しぶりに湖畔で石飛ばしに興じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は見事な石飛ばしで、水面に何回も波紋を広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "幼い頃、父とよく浜辺で石飛ばしをしたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "石飛ばしは、単純な遊びだが奥が深い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この平べったい石なら、きっといい石飛ばしができるよ！」と少年は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕暮れの運河で、一人黙々と石飛ばしをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "斯くて一部は精妙の武具を用ゐて先陣に、トロイア及び青銅を穿つヘクト，ル敵と爲し、一部後陣に身を隱し、矢と石飛ばし敵陣を　720亂せばトロイア軍勢はすでに戰疲れたり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて勇將石飛ばしイタイメネース生める息、　585ステネラオスの頸にあて其筋肉をつんざけり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
