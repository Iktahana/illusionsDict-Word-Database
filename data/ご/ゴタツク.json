        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからそれへと悪くごたつくな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のわるい彼女は、朝起きを昔しから辛がつてゐたが、ごたつく台所の音が耳に入ると、矢張り寝てもゐられないのであつた。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんの方が全責任を負う（雇人対手のように）気にならず、隆がこう云ったからなど云い、ごたつくこともある由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間感情の紛糾を、真に解決しよう、真に発展させよう、社会的な本源につきつめて究明してゆこうというより、社会的なものだ、相対的なものだ、という一定の観念の上に立って現実にはごたつく気持の縺れ合いに身をまかせ、身をよじり、手をふりしぼる心の姿態を作家的自覚によって描いてゆく。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも余りごたつくので。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのんびりしたこの筋違の広場にも、やがて甲武鉄道の延長から赤煉瓦の駅舎出現、名代のめがね橋とり毀しなど三十年頃からそろそろごたつく。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
