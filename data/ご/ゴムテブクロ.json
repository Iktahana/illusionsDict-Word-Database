        "examples": {
          "standard": [
            {
              "text": "手術を始める前に、外科医は慎重に滅菌されたゴム手袋を装着した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "食器洗いの最中に、ゴム手袋に穴が開いて中まで水が浸みてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "汚れ仕事をするから、丈夫なゴム手袋を用意しておいたほうがいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "襯衣を肘の上までまくり上げ、手には長いゴム手袋をはめ、その上にまたもう一つ、白い絹らしい布で出来た手袋をはめていた。",
              "citation": {
                "source": "人体解剖を看るの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてゴム手袋をぬいで、持参の小壜から石鹸水らしいものを手にたらして、両手を丁寧に洗った。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな毒瓦斯は、吸着剤の活性炭と中和剤の曹達石灰とを通せば遮られるし、ゴム衣ゴム手袋ゴム靴で結構避けられます。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "無菌法が誕生して外科医の特別な服装が発達し外科医は滅菌したガウンと帽子を身につけゴム手袋をはめ口と鼻の前にマスクをつけて手術し患者を細菌から守っている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりにゴム手袋とゴム靴がないか。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "このころになると通りを歩く人々の大半がゴム靴とゴム手袋を完全装備していた。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴム手袋とゴム靴でさらに保護できる。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
