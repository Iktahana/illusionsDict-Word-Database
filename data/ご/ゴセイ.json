  {
    "uuid": "5f3abcce-8d68-5246-9bb6-37c50a1be4df",
    "entry": "五世",
    "reading": {
      "primary": "ごせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "five generations",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで、彼は、英国のジョージ五世に言葉をかけられた。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五世弥五右衛門は鉄砲十挺頭まで勤めて、元文四年に病死した。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "Augustinus　中世の神の國と云ふ思想は四五世紀の間に出た Aurelius Augustinus の書 De civitate Dei（libri ※）をして代表せしめることが出來る。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いずれお解りにならないところは、そちらの方からお訊ね下さい、――私は去年、結婚した時のことから申しますが、まずその前にお耳に入れておきたいことは、私の家は、決して金持ではありませんが、ここ約五世紀の間は、現在のリドリング村に住んでいて、ノーフォーク地方では、第一の旧家だと云うことです。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年、私が結婚したところから始めましょう――いえ、まずその前にお耳に入れておきたいのですが、私の家は、決して裕福ではありませんが、ここ約五世紀の間は今のリドリング・ソープに住んでいて、ノーフォークのあたりでは第一の旧家だということです。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、十五世紀にコンスタンチノブルの最初サルタン珍事を好む、基督教の大僧正に詛はれた者は地も其尸を壞らず。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハネス・グーテンベルクが印刷の技術をまとめたのが、十五世紀の半ば。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋳造活字に話を限っても、朝鮮ではすでに、十五世紀前半にこの技術が生まれていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五世紀半ばのイタリアから目覚ましく展開した文芸復興の流れの中で、教会を精神的な抑圧装置とした中世封建社会の重苦しい空気を払いのけ、良くも悪しくも人間くさい精神を解き放とうと彼らは試みました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五世紀に誕生した印刷術は、従来の本の概念にはひとまず手を触れず、その製造の工程に食い込みました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五世紀から十九世紀までも英国で行なわれたような、労働立法を制定して、額に烙印を捺すのが一等だ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に魏の能く五世を保せんやと（『史記評林』四六と七八、『広弘明集』七）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもとモールス人が始めた踊りで、スペインでモリスコと呼び、仏国では十五世紀に行われて、モリスクといった。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "エーとそれアノ何じゃそれからまた、十五世紀にアジア諸国を巡った露人ニキチンの紀行に多分交趾辺と思わるマチエンてふ地を記し、そこにも似た婦人、昼は夫と臥せど夜は外国男を買うた話が見える。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六世紀に出たストラパロラの『面白き夜の物語』（ピャツェヴォリ・ノッチ）十三夜二譚は余未見の書、ソツジニが十五世紀に筆した物より採るという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏国アミアンの僧正は領内の新婦にこの事を行うを例としたが、新夫どもの苦情しきりなるより、十五世紀の初めに廃止したというに、尾佐竹猛君の来示に、今もメキシコで僧がこの権を振う所ある由。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五世紀に伊人ポッジオが金銀よく汚れた物を浄くする一例として書いたは、ある富有な僧、極めて犬を愛し、その死するやこれを人間同様寺の墓場に葬った。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一八一一年版エリス著、初世英國律語體傳奇集例、卷一、二〇五―四三頁）英國デヴォン州ホルスヲーシーの寺の壁を十五世紀に建てる時人柱を入れた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐倉の地は、よく／＼堀田家に縁ありと見えて、正俊の五世の孫、正亮移されてこゝに城主となりたり。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五世紀十六世紀頃なら相当な人物であつたかも知れないが、Ｘ光線や無線電信の行はれる二十世紀には到底向かない男だ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルイ第十五世時代に出来た飾箱の中に、何一つ欠点の挙げやうのない、美しい、小さいタナグラ人形があつた。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五世紀頃には、かつては同輩であつた諸侯は、国王麾下の将軍に過ぎなくなり、十七世紀頃には、その宮臣に過ぎなくなつてしまつた。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "主従は二世三世、だんなとあっしゃ五世六世、ふたりともいまだにひとり身でいるが不思議だが、ひょっと伝六女じゃねえかと、ひとさまが陰口きくほどの仲じゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "万有の精は吾が心のうちにあり天地を流れ、吾が心を流れておお、この止め度なさ君を抱きて吾狂せん――　街の音楽は十五世紀の理想家が歌つた恋歌を奏でてゐるかのやうである。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨオジ五世のは、国々の珍しい切手ばかしを選り好みをするのだが、池田氏のはそんな事には頓着なく、どんな有り触れた物でも構はない、手当り次第に集めるので、かうして掻き集めたのが、今では積り積つてざつと二十万枚ある。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元前五世紀の人でアレキサンドリア出のギリシアの著者アキレス・タティオス（Achilles Tatios）の記したところによると、カルデア人はこういうことを主張していた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元前五世紀の道教学者列子は『始めに、一つの組織のない団塊、すなわち、渾沌があった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "シキスツス第五世は壮麗なヴァチカン宮の図書館を建設し充実した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五世紀の頃に至って、沖縄島に尚巴志という一英傑が起って三山を一統した時に、久しく断絶していた本国との連絡は回復せられ、日本及び支那の思潮は滔々として沖縄に入り、十六世紀の初葉に至って沖縄人は日本及び支那の文明を消化し沖縄的文化を発揮させたのである。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰路につかれようとしているジョウジ五世陛下と皇后陛下とが、遠く小さく、おなじく帰路につこうとしている私たちから拝された。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
