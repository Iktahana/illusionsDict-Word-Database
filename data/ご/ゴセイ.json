[
  {
    "uuid": "b6d7c57d-d119-5e7d-a829-7e0169cac2b4",
    "entry": "悟性",
    "reading": {
      "primary": "ごせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
