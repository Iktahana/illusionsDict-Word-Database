          "literary": [
            {
              "text": "護憲運動のあった時などは善良なる東京市民のために袋叩きにされているのですよ。",
              "citation": {
                "source": "或恋愛小説",
                "author": "――或は「恋愛は至上なり」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、社会党を中心として良識ある政治家を糾合した、護憲、民主、中立政権にしてはじめて実行しうると思います。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道士、えらいごけんまくだな」「騒いでいるのは、こッちではない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
