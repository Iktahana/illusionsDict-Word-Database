[
  {
    "uuid": "a09a8e05-446a-578f-a32b-ce67460e7299",
    "entry": "業苦",
    "reading": {
      "primary": "ごうく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
