        "examples": {
          "standard": [
            {
              "text": "あの事件は、ごろ新聞でしか詳細が報じられなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かつては、ごろ新聞が社会の裏側を暴く役割を担っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼が手に入れた情報は、まるでごろ新聞の記事のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、また考えてみると、近ごろ新聞などでよく、電車切符を人からねだっては他の人に売りつける商売があるという記事を見ることがある。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また学会全般の事情も知らぬので、近ごろ新聞雑誌でさかんに原子学が取りあつかわれているから、これがよかろうと簡単に決めたのなら、ちょっと軽率だと言いたいね。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ新聞を見ますと、政府を作るために政治家がいろいろ相談をしている。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎君は、このごろ新聞でさわがれている黄金仮面という怪物のことを、とっさに、思いだしました。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
