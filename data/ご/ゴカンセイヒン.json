        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さらにＡＭＤは３８６互換製品のライン・ナップを拡充していった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この訴訟が決着を見る前に、ＡＭＤは同年六月、互換製品の販売を開始した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでインテルはすでに提訴済みの著作権侵害訴訟に加えて、ＡＭＤの互換製品の販売を中止させる訴えを裁判所に求めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、この三点を控えればＡＭＤは８０２８７互換製品を販売できると認められたと考えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
