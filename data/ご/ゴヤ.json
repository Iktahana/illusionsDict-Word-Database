[
  {
    "uuid": "6110cc16-6915-573f-a8de-a887cf393142",
    "entry": "五夜",
    "reading": {
      "primary": "ごや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
