[
  {
    "uuid": "9697221d-de6d-5a06-99a4-c7ee2e3477bd",
    "entry": "轟然",
    "reading": {
      "primary": "ごうぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
