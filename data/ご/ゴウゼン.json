      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "roaring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、逃げて行く軍医を、うしろからねらって、轟然と拳銃を放った。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、橇の上から轟然たるピストルのひゞきが起った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顛覆した列車の窓からとび出た時の、石のような雪の感触や、パルチザンの小銃とこんがらがった、メリケン兵のピストルの轟然たる音響が、まだ彼の鼓膜にひゞいていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、列車は轟然たる車輪の響きを高めつゝ橋にさしかゝった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その時、突然、轟然たる大音響に彼は、ひっくりかえりそうになった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一向、此の變則の名所に就いて、知識も經驗も無かつた彼は、次第に暗く成り、愈々深くなり、もの凄じく成つて、搖れ／＼轟然たる大音響を發して、汽車は天窓から、鈍き錐と變じて、山の底に潛込むが如き、易からぬものの氣勢に、少からず驚かされたのである。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟然たる響と共に、弦月丸は沈沒して、妾は一時は逆卷く波間に數十｜尺深く沈みましたが、再び海面に浮び上つた時、丁度貴方のお聲で、私の名をお呼びになるのが聽えました。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟然一發の彈丸は悲鳴をあげて、我が前檣を掠め去つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞻むれば一｜隻の海賊船は轟然たる響諸共に、船底微塵に碎け、潮煙飛んで千尋の波底に沈み去つた、つゞいて起る大紛擾、一艘は船尾逆立ち船頭沈んで、惡魔印の海賊旗は、二度、三度、浪を叩くよと見る間に影も形も。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この絶壁下には先頃まで鉱山事務所があったのだが、轟然たる山崩れと共にその事務所はメチャメチャになり、一人の技手は逃げ損って蛙のごとくに押潰され、その片腕とか片脚とかは、かの巨巌の下に今なお取出す事が出来ず残っているという事だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三、同時に轟然一発、頭を覗って打出す短銃。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰助蒼くなりて一足｜退れば、轟然たり、短銃の第二発。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "散弾が轟然として四辺に迸ると、頑強の敵も流石に胆を挫がれたらしい、踵を旋してばらばらと逃げ出した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の実力試験「この石を線路に置いたら、汽車が引っくり返るか返らないか」「馬鹿な……それ位の石はハネ飛ばして行くにきまっとる」「インニャ……引き割って行くじゃろうて……」「論より証拠やってみい」「よし来た」　間もなく来かかった列車は、轟然たる音響と共に、その石を粉砕して停車した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟然たる発火と共に、煙が室内いっぱいに立ちこもった。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、イングンの眞白い兩腕が夫の首筋にからむと見えたその一瞬時だつた「パアン‥‥」　と、轟然たる爆音。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は小牛のような野猪が、轟然と響く鉄砲の音とともに、地響打って倒れるだろうと思ったが、鉄砲の音は小さく響いただけで、野猪は悠然とむこうの方へ往ってしまった。",
              "citation": {
                "source": "山の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢や銃弾も中らばこそ、轟然一射、銃声の、雲を破りて響くと同時に、尉官は苦と叫ぶと見えし、お通が髷を両手に掴みて、両々動かざるもの十分時、ひとしく地上に重り伏せしが、一束の黒髪はそのまま遂に起たざりし、尉官が両の手に残りて、ひょろひょろと立上れる、お通の口は喰破れる良人の咽喉の血に染めり。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を過ぎて轟然千曲の濁流を一過すれば、右方囑目遠く平けて遠山之を限る。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車は轟然と突き進んだ。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟銃は轟然と鳴り響いた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃声は轟然と窓ガラスを震わして鳴り響いた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　銃声が轟然と真夜中の薄闇を揺り動かした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『遂に最後の瞬間が来た、機関車は轟然たる大音響と共に坑の向う側に突撃した。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたい三上は」「さては女郎買いをしやがったな」「伝馬で帰ったのかい」「うまくやってやがらあ」　各人が考え、想像していたことの最初の言葉が、彼のまわりに、桟橋から船に落ちる石炭のように轟然と、同時に飛びかかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その怪物からは続けざまにドンドンドンと轟然たる砲声が放たれた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜来の雨が明方から勢ひを増して天も地も轟然たる唸りを挙げてゐた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "樵夫は高い樹の傘下にある、轟然と伐採する樹の枝は爛れた空を掃くあらゆる日本の神事は我等の手をもつて主宰せよ。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、またもやごうぜんたる音がして、全船が震動した、同時に船は、木の葉のごとく巨濤の穂にのせられて、中天にあおられた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "地に伏せ」　ドノバンがさけぶと同時に、耳をつんざくごうぜんたる霹靂！",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
