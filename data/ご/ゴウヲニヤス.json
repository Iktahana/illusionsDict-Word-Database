    "definitions": [
      {
        "index": 1,
        "gloss": "to lose one's temper",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
