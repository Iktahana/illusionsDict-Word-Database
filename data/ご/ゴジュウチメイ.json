    "definitions": [
      {
        "index": 1,
        "gloss": "at age fifty, one comes to know the will of Heaven",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
