      {
        "index": 1,
        "gloss": "the five sins (murder, theft, adultery, falsehood, and alcohol)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
