        "examples": {
          "standard": [
            {
              "text": "新しい事業のご成功を心よりお祈り申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプロジェクトのご成功は、チーム全員の努力の賜物です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「皆様のご成功を祝して、乾杯！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "切にご成功を祈るよ」「ところが、このごろ人骨が手に入らないので、仕事がすすまなくて弱っています。",
              "citation": {
                "source": "骨仏",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」もう階段をおりかけたラスコーリニコフは、こう相手のことばを受けたが、ふいにくるりとポルフィーリイの方へ振り返って、「まあ、今後いっそうのご成功をお祈りする、とでも申しましょうか。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくご成功は望み得ますまい」　と、諫めるばかりで、賛成するものはいなかった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
