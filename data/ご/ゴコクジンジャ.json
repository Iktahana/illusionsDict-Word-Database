    "definitions": [
      {
        "index": 1,
        "gloss": "shrine honoring war dead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――してみると、やっぱり小郷を死なせるというのはむりかな」　考えながら、護国神社の前から清水の方へ折れて行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸軍病院に敬意を表し、護国神社に合掌する、青銅の大鳥居は尊い、大厚皮香の木ぶりをよろこんだ。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前、道後温泉入浴、護国神社参拝、午後、一洵兄と同道して月村君を訪ね、三人打連れて漫歩漫談、降りだしたので急いで帰つた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "清明を感じる、風は冷たいけれどなごやかであつた、未明、眼覚めて起床、よねんなく執筆、暁天にひゞきわたる護国神社の太鼓の声は尊い。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "護国神社の大鼓と共に起きる、せつかくの日曜日が雨で気の毒だ、私は雨傘がないので、しやうことなしに蟄居、雨もわるくない、落ちつかせてくれる、日記、句稿、書信など整理する。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "起床してから、東雲神社の大鼓、そして護国神社の大鼓がとうとう鳴りだした。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くから眼は覚めていたけれど、――護国神社の大鼓が鳴りだより起きた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "護国神社参拝者が今日は特に多い、拝殿前に並列して合唱する女学生の姿が見え、声が聞える、雪はしづかに人はつゝましく、ああ。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "快眠したので気持よく眼が覚める、起きると間もなく護国神社の大鼓が鳴りだした。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟睡の熟睡だつた、護国神社の大鼓も知らなかつた、起きるより先づ一杯、そして道後へいそいで一浴。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝、護国神社参拝、それから道後温泉入浴、やつとはぎを見つけてうれしかつた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起、すつかり片づいてから、東雲神社の、それから護国神社の大鼓が鳴つた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝、護国神社参拝、道後入浴、余寒春寒、そゞろに寒い。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどよい目覚め、護国神社の大鼓の声と同時だつた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "とろ／＼したと思つたら、もう護国神社の大鼓が鳴りだしたので起きた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起、手早く掃除して、護国神社参拝。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まづ東雲神社の大鼓、それから護国神社の大鼓、それから、それから。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝、護国神社参拝、個人も団体も陸続として参拝する。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "未明地震、眼が覚めたのですぐ起きる、東雲神社の大鼓、それから護国神社の大鼓。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "とう／＼護国神社の大大鼓。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝、護国神社参拝。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――護国神社参拝、いつも参拝がたえない、このごろことに多い。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "東が白むのを待ちかねて起きる、まもなく護国神社の太鼓が、とうとうとうと鳴り出した、だいぶ日が短くなつて、もう五時も近からう。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "護国神社の太鼓と共に起床。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝護国神社参拝、まことに秋である。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時を過ぎると東雲神社の太鼓、五時ちかくなると護国神社の太鼓が鳴る、その間にいつも私は起床する、――けさもさうだつた。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起、護国神社の太鼓が鳴る。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夜、空寂にたへないので、そこらをあちこち散歩する、月夜の護国神社に詣でる人影ちらほら、家の中で家内むつまじく月見の人々。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "護国神社から号令拍手の声がたえない、ぢつとそれに耳を傾けてゐると、故殿下哀悼と東亜新秩序建設の熱意にうたれる。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "）午後護国神社参拝、今日はとりわけ参拝者が多い、朝から参拝者がつゞいてたえない。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
