[
  {
    "uuid": "248c7fea-fa54-5dd0-991e-7e4aa0eec27a",
    "entry": "御寮人",
    "reading": {
      "primary": "ごりょうにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
