    "definitions": [
      {
        "index": 1,
        "gloss": "abode (of a nobleman or emperor)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つい前日に摂政宮殿下の御座所だったとのことであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "御座所の方に向って、また、四辺を広く眺めまわして、しみじみと私は崇敬した、日本皇室の神聖と、吾が民族の由来する伝統と精神とを、そうして愈々に幸わうわが国の言霊とを。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "御座所の後ろにはささやかな、また清らかな浅い池があった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし天皇はそれでも寸分もおいといにならないで、雨がひどく降るたんびには、おへやの中へおけをひき入れて、ざあざあと漏り入る雨もれをお受けになり、ご自分自身はしずくのおちないところをお見つけになって、御座所を移し移ししておしのぎになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お使いの口子は、奴里能美のおうちへ着きますと、天皇のそのお歌をかたときも早く皇后に申しあげようと思いまして、御座所のお庭先へうかがいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "）五郎　上樣は桂どのと、川邊づたひにそゞろ歩き遊ばされ、お供の我々は一足先へまゐれとの御意であつたが、修禪寺の御座所ももはや眼のまへぢや。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は修禪寺の御座所へ寄せかけ、多人數一度にこみ入つて本意を遂げうぞ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちは御座所へ走せ參じて、この趣を注進せい。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かへで　敵は誰やらわからぬが、人數はおよそ二三百人、修禪寺の御座所へ夜討をかけましたぞ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々になつた一番下の所に警護の武士の詰所があり、二番目が先づお附の人の居た場所、一番上の狹い所が恐らく上皇御自身の御座所ででもあつたらう、といふＭ――老人の解釋であつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすると、御座所の御部屋の廣さは僅かに現今の四疊半敷にも足りない程度のものであつたに相違ないのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ島のうちでも、全然家とか村とかいふものから引離された、斯うした所を選んで御座所を作つたものと想像せらるゝのであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "想うにこの一段ごとに一軒ずつの小屋があり、御座所やお召使または警護の者共それぞれの住所にあてられていたものらしいと想われた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "）五郎　上様は桂どのと、川辺づたいにそぞろ歩き遊ばされ、お供のわれわれは一足先へまいれとの御意であったが、修禅寺の御座所ももはや眼のまえじゃ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上は修禅寺の御座所へ寄せかけ、多人数一度にこみ入って本意を遂ぎょうぞ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちは御座所へ走せ参じて、この趣を注進せい。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえで　敵は誰やらわからぬが、人数はおよそ二三百人、修禅寺の御座所へ夜討ちをかけましたぞ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤熊百合、王の御座所の天幕の屋根飾、夢を鏤めた笏、埃及王の窮屈な禮服を無理に被せられた古風な女王。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日五十ばかりの主人が上つて来て、慶長年間から存在してゐるこの旅館の古い歴史を話して行つたが、氷川のゐる一棟が、秀吉の陣屋の御座所であつたとか云ふ話は、氷川にはちよつと直り来ないやうな感じであつた。",
              "citation": {
                "source": "倒れた花瓶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "（細川幽斎九州道の記に備後の津公儀御座所に参上して十八日朝｜鞆までこし侍るとあり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」本文には又備後の津の公儀御座所を豊公の宿だとしてあるのに、欄外にはかう云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「備後の津公儀御座所といふは義昭将軍をいふ也。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人は唐衣、童女は袗も上に着ずくつろいだ姿になっていたから、宮などの御座所になっているものとも見えないのに、白い羅を着て、手の上に氷の小さい一切れを置き、騒いでいる人たちを少し微笑をしながらながめておいでになる方のお顔が、言葉では言い現わせぬほどにお美しかった。",
              "citation": {
                "source": "源氏物語",
                "author": "蜻蛉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ天地のもと、われら敬愛の心もて、御身の御座所の前にかく平れ伏し、讃美の誠を捧げまつる。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三津浜では藩の船番所を世子の御座所となし、我々は町の人家を徴発して下宿した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは天下の評定所でございますから、御老中は勿論将軍家も年に二度ぐらいはお成になるという定例でございます、即ち正面の高座敷が将軍家の御座所でございまして、御老中、若年寄、寺社奉行、大目附、御勘定奉行、郡奉行、御代官並びに手代其の外与力に至るまで、それ／″＼席を設けてあります。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番奥の庭に御座所があるのです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇后の御座所の火事を立小便で消すことのできるような男なら、いつ大水を起して宮城を水浸しにしてしまうかもわからない、それに、敵艦隊を引っ張って来たあの力では、一たん何か腹を立てゝ暴れだしたら大へんなことになる、と、ボルゴラムは死刑を説くのです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間振りではあり、ほろ酔の好い気持ちで、長湯して戻って来ると、奥の御座所に隣る広間が私共の座敷に充てられ、一同は既に膳についてビールを飲んでいた。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
