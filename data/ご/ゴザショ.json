[
  {
    "uuid": "19e2608c-6369-5b1f-a7cc-f37e9ff2af25",
    "entry": "御座所",
    "reading": {
      "primary": "ござしょ",
      "alternatives": [
        "おましどころ",
        "おわしどころ",
