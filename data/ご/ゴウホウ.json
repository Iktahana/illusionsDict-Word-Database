      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "armful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上水の兩岸、みな櫻、幹古りて大に、その小なる者も合抱に下らず。",
              "citation": {
                "source": "小金井の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "この潤ひと柔かみとは、『自然』と『我』との融合抱和になくてはならない最勝の媒介者であります。",
              "citation": {
                "source": "雨の日に香を燻く",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十年の星霜を閲した「合抱」の木であつたから、これを移すのは容易な事ではなかつただらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
