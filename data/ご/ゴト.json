    "definitions": [
      {
        "index": 1,
        "gloss": "cheating at pachinko (for monetary gain; through illegal tampering with the machines, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今年私ハ、小サイタライノオ風呂ニ二三日ゴトニ入リマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母さんは台所の方で、ゴトゴト音を立てながら、時折呟いてゐるのが聞えた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お祖母さんは暗い台所でゴトゴト何かしてゐて、何も聞えないふうだ。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "家敷の二方に並ぶ病室からは、患者や附添人等の呑気な饒舌が、時には高く、その余はゴトゴトと聞えて来た。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩は鋼鉄のように硬くなりながらも、イワベンケイ、ミヤマダイコンソウ、ムカゴトラノオなど、黄紫のやさしい花を、点々とその窪洞に填めながら、ギザギザに尖っている輪廓を、無数に空に投げ掛けている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ピストルに吃驚した竹内が歩哨小屋から靴をゴト／＼云わして走せて来た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の女の姿が消えると間もなく、下の雨戸を開ける音がゴトゴトして、建付の曲んだ戸が漸と開いた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言って、ゴトンと閉めた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど鶴のような足取りで二歩三歩あるくと、立ち止まって首を下げて嘴で桟橋の床板をゴトンゴトンと音を立ててつっついている。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服も煙草も二階へ置いて来ちゃったんだ」「困るわねえ」「弱ったなア」　そのうちに二階の男が起きたらしくゴトゴトと物音がし始めた。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリキの鐵瓶に入れて、ゴトリ／＼と煮て、いや、うでて、そつと醤油でなしくづしに舐めると言ふ。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして恰度十一時が――葛飾の居間に掛っている寺院の鐘のような工合に響く時計が十一時を鳴り終って直ぐ、画室の方でゴトンと何か重い物の倒れた音がしました。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　此の間、何うかすると、ゴト／＼、ゴト／＼と、輕い、併しながら不愉快な響が耳に入ツて、惡く神經を小突く。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて心臓の動悸がゴトンゴトン、ボコンボコンという雑音を含みながら頭蓋骨の内側へ響きはじめる。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとからゴトーンと人間の身体が倒おれるような音が響いた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のために、何の意味で、あんな無味平淡なタダゴトの詩を作るのか。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした文学がいつたい「何のために」「何の興味」で創作されるのかといふことは、子規のタダゴト歌以上に、私にとつて釈きがたい謎であつた。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの平凡無味なタダゴトが、いつも私を心ちよい夢の恍惚にさそふまで、特殊な俳味的の芸術心境を感じさせた。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ト　フエフキガ　ヒトリゴトヲ　イフト　ヂイサンハ　カホヲ　アゲテ、「サウサ、カナヅチハ　ナンデモ　ツクルンダ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　マタ　フトコロニ　コヒツジヲ　イレテ、「シカタガ　ナイカラ、コノ　コヒツジハ　オレガ　ソダテテ　ヤラウ」ト　ヒトリゴトヲ　イヒナガラ　ヤツテ　ユクウチ　トツプリ　ヒガ　クレマシタ。",
              "citation": {
                "source": "ヌスビトト　コヒツヂ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレヲ　キイタ　コノ　マヅシイ　ヲトコノ　ヒトハ、「ヨシ、ソレデハ　ジブンモ　センサウノ　アル　トコロヘ　イツテ、リツパナ　テガラヲ　タテ　タイシヨウニ　ナラウ」ト　ヒトリゴトヲ　イヒマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カイドウニ　ソツタ　イエイエノ　ヒトタチハ、ムカシ　ジブンタチノ　ノツタ　バシヤガ　コドモタチニ　ヒカレテ　イクノヲ　ミルト、シゴトヲ　ヤメテ　オモテニ　デテ、バシヤヲ　ミオクルノデ　アリマシタ。",
              "citation": {
                "source": "フルイ　バシヤ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
