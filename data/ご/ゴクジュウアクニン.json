        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが自らの身の上に及んで来て、共犯者だと云はれて、否応なしに令状を執行されて、極重悪人の罪名を附せられた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "一念弥陀仏、即滅無量罪障と聞けど、わが如き極重悪人の罪を救はれざらむ事、もとより覚悟の前ぞかし。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上人はさすがに、この極重悪人をも捨てなかった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「極重悪人の新面」を、彫み上げるまでは永遠に、彫まなければならないのであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「極重悪人の新面をね」「極重悪人とはどんなもの？",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "術を施している中に、極重悪人の顔を持った、男か女かに会いたいのが、妾の本当の希望なのだが、悪人がこの世にないとすれば、そういう顔の持ち主とは、永久会うことは出来ないかも知れない」　鑿の鈍るような気持ちがした。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「極重悪人というような言葉は、内容のない形容詞で、そんな人間はこの世になく、自然そんな人相の、持ち主などもないのかもしれない。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極重悪人の人相がなければ、極重悪人の新面を作り出すことは出来そうもない。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな極重悪人とても。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "極重悪人だというので、ワイワイ追いかけて来たから淫仙先生も止むを得ず屍体を抛棄して、山の中に姿を隠したが、もう時候は春先になっていたのに、二三日は、その背中に担いだ屍体の冷たさが忘れられなくていくら火を焚いても歯の根が合わなかったという」「よく病気にならなかったものですね」「ウン。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞　私は極重悪人です。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも自ら極重悪人と感じたのである。",
              "citation": {
                "source": "善くならうとする祈り",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞が自らを極重悪人と認めたのもこの素質あればこそである。",
              "citation": {
                "source": "善くならうとする祈り",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもみずから極重悪人と感じたのである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞がみずからを極重悪人と認めたのもこの素質あればこそである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿弥陀如来はいかなる極重悪人でも、ことごとくこれを極楽に摂取するというのである。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧仏教によって毫も顧みられなかった殺生者の如き、いわゆる極重悪人の輩でも、阿弥陀如来は救うて下さる。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……極重悪人」　追って出た若い武士の叫びであった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……宮家の御首級いただこうとな※　……不忠、大逆、極重悪人め！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謀反人の極重悪人、さようなものの妹｜風情と恋語りした昔思えば、情けないとも口惜しいとも、言葉交わすも今限り、えい退きおろう！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私は斯ういう極重悪人ですから、この上何んな責苦を受けても辛抱します」「悪人でも何でもありません。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天は何ぜなれば揃いも揃った極重悪人に、かくも美わしき肉体を附与し給うたのであろう。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが国家の刑罰というものは、如何なる極重悪人に対しても、なるべく痛くない様に首を絞めて、くびり殺すのがせいぜいだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に比類なき極重悪人である。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
