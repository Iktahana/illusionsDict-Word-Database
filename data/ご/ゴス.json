[
  {
    "uuid": "baa3ec33-e84f-58b3-b40e-b2ce146b976e",
    "entry": "呉須",
    "reading": {
      "primary": "ごす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gosu porcelain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　この呉須の吹きかけの湯のみは十年｜前に買つたものである。",
              "citation": {
                "source": "わが散文詩",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜繪付といつて鐵やコバルト（呉須）などで器に文樣を描き其上から釉をかけたのもある。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴス（呉須、呉洲、の字を用ふ、藍繪のこと）の發色が明代のものは堪らなく味がいゝ。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤繪物も案外日本に遺品が多い、案外といふより所謂呉須赤繪鉢の如き、支那になくして日本にのみ存在するといつてよい。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには青磁、信楽、唐津、朝鮮刷毛目、古瀬戸、赤呉須等略一通りは揃っている。",
              "citation": {
                "source": "なぜ作陶を志したか",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にわが懐石料理に尊重する器具の例を挙げるならば、染付の各種、青磁万体、呉須赤絵、金襴手類などは、残らず中国の食器として生まれたものである。",
              "citation": {
                "source": "料理と器物",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山二郎から焼物を教わってまだ間もない頃、鎌倉で美事な呉須赤絵の大皿を手に入れた。",
              "citation": {
                "source": "千年の時差",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青絵というのは、染付のことで、呉須土で描いた南画めいた構図で、よく寒山拾得のような人物や山水などが、達筆に密画でなく描かれていた。",
              "citation": {
                "source": "九谷焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉須は非常にむつかしいのだそうで、これで当時一家をなしてる人はなかったようだ。",
              "citation": {
                "source": "九谷焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが一度古く出来た大鉢やいわゆる呉須茶碗等の失透釉のものに来ると、すばらしい美しさである、骨もある腰も強く、すべてが豊である。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の人はそれを「呉須茶碗」とか「ぼてぼて茶碗」とか呼ぶ。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に呉須（菁華）がはいっていないから――即ち呉須を用いずに、先ず白い生地器体を拵えて、その上絵として花鳥を描いたものである――だから、天啓でないように言うものもあるかも知れない。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで呉須でないため、南京赤絵という特別な名が出来たわけだが、呉須がなくとも時代的に区別せば天啓であることに変りはない。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年）呉須水鳥火入れ　古染付と言うものに二つの区別がある。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一は染付と言うけれども、一は通り名を呉須と称している。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の玄人筋でも、どうかすると呉須だ染付だと、物を前にして論じ合ってることが間々ある。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉須はどちらかと言えば下手である、と。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "染付は丁寧に造られ、絵もまた精密に描けているが、呉須の方は土の仕事からが粗造であって、絵付けもまた荒っぽい、良く言えば無造作に描かれている。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "染付は「高価的」作意に忠実だが、呉須は「安物的」に無邪気だ。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "製作率から考えて見ても、染付百個作る時間で、呉須なら五百個作れるかもわからないところのものである。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、染付が官窯の優品だとすれば、呉須は民芸の部類に属するかも知れない。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、茶が興って三、四百年来、茶人という美術鑑賞に優れたグループは、趣味上、実用上、染付と呉須いずれを喜んだかを見ると、呉須の方を上座に置いて尚んでいたようである。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉須は全く自由に作られ、自由に描けている。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを先刻チャンと知ってかかって、呉須の方を上座に置いた先輩の措置は誤りがない。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび私は、すごすご出発点に引返して、全身くたくたに疲れ、ぜいぜい荒い息を吐きながら、スタートラインに並んだ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまちには、よく似た路地が蜘蛛の巣のように四通八達していて、路地の両側の家々の、一尺に二尺くらいの小窓小窓でわかい女の顔が花やかに笑っているのであって、このまちへ一歩踏みこむと肩の重みがすっと抜け、ひとはおのれの一切の姿勢を忘却し、逃げ了せた罪人のように美しく落ちつきはらって一夜をすごす。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い妻の機嫌を取り、女房の尻に敷かれ、猥褻な性的遊戯をして日を暮す以外に、人生に向つて意欲する何の理想もなく野心もなく、無為劣等な動物的人生をすごすことが、現代大衆やサラリイマンの理想とすれば、これほど陰鬱な梅雨時の社会はない。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手を、よごすのがいやなのさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁はすごすごと小石をまた懐へ入れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると少年は苦痛な顔をして受取りもせず、踵を返してすごすごと他の店先へ掃きに行った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
