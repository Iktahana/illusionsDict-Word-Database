        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "向うからまた坂じゃ、今度は上りさ、ご苦労千万。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　婦人は炉縁に行燈を引附け、俯向いて鍋の下を燻していたが、振仰ぎ、鉄の火箸を持った手を膝に置いて、（ご苦労でござんす。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の方にはまだ一枚扉があって、大きなかぎ穴が二つつき、銀いろのホークとナイフの形が切りだしてあって、「いや、わざわざご苦労です。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ギイギイ、ご苦労だった。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやどうもご苦労さまでございます。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そううまくは行かないサ、ハハハハ、イヤそんなら行って来ようか、ご苦労な話だ、』と江藤が立ち上がろうとする時、生垣の外で、『昨夜またやったよ、聞いたかねもう。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、先生、今晩は、ご苦労さまでございます。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやどうもご苦労をねがひました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じつに永らくご苦労だつた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の方にはまだ一枚扉があつて、大きなかぎ穴が二つつき、銀いろのホークとナイフの形が切りだしてあつて、「いや、わざわざご苦労です。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ギイギイ、ご苦労だつた。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "入らつしやいと云ひながら好く視ると、どの人も覚えのある顔で、半月ほど前にこゝらへ来て、測量をしたり杭を打ち込んだりして行つた復興局の人達でしたから、わたしも商売柄、先日はご苦労様でしたとか何とか挨拶をして、さてお誂へを訊くと、サラダか何かのあつさりしたもので、ビールを飲ませろと云ふんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつァはご苦労だったのォ」といって、和太郎さんは牛車から下りもせずに、家の方にいってしまいました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてと、ご苦労を掛けた提灯を、これへ置くか。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれをご苦労ながら持て来て下さい。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は、雨が降りますのに、ご苦労でしたね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご苦労、ジョン、ふたりで大丈夫だ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "路之助の姉芸妓が、おおしんど、か何かで、肩へ色気を見せたのですが、「えろう遅うなって、ご苦労え、あのな、ついそこで、いえ、あのな、むこうへ、……境はん。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでご苦労なことに、教育漢字のそれぞれが何年で教えられるかを暗記してチェックをかける。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この初代イージーワードという代物は、使う側も大変にご苦労であったが開発する側も骨が折れたに違いない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな値段でマシンをつかまされたＴ田も哀れだったが、エルゴソフトも実際ご苦労だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそれは遠方のところをご苦労さまで……それはあのなくなったは気違いのことでしょうな」「さようでございます。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "善右衛門さんからよろしくと申しましてございます」「まことにはやご苦労さまに存じます。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に話したいことがあるから、ご苦労ながら引き返してもらいたいという口上を持って来たのである。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご苦労様、願います」と残る者は二人にいいながら、タラップまで見送った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アア、ご苦労様」藤原は言った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご苦労さまね」　しんみりおっしゃった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご苦労だが、もう十分間そうして手をあげて、そこにじっとしていて下さい。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなさんご苦労さま。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ごほうじが　すむと、だんかの　ごしゅじんは　すました　かおで、「はい、ごくろうさま。",
              "citation": {
                "source": "こぞうさんの　おきょう",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
