        "examples": {
          "standard": [
            {
              "text": "指定のゴミ袋を使わないと回収してくれないから、コンビニで買ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大掃除をしたら、ゴミ袋が10枚以上もパンパンになってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ゴミ袋が破れて中身が飛び出さないよう、二重にして縛った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "高志はなにもいわず、ゴミ袋にメロンの皮と紙の皿を放りこみ、令子は果物ナイフを鞘にしまい、まな板をビニール袋に入れた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "年齢が加って、社会的な体面のようなものが出来ると、ゴミ袋はいつしか尨大なものになって、つまりはゴミ袋をどうやらころがしてゆくのが日々の実体みたいなところを生じる人さえあるのだから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
