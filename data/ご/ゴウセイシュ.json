        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（氏がいやに大きな聲を出したのは、家を出る時一寸引掛けて來た合成酒のせゐに違ひない）マリヤンが今度お婿さんを貰ふんだつたら、内地の人でなきや駄目だなあ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（氏がいやに大きな声を出したのは、家を出る時ちょっと引掛けて来た合成酒のせいに違いない）マリヤンが今度お婿さんを貰うんだったら、内地の人でなきゃ駄目だなあ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの酒は、あまり感心しませんなあ」「そ、そんなはずは……ごほん、ごほん」「どうも、感心できませんや、砒素の入っている合成酒はねえ。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで一盃あれば結構な話であるけれど、三月から十一月までに、ただの一回、僅かに二合の合成酒が配給されたのみ。",
              "citation": {
                "source": "岡ふぐ談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あったら、合成酒でない方が願いたいよ。",
              "citation": {
                "source": "にぎり飯",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あつたら、合成酒でない方が願ひたいよ。",
              "citation": {
                "source": "にぎり飯",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日同様ザルソバと合成酒です。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、合成酒でしょう。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
