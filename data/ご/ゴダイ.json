  {
    "uuid": "79e3e063-0ba9-5afd-8c69-528e89e7950c",
    "entry": "五代",
    "reading": {
      "primary": "ごだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Five Dynasties (of China; 907-979)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……男振は音羽屋（特註、五代目）の意氣に、團十郎の澁味が加つたと、下町の女だちが評判した、御病氣で面痩せては、あだにさへも見えなすつた先生の肩へ、……あゝ噛りついた。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○八月、市村｜家橘改名して五代目尾上菊五郎となる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十月十三日、五代目坂東彦三郎、大阪に客死す、四十六歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月十二日、五代目市川門之助死す、五十八歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、中村福助は養父の名を継ぎて五代目中村芝翫と改名し、歌舞伎座の中幕に「楼門」の石川五右衛門を勤む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○二月十八日、五代目菊五郎死す、六十歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○この興行より市村家橘改名して、十五代目市村羽左衛門となる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月八日、五代目市川寿美蔵死す、六十二歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十二年（己酉）　一九〇九○二月、歌舞伎座にて五代目菊五郎追善興行。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村芝翫は五代目歌右衛門と改名。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞伝上人様は、このお寺の中興開山、五代目の上人様でございまして、――」と、またもや長い説明が続く。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」伏して昭穆を案ずるに、将門は已に栢原帝王五代之孫なり、たとひ永く半国を領するとも、豈非運と謂はんや。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の五代の祖、川那子満右衛門の代にこんなことがあった……。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに道修町の薬種問屋へ雇われたが、無気力な奉公づとめに嫌気がさして、当時大阪で羽振りを利かしていた政商五代友厚の弘成館へ、書生に使うてくれと伝手を求めて頼みこんだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五代は丹造のきょときょとした、眼付きの野卑な顔を見て、途端に使わぬ肚をきめたが、八回無駄足を踏ませた挙句、五時間待たせた手前もあって、二言三言口を利いてやる気になり、「――お前の志望はいったい何だ？",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うはははは……」　笑いやんで、五代は、「――帰れ」　と、言った。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の垂仁天皇のお言いつけによって、常世国へたちばなの実を取りに行ったあの多遅摩毛理は、日矛の五代目の孫の一人でした。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新車は後の門之助、家橘は後の五代目菊五郎である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「香以の友であった永機はまた九代目市川団十郎、五代目尾上菊五郎とも交が深かった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛は四谷の忍町に五代つづきの質屋を営んでいて、女房お此と番頭庄右衛門のほかに、手代三人、小僧二人、女中二人、仲働き一人の十一人家内で、おもに近所の旗本や御家人を得意にして、手堅い商売をしていた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢が天下を定めてからすでに五代・百年、始皇帝の反文化政策によって湮滅しあるいは隠匿されていた書物がようやく世に行なわれはじめ、文の興らんとする気運が鬱勃として感じられた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏直を入れて、後北条は五代になるのだ。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣屋は塗籠め、小路を割り、人数繁きこと、稲麻｜竹葦の如し」　と『北条五代記』にある。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも五代の積威を擁して八州の精鋭を集めただけあって、上方勢が攻めあぐんだのも無理はない。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ば一生涯を送るとも、かつて退屈の気あるべからず」と『北条五代記』にあるから、此又相当なものである。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良時代は、大化改新後に於けるわが国の統一国家としての活動期であるが、第四十五代｜聖武天皇の御代に至つて、その文化は「咲く花の匂ふが如く」燦然と光りかゞやいたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "側用人は、初めは将軍に近侍して老中へ取次役をしてゐたのであるが、後には五代綱吉の時の柳沢吉保のやうに、政事に参与して、権勢を振つた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸幕府の衰亡　江戸幕府は、三代将軍家光に至つて、あらゆる機構が整ひ、武家政治は完成された形を示したが、五代将軍綱吉に至つて、幕府の太平が謳歌される傍ら、綱吉の偏執的な性格や、生類｜憐愍令や、悪貨鋳造などからの影響もあつて、太平の余弊たる享楽主義が天下を風靡した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアは五代綱吉時代にカムチャツカを収めたが、つひに我が千島列島を侵し、女帝エカテリナは日本語の研究をやらせてゐたといふくらゐだから、北海道を手に入れようと窺つてゐたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その長三郎が当年｜二十歳になりますから、おかみさんは三十八で、容貌も悪くなく、年よりも若く見える方でございます」　治兵衛は半七の問いに対して、伊豆屋は四谷坂町に五代も暖簾をかけている旧い店で、屋敷方の得意さきも多く、地所家作も相当に持っていて身上も悪くない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            }
