    "definitions": [
      {
        "index": 1,
        "gloss": "the five elements (in Japanese philosophy: earth, water, fire, wind and void)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "凡、その地をわかちて、五大州となす。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "総称して五大（地大は堅固の性あり、水大は洗浄の性あり、火大は成熟の性あり、風大は破壊の性あり、空大は自由性あり）といっております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に五大は五智であると認めます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "※がかりは澄ましたもので、「家内安全、まめ、そくさい、商賣繁昌、……だんご大切なら五大力だ。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土手の霞暮れんとして、櫻あかるき三めぐりあたり、新しき五大力の舷の高くすぐれたるに、衣紋も帶も差向へる、二人の婦ありけり、一人は高尚に圓髷ゆひ、一人は島田艷也。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその小女から、帆柱を横たえた和船型の大きな船を五大力ということだの、木履のように膨れて黒いのは達磨ぶねということだの、伝馬船と荷足り船の区別をも教えて貰った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前にぐいと五大力の苫を葺いた舳が見え、厚く積った雪の両端から馬の首のように氷柱を下げている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日、辛卯、南京十五大寺に於て、衆僧を供養し、非人に施行有る可きの由、将軍家年来の御素願なり、今日京畿内の御家人等に仰せらると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しわが手に五大洲を描けるの地図あらば、焼いて粉にして民と共に、万石の酒に呑まむかな』と。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "躍る心を推し鎮めて今｜暫し五大洲上を見渡せ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一大隊長　　篠原　国幹第二大隊長　　村田　新八第三大隊長　　永山弥市郎第四大隊長　　桐野　利秋第五大隊長　　池上　四郎第六大隊長　　別府　晋介　大隊長は凡て、名にし負う猛将ぞろいである。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その声の調子には、ヨーロッパの五大国の人間にさえ聞きなれたところが少しもなかったんだぜ！",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いでやと毛布深くかぶりて、えいさえいさと高城にさしかかれば早や海原も見ゆるに、ひた走りして、ついに五大堂｜瑞岩寺渡月橋等うちめぐりぬ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吟庵は閑にして俳士髭を撚るところ、五大堂は寂びて禅僧尻をすゆるによし。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに日本の肩味が広くなればなるほど、これが何で五大国の一かと重ね重ね怪しまるるほど日本人の実価が下ったように思う。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "五大堂、雄島の間に逍遙すべし。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯く勝地多く、尚ほ他に舊蹟も多きが中に、余は特に南湖、感忠銘、關山、白河故關蹟、甲子温泉を擧げて、白河の五大勝と云はむとする也。",
              "citation": {
                "source": "白河の七日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "四天狗巖、五大堂、釋迦堂、南院の堤を山寺の四大觀と稱す。",
              "citation": {
                "source": "遊羽雜感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十余州を踏破するの自由は、我らの志を満足せしむる能わざるが故に、我らは五大洲を周遊せんことを願えり、これ我らが宿昔の志願なりき。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一層大きいなら、日本の話より五大州の話、ないしは天文地文の話、地獄極楽の話などの方が、効能がありはしませんかな。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次は怒り物といって忿怒の形相をした五大尊、四天、十二｜神将の如き仏体をいう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "五大洲の彼に圧せらるる形勢は既にその四所に蔓延し、一塊の乾浄土を剰すは、ただ僅にわが黄人の故郷、亜洲あるのみ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルゲントウは後方に主力を止め、攻撃に使用した兵力は五大隊半に過ぎなかった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "五大政党の政策についての討論から始められ次第にテーマを拡大した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃声の盛んに起った時、第五大隊の医官小野道秀が病を発した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "活差別相は「ドラマ」の體を觀るに國を萬民としてみる如く、地球を五大洲としてみる如くすることにて、活平等相はおなじ體を觀るに國を一國としてみる如く、地球を一地球としてみる如くすることなり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "我黨は廼ち五大洲を睥睨して彼の千魂萬魂といはれたりし怪物、わが日の本の鴎外將軍が審美の利劍に劈かれて、つひにこそそが正體をあらはしつれと、洽くとつ國びとにのらまくす。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時磐の身分は「静岡県貫属士族」で、其戸籍は「静岡第五大区百姓安右衛門方同居」であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく南洲の偶成七絶に、大聲呼酒坐高樓　　　　大声酒を呼んで高楼に坐し、豪氣將呑五大州　　　　豪気将に呑まんとす五大州。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろごだごだいたしました。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
