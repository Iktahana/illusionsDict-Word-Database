    "definitions": [
      {
        "index": 1,
        "gloss": "kimono fabrics shop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
