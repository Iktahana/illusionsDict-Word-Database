    "definitions": [
      {
        "index": 1,
        "gloss": "five cardinal sins (killing one's father, killing one's mother, killing an arhat, shedding the blood of a Buddha, causing a schism within the sangha)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "親鸞　たとい十悪五逆の罪人でも。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「罪は十悪五逆の者。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "十方の衆生至心に信楽して、我が極楽浄土に生れんと欲せば、ないし十念せよ、五逆罪と正法を誹謗したものとのほかは、ことごとく往生せしめるという誓願を、阿弥陀如来は持っておられるというのである。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおその極楽には九品の階級があって、たとい五逆十悪の如き諸の不善の業を具している程のものでも、死ぬる時に善知識に遇うて妙法を聞き、念仏すれば、下品下生の極楽へは生れる事が出来るとさえ説いているのである。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏無間、禅天魔、真言亡国、律国賊とは、彼のいわゆる四個の格言であるが、中にも念仏者は正法を誹謗するもので、阿弥陀如来の誓願にも、五逆と正法誹謗者とは除外されているのであるから、彼らは無間地獄へ落ちて、永劫浮ぶ瀬はないというのである。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五逆罪の一つじゃぞ！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして彼を苦しめたさまざまの欲望、情熱、憎悪などは、「十悪五逆」として仏の前に懺悔せられたのである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしまだ死ぬ時も来ない親に身をなげさせるのは五逆罪であろう。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミダ如来は西方浄土を荘厳し一念十念をもきらわず十悪五逆罪をもみちびこう」と云う。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "義王「ほんとうに死ぬ時も来ない親に身を投げさせるのは五逆罪うたがいがない」と云って身をなげるのを思いとどまって二十一で様をかえてしまった。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のためここで父上が命を失われるのは、五逆罪となりましょう、私を捨ててどうかお早く落ちて下さい」「小太郎よ、もうわしは決意したのだ」　というと、息子の傍らに腰を下して動こうとはしなかった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "親殺しの主殺し、五逆五悪の大罪人小三郎は、裸馬に乗せられて、幾十人の獄卒に護られ、罪状を書いた高札を掲げて、江戸中｜目貫の場所を引廻しの上、鈴ヶ森の処刑場に着いたのは、巳刻半（十一時）少し過ぎでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "刑場の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "親殺しの主殺し、五逆五惡の大罪人小三郎は、裸馬に乘せられて、幾十人の獄卒に護られ、罪状を書いた高札を掲げて、江戸中目貫の場所を引廻しの上、鈴ヶ森の處刑場に着いたのは、巳刻半（十一時）少し過ぎでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "刑場の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥陀超世の悲願というのは、たとえ十悪の凡夫でも、五逆の大罪を犯した者でも、ひとしく慈悲をもって見、飽くまで救ってとらそうという御誓願を申したのじゃ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十悪五逆の徒にも、仏の道では救いがある。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十悪の徒、五逆の悪人でも、救いを求めれば救うてくれる慈悲光の弥陀尊仏に対面させてから後、城太郎に会わせてやって晩くはない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
