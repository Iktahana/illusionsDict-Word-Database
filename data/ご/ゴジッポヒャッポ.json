    "definitions": [
      {
        "index": 1,
        "gloss": "six of one, half a dozen of the other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
