    "definitions": [
      {
        "index": 1,
        "gloss": "messy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腹はむしゃくしゃすると同時に堪えぬなつかしさの痛み、悔いないでよいことへの悔い――そういったことでごちゃごちゃになっていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "背嚢や、毛布や、天幕や、外套が、乱雑に畳まれて、ごちゃごちゃと並べられていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　詰襟の善人らしい支那人は、日本語と、支那語を、ごちゃごちゃに使った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本建ての屋根瓦のごちゃごちゃした上に西洋風の塔が取って付けたように抽き立っていた。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不思議な意図も慧鶴青年の胸に蓄えられたまま、人間慾と超人慾とのごちゃごちゃに混った青年慧鶴は、清水と富士をあとに残し、何事かを極める為に美濃ノ国へ旅立ったのである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中のどれが一番、重大な原因であるか判らないほど、ごちゃごちゃのものに追い立てられて彼は清水を急いで離れて行ったのであった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃古靴を売る事は……長靴は烟突のごとく、すぽんと突立ち、半靴は叱られた体に畏って、ごちゃごちゃと浮世の波に魚の漾う風情がある。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山羊に追いついてからふりかえって見ますと畑いちめん紺いろの地平線までぎらぎらのかげろうで百姓の赤い頭巾もみんなごちゃごちゃにゆれていました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはその間にすっかり考えをまとめようと思いましたが、何もかもごちゃごちゃになってどうしてもできませんでした。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして昔はそのへんには熊がごちゃごちゃ居たそうだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ目入道、狐、狸、猫も鼬もごちゃごちゃと小さく固まっていたが、松崎の殺進に、気を打たれたか、ばらばらと、奥へ遁げる。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の中が、すっかり、ごちゃごちゃになっていました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "木更津汐干の場の色彩はごちゃごちゃして一見｜厭になりました。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、芝の根や、草の葉や、くさった木ぎれなどが、ごちゃごちゃはいっていましたが、でもところどころ、白いものがきらきら光っています。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "樟脳とナフタリンの匂いのするスカートと花模様の袂がごちゃごちゃに玄関で賑わって六日目の朝、妹たちが到着した。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動小屋の絵看板がごちゃごちゃと並んだ明るい新世界の通りを抜けると、道は急にずり落ちたような暗さで、天王寺公園だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物園前で市電を降り、食物屋や雑貨屋がごちゃごちゃと並んだ繁華な大門通りを抜けて、大門の近くで右へ折れると、南海電車の萩の茶屋の停留所の手前に、「ヒチ、大西」　と青い暖簾がかかっていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、粘土細工、積木細工、絵草紙、メンコ、びいどろのおはじき、花火、河豚の提灯、奥州斎川孫太郎虫、扇子、暦、らんちゅう、花緒、風鈴……さまざまな色彩とさまざまな形がアセチリン瓦斯やランプの光の中にごちゃごちゃと、しかし一種の秩序を保って並んでいる風景は、田舎で育ってきた私にはまるで夢の世界です。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ雁次郎横町というのか判らないが、突当りに地蔵さんが祀ってあり、金ぷら屋や寿司屋など食物屋がごちゃごちゃとある中に、格子のはまった小さなしもた家――それが父の家でした。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動小屋の絵看板がごちゃごちゃと並んだ明るい通を抜けると、道はいきなりずり落ちたような暗さで、天王寺公園であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内のあちこちに、際限のない不規則さでごちゃごちゃに入り交って、無数の腰掛けと机とがあった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "文を書いてゆくうちに、当然句読点をつけなければならんような文意の切れるところへくると、そういう連中はとかく、その場所で普通より以上に記号をごちゃごちゃにつめて書きがちなものだよ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一方の者がまず――町の名でも、河の名でも、州の名でも、国の名でも――つまり、いろんな色のついたごちゃごちゃした地図の表面にあるどんな名でも言って――相手に捜させるんだ。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョッキや、水差しや、籠入りガラス罎などが、ごちゃごちゃに押し合いへし合いしながらまざり、柳細工の細口罎が厚いガラス罎とやけにぶつかる。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ビデオプレイ』という雑誌で連載化されたこのシリーズでは、パーソナルコンピューターを使ってパターンを描き出したり、立体映像を作ったり、時には磁石で画面をこすって、色合いをごちゃごちゃにしてしまうといった乱暴な楽しみ方を伝授していきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野はそのごちゃごちゃした頭をいただいて肉屋の前に立った。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "別にすると、なぜ別にする、なぜごちゃごちゃにして置かないかと云う疑問が起る。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらがごちゃごちゃに植わっている様な狭い畑もあった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦や管のプレイヤーまでいる、ごちゃごちゃしたスタジオに、ミック・ジャガーが坐っていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その横には、これも眼玉の青い唇の真赤な白人の若い女が、ぺたりとくっついていて、前の卓子には、酒壜やコップがごちゃごちゃ並んでいた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
