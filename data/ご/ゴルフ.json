        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "洋服のときはゴルフパンツである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしとにかく一度ゴルフ場へお伴をして見学だけさせてもらおうということになって、今年の六月末のある水曜日の午前に二人で駒込から円タクを拾って赤羽のリンクへ出かけた。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフもだんだん見ているとなかなか六かしい複雑な技術だということが少しは分って来る。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日Ｍ君Ｎ君の解説を聞いたことだけから考えても、すべての芸道に共通な要領がゴルフの術にも要求されていることが分る。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代的のものでもゴルフの外に庭球野球｜蹴球籠球排球などがあり、今は流行らぬクリケット、クロケーから、室内用にはピンポン、ビリアードそれから例のコリントゲームまである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、ゴルフ競技会の前夜は、貴男は敬虔な態度で夜を徹して妾の小指を保管すること。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　アラビア丸――怪奇な青色の女、デッキ・ゴルフ、七色の弾丸のような意志が接触する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "また絶えず石炭を積み込む荷揚ロープの緩急が打ち寄せる波の音と和して、消燈された甲板のゴルフ棒の蔭で船員と港の土人街の女とが抱擁して別離を悲しんでいる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ラグビー争闘の場合の靴の跡を刺繍され、……野球における華美な盗塁と、……水球のときの潜水と、……ミニチュア、ゴルフの墜死と、……ボクシングにおける残酷な、……マットの中の死を。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフのなんとかいうあの棒などもそうである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が上鉱を掘り出す程、肥って行くのは、自動車を乗りまわしたり、ゴルフに夢中になっているＭの一族だ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の本、山登りの本、唯物論的弁証法の本、ゴルフの本、なんでも無いものはないように見える。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばゴルフの大家｜梅木鶴吉という人があるとする。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして書店の陳列棚に「ゴルフの要訣、梅本鶴吉著」という本があったとすると、十人が九人まで「本」を「木」と読んでその本を買って来るであろう。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフについては自分自身には少しの体験も持ち合わせないのであるが、Ｔ氏の話によるとあれのクラブの使用にもやはり自由なる手首の問題が最も大切だということになっているそうである。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚後一ヶ月目の年の暮から、私をこの海岸の旅館に寄越して置いて、自分は年始廻りやら、正月の交際を済まして五日の日に宿へ来た彼は、割合に荷嵩な手荷物やらゴルフの道具やらを持ち込んだ。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、雄吉君が桃色みたいな派手なゴルフ服を着て、鼻眼鏡をかけてやって来ました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子もゴルフ用の鳥打ちや、ビバや、お釜帽を次から次に冠らせられた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣魚とか、ゴルフとか、美術品の蒐集などという趣味娯楽は、私の全く知らないところである。",
              "citation": {
                "source": "秋と漫歩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんと二人で砂浜へ裸足で飛んで出て、かけっこをしたり、相撲をとったり、高飛びをしたり、三段飛びをしたり、ひるすぎからは、ゴルフなるものをはじめた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフと言っても本式のものではない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを野球のバットでゴルフみたいなフオムで打って、畑の向うの約百｜米ばかり離れた松の木の下の穴に入れるのである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに感謝してむしゃむしゃ喰べながら、またゴルフをつづける。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごはんを食べて、それからすぐに二人で砂浜へ出てゴルフを始めたが、最初の時ほど面白くなかった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフの最中に、別荘の隣りに住んでいる生田繁夫という十八になる中学生が、「こんにちは」と言ってやって来て、こちらが、「こんにちは」と挨拶を返したらすぐに、「この代数の問題を解いて下さい。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフをつづける気力も無く、僕たちは悲しい冗談を言い合いながら、家へ帰った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面の芝生で、ところどころに低い灌木の繁みがあつたり、小さい沼があつたり、土地の起伏もゆるやかで、一昔前だつたら都会の人たちは、絶好のゴルフ場とでも言つてほめたであらう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフパンツはいて、葡萄たべながら飛行機に乗っていると、恰好がいいだろうな。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフパンツのようである。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
