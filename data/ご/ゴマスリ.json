        "examples": {
          "standard": [
            {
              "text": "彼は上司にごますりをして、気に入られようとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そんなごますりばかりしていても、実力はつかないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あいつのごますりには辟易するね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "やかましい瀬戸黒茶碗はごますりと一緒に焼かれていたのです。",
              "citation": {
                "source": "瀬戸・美濃瀬戸発掘雑感",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "……恥知らずの、碌でなしの、わるものの、ごますりめ！",
              "citation": {
                "source": "マリ・デル",
                "author": "MARI D'ELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか二年前は、畜舎の奴隷、ごますり労働者だった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに兄のレフェニュウがあなたのような人にそんなことをするなんて、びっくりです」　フェンウィックがごますり声で言った。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
