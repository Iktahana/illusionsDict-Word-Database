        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "リゼットの疲れた胃袋に葡萄酒がだぶついて意地の悪い吐気が胴を逆にしごいた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計屋の店には明るくネオン燈がついて、一秒ごとに石でこさえたふくらふの赤い眼が、くるっくるっとうごいたり、いろいろな宝石が海のやうな色をした厚い硝子の盤に載って星のやうにゆっくり循ったり、また向ふ側から、銅の人馬がゆっくりこっちへまはって来たりするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計屋の店には明るくネオン燈がついて、一秒ごとに石でこさえたふくろうの赤い眼が、くるっくるっとうごいたり、いろいろな宝石が海のような色をした厚い硝子の盤に載って星のようにゆっくり循ったり、また向う側から、銅の人馬がゆっくりこっちへまわって来たりするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計屋の店には明るくネオン燈がついて、一｜秒ごとに石でこさえたふくろうの赤い眼が、くるっくるっとうごいたり、いろいろな宝石が海のような色をした厚い硝子の盤に載って、星のようにゆっくり循ったり、また向こう側から、銅の人馬がゆっくりこっちへまわって来たりするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもはちらっとうごいたようでした。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき風がどうと吹いて来て教室のガラス戸はみんながたがた鳴り、学校のうしろの山の萱や栗の木はみんな変に青じろくなってゆれ、教室のなかのこどもはなんだかにやっとわらってすこしうごいたようでした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計屋の店には明るくネオン燈がついて、一秒ごとに石でこさへたふくろふの赤い眼が、くるつくるつとうごいたり、いろいろな寶石が海のやうな色をした厚い硝子の盤に載つて、星のやうにゆつくりめぐつたり、また向う側から、銅の人馬がゆつくりこつちへまはつて來たりするのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもはちらつとうごいたやうでした。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで王女は、好奇心がうごいたので、遊歩場であうとさっそく、この外国紳士に、話しかけました。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、少し面をあげて鬚をしごいた。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まず都へ上って年を経て、やがて国許へ立帰る侍が、大路の棟の鬼瓦を視めて、故郷に残いて、月日を過ごいた、女房の顔を思出で、絶て久しい可懐さに、あの鬼瓦がその顔に瓜二つじゃと申しての、声を放って泣くという――人は何とも思わねども、学問遊ばし利発な貴女じゃ、言わいでも分りましょう。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから順慶自身は、光秀の勧誘に、心うごいたが、家老杉倉右近、島左近の二人が主人を諫めて出陣せしめず、ただ人数だけを山崎の対岸なる八幡の洞ヶ峠に出した。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生のうち、たったいちど、思わず右手が一尺うごいたからって、それが手癖の悪い証拠になるのでしょうか。",
              "citation": {
                "source": "燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅は時々両脚で両翅をしごいた。",
              "citation": {
                "source": "若い作家と蠅",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "行司、なにをまごまごいたしおるか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうほ、絵里子はね、――」　おうほと、博士独特の妙な感歎詞をなげるごとに、博士の頤髯がごそりとうごいた。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しごいた太刀の音である。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さよう」というと朱舜水、雪白のあごひげをしごいたが、「不快な音色でございましたよ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして素早く、そのグニャリと垂れ下った女の手の皮を握ると、手袋を嵌めるあの要領でスポリと逆にしごいた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざわざわと停車場の出口にあたって少数の人がうごいたように思った。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、傍の時計屋の入口で手を腰に当てて厳しい顔で此方を見張っている彼女が母親だと判ると、俄にわざとらしく空咳をしたり髭をしごいたりして、歩き始める。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルスタムは、考え惑った風で、手に力を入れ白髭をしごいた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、これから何か始りそうで、そわそわしたものがわたしのなかで揺れうごいた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、これから何か始まりさうで、そわそわしたものがわたしのなかで揺れうごいた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛いく胸を張り腰を据えて、如何にも優しい身ごなしで、油をぬったり、一枚一枚の羽をしごいたりして居る雌鴨の様子を、わきからだまって見て居るうちに、雄鴨はどうしても離れられない様な愛着を感じた。",
              "citation": {
                "source": "一条の繩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今思い出しても涙が出るよ」　呑兵衛ドクトルも眼を赤くして関羽鬚をしごいた。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら感心にまだこの紐がちゃんとしている」由子は一種の愛惜を面に表して、藤紫の組紐をしごいたりしたが、やがて丁寧にそれを畳んで、お清さんの前へ置いた。",
              "citation": {
                "source": "毛の指環",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をうつすと、テーブルの脚のところに何本もしごいた拷問用の手拭がくくりつけてある。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸になった彼女は花束の代りに英字新聞のしごいたのを持ち、ちょっと両足を組み合せたまま、頸を傾けているポオズをしていた。",
              "citation": {
                "source": "夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗い灯かげの下では、人は影のように揺れうごいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
