[
  {
    "uuid": "654f81ee-7d5f-5bce-9dd2-cc795f3b77c6",
    "entry": "後家",
    "reading": {
      "primary": "ごけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
