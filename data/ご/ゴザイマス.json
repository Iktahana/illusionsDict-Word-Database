    "definitions": [
      {
        "index": 1,
        "gloss": "to be",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ何か強いて申上げようとすれば次のような事で御座います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この青い所は海で……このとび色をして居る所が山で御座います。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此樽の中のセメントは何に使われましたでしょうか、私はそれが知りとう御座います。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのおっかさんがきまして、民や、決して気を弱くしてはならないよ、どうしても今一度なおる気になっておくれよ、民や……民子はにっこり笑顔さえ見せて、矢切のお母さん、いろいろ有難う御座います。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姐さん草鞋があるかい」　「え、御座います」　「そうかい、じゃ一つくんな」　「はい」　その時、通りかかった……これも渡世人の旅人が三人。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "七五郎が、　「へえ、武井の御貸元で御座いますか、実は折入って……」　吉兵衛、それと見て、　「何だ、手前七五郎じゃねえか。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の用だ」　「これは都田村の親分で御座いますか」　安五郎が吉兵衛に、　「吉兵衛、お前の知ってる人か」　「へえ、この近在の村の若い者で御座いますよ」　「そうか、七五郎さんとやら、一体俺に何の話か知らねえが、丁度今将棋の面白え処だ、もうじき済むから済んでから話を聴こう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方が清水港の長五郎と云う方で……へえ長五郎さん、向って右が武井の御貸元、左が都田村の吉兵衛親分で御座います」　次郎長が安五郎に、　「初めてお目にかかります。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ども安の奴等もまさか此処まで追ッ掛けちゃ来めえ」　「併しお貸元、夜道は危のう御座います。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明ける迄あっしの処でお休みなすっちゃ如何で御座います」　「……そうだな。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石松、外へ向って次郎長に、　「御貸元、汚ねえ処で御座いますが、さッどうかお入んなすって……」　「あら兄さん、お客様なの」　次郎長、入って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お貸元、どうか気を悪くしねえでお呉んなせえまし、何しろ年寄りで御座いますから……」　「いや、お年寄りの怒るのも無理ァねえ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしは清水港の次郎長って、けちな野郎で御座います」　湯をくむお静「昼間の男だ」と気付く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃいませ」　「御免なすって……石松つあんのお宅はこちらで御座いますか」　「あの……兄さん今一寸留守なんですけど」　「へえ儂は駿河の清水港の次郎長の身内、大瀬半五郎と申します」　「お父っつあん、お父っつあん」　とお静、奥へ呼ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半五郎が、　「これァ石松つあんの父っつあんで御座いますか。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、手前共親分が石松つあんに色々御厄介に相成りましたそうで、親分に代りまして厚くお礼申し上げます」　と菓子包か何かを差し出して、　「失礼で御座いますが、どうかお納めなすって……」　源兵衛、考え込んでいる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "実ァ儂は急ぎの用事が御座いますので、これで失礼致します。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎長が改まって、　「さて石松、帰ったばかりの処を気の毒だが、お前に今から使いに行って来て貰い度えンだ」　「宜しう御座います。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは爺っつあんか、俺ァ都田村の吉兵衛って者だ」　「はい……」　「石松つあんとは以前からの友達だ」　「久し振りに二人で一杯やりてえと思って来たんだが……まだ帰って来ねえのか」　「石松が帰って来るので御座いますか」　「なんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の石松つあんの御宅は此方で御座いますね。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎が、Ｔ「その印籠を所持致す奴こそ敵棚倉伝八郎」　聞いた三次が「よう御座います」と引受けて、Ｔ「三日もありゃきっと探し出してお見せします」　何分よろしくと三四郎が頼む。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳兵衛、御世辞を言い乍ら「何御用で御座います？",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、心に何か決する処があってか、Ｔ「宮本先生と　御同宿致すとは　願ってもなき倖せ」　そうで御座います、と亭主。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何で御座いますか、と亭主。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまが、言いにくそうに、Ｔ「御迷惑で　御座いませんのなら」　と言って、艶な瞳で、団九郎をチラと見て、Ｔ「いつまでも　御一緒に御供が　致し度う御座いますわ」　と言われて、　団九郎、身体がゾクゾクして来た。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、ガラッと障子が開いて、風呂上りのおしまが、Ｔ「何で御座いますの　今の音は？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵が、Ｔ「今の物音は　拙者が　投げられました音」　と言われておしまが、うっとりと、　「まァＴ「お強う御座いますのね　先生は？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「助けて戴きましたのは嬉しう御座いますが」　と言って、Ｔ「隣り村へ　お嫁に行かねば　なりません」　と悲し気に、Ｔ「それが、悲しう　御座います」　と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が結婚致しましたのは、松江に来てからのことで、二十四の秋でございますから、当時としてはずいぶん遅い結婚でございました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
