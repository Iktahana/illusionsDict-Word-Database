[
  {
    "uuid": "234018e8-b8c0-50fe-aa83-a1a2a0be5af5",
    "entry": "毫も",
    "reading": {
      "primary": "ごうも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
