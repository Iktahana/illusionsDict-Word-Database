        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいゴルフ倶楽部を購入したので、早く打ちに行きたいです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドライバー、アイアン、パターなど、様々なゴルフ倶楽部を使い分けます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、お気に入りのゴルフ倶楽部を大切に手入れしています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "社長は漫遊中、某公爵と懇意になって、帰朝後も公爵を名誉総裁とするゴルフ倶楽部に入って交際を続けている。",
              "citation": {
                "source": "社長秘書",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の拡張の時にはうんと持って貰う」　と社長はゴルフ倶楽部へ商売をしに行くのである。",
              "citation": {
                "source": "社長秘書",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "医療や法律関係、学校関係、果てはゴルフクラブにいたるさまざまな業種用のアプリケーションが書きためられており、ユーティリティーやプログラム開発用のシステム、言語などにもずらりと豊富なメニューがそろっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年この町にゴルフクラブができ、私もすすめられて入会した。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "書上さんの邸内には雨の日でも夜間でも練習できるインドアの練習場があって、桐生にゴルフクラブができたとき専用の練習場ができるまでここで最初の練習をはじめた。",
              "citation": {
                "source": "ゴルフと「悪い仲間」",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "文左衛門さんはその後私の顔を見るたびに裏庭の練習場を使いなさいとすすめるが、私はかりそめにもゴルフクラブを手にとらなかった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "桐生市の主として織物業のダンナ方が集って、桐生ゴルフクラブというのができた。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は二ヶ月前に女房といっしょにゴルフクラブに入会した。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
