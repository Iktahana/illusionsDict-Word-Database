        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "話しているほうは主任で、署長はバット（ゴールデンバット。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　杜は「ゴールデンバット」ばかり吸っていた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体ゴールデンバットの箱ぐらいなり。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもそのルバシュカは、長い腕を遠くから持つて來て環を描きながらゴールデンバットだけは燻してゐた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原遊里の話も、ピンヘッド、ゴールデンバット、パイレートの煙草の香も、負ぐせのついた若鶏の話も、陸奥から出京した少年の心には同様の力を以て働きかけたものに相違ない。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その橋を渡れば、すぐカフェ・ゴールデンバットの入口があった。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘田医師は、盗みとった魔薬を悪用し、金と同じ手を用いて、カフェ・ゴールデンバットに君臨したのだった。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひまさえあると、だれかの家へ集まって、ゴールデンバットの空箱で作った啄木カルタに夜をふかしたりした。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
