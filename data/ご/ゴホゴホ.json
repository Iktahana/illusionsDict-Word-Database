          "literary": [
            {
              "text": "その松林のずうっとずうっと高い処で誰かゴホゴホ唱へてゐます。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴホゴホ声が又起りました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の坊さんはしばらくゴホゴホ咳嗽をしてゐましたが、やっと心を取り直して、又講義をつゞけました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その松林のずうっとずうっと高い処で誰かゴホゴホ唱えています。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の坊さんはしばらくゴホゴホ咳嗽をしていましたが、やっと心を取り直して、又講義をつづけました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "莨を填めては吸い填めては吸い、しまいにゴホゴホ咽せ返って苦しんだが、やッと落ち着いたところで、「お光さん、一体今度のお話の……金之助さんとかいうのでしたね？",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴホゴホ咳をしながら判座帳を出して、「旦那昨夜、塩子の祭りで人殺しがありやした」と言った。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計のチクタクばかり耳について眼はいよいよさえるばかり、時々おばあさんがゴホゴホとせき入る時は、起してお話でもしやうか、と思ふたりいたしました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴホゴホと絶え入れるように咳入って、片手がまさぐるように、枕許のハンカチへ行く。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドサ貫は何か言おうとしたらしかったが、その時ちょうど真向うからからッ風がさっと吹きつけて来て、彼はゴホゴホとせき込んだ。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴホゴホむせたが、なんとか全部飲ませた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリクソンがゴホゴホむせながら、「最強の札だ。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
