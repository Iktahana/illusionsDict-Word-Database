        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「やあ、田中さん！ご機嫌いかが？」と街角でばっぱり会った友人が声をかけてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "久しぶりに実家に電話をかけ、第一声で「お母さん、ご機嫌いかが？」と尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "隣人と顔を合わせるたびに「ご機嫌いかが」と挨拶を交わすのが習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「みなさんご機嫌いかが」　あがっていたとみえて、How do you do と Yankee Doodle がごっちゃになり、How doodle do といいかけた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんちは、あたしのワニちゃん、ご機嫌いかがなの？",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうなの、彼女はいつもちょっと芝居がかってるのよ、でね、可哀想にお父さんたら自分の宝物を持ってゆかれるのを放ってるのよ」「ご機嫌いかがですか、僕の好きなゴリオのお父さん？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、ごきげんいかがですな、玉太郎の王子さま」　という声に、おどろいて顔をあげると、もうそのときには、手のとどきそうなところにラツールの筏が近づいていた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごきげんいかがでいらっしゃいますか」　Ｆさまはあたしをごらんになってから、ママのほうへむいておっしゃった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、ごきげんいかがなの？",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも、すこし妙だと思うけれど、ひとりでに顔が笑い出して、「こんにちは、ごきげんいかが？",
              "citation": {
                "source": "キャラコさん",
                "author": "雁来紅の家",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにょうかんげえたんでえ、このおれさまに向って、ごきげんいかがですかなんてぬかしゃがって、ふてえやつだ。",
              "citation": {
                "source": "狐と猫",
                "author": "ヤーコップ、ウィルヘルム・グリム　Jacob u. Wilhelm Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お早う、ごきげんいかが」　声も少年のように、歯切れよく叫びながら、花世は大股に、こっちへ近よって来た。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
