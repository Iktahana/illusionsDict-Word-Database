    "definitions": [
      {
        "index": 1,
        "gloss": "your husband",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あなたのご主人はいらっしゃらないのですか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたのご主人は知っていないんですか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもの大事のご主人さま。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄はそんな宮子のみだらな姿勢から、ふと眼をそらしながら、「ご主人はお留守ですか。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人記者って随分あつかましいと、お思いでしょうが、でも、ぜひこちらのご主人にお眼に掛らねばならぬ急用がありましたので……」　べらべら喋りながら、腹の中では舌を出していた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、ちゃんとご主人たちのいるテーブルの上でなければ、うたいたくなかったのです。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、この家では、ネコがご主人で、ニワトリが奥さんでした。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あたしたちのご主人のおばあさんにも、聞いてごらん。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなは、ああして、ご主人の考えを狩りに連れていこうと、むかえにきたんですよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、あんまり早くとんでいってしまったものですから、ゲルダの目には、ご主人の姿は見えませんでした。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このおれが、あれのご主人だなどとは、だれも知るまいよ。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴ぬぎや、くしを持っているのは、カラーのご主人なんですからね。",
              "citation": {
                "source": "カラー",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご主人の家のかたにきまってるじゃないか！",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころは、お屋敷の中で、ビロードを張った椅子の上に寝かしてもらったり、ご主人のひざの上に抱いてもらったりしたものだよ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがご主人だった、その部屋がさ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは、わしがご主人だったんだ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのひとに、そんなご主人があるとは、実は、私もそのときはじめて知ったのである。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「規矩男さんは、ご主人に似ていらっしゃいますこと」「規矩男は主人に似てるといっても形だけなんでございますよ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今、ご主人も奥さまもお留守のことをよく申し上げて」　何となく機嫌のよくなった逸作が、持前の癖を出して若者を揶揄いかけた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの、野中のお宅のご主人は、いまは、あの野中先生なんでしょう？",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんはそれには取り合わず、改まった顔つきをして、「あの、ねえさん、すみませんがね、ここのご主人にないないお話し申したい事がございますのですけど、ちょっとここへご主人を」　と言いました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのご主人は、本郷の大学の先生をしていらして、生れたお家もお金持ちなんだそうで、その上、奥さまのお里も、福島県の豪農とやらで、お子さんの無いせいもございましょうが、ご夫婦ともまるで子供みたいな苦労知らずの、のんびりしたところがありました。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の暮、でしたかしら、奥さまが十年振りとかで、ご主人のお友達の笹島先生に、マーケットでお逢いしたとかで、うちへご案内していらしたのが、運のつきでした。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹島先生は、酒をお猪口で飲むのはめんどうくさい、と言い、コップでぐいぐい飲んで酔い、「そうかね、ご主人もついに生死不明か、いや、もうそれは、十中の八九は戦死だね、仕様が無い、奥さん、不仕合せなのはあなただけでは無いんだからね。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらご主人でもあれじゃなんぼなんでも――」　嘉六は口を噤みました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっちゃっときゃ、まあ母子心中か餓死なんです」「ご主人は」「主人は、僕の農芸大学の先輩に当る園芸家なんですが、天才肌でまるで家庭の面倒なんか見ないんです。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「まあ、お前さんは、バクダッドに住んでいながら、私のご主人さまの名を、知らないというのかい。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は私のご主人を殺して、あの天じょうからぶらさげてくれというのか。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリ・ババはモルジアナを招いて、その耳に口をつけて、「お前のご主人はね、どろぼうに切りきざまれて殺されてしまったのだよ。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ごほうじが　すむと、だんかの　ごしゅじんは　すました　かおで、「はい、ごくろうさま。",
              "citation": {
                "source": "こぞうさんの　おきょう",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
