[
  {
    "uuid": "32f496a6-14b4-5b80-8fa3-dd9f602c538e",
    "entry": "ご機嫌",
    "reading": {
      "primary": "ごきげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
