        "examples": {
          "standard": [
            {
              "text": "巡礼者は寺院の前で五体投地をして祈りを捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の深い信仰心は、五体投地する姿から伝わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はその教えを理解するため、五体投地して師に請うた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「後光がさして観音様に見えた」とか、「思わず五体投地礼を繰り返しそうになった」とか、いろんなところで言いふらしてきましたから、きっと「またか」と嫌がられるでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教でよくいう五体投地の形をしているのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とは知らず、骨までゾッとしたものに襲われて、この少年の挙動をさまたげてはならない――という気になって、粛然として息を呑んでいると、五体投地の少年の前面に、つまり、親柱の麓のところに、異様にかがやくものの存在を認めました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
