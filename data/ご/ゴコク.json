  {
    "uuid": "bad7bdad-dcbd-5ae2-a03c-965a9fe8754c",
    "entry": "午刻",
    "reading": {
      "primary": "ごこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "noon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "全線に亙り戦いも午刻には終ったが、寄手は四千余の死傷を出した上に大将を討たせた様な始末である。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには先づ各自各家に弁当かまたはその他の食物を用意し、午刻頃より定めの場所に行きて陣取る。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分並藤田子同所へ出張被仰付、午刻青森出立、夕七時油川村著、菊屋重助宅へ落著。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "午刻より新城村病院へ行、日暮帰寓。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "爰許今朝出馬、黒石通り、中野村迄帰程、様子相尋候処、五七日内には出艦手筈難及由に付、午刻より又々弘前行相催す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "午刻より弘前出立、夕七時頃中野村へ著一泊。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "午刻許青森より進撃艦八艘出帆。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "午刻より長谷寺、祥雲寺参詣。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様御帰藩被遊候に付、朝五半時揃総出仕、午刻御著。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞白午刻東京より帰着之由。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "午刻頃播州｜伊津湊へ著船。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "応仁元年五月五日の条に、「午刻猿楽参。",
              "citation": {
                "source": "能舞台の解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "是から楊枝を遣い始めようとすると、ゴーンと云うのが上野の午刻だから今の十二時で何う云う訳か楊枝が四本あります、一本へ歯磨を附けまして歯の齦と表を磨き、一本の楊枝で下歯の表を磨き、又一本の楊枝で歯の裏を磨き、小さい楊枝が有りまして、これで歯の間々を掃除いたします。",
              "citation": {
                "source": "霧陰伊香保湯煙",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "午刻出仕して蓮華会を修する。",
              "citation": {
                "source": "憑き物系統に関する民族的研究",
                "author": "その一例として飛騨の牛蒡種",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「巳刻（十時）から午刻（十二時）の間で」「待ちな、元三大師の御籤には忌日があるものだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "第廿七吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その翌る日の昼過ぎ、午刻半（午後一時）少し前でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "花見の留守",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分が謎々を解いて、漸く見つけてやった一万両の小判を、与力衆から尾張の御留守居へ申し入れると、――それは千万辱けない、明日正｜午刻（十二時）当方から受け取りに参るで御座ろう――と来た。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の上で折目を伸ばすと、いつもの蚯蚓をのたくらせた女文字で、当斑組より八丁堀屋敷に預け置候金子一万両は至急当方にて入用に付明日正｜午刻参上受取る可候、尾州家に御送り届けの儀は全くの筋違ひに付堅く無用に被遊可く為念申入候　敬白　月　　日斑組首領　こうのたくらせているのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "正｜午刻（十二時）のお時計が鳴るのを合図のように、笹野新三郎役宅の玄関に立ったのは、尾州家のお使い、大橋要人、同じく津田孫太郎、同じく鈴木倉之進の三名でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「主人の弟の新之助は、午刻半（一時）頃家を出て、日本橋で四軒廻り、四軒目は晩飯を御馳走になつて、少し醉つて、酉刻半（七時）頃歸つた相です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "釣針の鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その翌る日の晝過ぎ、午刻半（午後一時）少し前でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の留守",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「巳刻（十時）から午刻（十二時）の間で」「待ちな、元三大師の御神籤には忌日があるものだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "第廿七吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "溜屋の寮へ着いたのは、かれこれ巳刻半（十一時）――やがて午刻近い刻限で、塀の下、藪の蔭などに、昨夜の名残の雪を、ほんの申訳ほど残している有様でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話の始まつたのは丁度｜辰刻半（九時）それから準備を整へ、正｜午刻少し前には、妻玉江、娘百合、あやめ、下女お篠、下男作松、内弟子｜鳩谷小八郎を、それ／″＼の部屋へ入れ、主人春日藤左衞門は、一色友衞とたつた二人、奧の稽古部屋に相對して、三十年前友衞の父一色清五郎の封じた、禁制の賦の包を解きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前なんかの口を出す場所ぢやねえ、引込んでゐるがいゝ」「だつて御新造さんは、上野の午刻の鐘が鳴るズーツと前から、ツイ今しがたまで、私と一緒にお勝手に居たんだもの」「何んだと？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆んな昨日の晝の通りに、――お勝手にはお内儀と下女、お孃さんは親御さんの部屋に、鳩谷さんは御自分の部屋、作松は物置、――御主人と一色さんは稽古部屋、そして昨日と同じやうに、上野の午刻が鳴つたら、禁制の賦を吹くのです」「そんな事が――」　あまりの事に、春日藤左衞門はさすがに尻ごみしました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "禁制の賦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次と八五郎が、赦免状と生き証人をつれて鈴ヶ森に乗込んだ時は、午刻（十二時）を遥かに過ぎてもう未刻（二時）近くなっておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "刑場の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何がお早うだい、先刻上野の午刻（十二時）が鳴ったぜ、冗談じゃない」　銭形の平次は相変らず、狭い庭に降りて、貧弱な植木の世話に没頭しておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死相の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「午刻半（一時）でしょうね」　八五郎は天文を案ずる恰好で答えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死相の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は一日中舞臺へ出て居るのか」「え、江戸中の皆樣が御存じで、晝の午刻から、夕方の酉刻過ぎを、お客樣の前に身體をさらして居ない日はありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "僞八五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
