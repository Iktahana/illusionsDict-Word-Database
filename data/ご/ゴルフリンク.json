          "literary": [
            {
              "text": "ゴルフリンクの入り口でお茶を引いているキァデーの群れがしきりにクラブを振りまわしている。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフリンクから遊びつかれた人たちが帰ってくる。",
              "citation": {
                "source": "六甲山上の夏",
                "author": "九条武子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは四五日一緒でしたが、途中名古屋のゴルフリンクで、わたしはあの人にゴルフを教えたのですがね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　翌日、練習休みで、近くのゴルフリンクヘ一同でピクニックに行きました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　翌日、練習休みで、近くのゴルフリンクへ一同でピクニックに行きました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフリンクの下の砂浜伝いの細道は、岬のすぐ先きで陸に向かい、やがて立派な道になつてクレイブン邸のほうへ通じていた。",
              "citation": {
                "source": "緑色の人",
                "author": "THE GREEN MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "六甲を植林せず、ゴルフリンクや何々ガーデンと土一升金一升にやったばちの由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
