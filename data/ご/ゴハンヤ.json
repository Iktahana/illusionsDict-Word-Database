        "examples": {
          "standard": [
            {
              "text": "「駅前にある小さなごはん屋は、安くてボリューム満点だと評判だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「仕事帰りにふらっと一人で寄れる、お気に入りのごはん屋がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あのごはん屋の定食は、まるでおふくろの味を思い出させる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ひばり、ごはんや。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねずみが悪ささえしなければ、わたくしどももがまんして、あわび貝でかつ節のごはんや汁かけ飯を食べて満足しています。",
              "citation": {
                "source": "猫の草紙",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
