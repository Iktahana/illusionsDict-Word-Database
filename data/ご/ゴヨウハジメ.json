    "definitions": [
      {
        "index": 1,
        "gloss": "re-opening of offices in New Year (usu. January 4)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ろくな御用始めもないので、粉煙草ばかりせゝつて、心待ちに八五郎の來るのを待つてゐたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五つの命",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろくな御用始めもなくて、少し腐つてゐた矢先でもあつたのでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "荒神箒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿野郎、――よくもそんな間拔けな事が考へられたものだ」「――それも樽を据ゑた家に限るね、一升買ひの酒ぢや、飮んでも身にならねえ」「呆れた野郎だ」「でなきア、御用始めに、眼の玉のでんぐり返るやうな捕物はないものかなア。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "どんど燒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、こいつは飛んだ御用始めになりさうだぜ、手前は裏からそつと廻つて、あの客人に氣を付けるんだ」「へエ――」　八五郎は腑に落ちない顏を擧げました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵粮丸祕聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し詰つてその噂も漸く忘れられ、氣に掛り乍ら正月を迎へた平次、四日の御用始めに三人目の犧牲者の伜に飛込まれたのですから、これには全く驚きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵粮丸祕聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろくな御用始めもないので、粉煙草ばかりせせって、心待ちに八五郎の来るのを待っていたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "五つの命",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、こいつはとんだ御用始めになりそうだぜ、手前は裏からそっと廻って、あの客人に気を付けるんだ」「ヘエ――」　八五郎は腑に落ちない顔を挙げました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "兵糧丸秘聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し詰ってその噂もようやく忘れられ、気に掛りながら正月を迎えた平次、四日の御用始めに三人目の犠牲者の倅に飛込まれたのですから、これには全く驚きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "兵糧丸秘聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿野郎、――よくそんな間抜けな事が考えられたものだ」「――それも樽を据えた家に限るね、一升買いの酒じゃ、飲んでも身にならねえ」「呆れた野郎だ」「でなきゃア、御用始めに、眼の玉のでんぐり返るような捕物はないものかなア。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "どんど焼き",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、憚りながら、今日は申し分のない御用始めだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "懐ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、神楽坂の浪人者殺し、あの話をまだ聴かずにいるんですか」「聴いたよ、――が、二本差と鉄砲汁は親の遺言で用いないことにしてある」「へッ、こいつはたまらねえ御用始めですぜ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "懐ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、神樂坂の浪人者殺し、あの話をまだ聽かずにゐるんですか」「聽いたよ、――が、二本差と鐵砲汁は親の遺言で用ゐないことにしてある」「へツ、こいつはたまらねえ御用始めですぜ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "懷ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用始めに千兩箱の山の崩れたのを見るのも、ちよいと溜飮の下がる景色ぢやありませんか」　八五郎は呑氣なことを言つて居るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "屠蘇の杯",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日の御用始めから、無暗に御用繁多で、平次も八五郎もそれに追ひ捲られ、砂利詰の千兩箱や、その下敷になつた徳右衞門のことなどは思ひ出す折もなかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "屠蘇の杯",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日をヒッソリ暮して、四日の御用始めに出勤した小室君は俄に腹痛を催して、輾転反側した。",
              "citation": {
                "source": "秀才養子鑑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用始めの日に会社で発病したから周知の事実になっていた。",
              "citation": {
                "source": "秀才養子鑑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
