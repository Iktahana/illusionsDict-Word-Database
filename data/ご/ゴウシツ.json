    "definitions": [
      {
        "index": 1,
        "gloss": "suffix for room numbers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
