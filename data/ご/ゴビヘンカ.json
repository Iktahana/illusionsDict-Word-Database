        "examples": {
          "standard": [
            {
              "text": "「ラテン語は語尾変化が非常に複雑な言語として知られている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「英語の動詞の語尾変化は、現在形と過去形では規則的に行われるものが多い。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「語尾変化を正しく理解することは、外国語習得において不可欠なステップだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "段々うたふの語尾変化によつて、うたへとうたひとを区別する様になつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、茲で平均性――低質性はその語尾変化であった――は、もはや単なる平均性ではない、何故なら、平均性は平均性に違いないがそれは切り下げられたる平均ではなくして、却って引き上げられた水準をこそ意味して来るのだから。",
              "citation": {
                "source": "イデオロギーの論理学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は互いに語尾変化をやりとりしました。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
