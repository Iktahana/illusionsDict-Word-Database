        "examples": {
          "standard": [
            {
              "text": "「ご近所さんにたくさん大根をもらったから、今夜はおでんにしましょう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎朝、道ですれ違うご近所さんと挨拶を交わすことで一日が始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ご近所さんと協力して、土曜日の朝に公園のゴミ拾い活動を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ご近所さんがね、週一回ここをたずねてくるんじゃよ。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とはいっても、おやゆび姫はご近所さんに気なんてありませんでした。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご近所さんを怖がらせたり、こんな時間に警察を呼ぶようなことをするんじゃないよ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
