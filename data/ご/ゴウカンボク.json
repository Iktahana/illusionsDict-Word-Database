    "definitions": [
      {
        "index": 1,
        "gloss": "silk tree (Albizia julibrissin)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "源右衛門の家の背戸は、葉の落ちた野茨、合歓木、うつぎなどの枝木で殆んど覆われている。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃わが邦へ渡ったかの国人が、奥羽地方で合歓木をかかる難地へ植えて砂防を完成すると聞き、帰国の上官へ告げて試むると果して竣功したという。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは合歓木の木立でしたよ。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "合歓木がその崖に枝垂れて花咲いたりする眺めもある。",
              "citation": {
                "source": "犬三態",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "100 ポンドより　Ｙ、合歓木に似た葉で黄色い小粒なポクポクした花の枝を採って来てくれた。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の欄から手の届くほど近いところには、合歓木や藤が暗く掩い冠さっていた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が没した後父と来たとき植えさせた合歓木が風に吹き折られもせず一丈ほどに成長している。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今宵十時よりお庭の合歓木の蔭にてお待ち申し上げそろ、神ぞしろしめせ、おいでなくばこの命ひとつ今宵かぎりにそろ。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝間をぬけ出た奈尾は、庭の片隅にある合歓木のほうへ、静かにすべるように歩いていった。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす月の光を吸って、合歓木の花が夢のようにおぼろに夜空を暈かしていた。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――奈尾は合歓木の樹蔭へ身を寄せた。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈尾の全神経はしびれたようになり、合歓木の幹にもたれた躯は地上から浮きあがって、泡沫のように空間へ消えてゆきそうに思えた。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あすの晩もういちど、どうかもういちどだけ」　忍び足に去ってゆくのを聞きながら、奈尾は合歓木の幹に背をもたせ、放恣な姿勢でじっと眼をつむった。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この辺がいい」兄が芝生の端まで来て立ちどまった、「毛氈をこっちへもらおう、それはそこへ置いといていいよばあや、いやもう少しこっちだ」酒宴のしたくである、合歓木の花を眺めながら、庭で夜宴を催すのは毎年の例であった。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お庭に合歓木を植えましょう、ねえ」奈尾はこう半三郎にささやいた。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――約束の合歓木も庭の西の端に植えられた、椙原の庭のよりも大きい樹で、枝も充分に張り、花が咲いたらどんなにみごとかと想像された。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩田へ来てからはあわただしい日が続いて、夏のうちはふと思いだす程度であったが、秋風の立つころになって生活もおちつき、根づいた合歓木の葉が哀しく枯れだすのを見ると、しばしばあの夜のささやきの声が思いだされ、あやしく胸のときめく時間がかえって来た。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――合歓木をお植えなされ候ことわが身のいのちを覚えそろ、御いたつきの趣き承まわり及び候より、夜々、合歓木の樹蔭にて御平癒を祈りまいらせそろ、おはこびある折のありや否やは知らず、せめて祈りの夜々のみは赦したまわり候え。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔に憑かれたような足どりで奈尾は合歓木の側までいった。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ来てくださいましたね、やっぱり」からたちの生垣の外から、すぐにこうささやく声がした、「御病気はいいのですか、こんな時刻に出てお悪くはないのですか」　奈尾はわれ知らず合歓木の幹によって身を支えた、全身がしびれて、そのまま倒れるかと思えたのである。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈尾は合歓木の樹蔭へゆき着いた。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来年になったら、この合歓木は」こう男が云った、「――私たちを夢のようにおぼろな花笠でおおってくれるでしょう……」　来年になったら。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈尾は喪心したように合歓木の樹蔭をはなれた、ほとんど夢中で、よろめきよろめき家に帰った。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は奈尾をよく知っている、奈尾になにが必要だかということも……あの人は喜んで合歓木を植えてくれたではないか。",
              "citation": {
                "source": "合歓木の蔭",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり同刻限に青年男女川の辺に集まり、手に手に合歓木と大豆との葉を持ってこれを水に投込み、ネムは流れよ、まめの葉はとまれと唱える。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは対馬の久根村でネブノキ流しというもの、これは合歓木の枝を折って海に流し、年中睡くないようにというまじないとするらしく婦人がもっぱらこれに携わるというが（島誌）、その期日は七日の朝ではなくて、旧六月十五日になっている。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは旧暦七月六日の夜、藁で作った二間ばかりの舟に、満船｜蝋燭を点したのを各町から出し、それにこの土地ではネブタの木という合歓木かまたは竹へ、短冊形の色紙と燈籠とを付けたのを持った青年が多く付添うて、旭川の川原まで持出し、花火を揚げたりいろいろと景気をつけた後に、川へ流すのである。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち人を苦しませるネブタというもの、睡魔とまでは言い得なくとも何か流して離れてしまえるものがあるように考えたのが元だったらしく、合歓木をネブタという方言は、恐らくはまず来てこれを助けたのである。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
