    "definitions": [
      {
        "index": 1,
        "gloss": "to be in confusion or commotion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旅籠の表は黒山の人だかりで、内の廊下もごった返す。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "予約がないと席がないほど千客万来のところへ、店頭で牛肉を買っている人々のごった返す混雑といったらないのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子供の悲鳴、ごった返す人垣。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送り人のごった返す中で、有王は、俊寛の姿を探し求めたが、それらしい人の姿は見当らなかった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵や花で飾られた衣をまとった公卿たちでごった返す入道邸は、院の御所を思わせた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも上を下へとごった返すが好い。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中では不愉快極まるものの大群がどこかの地下墓所からボイルストン街地下鉄(*15)の床にできた割れ目を通して這い上がり、プラットフォームにごった返す群衆に襲いかかっていた。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸があく、土間がごった返す、炉辺がにわかに動揺めいてきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆が一番ごった返す晩だよ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょどまたその頃に太子一行の荷物や自動車も次便船で来、また王宮から太子専用の料理人やそのほか二、三人の下働きの従僕たちも日本へ着いたばかりの時分で、駿河台のヴァローダ商会はこれらの荷物や従僕たちで毎日ごった返す騒ぎを演じていた頃だったと覚えている。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくたいへんな人で、ごったがえすような、ありさまだったよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごったがえす山塞　二少年は、どうしたろうか。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かごいりチミーは　ごったがえす　やさいのなかで　ふるえていました。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、すぐあちらこちらに私語がはじまり、それが、たちまちのうちに、ごったがえすようなそうぞうしい話声となって、室じゅうに入りみだれた。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "町なかの往来は、おおぜいの人で、ごったがえすようなさわぎでした。",
              "citation": {
                "source": "白ヘビ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "官邸の内部はたちまちごったがえすような騒ぎになったが、出血がどうしてもとまらぬので、テーブルをつなぎ合して臨時の手術台をつくり、切開の準備を整えていた医師たちも、互いに顔を見合せたまま躊躇しているのを暗黙のうちに察したらしく、大隈は、「愚図愚図するな、早く切れ！",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
