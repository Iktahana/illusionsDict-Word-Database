[
  {
    "uuid": "ec6786e5-e863-58be-ba02-753baf76f1b4",
    "entry": "ご注文",
    "reading": {
      "primary": "ごちゅうもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
