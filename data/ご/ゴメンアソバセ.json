        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あら、ご免あそばせ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホッ、ホッ、ホッ、ご免あそばせ」――で、スルリと抜けたのである。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホッ、ホッ、ホッご免あそばせ」　女煙術師は行き過ぎた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、「ご免あそばせ」と低い声が廊下でして、障子がそつとあいた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "保則さま、ご免あそばせ、しまいにわたくしは御身様があそこにお住みになられているのではないかと、そんなふうに考えることもございました。",
              "citation": {
                "source": "玉章",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ご免あそばせ、わたくしがあなた様の御本心に辿りつくまでには三日も四日も考えつづけて、やっとあなた様がお方様のためにそのようにご衣裳をお取りかえになることを知ったのでございます。",
              "citation": {
                "source": "玉章",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごめんあそばせ……ごめんあそばせ……」「おっ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "『失礼ごめんあそばせ。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごめんあそばせ」　房枝は、その場にいたたまらなくなって、スミ枝たちにはかまわず、一散に外へ走りだしたのであった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごめんあそばせ……もうぢき、帰つて来ると思ひますわ」　あたふたと、彼女は、自分の居間へ駈け込んだ。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "普段とちつとも変りない顔をしてゐますわ」　そのまま、彼女は、「ごめんあそばせ」と、自転車へ飛び乗つた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホッ、ホッ、ホッ、ごめんあそばせ」例の眼で笑い例の口で笑う。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々玄八郎が、いぶかしげな低声で、「ヤ、お蓮様ではないぞ」「アノ、そのお蓮様のことでござりますが……ごめんあそばせ」　声とともに、静かに障子があいて顔を出したのを見ると、お蓮様づきの侍女、早苗です。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、ごめんあそばせ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だんろのそばにすわって、すてきにのどを鳴らして、お手々をぺろぺろ顔をごしごし、だっこするとほんとふわふわなんだから、それにつかまえるのも上手いのよ、ネズミを――あらごめんあそばせ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ごめんあそばせ。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でね、だんろのそばにすわって、すてきにのどを鳴らして、お手々をぺろぺろ顔をごしごし――だっこするとほんとふわふわなんだから――それにつかまえるのも上手いのよ、ネズミを……あらごめんあそばせ！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「このあいだ『殿方ごめんあそばせ』って映画で、ブリジット・バルドーがお臀を見せるところがあったよ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、少し訳がございまして、……」「あら、ごめんあそばせ、失礼なこともうし上げまして、あなたがそんなにお若いのにご要心深いと、ついそう思ったものですから。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごめんあそばせ、じょうだんですのさて急ぎます音楽を、どうぞ！",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこんなふうになつたおかげでオイラは、だな――あら、ごめんあそばせ。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰つてから私が机にむかひながら　今日は裏へ出てみようかしら、よさうかしら　などと思つてるときに玄関の格子がしづかにあいて「ごめんあそばせ」と小さな声でいつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると忘れるまもないなつかしい声が「ごめんあそばせ」と格子のところでいつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が柱からはなれて机のまへに坐りなはすあひだに「ごめんあそばせ」とおちついた柔い声がして、その声があけたやうにするすると障子があいた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごめんあそばせ、たいへん失礼いたしました」「なに、自分でも可笑しいんだ」　そうしててれたように顎を撫でた。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごめんあそばせ、おひやを忘れまして」　こう云いながら、おなつは枕近くへ寄って、静かに盆を置いた。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごめんあそばせ」　さえは自分の頭から櫛をぬき取ると、丁寧に紙で拭いてから、伊兵衛の鬢の毛をそっと撫でつけた。",
              "citation": {
                "source": "彩虹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ごめんあそばせ」　そう云って返辞を待とうとしたとき、うしろにひき添って来た大目附の者が、志保を押しのけざま引戸を明け、五浦なにがしと共につかつかと中へ踏み込んだ。",
              "citation": {
                "source": "菊屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
