[
  {
    "uuid": "64c8acef-fb7c-5818-8bc3-4a34accaea54",
    "entry": "極暑",
    "reading": {
      "primary": "ごくしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
