    "definitions": [
      {
        "index": 1,
        "gloss": "sunrise viewed from the top of a high mountain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
