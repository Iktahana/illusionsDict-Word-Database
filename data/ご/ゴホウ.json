[
  {
    "uuid": "942ad473-11e5-524f-8ed3-ad421d1f5b95",
    "entry": "午砲",
    "reading": {
      "primary": "ごほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
