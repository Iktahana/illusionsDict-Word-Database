        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ご主人様へ」というのである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご主人様は震災の時に、悲しいことにおなりになったと聞きましたが、当日はやはりご一緒に宅においでになりましたか」「いいえ」　と夫人は強く言って、急に悲しそうな表情になり、「ちょうどあの日は、お友達が見えまして、朝から他行致したのでございます。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（有王に抱きつく）有王　（驚き、つくづくと俊寛を見る）あゝ、ご主人様だ！",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王　あゝいたわしや、ご主人様。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王　ご主人様、もはやご安心なさいませ、私がまいりました。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王　私の尊いご主人様、私はあなたのために命を惜しみませぬ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご主人様のお心をお支えくださるように！",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王　（つくづくと俊寛を見る）あゝご主人様何ごとも時でございます。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ほとんど無意識に頭を岩かどに打ち当てんとす）有王　（まっさおになり、俊寛を抱き止める）ご主人様。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（失神して倒れる）有王　（俊寛を抱きかかえたるまま）ご主人様、お気をおたしかに！",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王　（つくづくと俊寛を見る）ご主人様、なにとぞ私の申すことをお聞きください。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご主人様、あなたは静かにこの世を終わってください。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王　ご主人様、なにとぞお心を静めてください。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王　（驚く）ご主人様。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（俊寛の姿の見えざるに気づいて、驚き薪を投げる）ご主人様。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王　（登場）ご主人様。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（血の痕をたどり、岩の上によじ、俊寛の死骸を見つける）おゝご主人様。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて俊寛の死骸を抱きつつ）あゝ、いたわしいご主人様。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝご主人様、あなたは呪うて死なれましたか。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご主人様がご親切だからでございましょうが、下女下男までが親切で、わたしの顔を見ますると「勢州が見えたから何かやりな」と、面桶の中へ、焚きたてのご飯などを、お入れ下さるのでございます。",
              "citation": {
                "source": "怪しの者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご主人様と争うなどと！",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいはい私のご主人様の。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ私のご主人様と申すは、松倉屋の奥様にござります。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……品物の中身は存じませぬが、どうやら高価の品物らしく、それが証拠には勘右衛門様が――はい松倉屋のご主人様なので、――品物を取り返そう取り返そうとして、いやはやいやはやとてもしつこく、追っかけて来ましてございます。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わしが伊豆守殿よりお預かりした品を……」「その伊豆守様は梶子の身にとり、申してみますればご主人様のようなもの。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来がご主人様のご進物を。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご主人様のおいいつけであろうと、女子供の玩具のような、あのような人形をお武家様たるあなたが、大切らしく京まで送る！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご主人様のおいいつけであろうと、お断りするのが当然というもの、それを無理にも送ろうなどと……これは少し変ですわねえ」　ここで梶子は民弥の顔を、審かしそうにジロリと見た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご主人様へ」と血で書いてある。",
              "citation": {
                "source": "赤格子九郎右衛門の娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私にとってはご主人様、貴郎様にとりましてはお父上様が、磔柱へ付けられる前に、そっと私めに手渡した大事な書面でござります。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
