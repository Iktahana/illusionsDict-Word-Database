[
  {
    "uuid": "5c55feb7-7588-5599-abf9-ee8367935a46",
    "entry": "極々",
    "reading": {
      "primary": "ごくごく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
