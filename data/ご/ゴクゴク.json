      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "extremely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まかり間違うて大公儀の耳にでもそげな事が入ったなら、直ぐさま、黒田五十五万石のお納戸の信用に差響いて来るやら知れぬ話じゃけに、成る限り大切を取って極々の内密に、しかも出来るだけ速よう下手人を探し出せと言う大目付からの御内達で、お係りのお目付、松倉十内｜様も往生、垂れ冠って御座る。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに遠く行き去った愛惜物が突然また再現したような喜悦に似た感情が、今度は今迄のすべての気持を反撥し、極々単純に、直ぐにも逢う約束をかの女にさせようとした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と足音をひそめて私が近寄ると、氏は極々あたりまえの顔をして「炎天の地下層にですな、小人がうじゃうじゃ湧こうとしてるんじゃ無いですかな。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新詩社は新宿よりの千駄ヶ谷の畑中の極々質素な平家でありました。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "極々まれに、こわごわ娘達の様子を聞くことはあつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、どういふ原因が其処にあつたものか、ともかく女同志の親密な気持ちには時々はかり知れない神秘的なものが介在してゐるかと思へば極々つまらない迷信にも一大権威となつて働きかけられる場合もないではないぢやありませんか。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、二人は母親達に極々安心の行くやう言葉の順序をつくした書き置きをしたため、都をあとにあてもなく落ちて行つたのです。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見れば秀吉は宜いけれど、氏郷は巨額の年俸を与えられたとは云え極々短期の間に其年俸を受取れるか何様か分らぬ危険に遭遇すべき地に置かれたのだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "極々淺近な例を取つて語らうならば、此處に一商人があつて碁を非常に好む人とする。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "野澤先生は自分の極々祕密にして居たことを知つて居るのだといふ考である。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ママも年とったらアイノコの孫を抱くのだね、楽しみだね」と、極々座興的ではあったけれど或時かの女がそれを息子の前で言ってどやされたことをかの女は思い出した。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸作の特種な欲望とは極々限られた二三のものに過ぎないと言える。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い、喰べもののまずい病院から引き取って世話をしたと言ったまででは、極々当りまえの世話人根性のようだけれど、その実、気違いの京子と暮す事は何という気遣いな心の痛む事業だろう。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもつと短い、極々煎じつめただけのものに畢竟は徹底して行くのが自分の芸術に取つて最も落つきある正しい道ではあるまいかと思へてならなかつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めからすらすらと的確に思ふ儘の表現ができるだらうけれど、私ごときには、それにまだ歌には極々の不丹練者であるから、人の十倍二十倍の苦しみを経なければとてもとてもと云ふ観念の臍を固めてゐた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁葺の極々粗末な作りやうで右手の戸袋によつて駄菓子のやうなものがガラス箱に入れて置いてある。",
              "citation": {
                "source": "竹の里人〔三〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよの念力が極々細微な径路を伝わって省作を動かすに至った事は理屈に合っている。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "極々愚鈍の富者は小間物屋の肆前に立って、噫悲しい哉、今は吾が買う可き何物をも新に見出し得ざるに至ったと嘆じて、何か買いたい物の有った時の幸福さを味わうと同時に、豊満せる財嚢を抛ち棄てて落涙するという昔話を其儘演出するに終らねばならぬ。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "極々手近な例を取って語るならば、ここに一商人があって碁を非常に好むとする。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あとからあとからと極々雑多色とりどりの人影がつづいて、ざッと二三百名でした。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく現代に於ては沖縄人にして第一この大欠点をうめあわす事が出来ないとしたら、沖縄人は市民としても人類としても極々つまらない者である。",
              "citation": {
                "source": "沖縄人の最大欠点",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "斷つて置く、以下に書き記す處は、或は此無限の生命ある世界に於て、殆んど一顧の値だに無き極々些末の一事件であるのかも知れない。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "断つて置く、以下に書き記す処は、或は此無限の生命ある世界に於て、殆んど一顧の値だに無き極々些末の一事件であるのかも知れない。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは極々の内証話だが、高田文相も岩村男と同じ意味に於て立派に二つの資格を備へた美術通である。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代によって、人間の善意の表現も極々の転形を示すのだが、今日私たち日本の文学の成長の可能は、どんなところにかくされているのだろうか。",
              "citation": {
                "source": "地の塩文学の塩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者が益々、文芸批評の本来性として在る極々の要因を、情熱の源泉として身につけて、細密にして柔軟、逞しい成長をとげてくれることを切望するのは、作家としても決して私一人ではなかろうと思っている。",
              "citation": {
                "source": "作家に語りかける言葉",
                "author": "――『現代文学論』にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校の郊汀さんを訪ふ、初対面であるが、どちらもノンベイなので、新天地へ出かけて飲みまはる、中国新聞社で黙壺君に落ち合ひ、三人元気よく江波の山陽茶屋（とでもいはうか）まで押しだして、うまい料理を食べた、そして、それから、……それから、そして、……地極々々！",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は極々人間的なのです、総ての見方が。",
              "citation": {
                "source": "大橋房子様へ",
                "author": "――『愛の純一性』を読みて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し此事は誰にも言わぬ様に願います」との注意を遺して退きたり、是より夜の明るまで余は眠るにも眠られず、様々の想像を浮べ来りて是か彼れかと考え廻すに目科は追剥か盗坊か但しは又強盗か、何しろ極々の悪人には相違なし。",
              "citation": {
                "source": "血の文字",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに雪片がくっつき合っているのはつまり寒気がさほどひどくなくて雪片が温まっているからなので、ごくごく寒い摂氏零度以下二十余度にもなるともはや雪片に湿り気がなく従ってみんなバラバラに粉のようになってしまう。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
