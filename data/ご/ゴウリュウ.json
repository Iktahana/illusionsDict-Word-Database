    "definitions": [
      {
        "index": 1,
        "gloss": "confluence (of rivers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
