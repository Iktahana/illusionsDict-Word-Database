        "examples": {
          "standard": [
            {
              "text": "彼はカフェでゴロワーズに火をつけ、物思いにふけっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "フランス製のゴロワーズは、独特の香りがする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の映画には、ゴロワーズを吸う俳優がよく登場した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから、ゴロワーズのカポラールと、フィルターのついたジタンが、ひと箱づつ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴロワーズとジタンは、日本で売っているものではなく、フランス国内のものだった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス製の小さなノートが五冊に、ゴロワーズとジタンがひと箱ずつあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
