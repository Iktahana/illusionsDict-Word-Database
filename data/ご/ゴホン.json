  {
    "uuid": "b868e28a-920d-5ac9-854e-72bf17502156",
    "entry": "五本",
    "reading": {
      "primary": "ごほん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
