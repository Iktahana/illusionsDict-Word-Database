[
  {
    "uuid": "0f3d8d5e-6105-51e2-977b-d03f46acc733",
    "entry": "ご無沙汰",
    "reading": {
      "primary": "ごぶさた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
