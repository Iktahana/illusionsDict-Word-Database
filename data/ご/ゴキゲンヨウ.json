          "standard": [],
          "literary": [
            {
              "text": "」　傘の中から面と肩を斜っかいに、つっかかるように暖簾の中へ突出して、「や、お閻魔殿、ご機嫌よう。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご機嫌ようお越しなされ」　※の音が忙しく響いて、山岡大夫の舟は見る見る遠ざかって行く。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら姉えさん、ご機嫌よう。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして無事に、お互いに「ご機嫌よう」と言って別れてしまった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、ご機嫌よう。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分ご機嫌よう」と小さな声で云った。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今晩は……本田さん……ご機嫌よう……」　誰か何処かで呼ぶものがある。",
              "citation": {
                "source": "人間製造",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご機嫌よう」　私も、慌たゞしく帽子に手をかけた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、皆さん、ご機嫌よう！",
              "citation": {
                "source": "月世界探険記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、ご機嫌よう、コルシカ人に用心なさい」といって、それから一人で尾根伝いにのぼっていってしまった。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたも、どうぞご機嫌よう。",
              "citation": {
                "source": "二つの運命",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご機嫌よう、すぎの木さん。",
              "citation": {
                "source": "もずとすぎの木",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご機嫌よう」　日が暮れかかる前に、ちょうと花とは、たがいにこういって、別れを惜しみました。",
              "citation": {
                "source": "くもと草",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ラネーフスカヤ夫人の手にキスする）ではそれまで、ご機嫌よう。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロパーヒン　じゃ君、ご機嫌よう。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご機嫌よう、お仕合せでね。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではご機嫌よう」　汽車はみるみる出て行き、その燈もまもなく消え失せて、一分の後にはもう音さえ聞こえなかった。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ご機嫌よう」　彼女は彼の顔を見るとさっとばかり蒼ざめたが、やがてもう一ぺん、わが眼が信じられないといった風に、恐る恐る彼の方をふり仰ぎ、両手のうちにぎゅっと扇を柄付眼鏡もろとも握りしめた。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいオサラバ、彦兵衛さんや」「ご機嫌ようおいでなさりませ」「アイアイ有難う有難う」　跛者で醜貌の猪十郎、薬草車を引き出した。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、ご機嫌よう……。",
              "citation": {
                "source": "北海の波にさらわれた蛾",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バケツさん、どうぞご機嫌ようお暮らしなさい。",
              "citation": {
                "source": "ねずみとバケツの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師が恋する……ニーナ　ご機嫌よう、トリゴーリンさん！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリゴーリン　ご機嫌よう。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご機嫌よう、トリゴーリンさん！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリゴーリン　（ソーリンに）ご機嫌よう、ソーリンさん！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではご機嫌よう、皆さん！",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではご機嫌よう、ソーニャさん、こんな調子で話していたら、それこそ夜が明けてしまいますよ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……アーストロフ　（統計グラフをかかえて登場）ご機嫌よう！",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（アーストロフに手を差しだす）ご機嫌よう。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレーナ　ご機嫌よう。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
