    "definitions": [
      {
        "index": 1,
        "gloss": "freshwater goby (any fish of genus Rhinogobius)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
