  {
    "uuid": "e3be5907-aad9-55ef-9e3d-11d5e7c8529b",
    "entry": "後手",
    "reading": {
      "primary": "ごて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
