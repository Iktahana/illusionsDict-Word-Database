        "examples": {
          "standard": [
            {
              "text": "その会社の買収計画は、極秘事項として社内でも一部の人間しか知らされていなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "機密文書には、極秘事項が多数記載されており、閲覧は厳しく制限されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この件は極秘事項ですので、絶対に口外しないでください」と担当者は念を押した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "情報処理部隊が一六ビットのパーソナルコンピューターを開発していることは、極秘事項だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしこれは極秘事項だぜ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
