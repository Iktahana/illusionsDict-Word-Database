    "definitions": [
      {
        "index": 1,
        "gloss": "with a scraping sound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして黒いゴリゴリのマントらしいものを着てまっ白に光った髪のひどく陰気なばあさんが黙って出て来て黙って座った。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだんいたゞきに近くなりますと雪をかぶった黒いゴリゴリの岩がたびたびみちの両がはに出て来ました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかとの裏の三角形の鉄片がまず門内の敷石と摩擦してゴリゴリまたゲリゲリとすさまじい音を立てる。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴリゴリ、ゲリゲリと鋸の目立てをするような音はほとんど聞かれなくなった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子さんの泥棒よけ夢野久作　夜中に雨戸のところでゴリゴリと音が始まりました。",
              "citation": {
                "source": "雪子さんの泥棒よけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにゴリゴリと物を削る音が一そう高くなったようです。",
              "citation": {
                "source": "雪子さんの泥棒よけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか家中、金で張ったるんじゃあんめえ」　と言いながら、今度はお座敷の床の間の壁のまん中をゴリゴリ始めました。",
              "citation": {
                "source": "雪子さんの泥棒よけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "外からはゴリゴリと壁を破る音……。",
              "citation": {
                "source": "雪子さんの泥棒よけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々そこをゴリゴリすり合わせるとうまく鳴るが、毎日忘れずにそれをやるのはやっかいである。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳がわからぬまま、クシャクシャになった頭を掻きまわしたり、鬚だらけになった顎をゴリゴリ撫でまわしたりしているところへ扉をノックして、古木先生が悠然として這入って来た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "警告の意味で、故意と声を立てて大きな欠伸を連発していたが、それでも白浪を蹴って進む林技師の雄弁丸が、どうしてもＳＯＳの長短波に感じないので、とうとう精も気魄も尽き果てたらしく、ゴリゴリと巨大なイビキを掻き始めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "キンクスの〈ユー・リアリー・ガット・ミー〉や、ボビー・フラー・フォーの〈アイ・フォウト・ザ・ロウ〉のような、そして、この〈ゲット・オフ・オヴ・マイ・クラウド〉のような、ギターコードでゴリゴリ押しまくる曲は、慶一は、とりあえず無条件で好きになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい、トーイズの〈ラヴァーズ・コンチェルト〉なんて、ギターコードでゴリゴリとは、およそ無関係な曲も好きだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程、その店の主人らしい、頸の太い、禿頭の先端の尖ンがった、赭ら顔の五十男が、恐ろしく憂鬱な表情をしながら、盛んに木の葉を乾かした奴を薬研でゴリゴリこなしていましたが、助役の註文を受けると、早速緑色のテープを巻いた小さな円い花環の藁台へ、白っぽい造花を差し始めたんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの黒い薬をゴリゴリと噛みくだいて嚥んだので、マッチで火を点けたのではないから、箱には擦った痕跡がついていないのです」「するとその婦人は、あのマッチの不足分は全部胃の中に送ったというのだな」「そうです。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてゴリゴリする白縮緬の兵児帯などを袴着にまでしめさせて、祖父は一つのランプと一張りの繭紬の日傘とをもって国へ帰って来た。",
              "citation": {
                "source": "明治のランプ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寐棺の中に自分が仰向けになっておるとして考えて見玉え、棺はゴリゴリゴリドンと下に落ちる。",
              "citation": {
                "source": "死後",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "友禅の長｜襦袢のこともあったが、売出されたばかりの、ごく薄手の上等の英ネルの赤いのを胴にした半じゅばんへ水色っぽい友禅ちりめんの袖をつけて、袷仕立にした腰巻き――塵よけともいうが、白や、水浅黄のゴリゴリした浜ちりめんの、湯巻きのこともある。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽二重や、絖や、芦手模様や匹田鹿の子の手ざわりではなく、ゴリゴリする浜ちりめん、透綾、または浴衣の感触となった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳格方正を以て聞えた若林博士は、何故に今夜に限って、斯様な不誠意を極めた屍体解剖を試みるのであろうか……と疑いの眼を瞠っているうちに、屍体は間もなく……ゴロリと俯向けに引っくり返されました……と見ると、疵だらけの背筋の中央、脊椎の左右の筋肉が円刃刀でもってゴリゴリと切り開かれました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "腮一面の無精鬚をゴリゴリと撫でまわして腕時計をチョット覗いたが、やがてブカブカした緞子張りの安楽椅子に反りかえって長々と欠伸をした。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茶気た室内電燈に照らされた寝台の中には最前の小柄な瘠せ枯れた白人の老爺が、被布から脱け出してゴリゴリギューギューと鼾を掻いている。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり、餌をくわえて駆けだすのがあるかと思えば、ゴリゴリと餌を噛んでいる響きが指先へ感じてくる場合もある。",
              "citation": {
                "source": "鯛釣り素人咄",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大豆をゴリゴリひいたり、道端の草をゆでたり、そんなこと以外はお互に何か考えているような表情で笑いもなく毎日を送った。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鯛ならば、ゴリゴリと来るからグイと合せておいて、リールを巻く。",
              "citation": {
                "source": "ガラガラ釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤錆になったり刃の鈍くなったもので、ゴリゴリとごつく削っていたのでは、かつおぶしがたとえ百円のものでも、五十円の値打ちすらないものになる。",
              "citation": {
                "source": "だしの取り方",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "里芋でいっても、ゴリゴリした芋だったら、どんな煮方をしたって、料理人の手に負い切れないのです。",
              "citation": {
                "source": "日本料理の基礎観念",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤錆になったり、刃の鈍くなったもので、ゴリゴリとごつく削っていたのでは、かつおぶしが例え一円のものでも、五十銭の値打ちもしないものになります。",
              "citation": {
                "source": "日本料理の基礎観念",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
