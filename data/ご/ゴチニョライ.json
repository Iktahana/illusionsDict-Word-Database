        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お寺の本堂に安置された金色の五智如来像が、厳かな雰囲気を漂わせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "密教の教えでは、五智如来が宇宙の真理を表す五つの知恵を象徴している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "五智如来のそれぞれの印相の違いについて、ガイドが詳しく説明してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これを人格化し五智如来といいます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴滝には今は五智如来の堂しか残つてゐないが、あそこいらにその大きな寺があつたのであらう。",
              "citation": {
                "source": "早春",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷丸畑の永寿庵を修理して、その本尊の五智如来をきざみ、それが終るや、四国堂の建立と、八十八体仏の彫像、その大願を成就したが、それで故郷に大安住の終りを求めたわけではない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後の直江津の海岸に五智如来と称する名高い寺がある。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "稿本の中に上人が当村寺の本尊五智如来を刻んだということが書いてあったのです。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
