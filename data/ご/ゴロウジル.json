        "examples": {
          "standard": [
            {
              "text": "先生が描かれた絵を、皆で恭しくご覧じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "王様は庭園の美しい花々を静かにご覧じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの著名な建築家が設計した建物を、実際にこの目でご覧じる機会を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あんまり乱暴におはなし遊ばすので、このお娘が、はは様のお顔を、びっくりしてごろうじる――」　まったくわたしは吃驚して！",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            }
          ]
        }
