    },
    "definitions": [
      {
        "index": 1,
        "gloss": "accidental shooting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（真名古課長が誤射されたのです。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（好ぎたって云ったらおれごしゃぐど思うが。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのこらぃなごと云ってごしゃぐような水臭ぃおらだなぃな。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、中折帽を取って、ごしゃごしゃと、やや伸びた頭髪を引掻く。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いかにも、そんげえなものには怯えまい、面魂、印半纏も交って、布子のどんつく、半股引、空脛が入乱れ、屈竟な日傭取が、早く、糸塚の前を摺抜けて、松の下に、ごしゃごしゃとかたまった中から、寺爺やの白い眉の、びくびくと動くが見えて、「蜻蛉だあ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人でない人が見たら、行進中の旅団があらわすようなこの長ったらしい重苦しい行列は、やけに七面倒くさい、ほとんど了解に苦しむごしゃごしゃ騒ぎに見えるのが常だ。",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その十五人もこんぐらかったりごしゃごしゃになったりして、どこで逢って、どんな顔をしていたかあやふやだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……実ア、まだよく読んでいねえのだが、なにやら、ややこしいことがごしゃごしゃ書いてある。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "三人目",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく蒼い顔をしていますね」「実にどうも、二進も三進もゆかないことになって……」　先生はうっすらと汗をかいて、両手の中で手巾をごしゃごしゃにしたり、引っ張ったりしている。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな、急に声が低くなって、額をあつめて、ごしゃごしゃと話し合っているところへ、芳衛さんが、細かい花模様のある、提灯のように裾のひらいたオーガンジの服を着て、気取ったようすで入って来た。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿紙の上に、こまかい例の私の字でごしゃごしゃと（一）（二）という下に書きこんであって、そこから様々の情景と人々の生活が歴史の中に浮上って来る。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
