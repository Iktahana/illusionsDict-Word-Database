      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "error in copying",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陸閉といふ地は不明だが、蓋し降間の誤写で、後の岡田郡｜降間木村の地だらうといふことである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　正誤表に載せてある誤には、誤植もあれば、誤写もある。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤植や誤写の外に、誤訳がある。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤植や誤写は自分に発見し易いが、誤訳はそれがむずかしい。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　以上のうちで伊庭君の指摘せられた誤訳は、他の誤植や誤写なんぞと一しょに、最初別々に印刷した第一部と第二部との正誤表に載っているが、杉君と向君との指摘せられた誤訳は両部を合併して、ファウスト考に添えるはずの正誤表にだけ載っている。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『曾我物語』に、仁田忠常が頼朝の眼前で仕留めた「幾年経るとも知らざる猪がふしくさかく十六付きたるが」とは誤写で、何とも知れがたいが、多分何かの木が生えていたとあったのかと思う。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "改作二句・伸びて伸びきつて草の露・柿は落ちたまゝ落ちるまゝにしてをく『後記』昨日の誤写を補足して置かう、――いはゞ引越祝をやつた記事の追加だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤読か誤写か、乃至排印に当つての誤植か知らぬが、兎に角誤謬があるらしく見える。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しさうだとすると、誤写も誤植もありやうがなくなる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と思はれる註がウタカタの誤写ならば、此からの話とも関聯があるのだ。",
              "citation": {
                "source": "言語の用語例の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "文献時代の誤写か、其に先つ伝承時代の聞き違へ、聯想の錯誤かとも思はれるが、古典研究に大切な準拠をなくする事になる。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も同じ図書館に「南高来郡一揆之記」といつて南の一字加はつた写本もあり、之は上中下三冊になつてゐるが、内容は同じ物で、前者の方が誤写や脱字が尠いやうに思はれた。",
              "citation": {
                "source": "島原一揆異聞",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "古義では、「アキラケクといふは古言にあらず」として、キヨクテリコソと訓み、明は照の誤写だろうとした。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○楽浪の比良山風の海吹けば釣する海人の袂かへる見ゆ　〔巻九・一七一五〕　柿本人麿歌集　槐本歌一首とあるもので、槐本は柿本の誤写で人麿の作だろうという説がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、田楽｜林・林田楽など言ふ語のあつた事は事実で、此「林」を「村」や「材」などゝするのは、誤写から出た考へ方であります。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについて伊勢貞丈は、その安斎随筆において、案ずるに大蔵は火蔵の誤写にして、火蔵は火葬なるべし。",
              "citation": {
                "source": "火葬と大蔵",
                "author": "焼屍・洗骨・散骨の風俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "集解の穴の説に、泥部を「波都加此之友造」とあるのは、必ず「波世都加比之友造」の誤写であるに相違ない。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだしここに「波都賀此」とは、疑いもなく「波世都賀比」の誤写で、泥部すなわち「ハセツカヒ」の「トモノミヤツコ」であったに相違ない。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の両文書、ともに誤写、読みにくいところもあるが、今彼此を参酌して当時の事情を推測してみると、大要次のような事件があったらしい。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山脈北西方大烏帽子岳ニ連リ、山脚東方赴クモノ芦沢ノ両岸ヲ圧シテ利根川ニ限リ、南方ハ字宝川ニ至ツテ布川山（○布引山ノ誤写）トナリ、北方山羊沢ニ達ス。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみれば剥解之問は訓解之問の誤写であろう。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの個所を斉魯二篇河間七篇の誤写と見ることである。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに目撃候｜間、如此の事また候へば云々」（末の方は誤写があるらしい）。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "菫の方言など一　諸君｜蒐集の民謡はいつも大なる興味を以って拝見していますが、その中には今はもう歌わないもの、ある老人が僅かに記憶していたもの、意味の不明で誤写だろうかと思うものなどがあって、地上楽園も時としては枯野をあるくような感じがします。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "このツシヤは明らかに誤写ではなく、少なくとも四つ以上、『おもろ』の中に出てくるから、そういう語がもとあったのである。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（好ぎたって云ったらおれごしゃぐど思うが。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのこらぃなごと云ってごしゃぐような水臭ぃおらだなぃな。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、中折帽を取って、ごしゃごしゃと、やや伸びた頭髪を引掻く。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いかにも、そんげえなものには怯えまい、面魂、印半纏も交って、布子のどんつく、半股引、空脛が入乱れ、屈竟な日傭取が、早く、糸塚の前を摺抜けて、松の下に、ごしゃごしゃとかたまった中から、寺爺やの白い眉の、びくびくと動くが見えて、「蜻蛉だあ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人でない人が見たら、行進中の旅団があらわすようなこの長ったらしい重苦しい行列は、やけに七面倒くさい、ほとんど了解に苦しむごしゃごしゃ騒ぎに見えるのが常だ。",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
