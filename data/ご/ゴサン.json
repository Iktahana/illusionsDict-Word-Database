[
  {
    "uuid": "df9890d4-210f-5ffe-9c5b-c804e90429df",
    "entry": "午餐",
    "reading": {
      "primary": "ごさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lunch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "またある時は若い婦人に扮装して午餐会に現われ、父の隣席に坐って一座を驚かせた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はマルリンクの処へ午餐に呼ばれましたので。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "儀式には厭だから行かないが、午餐だけは断るわけにも行かないものですからね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに午餐といっても極近い親類や友達の外は呼んでないのだそうです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつは風が甚だしく寒いので、更に品川の町に入り、海寄りの小料理屋へ上って、午餐を喫いながら硝子戸越しに海を見た。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "午餐の済んだ後、市郎は縁側に立って、庭の南天の紅い実を眺めていると、父の安行が又入って来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "白帝園はカンツリー・クラブの大食堂で私たち三人――私と素峰子と運転手と――が、この八月六日の極めて簡素な午餐を認めていた時に、たまたま給仕を通じて私に挨拶に見えた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の報酬はいうに足らぬほどなれど、棲家をもうつし、午餐に往く食べもの店をもかえたらんには、かすかなる暮らしは立つべし。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が文書を受領して大臣の室を出でしとき、相沢はあとより来て余と午餐をともにせんといいぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "午餐する茶を沸すと、草取りに畑へ行きし、下婢は今かへり來らし。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど時分がよかったので午餐まで出して一本｜燗けた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "午餐にはフエデリゴ新に獲たる友だちと、我を誘ひ出して酒店に至り、初め白き基督涙號を傾け、次いで赤き「カラブリア」號を倒し、わが最早え飮まずと辭むに｜闊く漲り遠く下ればなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが姫の面を見しは午餐の時なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "午餐もお品は欲しくなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日の午餐過に卯平は使と共にのつそりと其の長大な躯幹を表の戸口に運ばせた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "午餐に家の者は田から戻つて其の飯を喰べた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午にはまだ間があるうちに午餐の支度を急いでおつぎは田圃から茶を沸しにのぼる。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "午餐過からおつぎは縫針へ絲を透して竿へ附けて與吉に持たせた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "午餐に勘次が戻つて、復口中の粗剛い飯粒を噛みながら走つた後へ與吉は鼻緒の緩んだ下駄をから／＼と引きずつて學校から歸つて來た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ」と與吉は脣を反らして洟を啜りながら「先生そんでも、明日は日曜だから此れつ切で歸つてもえゝつちつたんだ」「午餐くつたか」卯平はのつそりと飯臺の側に近づいた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは午餐から開墾地へ出る時、菜にする干納豆を汁椀へ入て彼の爲に膳を据ゑて行つたのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "二八　勘次は午餐過になつて復た外に出た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の報酬はいふに足らぬほどなれど、棲家をもうつし、午餐に往く食店をもかへたらんには、微なる暮しは立つべし。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が文書を受領して大臣の室を出でし時、相澤は跡より來て余と午餐を共にせんといひぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の報酬はいふに足らぬ程なれど、棲家をもうつし、午餐に往く食店をもかへたらんには、微なる暮しは立つべし。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんもお草臥だらうから、お湯にでも入つて、さうして未だ御午餐前なのでせう」「いえ、※車の中で鮨を食べました」　三人は倶に歩始めぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "午餐が済んで人々がサルンに集まる時などは団欒がたいてい三つくらいに分かれてできた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漣はその時あたかも『新著百種』中の『妹背貝』を書終って、丁度発行所の吉岡書店から原稿料を請取って来た処だというので、紅葉はソンナラ午餐を奢れといい、自分は初対面であったが、三人して上野の精養軒へ行った。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあおめざめでしたか、あんまりよくお寝みでしたから、お午餐も差しあげませんで」　と言いながら、ばあやが夕食を運んできた。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきりが林の向ふの沼の方に逃げながら、「ふいごさん。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
