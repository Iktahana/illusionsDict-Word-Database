        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして泣き泣き大声を張りあげて、「ご覧くださいまし。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞご覧くださいまし」とそのたちばなを両手にさしあげて、繰りかえし繰りかえし、いつまでもそのお墓の前で叫び続けて、とうとうそれなり叫び死にに死んでしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何枚か新しい踊る人形を、ぜひご覧ください。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですがその間がみなじゅうぶんとは言い難いため、ご覧ください、あとの男が『時の』と『分前』のあいだに『十五』を押し込んでいます。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞご覧ください」　と言い残して事務員は立ち去った。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "内にはいってご覧ください」「さあさあ内へ、さあさあ内へ」　まるで車掌が電車の中へ客を追い込もうとするかのようにむやみに内へを連発する。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞご覧くださいますよう」「どれ」　と信輔は受け取った。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語原文は Job 39:25, King James Bible \"Authorized Version\", Cambridge Edition（http://www.kingjamesbibleonline.org/Job-39-25/）をご覧ください。",
              "citation": {
                "source": "チカモーガ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "私をご覧くださいまし！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあさあ皆さんご覧ください。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "HTML 版をご覧ください。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、SI 単位系に換算した部分の注記も HTML 版をご覧ください。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぁ、ぜひ、この機械をご覧ください。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じっと、つぶさにご覧ください。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドミン　ご覧ください。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここをご覧ください、お嬢様。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "単位を SI にした部分は HTML 版をご覧ください。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "くだんのものか全部ご覧ください」　半時間、大統領が目視で読んだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の子供をご覧ください。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソファを離れながら彼を振り向き、「よろしかったらご覧ください」　と言った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをご覧ください」　マクスグラジャ大将は話しながら、ポケットから白い包みを取り出して、紙袋を破った。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞご覧くださいませ。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――いや、確たる証拠もないと仰ッしゃいますが、この二品をご覧ください。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "囚人の詩か」「いえいえ、そこはともかく、詩句すべてに流れている不逞な反逆の血と、その恨みかたの凄まじさをご覧ください」「いかさま、これは革命者の心胆の迸しりだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをあとでご覧ください」　と、何やら書簡らしい物を、そっと手に握らせて、風のように立ち去ってしまった。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつご覧くださいませぬか」　彼の好学をそそって、ついに閣の上に誘った。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずご覧ください」　と、主人の前に差し出した。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心をごらんください。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、あなたがたもご商売でしょうが、わたくしの声や顔付きをよくごらんください。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、もっと近よってごらんください。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
