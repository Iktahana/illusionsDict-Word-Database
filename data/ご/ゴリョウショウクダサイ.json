        "examples": {
          "standard": [
            {
              "text": "工事中はご不便をおかけしますが、何卒ご了承くださいませ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "こちらの変更点について、皆様のご了承をお願いいたします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "予約が混み合う時期ですので、ご希望に添えない場合がございます。何卒ご了承ください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何ぶん古い作品ですのでご了承ください。",
              "citation": {
                "source": "チカモーガ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪奇小説の古典としての歴史的価値から、そのまま訳出したものですのでご了承ください。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史的な価値に鑑み、そのまま訳出しましたのでご了承ください。",
              "citation": {
                "source": "絞首刑",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品には差別に関わる今日では社会的に受け入れられない表現がありますが、時代背景に鑑みそのまま訳出しましたのでご了承ください。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
