        "examples": {
          "standard": [
            {
              "text": "あの金持ちはかなりの業突く張りで、びた一文も無駄にしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "業突く張りの彼は、他人の不幸を顧みず自分の利益を追求した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちのお菓子まで取り上げるなんて、本当に業突く張りな人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
