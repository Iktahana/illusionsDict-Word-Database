    "definitions": [
      {
        "index": 1,
        "gloss": "rush mat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "母親は青葉の映りの濃く射す縁側へ新しい茣蓙を敷き、俎板だの庖丁だの水桶だの蠅帳だの持ち出した。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍に茣蓙を敷いてブリキの独楽を売っている老人が、さすがに怒りを浮かべながら、その下駄を茣蓙の端のも一つの上へ重ねるところを彼は見たのである。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時の茣蓙遊びの記憶――ことにその触感が蘇えった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな上へ茣蓙を敷いた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「子供というものは確かにあの土地のでこぼこを冷たい茣蓙の下に感じる蹠の感覚の快さを知っているものだ。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして茣蓙を敷くやいなやすぐその上へ跳び込んで、着物ぐるみじかに地面の上へ転がれる自由を楽しんだりする」そんなことを思いながら彼はすぐにも頬ぺたを楓の肌につけて冷やしてみたいような衝動を感じた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どッこいしょ、）と暢気なかけ声で、その流の石の上を飛々に伝って来たのは、茣蓙の尻当をした、何にもつけない天秤棒を片手で担いだ百姓じゃ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ、廻り縁の座敷に、畳屋の入つてゐたのも、何となく心ゆく都の時雨に似て、折から縁の端にトントンと敲いた茣蓙から、幽に立つた埃も青い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェルト草履は、見た眼にも優雅で、それに劇場や図書館、その他のビルディングにはいる時でも、下駄の時のように下足係の厄介にならずにすむから、私も実は一度はいてみた事があるのであるが、どうも、足の裏が草履の表の茣蓙の上で、つるつる滑っていけない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも茣蓙で包んで上箱に入れて、貴重品扱いにして門司の山九運送店宛に出して下さいな。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてあの娘は重たい島田を振立てて壺を振りまする以上、鉢巻を致しておりませぬ事には、第一、盆茣蓙の景気が立ちませぬ」「何と……あの娘が壺を振ったと申すか」「振りますとも、振りますとも。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは貴方のお話の、盆茣蓙の壺とやらを、お熊さんが振らっしゃったのは……」「……親孝行の一心からで御座いまする」「ヘエッ……そのような親孝行が……」「……御座いますから世間は広い。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤けた天井からは勿論、真黒な自在鍵、周囲に縄や茣蓙張りの椅子なぞ。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして梨を作り、墨絵をかきなぐり、めりやすを着用し、午の貝をぶうぶうと鳴らし、茣蓙に寝ね、芙蓉の散るを賞し、そうして水前寺の吸い物をすするのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その根に、茣蓙を一枚の店に坐ったのが、件の婦で。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちまた、その伝で、大福｜暖いと、向う見ずに遣った処、手遊屋の婦は、腰のまわりに火の気が無いので、膝が露出しに大道へ、茣蓙の薄霜に間拍子も無く並んだのである。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女児二　茣蓙の上に散っていれば、内でもお掃除するわ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今灯を点けたばかり、油煙も揚らず、かんてらの火も新しい、店の茣蓙の端に、汚れた風呂敷を敷いて坐り込んで、物｜馴れた軽口で、「召しませぬか、さあさあ、これは阿蘭陀トッピイ産の銀流し、何方もお煙管なり、お簪なり、真鍮、銅、お試しなさい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れ渡りの旅商人が、因縁は知らずここへ茣蓙を広げたらしい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　四十一　折から白髪天窓に菅の小笠、腰の曲ったのが、蚊細い渋茶けた足に草鞋を穿き、豊島茣蓙をくるくると巻いて斜に背負い、竹の杖を両手に二本突いて、頤を突出して気ばかり前へ立つ、婆の旅客が通った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に続く木川子、それにかく申す吾輩、殿軍としては五尺六寸ヌーボー式を発揮した未醒画伯、孰れも着茣蓙を羽織って、意気揚々｜塩原へこそ乗りこんだり。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、大きな茣蓙を抱え込んだものだから、日光避暑連中は目を回しておった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光へ着くと、未醒画伯は弟妹首を延ばして待っている郷家へ一夜の宿り、吾々三人はボロ洋服に茣蓙を引っ掛けて小西別館へと入り込んだ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上へ茣蓙を付し、檜木笠を被っているのだから「どうも御気の毒様で」といわれたのも無理はない。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤土の広場の松の、あちこちには、人のぶらつくのも見え、谷に臨んで、茣蓙毛氈を敷いた一組、二組も、色紙形に遠く視められる。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すでに、二日の日の午後、火と煙を三方に見ながら、秋の暑さは炎天より意地が惡く、加ふるに砂煙の濛々とした大地に茣蓙一枚の立退所から、軍のやうな人ごみを、拔けつ、潛りつ、四谷の通りへ食料を探しに出て、煮染屋を見つけて、崩れた瓦、壁泥の堆いのを踏んで飛込んだが、心あての昆布の佃煮は影もない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、結句此がために勢づいて、茣蓙縁臺を引摺り／＼、とにかく黒塀について、折曲つて、我家々々の向うまで取つて返す事が出來た。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒塀の、溝端の茣蓙へ、然も疲れたやうに、ほつと、くの字に膝をついて、婦連がいたはつて汲んで出した、ぬるま湯で、輕く胸をさすつた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りかゝつた見知越の、みうらと言ふ書店の厚意で、茣蓙を二枚と、番傘を借りて、砂の吹きまはす中を這々の體で歸つて來た。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
