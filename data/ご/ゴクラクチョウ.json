    "definitions": [
      {
        "index": 1,
        "gloss": "bird of paradise (Paradisaeidae family)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
