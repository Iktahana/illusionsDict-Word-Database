    "definitions": [
      {
        "index": 1,
        "gloss": "tribune (of ancient Rome)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
