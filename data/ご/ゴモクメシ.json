    "definitions": [
      {
        "index": 1,
        "gloss": "casserole of rice, fish or meat, and vegetables",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "豚の鼻十、五目飯で焚き込み。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅僧も私と同じくその鮨を求めたのであるが、蓋を開けると、ばらばらと海苔が懸った、五目飯の下等なので。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方では、相当な科学者の書いたものでも、単に読者の退屈を紛らすためとしか思われないような、話の本筋とは本質的になんの交渉もないような事がらを五目飯のように交ぜたり、空疎な借りもののいわゆる「美文」を装飾的に織り込んだりしたようなものもまた少なくはないようである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅僧も私と同く其の鮨を求めたのであるが、蓋を開けると、ばら／＼と海苔が懸つた、五目飯の下等なので。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの家にもおばあさんがあって、僕の来たのを珍らしがって、丁度きょうは先祖の御命日とかで五目飯をこしらえたからまあ上がって、ゆっくり食って行けというので、僕も囲炉裏のそばに坐り込んで、その五目飯を腹いっぱいに食った。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の時には蜜柑と五目飯の生薑とが一座の眼をあざやかにした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなりから粕漬、お寺から五目飯を頂戴した、何とでつかい胃袋！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日はおとなりから五目飯を、今日はお寺から小豆飯を頂戴した、感謝々々。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十五　五目飯　と申すのは色々の野菜を入れたものです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうそう」と三吉も思出したように、「丁度岩沼の基督降誕祭に招ばれて行った後へ、君が訪ねて来て……あんな田舎らしい基督降誕祭に遭遇ったことは僕も始めてでしたよ……信者が五目飯なぞを煮いて御馳走してくれましたッけ。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨董飯（ピピンパッフと呼ぶ五目飯）に舌鼓を打った。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家婦が「五目飯」を馳走してくれた。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのために五目飯や三題噺のようなことにはならず、渾然として一体になっているのが、この句の手際であろう。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘酒だの五目飯などひさいでいる腰掛茶屋で、そこは門司から小倉への中間ぐらいな大道路の傍らで山というほどでもない小高い丘の登り口にある角店である。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のごもくめしの好きな連中でした。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食はお寒いごもくめしですませて座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼終り、支那グリル一番のごもくめしと、焼売。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
