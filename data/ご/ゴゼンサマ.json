      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "coming home after midnight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）　ごぜんさまはね　いつも　いらいらしてる　おばさまのこと。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう　どうしようもないとこだったんだけど、　そこへなんと　たまたま　しろウサギが　ごぜんさまのもとへ　むかうところ　このひろまを　とおりがかったんだ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶつぶつ　ひとりごとを　いっててね、「あいや、　ごぜんさま、　ごぜんさま！",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから　てぶくろも　おうぎも　ないままじゃあ　そりゃあ　ごぜんさまのところへも　おうかがいできない。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく　ごぜんさまのところへ　むかったんだ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "８　ブタの　あかちゃん　アリスが　ごぜんさまのところへ　うかがった　おはなし、　ききたい？",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごぜんさまは　おへやの　まんなかに　すわって　あかちゃんを　あやしてる。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごぜんさまは　すてきな　ぼうしと　ガウンを　みにつけてる、　よね？",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごぜんさま　アリスには　ひどく　ぶしつけで。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしぶりの　おともだち、　ごぜんさまと　おはなしするためにね。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
