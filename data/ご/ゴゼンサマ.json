[
  {
    "uuid": "5c156873-13b2-552c-ae1e-9d7e0e1882d6",
    "entry": "午前様",
    "reading": {
      "primary": "ごぜんさま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "名詞"
      ],
