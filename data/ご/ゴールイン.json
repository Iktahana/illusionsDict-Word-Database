        "examples": {
          "standard": [
            {
              "text": "10年間の長い交際期間を経て、二人はついに来月の吉日にゴールインすることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学生時代からの憧れのカップルがゴールインしたという知らせに、友人たちはSNSで祝福のメッセージを送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はプロポーズの成功を同僚に報告し、「ようやく彼女とゴールインできました」と照れくさそうに笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
