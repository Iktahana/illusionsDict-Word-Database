    },
    "definitions": [
      {
        "index": 1,
        "gloss": "purveyor (to the Imperial Household, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ときどきには同役や御用達町人なども連れて来る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が思うだろう、この小さく愛らしい石が、絞首台と監獄への御用達であると。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし明日にもさうと云ふ御考でゐらつしやるならば、私……こんな事を申しては……烏滸がましいので御坐いますが、大した事は出来ませんけれど、都合の出来るだけは御用達申して上げたいのでございますが、さう遊ばしませんか」　意外に打れたる貫一は箸を扣へて女の顔を屹と視たり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用学者に御用歴史家、御用商人に御用達、御用御用と呼びかける捕り手の奴ばらときたひにはとても悪趣味で鼻持ちがならない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時眞志屋の先祖が御用達をいたしてゐますので、内々お許を戴いて死骸を引き取りました。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだお前さんから、いろんな農産物を買うつもりだったけれど、仕方がない、私は政府の御用達も務めていますからね……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用達という言葉が、強くナスターシャ・ペトローヴナの心を動かした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただね、あんたさん、その御用達の話ですがね、裸麦の粉だの、蕎麦粉だの、挽割麦だの、または屠殺した家畜だのをお買い上げになる時は、どうぞ妾に恥をかかせないで下さいよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そいじゃあ、どうか、御用達の節にはお忘れにならないで下さいよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の金融は、そのほかに幕府や諸藩の御金御用達があつた。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "油堀は問屋町で、伊勢八は伊東八兵衛という水戸侯の金子御用達であった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女たちは幕府のころ、上野の宮の御用達をつとめた家の愛娘であった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば年来、政府の御用達は三井八郎右衛門で、政府の用を聞くのみならず、役人等の私用をも周旋するの慣行でした。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がその富豪は王様のお妾がいつも借金の必要に迫られてゐる事を知つてゐたので、内密に其の金子を御用達しませうと、申し込ませた。",
              "citation": {
                "source": "フランソア・コッペ訪問記",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は御目附の外御側御用達を兼務していたから、この度の如く世子が京都へ行かれて朝廷や幕府の間に多少の斡旋奔走せらるる際は、別して補佐の責任も重かったため、病気を押した結果、遂に大患にもなったのであるから、世子その他の人々もこの事については頗る心配されて、療養上の保護も厚く受けていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲「ハテ恵比寿麦酒の会社長で、日本で御用達の発りは、蛭子の神が始めて神武天皇へ戦争の時｜弓矢と酒や兵糧を差上げたのが、御用を勤めたのが恵比須の神であるからさ。",
              "citation": {
                "source": "七福神詣",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠太郎は二十歳の青年で、尾張家｜御用達の大町人、清洲越十人衆の一人として、富と門閥とを誇っている、丸田屋儀右衛門の長男であった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が禿げかかってるせいでもありますまいが、ばか丁寧な口の利きようをするくせに、いやに図々しく、月にどのくらい食いこみになりますか、それは困ったものですね、少しのことなら御用達しましょうと、そういった調子なんです。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府直属の金貸しといえば、御為替方御用達じゃ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを上州前橋竪町の御用達で清水助右衞門と直してお話を致します。",
              "citation": {
                "source": "西洋人情話英国孝子ジョージスミス之伝",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "春見は困り果てゝ居ります所へ入って来ましたのは、前橋竪町の御用達の清水助右衞門という豪家でございます。",
              "citation": {
                "source": "西洋人情話英国孝子ジョージスミス之伝",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "清「此の観音さまは見た事があるが、慥か持主は上州前橋の清水という御用達で、助右衞門様のであったが、何うしてこれがお前の手に入ったえ」ま「はい、私は其の清水助右衞門の娘でございます」　と云われ清次は大いに驚きましたが、此の者は何者でございますか、次に委しく申上げましょう。",
              "citation": {
                "source": "西洋人情話英国孝子ジョージスミス之伝",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方は予て約束もありますから、橋本幸三郎方へお藤を縁付けたいと云う事で、彼の川口町の橋本幸三郎と云う御用達の家へ縁付けました。",
              "citation": {
                "source": "霧陰伊香保湯煙",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは四つ目の藤野屋杢左衞門と申してお駕籠御用達しで、名字帯刀御免の分限でござります。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると先程より藤野屋杢左衞門の娘お花と申して今年二十一歳に相成り、近辺で評判な別嬪の娘ですが、不思議な女で、御用達のお嬢様で有りながら絹布を着た事は有りません。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "多助の女房になりますのは前囘に申上げました通り、御用達藤野屋杢左衞門の娘お花で、実に別嬪でございます。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は米次郎といった人で、維新前までは、霊岸島に店を構えて、諸大名がたのお金｜御用達を勤めていた。",
              "citation": {
                "source": "花を持てる女",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "船橋は有名な古肆で、御菓子司の称号を暖簾に染め出していた御用達である。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし人、吾人に向かって今日の有名なるわが邦の紳商は封建時代のいわゆる官吏の一部ともいうべき御用達といくばくの相違あるかと問わば、吾人はいまだその相違の点を挙ぐるあたわざるに苦しむなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり旅の者はもちろん、怪しい浪人体のものは休息させまじき事、俳諧師生花師等の無用の遊歴は差し置くまじき事、そればかりでなく、狼藉者があったら村内打ち寄って取り押え、万一手にあまる場合は切り捨てても鉄砲で打ち殺しても苦しくないというような、そんな御用達所からのお書付が宿々村々へ渡っていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
