    "definitions": [
      {
        "index": 1,
        "gloss": "tough negotiations",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、これが直らなかつたら打ち殺すぞとか、おこられてもいいから北海道の兄を呼び寄せて強談するとか、頻りにいろいろな恨み言を云つてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸幕府を直接｜覆したものは、創業の家康が極度に恐れた外様の雄藩、強藩ではなくて、志士と呼ばれる下級武士の活躍であり、大頭鯨を追つて来た船を保護するために、アメリカ政府が持ち込んだ強談判であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒武者は茶飲み茶碗か何かで酒をあをりながら、あの人を、おどしたり、すかしたり、様々に弁舌を弄して強談判を持ちかけてゐるのですが、決して埒があきません。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛吉さん、お前が酒と連立ったんじゃ、向上から鴨川で対手になってくれやしない、序幕に出した強談場だし、若干金かこっちから持込というのだから、役不足だったろう、まあ飲むが可い、」と笑っている。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それだよ、その事だよ、何も、押借や強談なら、」　しかり、押借や強談なら、引手茶屋の女房の、ものの数ともしないのであった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「荷物をおろして下さるか、お祭りを停めて下さるか、さあ、どっちですって、あたし、今朝っから強談判をしているところなのよ」　娘たちは声を立てて笑う。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽輩の分際として、老職へ、強談するのか、身に――身に――」　斉興が、興奮した手から、湯を溢そうとするのを、由羅が、手を添えて「将曹――二人を退げてたもれ」「退れっ」　斉興が、八郎太の方を睨んだ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が大使に強談判をして……」「いや、そんなことをしても無駄じゃ。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（田沼様に直々逢い、お浦をかせに強談し、ふたたび禄をいただくか。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいよいよお浦をかせに、田沼様に強談しようものと、このうちこわしの夜に出て来たのであった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……姉小路卿と梶子という婦人――有名な女隠密だが、この二人を抱き込んでよ、かつて殿様がお捕えになった徒党――明暦義党の沢山の徒党を、許してくれと強談しているそうだ」　こう憎さげに云ったのは、口もとのしまっている男であった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町「あいたゝ／＼」　蟠「さアこれでもか、何うだ／＼」　と無理｜強談、折柄暮方の木蔭よりむっくり黒山の如き大熊が現われ出でゝ、蟠龍軒が振上げた手首をむんずと引ッ掴み、どうと傍に引倒しました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしてくれるかどうかとの強談判に過ぎないので、人のせゐではなかつた。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはお辞儀といふよりも、何か強談を持ちかけるといつた工合の、一種の身構への感じられる強つい調子だつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再々｜強談判を重ねたあげく、一夜のこと当家先代の番頭今居定助と申す人がオーカミイナリの先祖の古墳と申すところで神の矢に射ぬかれて殺されておりました。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "なくなった夫人が庭にイナリのホコラをたてて朝夕の参詣を欠かさなかったのも、そのタタリを怖れてのせいでした」「上京後もオーカミイナリの強談判はひきつづいていましたか」「私が当家へ参って後は、そのような形跡はありません。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから天狗の強談判がはじまると人々は、蛭川さんにいたく同情したものですよ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで先生のこれまでの履歴と抱負を話して下さい」と、お互いにあぐらを組んでの強談判といった工合である。",
              "citation": {
                "source": "実践について",
                "author": "――馬になった話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、何の事は無い、「素人で左様釣っては、商売人の顔を踏み付けた仕打ちだ、大抵好い加減に釣ってれば好いに」という、強談なのです。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "船乗は迷信深いものだから、つまらぬ気迷いを起さねばいいがと案じていると、果して伊豆柿崎の三郎助という水夫が、端舟を捨ててやらなかったので、要吉の怨みで船がひき戻されたのにちがいない、死んだものの思いのかかった端舟だから、この際、どうでも捨ててもらわねばならぬと、血相変えて強談にかかった。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより猿の湯に引き返し、強談もて娘を申し受くる所存に候。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、着物を買い過ぎて、呉服屋へ借金のかさんだ女へ、その呉服屋に代わって、払いの強談を持ちこんでやるのだが、愚かな女だ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく珊瑚が戻ったのだから、今度だけは内済にして、そのうえ別に強談もしなかったという。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "うし紅珊瑚",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにも関せず、盗難にでも罹ったかのごとくに思ってるらしい主人がいかに軍隊の歓迎だと云って、いかに華族様の勧誘だと云って、強談で持ちかけたらいざ知らず、活版の手紙くらいで金銭を出すような人間とは思われない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十三世修理太夫｜利視のときには、芝の増上寺から借りた二千両の金の期限がきても返済できずにいたところ、増上寺の坊主どもが八十人ばかり上邸へおしかけ、登城しようとして玄関先に出てきた修理太夫の袂をとって強談したような例もあるが、途上の待伏せは、これが最初であった。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女が私の一座にいるうちに、殴り込み、ゆすり、喧嘩、強談を持込まれたことは幾度あったかわからないほどで、ここにいる女房のお六が証人でございます」「人柄は？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもいけない時は、法來坊が四十八貫の鐵棒を持つて押し出し、大地を叩いての強談判だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "からくり屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下手人を出さなければ、本日正｜午の刻、龍の口評定所へ訴出ると言ふ強談ぢや。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
