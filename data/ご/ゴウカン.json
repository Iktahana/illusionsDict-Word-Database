[
  {
    "uuid": "af2a0358-958c-5de3-b726-1f8130e9a81e",
    "entry": "強姦",
    "reading": {
      "primary": "ごうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rape",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "強姦でも、強盗でも、窃盗でも、自分の経験を大ッぴらに喋りちらした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この馬賊上りの、殺人、強盗、強姦など、あらゆる罪悪を平気でやってのけた鬚づらの豪の者が、娘々したすゞに少なからず参っている有様は、実際不思議だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一方の窓の上の壁には、人民から強奪、強姦して国を売る張作霖の漫画と、共産党とソヴェートロシアを、「共産賊党」「赤色帝国主義」と称しているポスターが、電燈の陰影の背後に、ボンヤリと並んでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生から、掠奪、強姦を仕事のようにやっていた彼等である。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中津が強盗、殺人、強姦などをやってきた、そして多くの人々から、恐るべき蝎として、嫌われ、おっかながられている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――張作霖、張宗昌、強盗、強姦、売国的………　ふと、一郎は、両手で彼女の手からビラを叩き落してしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝都の真中で密売淫や強姦を十分に取締る事の出来ぬ警察力や、待合の二階で醜業婦共に鼻毛を読まれている当世の大臣や役人｜輩に、盆踊り位をとやかくいう権能は余りあるまいテ、馬鹿な話である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありふれた強盗、強姦、殺人事件にばかりぶつかって最初から犯人のアタリを附けてかかる流儀に慣れ切っている草川巡査は、この事件に限って、実際、暗黒の中を手探りで行くような気迷いを感じながら、駐在所を出たものであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人、放火、強姦、身をふるわせてそれらへあこがれても、何ひとつできなかった。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、強姦という極端な言葉さえ思い浮んだ。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのはかの騷動の時、渠等のうちには、その妻女は直參派の爲めに強姦されたり、妊婦はその局部を竹槍で刺し通されたといふ樣な目に會つてゐるものがあるからである。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "強姦奪掠憚らねば、市街の商人は武裝して、我が暴行を防がむとす。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし隋の煬帝、父を弑し継母を強姦し、しかして仏教を尊信することはなはだし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "強盗殺人犯の脱監密通した令夫人鉄道線路の飛び込自殺××氏の毒物嚥下山林中の強姦未遂。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは物盗りを死刑するやうにではない、強姦者を処刑するやうにではない、新しい階級的犯罪に新しい死のタイプを我々が与へるのだ。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "強姦に関する研究を述べたので、医学法学上大いに参考となり別に驚くに足りないものだったが、題号が突飛なので英国で出版むつかしくパリで出版して英国へ輸入した。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがまた、父親に強姦されるために生まれてきたみたいな、とんでもないブロンドだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆を噛りながら新聞を読んでゐると、強姦て活字がある。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "脅喝、詐僞、姦通、強姦、喰逃……二十も三十も一時に喊聲をあげて頭腦を蹂躙る。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "脅喝、詐偽、姦通、強姦、喰逃……二十も三十も一時に喊声をあげて頭脳を蹂躙る。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光の中には、強盗殺人犯か強盗強姦犯かの眼に見る獰猛な光と、高利貸かやりて婆さんかの眼に見る意地の悪い執拗な光とを併せていた。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊＊＊店員たちが縛りあげられた、その眼の前で女房を強姦しその上五千円近い金を掠奪された。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この左官に時計屋が、強盗殺人強姦の犯人であるとは――何んと立派な手柄であることか！",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が仮令えば、愛する良人を持って、その愛に対する本能的な純粋さを持ち、希望し、勿論そのために総ての誘惑は可抗的なものであっても、若し泥棒や何かに強姦されでもした場合、単に生理的にでも、同じような亢奮を感じるものと仮定すると、如何に其を自然だとは云え、淋しい気がする、というのである。",
              "citation": {
                "source": "無題（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、渠等には淡路をなつかしい故郷と思ふ樣な氣がなかつたと云ふのは、かの騷動の時、渠等のうちには、その妻女は直參派の爲めに強姦されたり、姙婦はその局部を竹槍で刺し通されたといふ樣な目に會つてゐるものがあるからである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "強姦や姦通の事件だから、よくない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
