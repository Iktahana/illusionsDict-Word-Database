        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大抵の登山者は、ここで一息いれる、水を飲む、床几にごろりと横になるのもある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして眠くなると、虹でも吐くやうなをくびを一つして、ごろりと横になるのです。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のほうから、このとおり、もうたかってくるんだからね」　それにはちょっと右門も顔を赤らめたようでしたが、宵の五つ半といえばまだだいぶ間がありましたから、名人閑日月のたとえどおりごろりと横になると、ここちよげに午睡の快をむさぼりだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の隅にごろりと横になる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お腹がへって、からだが疲れてふらふらしてくると、清造はどこか道ばたの木の根でも、お堂の縁にでも腰をおろして、ごろりと横になるのでした。",
              "citation": {
                "source": "清造と沼",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ごろりと横になる）ふみ　いやだわ。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "どりゃすこし睡るとしよう」　遠慮を知らぬ金博士のことであるから、あわてるチーア卿を相手にせず、ごろりと横になると、早ぐうぐうと大鼾。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（諦めて起ち上り、押入の中から掛蒲団を出し、それにくるまつてごろりと横になるが、突然、頭をもたげ）おい、飯はどうするんだ、飯は……。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺子屋机の前に、袴も取らずに坐っていた馬琴は、何んと思ったか、急にその場へごろりと横になると、如何にも屈托なさそうな欠伸をした。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "床を敷いて寝たものだろうか、ただしは着のみ着のままで、ごろりと横になるか、または昨夕の通り柱へ倚れて夜を明そうか。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうちはそれでも夜になると家に帰つて来たけれどしまひには疲れて来れば処構はずそこらへごろりと横になる。",
              "citation": {
                "source": "吸血鬼",
                "author": "ジョン・ポリドリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……枕をもて」　ごろりと横になる。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々｜褥の外へ二本の脚を長々と伸ばして、ごろりと横になる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、こわれたいすを三つならべて、その上に、ごろりとよこになると、だいたんふてきなポケット小僧は、まもなく、ぐっすりと眠りこんでしまいました。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
