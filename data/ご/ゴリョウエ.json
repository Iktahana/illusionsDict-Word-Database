[
  {
    "uuid": "1a1a2d4c-9037-5a9c-985b-f32a855e8a66",
    "entry": "御霊会",
    "reading": {
      "primary": "ごりょうえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ceremony to appease evil gods and the spirits of the dead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "即、祇園・御霊会の起つたのが其である。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "端午の節供でもあるが、同時に昔の御霊会に関係があつたらしい。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月御霊は、古い御霊会を意味した名だが、かう呼ぶことが既に、色々な聯想の中心に立つた信仰のあつた事を示してゐる。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其から暫くして、御霊会に祇園会が行はれる。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園会成立に深く絡んだ御霊会の立て物に、宮廷の大嘗の曳き物「標山」の形をとりこんだのであつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "障神・八衢彦・媛の祭りと、御霊信仰とが一つになつて、御霊会が出来、盛んに媚び仕へを行うて、退散を乞うた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近い祇園御霊会細記などを見ても、江戸の末までも此｜名所が世間には忘られてゐながら、山・鉾に縋り付いて、生き残つてゐた事が知れる。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また栄華物語若枝の巻、枇杷殿大饗応の条に「御霊会の細男手拭して、顔を隠したる心持ちする」とある。",
              "citation": {
                "source": "はちまきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御霊会には、真の人間が扮装して出たのであらう。",
              "citation": {
                "source": "はちまきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都などでは、殊に此考へが盛んになつて、五个処に御霊様を祀つて、御霊会を行ひ、神を慰め、悪事をやめて貰つたのである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御禊は元より、御霊会の祓除「夏越し祓へ」の本処として、陰陽師の本拠の様な姿をとつたのである。",
              "citation": {
                "source": "貴種誕生と産湯の信仰と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "師義記に、貞治四年祇園御霊会の神輿を舁いだとあるエタも、おそらくこの犬神人の事であったと解せられる。",
              "citation": {
                "source": "サンカ者名義考",
                "author": "――サンカモノは坂の者",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば一方では、武家が祇園御霊会の神輿を舁かしめ、堂上家がエタに飲料水の井戸を掘らしめて、あえて不思議としなかった時代にも、五山の僧侶などは甚だしくこれを忌がったものである。",
              "citation": {
                "source": "エタに対する圧迫の沿革",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また貞治四年「師茂記」に見える「穢多」は祇園御霊会の駕輿丁であった。",
              "citation": {
                "source": "「エタ」名義考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「師茂記」貞治四年六月十四日の条に、武家の沙汰として祇園御霊会の神輿を穢多に舁かしめたとある穢多は、無論同社の犬神人たる坂の者を云ったものであろう。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "『山城名勝志』引「季瓊日録」（寛正五年）によれば、六月十四日の祇園の祭礼に、北畠から跳戈を出し、歌舞して御所へ参るのが旧例だとあって、此の徒が遊芸に由って御霊会の神事に仕えていたことがわかる。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の事実によると、足利時代の唱門師が下級の陰陽師で、祈祷もすれば初春の祝言も唱えると、近世の大和・三河等の万歳に同じく、また算置きと、歌舞遊芸とを兼ねることは、昔の傀儡師や後代の算所太夫のようで、また御霊会の風俗踊りに加わって前棒を勤めたのは、田楽法師・鉢叩き・鉦打にも似通うところがある。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の唱門師たる犬神人は甲冑を帯して御霊会の行列の先頭をつとめたり、時には神輿をも舁いだりしている。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都四周の大きな御社や寺で、御霊会または聖霊会と名づけていと花やかなる儀式の行われていたのも、要は共同にこれらの亡魂を慰撫して、人生に向ってその幽憤を漏らさしめぬためであったことは、記録がすでにこれを語り伝えている。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月七日の宵暁を中心としたネブタ流しを、一種の御霊会だと言う説は正しいと思う。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
