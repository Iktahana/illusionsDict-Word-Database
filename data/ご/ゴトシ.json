[
  {
    "uuid": "71e31f54-05d8-52b9-bb35-1a83d436d44e",
    "entry": "如し",
    "reading": {
      "primary": "ごとし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "補助動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "like",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "製作の経験も何もない野次馬たちが、どうもあの作家には飛躍が無い、十年一日の如しだね、なんて生意気な事を言っていますが、その十年一日が、どれだけの修業に依って持ち堪えられているものかまるでご存じがないのです。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等みな軍務を終りて、歸港の情に渇ける如し。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕月榛の木原に上りて、空は水の如し。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『間拔奴、見損やがつたか、汝、記憶えとけ、深川の芳兄いてで鳴らしたもんだい、手前達の樣な、女たらしに、一文たりとも貰ふ覺えはないぞ、ヘツ、どうだい、その面は、いやにキヨロツキやがつて、憚乍ら口惜しけりや腕ツコキで來い、白痴ツ』『女たらし』の一言に力を罩めて憤怒の焔燃ゆるが如し、果然彼には一物あり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『イヨー、大哥』『えらいぞ』『音羽屋ア』『やつちえねえ、骨はおれが拾つてやる』彌次馬の騷ぐこと、夕立の如し。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、それは困る、と生物學者のはうから抗議が出て、とかく文學者といふものには科學精神が缺如してゐる、などと輕蔑せられるのも不本意である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そが暗き思ひいつの日　　晴れんとの知るよしなくて、溺れたる夜の海より　　空の月、望むが如し。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金銀は卑しきものとて手にも触れず、仮初にも物の直段を知らず、泣言を言はず、まことに公家大名の息女の如し」とは江戸の太夫の讃美であった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "審査委員が如何に私情ないしは私利のためにもせよ、学位授与の価値の全然ないような低能な著者の、全然無価値かあるいは間違った論文に及第点をつけることが出来ると想像する人があれば、それは学術的論文というものの本質に関する知識の全く欠如している人に相違ないであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に、今日の教育と云うものが、学問的に偏し、技芸的に偏し、人格的精神的の教育が欠如して居るかと思ふ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣は雨に濡れたらんが如し。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲胄堂の婦人像のあはれに絵の具のあせたるが、遥けき大空の雲に映りて、虹より鮮明に、優しく読むものゝ目に映りて、其の人恰も活けるが如し。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の人も無げなる事、恰も妓を傍にしたるが如し。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の水を説かんとして先づ隅田川を説くは、例へばなほ水経の百川を説かんとして先づ黄河を説くが如し、説述の次第おのづから是の如くならざるを得ざるのみ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○浜離宮の北、離宮と海軍省用地との間の一水は前に説きたる如し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "深川側の川渠は大概かくの如し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京諸溝渠の大概は上記の如し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京湾は甚だ広けれども品川以北中川以西即ち東京の前面の海上は大抵上に説けるが如し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、「京管領細川右京太夫政元は四十歳の比まで女人禁制にて、魔法飯綱の法愛宕の法を行ひ、さながら出家の如く、山伏の如し、或時は経を読み、陀羅尼をへんしければ、見る人身の毛もよだちける。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅梅　紅梅の香なきは艶なる女の歌ごゝろ無きが如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞香　ぢんちやうげは、市人の俳諧学びたるが如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば聊か気質の偏りのある人の、年を積み道に進みて心さま純く正しくなれるが如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山桜桃　にはうめは、いと小さき花の簇れて咲くさま、花の数には入るべくもあらず見ゆるものながら、庭の四つ目籬の外などに、我は顔もせず打潜みたる、譬へば田舎より出でたる小女の都慣れぬによろづ鼻白み勝にて人の背後にのみ隠れたるが、猶其の姿しほらしきところ人の眼を惹くが如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃　桃は書を読みたることも無く、歌をつくるすべも知らぬ田舎の人の、年老いて世の慾も失せたるが、村酒の一碗二碗に酔ひて罪も無く何事をか語り出でつ高笑ひなせるが如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば肥へて丈高き女の、雪と色白きが如し、眉つき眼つきは好くもあれ悪くもあれ、遠くより見たるに先づ心ひかる。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば貴ききはにあらぬ女の思ひのほかに心ざま寛やかにて、我はと思ひあがりたるさまも無く、人に越えたる美しさを具へたらんが如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉は一葉をいたく小さくしたるが如く、一つの茎に花の六つ七つ五つ咲くさまは玉簪花の如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の風情はまことにこの物語に云へるが如し、人のさとりはこの物語にあらはしたるが如くならぬが多きぞ口惜しき。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああかの高きに星あり……………しづかに蛇の這ひ行くごとし。",
              "citation": {
                "source": "歡魚夜曲",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よやわが十指は晶結し背にくりいむは瀧とながるるごとししきりに掌をもつて金屬の女を研ぎ胴體をもつてちひさなる十字を追へば樹木はいつさいに※轉し都は左にはげしく傾倒す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
