[
  {
    "uuid": "0c1bc49c-62d3-5ea4-bd10-73ed4e686437",
    "entry": "極楽",
    "reading": {
      "primary": "ごくらく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
