    "definitions": [
      {
        "index": 1,
        "gloss": "Sukhavati (Amitabha's Pure Land)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旅館の主人、馬を勧め、剛力を勧め、蓆を勧め、編笠を勤む、皆之を卻く、この極楽の山、只一本の金剛杖にて足れりと広舌して、朝まだき裾野を往く。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、眼を上げて、世界の出来事を見ると、地獄と極楽との絵を重ねて見るような、混沌さを覚えた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお仏教語として品を呉音で読んで極楽浄土の階級性を表わす場合もあるが、広義における人事関係と見て差支ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとに民子さん、きょうというきょうは極楽の様な日ですねイ」　顔から頸から汗を拭いた跡のつやつやしさ、今更に民子の横顔を見た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「こんな極楽はない」　老人の悲痛な叫び聞いては、雪枝もホロリとせざるを得ません。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　極楽鳥の飾りをつけたフェルトの流行とは正反対のグランとツバの拡い帽子を目深にした身装、……流行品店の飾窓に映るかの女の姿態を裸体にするキャバレーの門柱のムーラン・ルージュ。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人が、地獄か、極楽かで、その金を出して、自分の休息場を買うのである！",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのエキゾティックなものに憧憬をもっていた子供心に、この南洋的西洋的な香気は未知の極楽郷から遠洋を渡って来た一脈の薫風のように感ぜられたもののようである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すたれ釘世をすぢかいになり下る　　　　　　　　底抜け徳利のチリンカラカラ古釘と底抜け徳利の風鈴は　　　　　　　　　　阿弥陀も知らぬ極楽の音　その蒲鉾板の裏表を手に取って引っくり返して見ながらニッコリと笑った良助は、その前の雨戸をガタガタと叩いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやぢが汗水たらして稼ぎためた大きな身代に倚りかゝつて愚図々々してゐる中には、ひとりでにその身代が手前のものになるから、それで飯を食つて死んでしまへば、この上なしの極楽だ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄と極楽とが手を繋いでいました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この心境を説明するのに、人間の言葉に詰って「極楽世界」とか「三昧王三昧」とか、いろいろなことを言いますが、やはり片手落ちの表現に過ぎません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教はもっと度量が広く、疑いつつ弥陀を念じても疑城胎宮（疑いを持ちつつ念仏するものの生れる極楽浄土の辺地）といって極楽圏に対して番外当選ぐらいのところまでは行けることに、浄土教の祖師たちは説明されていますものの、疑わないに越したことはありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七一課　モダン極楽・モダン地獄　地獄、極楽とは一応、私たちの心の状態を指します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対なのが極楽であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、モダン極楽もないことはありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "便利極楽、器械文明が安価に普及されて便利になったことであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭愛極楽、家庭というものが認められて来て、そこを中心に安楽境を作ろうとする傾向が多くなって来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "設備極楽、いろいろの設備でだいぶ公衆慰安の目的のものが増えて来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命安全極楽、昔から見ればどのくらい人の生命が保護されて来ているか判りません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、安楽というものは意識に上りにくく、苦痛の方は意識されやすいもので、極楽の方は拾い出しにくいのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に古来、文学上の名篇も地獄的の心境を書く方に傑作が多く、極楽的のものは少いとされております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代人の実感上、地獄感が多いか極楽感が多いかと言うと、勿論地獄感の方が多いと言う人が多いでありましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、仏教では現実上の極楽必ずしも絶対のものでなく、地獄もまた絶対のものでないと説くのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "因縁果の理法によって出来たものとすれば、その因と縁を突き止め、その善きを加え継ぐことによって極楽はいよいよ続き、地獄はその性を失う。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この理法を信じ望を失わず、善を積み、悪を斥けて、一歩一歩に努力の満足を得つつ行く、これが真の意味の極楽浄土であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚さんは大きい声をはりあげて、地獄やごくらくや仏様の話をしました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら念仏を申したとて、嫁をいぢめるやうな年寄はごくらくへはいけぬぞよ。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではとても和尚さんのお供をして、ごくらくとやらへはいけまい、と菊次さんは思つて情けなくなつたのであります。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつちの路がごくらくへつづき、こつちの路がろくでもないところへつづいてゐることが……。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
