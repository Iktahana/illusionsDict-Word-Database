        "examples": {
          "standard": [
            {
              "text": "彼の暗証番号は、五桁の数字で構成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この書類には、五桁の管理番号が振られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宝くじの一等賞金は、五桁の宝くじ番号によって決まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一桁の数にマルをつけると、百以下の差だし、二桁の数にマルをつけると、千以下の差だが、五桁の数にマルをつけると、十万乃至百万の差になる。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも三桁というのは、一般の場合であって、精密な物理の測定では四桁も五桁もちゃんと測定がなされていることもしばしばある。",
              "citation": {
                "source": "地球の円い話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
