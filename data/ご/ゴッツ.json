        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "是に於て誰か知ら然る可き人物を会津の主将に据えて、奥州出羽の押えの大任、わけては伊達政宗をのさばり出さぬように、表はじっとりと扱って事端を発させぬように、内々はごっつりと手強くアテテ屏息させるような、シッカリした者を必要とするのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人はにやにや笑って答えないが、若者の一人が真面目くさって考えこみ、多少ためらった末に「そりゃ、ごっつぉうの方がええ」と答え、「わしかてその方がええ」ともう一人の若者がそれに相槌を打つのを聞くと、その男は怒ったような破れ鐘のような声を出して怒鳴るのであった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと足とごっつんこだ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大声をとどろかせるクイーン、一同はてんでばらばらに走り出して、たがいにごっつんこ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "……若宮　さあてと、ごっつおさん。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年　……（紙袋の方も渡して、百姓の手元を見ている）百姓　そりゃ、へえ……ごっつおさまだ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（遠ざかりながら）馬流のお祭りにゃ、ごっつおして待ってるから、きっと来うよう！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はしばらくすると勝手へ出て行ったが、すぐ、生水を呷っているらしい喉鳴りがごっつりと、幾たびもつづいた。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから秒間はずっと伸びて胸ぐるしい腹這いから、少しずつらくにするためにからだをずらせると、機械にごっつりと打つかった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤油の空樽にどっかと腰かけて、ごっつい植木屋バサミで、枝豆をシャキシャキと枝から切り落している。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、体のつくりが極端にごっついため、ぼくよりずっと大きく感じられ、威圧的だ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
