        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」狸はいまは破れかぶれになり、「後生だから手を放せ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だから塗らせてくれ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がなくちゃ弁当が食べられないから、困ったなア、民さん、待っていられるでしょう」「政夫さん、後生だから連れて行って下さい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、三度々々ちゃんとご飯喰べてお呉れと云うに、さ、ほんとに後生だから」　母親はおろおろの声である。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だから……」そう云って歎願しているが、さっきの人達はもう行ってしまって、それに代る助力者も急には出て来なかった。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だから、しばらく踏み外さないでいろよ。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、後生だからあきらめてくれるな。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『まアそんなことを言わないで信仰してお呉れ、後生だから。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥さん、ウ※スキーを一杯後生だから飲ませてください」「あなた、そんなに飲んでいいの」　奥さんは本当に心配らしく、立ちながら、眉を寄せて渡瀬の顔を覗きこむようにした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは居ないし、兄やに云へばどなられるし……末ちやん後生だから昨日の事黙つて居ておくれ」　とおろ／＼声になつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千歳はおろおろ声になって、「後生だからそんなこと言わないで、あなたはお父様にお詫びして姉様と一緒になって――」　千歳が思わず取縋った慶四郎の手から、却ってぴりぴりするような厳しい震えを千歳は感じた。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりして下さいよ、後生だから、お前さん、私が附いてるから。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帰ったら何か持たして寄越さあ、邸でも、庫でも欲しかあ上げよう、こいつあ、後生だから堪忍しねえ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしといて頂戴、後生だから。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と手に唾して躍りかかれば、「あれ、後生だから後生だから。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だからそれだけは止しておくれ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれ、目の縁はまだしもよ、上は止して、後生だから。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――深更に無理を言ってお酌をしてもらうのさえ、間違っている処へ、こんな馬鹿な、無法な、没常識な、お願いと言っちゃあないけれど、頼むから、後生だから、お澄さん、姐さんの力で、私が居る……この朝だけ、その鷭｜撃を留めさしてはもらえないだろうか。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　小父者は外套の袖をふらふらと、酔ったような風附で、「遣れよ、さあ、（戻馬乗らんせんか、）と、後生だから一つ気取ってくれ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だから貢がしてくださいよ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だから早く勉強して、りっぱな人物になってくださいよう」　その音柔媚なれども言々風霜を挟みて、凛たり、烈たり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、後生だから置いて頂戴よ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だからお湯を一杯……。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だから若旦那をここまで呼んで来て頂戴。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、後生だから堪忍して与って呉れ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんは此処の勝手を知っていると云うなら、後生だから僕の家まで行って来て呉れないか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だから承知して呉れないか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……サ……ここから出せ……出してくれ……この檻の中から……そうして一緒に研究を完成しようじゃないか……ね……ね……後生だから……」　私は思わず熱い涙に咽せんだ。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生だから……あたし……」「どうしたんだい」「……………」　彼女が受話機を箱の上に置く音がした。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごしょうだから返して下さい。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
