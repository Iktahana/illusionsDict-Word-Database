[
  {
    "uuid": "11ab5b5e-64d2-5e8a-93a6-a69c6f1c545f",
    "entry": "五蘊",
    "reading": {
      "primary": "ごうん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
