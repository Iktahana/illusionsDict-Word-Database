    "definitions": [
      {
        "index": 1,
        "gloss": "study of foreign languages",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
