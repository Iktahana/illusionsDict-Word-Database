    },
    "definitions": [
      {
        "index": 1,
        "gloss": "go player",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "周防山口の地方裁判所に父が奉職して居た時分、馬場金之助という碁客が居て、父と非常に懇親を結び、常に兄弟の如く往来して居たそうです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦の間には二人の娘まで出来て、家庭は至極円満であったが、ふとしたことから囲碁に興味を持って、素人｜碁客の間では評判になるようになった。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新住職は三十四五の色の白い男で、愛碁家らしいので、早速対局してみると、素人碁客ではあるが彼女よりは遥に強かった。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "源はその女から囲碁を習ったが、上達が非常に速で、僅の間にその地方第一の碁客となった。",
              "citation": {
                "source": "緑衣人伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙技な碁客も傍観者の時は、時に好着手を見出すものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "法華信者が偏頗心で法華に執着する熱心、碁客が碁に対する凝り方、那様のと同様で、自分の存在は九分九厘は遊んでいるのさ。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "殖産に不適当なる人物なれば、いかなる卓識の先生も、いかなる専門芸能の学士も、碁客将棋師に等しくして、とても一家の富を起すに足らず。",
              "citation": {
                "source": "慶応義塾学生諸氏に告ぐ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそこに、碁客のそばに、置きざりにされた形になった。",
              "citation": {
                "source": "塩花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは碁客ではないけれども、伏見で石屋を営んでゐる五十三四の小肥りの男は、一月に必ず一度飲みに来て十五六時間飲み通すのがきまりであつたが、それは、まるで、親爺がまだ死なないことを確めに来るやうだつた。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日林町のモミヂといふ旅館で、呉清源八段をかこんで、文人碁客の座談会があつた。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "初段格はおうちになさるということを古い碁客から承りましたよ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "お相撲さんも碁客先生も、あのやうな仕事に一生をかけて熱心なのは、どういうわけか、感心なことのやうにも、不思議なことのやうにも、少し空恐ろしいくらゐのやうにも、私には想像されることがしばしばだが、そんな時には、自分のことをとんと失念してゐるのを忘れてゐるのが常である。",
              "citation": {
                "source": "棋家の文章など",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "机竜之助の刀を突きつけてジリジリと詰め寄るのは、非常に悠長なもので、名人の碁客が一石をおろすほどの静粛と、時間とを置いて、弁信法師に迫っては行くが、まだたしかに両者の距離は三間からあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、きみもぼくも、武器がなくなったのだから、ごかくの戦いができるというものだ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
