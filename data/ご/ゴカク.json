  {
    "uuid": "fc9ae867-7202-58fe-9ed9-2188f398025f",
    "entry": "碁客",
    "reading": {
      "primary": "ごかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
