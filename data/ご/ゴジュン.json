        "examples": {
          "standard": [
            {
              "text": "英語と日本語では、語順が大きく異なる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "正しい語順で話さないと、意味が通じないこともある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は外国語の語順に苦労していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "英語の語順では、Ｅのあとに決まってこれが来るというものがない。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬語系統の語づかひに馴れなかつた地方人は、標準語として這入つて来た敬語・丁寧語を、その地方言語順列の中にとり込んでも、やがて敬語・敬礼語らしい感じも失つて行くか――或は、さう言ふ敬語感をとり入れるだけの素地に乏しかつた。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
