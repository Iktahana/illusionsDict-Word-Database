[
  {
    "uuid": "a05c400a-e101-5e87-8278-5f98e0a798ff",
    "entry": "ごく普通",
    "reading": {
      "primary": "ごくふつう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
