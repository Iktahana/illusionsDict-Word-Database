        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "目に何か入ったのか、ゴロツク感じがしてとても不快だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コンタクトレンズが合わないと、一日中目がゴロツク。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "砂漠を歩いていると、常に目の中に砂がゴロツク感じがする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
