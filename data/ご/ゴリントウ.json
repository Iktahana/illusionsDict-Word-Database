[
  {
    "uuid": "78d00234-6a51-582e-b8c7-e43ce600993f",
    "entry": "五輪塔",
    "reading": {
      "primary": "ごりんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
