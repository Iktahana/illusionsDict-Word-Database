    "definitions": [
      {
        "index": 1,
        "gloss": "gobang (game played on go board involving lining up stones)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「五目並べならできます。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ハハヽヽヽヽ五目並べじゃしかたがない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の住職と五目並べをして暮す日もあつた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が小降りになるまでと、二階の方達と五目並べなぞしてゐると、丁度｜徒爾で困つてゐる三人連れの中年の御婦人があつたので、その三人の女の方を誘つて、岡田村まで大きな箱自動車で出掛けました。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ五目並べの事ですか」「五目並べなんていおうものなら、卓一君は眼に角を立てゝ怒りますよ。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五目並べなんていったのは昔の話で、今では高木名人考案の縦横十五線の新連珠盤が出来て、段位も段差のハンディキャップも確立するし、国技として外国に紹介するには最もいゝ競技で、国際親善の為に大いに発展させるべきものだといいましてね、その連盟とかに金を出せというんです。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従兄と兄はその前へ置いた碁盤で五目並べをして居る。",
              "citation": {
                "source": "住吉祭",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りきて、かくと云へば、男は独り棋盤に向ひて五目並べの稽古してありしと云ふ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして子供に調戯ったり、書生と五目並べをしたり、嫂と芝居の評をしたりして帰って来る。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、本式の碁はあなた方にむづかしいから、五目並べといふ別のゲームを教へようと答へ、二人で三十分ほど五目並べをやつた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はどうかすると、祖父の悪い方の碁盤を持って来て、五目並べや囲碁の真似などをして遊んだ。",
              "citation": {
                "source": "同胞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隆吉や時には女中をも交えて、トランプをしたり、五目並べをやった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日四方太、青々、余の三人が落合って居士もその中に加わって、四人で五目並べをしたことがあった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよさんは、伸子と下手な五目並べなどしながら、身の上の不安を訴えた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ五目並べでもやろうか」「やりたいけれど」と猿沢。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は末吉エンジナーと五目並べをしていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は末吉エンジと五目並べをしながら、相手の置く石の一つ一つが、みな三四、または四四になるような、極めてゆだんのならない気分を味わっていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
