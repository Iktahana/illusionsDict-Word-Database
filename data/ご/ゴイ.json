  {
    "uuid": "fd2e4d92-a334-5995-8a20-cdc0750e84cd",
    "entry": "五位",
    "reading": {
      "primary": "ごい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fifth court rank",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　三十計りの男と十五位な娘とが頻に焼ていたが、驚て戸外の方を向いた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位が鳴いて通った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、静かに寝られないでいると、空を五位が啼いて通った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄砲疵のございます猿だの、貴僧、足を折った五位鷺、種々なものが浴みに参りますからその足跡で崕の路が出来ますくらい、きっとそれが利いたのでございましょう。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位鷺　眼のふち清々しく、涼しき薫つよく薫ると心着く、身は柔かき蒲団の上に臥したり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位鷺がギャアと夕空を鳴いて過ぎた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の空から明け初めて、寝呆けたような鴉の声と五位鷺の声とが宮の森のあたりからかすかに聞えて来ましたが、静寂な天地はたちまちそれを吸い取って、まだ闇の気配の残る、燻しをかけた銀世界にはなおも霏々として雪は降り続くのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の大中年の頃の人）の正偏五位というのがありますから左に御紹介しましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正偏五位　正というのは平等方面のことであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五位鷺飛んで星移り、当時は何某の家の土蔵になったが、切っても払っても妄執は消失せず、金網戸からまざまざと青竹が見透かさるる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅黄の襟に頬白う、………また雨催の五位鷺が啼くのに、内へも入らず、お孝は彳む。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も其は、或機會に五位鷺が闇夜を叫ぶ、鴉が啼く、と同じ意味で、聞くものは、其處に自分一人でも、鳥は誰に向つて呼ぶのか分らない。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人通りのない、故道松並木の五位鷺は、人の居處から五｜本目の枝に留ります、道中定り。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くに犬｜吠え、近く五位鷺啼く。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊ばかりじゃあねえ、今に化け物が出るだろう」　蚊の声、虫の声、古寺の闇はいよいよ深くなって屋根の上を五位鷺が鳴いて通った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "百舌鳥の声、五位鷺の声、或る日は万歳万歳のさけびが聞える。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二十四、五位に見える色の白い品のいい婦人であった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟に脅かされた五位鷺だと牧瀬はいつた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "純友が賊衆追捕に従事して、そして盗魁となつたのも、盗賊になつた方が京官になるよりも、有理であり、真面目な生活であると思つたところより、乱暴をはじめて、後に従五位下を以て招安されたにもかゝはらず、猶ほ伊予、讃岐、周防、土佐、筑前と南海、山陽、西海を狂ひまはつたのかも知れない。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高見王の御子｜高望王が平の姓を賜はつたので、従五位下、常陸大掾、上総介等に任ぜられたと平氏系図に見えてゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高望王の御子が、国香、良兼、良将、良は上総介、従五位上とある。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから良広には官位が見えぬが、次に良文が従五位上で、村岡五郎と称した、此の良文の後に日本将軍と号した上総介忠常なども出たので、千葉だの、三浦だの、源平時代に光を放つた家※の祖である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に良持は下総介、従五位下、長田の祖である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "傭前介藤原｜子高を殺し播磨介島田｜惟幹を殺した後にさへ、純友は従五位を授けられんとしてゐる、其は天慶二年の事である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼盛は卅六歌仙の一人であり、是忠親王の曾孫であり、父の篤行から平姓を賜わり、和漢の才もあった人ではあるが、従五位上｜駿河守になっただけで終った余り世栄を享けなかった人であるから、年齢其他の関係から、女には疎まれたのかも知れない。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは少し言過ぎるかも知らぬが、定基の兄の為基、これは系図には、歌人とあり、文章博士、正五位下、摂津守とある。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し定基は何彼と尋ねると、いずれ五位六位ほどの妻であろうか、夫の長い病の末か、或は何様いうかの事情の果にいたく窮乏して、如何ともし難くなって、吾が随一の宝の鏡を犠牲にして売って急を凌ごうということらしい。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "従五位｜勲三等、前の軍医監、同姓｜英臣の長男、七人の同胞の中に英吉ばかりが男子で、姉が一人、妹が五人、その中縁附いたのが三人で。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは蓋し一門の大統領、従五位勲三等河野英臣の発議に因て、景色の見物をかねて、久能山の頂で日蝕の観測をしようとする催で。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風の吹く城の向うで化猫草の穗のゆらゆらとうごいてゐてなにものかかなしい追憶の敵が笑つてゐる。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
