    "definitions": [
      {
        "index": 1,
        "gloss": "ox-drawn coach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
