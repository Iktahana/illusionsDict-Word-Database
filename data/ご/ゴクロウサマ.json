    "definitions": [
      {
        "index": 1,
        "gloss": "thank you (for your hard work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
