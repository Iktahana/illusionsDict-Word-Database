    "definitions": [
      {
        "index": 1,
        "gloss": "god (esp. the Christian God)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
