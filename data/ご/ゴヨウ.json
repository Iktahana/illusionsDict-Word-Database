    "definitions": [
      {
        "index": 1,
        "gloss": "using together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「とこやですが、ごようはありませんか。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とこやですがごようはありませんか。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごようのないもな通しません、通しません。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "じんみんたちは往来にあつまって、れいの侍従長に、皇帝さまは、どんなごようだいでございますかと、たずねました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "老王さまは、すっかり、あたらしいお召ものに着かえて、金のかんむりもしゃくも、ぴかぴかみがき立てて、いかめしいごようすでした。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "基康　何かごようか。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぎ、もみ、つが、ひのきがや、いぬがや、あかまつ、くろまつ、やくたねごよう、こなら、かしは、かしはなら、くぬぎきり、つるまんりよう。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きしやのしよくどう村山籌子たまごよたまごようでたまご。",
              "citation": {
                "source": "きしやのしよくどう",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先奥様がお亡くなり遊ばした時、ばあやに負されて、母様母様ッてお泣き遊ばしたのは、昨日のようでございますがねエ」はらはらと落涙し「お輿入の時も、ばあやはねエあなた、あの立派なごようすを先奥様がごらん遊ばしたら、どんなにおうれしかったろうと思いましてねエ」と襦袢の袖引き出して目をぬぐう。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この　しゃしんやさんは　きかいを　さげて、ごようを　ききに　あるくのです。",
              "citation": {
                "source": "しゃしんやさん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よく、おまえはあちらにいって、人々のうわさや、また、どんなごようすの方だか見てきておくれ。",
              "citation": {
                "source": "赤い姫と黒い皇子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来徳大寺大納言様には、ご逼塞のごようすでございますなあ。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどうでしょうあなた様には妾が悪女ででもあるかのように、逢うまい逢うまい、話をしまいと、そういうごようすをお見せになられて、避けてばっかりおいでなされた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見受けしますればかん難辛苦を、数々お重ねなされましたごようす、私などおよびもつきませぬ。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいそう　びくついた　ごようすの　ダッチェス、　パイのなかを　かきまわすばかり。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が　あっても　起きない　ごようす　――　ベッドの上で　ロープが　ぺろんぺろん　しているのに。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の心霊のごようすは、いかがでした」「ありがとうございました。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "とこれも驚いた大作、かみにはおやすみではあろうが、ひとまずごようすをうかがって、もしお眼覚めならば御聴聞に達しようと、境の襖をそろそろと開けてみてそしてギョッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ながら殿様なんざア男でせえふるいつきてえぐらいいいごようすだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "与吉はわざと眼をしょぼしょぼさせて、「しかし、もとより御酔狂ではござんしょうが、このおん痛わしいごようす――」「与吉といったナ」　と、刻むような左膳の微笑。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、あのごようすは、ただごとじゃあねえ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "離家へあげると、お米は壁の紙張へ身をすりつけるようにしながら、あなたが死んだ姉をお愛しがられるごようすはあまり哀れでございます。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "金鳳釵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いるわよ、ねこちゃん、いることよ」「おくさまを、およめにほしいというかたが」「あらまあ、そうお、どんなごようす？",
              "citation": {
                "source": "おくさま狐の御婚礼",
                "author": "ヤーコップ、ウィルヘルム・グリム　Jacob u. Wilhelm Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあその次は」「ごようしゃを願います。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか　ごようでしょうか。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにをそんなに見るんだ」「この頃なんだか浮かないごようすですから」といしは云う、「いつものお癖がちっとも出ませんし、来てもすぐお帰りになりますわ」「いつもの癖ってなんだ」「こういうお顔をなさるわ」　いしは唇をむすんで上へ歪めてみせた。",
              "citation": {
                "source": "いしが奢る",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御母君のごようすはいかがかと、じつは拙者もないないお案じ申しあげとる。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんせ、この暑気ではな……ごようすはいかがでござるな？",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご隠居さまのこのごろのごようすが、なんとしてもわたくしの目には腑におちぬことだらけでございます。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
