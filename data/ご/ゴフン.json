[
  {
    "uuid": "2977795e-1fe6-5b89-bb27-2e928acb9718",
    "entry": "５分",
    "reading": {
      "primary": "ごふん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "five minutes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――「パリには種々の水源があるが、５分の４の水はカナル・ド・ルルク（Ourcq 川が起源）からであり、これはナポレオンの決定により船の運行も目的であった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお手紙を　よんだ　ダッチェスは　おへんじ　したためます　――「では　よろこんで　４時１５分に　うかがいます。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かっきり４時１５分、　たいそう　おしとやかに　とんとんと　たたかれる　ドアの音。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「たぶん　あと５分ってとこね。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから　５分も　すると　ふたりして　いきを　切らしながらも　おうし土手を　かけおりる　ウサギたち、　ふくろを　なかば　引きずるように　かかえていて　時には　草に　どしんどしんと　当たることも。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガスの放出を約５分のあいだ続ける。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "証人は「20大樽のモラセズを５分間にドアを占めるや否や処理した」と答えた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがミルクの暖かさのときに、ジンに注ぎ前と同じように５分ほど、ビールを透明にするときと同じようによく掻き混ぜる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べて５分ほどしてその男は異常にじっと見るようになり、目を閉じることが出来なくなった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出発を５分待ちましょう。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、あと５分俺を待ってくれたら、俺が時間に間に合い、５分遅れず予定通り出発したら、もし……。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "２つ目は君が実際に着くまで旅客機が待った場合、３つ目は実際に待っていた５分以内に君が着いて搭乗した場合だ。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか５分遅れで出社した日、親父が呼び入れて身体のことを聞いた。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ始まって５分、芝居は序盤も序盤なのだが…舞台上のその３人もいまや、１人も演技をしていない。",
              "citation": {
                "source": "グローバルタワーにて",
                "author": "福永信",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランチカウンターにおけるビズネスマンの５分間食事はビジネスタイムを節約する代わりにしばしば自分の健康を損なう。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "19世紀の40年代のアイルランドにおける厳しい流行ではアイルランドの全医師の５分の１が発疹チフスで死亡した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな男でも声が聞こえる範囲なら、５分以内にぞくぞくっとさせることができる。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この昆虫は魅力が無いわけではなく人類の歴史に大きな影響を持っているにもかかわらずエンサイクロペディア・ブリタニカでは１つの欄の３分の２だけであって「ラウス（アイルランドのレンスター地方の一部）」の半分、ケンタッキーのルーイヴィルの５分の１を占めるに過ぎない。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "７１５はすなわち朝の７時１５分、彼女の枕もとで目覚まし時計の鳴る時刻だ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このどちらかと言うと面倒な方法はアンモニアの存在のもとで硝酸銀の10分の１規定溶液の還元に基づくものであったが、決定された５分間（28）に完全な還元を起こさせるには Baumann 原法の３パーセントより濃度が高い８パーセントのアンモニアを使う必要があった。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「絵の場合でいえば、見事な絵がかけて、その最後の仕上げにごふんをかけるというようなことだろうね。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "土の上にごふんをぬって、みがきをかけたお人形のはだと、そっくりではありませんか。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
