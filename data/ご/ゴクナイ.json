[
  {
    "uuid": "d5e4a22e-d0b3-5ad7-9d87-498fb8b19b91",
    "entry": "極内",
    "reading": {
      "primary": "ごくない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "highly confidential, top secret",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大連が一台ずつ、黒塗り真円な大円卓を、ぐるりと輪形に陣取って、清正公には極内だけれども、これを蛇の目の陣と称え、すきを取って平らげること、焼山越の蠎蛇の比にあらず、朝鮮｜蔚山の敵軍へ、大砲を打込むばかり、油の黒煙を立てる裡で、お誓を呼立つること、矢叫びに相斉しい。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでおしまいかと思うと、まだ、上陸するとからここのキト旅館で、あの無数の意地悪鴉を恐れ恐れ、それこそ極内密でまた、こつこつ、ほのぼのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、滅相、途轍もねえ、嬢的にそんなこといわれて堪るもんか、ヘッ、」　と頸を窘めたが、「内証だ、嬢的にゃ極内だがね。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはお前さんだけに極内でお話し申すが、実は八幡様から盗み出して来たのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦山権現の戯曲に京極内匠が吉岡の第二女に「長刀疵が所望じゃわい」。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "大理石色の薔薇の花、紅く、また淡紅に熟して今にも溶けさうな大理石色の薔薇の花、おまへは極内證で花瓣の裏をみせてくれる、僞善の花よ、無言の花よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれは極内密にしてほしいというのであった。",
              "citation": {
                "source": "外務大臣の死",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上｜狐狸退治の秘伝、親類縁者たりとも極内々の事内々の事。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、これは極内々の話だが、汽車には寝台車といふものがあつて、相当の料金さへ出せば、誰にも顔を見られず、一人で帷のなかで思ひ出し笑ひが出来る仕掛になつてゐるさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランシング氏に聴かれて、また長つたらしい演説でもされては困るから、極内々で耳打をするが、実はその聖書は、氏の夫人が結婚の当時、贈り物にしたものである。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそこへ善導さるべきであったその善思想という積極内容は、一体何であったか。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に、この位い具体的な積極内容は、これまでの思想統制内容にはなかったわけだ。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "を送りけるが、是ハ極内※を以て御｜覧被成候得バ、極テたしかなるたよりにて山口に迄御送被成度。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年七月二十八日　三吉慎蔵あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "源右衞門さんにはお内儀があつて、子を産んだからお芽出たうと人が祝ふけれど、光明寺の和尚さんが、女子を引つ張り込むのは極内ぢや。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレはその時塾に居た小野友次郎が警視庁に懇意の人があって、極内々その事を聞出して、私と同時に後藤象次郎も共に放逐と確に云うから、「ナニ殺されるではなし、イザと云えば川崎辺まで出て行けば宜いと申して居る中、その翌日か翌々日か小野が又来て、前の事は取消しになったと云うので事は済みました。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くなる上は、女子が父母に婚姻を勧めらるゝとき、自分の見聞広ければ配偶の可否を答うるも易く、又或は其身躬から意に適したる者を認め得たるときも、極内々に父母に語るか、又は窃に人を以て言わしむるかして、親子共に非常の便利ある可し。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑も子宮の字は洋語の Uterus（ユーテルス）に当り、相互直訳の文字にして、西洋諸国に於ては医師社会に限りて之を用い、診察治療の必要に迫れば極内々に患者又は其家人に之を告ぐるのみ。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つの心配は己が預かりの帳面に筆の働きをもって極内の仕事を行なわんとするの一事のみ。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、同じ敵討物でも、京極内匠など、彼に見たくもなし、六助は、お園ほどに成功するか、疑はれぬでもない。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊には年末の事でございますから、これから頭の宅へ内々参ってだん／″＼歎願をいたしまして、極内分の沙汰にして病死のつもりにいたしました。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らば、過日一寸奉申上置候御膳酒味として、極内々にて申し候に付恐れ乍ら持たせ奉指上候。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」「叱ッ、極内だ」「だってそんな糠袋。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さあさあ、もう、そのくらいにしておいてください」「……よしよし、では入ってやるが、だが、ひょろ松、くどいようだが、叔父の禿げあたまには極内だぞ」「それは、嚥みこんでいますが、どうして、そうまで金助町に内証にしたがるんです。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕も不思議の極内心少々｜怖くなったから、なお余所ながら容子を窺っていると、薬缶はようやく顔を洗い了って、傍えの石の上に置いてあった高島田の鬘を無雑作に被って、すましてうちへ這入ったんでなるほどと思った。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "極内でわしに聞かしとくれ。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "話はあとでするが、まず、先にこれを読んでくれい」　そういうと、地袋の手箱から「極内不可認」という朱判の据わった、官庫の秘冊をとりだして二人の前に置いた。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "古の恐怖が現在まで残存していることを示す平易な徴を私が開示してもなお他の人々が南極内部への干渉を止めないならば――少なくとも禁断の謎を秘め悠久に呪われた冷酷な究極の荒野を余りに深くほじくり返すことを止めないならば――名状し難く恐らくは計り知れない災厄についての責任は私にはないのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こう地の土手下の茶屋で、極内でドブロクを飲ませてくれる家がある。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然｜極内で高級の方へも足を踏み込む」「矢っ張り監視を受ける丈けのことはしているんだね。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしも梅花堂流の易者だよ、それくらいなことは、とうに心のうちで卦を立てて観抜いている」「じゃあ先生にだけ話しますけれど、極内にしていておくんなさいね」「誰がそんな事をツベコベと喋舌るものか。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
