        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その子は、目をつむりながら、ごくっとのんだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「莫大な金貨※」理学士はごくっと唾をのんだ。",
              "citation": {
                "source": "幽霊屋敷の殺人",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たっぷり水を入れると、ハウスマンはごくごくっと飲んだ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "音とはいえないかもしれない、水を飲むときに喉がごくっという、音とも波動ともわかちがたい音、抱き緊めているおれの手に、それがはっきり感じられたのだ。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなごくっと喉を鳴らし、暫くは真偽のほどを計り兼ねて沈黙した、……やがて勘一郎がぐっと向直って、詰問するように云った。",
              "citation": {
                "source": "城中の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒笑はごくっと唾をのみ、ひきずられるように膝を進めた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むしむしして頭が痛いから、ちょっと川風に当りに来たんじゃないの」「――お孝……」　時三は大きく喘ぎながら、ごくっと唾をのみ、片手を妙なぐあいに振って、それからしゃがれたような声で云った。",
              "citation": {
                "source": "寒橋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠二郎はごくっと喉が鳴り、口の中へなまつばが出て来た。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "側にいる三左衛門がじりじりしてきて、「これ三之丞、滝川氏の申されること道理とは思わぬか、返辞をせい、返辞を」「はっ、……ただ今」ごくっと音をさせて、鉢盛りの芋をきれいに食べおわった三之丞はじめて幸之進の顔を見て、「伯父上のお言葉ゆえ、くどうはござるがもういちどお返辞を仕る。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれはおれの兄だが、いちどこうと思ったら雷が落ちてもあとへは退かない性分だ、ましてこんどの調べは天下の大変にも関することで、みんなそれぞれが命がけなんだ、実際のところ二人や三人の生死にかまってはいられないんだが、しかし、おれにはおれで思案がある」　若者はごくっと唾をのんだ。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからごくっと唾をのみ、喉になにか詰ったような声で云った。",
              "citation": {
                "source": "百足ちがい",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新八はごくっと唾をのみ、頷きながら「石川さんです」とかすれた声で云った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはひと滴の酒しか入っていなかったが、彼はそれを、たっぷり入っているかのように呷り、喉でごくっと音をさせた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ごくっと唾をのみながら俯向いた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、膝の上で両手の指を動かしながら、ごくっと頷いた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水を注ぎました」「…………」　黙って、ごくっ、ごくっ、と飲みほしている。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……悪かった」　楊雄は、ごくっと、乾いた口に、息を呑んだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
