    "definitions": [
      {
        "index": 1,
        "gloss": "escort (e.g. under guard)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あいつ等は一体、護送されているのなら、捕縄をかけられていなけりゃならないんだのに。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」護送に行く看護長が廊下から叫ぶと、防寒服で丸くなった傷病者がごろ／＼靴を引きずって出てきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室の入り口では護送に行く筈だった看護卒が防寒服をぬぎ、帯剣をはずして、二三人で、何かひそ／＼話し合っていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シロオテは、長崎へ護送された。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが為に、護送の警官の足が留って、お孝は旅僧と二人、可懐しそうに、葉が差覗く柳の下の我家に帰る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の護送官に前後を擁せられ、彼は腰縄をさへうたれてとぼ／＼と歩いて来た。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が東京へ護送せらるゝ為梅田の停車場から汽車にのつたのは、それから二日後の事であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　護送されたる一列の貧民は、果報｜拙くして御扶持を頂くことを得ざりき。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は市へ護送せられて予審に掛かった。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）時十六分同地發輕便鐵道により東京に護送せられたるものなり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年六月八日東京朝日新聞は、去る三日和歌山縣東牟婁郡新宮町にて、祿亭事ドクトル大石誠之助を初め同人甥西村伊作、牧師沖野岩三郎外五名家宅搜索を受け、五日大石は令状を執行され、六日警官三名の護衞の下に東京に護送せられたる旨を報ぜり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "護送の途中、汽車で大阪駅を通った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "護送の巡査が駅で餡パンを買ってくれた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日になると許宣は二人の護送人に伴れられて牢屋を出た。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "許宣は護送人といっしょに鎮江へ往って、李克用の家へ寄った。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "李克用は親類の手簡を見て護送人に飯を喫わし、それからいっしょに府庁へ往って、それぞれ金を使って手続をすまし、許宣を家へ伴れて来た。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るところ松向寺殿｜御遺骸は八代なる泰勝院にて荼※せられしに、御遺言により、去年正月十一日泰勝院専誉｜御遺骨を京都へ護送いたし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを護送するのは、京都｜町奉行の配下にいる同心で、この同心は罪人の親類の中で、おも立った一｜人を大阪まで同船させることを許す慣例であった。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "護送の役をする同心は、そばでそれを聞いて、罪人を出した親戚眷族の悲惨な境遇を細かに知ることができた。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで高瀬舟の護送は、町奉行所の同心仲間で不快な職務としてきらわれていた。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "護送を命ぜられて、いっしょに舟に乗り込んだ同心｜羽田庄兵衛は、ただ喜助が弟殺しの罪人だということだけを聞いていた。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを護送してゆく京都｜町奉行付の同心が悲しい話ばかり聞かせられる。",
              "citation": {
                "source": "高瀬舟縁起",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "サモアから濠洲へ、濠洲から独領西南アフリカヘ、アフリカから独逸本国へ、独逸から又ミクロネシアヘと、盥廻しに監禁護送されて来たのである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の噂では、私が近い中に逮捕護送されることになっているらしい。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は健児社の健児一同、当然斬られるものと覚悟したらしく、互いに顔を見合わせてニッコリ笑ったという事であるが、同じ時に奈良原少年と同じ鎖に繋がれる仲よしの松浦愚少年が、護送の途中でこんな事を云い出した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、それをさきへやり過ごそうとした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ彼は第一学期の試験が来るまで、じっと自分の家にいて養生をしながら過ごそうと思いついたのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ひと晩を、ゆかいにすごそうじゃありませんか？",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆかいに、うんと楽しくすごそうよ。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "木之助は道のはたへ寄って馬車をやりすごそうと思った。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
