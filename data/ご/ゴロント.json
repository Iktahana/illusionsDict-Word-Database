    "definitions": [
      {
        "index": 1,
        "gloss": "(land) with a thump",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あああ」馬場は溜息ついて縁台にごろんと寝ころがった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、金屏風の背後から謹んで座敷へ帰ったが、上段の室の客にはちと不釣合な形に、脇息を横倒しに枕して、ごろんとながくなると、瓶掛の火が、もみじを焚いたように赫と赤く、銀瓶の湯気が、すらすらと楊貴妃を霞ませる。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "武助さんは黙つて上にあがると、大黒柱の方に頭をむけて、ごろんと寝ころんだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」馬場は溜息ついて縁臺にごろんと寢ころがつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」徹宵、議論の揚句の果は、ごろんと寝ころがって、そう言って二人うそぶく。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷居際へ、――炉端のようなおなじ恰好に、ごろんと順に寝かして、三度ばかり、上から掌で俯向けに撫でたと思うと、もう楽なもの。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　うむと唸って、徳利を枕にごろんとなると、辷った徳利が勃然と起き、弦光の頸窪はころんと辷って、畳の縁で頭を抱える。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は獺のやうに、ごろんと寢た。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらにごろんと横におなりになつて、そこらの書物を見てゐられたお客さまは、おくみが次の間に坐つてお辞儀をするのを見て坐り直された。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが博物館は休みだつたので、広小路の方へぶらぶら歩いて行くと、石段のところに、赤ん坊を抱へた女がごろんと横臥してゐるのだつた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の部屋に戻ると、暫くごろんと寝転んでゐたが、何かに急きたてられ、さうだ、かうしてはゐられない、と立上つた。",
              "citation": {
                "source": "飢ゑ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "（俺も機関手なんて罷めようか――）　詰所を出ると、前の草原に、ごろんと寝た儘、喘ぐように、考え続けた。",
              "citation": {
                "source": "鉄路",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要吉は、夢の中で、そういいながら、ごろんとひとつ寝がえりをうつと、昼間のつかれで、今度は夢もなんにも見ない、深い眠りにおちていきました。",
              "citation": {
                "source": "水菓子屋の要吉",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めの程は、嘉吉も笑つてゐたが、二年になつても三年になつても家の商売に馴れやうとはせずに、何時も家ぢゆうの陽のあたる処を見つけては、その陽溜りへ講談本なぞを展げてゐたり、夏になると、ひといちばい暑つがりやで、台所の板の間へ茣蓙を敷いて、まるで生魚のやうにごろんごろんとしてゐるのであつた。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こんなトリックを思いついたばかりに、却って身を滅ぼすところだった――）　秀三郎は、又ごろんと寝椅子にころがると、チェリーの缶に手を差しのべたのでした。",
              "citation": {
                "source": "足の裏",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず伸上って見ると二三間先の線路のわきに黒っぽい着物を着た男が、ごろんと転がっていました。",
              "citation": {
                "source": "穴",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごろんごろんと転げるように動いていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "動かすと、そのものの身体は丸太のようにごろんところげた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は怒ってごろんごろんと体当りを喰わした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷と雪の塊りをのみこんで、何か堅げな、ごろんごろんとした液体となって流れた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははあ、あれだな」　と、中尉が、その方に向って、また匐い出そうとしたとき、そのロケット爆弾が、ほんのすこしであったが、ごろんと動いたようであった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ごろんと、うしろにたおれて、ぼんやり考えこんでいたが、そのうち、ふと、誰かのいったことばを思い出した。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "足をとられてごろんごろんと転がること数十回、数百回。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい毛布春の野原はいい毛布草はやさしくやはらかいごろんと横にころがれば、ほかほかぬくい日が照つてどうやらすこしねむくなる。",
              "citation": {
                "source": "歌時計",
                "author": "童謠集",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、むしろの上にごろんと寝ると、隅っこのところへ手をのばして、ごそごそやっていたが、やがてその手が、船で使う角灯をつかんできた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてごろんと横になった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のしっかり閉じられた瞼の下に大きな眼玉がごろんと動くのが見えた。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前、起してくれ」「はい、起します」　中尉はそこにごろんと横に寝た。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の火星人は、先生と丸木とをとおまきにして、つっ立っている奴もあれば、無作法にもごろんと地面に寝そべっている者もあった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして急に弱くなって、ごろんとその場に倒れた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
