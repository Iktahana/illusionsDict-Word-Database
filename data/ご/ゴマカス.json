[
  {
    "uuid": "0a02c3f0-52b3-516e-8510-fff5e6a2d0ed",
    "entry": "誤魔化す",
    "reading": {
      "primary": "ごまかす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
