      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to deceive",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんなわけで我々の口にする美しいみたいな話は、みんなただ自他の目を誤魔化すために過ぎないのです。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この信者のなかで工面のよさそうな奴を奥座敷へ引き摺り込んで、どう誤魔化すのか知らねえが、多分の金を寄進させるという噂だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼しかし鼻の表現だけは偽る事も誤魔化す事も出来ない。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん俺は変な顔をしているだろうと、豹一はそれを誤魔化すように、「喧しい奴らだ」　と言いながら、手を伸ばして赤井の煙草を一本抜きとり、吸ったが、それで一層胸が悪くなった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安な気持を誤魔化すためにこんなに喋っているのだなとふと思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を青二才とあなどって、いい加減に誤魔化すのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋作はそれを妬んで、夜なかにそっと自分の人形を傷つけて、それを誤魔化すために途方もない怪談を作り出したに相違ないと認めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも初めからさすがに亭主を殺す料簡はなく、亭主の寝息をうかがってそっと盗み出して、台所の床下へかくして置いて、よそから泥坊がはいったように誤魔化すつもりだったのを、徳蔵に見つけられてしまったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん太鼓持の姿で入り込んでは、すぐに正体があらわれますから、田舎者に化けてお城へ乗り込み、いざというときには偽気違いで誤魔化す計略。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "科人が人違いと誤魔化すのは珍らしくないので、いかに半七が人違いと呶鳴っても、彼等は耳にもかけずに押さえ付けたのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "物価の高いことと、勘定を誤魔化すことを考えるのが巧いことは、またこれも想像以上だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは理智的で、惨忍性をもっていて、いつでも私の傍から離れたがろうとばかり考えていらしって」「それは、檻の中の理論である」　彼は彼の額に煙り出す片影のような皺さえも、敏感に見逃さない妻の感覚を誤魔化すために、この頃いつもこの結論を用意していなければならなかった。",
              "citation": {
                "source": "春は馬車に乗って",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼はふたたび筆を取れぬといふおのれの感情をいつはり誤魔化すことはできなかつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "西村電機商会は近ごろの不景気のために大穴をあけ、世間の手前および取引先を誤魔化すために先日、社長が五万円の贋造紙幣を買い込んだのです。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、誤魔化すように眼ばたきをして、『いつ？",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手で誤魔化すこたあ出来んぞ。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは、ただ人眼を誤魔化すために思いついただけのことで、ほんとうは、知事のお嬢さんをかどわかそうってのが、あの人の魂胆なんですわ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてどうして、畜生め、女の声を出しをらうと悪魔の作り声をほざかうと、おれを誤魔化すこたあ出来ねえぞ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り損卦の相談には忽ち聾になって、トンチンカンの挨拶で誤魔化すという。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "不躾な祖父の追窮にも、父は誤魔化す様に笑うのみではっきり言おうとはしなかった。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりそこ、ここの火薬庫の主任が、一生一代の大きなサバを読んで渡すことがあるそうで、古い話ですが大阪や、目黒の火薬庫の爆発はその帳尻を誤魔化すために遣ったものだとも云います。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もその又雌の河童はこの国第一の美人だつた上、夫の道路工夫を誤魔化すのにも妙を極めてゐたと云ふことです。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはおれを気持よく誤魔化すやつに感謝する。",
              "citation": {
                "source": "素面の管",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しその多くの人が途中で誤魔化す、極めて安易な習慣的な考察法へその人生観の方向を逃がして了ふ、又ある人はその極点へ押しつめぬうちに極めてこれも習慣的な自殺を企ててしまつたりする。",
              "citation": {
                "source": "悲願に就て",
                "author": "――「文芸」の作品批評に関聯して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は顔の表情を誤魔化すことはできるにしても、足の表情を誤魔化すことは不可能だ。",
              "citation": {
                "source": "風人録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "航路が複雑だったのは、米国の西部海岸に備えつけられた水中聴音機や其の辺を游戈している監視船、さては太平洋航路を何喰わぬ顔で通っている堂々たる間諜船舶の眼と耳とを誤魔化すためだったのだ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳二　　（誤魔化すつもりもなく）ああ、行つたよ。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "此奴は世界一正直で、人がいくらおだてゝくれても自らを誤魔化すことがない。",
              "citation": {
                "source": "いづこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵勢が勢ひに乗るときは下手から誤魔化すに限る、といふ大司馬石星の意見で、沈惟敬といふ誤魔クラガシの天才を選びだし、口先一つで日本軍をだまして返せ、彼を和議使節として特派した。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その人は、あわてたのをごまかすように、わざとゆっくり、川をわたって、それから、アルプスの探険みたいな姿勢をとりながら、青い粘土と赤砂利の崖をななめにのぼって、せなかにしょった長いものをぴかぴかさせながら、上の豆畠へはいってしまった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
