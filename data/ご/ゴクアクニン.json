    "definitions": [
      {
        "index": 1,
        "gloss": "utter villain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまらんものを書いて、佳作だの何だのと、軽薄におだてられたいばかりに、身内の者の寿命をちぢめるとは、憎みても余りある極悪人ではないか。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな極悪人でも、自分がこれから残虐の犯罪を行はうといふその直前に於いて、山水の美にうつとり見とれるほどの余裕なんて無いやうに思はれるが、しかし、この十六歳の美しい処女は、眼を細めて島の夕景を観賞してゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一線、やぶれて、決河の勢、私は、生れ落ちるとからの極悪人よ、と指摘された。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "素より不信の極悪人、此儘に打ち捨て置き、風来犬にな食す可きなれど、今日は異例の情をもて、聖まりやに祈りを上げ蘇生らして呉れむずらむ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし右大将家としたなれば、己は主君に二｜刀まで傷を負わしたから、不忠不義の極悪人となって死なねばならぬ、それも己一人死ぬるなら好いが、父をはじめ一家一門にもその咎めがかかって、人に羨まれる畠山の家門を恥かしめることになる。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に人の性を失つた極悪人のした事としても受け取れない。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "死の佇んでいる玉座をそこは人知れぬひそやかな都市霞なる西方の深い窪地にあり善人悪人聖人極悪人みな永遠の眠りについている。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人を戦慄させたような極悪人の場合は別として、世人は、被告が寛大の刑に処せられることに対して、大した抗議を懐くものではありません。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は極悪人の決心をして唇を噛んだりした。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄で、ひどい目に逢うのじゃ」と申して居りましたが、母の考えなどとは丸切り違って、坂下鶴吉は（典獄や弁護士などはこう呼んで居る以上、どんな極悪人でも改心した以上罪人扱いには出来ないかも知れません）この世で捕まった代りに、先きの世では天国へ行ったことになって居ます。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた様方もご承知の通り村井勘作という極悪人がお処刑になった事がございます。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い森の樹々が、さながら生けるものの如く、黒い鬚を垂れ、長い枝を伸ばして彼を絞め殺さうとし、星は彼の先きに立つて走りながら、万人にこの極悪人を指し示すかとも思はれ、路そのものまでが、彼の跡を追つて来るやうに思はれた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "つひぞこれまで、これほどの極悪人が世に現はれた例しはないのぢや！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「立ち去れ、呪はれたる極悪人！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "……極悪人と名探偵とを兼ねている……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は一つには支倉が極悪人であると云う心証を与える為でもあり、一つには警察署の方で不問に附しても、検事局或いは予審廷で犯罪事実が現われては何にもならぬのみならず、反って警察側の失策になる事を恐れたのであろうが、いずれにしても警察当局者が功名に逸ったと云う非難は或程度まで受けねばなるまい。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼は勢いに駆られて彼支倉を極悪人として告発した。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際署長の眼には、彼支倉は極悪人として映じたであろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、この極悪人の死を知るのみであって、左枝が、彼女の胸を離れ去っていたことは知らなかったのである。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが彼を極悪人のように見せた。",
              "citation": {
                "source": "上海された男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "直助権兵衛の様な重要な役だつて、大凡、極悪人の生活の切れ端だけを見せるに止る様な形をとつて来たのが、大体、普通の四谷怪談の演出であつた。",
              "citation": {
                "source": "お岩と与茂七",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「途中において松浦氏を――拙者を親の敵と狙う、松浦氏を見かけましたのでな、生かしておいては何かと邪魔、いっそ返り討ちにかけてやろうと……」「極悪人め！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫のいい極悪人のずるい心がつくり出したような安心ですからね。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が再び正気に返った時には、かの極悪人は気を落着けていて、※杖を腕の下にし、帽子をかぶっていた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもそうらしいようなことを言ったのは、彼の一家の特質を享けついでいる彼として、犯罪とか極悪人とかへのやけつくような憧憬から生れ出た妄想を、其の儘、事実らしく物語ったものであろう。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さん方はなんといふ呑んだくれの極悪人の気狂ひどもだらう！",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛典に馴れて甘やかされた考えからではなく、妻と娘に殺された、父にして夫なる当の中納言藤原泰文は、かねて放埒無残な行いが多く、極悪人といわざるも、不信心と不徳によって知られた定評のある人物で、名を聞くだけでも眉を顰めるものが少くなかった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "極悪人だの」「しかしご前と比べましては！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」利鎌と笄「聞けば聞くほど極悪人！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一闡提（極悪人）も成仏し得る。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
