    "definitions": [
      {
        "index": 1,
        "gloss": "rebirth in paradise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうなれば、不幸極まる、あわれな、情ない老人が、かえって百万人の中に一人も得られない幸福なものとなって、明かに端麗な天人を見ることを得て、極楽往生を遂げるんです、――夫人。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏は知見を以って何事も、広く知食すことなれば、そなたの念仏代りの言葉をも、とくと事情をお汲み取りなされ、念仏に通用さして下さるはもとより、只今｜正定聚の数に入り、極楽往生疑いなし。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また昼夜に六回の仏前のお勤めをいたしますのにも自分の極楽往生はさしおいて私はただこの子によい配偶者を与えたまえと祈っております。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が抜苦与楽の説法を疑ふ事なく一図に有がたがツて盲信すれば此世からの極楽往生決して難きにあらず。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「身延詣でのかわいい女子に酌をして貰うなぞとは、極楽往生も遂げられると申すものじゃ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……その代り、あみだ様のお側にお出になったとき、始めて極楽往生を遂げることが出来る。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人はあまりにも悲惨な世の中の有様を見、またかくも多くの人々が日々に死して行くのを嘆き悲しむのあまり、何とかして死した人々に仏縁を結ばせてやりたいものだと発願したので、毎日毎日街を歩き廻って屍を発見する度に、その額に阿の字を書いて極楽往生を念じたのであった。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏が来れば郭公がしきりとあの哀切な声でなき、昔の人の言った様に、死出の旅路の道案内をすると云われているこの鳥の鳴き声は何だか自分が死んだ時には必ず道案内をして極楽往生をさせてやると約束している様に聞かれて真にうれしく感ずるのである。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "年老の人達は大抵は蚊帳の中へ入つて二三十分宛も念仏交りに極楽往生の有難味を説いて聞かせた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死際に苦しんだり、骨が都合よくあがらなかつたりする者は、本人に何か罪があつて、極楽往生が出来ぬのか、家人に悪いことがあつて死後までも迷惑を残すのか何れかだといふ迷信があるのである。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、今夜は極楽往生としとくかね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山内が「さ、引導、渡してくれる――南無阿弥陀仏、御大師様の廟で殺されるからは、極楽往生疑いなし、南無阿弥陀仏、南無阿弥陀仏。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「極楽往生はしておられる」　義観は、朗かに、自信ありそうに云った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤鬼青鬼が引導を渡して、貴人がこれから極楽往生を遂げるというところ。",
              "citation": {
                "source": "鬼仏洞事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて世は藤原氏全盛時代となり、恵心僧都の浄土教となり、極楽往生の欣求が世に満ち、宗教はこの世を一つの大きな夢に化した。",
              "citation": {
                "source": "本邦肖像彫刻技法の推移",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘糟が国に残して置いた妻室が夢に忠綱が極楽往生をとげたという告げを聞いて驚いて国から飛脚をたてたが、京都からの使者と途中で行き会うて忠綱が戦場最期の有様を物語ったということである。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紙幣を握って死ぬなんて、極楽往生じゃねえか、なア」と村人はこの老爺の死をうらやんだ。",
              "citation": {
                "source": "一老人",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし彼らはもと屠殺を業とし、皮革を扱い、肉食に慣れていたがために、穢れたるものとして、仏者から嫌われ、ことに仏臭を帯びた神道者流から甚だしく忌まれた結果、自然と仏縁にも遠かったのを、幸いに真宗の布教によって救われて、始めて極楽往生の有難いことを覚ったのであった。",
              "citation": {
                "source": "特殊部落と寺院",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は盛んに念仏宗を下層民の間に宣伝して、口に念仏を唱えしめて、彼らに極楽往生の安心を与えたのであった。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "極楽往生の安心を得たならば、自然に歓喜踊躍の情が湧き出づる訳ではあるが、つまりは普通に落伍者の流れて行く道の一つなる遊芸の徒と、念仏の行者とが合致したものと解する。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "善人ならばわざわざ弥陀のお世話にならずとも、自力で極楽往生の道があろうが、他によるべのない悪人は、弥陀の他力本願に依頼してのみ往生が出来る。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "極楽往生の為には神を祭る事もいらぬ。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その唱うる念仏は報恩謝徳の念仏であって、極楽往生を願う為の念仏ではない。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお宗旨では穢れを言わず、いかなる罪人でも、一向専修の念仏の功徳によって、極楽往生疑いなしと教えたものです。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死ねば深切な人ができると緑雨は言った、死なぬ中に深切な人をたくさん持った馬楽はホンマに幸福な男だ、極楽往生だと言える」　たったこれだけなのであるが、いかに生前、馬楽の礼讃者の多かったかがわかるではないか。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "一念弥陀仏、即滅無量罪、願わくは、逆縁を以て順縁となし、最後の念仏により、極楽往生の遂げられんことを、お願い申します」　高らかに念仏を称えて、首をさし伸べた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに至って私の思いますには、なまじ高位高官に列せられ、世の浮沈をなめるよりは名誉を捨て、官を退き、この世の栄誉を捨てて、来世の極楽往生を願った方がどんなに良いかとも思うのですが、凡夫の悲しさ、中々実行できません。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日の日中を満願とし、大念仏を行ない、重盛自らもその列に加わって、極楽往生を願うのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄土門では極楽往生を説くが、本分にその極楽が在るのであって、何も特別な個所を指して、しか呼ぶのではない。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
