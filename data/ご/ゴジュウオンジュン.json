        "examples": {
          "standard": [
            {
              "text": "この辞書は、すべての単語が五十音順に並べられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "名簿を五十音順に整理するのは、図書館の基本的な作業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "五十音順に並べ替える機能は、検索の効率を上げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "上の句の頭字を五十音順に列べた其｜配列法が、最初少からず富江の怨嗟を買つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の句の頭字を五十音順に列べた其配列法が、最初少からず富江の怨みを買つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり今で云へば五十音順のカードによつて整理するといふやり方である。",
              "citation": {
                "source": "支那目録學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔原本はいろは順の旧仮名遣いで配列されているが、五十音順に直した。",
              "citation": {
                "source": "妖怪学講義",
                "author": "緒言",
                "note": "青空文庫"
              }
            }
          ]
