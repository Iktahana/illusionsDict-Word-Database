        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それ位で知人もない神戸へ行くのは危険だ、それは止したがいいと、私はしきりに手を振ったが、七面鳥さんなかなか強情っ張りで、容易に私の戒告を聴こうとはしなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「強情っ張りよ」　妹が老婆を見て云った。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このおじさんは強情っ張りがいちばんきらいだからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はこの上なく自尊心の強い強情っ張りなんです。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、二人とも、親譲りの、強情っ張りだからの」「頼まあ、俺、じゃあ、行くから」　南玉は、頷いて、元の座へ戻りかけた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "このむすめは、わんぱくにそだって、おまけにごうじょうっぱりでしたから、なんでもしたいとおもうことをしなければ、気がすみませんでした。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
