        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一｜銭もつかわんで、ごっそりためておいて、大きな倉でもたてるつもりかや。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君の小さな口の中に、すずしい秋の朝が、ごっそりひとつはいりこんだみたいだ。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがオレの机の引き出しには、名刺がごっそりつっこんである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軒は、夜盗がはいって、奥さんの衣類をごっそり持ってゆかれました。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一つ、あの人形には電波を受けて、靴の下に仕掛けてある浚渫機みたいな、何でもごっそりさらい込む装置――あの装置を動かせるようになっているんだと思う。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ｍの袷のための反物屋が来てごっそりと 12.70 もって行ってしまったので大打撃なり。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "好餌を発見すると、得たりとばかりごっそり移動し、食欲を満足させる。",
              "citation": {
                "source": "鰻の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの上、あなたがたがここに居坐っていたら、それこそ何もかも、ごっそり行かれてしまうことでしょうねえ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちには　ドクムギを　ごっそり　ほりかえした　あと。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは、まあそのくらいのつもりだったらしいが、だんだん面白くなったらしく、仕舞には、ブルージンをはいて、トンカチをもって出かけて行き、ごっそり石ころを持って帰るようになった。",
              "citation": {
                "source": "娘の結婚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで何にも知らずにいて、これだけのものをごっそり手に入れる娘さんは、いくらもともと母から譲られた自分のものとはいえ、たしかに日本一の果報者に相違ねえと、あっしは申すので」　なるほど、それに相違ないのだった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといっても一枚買いの客が圧倒的で、二枚とか三枚とか買いに来る客もあるが、なかには五〇枚ほどごっそり買って行く客もあるとのことである。",
              "citation": {
                "source": "宝くじ・その後",
                "author": "始めてから十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことにチャールズ・ウォードが蓄えている精神的な表象の主要な部分、主に現代と彼自身の生活史に関わる部分がごっそり抜け落ちてしまっていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "この件は大いなる種族の間で完全な禁忌事項となっており、恐るべき過日の抗争や、鋭敏な精神たちをごっそり未来に向かって投影することを強いるかの来るべき災厄と結びついているらしかった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつめでは、セリフがキリスト教的禁忌に及んだ場面になると、英語版ではごっそりなくなっている。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ大変面白く、歴史の現実の豊富を、ごっそりとすくい上げて見られるうれしさを感じます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "うどんが運ばれると、細ネギをごっそりかけ、一息につるつるとすすり、汁まで余さず飲んでしまう。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはすでに独立歩兵第十二聯隊付衛生下士官の矢木城介軍曹らも、ごっそり転属を命じられて集結していた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帰還の準備中に、パビナールがごっそり抜き取られたのである。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり第三者のものをごっそり奪い、首を切るけど、キミの喉は切らせないという同盟だな」　デンやハウスマンが連中を警戒させているわけじゃない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "むき出しの丘斜面は、開花した花々が、霜のため大鎌でごっそり切られたかのようだとか。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風呂敷にごっそり包んで、背中へ載せた古本屋を、私は、はだしで追いかけて、北上川の渡船場で、地団太踏んで泣きわめいた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめて岬へ赴任したときでも、もう明日にも人手に渡りそうな噂だったその家は、蔵の白壁が北側だけごっそりはげていた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついこの間仕入れたばかりの赤糸がごっそり姿を消している。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時に吹上浜の浪は砂丘まで襲いかかり、砂をごっそり持って行くのだ。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大江へんは建物ごとごっそり削られたとです」「ひどかでしたばい」　婆さんは口をとがらせた。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "織田信長がごっそり金と物資を運び去り、豊臣秀吉は市の三方にある濠を埋め、会合衆（佐貝の倉庫業者で共和自治体の司政官）らを強制的に大阪へ移住させた。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるでごっそりやっちまうんだからな。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が組合の仕事に打ちこもうと思った矢先に、当のアナ系の組合に属していた工場の連中が、ごっそりと寝返りを打って、ボル派の組合に一人のこらずはいってしまったのである。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこの丸万には、自分の恥をさらすようだから、まだ言ってなかったが、アナ系の組合に属していた工場の連中を、ごっそり引き抜かれた俺は、くやしくてくやしくて、ボル派の組合の江東支部へ、殴り込みをかけてやろうと思ったものだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
