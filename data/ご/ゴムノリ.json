        "examples": {
          "standard": [
            {
              "text": "パンクした自転車のタイヤを直すため、パッチの裏にゴム糊を薄く塗った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工作で革のパーツ同士を接着するのに、専用の強力なゴム糊が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蓋を閉め忘れたゴム糊が、瓶の中でカチカチに固まってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ええ――」　赤インクの瓶やゴム糊、硯箱、そんなものが置いてある机の上へ袱紗包みを置き、朝子は立ったまま、「校正まだよこしませんですか」と矢崎に訊いた。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一枚一枚、すこしずつ外して並べ、ゴム糊を塗る。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "次へ廻ると、ゴム糊の乾かぬほどの速度で、その花びらを一つ置きに張ってゆく。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚にならんだ、美しい自転車油とゴムのりのかん。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから人さし指をゴムのりのかんの中につっこんで、どろりとしたよいにおいのするやつをつぎのゴムとチューブの穴のある個所にぬらぬらとぬる。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹糸を引っ張ると取れたから、あたかもゴムのりでくっつけたかのようだった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "開けてやれ」　厚い封筒にはよくあることだが、ゴムのりが十分にくっついていなかったので、ペンナイフの背側で封を開くことができ、いじった形跡は何も残らなかった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
