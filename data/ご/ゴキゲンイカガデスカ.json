        "examples": {
          "standard": [
            {
              "text": "お手紙の冒頭に「寒暖差の激しい折、皆様ご機嫌いかがですか」と記した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "取引先の担当者に「その後、プロジェクトの進み具合やご機嫌いかがですか」と聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ご機嫌いかがですか」という丁寧な挨拶は、相手への敬意を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「そうなの、彼女はいつもちょっと芝居がかってるのよ、でね、可哀想にお父さんたら自分の宝物を持ってゆかれるのを放ってるのよ」「ご機嫌いかがですか、僕の好きなゴリオのお父さん？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにょうかんげえたんでえ、このおれさまに向って、ごきげんいかがですかなんてぬかしゃがって、ふてえやつだ。",
              "citation": {
                "source": "狐と猫",
                "author": "ヤーコップ、ウィルヘルム・グリム　Jacob u. Wilhelm Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
