      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "light used as a religious offering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕日が向うの岡にかくれて床が薄暗くなったから御神燈をつけ御てらしを上げた。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉上等がかえると御てらしが消えて御神燈の灯がバチバチと鳴る。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯上りの横櫛は薄暗い露地を月夜にして、お孝の名はいつも御神燈に、緑｜点滴るばかりであった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手切話しに、家を分けて、間夫をたてひく三度の勤めに、消え際がまた栄えた、おなじ屋号の御神燈を掛けたのが、すなわちこの露地で、稲葉屋の前がそれである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、土間に釣った未だ灯を入れない御神燈に蔦の紋、鶴沢宮歳とあるのを読んで、ああ、お師匠さん、と思う時、名の主は……早や次の室の葭戸越、背姿に、薄りと鉄瓶の湯気をかけて、一処浦の波が月に霞んだようであった。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯なき御神燈は、暮迫る土間の上に、無紋の白張に髣髴する。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神燈は未だ白かったのに、夜の暗さ、別荘の門、街道も寝静まる、夢地を辿る心地して、宮歳のかよわい手に、辰吉は袖を引かれて来たのであった。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神燈の影一つ、松葉の紋も見當らないで、箱のやうな店頭に、煙草を賣るのもよぼ／＼のおばあさん。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　出口の柳を振向いて見ると、間もなく、俥は、御神燈を軒に掛けた、格子づくりの家居の並んだ中を、常磐樹の影透いて、颯と紅を流したやうな式臺へ着いた。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月と云えば、暗いのも、明いのも、そこいら、……御神燈｜並に、絽なり、お召なり単衣に衣更える筈。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……けたたましく、可哀に、心悲しい、鳶にとらるると聞く果敢ない蝉の声に、俊吉は肝を冷しつつ、※々と面を照らす狐火の御神燈に、幾たびか驚いて目を塞いだが、路も坂に沈むばかり。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　密と、下へ屈むようにしてその御神燈を※すと、他に小草の影は無い、染次、と記した一葉のみ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俯向いて彳んでまた御神燈を覗いた。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊吉は、ト御神燈の灯を避けて、路地の暗い方へ衝と身を引く。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新道を抜けては※の芽のむせびをあはれみ、御神燈のかげをばそれしやの浴衣ともすれちがふ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わつしよい、わつしよい、わつしよい、わつしよい、子供の祭だ、祭だ、祭だ、提灯点けろ、御神燈献げろ、十五夜お月様まんまるだ。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お月様紅いぞ、御神燈も紅いぞ。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "磨硝子の瓦斯燈で朧の半身、背に御神燈の明を受けて、道行合羽の色くッきりと鮮明に、格子戸の外へずッと出ると突然柳の樹の下で、新しい紺蛇の目の傘を、肩を窄めて両手で開く。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帳場の灯と御神燈の影で、ここに美しく照らし出されたのは、下谷数寄屋町｜大和屋が分の蝶吉である。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついて右へ廻ると粋な格子戸の内に御神燈を釣したのがあるが、あらず、左へ向うと、いきなり縁側になって、奥の石垣が見透される板屋根の小家がある、そこが引越先であった。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてはや半札の円公は、御神燈の下から、まず御馴染の顔色を御覧に入れますると、「よう！",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "数寄屋町の御神燈の下を潜る事、毎夜あたかも燕のごとしで、殊にこの大和家には、蝶吉という、野郎首ッたけの女が居るから、その取入ること一通ではなく、余所の障子を張ってやりの筆法で芸妓の用達から傭婆の手助までする上に、隙な時は長火鉢の前で飼猫の毛を梳いている。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間わきの壁を抜いて、御神燈といいますか、かき入れなしの磨硝子に、鉢から朝顔の葉をあしらって夕顔に見せた処が、少々｜歪曲んで痩せたから、胡瓜に見えます、胡瓜に並んで、野郎が南瓜で……ははは。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女にしては力んだ眉をひそめて、団扇を片手に低い溜息をついたのは、浅草｜金龍山下に清元の師匠の御神燈をかけている清元｜延津弥であった。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏通りへ入ると、黄色い柿の花の散っている門構えの家などが見えたり、ごみごみした飲食店や、御神燈の出た芸者屋が立ち並んでいたりした。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年西洋に在りし為、三味線や御神燈を見ても遊蕩を想はず、その代りに艶きたるランプ・シエエドなどを見れば、忽ち遊蕩を想ふよし。",
              "citation": {
                "source": "田端人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯｜雨上りの瓦屋根だの、火のともらない御神燈だの、花の凋んだ朝顔の鉢だのに「浅草」の作者｜久保田万太郎君を感じられさへすれば好いのである。",
              "citation": {
                "source": "野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "お座敷へ出る芸者が二人ある御神燈のともった格子戸を出、静かにこちらへ歩いて来る。",
              "citation": {
                "source": "浅草公園",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い衆が「暫く、士連中の弟子入りが無かったが――」　と、呟きつつ、御神燈の下を眺めた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙ちゃんの家は私達の居た家から三軒ほど北にあった、格子で高いポックリの鈴のついたのが一っぱいならべてある御神燈のつってある――こんなものを見つけない私にはたまらないほどこう云う様子の家がうれしかった。",
              "citation": {
                "source": "ひな勇はん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
