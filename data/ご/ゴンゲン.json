[
  {
    "uuid": "b2ed1c16-ec36-51a3-8745-49cd6daa3bb1",
    "entry": "権現",
    "reading": {
      "primary": "ごんげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
