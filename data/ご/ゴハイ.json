[
  {
    "uuid": "b9f601ef-cbed-548c-8f09-3f07686e75b7",
    "entry": "誤配",
    "reading": {
      "primary": "ごはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "misdelivery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "判じ文を唯一の手がかりとなさるならば、貴殿のお知恵によって、絵のところに待っているという三つ刺したくしだんごはいずれの地名か、それをお判じなすってお出かけなさることだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうでも捨てるとなると、あねごはいったいどうするだろう。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はなかなか手ごはい。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今度は村長の手ごはい肘鉄砲を喰らつて、どんでんがへしに、その場へ投げ出された。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ系統の語らしいものに、口ごはいと言ふ語がある。",
              "citation": {
                "source": "方言",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此語は、馬などにも言ふ口強と言ふ語の、謂はゞ、連体法のくちごはいが、くちごはい事など言ふ接続を忘れて、な（＜なる）を落す上方修飾語の常習と誤認して、名詞と思うたのである。",
              "citation": {
                "source": "方言",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、手ごはい、喰へない男、としての「医師高間房一」だつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくごはいいか）　と、いったような意味をこめて、いよいよ最後の決心をかためさせたのです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにもりんごはいろいろな効能を、例えば乾燥する力とか収斂する力とかを、もっているかも知れないが、我々はそれらに相応する感覚をまるで持っていない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
