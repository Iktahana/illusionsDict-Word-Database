        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "扨又其の人事の全體の中で、極小、極短、極弱、極薄の地位を有して居るのが個人の状態である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてまたその人事の全体の中で、極小・極短・極弱・極薄の地位を持つのが個人の状態である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の外にある二十枚の皿を白菊と云って、極薄手の物であると申すことですが、東山時分に其様な薄作の唐物はない筈、決して薄作ではあるまいと仰しゃる方もございましょうが、ちょいと触っても毀れるような薄い皿で、欠けたり割れたりして、継いだのが有るということです。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "極薄な味のないところが、却ってよいのではないか。",
              "citation": {
                "source": "道は次第に狭し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "色が浅黒く、いい恰幅で、藍がかった極薄地羅紗の単衣羽織に、透しのある和蘭呉絽の帯しめ、れいの、お揃いの蕃拉布を襟に巻いている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に初めは極薄きを用い、追々其喰料を増加して漸次に復常し、書を読み、或は近傍を歩行するに至れり。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "與謝の海の如きも、砂嘴で作つた潟に過ぎないので、一半の水が淡水で、海に近い他の一半も鹹氣が極薄いのであります。",
              "citation": {
                "source": "潟に關する聯想",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "前方には再び書棚が現れ、その一つの前の床の上に最近若干のケースが落下し、そこが極薄く埃をかぶっただけの山になっているのに気づいた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷床は極薄くそこここに黒い土が見える。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その看板には、ごくうすい色で、栗毛の馬に乘つたふたりの少女の圖が描いてあつた。",
              "citation": {
                "source": "夜に就て",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体がずんぐりしていて、頭が大きく、まっ白なほどの金褐色をした頭髪と眉毛、ごくうすい青色の眼、広い蒼白い頬、太い唇、多少｜脹れた顔、赤い小さな手をしていた）――その少女が、彼の近くへやって来て、立ち止まって親指を口にくわえ、彼の泣くのをながめた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――くめは色も縞柄もじみな着物でごくうす化粧をしていた。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのもう一まいのドアは、うすい鉄板を木目に色どったもので、内がわにはめてある鏡も、ごくうすいガラスでできているので、りょうほうで一センチぐらいのあつみしかありません。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
