        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「御免なさい」と云ってそれを修正する。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）本当に御免なさいよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと御免なさいよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒から直ぐに土間へ入って、横向きに店の戸を開けながら、「御免なさいよ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、御免なさい。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "向後気をつけます、御免なさいまし」と叩頭したが、それから「片鐙の金八」という渾名を付けられたということである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御免なさいといってあけてやってまた鐘を見せに連れて行きました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳二郎は急に眞面目な顏をしてこの有樣を見て居たが、忽ち顏を背向け山の方を見て默つて居る、僕は暫くして「徳、最早歸らう」と言ふや女は急に頭を上げて「御免なさいよ、眞實に坊樣は私の泣くのを見て居てもつまりません。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "慝すかお前は』と僕の顔を睨みつけましたから、僕も益々｜可怕なり、『御免なさい、御免なさい』とたゞ謝罪りました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と今度は真実に怒って言いますから、僕は何のことか解らず、たゞ非常な悪いことでも仕たのかと、おろ／＼声で、『御免なさい、御免なさい。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがある日のことでございました、『御免なさい』と太い声で尋ねて来た者があります。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "手持不沙汰に、後退にヒョイと立って、ぼんやりとして襖がくれ、「御免なさいまし。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほほほ、申過しました、御免なさいよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "千世ちゃん、御免なさい、と云って、お前さんもおややまり。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「貴方、御免なさいまし、ほほほ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「聞いて遣わす、お酌をおし……御免なさいよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うまい装をして、」　と膚の摺れる、幽かな衣の捌きが聞えて、「御免なさいまし。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　と敷居に、其の袖も帶も靡くと、ひら／＼と團扇が動いて、やゝ花やかな、そして清しい聲して、「御挨拶もしませんで……何うしたら可いでせう……何て失禮なんでせうね、貴方、御免なさいまし。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お沢　（声の下に驚き覚め、身を免れんとして、階前には衆の林立せるに遁場を失い、神職の手を振りもぎりながら）御免なさいまし、御免なさいまし。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免なさいまし、三人｜巴になってごたごたしてるので、つい見はぐしたよ、どうしたろう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に窺う、八蔵、銀平、時分はよしとぬっと入り、「あい、御免なさいまし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっしと撲たれて悲鳴を上げ、「ああれ御免なさいまし、御免なさいまし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょいと御免なさい、御免なしい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へい、真平御免なさい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ御免なさいよ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は、ごめんなさい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「呼び出したりして、ごめんなさいね。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、ごめんなさい。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、ごめんなさい。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は、ごめんなさい」ジョバンニはまっすぐに立ってまた叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
