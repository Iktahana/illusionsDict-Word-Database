    "definitions": [
      {
        "index": 1,
        "gloss": "the majority (of people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
