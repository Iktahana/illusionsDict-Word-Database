    "definitions": [
      {
        "index": 1,
        "gloss": "homa-mandala (fire altar)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "護摩壇に向つて、髯髪も蓬に、針の如く逆立ち、あばら骨白く、吐く息も黒煙の中に、夜叉羅刹を呼んで、逆法を修する呪詛の僧の挙動には似べくもない、が、我ながら銀の鍋で、ものを煮る、仙人の徒弟ぐらゐには感ずる。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台坐には、十一坐、九重坐、七重坐、蓮坐、荷葉坐、多羅葉坐、岩坐、雲坐、須弥坐、獅子吼坐、円坐、雷盤坐等で、壇には護摩壇、須弥壇、円壇等がある。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "護摩壇、垢離場、懺悔の部屋、小さい無数の礼拝所、数限りない石祠等、広い境内の到る所に、隙間もなく建てられてある。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "護摩壇に盛んに煙が上って、陰気臭いにおいが鼻をぷーんと打つ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、空闥に案内して貰って薬師堂を調べる事にしよう」　薬師堂の階段を上ると、中央には香の燃滓が山のように堆積している護摩壇があり、その背後が厨子形の帷幕になっている。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "護摩壇前の経机には、右端に般若心経が積み重なっていて、胎龍が唱えたらしい秘密三昧即仏念誦の写本が、中央に拡げられてある。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お由羅が入ると、青い衣をつけた、三十余りの侍が、部屋の隅から、御辞儀をして「用意、ととのうております」　部屋の真中に、六七尺幅の、三角形の護摩壇が設けられてあった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛之助の病平癒の祈祷をするといって、この護摩壇を設けたのであったが、三角の鈞召火炉は、調伏の護摩壇であった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く、四人は、そのままで黙っていたが「烏帽子で、護摩壇の跡を見た」　と、玄白斎が、口を切った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧は、その真中へ、自分で、杭を打ち、縄を三重に張って、三角の護摩壇を形造った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘呪相争　息災、延命の護摩壇は、円形であった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "山間の冷気は夜松浦川の渓を襲ひ、飽くまで醸しなされたる狭霧は恰も護摩壇の煙のごとし。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家の二階の一室には護摩壇が備へてあつて、毎月一、二回その老法印が來て護摩を焚き、不動、慧智の修法を行ふのでありました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、私は或る時、この護摩壇の奧にある本尊樣を摘發して子供心を驚かせたことがあります。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人は護摩壇のあるところを聖天樣とも云つてゐましたから、この怪物は多分大聖歡喜天像で、おそらく生殖の神を象徴したものでありませう。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九尺四方｜白木の道場の正面には、不動明王の御像を掛けさせ護摩壇を据ゑ、燈明供物を並べ、中程のところに東海坊、白衣に袈裟を掛け、散らし髮に兜巾を戴き、揉みに揉んで祈るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、「それ――ツ」　壇上の東海坊が聲を掛けると、壇の四方を埋めて人間の脊丈けほどに積み上げた夥しい枯柴に油を注ぎかけて、護摩壇の火を取つて移しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかしたら、閻魔の屋敷の雪隱の床下かも知れないと思つて這ひ出すと、眼の前に燃え殘りの護摩壇が見えるぢやありませんか」　ガラツ八の話は手振りが交りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」「火伏の行とか何んとか言つて、散々｜賽錢と祈祷料をせしめた上、四方から火を掛けさせ、煙が一パイになつた時を見測らつて護摩壇の拔け穴から、茶店の床下へ拔ける筈だつたんだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも急造らしい小さな堂ですが、豪勢な調度や、金色｜燦然たる護摩壇は、如何にも流行の神らしく、白痴脅かしのうちにも、人を壓する物々しさがあります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の小僧はどつちも十二三で、物の數でもなく、二人の女はこんな邪惡な修驗者にあり勝の妾で、一人はお雪と言つて二十七八、一人はお鳥と言つて二十三四、二人とも恐ろしく派手な風をして居りますが、病身らしく蒼ざめて、相當の力を要する、護摩壇の下の細工などは出來さうもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とこをで護摩壇の下の拔け穴だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日道灌山へ行つてゐたことは皆んな知つてゐるし、護摩壇の下に拔け穴のあつたことも、前から知つて居たつて本人が言ふさうですよ」「それから」「今でも滅茶々々に東海坊の惡口を言つて歩きますよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "行子が黒谷の尼院の局まがいで、似たような境遇の預姫と長い一日をもてあましていたころ、雑仕の比丘尼たちの乏しい食餌に悩み、古柯という葉を灰で揉んで噛んだり、護摩壇の罌粟加持につかう罌粟の精を飲んだりして空腹をまぎらしていた。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに代って呼び込まれたのは、俗に祈りの道六と言う、その頃高名な修験者、「如何なる悪魔｜化性の者と雖ども、私の祷りに退散しないという事は無い」　という見識、されば一室に護摩壇を築き、秘仏を勧進して、三日三夜の間、揉みに揉んで熱祷を捧げましたが、それとても、何んの験もありません。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第三夜　お化け若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "護摩壇も、天井裏も、床下も、押入れも一刻ばかりで見盡しましたが、竹筒は愚か、小判の片らも見付かりません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "九百九十兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "護摩壇も、天井裏も、床下も、押入も、一刻（二時間）ばかりで見尽しましたが、竹筒はおろか、小判の片らも見付かりません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "九百九十両",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、銭形の親分、ちょうどいいところだ、――仏罰の恐ろしさ、これを見て下さい」　優曇法印は立ち上がって、護摩壇の前を指します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "九尺四方｜白木の道場の正面には、不動明王の御像を掛けさせ護摩壇を据え、灯明供物を並べ、中ほどのところに東海坊、白衣に袈裟を掛け、散らし髪に兜巾を戴き、揉みに揉んで祈るのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
