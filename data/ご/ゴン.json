  {
    "uuid": "b560ad4c-7b9a-52a7-bf88-0061b43c5240",
    "entry": "ごん",
    "reading": {
      "primary": "ごん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "great burdock",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "美代はこの夜三時過ぎまで結びごんにゃくをこしらえていた。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいぼれは一晩中こごんで肝臓を庇っていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろで誰かこごんで石ころを拾っているものもある。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニッと団九郎、いきごんで武蔵を見る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、綺麗ですね……」と、私は花立に※さつたコスモスの花を眺めながら云つたが、何となく何時ものやうな明るいなごんだ氣持にはなれなかつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんごん胡麻は老婆の蓬髪のようになってしまい、霜に美しく灼けた桜の最後の葉がなくなり、欅が風にかさかさ身を震わすごとに隠れていた風景の部分が現われて来た。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんぶだごんの価値でも説く事か、天女に対して、三銭也を口にする。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう考えながら医院を出ると、下痢をしている身体にもかかわらず、妙に意気ごんで宿に帰って行った。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはっきり言わさねば承知出来ないと意気ごんだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀の子、泳いでいる大｜章魚、あなご、ごんずい……大して面白い見せ物ではありません。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中山から、少しはなれた山の中に、「ごん狐」という狐がいました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんは、一人ぼっちの小狐で、しだの一ぱいしげった森の中に穴をほって住んでいました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日雨がふりつづいたその間、ごんは、外へも出られなくて穴の中にしゃがんでいました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨があがると、ごんは、ほっとして穴からはい出ました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんは、村の小川の堤まで出て来ました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんは川下の方へと、ぬかるみみちを歩いていきました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんは、見つからないように、そうっと草の深いところへ歩きよって、そこからじっとのぞいてみました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵十だな」と、ごんは思いました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵十がいなくなると、ごんは、ぴょいと草の中からとび出して、びくのそばへかけつけました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんはびくの中の魚をつかみ出しては、はりきり網のかかっているところより下手の川の中を目がけて、ぽんぽんなげこみました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんはじれったくなって、頭をびくの中につッこんで、うなぎの頭を口にくわえました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎは、キュッと言ってごんの首へまきつきました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんは、びっくりしてとびあがりました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎをふりすててにげようとしましたが、うなぎは、ごんの首にまきついたままはなれません。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんはそのまま横っとびにとび出して一しょうけんめいに、にげていきました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんは、ほっとして、うなぎの頭をかみくだき、やっとはずして穴のそとの、草の葉の上にのせておきました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　十日ほどたって、ごんが、弥助というお百姓の家の裏を通りかかりますと、そこの、いちじくの木のかげで、弥助の家内が、おはぐろをつけていました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんは、「ふふん、村に何かあるんだな」と、思いました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、葬式だ」と、ごんは思いました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
