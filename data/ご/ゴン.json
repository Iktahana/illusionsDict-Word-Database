[
  {
    "uuid": "b688b023-9666-553c-b5b4-776afc706bb8",
    "entry": "艮",
    "reading": {
      "primary": "ごん",
      "alternatives": [
        "こん",
        "え"
      ],
      "is_heteronym": false
    },
    "grammar": {
