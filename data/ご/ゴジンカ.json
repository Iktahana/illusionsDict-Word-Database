    "definitions": [
      {
        "index": 1,
        "gloss": "deified volcano or volcanic eruption",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういへばソレントオは熱海、ポジタノは舞鶴、またオの煙は大島の御神火に相応します。",
              "citation": {
                "source": "伊豆伊東",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島人の疲れいたはる御神火の恵みあふるる湯のけむりかもてんだ。",
              "citation": {
                "source": "だだをこねる",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "元村から御神火までは三十一丁位だとありましたが、本當は煙の噴いてゐるところまでは一里位はありませう。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく孤獨さうな樣子でしたが、私は早足で御神火茶屋にかけ上りラクダを頼みました。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、一日か二日の旅だつたら、無理にでも、着いたらすぐ御神火を越して波浮へ出て泊りたいと思ふ位でした。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤ素通りか」「東京の客人は、宵越しの辨當を持つて山へ登るんだから、ガツチリしてゐるよ」　あんなザツパクな人情では、むしろ宵越しの辨當でも持つて御神火を越した方が、よつぽどケンメイだと思ひます。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴヱスビオの山の煙のやうに雄大でもないが、貧しいながらも、此岡田村から見る御神火は私の小ナポリです。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしゃ大島御神火そだちよ　初めの一句は調子外れで、後はどうにか歌ってのける。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神火茶屋まで登っても、さてそれから沙漠を横断して内輪山の火口壁まで行くのが大変だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま御神火茶屋から火口へ行くには、熔岩原を横断するわけにいかないから、外輪山と押しよせた熔岩の間に幅十米ぐらいのスキ間が残って谷をなしてるところを迂回して行くのであるが、大廻りだし砂の道だし、急いでも片道一時間かかるそうだね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホウホウのていで熔岩の上から這い降りて、御神火茶屋へ同行の青年に尻を押されて這い登りましたよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧の火口に見切りをつけ、御神火茶屋から数百米のところに湯場と称して、自然噴出の蒸気を利用したムシブロがある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神火茶屋に働いてる十六七の娘たちは眼下にせまる熔岩を見下しながら、熔岩がそこまで迫ってきた時は、ちょッと熱かったが面白くてたのしかったなどと言っていたね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢の大神宮では今日でもヤマビワの木で錐の様にヒノキをもんで発火させ、これを御神火として神前へ供する儀式がある。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは豆南の一角、海をへだてた大島の御神火と対して、町に湯煙のたえない熱海の湯治場。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
