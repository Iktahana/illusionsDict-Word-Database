    "uuid": "f9457edf-70f8-5984-a3f5-4faa36f3da55",
    "entry": "ゴリ押し",
    "reading": {
      "primary": "ごりおし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pushing through",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "キンクスの〈ユー・リアリー・ガット・ミー〉や、ボビー・フラー・フォーの〈アイ・フォウト・ザ・ロウ〉のような、そして、この〈ゲット・オフ・オヴ・マイ・クラウド〉のような、ギターコードでゴリゴリ押しまくる曲は、慶一は、とりあえず無条件で好きになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車へ乗る事も久しぶりだけれども、何となく東京へなごりおしい気持ちなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しはあのひとのこゝろになごりおしさや悔ひを殘すことが出來たらそれで本望だと感傷のこもつた電話のかけかただつた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年組はなごりおしそうに、ベッドへいそいだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで正太は、やっとすこし元気づいて、なごりおしくも敦賀の町をあとに、東京へむかったのであった。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なごりおしくいつまでもいつまでも立ちつくす。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
