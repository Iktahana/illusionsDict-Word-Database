    },
    "definitions": [
      {
        "index": 1,
        "gloss": "give and take",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一説にメズサもと美麗な室女だったが、海神ポセイドンとアテナ女神の堂内で婬し、涜した罰でその髪を蛇にされたと、ゴルゴネス三姉妹の同胞になおグライアイ（灰色髪女）三姉妹あり、髪が灰色になった老女で、ただ一つの歯とただ一つの眼を共有し、用ある時は相互譲り使うた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術鑑賞に必要な同情ある心の交通は、互譲の精神によらなければならない。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "互譲と、協和に成り立つ道徳的文化こそ人類のためであり、また民族共存共栄の希望に満つるものである。",
              "citation": {
                "source": "日本的童話の提唱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "互譲の精神を以て相頼り相助くるところに男女の義務が存在し、美しき道徳の根源はここに涵養される。",
              "citation": {
                "source": "婦人問題解決の急務",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果は、双方の互譲となって、一　中国五ヵ国の譲渡。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し、大人の世界に於て、犠牲とか互譲とかいたわりとか、そういうものが礼儀でなしに生活として育っているのは淪落の世界なのである。",
              "citation": {
                "source": "青春論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、ごじょうだんをおっしゃって、そんなお人がらな半※を。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いいかげんなころを見はからって、ご自分の方が先におあがりになり、ごじょうだんのように建の太刀をお身におつけになりながら、「どうだ、二人でこの刀のとりかえっこをしようか」とおっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞「オホホホごじょう談ばかりおっしゃります。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ですから、私が代行いたしまして、お片付けするんです」「そんなら、お前の判を捺せ」「ごじょうだん」　青ン膨れの店員が嫌な顔をした。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……潮ざしをはからって場所を決めるのは、相当の名人がいたすことでございます」「じゃア、ご名人にたずねるがの、するてえとなんだナ、竿さえひっかついでそこへ行きゃあ、いやでも、釣れるてえわけか」「ごじょうだん」　と、らっきょう、いやな顔をする。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ときに、ひょろ松、おれが釣ろうというのは、腹の白っこい、指ほどの鱚じゃねえんだぜ」「へへ、じゃ、鉄炮洲で赤穂鯛でも釣ろうとおっしゃるんですかい」　顎十郎は、首をふって、「いや、もっと大きい」「ごじょうだん。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、隕石ってやつは、だいぶと路考｜贔屓とみえるの」「ごじょうだん」「久米の仙人でもあるまいし、隕石が路考贔屓の娘ばかり選んで隕ちかかるというわけはなかろうじゃないか。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごじょうだんを、お姉さま。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            },
            {
              "text": "大野　ごじょうだん！",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へへへへ、ごじょうだんもいいかげんになすっていただきてえもんで。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごじょうだんをなすってはいけません」　目をおさえられながら、それはむしろ叱責するような声でありましたが、後ろの人はなんにも言わず、まして手を緩めようとも、放そうともしません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとに、どなたですか、ごじょうだんをあそばしてはいけません、どうぞお放し下さい」　お雪には、その押えられた手の主が誰であるか、見当がつかないらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殿様、ごじょうだんをあそばしちゃいけません、御入用ならば、そのままそっくりお持ち下さればいいに……」　七兵衛は、いつまでも障子の外から、こっちを覗いてニタリニタリと笑っているばかり。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼さえだれも寄りつきません」「それでは畑のあたりに出没してくだすってもよろしい」「あすこも淋しいです」「入道がこわがっちゃいけませんな」「先生、この役は私ごめんこうむります」「黒須君、これで美事あなたの試胆会がすみました」「ごじょうだんでしたか？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハハハ……、ごじょうだんを。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が、他言は無用だぞ」「仰っしゃるまでもございません」「褒美に、吉原へ連れて行ってやろう」「ごじょうだんを。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごじょうだんでしょう。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやなにを……」「この呂宋兵衛が、命がけでとった柴田方攻軍の秘帖、秀吉公への土産にするのだ」「いいえ、わしはなんにも知りませんよ」「城中のくらがりで、たしかに汝の手へわたしたはず」「ごじょうだんを……この婆はおまえさんがはたらくまえに、逃げだしたんじゃないか」「はてな？",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふふん、貴様たちみたいに、銅脈ばかりさぐりあてる玄人とはちがって、しかもこれは金鉱だ」「ごじょうだんでしょう、めッたやたらに、そんな鉱山があってたまるもんですか」「いやうそではない、すぐにこれから、その鉱山へ出立するのだ」「まったくですか？",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、らちゃくちゃない」「……ついに、堪忍ぶくろの緒を切って、おまえの娘を殺してしまった」「ごじょうだんでしょ、だんな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごじょうだんでしょう、君！",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稼いだものは稼いだだけ、米でも金でもようございますから、現の物でいただかなくちゃ、こちとら、日稼ぎの貧乏人は、女房子を食わしちゃゆかれませんので」「米一升に、銭百文あれば、その方たちの暮しでは、ふだんの収入よりもはるかによいはずではないか」「ごじょうだんを仰っしゃっちゃいけません。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "お代さえいただけば、揚げてあるやつを直ぐお出しいたしますが」「銭はない」「ごじょうだんを」「ほんとだよ」「では、お酒のお代のほうは」「この先の寺の横丁を曲がると、童学草舎という寺子屋があるだろう。",
              "citation": {
