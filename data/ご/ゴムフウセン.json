        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たうとう狼をたべてから二十五日めに狸はからだがゴム風船のやうにふくらんでそれからボローンと鳴って裂けてしまった。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※まことに人生、一瞬の夢、　　　　ゴム風船の、美しさかな。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西扉の傍には、何のつもりか舶来の酒の壜や前菜料理の材料なぞと一緒に大きくふくらましたゴム風船の沢山浮んでいる見世飾があって、それらの透き間から垣間見ている者もいた。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "花火や、ゴム風船の音もへったようでした。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人がチットモ気付かない間にその部分の血管が、心臓から押出される血液の圧力に堪えかねて、少しずつ少しずつゴム風船のように膨れ上り初める。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな子供のいる食卓の上には子供の数だけのゴム風船が浮游している。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風船屋が、慌てて風船を捕まへようとしましたが、糸の切れた赤い数十のゴム風船は、ぐんぐんぐん空高く舞ひ上りました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロちやんは、赤いゴム風船を、買つて貰ひましたが、あまり人混みでありましたので、人に押しつぶされて、パチンと破れてしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "張り切つたゴム風船を、一気に踏み潰して、ポンとあつけない音を耳にした時のやうな、洞ろな晴々しさを感じた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩になれば、ゴム風船などを賣る商人が荷物にした商品を背負つてやつてくることになつてゐるし、法界節屋の連中も停車場のある町から來て、その舞臺で、安來節や手踊りなどをすることになつてゐた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "人聲の中から時々、頓狂に、ゴム風船の破れる音や、笛の音が聞えた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の道の兩側には、ランプをつけた屋臺のゴム風船屋などが、四つ程ならんでゐた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "器械がまわり、時間がたつにつれ、足の先に腰が現われ、それからその先に胴中やら、胸やら肩やら、そしてあの醜い首やらがむくむくと、まるで畳んであったゴム風船をふくらますように現われてきたではないか。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶が探し疲れて家へ戻って来ると、迷い子になった子供はゴム風船を持って一人ぼんやりと勝手元に立っていた。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぼんだゴム風船の様にベロベロ皮膚のたるんだ頸が、驚くほど延びた。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "星が澄んできらめき渡り、ゴム風船をすりあふやうな、透明な夜風がゆき子の絹ポプリンの重たいスカートを吹いた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼が、まるで黒いゴム風船のように、飄然とこの屋上庭園に上ってきたとて、誰も咎める人などありはしない。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の上の広くもない歩道は、青や赤のゴム風船を片手に子供の手をひいてそろそろ歩いている夫婦ものや、真新しくそりかえった足袋に派手な草履をはいた若い女づれの一組などで日曜日らしく混雑している。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた脚は――と言うよりもズボンはちょうどゴム風船のしなびたようにへなへなと床の上へ下りた。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでゴム風船をふくらまさうとして力んででもゐるやうな、オペラ・コミックの一節のやうな。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすきみわるい大きなまるい頭が、まるでゴム風船をよせあつめたように見え、そしてかれらは、まるで風が障子の破れ目にあたるときに発するような奇異な声をあげて、しきりになにごとかささやきあった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまるでベビー服の下で、ゴム風船を膨らしているような具合だった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴム風船や、紙のお面をくれてたわ。",
              "citation": {
                "source": "母の日",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○大劇場横でピーイピーピー横長いゴム風船を売ってる。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜといって、今空から一人の人間が、浮力を失ったゴム風船みたいに、ふわりふわりと下りて来るではないか。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると減圧箱は、ゴム風船がちぢむ時のように見る見る小さくなった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴム風船地球儀は、目下｜印度洋の附近を書いていられる。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二つ、ええと、ゴム風船の地球儀は、印度洋の附近を書いていられるところだと。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユウ子ちゃんが、うちのにわであそんでいますと、赤いゴムふうせんが、空からふわふわとおちてきました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふろしきの中には、二十センチほどの長さの竹のつつが三本と、しぼんだゴムふうせんのようなものが三つ四つと、針金の輪になったたばが一つ、はいっていました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
