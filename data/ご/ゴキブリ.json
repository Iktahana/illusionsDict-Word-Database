        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "チャイナ中国の貿易船のネズミとゴキブリだらけの黴臭えおんぼろ箱のなかで終わるとかありえねえ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴキブリは、簡単には絶滅できない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国引揚者に、ハイや蚊がいないという話を、さもうらやましそうに聞いてばかりいないで、頼まれなくとも、鼠とゴキブリくらいは、自分で楽しみながら退治したらいいだろう。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの目はたぶん古いプレゴキブリから寄生的に進化したものであって現在のゴキブリやシロアリもこれから発生した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレゴキブリすなわち原始ブラッタリアは上石炭紀の化石形であって問題にするにはあまりにも離れている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
