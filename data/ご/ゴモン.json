    "definitions": [
      {
        "index": 1,
        "gloss": "crest (of a noble family)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
