          "standard": [
            {
              "text": "ゴルフボールが林の中に飛んで行ってしまい、探すのに苦労しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ティーショットで、新しいゴルフボールを思いっきり打ちました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのゴルフボール、よく見ると小さな傷がたくさんついてるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "退院して湯河原で静養中に、ゴルフボールを一ダース退院祝いにぶらさげて遊びに行くと、さっそく箱をあけボールをとりだして眺めたり撫でたり、まるで舐めやしないかと思うような喜びようであった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがつて彼は大へん立派な秘書であつた……提督の通信物がドンドン集まつてきてたまつたのを整理するのにも、ゴルフボールを相手にするときと同じようにすばやい一心不乱の精神集中法を用いていた。",
              "citation": {
                "source": "緑色の人",
                "author": "THE GREEN MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでなくちゃア」「私は今夜は頭痛がするわ」秋子さんは振向いて、立ち去ろうとする、ピカ一が後を追おうとすると、いくつかのゴルフボールがとんできて、頭へ一つ、つづいて一つ肩へ当った。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフボールはさっきからあやか夫人がお手玉にして遊んでいたのだから、ピカ一がふりむくと、あやかさんは素知らぬふり、椅子にもたれてアラヌ方を見ている。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
