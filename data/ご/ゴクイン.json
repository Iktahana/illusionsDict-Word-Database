        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それ故に派手は品質の検校が行われる場合には、往々趣味の下劣が暴露されて下品の極印を押されることがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "行かねばならないおんつぁんを、親身に送るものは、不良青年の極印を押された勃凸が一人ゐるばかりなのだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車屋の挽子がね、お前さん、え、え、ええッて、人の悪いッたら、聾の真似をして、痘痕の極印を打った、其奴の鼻頭へ横のめりに耳を突かけたと思いねえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら、男の心中の極印打ったも同じ事、喜んだかて可いのどす。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "有耶無耶の内は、夢だろうぐらいで私も我慢をしましたけれども、そうどうも手首へ極印を打たれちゃあ辛抱がなりません。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "守宮の血で二の腕に極印をつけられるまでも、膝に此の薬を塗られて何うしよう。",
              "citation": {
                "source": "処方秘箋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにとうにするはずの殉死をせずにいた人間として極印を打たれたのは、かえすがえすも口惜しい。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その矢先きへ、綾衣のひたいに剣難の極印が打たれたと聞いては、彼がおびえたのも無理はなかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が私の極印を押された許可状を持たずに、霊から引放した肉だけにお前の身売りをすると、そこに実質のない悪魔というものが、さも厳めしい実質を備えたらしく立ち現われるのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち愛の極印なき所有物を外界に向って恥じることもなく放射する。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども愛の極印のない所有物は、一度外界に放射されると、またとはその人に返って来ない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が愛の極印のないものを施すのは一番大きな罪だと知らねばならぬ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして愛の極印のあるものは、仮令お前がそれを地獄の底に擲とうとも、忠実な犬のように逸早くお前の膝許に帰って来るだろう。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古い色を見ると、木村の父の太っ腹な鋭い性格と、波瀾の多い生涯の極印がすわっているように見えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹柴館の夜に葉子は倉地を極印付きの凶状持ちにまでした事を知った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋼鉄製の蒸気機関の模型か何かのやうな厳畳づくりで、ぶつぶつ泡を吹いてゐるところは、どう見てもドイツ人の考案したらしい生物で、甲羅のどこかに『クルツプ会社製造』とでも極印が打つてありさうな気がします。",
              "citation": {
                "source": "若葉の雨",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "好男子で乱暴者でピストルの名手　極印つきの不良少年に二種類ある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り文化式が全盛で、極印付きが三千何百も居るのだからウンザリする。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "金物の彫りの方では、唐草の地彫り、唐草彫り、蔓彫り、コックイ（極印）蔓などで地はいずれも七子です。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は極印でも打たれたような額を客舎の硝子窓のところへ持って行って、人知れずそのことを自分に言って見た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、この頃になると、私は愈※その筋から、大学教授中の「危険思想家の巨頭」だと極印づけられ、いつ問題にされるか知れない状態になつてゐた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "問屋筋のかたぎのうちでは、大きな、極印のような判をベタベタと押した。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の『東洋巡歴記』はその死後に、十七世紀の初期に公にされて、廣く歐洲諸國人に愛讀されたが、その内容が如何にも奇怪で、可なり誇張もあるから出版の當初は荒誕なる虚構談として取扱はれ、シエクスピアの如きもピントを世界第一の虚言者と極印を付けて居る。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、スヴィドリガイロフはそれをおさえつけて、ごくいんぎんな調子で答えた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
