        "examples": {
          "standard": [
            {
              "text": "「呉牛月に喘ぐ」という言葉は、前の恐怖がトラウマになって、無関係なものにまで怯える様を指す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "失敗を恐れるあまり、まだ起きてもいない問題に「呉牛月に喘ぐ」ような状態になってはいけない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は過去のトラウマから、少し似た状況を見ただけで「呉牛月に喘ぐ」ようにパニックを起こしてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "呉牛月に喘ぐも、日と同じき熱さなるにあらず。",
              "citation": {
                "source": "日月喩",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜀犬日に吠え、呉牛月に喘ぐと云うから、わしのような田舎者は、かえって困るかも知れんてのう」「困りゃしませんがね。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
