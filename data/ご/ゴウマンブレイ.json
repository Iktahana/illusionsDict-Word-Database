    "definitions": [
      {
        "index": 1,
        "gloss": "(arrogance and) insolence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
