  {
    "uuid": "1d130657-ce7c-5961-b0fd-20e0040b593c",
    "entry": "獄",
    "reading": {
      "primary": "ごく",
      "alternatives": [
        "ひとや"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
