        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「そんなにごねても、決まったルールは変えられないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「子供がおもちゃを買ってくれと店先でごねている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「予算の件で下請けにごねられて、工期が遅れそうだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あの人はモー駄目だ、今度こそごねる、あの人が死ねば何某がその職を亜ぐだろう、その時は此方も位地を進めてもらえる、今日はついでにその人の処へ行って御機嫌を伺っておこうと一方の病気見舞は一方の御機嫌伺いと変じた。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから魚の往生をあがると云って、鳥の薨去を、落ちると唱え、人間の寂滅をごねると号している。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも一度はごねてみるのね」　幾島は吹きだして、「ごねるか、あなたが云ふからなんのことかと思つた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きなこと云ってごねるのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "へい」「じゃあ、なにを施せと、ねだっているんだ」「旦那に会わせろって、ごねるんですよ」「ふざけるな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
