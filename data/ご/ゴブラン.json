        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから部屋の隅の紐を引くと、部屋の三方の眼界を遮っていたゴブラン織の窓掛がスルスルと開いた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑のゴブラン織のやうな蔦の茂みを背景にして背と腰で二箇所に曲つてゐる長身をやをら伸ばし、箒を支へに背景を見返へる老女の姿は、夏の朝靄の中に象牙彫りのやうに潤んで白く冴えた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるにても、山川の美しさは、春や秋のは言わばデパートメントの売り出しの陳列棚にもたとえつべく、今や晩冬の雪ようやく解けて、黄紫赤褐にいぶしをかけし天然の肌の美しさは、かえって王宮のゴブランにまさる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この箪笥の側に旅行用の鞄、杖、洋傘などいろ／＼窓ゴブラン織の厚い窓掛、別にレエスの窓掛。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓に向つて机、肘掛椅子、堅い椅子、敷物洗面臺暖爐　　寢臺（燭臺置物、便器入れ兼用）　　　　　　　　　　　　　　　　　　　　　　部屋の入口の扉　この寢臺、置箪笥、ゴブラン織の窓掛なぞは部屋についた造作と見ていゝ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面臺の上には造花模樣の陶製洗面器と、同じ陶製の水さしとが置いてあつたが、下宿のあるところから遠くないゴブランの町の陶器店で手に入れ得る程度のものだ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼にも判る一｜大きさ小さなゴブラン織りの宮廷靴が、蹴合いに勝って得意な時の鶏の足のような華奢な傲慢さで絨毯の毛波を押しつけていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にはまたゴブランの市場に近い貧しい町々の方へ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "喇叭卒を先に立てた仏蘭西歩兵の一隊がゴブランの市場の方角から進んで来た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "タペストリも皆ゴブラン織で、ルネッサンス時代の大きな彫像が置いてあって、ほんとに素晴らしいクラシックよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽雅な近代風のゴチック様式で、ゴブラン織の深紅の窓掛を絞った高い窓が、四方の壁にシンカンと並んでいた。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった今気がついた左右の出入口の、褐色ゴブラン織りの垂れ幕は、青ペンキ塗りの粗末な扉を隠すためである。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると部屋の片隅のゴブラン織りの寝台から嗄れた声が聞こえて来た。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのゴブラン織のような合唱の中を、風のように去来する可憐なボオイ・ソプラノはなんとも云えず美しいものだった。",
              "citation": {
                "source": "木の十字架",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェルサイユの宮殿は二階正面のガラスの大広間から西へ廻って二つ目に王妃の部屋があって、グリザイユの天井とゴブランの壁掛で装飾され、其処にも誇らしげに胸を張った彼女の肖像画を見た。",
              "citation": {
                "source": "パリの地下牢",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもまだ寝て居たところを起し、一緒に New York dentist というのに行って貰い、ゴブランにあることを知り（支店）、モンパルナスまで一緒に来た。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ待ちかねて居て、自動車へのりゴブランへ行った。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカンヂナヴィアの物靜かな風物、古い館、夭折した少女インゲボルク、奇妙な二三の插話、母の死、謎のやうなアベロオネ……　この手記の第一部は、かかる失意の人マルテが昔の人間のした立派な仕事、或博物館で見出した數枚のゴブラン織への讚歎によつて終る。",
              "citation": {
                "source": "「マルテの手記」",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二部はただちにそのゴブラン織を熱心に見てゐる少女達の上に開かれる。",
              "citation": {
                "source": "「マルテの手記」",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとよりゴブランではないが、大層もない外国輸入の絨毯がその十畳の間に敷きつめてあった。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯は、コイペルのゴブランにして、西洋の香水は慎しんで、沈香の心材に筏を彫った帯止だけにしておく。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "デッサンはちがうけど、帯はマアベルのゴブランで、帯止は沈香の花鏡の透彫りというのは、いったいどういうことなんでしょう……へんだわどころの話ですか。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家の欄干に敷き連ねた緋毛氈の古びた色と山鉾の柄に懸けたゴブラン織の模樣とは今も猶目に殘つてゐる。",
              "citation": {
                "source": "十年振",
                "author": "一名京都紀行",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴブランの幕下りている。",
              "citation": {
                "source": "チチアンの死",
                "author": "ホーフマンスタール　Hugo von Hofmannsthal",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴブランの幕あがり、舞台現じ来る。",
              "citation": {
                "source": "チチアンの死",
                "author": "ホーフマンスタール　Hugo von Hofmannsthal",
                "note": "青空文庫"
              }
            },
            {
              "text": "パホエホエとアアとが、いろいろな色に入り乱れ、粗いタッチの多彩なゴブラン織をくりひろげている。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、中欧の古城に秘められた、ゴブランの壁掛けを連想させる景色であった。",
              "citation": {
                "source": "ツンドラへの旅",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬宮附属の博物館に保管してあったロマノフ家の宝物のうち、大カザリン女帝の王冠の柘榴石とイワン雷帝の王冠の真珠とアレクサンダア二世の王冠の青ダイヤと、そのほか壁掛のゴブランなどが、いつの間にか模造品と上手にすりかえられているのを式部次官のトルストイ伯爵が発見し、専門家の確認書を添えて父に報告しました。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに似た景色を前に見たような気がちょっとしたが、それは錯覚であって、この景観の記憶は、ヨーロッパの古城に秘められた古いゴブラン織の思い出である。",
              "citation": {
                "source": "海底の散歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
