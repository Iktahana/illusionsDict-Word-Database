    "definitions": [
      {
        "index": 1,
        "gloss": "I'm sorry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「君ちやん（僕の名、実は君介、どうもブラ公みたいな名ですよ）どうも遅くなつて御免よ、富田の奥さんがいろんな話をしなさるから、あとからあとから話しなさるから。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『だから謝罪た、へん其樣な横柄な言草があるけえ、蹈みましたから、御免下さいましと云ふもんだ。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免なさい」と云ってそれを修正する。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免下さいお嬢さん。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ御免なせえ」　「いらっしゃいまし」　とお静。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "御貸元、さ、どうかお上んなすっておくんなせえ」　「じゃ御免なすってお呉んなせえ」　ふと次郎長の傷に気が付いた石松、　「そうだ、傷の手当をしなくっちゃならねェ……父っつあん傷薬は何処に有ったっけ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃいませ」　「御免なすって……石松つあんのお宅はこちらで御座いますか」　「あの……兄さん今一寸留守なんですけど」　「へえ儂は駿河の清水港の次郎長の身内、大瀬半五郎と申します」　「お父っつあん、お父っつあん」　とお静、奥へ呼ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "へえ御免なすって……」　と出て行かんとした半五郎、何かを思い出したか、引っ返して源兵衛の顔をしげしげと見る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、　「間違ったら御免なせえまし。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ帰ってねえ」　「隠してるんじゃあるめえな」　「いや、本当に居ねえらしい」　吉兵衛、源兵衛に、　「帰って来たら、是非一度俺の家へ遊びに来る様に言って貰い度え」　「はい、承知致しました」　「じゃ爺っつあん、御免なせえ」　「御免下さいまし……」　吉兵衛、一同、共に去って行く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に源兵衛親娘が、　「兄さん、帰って来るのね」　「帰って来るなら来るで、手紙の一本位出しときァいいのに、気の利かねえ奴だ」　その時、　旅人が一人通り掛かって、　「御免なせえまし。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ御免なせえまし」　「御苦労様で御座いました」　旅人、去る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が、「旦那Ｔ「神信心って奴もやって見るとまんざら悪かァ御座んせんね」　と言って「急ぎやすから御免なせえ」と其の儘スタスタと去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ御免なせえ旦那」　と勝坊の手を引いて去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人鵜飼三四郎、御免と一言謝罪してすたすたと去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "入れ違いに今度は二ツ目左膳と、おさらばお小夜御免と内へ入る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔見合せて、「何と面白い事じゃ喃」と言って居る時、一人の浪人者がドンッと団九郎に突き当って御免、と其儘立ち去る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様が嬉しそうに、Ｔ「女の仇討は　珍しいぞ」　老臣がイヤイヤ、Ｔ「御免蒙ります」　断わられて、お殿様、悲観した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）本当に御免なさいよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと御免なさいよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、も一度、××の生活を繰りかえせと云われたら、私は、真平御免を蒙る。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そことは君が号外を前へ置いてひどくがっかりしているところだ」「それはいけない、そんな気のきかないところは御免をこうむる。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は先づ押ずしなるものを一つ摘んで見たが酢が利き過ぎてとても喰へぬのでお止めにして更に辨當の一｜隅に箸を着けて見たがポロ／＼飯で病人に大毒と悟り、これも御免を被り、元來小食の自分、別に苦にもならず總てを義母にお任して茶ばかり飮んで内心一の悔を懷きながら老人夫婦をそれとなく觀察して居た。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『御免、御免、最早飽き／＼した。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、これで御免を蒙ります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免くださいまし」　半七は何げなく挨拶すると、女は黙って鷹揚に会釈した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免くださりませ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度ごとに、ヘルンはまた『ごめん、ごめん』などと言って笑いふざけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれももう私は、ごめんです）あなたも作家、私も作家、けれども今まで一度も逢った事は無し、またお互いにその作品を一度も読んだ事のない者どうしが、ふっとした事で、こうして長い手紙を交換する。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、こんどの世話はごめんこうむる。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
