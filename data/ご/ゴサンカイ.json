        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "またある時は若い婦人に扮装して午餐会に現われ、父の隣席に坐って一座を驚かせた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ときパナマに駐在してゐるフランスの領事が、ルッセの部下の機械技師に服を買つてとゞけてやり、あすそれを着て午餐会に出てお出でとつたへたところ、技師はその日の中に黄色熱にかゝり、朝の三時にはもう死んでゐたといふ哀話ものこつてゐます。",
              "citation": {
                "source": "パナマ運河を開いた話",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折サアゼントは或る知合の午餐会に招ばれて往つて、ひどく自分を崇拝してゐる一人の娘に出会つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでチチコフは副知事の家の夜会に出席したり、徴税代弁人の家の大午餐会に出たり、検事の家のささやかな、とはいえ金のかかった午餐に招かれたり、市長の催しにかかる、これも殆んど午餐に等しいようなお茶の会によばれたりした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二章　旅の紳士は、もう一週間以上もこの市に逗留して、夜会だの午餐会だのといって方々へ出歩きながら、まあいわば、面白おかしく時を過ごした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、貧民救済のために慈善団体の設立をもくろみ、相当巨額の金を集めると、さっそく我々はこうした美挙を記念するために、市の高位高官連を残らず午餐会に招待する、無論それで集めた拠金の大半は費えてしまい、残りの半分では、取りあえず委員会用に、暖房装置と守衛のついた堂々たる家を借りる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い支那学校で行われた午餐会には、床の間に三個の大きな花のかたまり、つまり花毬の高さ四、五フィートのものがあった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから午餐会があつた。",
              "citation": {
                "source": "板ばさみ",
                "author": "オイゲン・チリコフ　Evgenii Nikolaevich Chirikov",
                "note": "青空文庫"
              }
            },
            {
              "text": "我国では儀式とか祭とか葬とか云へば、午餐会がなくてはならないからである。",
              "citation": {
                "source": "板ばさみ",
                "author": "オイゲン・チリコフ　Evgenii Nikolaevich Chirikov",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月七日（月曜）　十一時すぎに起き、すぐ支度し、電気倶楽部の午餐会へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十一日（水曜）　十一時半に迎へが来り、有恒倶楽部の午餐会へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "林冲、王倫を面罵して午餐会に刺し殺すこと　ここに一軒の偽茶店を構えて、多年、梁山泊の渡口を見張っている旱地忽律の朱貴だったが、まだかつて今日までには、こんな堂々たるお客様を、お迎え申したことはない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうでしょう、この午餐会は」「何事か、起らずにいまいな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて酒もめぐり、談笑にわき、午餐会もようやく酣と見えてきた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
