          "literary": [
            {
              "text": "「こんなさ、めんどうなことやってバレたら、ゴミ捨て場に放り出しとくよりヤバいんじゃねえの。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いやいや、匂いと言えば、その穴の中のゴミ捨て場のような臭いだけで、それ以外には無い。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はほとほと嫌気が差したので、カーネーションを引っこ抜いてゴミ捨て場に捨てた。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんで声もしない飢餓の群は、橋の下にも、浅草寺の裏にも、ゴミ捨て場のように、蠅をかぶっていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
