    "definitions": [
      {
        "index": 1,
        "gloss": "purveyor (to the government or Imperial Household)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本が出兵していたころ、御用商人に早変りして、内地なら三円の石油を一と鑵十二円で売りつけた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "目かくしをされた馬は、鼻から蒸気を吐き出しながら、おとなしく、御用商人が出てくるのを待っていた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　親爺のペーターは、御用商人の話に容易に応じようとはしなかった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用商人は頬から顎にかけて、一面に髯を持っていた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用商人は、彼をだましたのだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新前には多くの土蔵を建て列ね、数頭の馬車を貯えて、江戸の諸大名の御用商人を勤めて居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ署の玄関の石段を、固い姿勢で豹吉は登って行った――と、作者は書いたが、たしかに警察署の玄関へはいって行くことは、署員か御用商人か、新聞記者か、それとも警察の関係者以外にとっては、何か薄気味悪いものである。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山城屋宗右衛門のその一瞥で、屋敷の隅々までも見透すほどの鋭い眼光は、彼が江戸諸大名の御用商人として、一代に巨万の富をかち得た偉れた彼の商魂によつて磨き出されたものである。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして江戸の或る御用商人の小僧にやられた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの創立者は天秤棒のさかな屋からわが國有數の御用商人になつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用商人の校主は早くから望んでゐる男爵をまだ貰へない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来実業界の先輩と威張つてる奴らは昔からの素町人か、成上りの大山師か、濡手で粟の御用商人か、役人の古手の天下つたのか、斯ういふ連中のお揃ひだから真の文明流のビジ子スを知つてる者は無い。",
              "citation": {
                "source": "青年実業家",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "先輩の対手にならないのは仕方が無いが後継者の若い者までが株屋や御用商人の真似をしたがるから困る。",
              "citation": {
                "source": "青年実業家",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤というはその頃京橋十人衆といわれた幕府の勢力ある御用商人の一人で、家柄も宜かったし、資産も持っていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ蔵前の札差で山長と云えば、今で云うと、政府の御用商人で二三百万円の財産を擁しておろうと云う、錚々たる実業家に当る位置ですから、その一人娘の――尤も男の子は二人あったそうです。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神妙に申し立てぬと、生きのいい啖呵が飛んでいくぞッ」「それならばこちらでいうこと、かりにも加賀｜大納言さまお声がかりの御用商人でござんす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用学者に御用歴史家、御用商人に御用達、御用御用と呼びかける捕り手の奴ばらときたひにはとても悪趣味で鼻持ちがならない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "云って見れば民主的な国民の完全に独立独歩の企業が比較的貧弱であり、それが官営乃至御用商人的な企業の比でないという日本の経済的条件の下では、統制経済も多くの摩擦に拘らず割合円滑に行くということが注意に値いする。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋向うの大學の御用商人とかいふ男が醉拂つて細君を呶鳴る聲、器物を投げつける烈しい物音がひとしきり高かつた。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしの祖母は連合いが呉服の御用商人であり、兄がやはり絹呉服の御用商であった関係か、大丸とはゆかりがありげであった。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最近に及んで遅れ馳せに暴利取締令を出したり、全国にわたって十｜石以上の貯蔵米を申告させたり、御用商人に托して外米の輸入を計ったりしたような事が、かえって一層米価の暴騰を激成する結果となりました。",
              "citation": {
                "source": "食糧騒動について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出入りをする御用商人もなければ訪ねる客もなかった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支倉事件よりずっと後に、某省の官吏だった山田健と云う男が御用商人を野球用のバットで撲り殺した事件は読者諸君の記憶に尚新なる所だろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この松尾屋は今でいう御用商人で、奉行辺の権門にはよく出入して利を得ていた者である。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある有名な御用商人の店へ、番頭格に通っている田宮は、お蓮が牧野に囲われるのについても、いろいろ世話をしてくれた人物だった。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "辞職の許可が出さえすれば、田宮が今使われている、ある名高い御用商人が、すぐに高給で抱えてくれる、――何でもそう云う話だった。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀家百万石の御用商人、加賀屋と云って大金持、その主人を源右衛門と云ったが、その息子の源三郎なのであった。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の側の向うに、土木請負師か御用商人かと思われる、三人の男が居た。",
              "citation": {
                "source": "轢死人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな騒ぎのあと四五日すると、いつも町から、近くの軍隊へ野菜類を納める御用商人の一人が荷馬車を持つてやつて来た。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
