        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから勉強的埃払い。",
              "citation": {
                "source": "女客一週間",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は神経衰弱にならぬときめているから、それにはかからないが、知らず知らずの間に不自然な緊張があって、自分の勉強的仕事をやってゆくにも、おのずからたのしむ風のゆとりが欠けて極めて微妙な焦立ちが底に流れていた。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
