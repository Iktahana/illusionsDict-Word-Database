    "definitions": [
      {
        "index": 1,
        "gloss": "falling asleep in one's clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私たちはその夜は、上野駅の改札口の前にごろ寝をした。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたの朝の始発が出るまで、ごろ寝させて下さい。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　左手の脚柱の暗い投影の中に、濃い鼠の潮じみ雨じみた角錐形の天幕が一つ、その中に、これも鼠の頭巾附きの汚れ破れた雨外套をかぶって、誰やらごろ寝していた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝床のむしろを探ってみると、煖炉は丁度いい加減に暖まっているので、堀部君は靴をぬいで寝床へ上がって毛織りの膝掛けを着てごろ寝をしてしまった。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山小屋といっても、山の崖に斜めに丸太を横に立てかけ、その上を蓆や杉葉でおおうた下に板を敷いて、めいめいに毛布にくるまってごろごろ寝るのである。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は、毛布も何も一切掛けずに、ただ寝巻を着たままでベッドの上にごろ寝をしているのだが、慣れると清潔な感じがして来て、かえって気持がいい。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鍔作りの名人は戸を閉て切った仕事場のなかで、相も変らず酒に酔っぱらってごろ寝をしていた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺では寝巻を貸してやろうと云ったのを断わって、彼はゆうべからごろ寝をしていたので、そのまま這い起きて羽織をかさねた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大広間の三分の一は炊事場で、残りの三分の二の板の間に筵を敷き、漁夫たちはその上にごろ寝をするのだった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "数多の下女下男があるなかに、稲子沢の寝手間取りとて、年中ごろごろ寝てばかりいて食っている手合いも多かった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごろ寝して読みちらす、まさに安楽国である。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚を鋤焼して飲む、ごろ寝したのは三時を過ぎてゐたらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒好きな車夫も来て、台所の方によくごろ寝をしていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地の汚い浅山も酔い潰れて、次の室に衆と一緒にごろ寝をすることになった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの書生たちは、自分たちは一日ごろごろ寝転んでいて、この体の不自由な老人を不断に使いやがってしようがない。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この人到頭寝てしまったよ」　寒さ凌ぎに今までちびちび飲んでいた小野田が、いつの間にかそこに体を縮めて、ごろ寝をしはじめていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから白基竜君、君は停車場の待合室へ行って、腰掛けにごろ寝している連中のなかに安重根がいないか見て来てくれたまえ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつぱり、川棚の湯は私を最もよく落ちつかせてくれる、昨日、学校の廊下で藤椅子の上の昼寝もよかつたが、今日の、自分の寝床でのごろ寝もよかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　九月八日酔中、炊いたり煮たり、飲んだり食べたりして、それを片付けて、そのまゝごろ寝したと見える、毛布一枚にすべてを任しきつた自分を見出した。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "戻つて寝てゐたら、敬坊ひよろりと御入来、例の如くいつしよにごろ寝、まあ／＼この程度の脱線ならよか／＼。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿の花、お燗ができました酒がどつさりある椿の花　四月六日ごろ寝から覚めて、あれやこれやと忙しい（私の貧しい寝床は大前さんに提供したから）、冬村君が手伝つてくれる、樹明君もやつてくる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "積荷のあてがなくごろごろ寝転んでいた彼等にとって、それはもって来いの慰みだったのだ。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日｜方々歩いて、やがてやわらかな草の生えている所へ来ますと、みんなは足を出してそこへごろごろ寝ころびました。",
              "citation": {
                "source": "金太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨に濡れようと、泥水がはねかからうと、どす黒く足跡のついた畳の上へ、そのままごろ寝しても、まるで気に病まなくなるのだ。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともただ、下台所のペチカの側で、毛皮外套をかぶってごろ寝をした、ポカポカと暖かい古巣にもお別れなら、都会風の柔らかい肉饅頭を添えた玉菜汁に舌鼓を打つのも今日限りで、明日からはまた、雨や泥濘や、あらゆる道中の労苦を忍びつつ、旅をつづけて行かねばならないというような時だろうか？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダニーロと妻とは腰掛の上に、老婢は寝棚に眠り、揺籃の中ではいたいけな幼子がすやすやと寝息をたて、床の上にはつはものどもが押しならんでごろ寝をしてゐる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡さんで泊めて下すつたンですが、蒲団がないンで、夜ぢゆう炬燵のごろ寝で、奥さんにも、えらい御厄介をかけてしまひました」　おせいの亭主はさう云つて、ゆき子の立ち場が初めて判つたらしく、少々｜馴々しいぞんざいさで、亭主は暗い小舎のなかへ上り込んで来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "清さんは囲炉裏のはたにごろねをしていた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒巻と彼女はさっそく根岸の自宅へ戻って、用が一先ず片づいたので、酒をのみ、五時ごろねむった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は無いので、雪をとかして炊事をし、夜は六疊の間に八人くらいの割合でごろねをした。",
              "citation": {
                "source": "冬ごもり",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
