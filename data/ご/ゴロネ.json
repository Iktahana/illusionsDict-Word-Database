[
  {
    "uuid": "5c03c89c-1359-5ef9-868d-b599052d0958",
    "entry": "ごろ寝",
    "reading": {
      "primary": "ごろね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
