[
  {
    "uuid": "3554d4be-66f5-5c71-81c7-c12f57af4eac",
    "entry": "誤認",
    "reading": {
      "primary": "ごにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
