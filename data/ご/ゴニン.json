    },
    "definitions": [
      {
        "index": 1,
        "gloss": "misrecognition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "即ち、彼は刹那が個人精神中で考へ得らることであつて、生活といふ対人圏に流用されるすべてのものは、必竟「規約」以外の何物でもないことを誤認しはしなかつたか？",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな現象があるいは光り物と誤認されることがないとも限らない。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしていっそう難儀なことはその根本的な無知を自覚しないでほんとうはわからないことをわかったつもりになったりあるいは第二次以下の末梢的因子を第一次の因子と誤認したりして途方もない間違った施設方策をもって世の中に横車を押そうとするもののあることである。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に黒猫は充分に猫なることを表示しつつ旅行するに非れば、応々｜黒狐と誤認せられ、本気にて追跡さるることあり。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮の縁側の端居に、たまたま眼前を過ぎる一匹の蚊が、大空を快翔する大鵬と誤認されると同様な錯覚がはたらくのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "視像の場合でももちろん錯覚によって甲のものを乙と誤認することは可能である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤認があるかも知れない。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日パンの会を社会主義の会と誤認して刑事が二人来たといふ噂も立つて、今でも皆本当だと考へてゐる。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "取材でお世話になった方々に原稿を送り、事実の誤認がないか確認をお願いすると共に、批判を求めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "有体にいえば、妾は幼時の男装を恥じて以来、天の女性に賜わりし特色をもて些かなりとも世に尽さん考えなりしに、図らずも殺風景の事件に与したればこそ、かかる誤認をも招きたるならめ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フ氏の言いぶり古エジプトの竜も、単に大蛇にほかならぬようだが、日神の敵アポピは、時に大蛇、時にが同長の蛇を嚥んだところを、著者が殺し腹を剖くと、蛇なお活きいたとあるし、十六世紀にベスベキウス、かつて蛇が蝦蟆を呑み掛けたところを二足ある奇蛇と誤認したと自筆した（『土耳其紀行』一七四四年版、一二〇頁）。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟うに北陸の猩々は海狗を誤認したのだろう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツンツルテンでよかったな」「交通安全じゃあるまいし、そんなの穿いてたら、一キロさきからだって見つかるね」　ツンツルテンという事実誤認に対する反論は放棄し、慶一は高志のオレンジ色のトランクスをねめつける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして百年以後にはじめて名を得たる蕪村はその俳句において全く誤認せられたり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その用語の概略を言わんに（一）漢語　は蕪村の喜んで用いたるものにして、あるいは漢語多きをもって蕪村の唯一の特色と誤認せらるるに至る。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "青々の句はしっかりして居って或点で縦横自在であるが、時としてあまり自己の好む処に偏してへんてこな句を選みどうかすると極めて初心なる句を誤認して、極めて老成なる句となすような事がないでもない。",
              "citation": {
                "source": "病牀苦語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鳴り音をモルヒネの作用によって、人工心臓から生じた安楽の世界として誤認させられたに過ぎませんでした。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだとすると三人の同志たちは何によって同伴者的作家であるということを念頭においてのそのなぐりつけがやられるかのように誤認したのであろう。",
              "citation": {
                "source": "前進のために",
                "author": "――決議によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ明に金錢本來の性質を遺却し、手段を以て目的と誤認したるものなるを以て、道徳上の痴人たるを免れざるべし。",
              "citation": {
                "source": "美的生活を論ず",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者講究の粗漏よりして、あるいは諸論派の本旨を誤認せしものなきにあらざるべし。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この関係の誤認がイギリス経験論の、特にベーコンの大なる制限をなしている。",
              "citation": {
                "source": "科学批判の課題",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達がかりそめにも恐怖とか暗さを感じることがあるとしても、それは、先方が誤った観念からどういうことをしでかすかも知れないという先方の誤認する思想の程度を洞察してのことに過ぎないのです。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に団十郎の如きは、此策略を小生なりと誤認して、交際上の、幾分冷やかになり、大いに迷惑せし事ありたり。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども理窟の上に美のあるべき道理なければ、その美と認めたるは真の美に非ずして、知識の上より生ずる一種の快感を美と誤認せしなり。",
              "citation": {
                "source": "俳句の初歩",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして百年以後に始めて名を得たる蕪村はその俳句において全く誤認せられたり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その用語の概略を言はんに（一）漢語　は蕪村の喜んで用ゐたる者にして、あるいは漢語多きを以て蕪村の唯一の特色と誤認せらるるに至る。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯芝居の性格描写と言ふことが、そんなものであつて、ある通有性を詳細巧緻に描くことに了つて、到達した性格ならざるものを性格だと誤認することがあり、之に批評家・同業優人その他識者の「見巧者」が煩ひして、技巧万能に傾くことを言ひたがつてゐるのだ。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、この手を抜く手法から来る散文に近い印象を、或は一種の兆しと誤認して居るのではあるまいか、と案じている。",
              "citation": {
                "source": "歌の円寂する時",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此語は、馬などにも言ふ口強と言ふ語の、謂はゞ、連体法のくちごはいが、くちごはい事など言ふ接続を忘れて、な（＜なる）を落す上方修飾語の常習と誤認して、名詞と思うたのである。",
              "citation": {
                "source": "方言",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその頃盛んに山に草採りに行ったが、かす谷という所で面白い繖形科の植物が水際にあるのを見付けて零余子が茎へ出ていたので、それを採って帰り、「むかごにんじん」であることを知った。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
