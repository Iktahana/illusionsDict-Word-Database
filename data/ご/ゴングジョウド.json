          "literary": [
            {
              "text": "上人様、かような悪人でも、欣求浄土を望めるものなのでしょうか？",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、側の壁には、「三尊来迎便りあり、九品往生疑なし」ともかかれていて、今更に父が最後の時まで、欣求浄土の念を捨てなかったことも知った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "死後の幸福を祈る、いわゆる欣求浄土の思想で、貴族宗教の代表的なものといってよい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
