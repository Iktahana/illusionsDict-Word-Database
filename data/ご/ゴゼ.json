[
  {
    "uuid": "12e39fce-e4f3-5e77-84d4-27a5fed17999",
    "entry": "瞽女",
    "reading": {
      "primary": "ごぜ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
