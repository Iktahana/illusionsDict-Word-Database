      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "blind female beggar who sings or plays shamisen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "村の或家さ瞽女がとまったから聴きにゆかないか、祭文がきたから聴きに行こうのと近所の女共が誘うても、民子は何とか断りを云うて決して家を出ない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "気にかけないものだというと、瞽女が背負った三味線箱、たといお前が藁づつみの短刀を、引抱えて歩行いた処で、誰も目をつけはしないもんだが。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "孩児の頃より既に音律を好み、三歳、痘を病んで全く失明するに及び、いよいよ琴に対する盲執を深め、九歳に至りて隣村の瞽女お菊にねだって正式の琴三味線の修練を開始し、十一歳、早くも近隣に師と為すべき者無きに至った。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピイと吹けば瞽女さあね。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古祠、瞽女　ペスツムは宿るべき家もなく、こゝよりかしこへの道は賊などの出沒することもありと聞えければ、翌日まだ暗きに一行は車に上りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞽女はいづち往きけん見えず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒店に歸り着きし後は、瞽女は影だに見えざりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ若し再び瞽女に逢はば唯だ地上に跪いてこれに謝せん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は心に今一度瞽女を見んことを願ひしが、人に問ふことを憚りたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは彼女主人の美かりしをおもひ出で、又彼｜海神祠の畔なる瞽女の美しかりしをおもひ出でしが、その背後には心と身と皆美しかりしアヌンチヤタ」は底本では「アンヌチヤタ」］ありて、その一たび點したる火は今も猶我身を焦せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟中の女子は彼ペスツム古祠の畔なる瞽女なりしなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼洞窟は今カプリ島の第一勝、否伊太利國の第一勝たる琅※洞（グロツタ、アツウラ）にして、舟中の少女も亦實にかのペスツムの瞽女ララなりしなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "是日海原はいと靜にして、又我をして洞窟と瞽女との夢を想はしむ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の酒屋へ瞽女を留めた夜の話だ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞽女の唄が済んでからは省作の噂で持ち切った。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山五丁目六丁目は百人町の武家屋敷で、かの瞽女節でおなじみの「ところ青山百人町に、鈴木｜主水という侍」はここに住んでいたらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "村落の者は段々に瞽女の泊つた小店の近くへ集まつて戸口に近く立つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞽女は各自に晩餐を求めて去つた後であつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞽女は村落から村落の「まち」を渡つて歩いて毎年泊めて貰ふ宿に就てそれから村落中を戸毎に唄うて歩く間に、處々で一人分づゝの晩餐の馳走を承諾して貰つて置く。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "小店の座敷には瞽女の大きな荷物と袋へ入れた三味線とが置いてあつて淋しく見えて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女はかなりの婆さんであつたので、白粉つけた瞽女等に向つて揶揄ふ樣な言辭は彼等の間には發せられなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐を濟まして瞽女が手を曳き連れて來た處なのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞽女は危險相にして漸く座敷へ上つた時「目も見えねえのにさうだに押廻すなえ」瞽女の後に跟いて座敷の端まで割込んで來た近所の爺さんさんがいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い手拭を髷の後が少し現はれた瞽女被りにして居る瞽女が殖えたので座敷は俄に生たやうに成つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞽女は一つに固まつて成るべくランプの明るい光を避けようとして居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の態度を心憎く思ふ若い衆が「俺ら其の手拭被つてこつち向いてる姐樣こと寄せて見てえもんだな」立ち塞がつた陰から瞽女の一人へ揶揄つていつたものがある。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして座敷の隅に居た瞽女が代つて三味線の袋をすつと扱きおろした時巫女は荷物の箱を脊負つて自分の泊つた宿へ歸つて行つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物が図抜けて大きい時は一口に瞽女の荷物のようだといわれて居る其紺の大風呂敷を胸に結んで居る。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じいさん、ごぜんじゃでえ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごぜんなんておかしい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
