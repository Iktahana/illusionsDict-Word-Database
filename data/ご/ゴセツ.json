    "definitions": [
      {
        "index": 1,
        "gloss": "the five festivals (January 7, March 3, May 5, July 7 and September 9)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
