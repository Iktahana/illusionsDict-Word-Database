[
  {
    "uuid": "3db8e2d9-ea48-5eb0-8607-c7572ec1bcd0",
    "entry": "呉服商",
    "reading": {
      "primary": "ごふくしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
