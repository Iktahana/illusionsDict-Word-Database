    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dry-goods dealer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "天気がどんなでも一尺差はやはり一尺差であって、呉服商が一々寒暖計と相談する必要がない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家が呉服商であるから、着物に対する眼もこえていて、柄の好みなども一流であった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷をあとにし、その小都會へ來て、呉服商の二階で獨りして行李をあけた時には、私はもう少しで泣くところであつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなでその温泉場を引きあげ、私たちの世話になつてゐる呉服商へひとまづ落ちつき、それから母と姉と三人で故郷へ向つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中畑さんは、間もなく独立して呉服商を営み、成功して、いまでは五所川原町の名士である。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中畑さんも既に独立して呉服商を営み、月に一度ずつ東京へ仕入れに出て来て、その度毎に私のところへこっそり立ち寄ってくれるのである。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹川町の競呉服商である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は宇都宮の藩士であったが、維新後裁判所の書記を勤め、勇造が生れた時分は小さな呉服商を営んでいた。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学を出たら私に家業の呉服商を継がせる気であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は、大阪町奉行であった大塩後素の甥に当たりまして、京都高倉の御召呉服商長野商店の支配人を永らくいたしておりました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め長女敬が母と共に坐食するに忍びぬといって、媒するもののあるに任せて、猿若町三丁目｜守田座附の茶屋｜三河屋力蔵に嫁し、次で次女｜銓も浅草｜須賀町の呉服商｜桝屋儀兵衛に嫁した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "油町あたりの呉服商の細君であった祖母が、鼠小僧の人柄なぞをどうして知っていたのかと思ったら、そのころ祖母夫婦は、楽屋新道――葺屋町、堺町、などの芝居に近い――の附近に住っていた。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "左まで喜びもしなければ、品物が粗末だと云て苦情も云わず、只難有うございますと云て拝領して、その帰りに屋敷内に国から来て居る亡兄の朋友｜菅沼孫右衛門と云う人の勤番長屋に何か用があって寄た所が、其処に出入りの呉服屋か知らん古着屋か知らん呉服商人が来て何か話をして居る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処が此田舎町の大通で――矢張狭かつた――西洋小間物｜店、葉茶屋、呉服商、絵葉書屋などが並んで居た。",
              "citation": {
                "source": "父の墓",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その四家に命じて、町家の富裕なる者、就中呉服商などより御用金の貸上げを謀らしむる事。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外銀主と称える平田、呉服商の吉沢、三宅、などいうのが出入した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉服商は、朝廷へ参内する時の官服などを命ずる者である。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとは或る呉服商の隠居所だったとかで、石や植込の多い庭にだかれてるしゃれた平家だ。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、京大阪へ呉服商の見習いにでた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉山さんのお話では、当家出入りの呉服商人が身許を保証して頼んだものとか承わっております」「杉山さんとは？",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私の御相談相手の御老女」「出入りの呉服商とは、日本橋の伊勢屋？",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へい、呉服商でございます」「女子に喜ばれる商売だな」「その代り殿方にはいけません」「そう両方いい事はない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、隣室の呉服商を罵ったが、なるほどこれはいかにも怪しく、同じその夜にその千三屋も、どこへ行ったものか行方が知れなかった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば呉服商においては、呉服物を売る場合レーヨンが交っているか否か、レーヨンが入っているとしても、このような場合にはなんでもない、むしろこうした向きの使用にはレーヨンの特色を発揮するものであるとか、一々細々と親切に、お客の身になって説明するというふうであれば、お客も自然とついて来る。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアメリカ式の近代的百貨店によって、一般商人がどれだけ打撃を受けたか、例えば呉服商をその例にとって見ても、東京市内の呉服販売額の約七割は、百貨店に奪われている。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸日本橋の呉服商の隠居だという老人は、榎の下で野だての茶を珍しがり、宿へも呼んでくれたが、どうしてこの稼ぎを思いついたのかと訊いた。",
              "citation": {
                "source": "榎物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引退した呉服商や別荘暮らしの人たちなども、まだこの地を見い出していなかったのである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、私も兄も、まだ部屋住みで、住居は日本橋通三丁目でして、親爺が呉服商を営んで居りましたがね。",
              "citation": {
                "source": "押絵と旅する男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "平包みはただ物を平たく包むだけで、これならば支那からくる呉服商人なども持ってあるいている。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホ、ホ、ホ、ホ、商人といえば餅売りか、そこらの呉服商が、精々みたいに考えているからだよ」　御寮人は、聞き流して、むしろ愛嬌に取っていたが、娘は、堺商人の誇りをもって、一応いって措かなければ気がすまないような容子――　その自慢ばなしに依ると。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
