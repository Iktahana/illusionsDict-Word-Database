    "definitions": [
      {
        "index": 1,
        "gloss": "gondola (boat, esp. in Venice)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "印度の何とか称する貴族で、デッキパッセンジャーとして、アメリカに哲学を研究に行くと云う、青年に貰った、ゴンドラの形と金色を持った、私の足に合わない靴。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンドラもおもしろく、貧しい女も美しく見えます。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの水苔の生えた石段から私はゴンドラに乗った。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには魚が泳いでいて、黒いゴンドラが幽霊のように緑の水の上を走って行きます。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのむかしには、色あざやかなゴンドラの上でタンバリンの音がひびき、婚約の指輪が輝かしい総督の船ブーチントロから海の女王アドリアへ投げこまれたのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に伊太利ヴェニスの芸術家等は、ゴンドラを焼打ちして水市を破壊し、自動車と飛行機の爆音で充填された、幾何学的コンクリートの近代都市を造れと言ってる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは始て「ゴンドラ」といふ小舟を見き。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠水を望めば、燈影長く垂れて、橋を負へる石弓の下に、「ゴンドラ」の舟の箭よりも疾く駛るを見る。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポツジヨは例の「ゴンドラ」の舟にて、フジナまで送らんとて、我と共に立出づれば、ロオザとマリアとは出窓に立ちて、紛※を打振りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし予のゴンドラがサン・マルコ運河の口と向いあっているところまで来た時に、突然、その奥の方から、一人の女の声が、烈しい、発作的な、長く続いた一つの悲鳴となって、夜の静けさを破って聞えた。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ゴンドラの船頭は彼のただ一本の櫂を手から滑らせて、まっ黒な闇の中へ失ってしまい、とうてい取戻す見込みもなかったので、したがって、予らは、ここでは大きい方の水路から小さい水路へと流れている流れの導くままになるのほかはなかった。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ゴンドラは予自身のもののほかには一つも見えなかったけれども、多くの屈強な泳ぎ手が、すでに流れの中にあって、水面でかの宝を捜し求めていたが、その効もなかった。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、面は蒼ざめ手足は硬ばってあの葬式のようなゴンドラに乗って人々の間を漂い下っていった時、騒ぎ立っている人々の眼には妖怪のごとき気味の悪い様子をしているように感ぜられたに違いない。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は想像のできぬほどの興奮で戦き、その眼はゴンドラを捜し求めてしきりにあたりを見廻していた。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は自分のゴンドラに乗ることを彼に勧めずにはいられなかった。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "西暦六世紀にバーガンジー王たりしゴンドランが狩りに疲れて小流の側に睡る。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンドラにでも乗ってみたい心持ちがする。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は高等学校にいる時分ゴンドラという字を覚えた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンドラというと、女といっしょに乗らなければすまないような気がする。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "土なく樹なく草もなく、水と石との間を、黒塗りの胴に、白銀の船首優雅なゴンドラが、今はモーターに客を奪われ、波間に浮き流されて漂っている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の美しさを楽しみたいと、水辺をさ迷い歩いたが、黒いゴンドラは、灯の消えた建物の石壁の間で、ごとごと鳴っているだけだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒塗りの胴に、白銀の船首を飾った華奢なゴンドラは、ベニスの商人の豊かな日を偲ばしめる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると、軒から軒にかかっている橋の下を、舞姫たちが歌いながら、ゴンドラを流して行く。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンドラの形をした紙切りをはさんだ読みかけの本の頁をやたらにバラバラとめくったりして眠るまでの時間の費し方を考える様な様子なんかした。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェニスでは運河と礁湖がすっかり硝子張りになって、市民は一時ゴンドラから解放された――。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが己の館の石階に片足を踏み掛ける時、反対の足に力が入ると、乗つて来たゴンドラの舟がごぼ／＼と揺れた。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の上をすべるゴンドラの舟が、ひまな己達の体をゆすつてくれた。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンドラの舟に身を托して陸に上つた。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度昔のやうに、己は波にゆらいでゐるゴンドラの舟を離れて、水に洗はれて耗つた、君が館の三段の石級を踏んだ。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱い朝日の光が霧を透すので青青とした水が、紫を帯び、其れに前の家家の柱や欄干や旗やゴンドラを繋ぐ杭などが様様の色を映してるのが溜らなく美しい。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
