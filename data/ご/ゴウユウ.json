[
  {
    "uuid": "54be35e3-d982-549c-b2b2-e818b8905ecf",
    "entry": "豪遊",
    "reading": {
      "primary": "ごうゆう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "extravagant spree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だがしかし、彼がもし酒を飮まなかつたら、生涯そんな豪遊をすることも無かつたらう。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに美姫と、美酒と、山海の珍味を並べて、友達を集めて昼夜兼行の豪遊をこころみたために、百万円は瞬く間に無くなって、些なからぬ借財さえ出来た。",
              "citation": {
                "source": "夫人探索",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最上の豪遊は、カフェーにでもはいって、みんなして一本のビイルを飲むことであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月ヶ瀬」へ彼女が現れるのは、大抵夫婦喧嘩をしたときに限るので、あんまり腹が立ちましたよって「月ヶ瀬」で栗ぜんざい一杯とおすましとおはぎ食べてこましたりましてんと、彼女はその安い豪遊をいい触らすのである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "老畸人も亦たむかしの豪遊の夢をや繰り返しけむ、くさめ一つして起き上たれば、冷水に喉を湿るほし、眺めあかぬ玄境にいとま乞して山を降れり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし香以の豪遊は未だ衰えなかった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃新堀に後藤進一と云うものがあって、新堀小僧の綽名を花柳の巷に歌われ、頗豪遊に誇っていた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には新地の妓楼に上つて豪遊をするさうだといふゴシップもあつたが、それが仮令事実であつても悪い感じはしない程に先生の行動は周囲から切り離されたものゝやうに見えたのであつた。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は古井、稲垣両氏と長崎に至る約にてその用意を取り急ぎおりしに、出立の一両日前、重井、葉石、古井の三氏および今回出資せる越中富山の米相場師某ら稲垣と共に新町遊廓に豪遊を試み、妾も図らずその席に招かれぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も考えることであるが、あの兜の小判があれば当分は豪遊をつづけられる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今紀文だと評判せられて、あらゆる豪遊をすることが、新聞の三面に出るようになってからもうだいぶ久しくなる。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の人は煩悶して焼けになって、豪遊をするとなると、きっと強烈な官能的受用を求めて、それに依って意識をぼかしていようとするものである。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪遊の名を一時に擅にしてから、もうだいぶ久しくなるのだから、内証は或はそうなっているかも知れない。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自から稱す、汽車の通ぜざりし頃は、車夫を業とし、東京まで二日半にて走りつき、得たる賃錢を紅樓に一擲して豪遊せしも、すでに一炊の夢に歸しぬ。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画の先生達には大厦高楼を構えたり或は屡々豪遊したりするものもあるから、恁ういう大先生方は別として、高の知れた文人の目腐れ金に課税した処で結局手数損じゃ無かろう乎。",
              "citation": {
                "source": "駆逐されんとする文人",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "跣足で号外を飛んで売つた処で一夜の豪遊の足にならぬヮ。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕は豪遊なんぞしたくない。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速金に換えて懐ろが温まったので、サア繰出せと二人して大豪遊を極めたところが、島田の奴はイツマデもブン流して帰ろうといわんもんだから、とうとう遣い果して復た馬を伴れて戻るというわけサ。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、まだきちんと部費が出ないので、その棚に収まったのは、三人が銘々もちよったじぶんのコレクションだけで、慶一が期待したような「大豪遊」のチャンスは、まだおとずれていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "御貴殿たちが先日品川で豪遊をきはめて居られたのも、おなじく英氣を養ふ爲でござらう。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今夜は一つ、豪遊しようじゃないか」「まあ、あんた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は近来｜斯う云ふ所へ大分頻繁に出はいりをすると見えて、家のものとは、みんな御｜馴染だね」「君の様に金回りが好くないから、さう豪遊も出来ないが、交際だから仕方がないよ」と云つて、平岡は器用な手付をして猪口を口へ着けた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも、それが自己の持つてゐる漁場から、マオカへ引きあげて來た時、例年の通り、負けず劣らずの豪遊を試みてゐたので、その時義雄も渠等と知り合ひになつた仲だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠が燒けを起して豪遊したのは、それが爲めである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その豪遊を肆にして家産を蕩尽したのは、世の知る所である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛軒は酒肆妓館に入つて豪遊した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのＨ楼のみどりの許に、此頃足繁く通って来て豪遊する客があった。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "新富座主の豪遊する、木挽町の待合は、明治顕官の遊ぶところで、当時の待合のおかみ、芸妓たちは、お客の顕官を友達のように思っていたりするので、勘弥とその人たちを結びつかせた。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
