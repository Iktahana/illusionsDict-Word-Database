    "definitions": [
      {
        "index": 1,
        "gloss": "rubber tire (tyre)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
