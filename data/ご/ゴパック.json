        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうして＊ゴパックでまる一年も足の痛えほど、うんと一つ騒ぐことにさ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ゴパック　ウクライナ農民の間に行はれる代表的な舞踏の一種。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いんにや、ゴパックはあんな風にやあ、踊らねえだ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてどうして、ゴパックはあんな風にやあ踊らねえだ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "のうのうと手足を伸ばしたり、＊ゴルリッツアやゴパックを踊るなどといふ訳にいかなかつたのは勿論のこと、頭へ酔がのぼつて、足が自然に手習ひをしはじめても、横になつて休む場所もないといふ始末だつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
