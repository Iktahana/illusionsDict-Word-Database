[
  {
    "uuid": "f663b0b8-3157-5925-ba81-299db6bfb3a1",
    "entry": "午睡",
    "reading": {
      "primary": "ごすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
