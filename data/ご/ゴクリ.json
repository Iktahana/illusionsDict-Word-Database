    "definitions": [
      {
        "index": 1,
        "gloss": "jailer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのユーモアの一つは「錆びついた心」を持つた獄吏の戲畫的な存在である。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際子を思ふ至情からであるのだが、それが富之助には獄吏の笞かと思はれるのであつた。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が投ぜられたる獄室は世の常の獄室とは異なりて、全く我を孤寂に委せり、古代の獄吏も、近世の看守も、我が獄室を守るものにあらず。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は我に対しては獄吏と見ゆれども、或一部の人には天使の如くにあるなり、彼等が人々を折檻する時に、人々は無上の快楽を感ずるなり、我眼曇れるか、彼等の眼｜盲ひたる乎、之を断ずる者は誰ぞ。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分獄吏の中の誰かが、健気な少年連の態度に心を動かして同情していたのであろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十八年十二月十九日大阪警察本署において大阪府警部補　広沢鉄郎　印　かく冗長なる述懐書を獄吏に呈して、廻らぬ筆に仕たり顔したりける当時の振舞のはしたなさよ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　獄吏の真相　妾が在獄中別に悲しと思いし事もなく浮かと日を明かし暮らせしも無理ならず。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、元和の末年に李夷簡という人が蜀の役人を勤めていたとき、蜀の町に住む趙高という男は喧嘩を商売のようにしている暴れ者で、それがために幾たびか獄屋に入れられたが、彼は背中一面に毘沙門天の像を彫っているので、獄吏もその尊像を憚って杖をあてることが出来ない。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて毎度弾ずるごとに大入り故、獄吏に請いて猫を隠し置き、音楽で鼠を集めて夢中になって感心しいる処を掩殺させたとある。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "獄吏のように首斬り台の音丈を音楽だと主張しているのだ。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は算盤責めと云うて、木を以て製し、仰向に歯を並べたる上に、膝をまくりて坐せしめ、膝の上に重量五貫目の角石を三つ積み重ね、側より獄吏手を以て之を揺り動かす。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸く獄吏に引立てられて獄に帰り、案外なる無法の処置に呆れたり。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "官が給与の鼠紙を台に、自ら携へたる白紙を撚りて文字となし、麦飯の糊もて、歌など張り付け、余念もなく憂き日を忘れて過ぎけるに、一日、室内点検の獄吏、無断に持ち去りて棄てたりければ、愛惜言はん方なく、こゝにして、死なば、かたみとなぐさめし、我身の影の、行方知らずも。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫妻両人の毎週送り出す櫃は、何時も何時も獄吏どもには何らの興味をも与えない古本や、汚れた衣類ばかりであったので、歳月を経るに従って、これらの検査も次第に緩やかになって、終には櫃の蓋を開くことさえもせずに、これを通過させるようになった。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂレンマよりヂレンマへ、彼の戯曲は忠実な獄吏の如く、一時も心の声に耳を傾けない。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し婦人が小児の無差別な養育を拒むなら、誰れが巡査になり、獄吏になるのか？",
              "citation": {
                "source": "結婚と恋愛",
                "author": "エンマ・ゴルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆にして兵士たり、政治家たり、獄吏たり、死刑執行者たるの意志なくんば、如何にしてかの当局者と私有財産の存在を維持することが出来やう。",
              "citation": {
                "source": "少数と多数",
                "author": "エンマ・ゴルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "全てこれ等の御世話好きと、品行探偵と人間精神の獄吏――この人等はなんと云つてゐるか？",
              "citation": {
                "source": "婦人解放の悲劇",
                "author": "エンマ・ゴルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命裁判、檢察官、ギロテイン、及びその雇人即ち死刑執行人と獄吏とを夢みてゐる。",
              "citation": {
                "source": "革命の研究",
                "author": "ピョートル・アレクセーヴィチ・クロポトキン　Pyotr Alkseevich Kropotkin",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命裁判、検察官、ギロチン、およびその雇人すなわち死刑執行人と獄吏とを夢みている。",
              "citation": {
                "source": "革命の研究",
                "author": "ピョートル・アレクセーヴィッチ・クロポトキン　Pyotr Alekseevich Kropotkin",
                "note": "青空文庫"
              }
            },
            {
              "text": "死刑執行人の獄吏に金を払っているのではないか。",
              "citation": {
                "source": "革命の研究",
                "author": "ピョートル・アレクセーヴィッチ・クロポトキン　Pyotr Alekseevich Kropotkin",
                "note": "青空文庫"
              }
            },
            {
              "text": "一揆の時、兵隊の銃口の前に胸を曝して真先きに進んで行ったスペイン婦人を、諸君が讃美していることを知っている、社会主義の被告人を獄中で虐待した残忍な獄吏の胸をピストルで撃ち貫いた一婦人の名を、尊敬をもって語っているのを知っている。",
              "citation": {
                "source": "青年に訴う",
                "author": "AUX JEUNES GENS",
                "note": "青空文庫"
              }
            },
            {
              "text": "今春獄吏に導かれて、かれを巣鴨の病床に訪ひしは、舊知相見るの最後にてありき、かれ學あり、才あり、西の國の言葉にも通じ、宗教の旨をも味はひ知り、おほかたの藝能にもつたなからず、人にも侮られまじき程の品かたちは持てりしに、其半生を思ひやれば實に慘苦と落魄との連鎖とも言ふべかりき。",
              "citation": {
                "source": "藤村詩抄",
                "author": "島崎藤村自選",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼らはただ屠者であったばかりでなくまた実に死刑を執行する獄吏であった。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "興福寺の五箇所・十座の唱門は、非人中の番非人の如く、寺の所属として雑役に従事する以外に、猿楽以下、渡り神子・渡り遊女・鉦打・猿引等七道の者を進退し、また警察獄吏の事務をも執行し、土木工事にも役せられ、戦時には陣夫にも用いられていた。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを収容して下級の警吏獄吏に使役する事は、いわゆる機宜に適した所為であったに相違ない。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンの監獄の囚人が獄吏と戦闘をし、弾丸を籠めた喇叭銃★が尊厳なる法律によって囚人たちの中へ撃ち込まれたこともあった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の門前には先ず見るも汚らしく雨に曝らされた獄吏の屋敷の板塀が長くつづいて、それから例の恐しい土手はいつも狭い往来中を日蔭にして、なおその上に鼬さえも潜れぬような茨の垣が鋭い棘を広げています。",
              "citation": {
                "source": "監獄署の裏",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は以前二百十日の頃には折々立続くこの獄吏の家の板塀が暴風で吹倒される。",
              "citation": {
                "source": "監獄署の裏",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして蠍は十分ばかりごくりごくりと水を呑みました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
