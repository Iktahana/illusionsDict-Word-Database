[
  {
    "uuid": "6f369861-de19-5c38-b29b-d26d3ac923d0",
    "entry": "ご飯",
    "reading": {
      "primary": "ごはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cooked rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ご飯ができたからおんちゃんを呼んでおいでと彼らの母がいうらしかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、三度々々ちゃんとご飯喰べてお呉れと云うに、さ、ほんとに後生だから」　母親はおろおろの声である。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご飯中をどうも失敬しました。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二十「さて、それからご飯の時じゃ、膳には山家の香の物、生姜の漬けたのと、わかめを茹でたの、塩漬の名も知らぬ蕈の味噌汁、いやなかなか人参と干瓢どころではござらぬ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はご飯を仕掛けていたので、ゆるしてもらった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからご飯をやりました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからご飯にしよう、ね」　こどもはこんなにも巴里に馴れて来たのかとあきれたような心嬉しさだった。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやは、長火鉢からは少し離れた、次の間への障子際の、木目の新らしい桑の火鉢に、一ぱい火の盛られてある側で、赤いお箸や赤いお膳や、凡て赤づくしの器で、婆やと一しょに黙ってご飯をたべた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕平は、さっき頬っぺたの光るくらゐご飯を沢山喰べましたので、まったく嬉しがって赤くなって、ふうふう息をつきながら、大きな木鉢へ葡萄のつぶをパチャパチャむしってゐます。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎のおとうさんはだまって玉をホモイに渡してご飯を食べはじめました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイもいつか涙がかわきみんなはまた気持ちよく笑い出しいっしょにご飯をたべてやすみました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは、にわかに気がついたように立ちあがって、　「まあご飯を食べよう。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんはびっくりして、　「まあ、ご飯のしたくを忘れていた。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、だまってご飯をすましました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにちゃあんとご飯を入れる道具さえあったのです。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご飯さえ碌に呉れないんだよ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がヒステリー起こした時は、ご飯かて、たいてくれます。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君、どうして、あんなところへ入ってご飯を食べなければならなかったの？",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は毎晩々々夜更けてから、血の気のない程に蒼ざめて帰って来、私にご飯を食べさせてくれた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　姉は、夜更けてから、血の気の失せた顔をして帰って来て、私にご飯をたべさせてくれた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "張は　十日も　二十日も　ろくろく　ご飯も　たべず　考へましたが、よい　考へは　うかびません。",
              "citation": {
                "source": "驢馬の　びつこ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと悪いことには、番人のゐない水車小屋からよそのお米をかき出してご飯を炊いた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないと一緒にご飯も喰べられないんです」「敵わんね。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は姉の肩越しに、アンディーヴの鉢を覗き込んだが、「鼈四郎さん、それ取っといてね、晩のご飯のとき食べるわ」　そういった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "篤がお腹が減ったってあんまり泣くものですから、ご飯を食べさせていましたので、つい気がつきませんでして、済みません」　いいつつ奥歯と頬の間に挟った嚥み残しのものを、口の奥で仕末している。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、おそい朝ごはんを、気まずい思いで食べた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごはんを食べて、家のちかくの井之頭公園へ散歩に出かけ、行く途々も、議論であります。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、朝ごはんまへに、校正のはうを片附けてしまふつもりで、机にむかつたら、ひよつこり母がたづねて來た。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がかへつて、私は校正にとりかかり、ひるごろまでに濟まして、晩い朝ごはんをたべ、それから、〆切のせまつてゐる小説を少しづつ書きつづけ、そのうちに、しきりと侘びしくなつて來た。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんが、ちびちび晩酌をやつてゐる傍で、默つてごはんを食べてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
