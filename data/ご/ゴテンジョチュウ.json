[
  {
    "uuid": "9e5cb433-8fd3-50f8-a3ee-ebd41ac6dd7b",
    "entry": "御殿女中",
    "reading": {
      "primary": "ごてんじょちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
