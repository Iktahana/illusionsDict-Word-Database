          "literary": [
            {
              "text": "何ぶん古い作品ですのでご了承ください。",
              "citation": {
                "source": "チカモーガ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぶん古い作品ですのでご了承願います。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにとぞご了承下さい。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪奇小説の古典としての歴史的価値から、そのまま訳出したものですのでご了承ください。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史的な価値に鑑み、そのまま訳出しましたのでご了承ください。",
              "citation": {
                "source": "絞首刑",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品には差別に関わる今日では社会的に受け入れられない表現がありますが、時代背景に鑑みそのまま訳出しましたのでご了承ください。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
