    "definitions": [
      {
        "index": 1,
        "gloss": "prison gate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "獄門の晒首や迷子のしるべ、御触れの掲示などにもまたしばしば橋の袂が最もふさわしい地点であると考えられた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お紺は引きまわしの上で、千住で獄門にかけられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は主人の首の晒されている獄門台の下に生きながら埋められて、その首だけを土の上に晒されていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "各位が、我ために刑を撰んで、その最も酷なのは、磔でない、獄門でない、牛裂の極刑でもない。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝家委細の報告を受けて、来春には猿面を獄門に曝すぞと喜んでいたが、こうして秀吉に油断をさせていると思っていた勝家は、逆に秀吉に謀られて居たのである。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死罪は、覚悟しているだろうな」　と、越前が云うと、「御奉行さまのお言葉にそむきました上は、はりつけでも獄門でもどうぞ、御存分に……」　長吉は、面をあげながら云った。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかでも花鳥と新次郎の罪が重く、花鳥は引き廻しの上で獄門、新次郎は死罪となりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "善昌は無論に獄門です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下谷｜通新町の長助という若い大工が例の景品をせしめる料簡で、勇気を振るって木戸をはいって、獄門首のさらされている藪のきわや、骸骨の踊っている木の下や、三途の川や血の池や、それらの難所をともかくも通り越して二筋道の角に出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い薄暗い路を通って、例の獄門首や骸骨を見ながら、二筋道の曲がり角を左に取ってゆくと、どこかで青白い鬼火が燃えているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さん、鈴ヶ森で獄門にかけられて、沖の白帆でも眺めていたいのかえ」「よしてくれ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その罪重々であるというので、お定は引廻しの上で獄門に晒された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島破りの上に人殺しをしたんですから、引き廻しの上で獄門になりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "和泉屋の幾次郎は主人の女房と密通した上に、いろいろの悪事をたくらんだので獄門、女房のお大も死罪になりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして首をちよん切られて、その首は原つぱの獄門にさらされた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の若い馬賊の手下がそつと街に忍びこんだ、丁度街端づれの広つぱにある刑場の獄門の下をなにごころなく通ると。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "獄門の横木の上には探しあぐんだ大将の首は酒のよいきげんで手下を呼びとめた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そこで親分、街の酒場で鱈腹酒をのんでから、さあ俺は馬賊だ斬るなり殺すなり勝手にしろ、と大あぐらを組んだところが、すこぶるかん単でさ、冷たいものがすうと首筋を撫でたと思つたら、首と胴とが泣き別れで獄門の上で寒風に晒されるといふわけですからな。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日また新しい首が殖えたその翌日またひとつ首が殖えた、そしてものゝ十日も経たぬうちに五六十の首が獄門の横木の上にずらりとならんでしまつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の人々は獄門の酔つぱらつた首が毎夜のように合唱を始めて寝つかれないので、なんとかして貰はなければ困ると刑場の兵士に苦情を持ちこんだ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに兵士も獄門にあまり沢山首がならんで、もうひとつの首のせ場所もなくなつてしまつたので、或日馬賊の首をひとまとめにして街端づれの広い草地に、大きな深い穴を掘つて、その墓穴の中に埋めてしまつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の大将の家来が、或る街の処刑場の獄門の下を通りかかるとおい／＼と家来を呼び止るものがありました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと獄門の上を見あげますと、獄門の横木の上に、行衛不明の馬賊の大将の首がのつてゐるではありませんか。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
