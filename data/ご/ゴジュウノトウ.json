    "definitions": [
      {
        "index": 1,
        "gloss": "five-storied pagoda",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
