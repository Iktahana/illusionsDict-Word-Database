        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「どうかごゆっくり。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三兄は、決してそのお仲間に加わらず、知らんふりして自分の席に坐って、凝ったグラスに葡萄酒をひとりで注いで颯っと呑みほし、それから大急ぎでごはんをすまして、ごゆっくり、と真面目にお辞儀して、もう掻き消すように、いなくなってしまいます。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘエ……粗茶で御座いますが一服いかが様で……ドウゾごゆっくり……。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『アハハハハハばかを言ってる、ドラ寝るとしよう、皆さんごゆっくり』と、幸衛門の叔父さん歳よりも早く禿げし頭をなでながら内に入りぬ。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "繋ぎに誰か呼びますから、どうぞごゆっくりなすって。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　箱丁が言うので、小菊も、「どうぞごゆっくり。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銀ちゃんもごゆっくり。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃおれは外を散歩して来るから、ごゆっくり召し上れ」　と云って、裏の方へ出かけました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、ごゆっくり……」　と、やがて貴子は出て行った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はよ閉めて、おはいりやすな」　そして、「――ほな、ごゆっくり……」と遣手が下へ降りると、妓はぼそんと廊下へ来て私の傍へ並んで立つと、袂の中から飴玉を一つ取り出して、黙って私の掌へのせた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞごゆっくりと御参詣遊ばして……。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、ごゆっくり」　マダムも海老原がいるので強いて引き止めはしなかったが、ただ一言、「阿呆？",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうか、かまわないでください、すぐ失礼しますから」「どうかごゆっくりなすってくださいませ、こんな陋い処でございますが」　主人は次の室へ往って茶を持ってきた。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い気もちになった」「まだお酒がすこしありますが、沸かしましょうか」「もうけっこう、わしは一合で多すぎるくらいじゃ」「では、ここへ飯鉢と茶を置きますから、どうぞごゆっくり」　女は艫の方へ引きさがって往った。",
              "citation": {
                "source": "参宮がえり",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、その男の左の袖のカフスの内側と、縫取りしたモーニング・ラッパーの広いほうのポケットのなかにあるはずのいくつかの小さな包みとを、ごゆっくりお調べください」　彼がしゃべっているあいだは、床の上へ針が一本落ちても聞えそうなほど、ひっそりと鎮まりかえっていた。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どなたも、ごゆっくり。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうぞごゆっくり。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごゆっくり御覧なさいまし。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうぞ、ごゆっくり、あなた方のいらっしゃる間に、僕も一度お邪魔いたしたいですね。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごゆっくりどうぞ……」　送り出したあとから、またひとり女の姿が、黒板べいの口をくぐって現われました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごゆっくりどうぞ、と意味ありげにいった声も奇怪です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞごゆっくり……」　言いすてかとみるまに、もう一二間向うでした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
