    "definitions": [
      {
        "index": 1,
        "gloss": "dong (of a bell or gong)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
