    "definitions": [
      {
        "index": 1,
        "gloss": "Golgotha (site of the crucifixion of Jesus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
