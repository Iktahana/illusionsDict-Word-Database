        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その頃｜流行った鍔の広い中折帽を被って縞の着物、縞の羽織、それでゴム靴をはいて折カバンを小脇にかかえている、そうして非常にゆっくり落着いて歩いて来るのである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中折帽に着流しでゴム靴をはいて、そしてひどく考え込んだような風でゆっくり歩いて来る姿をはっきり覚えているように思うのであるが、しかし、これはよくある覚えちがいであるかもしれない。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴム靴によごれた青の靴下か。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "素あしにゴム靴でぴちゃぴちゃ水をわたる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴム靴の底のざりざりの摩擦がはっきり知れる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴム靴の中は、あたたかい。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この頃、ヘロンの方ではゴム靴がはやるね。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら一つお前さん、ゴム靴を一足工夫して呉れないか。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野鼠はいかにも疲れたらしく、目をとろんとして、はぁあとため息をついて、それに何だか大へん憤って出て来ましたが、いきなり小さなゴム靴をカン蛙の前に投げ出しました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもカン蛙は、その立派なゴム靴を見ては、もう嬉しくて嬉しくて、口がむずむず云ふのでした。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、君はもうゴム靴をはいてるね。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもベン蛙とブン蛙とは、雲なんかは見ないでゴム靴ばかり見てゐるのでした。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから苔の上をずんずん通り、幾本もの虫のあるく道を横切って、大粒の雨にうたれゴム靴をピチャピチャ云はせながら、楢の木の下のブン蛙のおうちに来て高く叫びました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあいつのゴム靴がめちゃめちゃになるだらう。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と二疋が両方から、まだ破けないカン蛙のゴム靴を見ながら一緒に云ひました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　実際ゴム靴はもうボロボロになって、カン蛙の足からあちこちにちらばって、無くなりました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふわけは、はじめカン蛙を見たときは、実はゴム靴のほかにはなんにも気を付けませんでしたので、三疋ともはだしでぞろりとならんでゐるのでは実際どうも困ってしまひました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもカン蛙は、その立派なゴム靴を見ては、もう嬉しくて嬉しくて、口がむずむず云うのでした。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもベン蛙とブン蛙とは、雲なんかは見ないでゴム靴ばかり見ているのでした。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから苔の上をずんずん通り、幾本もの虫のあるく道を横切って、大粒の雨にうたれゴム靴をピチャピチャ云わせながら、楢の木の下のブン蛙のおうちに来て高く叫びました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあいつのゴム靴がめちゃめちゃになるだろう。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と二疋が両方から、まだ破けないカン蛙のゴム靴を見ながら、一緒に云いました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは、ゴムぐつを買うようなわけにやいかんでなあ。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、黒いズックのゴムぐつをはいているではありませんか。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
