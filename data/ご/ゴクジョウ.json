        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煙草はたしか「極上国分」と赤字を粗末な木版で刷った紙袋入りの刻煙草であったが、勿論国分で刻んだのではなくて近所の煙草屋できざんだものである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば極上等のダイアモンドや水晶はほとんど透明である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上には、緑や黒の植木の鉢が立派にならび、極上等のパンやバターももう置かれました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウーと歯ぜせりをしながら、「天気は極上、大猟でげすぜ、旦那。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「極上がございます。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに毀れた方はざっとした菫花の模様で、焼も余りよくありませんが、こちらは中は金襴地で外は青華で、工手間もかかっていれば出来もいいし、まあ永楽という中にもこれ等は極上という手だ、とご自分で仰ゃった事さえあるじゃあございませんか。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の家の台所には、極上｜鼈甲製の皿が天井迄高く積上げられている。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉屋は、きょうは極上等の肉をどっさりつるして、お客をまっていました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十枚の極上のマットを並べた上で独り眠る。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一製鋼工場の平炉は今しも、底の方に沈んでいる最極上の鋼鉄の流れを放流しつくして、不純な鉱石混りの、俗に「※」と称するドロドロの火の流れを、工場裏の真暗い広場に惜し気もなく流し捨てている。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最極上のアルコールみたいな宗旨が出来上った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、それは先ず結構としても、その最極上のアルコールをアラキのまま大衆に飲ませようとするからたまらない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナメラが最極上利く』と云う者も居ります。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大きな褌盥に極上井戸水を一パイ張りまして、その中でその赤肝の薄切りを両手で丸めて揉みますと、盥一面に山のごと泡が浮きます。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨肉の中でも極上｜飛切の処で、小鳥や牛肉でも追付かない無上の珍味だったのです」　という結論が附いた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに残つてゐる衣類は、その親子の女の身分としては極上等の衣類だとしなくてはならない。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　首尾は大極上々吉、愛吉堪りかねて、「御、御串戯おっしゃらあ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "數日前支那旅行の歸りがけにわざ／＼其處まで訪ねて來て呉れた地崎喜太郎君が上海からの土産物の極上ウヰスキイを二三杯食前に飮んだのがきいて、まだ膳も下げぬ室内に仰臥してうと／＼と眠りかけてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはある信者の女が、自分の手で織ってよこしたもので、極上等の織物だったからな。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、街へ散歩、極上焼酎を買ふ、とても強烈でヂン以上だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫で一向差支ないぢやないか」「では極上品な例で説明してやらう。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その下に、折々、トレ・コンフォルタブル（極上）とあって、便所付きとか電燈付きとかいう文句のついたのがある。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ、と言って、僕は例の贅沢をならべ立てて、それから極上の白葡萄酒を一本と註文した。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「極上というものではあるまいね」「何処です？",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……極上誂織の白七子をお納戸の紋附に染め、江戸褄模様に翻れ梅、紅白の上絵彩色銀糸にて松葉を散らしに縫わせ……英泉の筆意を頼み、下着は縮緬鼠のさや形、帯は花色勝山に色糸を以て阿蘭陀模様を竪縞の如く縫わせたらば類なくてよかろうか。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店、旅宿などにても、極上等の座敷のたたみは洋服ならでは踏みがたく、洋服着たる人は、後に来りて先ず飲食することをも得つべし。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕上り品は主に極上品のカーテン地として売り出された。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "極上等の緑茶で仕立てる。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "耶蘇の像は、西洋人より見て、人間最上極上の美男として描かれたり。",
              "citation": {
                "source": "鎌倉大仏論",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "マドンナの像も、人間最上極上の美女として描かれたり。",
              "citation": {
                "source": "鎌倉大仏論",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
