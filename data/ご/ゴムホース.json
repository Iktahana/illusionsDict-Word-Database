          "literary": [
            {
              "text": "彼は、ミキサーに引いてあるゴムホースの水で、一と先ず顔や手を洗った。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "長靴ばきの道路人夫が、木の輪のついた長いゴムホースを、角の反宗教書籍出版所の壁についてる水道栓から引っぱって、ザアザア歩道を洗いだした。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方はモルタルの壁で、綰ねたゴムホースや、消火器や油差などが掛かっている。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの潜水夫は、ハヤブサ丸の外がわにとりつけてある、直立の鉄ばしごをおりて、タコのおばけのような丸い頭をふりながら、いのち綱とゴムホースのような送気管と、それにまきついている電話線を引きずるようにして、つめたい水の中へ、はいっていきました。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
