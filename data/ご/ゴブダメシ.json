        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――それでは可哀想にお濱もお安も、一寸試し、五分試しに殺されたやうなもので御座います。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それでは可哀想にお浜もお安も、一寸｜試し、五分試しに殺されたようなものでございます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此上は殿樣、この娘を五分試し一寸試しに斬つてやつて下さい。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "大盜懺悔",
                "note": "青空文庫"
              }
            },
            {
              "text": "娑婆で縛られた囚人どもは、寄ってたかって、世にも恐ろしい方法で、入牢の岡っ引を、一寸試し、五分試しに、いじめ殺してしまうのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "永楽銭の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その生娘のお園が、脂ぎつた丹右衞門の餌になつて、夜となく晝となく毒々しいほどさいなまれ、一寸試し五分試しに玩具にされてゐるのを見て、小半次はすつかり氣が變つてしまつたことだらう」「――」「一度眼がさめると、小半次は若くて血の氣の多い正直者だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "浮世繪の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この上は殿様、この娘を五分試し一寸試しに斬ってやって下さい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大盗懺悔",
                "note": "青空文庫"
              }
            },
            {
              "text": "言はなきア、平次の宗旨にはないことだが、お前の身體を五分試しだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "七人の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「七人の命には替えられない、言わなきゃア、平次の宗旨にはないことだが、お前の身体を五分試しだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "七人の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常人より良い聴官を持っていなければならぬ音楽家が、次第に耳が遠くなりつつあることを発見し、それを承服しなければならないということは、五分試し一寸試しの虐殺に逢うようなものである。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようしッ、あとで一寸｜試し五分試しだぞ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸試し五分試しのすえ、江へ投げこまれたのはぜひもない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
