        "examples": {
          "standard": [
            {
              "text": "「そこに何が御座あるか、燭台の明かりでよく確かめて参れ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古典文学の台詞回しを勉強していると、「〜に御座ある」という気品のある表現によく出会う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「御身の悲しみは、この私も痛いほど分かって御座あるつもりです。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
