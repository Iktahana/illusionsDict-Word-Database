[
  {
    "uuid": "e417771f-bc07-58c2-a6af-392f721d81e7",
    "entry": "ゴング",
    "reading": {
      "primary": "ゴング",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gong (instrument)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゴングが入ったりして、むやみにドラマティックで、マカロニ・ウェスタンの音楽みたいだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日は、みなさまのご熱望により、特に岩竹女史においでをねがいまして、有名なるゴングの心霊をここへよびだしていただき、いろいろとめずらしい実験をお頼みしたいと思います。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞゴングさん。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラッパをとりよせて、吹いてきかせよう」　ゴングさんの声がしたと思うと、闇の空中にラッパの形をしたものが浮きあがった。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱帯の蘭だ」　ゴングの声だ。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まちがいない」　ゴングの声だ。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんどは、にぎやかになる」　ゴングの声に、二つの火の玉に、ラッパに、蘭に小卓子などが、みんなゆらゆらひらひら飛び上り、まい下った。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは今、ゴングの方へ、誰にも知られないように赤外線灯を照らしています。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにが心霊ゴングだ）　と、東助は腹が立った。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この実験会が大成功に終って、ゴングの霊は拍手におくられて消えた。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の銅鑼だ、これから起きて仕度をすると第二の「ゴング」が鳴る。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大公が銀のゴングを打ち鳴らすと、直ちに折り扉が開いて中部屋が現れた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう気分であったから、乗客の待っている停留所を素通りしてしまい、下車する客にどなられた車掌から停車のゴングを鳴らされ、慌てて停車操作をする自分に、いっそうはらを立てる、という結果になるのだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六ちゃんは足を停めて、右足の爪先で地面を叩きながら、がんがんがん、と警告のゴングを鳴らす。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉が先生の耳に伝わるまでに、さして時間はかからなかったし、同時に先生の恋も終りのゴングを鳴らした。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食会のゴングがすぐ鳴りますから、そのときでは遅すぎます。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら冒険になれているといっても、あいてが、あの恐ろしい妖人ゴングです。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞は、この怪物に、「妖人ゴング」という名をつけていました。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴングというのはドラのことです。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのウワン、ウワン、ウワンという声が、まるでドラを、ゴン、ゴンとたたくように聞こえるので、だれいうとなく、妖人ゴングという、怪物にふさわしい名がついたのでした。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいわい、部屋がうす暗いので妖人ゴングは、まだにせものとは気がつきません。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると、ゴングのうしろにいた、ひとりの部下が、ツカツカと、トランクのそばによって、小林君をひき起こすのでした。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ゴングは、そういって、さようならというように、手をふってみせました。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖人ゴングは、一度も、姿をあらわしません。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あのゴングの声です。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とびこんできて、やにわに、どなりつけたのは、あのいやらしい怪物ゴングでした。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ゴングは、いまいましそうに、どなりつけたあとで、あごに手をあてて、ちょっと考えていましたが、なにか決心したらしく、ぶきみに笑って、「ようし、このお礼には、いいことがある。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ゴングが笑うと、どこからともなく、あのぶきみな音が、ウワン、ウワン、ウワン……と、聞こえてくるのでした。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、ゴングのおもいつきとは、いったいどんなことなのでしょう。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖人ゴングの巨大な顔が、俊一君のうちの池の中にあらわれたほどですから、俊一君も、ねえさんのマユミさんと同じように、妖人のために、ねらわれているのかもしれません。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
