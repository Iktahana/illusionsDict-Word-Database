          "literary": [
            {
              "text": "洋服のときはゴルフパンツである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフパンツはいて、葡萄たべながら飛行機に乗っていると、恰好がいいだろうな。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフパンツのようである。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本格的な仕事だつてやらうと思へば帝展や二科の若いやつ等になんて負けやしないんだけどな――一応生活を派手に構へた後でなけりや……」　そして、また、斯んな恰好の洋服をつくつたとか、ゴルフパンツも幾通りあるとか、問屋の娘が惚れて持参金つきで貰つて呉れと、煩いなどと大層な熱を吹いた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いズボンを穿いてゐるのが苦しくてならない、つひに今日よりゴルフパンツを引張り出して半ズボンの姿になる。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "下はゴルフパンツだから、すつかりフェヤウェーに於けるゴルフ姿と思つた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装は薄茶の厚手な背広に、同色のゴルフパンツをはき、靴下も竪縞の同色で、ひどく瀟洒としたものだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフパンツをはいた紳士、村の商人らしい男、百姓などが彼に挨拶する。",
              "citation": {
                "source": "東旭川村にて",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
