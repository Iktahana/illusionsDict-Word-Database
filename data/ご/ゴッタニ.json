[
  {
    "uuid": "52aa0695-abef-51a4-b8dc-2c9bfcd8193b",
    "entry": "ごった煮",
    "reading": {
      "primary": "ごったに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
