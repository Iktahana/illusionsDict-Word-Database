    },
    "definitions": [
      {
        "index": 1,
        "gloss": "various foods cooked together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "読んだ印象としては、詭弁と滑稽のごった煮と言ったところか。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の前には、御飯にごった煮にお新香が運ばれてきた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の前には、御飯にごった煮にお新香、まことに貧しき山海の珍味。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根と悪臭を放つ魚のあら骨とのごった煮。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足のぐらぐらする餉台の上には馬鈴薯と大根とのごった煮と冷たい飯とだけだった。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓の上には韮付焼麺麭が山のように盛られ、囲炉裏の大鍋には、サフランの花を入れた肉と野菜のごった煮が煮えあがって、たまらない匂いを村中に振りまいている。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、小一時間ほどののち、まるで呪文で引き寄せられたもやし豆の兵隊のように、族長を先に立て、総員十六人の村中が、一人残らず『極楽荘』の門の前に集まって来、そこでもじもじと身動きしていたが、ごった煮はいよいよ香ばしく煮えあがる。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして注がれた酒を黙って飲み、ごった煮と韮麺麭を腹一杯に喰べると、われ勝ちに脱兎のように逃げ出した。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉が伝え得るものは、私の心を蝕んだ恐れと当惑のごった煮のほんの一部でしかない。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろそれは漠然とした心理学的な象徴主義と美学的連想に関わる事情なのであり――異国的な詩と絵画、そして忌まれた禁断の書物の中を徘徊する古代の神話が混じり合って生まれた一つのごった煮だったと云う方がいい。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の論説にしても意見にしても、君たちのごった煮にさえも及ばないのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はヴォーケ・ママのごった煮を食べているが、我々はフォーブール・サン・ジェルマンの豪華な晩餐を愛している。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶なことを云われて民子は心配やら嬉しいやら、嬉しいやら心配やら、心配と嬉しいとが胸の中で、ごったになって争うたけれど、とうとう嬉しい方が勝を占めて終った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其損得に掛けて武士道――忠義をごったにし、それはそれ、これはこれと、全く別の事を一ツにして、貴殿の思わくに従えとか。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その柿の皮があかあかと紙くずとごったになって敷き石の上に散っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が正しいと信じた上は、屈辱に堪えて私生子を生もうとした允子の心は、子に対した場合は実に俗人的になって、「真理を愛し真実な生活をいとなむような人間にしたい」ことと、子供に「社会の中枢に立って立派に働いてもらいたい」心持とを、いつの間にやらごったにしている。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何小二が鞍の前輪へつっぷすが早いか、一声高く嘶いて、鼻づらを急に空へ向けると、忽ち敵味方のごったになった中をつきぬけて、満目の高粱畑をまっしぐらに走り出した。",
              "citation": {
                "source": "首が落ちた話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして凡てのことがごったになって、私をまたある硝子店の前へおびき出そうとしていた。",
              "citation": {
                "source": "悪夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の眼には、顔と顔とがごっちゃに重り合い、家と家とがごったになってる、何にも見分けのつかない混乱した世界が、ぼんやりと見えてきた。",
              "citation": {
                "source": "白日夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の言葉の奥には、いろんな感情がごったに乱れていた。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかもごったになってはてしがつかなかった。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "長謙さんの場合は、〈マックァサー将軍〉を植えてうっぷんをはらすという、ユウモラスな思いつきをする余裕があったが、満寿子さんの場合は、恥とザンキと、あの方のお身の上にたいする心配と絶望がごったにいりまじって、とても生きていられないというギリギリのところへいきなりおしつめてしまった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごらんになってちょうだい、寝台の下を」　のぞいてみると、ブゥルボン・ウイスキーや、ギルビィのジンや、サントリイの空瓶が、よくまぁ飲んだものだと呆れるほど、ごったに押しこんである。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "身動きする毎に、魚の臭いや何やら彼やらがごったになって、胸が悪くなるような臭気をあたりにまき散らす。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの小さな鋭い音が舗石の壁に沿ってごったに起こった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつの定まったイデオロギーは持たず、さまざまなものがごったに混合していて、考え方は、わるく言って幻想的、よく言って抽象的であり、リーダーは持たず、全員が参加する共同体の雰囲気があり、組織的であるよりは無秩序のなかからなにかを創造していく態度だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だが、その炯眼にしては、まるで無用な、時候見舞だの、移転の報らせだの、質屋のものだの、つまらん物まで、ごったに交じっているじゃないか」「一応はと、存じて」「嘘をいえっ！",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
