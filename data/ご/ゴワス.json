        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「仲々ご交際が広うごわすな。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、丸持の祕藏子だと、匙庵老が脈を取つて、氣鬱の症でごわす、些とお氣晴を、と來て、直ぐに野幇間と變化る奴。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男　　ごわごわするなあ、この着物。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「せき込むなよ……という事も出来るし、亭主がまた髯を捻って、「先方御｜親父が、府会議員とごわすれば、直接に打附って見るも手廻しが早いでごわす。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しく県庁に勤めたで、大なり、小なり議員を扱う手心も承知でごわす。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷先生の城山で切腹さした短刀ちゅうもんが、チャンと蔵してごわすじゃ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう云うわけでごわすか、俺等の田は、今年は大へん出来が悪くて、小作米の半分も出来ねえのでごわすが、来春の春蚕が上るまで待って項くわけに行きしめえか？",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それゃ、且那様、俺等もそれ位のごとは知ってるのでごわすが、俺等にゃ竹の樋より上の分にゃ、手が出ねえもんでごわすから。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「箱樋を引いて頂けゃ、水はそれで十分以上でごわすもの、そしたら、肥料もどっさり入れて、田の草取りなんかわらわらと、俺等は鬼のように稼いで、来年こそは、立派な稲にしてお目にかけしてごわす。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ、水揚水車を拵えちゃどうでごわす？",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窪地に、一っぺい水があんのでごわすから。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでごわす、拝みに参りましょうか」　つべこべと口早にしゃべるのを聞きながら、じっと目を閉じて、何ものかをまさぐるように考えていましたが、と、突然右門がすっくと立ち上がりながら外出のしたくにとりかかったので、伝六は早がてんしながらいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だ」「市原でごわす」「小次か！",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からひと押し、押しこんでいったらどうでごわすかよ」「バカッ」「違いましたか！",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……突然またどうしたんでごわす」「どうもせん。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんながそれほどお気に召したら、めっぽうわるい段じゃごわすまいが、それにしても、あの女はだんなよりおおかた七、八つも年増じゃごわせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのへやの床ぎわへこわごわすわると、恐ろしいものをでもしらせるように、三庵が青ざめた顔をふり向けながら、黙って床の間をゆびさしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "「根本………御座らしやるとも、根本ていのア、塩山では一等の丸持大尽でごわすア」と答へて、更に、「で貴郎ア、根本さア処の御客様かね」「其処に行輔といふ子息が有るだらう？",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御座らつしやる」と言つて吸ひ懸けた烟草の烟を不細工な獅子鼻からすうと出し、「大尽どこの子息に似合ねえ堅い子息でごわすア、何でも東京へ行かしつた時にア、それでも四五百も遣つたといふ噂だが、それから堅くなつて、今ぢや村でも評判ものでごわす」「一体｜汝は何処だね？",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩山かね」「いんにや、塩山ではごへん、その一つ前の村の倉沢でごわす」「もう根本は女房を持つたらう」「嚊さまでごわすか、持ちましたとも、……えいと……あれは確か三年前で、芋子村の大尽の娘さアだ」「子供は？",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はア、昨日出来て来たばかしで……村にやもう何十年と火事なんぞは無いだで、喞筒なんぞは有りませんだつたが、今度は、はア仕方が無えのでごわす。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今夜にも火事が打始らねえ者でも無えといふので、若い者が午から学校へ寄り集つて、喞筒の稽古を為て居るんでごわす。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……文三、こいつは馬鹿でごわす」　するとさっきからそのそばで、弓弦を張っていた当の文三、テレまいことか、頬をふくらませフッと横を向いたものである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠っぱしりをさせねえがよい』――子供や女は大事でごわす。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
