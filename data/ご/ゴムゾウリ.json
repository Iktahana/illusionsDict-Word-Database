        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――下駄、ゴム草履、櫛、等、等。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足にはゴム草履を穿いていた。",
              "citation": {
                "source": "一握の髪の毛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェックのパンツ一枚に、首からバスタオルを下げ、ゴム草履といういでたちで、風呂上がりの大魔神かなんかに見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上下になにかをまとっているかぎり、ゴム草履でも食堂に入れる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「用じゃなかったんでしょうか」　盗られた三足のゴム草履のことやシャボンのことが浮んで、心配になった。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、下谷の方から一人の娘、ゴム草履の刻み足、四方に気を配る風情で、橋の上へかかりましたが、一わたりその辺を見廻すと、そのまま細々と肩を狭めて、鳴海の側をスーッと通ります。",
              "citation": {
                "source": "悪人の娘",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が一人、ゴム草履で音もなく忍び寄ってきた。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いゴム草履にカーキー色のぶかぶかの作業ズボン、そして白い長袖シャツの店主は、いつもと変わらない笑ったような顔で、林檎を盛りつけた雨戸のかたわらに立っていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒトミも傘を持ち、夏の海岸ではくゴム草履をはいた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと共に、一つの船室から、ハイヒールのあわただしく弾む跫音と、ゴム草履とが、もつれながら駈けて来て、「あれ！",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日系の女性はゴムぞうりにバミューダ・ショーツ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルメットも、持ってきてくれ」　ゴムぞうりをパタパタさせながら、ミーヨは、走って校庭を出ていった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
