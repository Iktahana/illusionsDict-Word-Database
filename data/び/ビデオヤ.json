        "examples": {
          "standard": [
            {
              "text": "仕事帰りに近所のビデオ屋に寄って、今夜見るためのホラー映画を3本選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あのビデオ屋、アダルトコーナーのカーテンをくぐるのが中学生の時は緊張したなあ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ビデオ屋の返却ポストに投函し忘れて、延滞金がとんでもない額になっちゃった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつもサンドイッチを買うコンビニエンスストアの側のレンタルビデオ屋で隼人はスタンレー・キューブリック監督の『時計仕掛けのオレンジ』を借り、アパートに戻ると早速ナショナルのマックロードＧ15で再生してみる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレビ番組も、ビデオやレーザーディスクになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
