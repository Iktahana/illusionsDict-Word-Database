          "literary": [
            {
              "text": "そんな一つの病型があるんですかね。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の病型は斑紋で、豊かな頬に直径二寸くらゐのがまんまるく出てゐた。",
              "citation": {
                "source": "戯画",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の病型は湿性であるが――さうでなければ熱瘤は出ない――この病型のみでなく、凡て夜露は悪いのである。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "喉頭癩と言ふと何か特別の病型、つまり喉頭ばかりを冒す病型があるやうに思はれさうである。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節によって病型が異なり腺ペストは夏に多く肺ペストは冬に多い。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
