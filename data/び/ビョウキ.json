[
  {
    "uuid": "2a27123a-e43e-5d28-8919-8b6af246dbd4",
    "entry": "病気",
    "reading": {
      "primary": "びょうき",
      "alternatives": [
        "ビョーキ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
