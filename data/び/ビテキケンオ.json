          "literary": [
            {
              "text": "僕は別に縊死に対して美的嫌悪を感じない。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、僕は僕自身の縊死してゐる姿を想像し、贅沢にも美的嫌悪を感じた。",
              "citation": {
                "source": "或旧友へ送る手記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "轢死も僕には何よりも先に美的嫌悪を与へずにはゐなかつた。",
              "citation": {
                "source": "或旧友へ送る手記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし縊死することよりも美的嫌悪を与へない外に蘇生する危険のない利益を持つてゐる。",
              "citation": {
                "source": "或旧友へ送る手記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
