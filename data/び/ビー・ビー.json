        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでも何で、やっぱりＢＢ旅館のあぶれ……。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＢ旅館があまり混んでいるようでね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅から町長の案内で、海岸寄りのＢＢ旅館の前に初めは立った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "癪、癪でして、ええ、そもそもＢＢ旅館なるものが、そりゃあ本斗一の大店でしょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何がＢＢ、何が町長でございますだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大店のＢＢの肩ばかり持ちやがって、成っちゃいねえ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ｂ＝ＢＢ＝ｖと、ノートに書いて、「ね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球滅亡の仕立てとしては、やや情けないこんな出来事から始まる銀河放浪の物語は、もともとイギリスのＢＢＣで、ラジオドラマとして生まれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがベストセラーとなり、ＢＢＣはドラマの続編を作りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空文庫を訪れる人が少しずつ増え始めた、一九九七年の秋、視覚障碍者読書支援協会（ＢＢＡ）のメンバーであるという堀之内修さんから、「自分のページにリンクさせてもらった」とのメールがとどいた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀之内さんのページからたどって、ＢＢＡのサイトを開くと、「弱視者を含めた視覚障碍者全般の読書を支援するために点訳・音訳・拡大訳の３分野の活動を全て統合的に推進しています。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした一般的なパソコン点訳の流れに対して、ＢＢＡの作業フローは、漢字仮名交じりの原文データをコンピュータに変換させ、少ない手間で直接点字データを得ようとする形で描かれていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＢＡでは、原文データを機械に読ませる流れを想定していた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ目の拡大訳は、弱視者のための読書支援で、ＢＢＡはこの分野に重点的に取り組んでいるという。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＢＡは、支援の手が薄かったこの分野を、コンピュータを活用して補おうと考えていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会の勉強会に出席した野口さんが、ＢＢＡ代表の浦口明徳さんから、おみやげをもらってきた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "最優先の課題として意識していた青空文庫の作業マニュアルは、ＢＢＡの原文入力ルールにそってまとめることにした。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度の改訂を経て練り上げられたＢＢＡのマニュアルは、私たちが検討するべき要素の多くに、すでに答えを出していた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにそっておけば、青空文庫のテキストを、ＢＢＡが想定している、点訳、音訳、拡大訳の三つの流れにのせて、視覚障碍者の読書支援に活用してもらえるのではないかという期待もあった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「書式や体裁にこだわらず、内容を伝える」ことを優先するＢＢＡに対して、青空文庫は「底本の保存」を重視した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴眼者がパソコンなどの画面で読むテキスト・データを、そのまま点訳、音訳、拡大訳に利用していくというＢＢＡの構想のかなりは、今や常識的なものとなっている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＢＡが想定していた画面上の拡大訳は、今や、これらのソフトの基本機能として実現されている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ何号よりとか、ＢＢＢよりとかいうのはもう古い。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＡＢＲＡＢＢＡＤＡと綴りますがね。",
              "citation": {
                "source": "不思議な島",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "数秒間、彼は、石像のようになって、顕微鏡をのぞいていたが、やがて顔をあげると、「おお、これはたしかに、今大問題になっているＢＢ火薬だ！",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＢ火薬　曾呂利本馬は、もう解消して、名探偵帆村荘六は、顕微鏡からはなれた。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村探偵は、そのガラスでつくった試験管の中へ、ＢＢ火薬らしいもので黒くなった花片を、しきりにむしりとって、つめこんだ。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
