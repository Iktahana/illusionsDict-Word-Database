        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "君、ビッグ・ニュウス。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい迷信さ」「あたい、『ビッグ・パレード』だの『ウイングス』で随分教養のある青年達が、ただ兵士募集の触れ太鼓を聞いただけで、理由もわからず暗雲に感動して出征するのを見て、男って野蛮人だなあと思って呆れかえっちゃった」「それで大入満員だから困る。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、カーンストック引込線、ビッグ・ベン引込線、パーシヴィアランス引込線の三を「可能なる」ものと認むるものなり。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビッグ・ベンでも、バッキンガム宮殿でも、なんでもいい……」　令子は、なにかいいたげに慶一を見たが、結局、開きかけた口をつぐんでしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バッキンガム宮殿じゃない、ロンドン塔だ」「バカいえ、ビッグ・ベンていっただろうが」「ケンカなんかしないで。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺するってわけか」「うんにゃ、自殺は嫌いだ」「じゃあ、どうするんだ」「ふふふ、こいつはあまり誰にも聞かせたくないビッグ・アイデアだがね、外ならぬお仲間たちだから喋るが、実はアルプスの山の中へ立籠るんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビッグ・アイデアだよ」「あの籠みたいなものに、送影用のレンズや発振器装置などがついているんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この伊藤家食客時代にも数種の映画を見ているが、そのおもなるものは伊藤の「下郎」、キング・ヴィダーの「ビッグ・パレード」などであつた。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍體はその間に西六番街なるハビッグ葬儀社に送附された。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "★『ハッカーズ』によれば、この誌名はジャニス・ジョップリンが一時期参加したビッグ・ブラザー＆ザ・ホールディング・カンパニーのもじりであるという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにたどればビッグ・ブラザーはジョージ・オーウェルの『一九八四』から、ザ・ホールディング・カンパニーはマリファナを持っているという意味のスラングからきている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇足とは知りながら一言付け加えれば、灰になっても忘れることのなさそうなジャニスの「サマータイム」は、ビッグ・ブラザー＆ザ・ホールディング・カンパニー時代の佳作である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャバレのビッグ・フォアでしたよ、実はそのときは田川君が連れていってくれたんですがね」「わたくしもそうなんです」「え。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何がそうなんです」「田鶴子さんに初めて紹介されたのが、ビッグ・フォアだったんです。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ兵のいる陸地へ、こっちからいって上陸したということになれば、そのニュースは、ビッグ・ニュースとして全世界を震駭し、奮わざること久しきイギリス軍も勇気百倍、狂喜乱舞いたしますよ」「狂喜乱舞するかな。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今ドイツ側がビッグ・ニュースの放送をやって居ります。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時頭の上でビッグベンが厳に十時を打ち出した。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三面記事、ビッグ・ニュース、それを面白がるだけで、たくさん。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "万吉郎のビッグ・アイデアとはどんなことであったろう？",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜもっと早く、そのビッグ・アイデアに気がつかなかったのだろう。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はゆくりなくも、愕くべき第二のビッグ・アイデアを思いついたからだ。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は彗星の如く現れたジャズ・シンガー、曲は彼女が幸運を引き当てた「想い出のワルツ」、どよめきと共に次の幕が切って落され、ジャズのナンバーワンと絶讃をあびている、ジョージ・川口とビッグ・フォアー、なかでも太鼓のジョージ・川口の至芸には思わず息をのんだしだい。",
              "citation": {
                "source": "ジャズ狂時代",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "人工衛星や核融合などのビッグ・ニュースを、始終聞かされているうちに、たいていの人は、科学の成果に幻惑される。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この計画の一部として、コロラド州にビッグトムソン計画と呼ばれている開発計画がある。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……カルニヤ・ブレビッグ……」　もう御前を退出しなくてはならない。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……世界的なビッグ・ニュースである。",
              "citation": {
                "source": "キャラコさん",
                "author": "蘆と木笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "南条己未男は、彼の顔をみると、「おい、ビッグニュースだ。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
