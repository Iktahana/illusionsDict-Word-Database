[
  {
    "uuid": "24b2d7a1-c795-57ee-9ed4-4653d0eba4de",
    "entry": "美",
    "reading": {
      "primary": "び",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beauty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それあまあ、昔だつて一般世人は美術家より装飾美術家の方をリアリスティクだと思つてゐたものではあるらしい。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右匆々乍ら此の詩人への讃美と註文とである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は高森のことを想ふと、いつも一匹の美しい仔熊を聯想する。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "努力を尽しても、猶天命は俟たねばならないものだといふことを、努力の際中でも予想出来るのでなければ、努力といふことも畢竟何のための努力か分らなくなり、そんな所から美は出て来ないと思ふのだ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、今日私が、過去の錯乱を去つたのは、実に私が、謂はば、自力的に求めたればこそで、却て今日はじめて、花の美しさをも感じられるやうになつた次第である。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の後に出た詩人達は彼女の中に様々な美点を見付けた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "迸出の新鮮さといふ点からいふも、美の美しさといふ点からいふも、彼女の詩は後世が呼んで『純粋状態』の詩といふものに該当してゐる。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙事は謂はば文人画風の型を作り、かくて人間的心情は所謂美――私にとつてはデコレイション――とその余りの部分とに分裂した。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は長い間トリスタン・コルビエールは美的感情を欠いてをり、芸術に無智であると思つて来た。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの場合彼の話は話に終るのだが、偶には美事にやりおほせることがある。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の事はその美事にやれさうな方の事のやうに思へるのだ。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな奴とならさう美事にいかないまでも全然まづくなりつこはないのだ。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人美しい女が目にとまつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい女といふものはよいものである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは実に透明な青味を帯びた、美しい貝のやうな詩である。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの詩集は、北原兄の『思ひ出』以後における日本唯一の美しい抒情小曲集である。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして私と彼とは、互にその欠陥せる病癖を悲しみ、互にその夢想せるしかも正反対の性情の美しさを交換した。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには少年に特有なあの美しい感傷と、生娘のやうな純潔の気高さがあつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の生活は、今や空虚な狂熱や、耽美的な情緒に惑溺する時代を通り越した。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生は、彼にとつては一つの美しい現実であり、同時にまた理想である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はよく生きるためには、絶えず高潔な感情を求めて、現実の生活そのものを充実した美しさの上に、がつしりと、しかも肉体的に築きあげねばならないと言ふのは、彼の叙情詩の凡てが語る所の哲学である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには近代文明の不幸な疾病が憧憬する所の、あの美しく明るい健康の哲学がある。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもさうした純潔の詩人の生涯こそ、かの音楽家のそれと等しく、人生の最も神聖なる住宅、即ち道徳及びその他の感情生活の世界を支配する最高至美の権威でなければならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその他の者は、相変らず古典的な美文で、古典的な、熱のない脩辞を繰返して居るにすぎなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに私共の求めてゐたものは、もつと鮮新で、もつと自由で、そしてもつとしんみりとした情熱をもつた、純日本言葉の美しい音楽であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙吉ト新美ノ二人ガ、子供ヲ大事ニ気ヲ附ケマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば裏の竹藪に蛇が出たとか、蟇が鳴いてるとか、蟻の山が見つかったとか、梅の花が一輪｜咲いたとか、夕焼が美しく出ているとかいうようなことを、だれか家人の一人が発見すると、一々それをヘルンの所へ報告に行く。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど『美しいシャボン玉』を壊さないように、注意に注意して気をつけましたと、未亡人となった夫人が後で言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風ですよろこびやがれ凡俗！",
              "citation": {
                "source": "春の日の怒",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の片側は翳り、片側は日射しをうけて、あつたかいけざやかにもわびしい秋の午前です。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
