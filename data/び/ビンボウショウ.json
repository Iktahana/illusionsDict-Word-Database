    "definitions": [
      {
        "index": 1,
        "gloss": "parsimonious spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "或ひは、私は、貧乏性といふやつなのかも知れない。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏性という奴かも知れない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、貧乏性の損な性分なのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくよくの貧乏性に生れて來てゐるのか、その時／＼ですぐ忘れてしまひ得る幸福な性質を持つてゐるのか、その場はとにかく、その前後などを考ふることに於て、さほどには苦にならない。",
              "citation": {
                "source": "樹木とその葉",
                "author": "貧乏首尾無し",
                "note": "青空文庫"
              }
            },
            {
              "text": "印税の約束で出版した『秋風の歌』『砂丘』『朝の歌』『寂しき樹木』、それに散文集二册、すべて初版を出すか出さぬに本屋の都合でその版權が行衞不明になつてしまふなど、よくよくの貧乏性に生れて來たものと苦笑せざるを得ない。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "善兵衛がおひとよしだから姉さんはあんなになってしまってと、おやそさんは言ったが、勝梅さんのお母さんよりおやそさんの方がよっぽど貧乏性だった。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで考えてるンだけど、四人のうちで私が一番貧乏性かも知れないわね。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイヤも、サファイヤも、ルビーも、真珠も、すべてそのケシ粒ほどの如きものすらも手にとって眺めたことが一度もないという貧乏性なのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の貧乏性もよく分るけど、ほかの人の方がもっと貧乏性に見えるらしいのね。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、貧乏性とは、この際、適切な言葉だと青木は思った。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して、記代子は貧乏性ではないのかも知れない。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくは貧乏性だとさ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄、帝王のＡクラスにも貧乏性はあるもんだよ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような言語を弄して人を罵詈するものに限って融通の利かぬ貧乏性の男が多いようだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでも我等は貧乏性、土方にならぬが、まだしも、ましかと。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持ちであっても、貧乏性だと言われるたちの人柄に比ぶれば、随分幸福ものと言えよう。",
              "citation": {
                "source": "雅美ということ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の貧乏性とあの皮肉が、牡丹を、どんな風に觀たらうか。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この貧乏性の癖は、父親の福次郎にもあった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変な御謙遜でございますこと」「お前は貧乏性だから始終セカ／＼していると主人が申します」「矢張り花形でいらっしゃいますから、彼方此方で引っ張り凧になるんでございますわ」「何う致しまして。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もお針仕事の針子にさ、酒を出すなんて」「貧乏性だわねえ、あんたは。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏性とよく人に笑われたりするが、彼は貧農の家に生れたので、米つぶを見ると、母の汗を見るごとく、おろそかに思えなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事、こんな事、家康の耳にも、何となく聞えてくるが、家康は、鈍根な貧乏性を頑なに守っている吝嗇家のように、本多正信とぼそぼそ話していない時は、独り居室で書物など繙いている折が多かった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "山科でも申した通り、このたび江戸表へ下るのは、よい主人を求めて、すこしは貧乏性を直そうと、心を改めたで、下向と決めた迄の事。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
