[
  {
    "uuid": "7293e6cc-e3d8-5d42-9da1-0c92f78491ba",
    "entry": "微温的",
    "reading": {
      "primary": "びおんてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
