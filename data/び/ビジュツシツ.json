    "definitions": [
      {
        "index": 1,
        "gloss": "art room (e.g. in a school)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "音が〈ゲティング・ベター〉になり、美術室内部を教壇から見たショット。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと古代の絹かなにかで飾りたてられた美術室、如何程価のするか解らないような種々の珍奇の骨董品やら、書画の類が巧を尽して列べられてある、さらに居間に入れば価高い香料がプンと鼻を突いて心を酔わせる。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "石膏のぼろ／＼落ちた美術室の飾棚の上で首の落ちた少年像をまたまさぐるなんて！",
              "citation": {
                "source": "青春",
                "author": "献じる詞（牢獄にて）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは昨日、はからずも貴家の美術室を拝見する光栄を得たのですが、そのりっぱさにおどろきいりました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついては、今夜正十時、ぼくの部下のもの三名が、貴家に参上しますから、だまって美術室に通していただきたいのです。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの彫刻は、この家の美術室におさめてあるけど、けっしてわしの私有物ではないと思っているくらいだからね。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、壮太郎氏の案内で、美術室を見て、もとの応接室に帰ったのですが、しばらくのあいだ、ものもいわないで、目をつむって、何か考えごとにふけっているようすでした。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術室の入り口では、壮太郎氏と近藤老人とが待ちうけていて、賊のひとりに声をかけました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いいすてて、三人はドカドカ美術室へはいっていきました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつをいうと、ぼくはあんな貧弱な美術室に、いつまでも執着しているわけにはいかないのだ。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いずれきみにも見せるがね、この奥にぼくの美術室があるんだよ。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "★この項に属するもので、室外で殺した死体を、密室になっている美術室の高い窓からほうりこんで、そこで殺されたように見せかけるという、人間｜投擲の奇抜なトリックを考え出した有名な作家がある。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術室の怪　二十面相がドアをあけて、玄関のホールに立ちますと、その物音を聞きつけて、ひとりの部下が顔を出しました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず浴室にはいって、さっぱりと顔を洗いますと、毎朝の習慣にしたがって、廊下の奥のかくし戸をひらいて、地底の美術室へと、おりていきました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室のことですから、窓というものがなく、わずかに、天井のすみに、厚いガラス張りの天窓のようなものがあり、そこからにぶい光がさしこんでいるばかりですから、美術室は昼間でも、夕方のようにうす暗いのです。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十面相は、いま、その美術室のまんなかに立って、ぬすみためた宝物を、さも楽しそうに見まわしていました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの明智先生も、ここにこんなりっぱな美術室があろうとは、ごぞんじあるまいて、フフフ……。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とつぜん声がして、けさのひげむじゃの部下の男が、美術室へはいってきました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大爆発　二十面相は、十一体の仏像のピストルにかこまれ、明智探偵の監視をうけながら、もうあきらめはてたように美術室の中を、フラフラと歩きまわりました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術室の下には、さらに一段深い地下の穴ぐらが用意してあったのです。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、小林団長のいつかの知恵にならって、賊の美術室にちょうど十一体の仏像があるのをさいわい、そのうす暗い地下室で、団員ぜんぶが仏像に化け、にくい二十面相をゾッとさせる計略を思いたちました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わたしのうちの洋館の二階の美術室にかけてあります。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、わたしのうちには大学にかよっているむすこもいますし、書生もふたりいるほかに、わたしが社長をしている会社の若い社員に、三人ほどとまりにきてもらっているので、美術室のまわりはむろん、やしきのまわりにも、ぐるっと、見はりがついているわけです。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに美術室は、よく見ておかなければなりません。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドニスの像　明智探偵と小林少年は神山邸につくと、見はりをつとめている警官とも話しあい、やしきのうちそとを、くまなく見てまわり、ことにレンブラントの油絵のかかっている美術室は、ねんいりにしらべました。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "神山さんが、美術室へはいってみると、部屋のすみに立ててあったアドニスの石膏像が、まっぷたつにわれて、ころがっていたのです。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術室の窓は、いつもしめきって、かけがねがかけてあるのですが、女中さんがそうじをするときには、窓をあけますから、窓をあけておいて、女中さんが、ちょっと部屋を出たすきに、ボールがとびこんだのかもしれません。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハヤノ商会の四人の人夫が、それを二階の美術室にかつぎあげて、もとの場所においてかえりました。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行の大金庫の中へでも、あずけたらという意見も出ましたが、持ちはこびなんかしたら、その道があぶないというので、美術室から動かさないことにしたのです。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
