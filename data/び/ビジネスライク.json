        "examples": {
          "standard": [
            {
              "text": "彼はどんな相手に対しても常にビジネスライクな態度を崩さず、私情を挟まない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "余計な世間話は抜きにして、ビジネスライクに淡々と会議を進行させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "友人同士で始めた事業だが、仕事の場ではビジネスライクに接することを約束した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "せん子を小布施のところへ遣つてから、手廻りは何事も不如意で、代つてして呉れる内弟子のカリフオルニヤ生れの桑子はビジネスライクに過ぎて、気持にそぐはないところが多い。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車に乗ってビジネスライクに見えるところがお可笑くあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに役人はややともすれば、事をビジネスライクに運ぶため、またはその威儀を保つために、専断力を濫用します。",
              "citation": {
                "source": "役人の頭",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
