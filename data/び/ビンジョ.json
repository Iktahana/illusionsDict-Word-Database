    "definitions": [
      {
        "index": 1,
        "gloss": "beautiful woman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仇打の志があった美女の小まんはまた大力でもあったのでこういう唄が残っているといった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は美女なりに、醜女は醜女なりに、いかにも女性の心の弱さ、お洒落さ、見栄坊であることを象徴して好い。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女が化粧えば一層の匂いを増し醜女がとりつくろえば、女性らしい苦労が見えて、その醜なのが許される。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば『諸国咄』では義経やその従者の悪口棚卸しに人の臍を撚り、『一代女』には自堕落女のさまざまの暴露があり、『一代男』には美女のあら捜しがある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時裏の山、向うの峰、左右前後にすくすくとあるのが、一ツ一ツ嘴を向け、頭を擡げて、この一落の別天地、親仁を下手に控え、馬に面して彳んだ月下の美女の姿を差覗くがごとく、陰々として深山の気が籠って来た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "男滝の方はうらはらで、石を砕き、地を貫く勢、堂々たる有様じゃ、これが二つ件の巌に当って左右に分れて二筋となって落ちるのが身に浸みて、女滝の心を砕く姿は、男の膝に取ついて美女が泣いて身を震わすようで、岸に居てさえ体がわななく、肉が跳る。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ水で医者の内も死絶えた、さればかような美女が片田舎に生れたのも国が世がわり、代がわりの前兆であろうと、土地のものは言い伝えた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の雪より白く、透通る胸に、すや／＼と息を引いた、肺を病むだ美女の臨終の状が、歴々と、あはれ、苦しいむなさきの、襟の乱れたのさへ偲ばるゝではないか。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何等かの方法によって、この死灰の美女に息を吹き返させ自分同様、悩みと苦熱の血を通わしてやり度い。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西班牙の美女ラッケ・メレの舞踊を見ての礼讃。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呪いの方の眷属は多く妖艶なる美女の姿を装うて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ夫人は一夜の内に、太く面やつれがしたけれども、翌日、伊勢を去る時、揉合う旅籠屋の客にも、陸続たる道中にも、汽車にも、かばかりの美女はなかったのである。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人のためならば、このあたりの浜の名も、狭島が浦と称えつびょう、リボンかけたる、笄したる、夏の女の多い中に、海第一と聞えた美女。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と其の帶に挾んで、胸先に乳をおさへた美女の蕊かと見える……下〆のほのめく中に、状袋の端が見えた、手紙が一｜通。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……煙の遠いのは人かと見ゆる、山の魂かと見ゆる、峰の妾かと見ゆる、狩り暮らし夕霧に薄く成り行く、里の美女の影かとも視めらるゝ。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雫の餘波、蔓にかゝりて、玉の簾の靡くが如く、頓てぞ大木を樹上つて、梢の閨を探り得しが、鶴が齊眉く美女と雲の中なる契を結びぬ。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は立直って、「お蔭様で災難を、」　と襟首を見せてつむりを下げた。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は親しげに笑いかけて、「ほほ、私はもう災難と申します。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女はその顔を差覗く風情して、瞳を斜めに衝と流しながら、華奢な掌を軽く頬に当てると、紅がひらりと搦む、腕の雪を払う音、さらさらと衣摺れして、「真個は、寝ていましたの……」「何んですッて、」　と苦笑。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ヤレまた落語の前座が言いそうなことを、とヒヤリとして、漸と瞳を定めて見ると、美女は刎飛んだ杖を拾って、しなやかに両手でついて、悠々と立っている。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうと言って、」　と言に連れられた春のその日中から、瞳を美女の姿にかえした。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　美女は身を震わして、何故か嬉しそうに、「ああ、貴下もその（厭な心持）をおっしゃいましたよ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待ちちょいと、」　と声をかけた美女は起直った。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は膝をずらしながら、帯に手をかけて、揺り上げたが、「お待ちよ、今お銭を上るからね、」　手帳の紙へはしり書して、一枚｜手許へ引切った、そのまま獅子をさし招いて、「おいでおいで、ああ、お前ね、これを持って、その角の二階家へ行って取っておいで。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は莞爾して、「唯持って行ってくれれば可いの、何処へッて当はないの。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "連獅子のあとを追って、というのをしおに、まだ我儘が言い足りず、話相手の欲しかったらしい美女に辞して、袂を分ったが、獅子の飛ぶのに足の続くわけはない。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、折角、私がおさがりを頂いたんですからね、あの塚から、」　その古塚は、あわれ、雪に埋れた名工と、鼓の緒の幻の陽炎に消えた美女のおくつきである。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　むッくり下から掻い上げ、押出すようにするりと半身、夜具の紅裏牡丹花の、咲乱れたる花片に、裙を包んだ美女あり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
