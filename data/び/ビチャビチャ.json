        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みんな怒って、何か云おうとしているうちに、その人は、びちゃびちゃ岸をあるいて行って、それから淵のすぐ上流の浅瀬をこっちへわたろうとした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男はこっちへびちゃびちゃ岸をあるいて来ました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな怒って、何か云はうとしてゐるうちに、その人は、びちゃびちゃ岸をあるいて行って、それから淵のすぐ上流の浅瀬をこっちへわたらうとした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沼小沼が干たせいか、じょんじょろ水に、びちゃびちゃと泳いだ処を、ちょろりと掬った。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも着物の裾をも引き揚げないで、湿れるがままにびちゃびちゃと歩いていた。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「翁様、娘は中肉にむっちりと、膚つきが得う言われぬのが、びちゃびちゃと潮へ入った。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しとしという尋常らしい跫音が、今はびちゃびちゃと聞えて来た。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と思わず口へ出たが、はっと気が付いて、直ぐびちゃびちゃと歩行き出した。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あざけるように橋の下で、びちゃびちゃと川波が鳴りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚は仲間同士で抱きあったり縺れあったりするように、水をびちゃびちゃと云わして体を搦ましあった。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜も彼女は彼の寝間へ入って来て、夜深の窓の下にびちゃびちゃ這いよる水の音を聞きながら、夜明け近くまで話していたが、それは文字通りの話だけで何の意味があるわけでもなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　麻生は鶏を島村に渡して、鞋をびちゃびちゃ言わせて帰って行った。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の旭町はまるでどろんこのびちゃびちゃな街だ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸をうつ波のうねりは、河口一円にわたりて大きな弧をつくり、何故か敬遠して途中でびちゃびちゃと消えてしまった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "くらも、　うらぐちへ　つづく　ろうかも、　みずで　びちゃびちゃ　つるつる。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "また川を渡るのに初めはびちゃびちゃ水の中を歩いているが、それでは不便であるから橋を架ける。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その白みある明るい光では、よく赤児がしていた水枕のびちゃびちゃする音が、私の耳にきこえた。",
              "citation": {
                "source": "童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
