        "examples": {
          "standard": [
            {
              "text": "ビデオデッキの「再生」ボタンを押すと、ガチャッという重々しい音とともにテープが回る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "実家の物置に眠っているビデオデッキ、まだ動くならDVDにダビングしたいな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ビデオデッキの中にコインを入れちゃダメだよ！壊れて取り出せなくなるからね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それにビデオデッキまである」「人の部屋を覗くなよ」「まあそう怒らないで下さいよ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビデオデッキ付きテレビ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタルＨＩ―ＦＩ８ミリビデオデッキのコードは二股に分れ、一方はテレビにもう一方はＳＳＢトランシーバーに接続している。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビデオカセットをデジタルＨＩ―ＦＩビデオデッキのカセットホルダーにセットし、右向きの矢印のついた再生ボタンを押す。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＳＢトランシーバー、パソコン、テレビ、ビデオデッキの順に電源を切るとダンボール箱の中に手を突っ込み、皺くちゃになった青いナップザックを引っぱり出す。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また今後警察では聞き込み捜査を中心に……」　隼人は『時計仕掛けのオレンジ』の暴力シーンで思わず早送りにしたのと同じ心理で、ふとビデオデッキの右方向に矢印が二つ並んだボタンを押した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人はテレビを消し、ビデオデッキの早送りボタンを戻してからもう一度テレビをつけてみた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
