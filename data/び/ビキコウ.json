        "examples": {
          "standard": [
            {
              "text": "同じ庭の中でも、日陰と日向では異なる微気候が形成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都市部の微気候は、アスファルトの蓄熱によって気温が高くなりやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "盆地特有の微気候を活かして、この地域では美味しいブドウが育つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "地形の複雑なための二次的影響としては、距離から見ればいくらも離れていない各地方の間に微気候学的な差別の多様性が生じる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に微気候学的差別のみならず、また地質の多様な変化による植物景観の多様性も日本の土地の相貌を複雑にするのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
