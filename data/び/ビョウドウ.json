[
  {
    "uuid": "58a1c76f-851e-505e-a60a-20f18414748f",
    "entry": "平等",
    "reading": {
      "primary": "びょうどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
