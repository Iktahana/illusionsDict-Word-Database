[
  {
    "uuid": "71f2f4fe-29a4-54f2-bff3-9ead459ea501",
    "entry": "鼻骨",
    "reading": {
      "primary": "びこつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "nasal bone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、それから此方を向いて、「こつですたい、鯨の鼻骨は。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "肴は鯨の鼻骨に野菜の辛子漬。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "肋骨三本に、鼻骨だぜ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の小鼻は鼻骨と密着していない、きわめて手術のし易いタチの小鼻であると思った。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩眼は眼窩の中で煮え泡立つたまゝカリ／＼になり、鼻骨は失せてその跡がボコンと大きな見苦しい穴に落ち窪んでゐた。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い頭髪、へこんだ鼻骨等の外観上の類似点、及び他の相似からして、日本人と米国インディアンとが同じ先祖から来ているのだと考える人もある＊。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ふとい鼻骨と、頑健な顎骨が、あくまで男性的な強い線をひいていた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉は秀才がた、鼻骨はたかく、唇もとのしまりよく、愛嬌のこぼるるようなところがあり、面、肩の肉、背丈など、一体に薄肉のたちである。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻骨が鼻骨にふれた。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）御坊、なぞこの世の中にはまことなき奴儕がはびこつて、正しきものが虐げられるのでござらうな。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄の書齋が薄暗いのは、仙石屋敷の高臺から續く傾斜地――そこは泰養寺の山と云はれてゐる――の檜の木の大木や、枝のはびこつた松や、大きな椿や、江戸自慢といふ太い櫻やの影が追ひかぶさつてゐる上に、十數年を經た樹木がまた室近く繁り込んでゐる爲めばかりではない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕や脚一面に糜爛した腫物がはびこつてゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば二羽の鴉が犬とすれ／＼の低さにまで下つて、あつちに飛びこつちに飛びして、がア／＼と啼き騷いでゐる。",
              "citation": {
                "source": "鴉と正覺坊",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯樣いふ事情があつたのであるから、當時に神異なことを尊む風が驚くべく上下にはびこつた事は察するに難くない。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが僕は自らすゝんで採集の野へ立ち向ふ程の気力も失せて、稍ともすれば森蔭や水ふちの隠花植物のはびこつた日蔭に蹲つて、果てしもない嘆きの身柄を持ち扱ふばかりであつた。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の間からハラハラと水が滾れ落ち、万年草や孔雀歯朶が一杯にはびこつてゐる森の中だつた。",
              "citation": {
                "source": "出発",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その根はもう三尺四尺の長さにまで地中にはびこつてゐる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　札幌區立病院は、――義雄が有馬の家から散歩がてら出ると直ぐ横手に當るので、這入つて時々瞑想に眈つたことがある農科大學附屬博物館の、はびこつた牧草や、脊の高いアカダモや、ドロや、柳やの多い、その廣い構内の東南端に接して、――北一條七丁目の一廓の、廣く長く、まばらな鐵柵をめぐらした中に立つてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞所得　　　米　一升四合昨日　　　銭　二十九銭　　　米　二升今日　　　銭　五十五銭　五月十九日帰庵したのが六時半、夕あかりに雑草がはびこつてゐるのに驚かされた、あやめが咲いてゐた、棗が若葉を出してゐた。",
              "citation": {
                "source": "行乞記",
                "author": "室積行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "看病のために庭の掃除も手入も出来ぬ上に、植木屋が来てくれんで松も椎も枝がはびこつて草苗などは下陰になつて生長することが出来ぬのであらう。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は手に手をとつて、じめじめした沼地をば、深々と生ひはびこつた荊棘にひつ掻かれたり、殆んど一足ごとにつまづいたりしながら、前へ前へと進んで行つた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "苔や雑草がその屋根を蔽ひ、窓さきには林檎の樹々が枝をひろげて生ひ茂り、森はその館を蔭につつんで不気味な凄みをそへ、榛の茂みが家の土台ぎはから生ひはびこつて、池の汀へとすべり下りてゐる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏中草が繁げつてしまつて、鶏小舎の中にまで白い鉄道草の花がはびこつたりしてゐたのが、子供が七人もある人達が越して来ると、草が何時の間にかなくなつてしまつて、いゝ空地がたちまち出来上がり、子供達は自分より大きい箒で、落葉をはいては火をつけて燃やしてゐた。",
              "citation": {
                "source": "柿の実",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろこんで働けねえやうにしといて、いじめるンだから、闇がはびこつちまふンですよ……。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、三つの開閉器が捻られて、この一帯が暗黒になると、その時、何故に、テレーズの像が現われなければならなかったのでしょう」　そこで法水はちょっと一息入れて莨に火を点けたが、再びこつこつ歩き廻りながら云いはじめた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔障の雲がはびこつて地を亡ぼそと降るやうに。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、嘗つては、長崎の町にはびこつた、恐しい熱病にとりつかれて、七日七夜の間、道ばたに伏しまろんでは、苦み悶えたとも申す事でござる。",
              "citation": {
                "source": "奉教人の死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人間の感覚では想像出来ない凄まじい猛烈さで進行してゐる巨大な生物地球の表面に毒煙のやうにむらがり泥海のやうに氾濫し、毒草のやうにはびこつて人類を苦しめてゐるもろもろの害悪をはつきり識認した。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "都には今、いろいろ悪者がはびこつて、天子さまにも、み心をいためてゐられまするとか、うはさにききました。",
              "citation": {
                "source": "木曾の一平",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、猛獣や毒虫がはびこつてゐますし、奥地の方には、獰猛で危険な土人たちが住んでゐます。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
