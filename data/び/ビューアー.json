        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古いフィルムスライドをビューアーで見て、昔の思い出に浸った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レントゲン写真をビューアーにかざし、骨の状態を詳しく確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師は、患者のMRI画像をビューアーで注意深く観察していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "★『マッキントッシュ伝説』（インタビューアー　斎藤由多加、オープンブック、販売元　マックワールド・コミュニケーションズ・ジャパン、一九九四年）中のアラン・ケイのコメント。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★前出『一〇〇万人の謎を解く　ザ・ＰＣの系譜』所収、「パソコンの故郷『Ｂｉｔ-ｉＮＮ』を語る」（インタビューアー　渡辺和也）中の野口重次のコメント。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
