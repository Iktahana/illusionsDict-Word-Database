        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ、いま新らしき遊戲は行はれ遠望の海さんさんたるにわれ諸君とゆびさし眺望してながく塔下に演説す。",
              "citation": {
                "source": "交歡記誌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば我、皿持ちゆかん、鰯の頭を賜びさせ給へ！",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵軍が近寄るのでフィンが呼びさますと、「もう少し夢のつづきを見せてくれればよかったのに」と言ってその夢の話をして聞かせる。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "残夢再びさむれば、もう神戸が見えますると隣りの女に告ぐるボーイの声。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の夜空これはまあ、おにぎはしい、みんなてんでなことをいふそれでもつれぬみやびさよいづれ揃つて夫人たち。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾野の草が、人の軒下にはみ出るさびしい町外れとなって、板びさしの突き出た、まん幕の張りめぐらされた木造｜小舎に、扶桑本社と標札がある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合には本来の意味内容のほかに強いて他の新しい色彩を帯びさせられたものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会場では、この二つの頂点の処の肝心な数コマが白紙で蔽われて「カット」されていたことからしてみると、相当に深刻な描写があって人間の隠れた本能を呼びさますものがあるものと見える。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘がバルセロナの古い歴史を呼びさますようにえんえんと鳴る。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正時代の熱中期に買ひ集めた二百餘枚のレコオドのかびさへはえてゐたのを拭き磨いて今更の如く掛けてみるのだが、こんなのを嬉しがつて聽いてゐたのかと呆れるばかりだ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座で半襟、簪、其他娘が喜びさうな品を買ひ整へて汽車に乘つた。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような官能の刺激を通じて、われわれ祖先以来のあらゆるわびしくさびしい生活の民族的記憶がよびさまされて来る。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尊寺〔二〕宮沢賢治白きそらいと近くしてみねの方鐘さらに鳴り青葉もて埋もる堂のひそけくも暮れにまぢかし僧ひとり縁にうちゐてふくれたるうなじめぐらし義経の彩ある像をゆびさしてそらごとを云ふ",
              "citation": {
                "source": "中尊寺〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自分に口返事ばかりして、拍車を錆びさしたりしたことを思い出して、むっとした。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原に錆びさせられて腹立てた拍車は、今は、歩く妨げになるばかりだった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔白金環の天末を〕白金環の天末を、　　　　　みなかみ遠くめぐらしつ、大煙突はひさびさに、　　　くろきけむりをあげにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春黒雲峡を乱れ飛び　　技師ら亜炭の火に寄りぬげにもひとびと祟むるは　　青き Gossan 銅の脈わが索むるはまことのことば雨の中なる真言なり　　来々軒浙江の林光文は、　　　　　　かゞやかにまなこ瞠き、そが弟子の足をゆびさし、　　凛としてみじろぎもせず。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次々うつるひるのたくさんの青い山々の姿や、きらきら光るもやの奥を誰かが高く歌を歌いながら通ったと思ったら富沢はまた弱く呼びさまされた。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共の世界が旱の時、瘠せてしまった夜鷹やほととぎすなどが、それをだまって見上げて、残念そうに咽喉をくびくびさせているのを時々見ることがあるではありませんか。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はこれらの謎のやうな詩を總括して再びさきの獨斷を繰り返す。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、つい此の頃、飛行機で、八｜景の中の上高地の空を飛んだと言ふから、船に乗つても、羽が生えて、ひら／＼と、周囲十五｜里の湖の上を高く飛びさうでならなかつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い路ですからね、わたくしも路でないところへ踏込むかも知れませんが、転びさえしなければ草や樹で擦りむく位ですから驚くことはありません。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教的体験の少ない宗教家の説教で聴衆の中の宗教家を呼びさます事はまれであると同じようなものであるまいか。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがすぐれている所因は単に事がらを教えるのみでなく、科学的なものの考え方を教え、科学的の精神を読者の中によびさますからである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また錯覚からよびさまされて喜ぶ人はほとんどまれである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、時々映画で予期以外の付録として見せられることはあるが、今までこの競争に対して特別の興味をよびさまされることはついぞなかったようである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その確信が私の兇暴さを呼びさましたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
