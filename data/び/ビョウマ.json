[
  {
    "uuid": "7ff54384-4c86-5771-88a7-818738a5c5ad",
    "entry": "病魔",
    "reading": {
      "primary": "びょうま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
