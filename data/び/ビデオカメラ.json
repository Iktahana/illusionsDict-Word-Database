          "literary": [
            {
              "text": "『パソコン創世記』という、この分野の歴史を書いたものを電子本にする際、ビデオカメラを買った。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人はしばらくの間８ミリビデオカメラで周囲の光景を撮り続けていたが、通勤サラリーマンの数が比較的減ってくると駅に戻り、売店で新聞を買ってから山手線に乗った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人は新聞を網棚に載せ、８ミリビデオカメラを録画スタートさせて車内を撮影した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人は８ミリビデオカメラの可変ビューファインダーを覗き込んだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人は８ミリビデオカメラを構え、空へ通じるを体中に生やしながら無表情な顔で街を通り過ぎる群衆を撮り続けた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレビの画面には鏡で無限にコピーされた８ミリビデオカメラを構えた男がうつし出される。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
