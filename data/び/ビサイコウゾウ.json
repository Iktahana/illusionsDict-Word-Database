        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ内部の微細構造は消えていることが多い。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結晶内部の微細構造や角板の中に見える細い縞などが一体何であるかはまだはっきり分っていないのである。",
              "citation": {
                "source": "雪雑記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この微細構造の研究には、雪を染めて見るとか、油で固めて見るとかいうことも考えられたので、少しやって見たがどうも巧く行かなかった。",
              "citation": {
                "source": "雪雑記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物の材料として使われた多数の植物性の物質および混ぜ物として使われている多くの物質の微細構造159図を示している。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自然科学のイデオロギー性は、こう云った微細構造を有つのである。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから彼は特定の臓器の微細構造についての古典的研究に進んだ。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は上皮の発見者であり組織学すなわち組織の微細構造についての科学の創設者であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
