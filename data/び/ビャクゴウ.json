[
  {
    "uuid": "861f88ee-04d3-53c1-95f2-eebb6b87a30f",
    "entry": "白毫",
    "reading": {
      "primary": "びゃくごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "whorl of white hair on the forehead of the Buddha, represented by a white precious stone on statues of Buddha",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それ等は丸味を帯びた広い額の白毫の光に反映せられ、反つて艶冶を増す為めか、或ひはそれ等の部分部分にことさら丹念に女人の情を潜ませてあるのか、兎に角、彼は今まで如何なる名匠の美人画にも単なる艶冶や嬌態を示したものに、これほど心を引かれたことはなかつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勢州四日市にて見たる美人三日｜眼前にちらつきたるが其は額に黒痣ありてその位置に白毫を付なばと考えしなり。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷺は燃ゆ、白毫の明る眉間。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地は銀杏の片かげり、また、白毫の濡れ仏。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白毫の右左に、鏨で彫ったような十文字の疵があざやかに見えた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから買った後の九十五体の観音はどうで焼けてしまうのだから、その玉眼と白毫（眉間に嵌めてある宝玉、水晶で作ったもの）が勿体ない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "蠑螺堂百観音の成り行き",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その時、仏、眉間白毫相の光を放ちて、東方万八千の世界を照らしたもうに、周遍せざることなし。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "若も命中して、悪僧の眉間に白毫を刻する如く突立った。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その眉間の白毫や青紺色の目を知っているものには確かに祇園精舎にいる釈迦如来に違いなかったからである。",
              "citation": {
                "source": "尼提",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッと眼を打ってきた白毫色の耀きがあって、思わず彼は、前方の床を瞶めたまま棒立ちになってしまった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はその上にうすい暗みを帯びた藍色にすんで、星が大きく明らかに白毫のように輝いている。",
              "citation": {
                "source": "槍が岳に登った記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に延喜の御門の御代には、五条あたりの柿の梢に、七日の間天狗が御仏の形となって、白毫光を放ったとある。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那には「白蓮会」だの「哥老会」だの「六合会」だのというような、秘密結社がたくさんあったが、その中の「白毫会」という結社には、日本人も会員に加わってい、乞食の上州と宣った人物も（本名は富本雄之進とのこと）鮫島大学も会員であって、支那とそうして日本との間を密行していたそうな。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の観る仏像の白毫はただ白毫光の象徴として存在するのである。",
              "citation": {
                "source": "本邦肖像彫刻技法の推移",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恍々として玄義の如く燦々として白毫のやうに厳として聚ゆる権利の如くあらゆる慧智の王府のやうに偉大なる殿堂は輝いてゐた勝利の山に輝いてゐた。",
              "citation": {
                "source": "傾ける殿堂",
                "author": "上里春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は春日山の麓近くをめぐって、白毫寺へ行く道筋も美しい。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東天金星輝き、下弦の月、白馬峯頭に白毫の光りを添う。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白毫のガラス窓「変だな、君はこの大仏がルパンの仲間だって云うのかね」　警部は冗談だと思った。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はまさか大仏様の額にはめてある厚板ガラスの白毫を見落した訳ではあるまい。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大仏様の白毫が物見の窓になっていようとは、不覚にもまるで気づかなかった。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暫」は桜の木地彫、「助六」は胴がつげ、頭は象牙で扮装どおりの彩色、「矢ノ根」は同じくつげ着色、「不動」はびゃくだんの木地、ところがその額の白毫が問題なのである。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "始は学校で教わったことがあるだろう、白毫というものだ。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏像の命ともいうべき白毫をうばいかえさなければならない。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか十間か二十間も隔てると、もうお互いの姿も見えない白毫の霏々紛々なのだ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もう散り際にある脆い梅花は、それに愕いたかのようにふんぷんと飛片を舞わせて、香わしい夕闇に白毫の光を交錯させた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明りもきわめて鈍く、目をみはればみはるほど、白毫の光が睫毛をさえぎるので、ここはどこかしら？",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の雪、降る雪、そこらの屋根の雪が、白毫の旋風となって眼をさえぎる。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
