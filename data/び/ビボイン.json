        "examples": {
          "standard": [
            {
              "text": "フランス語には、鼻母音という特殊な発音がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、鼻母音の発音が苦手で、何度も練習を繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本語には鼻母音が存在しないため、外国人には習得が難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さすれば一種のン音と見るべきもので、音としては音便によって出来た他の「ん」と同種のものであろう（ンはｍｎngまたは鼻母音一つで成立つ音である）。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "室町時代においては、ガ行音が語頭以外の位置にある時は、今日の土佐方言におけるごとく、その前の母音を鼻音化したのであるから、その鼻母音の影響を受けてｇ音がng音になったものであろう。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
