        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし電灯産業の誕生期、その延長上に家電産業の勃興と軌を一にした電力産業のダイナミックな展開を見ることや、怪しげな銀座ルネッサンス商会の延長上にソニーのオーディオ・ビジュアル全面展開を予想することは、どんな誇大妄想狂にも不可能だったのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどオーディオ・ビジュアルという名の戦場のＶＴＲ戦線で激しい闘いを続けているうちに、両社は共に、急成長した裾野のコンピューター市場を取り逃がした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに立ち上げ時にファイルや命令をメニュー形式で表示してマウスによる操作を受け付ける、ビジュアル・コマンド・インターフェイスと名付けられたＷｉｎｄｏｗｓを志した小さな名残も付け加えられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "深き深き対象に対する愛、それ等の動きをビジュアライズし得る絵画的素質、並、統一し、整理する頭の確かさ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ニホンハ、ビジュツノクニトワカッテイル。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワタシ、ニホンノビジュツヒン、アツメテ、モッテイク。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
