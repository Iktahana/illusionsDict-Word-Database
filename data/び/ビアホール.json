        "examples": {
          "standard": [
            {
              "text": "友人と久しぶりに再会し、活気あふれるビアホールで昔話に花を咲かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ドイツの伝統的なビアホールでは、大きなジョッキでビールを味わい、陽気な音楽を楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末の夜は、ビアホールに繰り出して、美味しいソーセージと冷たいビールでリフレッシュするのが定番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "虚無の歌　　ヱビス橋のビアホールは、省線の惠比壽驛に近く、工場區街にあり、常客の大部分が職工や勞働者であるため、晝間はいつも閑寂にがらんとしてゐるのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
