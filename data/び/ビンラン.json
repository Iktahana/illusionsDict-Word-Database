[
  {
    "uuid": "fa2a805e-ef25-5d5d-8830-d437c0ca2240",
    "entry": "便覧",
    "reading": {
      "primary": "びんらん",
      "alternatives": [
        "べんらん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
