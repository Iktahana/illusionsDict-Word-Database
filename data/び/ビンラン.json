      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "handbook",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "詐欺師や香具師の品玉やテクニックには『永代蔵』に狼の黒焼や閻魔鳥や便覧坊があり、対馬行の煙草の話では不正な輸出商の奸策を喝破しているなど現代と比べてもなかなか面白い。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校便覧の活字も小さいので、眼の近い私には、人の二倍はかかってしまう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "福沢先生その誣罔を弁じ、大いに論者の蒙を啓かんとて、教育論一篇を立案せられ、中上川先生これを筆記して、『時事新報』の社説に載録せられたるが、今これを重刊して一小冊子となし、学者の便覧に供すという。",
              "citation": {
                "source": "徳育如何",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁良が光緒三年（明治十年）にウールジー(Woolsey)のインターナショナル・ローを訳述した時には、さきに用いた「万国公法」なる名称を棄てて「公法便覧」と題し、書中にも「万国公法」なる語を用いずして総べて「公法」と称している。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如く、初め支那において丁良が光緒三年（明治十年）にウールジー（Woolsey）のインターナショナル・ローを訳述した時には、さきに用いた「万国公法」なる名称を棄てて「公法便覧」と題し、書中にも「万国公法」なる語を用いずして総べて「公法」と称している。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて武知先生の塾へ手習に行っていた時、『ちと詩も作ったらよかろう、それには幼学便覧などを見るがよい。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も多くの初学者はまず幼学便覧などにある二字三字の熟語を上下にはめて、それで五言七言の詩を作るのであるが、私はそんな既成の語を綴り合しては自分の手柄にならぬと思い、何か一つ自分のいって見たいと思う事を、字の平仄を調べた上で、自分限りの修辞を以て作ることにした。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬ひ聖経に対する――和讃の形式を模したとしても――或は又修辞上の便覧書であつたところで、更に或は、倭漢朗詠集の前型として、声楽の台帳の用途を持つものにしてからが、短歌の価値の認められ出した事は明らかである。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "（飯島半十郎著『浮世絵師便覧』には国重を豊重となしたり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついで「慶応四年」七月付『兵士懐中便覧』は東北連合軍のため仙台で版行され、これと戦うべき官軍熊本藩の依頼によって大至急で翻訳上梓された『洋兵明鑑』には「明治元年晩冬」の序文が付せられている。",
              "citation": {
                "source": "福沢諭吉",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは市で印刷したので、きつと御参考にもなりませう」　私は机の上に残された「育児便覧」といふ刷り物を取り上げた。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、翌朝「売薬処方便覧」でポリモス錠の処方を調べ、その丸薬には強壮素として亜砒酸の極微量が含まれていることを知った。",
              "citation": {
                "source": "黒い手帳",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め『年鑑』という名にする心算であったが、経費と時間との関係で便覧風の調査が出来にくかったので、もっとアカデミックな名の『年報』としたわけである。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "佃は外套のポケットからかなりの厚みがあるＣ大学便覧を出して、伸子の横に椅子を引きよせた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、考えに捕えられた眼でじっとその眼を見かえしながら、開いたままのＣ大学便覧の上に両腕を置き、のろい口調でききかえした。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性への忠言、産児制限、効用並害悪、良人と妻の便覧、妻の知識、以上五冊の有益なる医学書を最も有効にして無害なる産児制限具の図解カタログとともに無代進呈す。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那関係が四十六位のうちあの便覧に出ている著者は十人位。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "隆ちゃんへは支那語のやさしい便覧すぐ送りましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、それから達ちゃん隆ちゃん、其々新しいポケット型の支那便覧をつけて送りましたから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛生学専門書、薬理学についての著作、外科臨床のための便覧、包帯術について図示した小冊子、である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はラージーの著作のほんの一部しか知らず、しかもそれらは主として便覧である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究者について便覧から得られるものはカリカチュアに過ぎない。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "便覧は多くのばあい単なる編集物である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "二天トイフ印章ヲ用フ」　そのほか、本朝画纂だの、古今書画便覧だの、古画備考だのという画史の記載も、ほとんど、こんな程度のものである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、「本朝古今書画便覧」の、――武蔵、二天と号す。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペン細字の丹精こめた便覧表である。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから次の年表を概念に入れておいていただくと、小説の便覧たるだけでなく、当年の社会激動を観る手引にも、ご便利ではないかとおもう。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ部分的には異説もあることなので、小説にたいする便覧程度でゆるしていただきたい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
