    "definitions": [
      {
        "index": 1,
        "gloss": "Bizen (former province located in the southeast of present-day Okayama Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毎年二月半ばから四月五月にかけて但馬、美作、備前、讃岐あたりから多くの遍路がくる。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明石町の南○明石橋下の一流は、築地一丁目二丁目三丁目を廻りて流るゝ釆女橋万年橋祝橋亀井橋合引橋築地橋軽子橋備前橋小田原橋三の橋等の下の一水に通ずる流れにして、栄橋新栄橋の下を過ぎてこゝに落つるなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが可厭ならお止しだけれど、極った人が出来た上は、片時も、寝衣で胡坐かいた獣なんぞ、備前焼の置物だって身のまわり六尺四方は愚なこと、一つ内へは置けないから、即座帰れ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚の埃を拂ひながら、地名辭典の索引を繰ると、糸崎と言ふのが越前國と備前國とに二ヶ｜所ある。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車案内の細字を、しかめ面で恁う透すと、分つた――遙々と京大阪、神戸を通る……越前ではない、備前國糸崎である。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大石には芸州の浅野が附いている、荒木には備前の池田が附いている。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "君勇が先斗町から呼ばれて行った先は、祇園の備前屋だった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、桑山竹夫が今日仙台からやって来たので、その歓迎の意味もあり、島野の招待で一同ぼそんと備前屋の二階にやって来たわけである。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田はその先輩や友人と一緒に備前屋へ来て、芸者の顔を見た時、ふと、「そうだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――たしか、先斗町の君勇という名の芸者だ」　小田は備前屋のおかみに、「祇園からでも先斗町の芸者はよべる……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、事実に於いて南部高信は津軽為信のために亡ぼされ、津軽郡中の南部方の諸城は奪取せられて居るのみならず、為信数代の祖大浦光信の母は、南部久慈備前守の女であり、以後数代南部信濃守と称して居る家柄であつたから、南部氏の津軽家に対し一族の裏切者として深怨を含んで居る事も無理のない事と思ふ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故管領様｜御内、御同姓備前守様御身寄にござりますか、但しは南河内の……」と皆まで云わせず、「備前守弟であるわ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御当家木沢左京様、又丹下備前守様御弟御さまほどの方々に対して、臙脂屋｜虚言詐りは申しませぬ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵愈々逼りたれば吾が兄備前守」と此処まで云いて今更の感に大粒の涙ハラハラと、「雑兵共に踏入られては、御かばねの上の御恥も厭わしと、冠落しの信国が刀を抜いて、おのれが股を二度突通し試み、如何にも刃味｜宜しとて主君に奉る。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、兄が殿様から拝領した備前長船の名刀じゃ、妖魔も此の霊徳には叶わないと思われる、今晩は是非夜伽をして、もし現れたら、一刀に斬って退治いたそう」　庄左衛門が主君から長船の刀を拝領したのは、平太郎も知っていて竊に羨ましく思っているところであった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もともと出鱈目と駄法螺をもって、信条としている彼の言ゆえ、信ずるに足りないが、その言うところによれば、彼の祖父は代々｜鎗一筋の家柄で、備前岡山の城主水野侯に仕えていた。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして岡田宮というお宮に一年の間ご滞在になった後、さらに安芸の国へおのぼりになって、多家理宮に七年間おとどまりになり、ついで備前へお進みになって、八年の間｜高島宮にお住まいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき天皇はそのころ吉備といっていた、今の備前、備中地方の、黒崎というところに、海部直という者の子で、黒媛というたいそうきりょうのよい娘がいるとお聞きになり、すぐに召しのぼせて宮中でお召し使いになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長からの数々の進物に対して、長政は、家重代の石わりと名づけたる備前兼光の太刀を贈った。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "また兵学に精通し、敬神家で、槍は一代に冠絶し、春日の名槍を自在に繰り、剣をよくして、備前｜長船小豆長光二尺四寸五分の大刀を打ち振うのであるから、真に好個の武将である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此夜、十二時近くなって、戦線に到着した窪田備前守麾下のフランス伝習隊は、幕軍の精鋭で、目覚ましき奪闘をなし、薩藩を破り長州勢を破り、墨染まで北進したが、薩兵の伏に陥り、備前守が討死したため、遂に退却した。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "備前鍛冶、三條｜小鍛冶などがそれである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職講習会へ来ていた備前の国幣中社安仁神社の禰宜太美万彦と云う者が、某日一人の伴とともにやって来た。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "備前の国赤磐郡太田村大字万富小字梅という処に山形尊と云う盲人があった。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二　いま一度、私は瀬戸内海の島に渡つて行つたことがある、備前の宇野港から數里の沖合に在る直島といふのへ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "また備前国｜邑久郡朝日村の飯盛神社は、旧藩主の崇敬厚かりし大なる塚を祭る。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "本多〔静‖六〕博士は備前摂播地方で学術上天然植物帯を考察すべき所は神社のみといわれたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
