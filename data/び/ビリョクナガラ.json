    "definitions": [
      {
        "index": 1,
        "gloss": "to the best of one's meager ability",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
