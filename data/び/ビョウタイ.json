[
  {
    "uuid": "27772638-5fb4-5207-a9ab-29bd852d2f56",
    "entry": "病体",
    "reading": {
      "primary": "びょうたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
