    "definitions": [
      {
        "index": 1,
        "gloss": "downtown high-rise area",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
