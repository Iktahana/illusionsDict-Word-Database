[
  {
    "uuid": "70be0cc4-02cf-51c6-a250-ce41cb9f5fd8",
    "entry": "病棟",
    "reading": {
      "primary": "びょうとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
