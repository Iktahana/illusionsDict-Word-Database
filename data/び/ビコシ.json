        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ときどき、そりは、はねあがりましたが、それは堀や生垣をとびこしているようでした。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "安心して手をゆるめると、倭文子はそれを待っていたように、必死な力で宮田を振りはなして、またひらりと石堤をとびこして、岩の上に飛び降りた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "初日の入場料のあがり高は、四十五万円もあって、六さんの胸算用をはるかにとびこした。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の人民的文化の下地の具体的条件をとびこして、せっかちに、まるで新しい「新しい文化」の発見にあせっているところもある。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大戦中から、ソヴェト文学が世界にもちはじめた読者との関係は、前時代のこの段階をとびこした。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢于仁は少年期をとびこして、いつしか立派な青年となっていた。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代をとびこして今日の私たちの心をしっかりととらえる情熱を傾けて、いずれもその作家たちの代表的な作品として生み出して来ているのである。",
              "citation": {
                "source": "若き精神の成長を描く文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しばらくすると、またへいをとびこして行ってしまいました。",
              "citation": {
                "source": "うぐいす",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私たちが、そういう場所にありがちな事もなげな気安さで、七年間の年月をとびこして話をしてると、帳場の障子蔭から顔をだしてじっと私の方を眺めてる日本髪の少女があった。",
              "citation": {
                "source": "常識",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "島村は物にこだわらない呑気な性質から、一年間の年月も種々な事件もとびこして、その方へ歩み寄っていった。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸進的な段階を飛びこした革命的な政治理論は議会とは別のところに存在する。",
              "citation": {
                "source": "咢堂小論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その砲弾は、鉄水母にあたらないで、その上をとびこし、はるかむこうの海面に背の高い水柱をつくった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "海底の丘をとびこして艇は必死に飛んで逃げる。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "多忙の庄吉は稀にしか現れないが、その時間を飛びこして、何十日目に現れても昨日の続きでしかないやうに太平の横へドッカリ坐る。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて中腹の一番大きなクレヴァースに達する、思いきって飛びこしたら訳はなかった、深さは三百｜米突、一番多く人間を呑んだクレヴァースだそうな。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮なしに裏口へ廻ると、牧場の柵になっている、見当がつかないから、それを飛びこして南へ南へと登って行った。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "房吉は逃げるとみせて、かいくぐり、敵の後へ走って竹矢来をとびこした。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に見事にとびこしたのだが、運のない時には仕方がない。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とびこした竹矢来の外側が深田であった。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹矢来に手をかけたとたんに物の見事に五、六間も外の方へ跳びこしていたてえのだが、そこが深田とは因果の話じゃないか。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロケットは、たいへんのりごこちがよく、見る見る空中にとびあがり、雪をかぶっている山の上をとびこし、それから、緑のもうせんを、きちんと、ごばん目にしきつめたような緑地帯の上をはしりぬける。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じッとしてさえ居れば、あいつは気がつかないで、僕たちの頭上を飛びこして行っちまうだろう」「うん。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをとびこして駈けだすと、路地を曲るころになって、ドロボーという女の叫び声が後にきこえた。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどこそだいじょうぶ、と思ったときには、子ジカはしげみをとびこして、どこかへすがたをけしてしまっていました。",
              "citation": {
                "source": "にいさんと妹",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し大きくなつてからは、この石をとびこした。",
              "citation": {
                "source": "石",
                "author": "平山千代子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、橋のまぎわまで来ると、はたと立ちどまり、不意をくらって乗り手はあやうく馬の頭をとびこして手足をひろげたまま投げだされそうになった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "はしっこいジャックはしっこいジャック、すばやいジャック、ろうそくたて一つ、ジャックがとびこした。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、溝のところまで行くと、さすがにそれを飛びこしかねたらしく、そこに立ち止ったまま、いつまでも口ぎたなく勘作を罵っていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの殿様もいやだ、この殿様もいやだというところを、ちょいと一つ飛びこして、この世の中全体に、見切りをつけて見る気には成れないものかね。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
