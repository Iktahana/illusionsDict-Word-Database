[
  {
    "uuid": "b3f3e6ee-81d9-5e2b-8c1b-b8e67118537e",
    "entry": "描法",
    "reading": {
      "primary": "びょうほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
