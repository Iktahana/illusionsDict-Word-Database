        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「なんだよ」「坐れよ」と高志が、となりのイスの黄色いビニールを平手で叩いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この東芝盤は、会社が「エバークリーン」と呼んでいる、静電気の起こらない盤で、赤い塩化ビニールを使っていたために、俗に「赤盤」と呼ばれて、未来の中古屋でご大層な値段をつけられることになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一も起きあがり、はだしのままビニールタイルの床を歩いて、インターフォンのまえにいき、呼出しスウィッチを押した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一もはだしで、ペタペタとビニールタイルの上を歩く。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロッカーには、大きなビニール袋が入っていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊べるぜ、あいつは」　ビニールレザーのギター・ケースを肩にかけ、慶一は柾生たちをうながした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高志兄さん、わたしがここに入ることも、反対だったんです」　中央の正面口から射しこむ西陽が、ビニールタイルの床で反射して、慶一の右側を歩きながら、こちらを見た令子の顔を、やわらかい光でつつみこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志はなにもいわず、ゴミ袋にメロンの皮と紙の皿を放りこみ、令子は果物ナイフを鞘にしまい、まな板をビニール袋に入れた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まいった、まいった」　東屋に入ると、ビニールコーティングした敷物を投げだし、高志が笑った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三脚のキャスターもガタがあるし、床のビニールタイルも移動撮影など考慮していないので、カメラが搖れる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いビニールレザーでおおわれている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーナツだの、サラミだの、なんだかわからないゴミだのが散乱し、ウィスキーやらビールやらが、なかば乾いてビニールタイルにへばりつき、テーブルやイスは、立っているものでさえも、あちこち勝手な向きをむいている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "はんだ付けをした箇所やビニール線の確認、次に電源をチェックしていく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが、奥さんの取ったものです」　原田医師がビニールの覆いを取ると、瀬戸引の盤の中に大きな肉塊が現れる。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビニールを溶かしこんだといふ窓硝子は、むろんその一枚々々の数も配置も正確に原型に従つてゐるのが、とりわけ手際よく素人眼を驚かせるに充分である。",
              "citation": {
                "source": "オルゴール",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サト子は、ビニールのネッカチーフに包んだ暁子からの預りものを、ぎゅっと胸のところへおしつけ、風に吹き飛ばされながら、八丁目から六丁目までの間を、いくども往復して時を消していたが、なかなか時間が経たない。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを、あなたに渡してくれとおっしゃって……」　サト子は、ビニールのネッカチーフに包んだ預りものを、愛一郎の手のなかにおしこんだ。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ内容は同じだけれども、包装が違っていて、昔はハトロン紙で包んだものを、今はビニールやポリエチレンでくるむというようなことだ。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮒の子を持つて來たんですけれど、池ん中に手網を入れてすくつて見ても、すぐ水が濁つてしまつて鮒の子がどこにゐるのか、判んなくなつちやつたと言ひ、ビニールの袋を差し出して見せたが、中には瘠せた鮒の子が、たつた五ひきしかゐなかつた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前後から、ビニールの疑似餌がうまくできているが、やはり本物にはかなわない。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありふれた身の回りのものがいつもの手触りを失ってビニールでできているようなつるつるの表面になってしまうのである。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃では、ビニール塗料などのような、素人にも用いやすい種々な塗料が出来ていて、いわゆるペンキ塗り作業でも、おもしろいほど、誰にもやれるからである。",
              "citation": {
                "source": "押入れ随筆",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いビニールの雨傘が揺れもせず私鉄の駅に向う道を遠ざかるのを、私は窓から見ていた。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妻と、姪と、ほかに四人のお手伝いがあって、合計六人で着手したが、テーブルの上にビニールの風呂敷を敷いて、一枚一枚、ビロードの布でふくのである。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔はみな、例の透明なビニールの仮面をつけていたことがあとになってわかったが、遠目には、透明仮面は少しもじゃまにならないで、あからさまな五つの美女の顔が、岩はだに密着していた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面がゴムあるいはビニールでおおわれているらしく、なめらかで弾力があり、どういう仕掛けなのか、それには体温さえもあった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面の壁といっても、そこもゴムかビニールの巨大なる曲面におおわれていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより底のほうにぼんやり見えていましたのは、ビニールの作りものにすぎません。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マネキン人形は鋸屑と紙を型にはめて、そとがわにビニールを塗るのですか」「そういうのもあります。",
              "citation": {
                "source": "悪霊物語",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち上ると自分の服を脱いだ場所にかけて行き、小さな平たい板と小刀と、ビニールに包んだ味噌らしいものを持って戻って来た。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
