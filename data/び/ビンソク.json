    "definitions": [
      {
        "index": 1,
        "gloss": "quickness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "親切・丁寧・敏速でなくてはいけぬと、監督は口癖だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本民族の趣味は確実に、敏速に低下して行きつつ在る。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その指先は白い一本の絹のように小刻みに、敏速に、神経的でしかも恐怖的な顫えを顫えつづけていた。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはホームズに、彼の敏速な推断を下す材料を与えたものだったのだが。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "霽波が戸を叩くと、小さい潜戸を開けて、体の恐ろしく敏速に伸屈をする男が出て、茶屋がどうのこうのと云って、霽波と小声で話し合った。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部落の間を通り拔けやうとすると、なんと敏速に逃げ出したことか、家といふ家がみな戸をあけすてたまゝ、屋内には早や一個の人影をも留めてゐなかつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "サヨナラ」　曼陀羅院長は田宮課長の敏速な手配にもかかわらずトウトウ捕まらなかったらしく、今日の日が暮れるまで何の音沙汰もありませんでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私はおそらくその刹那に、彼女の全身の、空想する限りの魅力に富んだ裸体像を神業の敏速さで彫刻し――おゝ恋といふよりもたゞそれだけのことかと唸つた。",
              "citation": {
                "source": "タンタレスの春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に迫つて來る夕闇のなかに、誰一人口をきくものもなく、いくつもの手先はただ機械的に敏速に動いた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙に乘じての青年たちの敏速な行動であつたのである。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら經驗を積んでも敏速に行かぬものもあるが、お道のは熟練といふよりは勘のするどさだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事に敏速であることは鑑定官の生命であり、誇りだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもはあんなに敏速に一つの荷を捌いて行く鑑定官の手が、容易に今の包を行かしめようとはしないのだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介は若々しく激して來てゐる自分から相手を考へてゐたのだが、伊貝のみならず一般に六十歳を越えたやうな田舍の老爺は、さう敏速に、小刻みには相手の言葉に對して感情の上に反應は示さぬ、彼等の神經がさうだといふのであらうか。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、既に十分の技術をもっている作家が、刻々に推移してしかも一般人の生活の歴史に重大な関係をもつ社会事相に敏速に応じ、それを正当な方向において、歴史の意味するところを報告し、より正確で深い人間性に迄ふれて一般人に各自のおかれている現実関係を理解させようとする任務を持っている。",
              "citation": {
                "source": "明日の言葉",
                "author": "――ルポルタージュの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｋ―はＴ―とは、似ても似つかない、栗鼠の敏速さで、出て行つた。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の科学の能力を最大限に発揮して刻々に活動している機械の速力、能率、音響、あらゆるものが、その機械を支配し操って働く者に、精神と肉体の極めて節約整理された敏速さと合理性とを求めており、それが可能な一定の近代工業のリズムを必要としている。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも敏速な犯罪のために、亡父殺しの犯人は分らなかったばかりか、或る国際事情のため、領事が暗殺されたことを発表しかねたので、駆けつけた副領事の計いで、即時死因を脳溢血とし一般に知れわたることを防いだ。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "例のイワン・アントーノヴィッチが極めて敏速に事務を遂行して、売買証書は登録され、日附が入れられ、台帳及び所定の場所へ記中されたが、〇・五分の登記手数料と、官報への公告料を課されたきりで、チチコフの出費は極めて小額で済むことになった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうすればいいのか……」　澄みきった頭の働きは敏速だった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に第六感が煌々と、サーチライトを見るように輝き出して、事件の焦点を照し出したり、行くべき方向を示したりするから、それに依って猶予なく敏速な活動を開始する事が出来る。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢の中で頭脳が如何に敏速な活動をなすかを、心理学は証明する。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "解放運動の一環としてのプロレタリア文化運動、芸術運動を、常に革命運動の全体性との関係において実践して行きつつ、客観的現実に対する正しい政治的把握から芸術理論の発展の萌芽を敏速にとらえ、その展開、押しすすめのためにあらゆる国際的な経験を精力的に摂取し、批判し、具体的な文化闘争の実践の中に活かした。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近も雑誌が製本屋へ廻ったとき狙われはじめたことがわかったので、勉は機会をうかがい敏速に数百部の雑誌を運び出してしまった。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法水は背文字を敏速く追うていって、しばらくの間、紙と革のいきれるような匂いの中で陶酔していた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは自分でも「正直のところあまりびっくりしてどうにも足が動かなかった」と告白しているとおり、この一種形容できない白昼の驚怖感が、刹那彼の神経を萎縮させて、とっさの判断、敏速｜機宜の行動等をいっさい剥奪し、呆然として彼をいわゆる不動｜金縛りの状態に、一時｜佇立せしめたのだと省察することができる。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ２１は、その有てるすべてを彼らに与えて、彼らから聴き出した知識を逐一もっとも敏速に通牒せよ――そして、一つの注意が付加された。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし七人が心身を一にし、一致の行動をとるのであるから、自由の活動、敏速の歩行、これは出来るに相違ない。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「語られる言葉」の心理的効果に敏速な判断を加へ、一方、その効果の表示に適切な機会を与へることである。",
              "citation": {
                "source": "対話させる術",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
