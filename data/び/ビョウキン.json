    "definitions": [
      {
        "index": 1,
        "gloss": "pathogenic bacteria",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
