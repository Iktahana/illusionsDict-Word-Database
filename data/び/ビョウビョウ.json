[
  {
    "uuid": "037d6126-05b5-5312-a01f-ec90f6c4b0b3",
    "entry": "渺々",
    "reading": {
      "primary": "びょうびょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
