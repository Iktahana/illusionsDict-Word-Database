    "definitions": [
      {
        "index": 1,
        "gloss": "White Tiger (Taoist god said to rule over the western heavens)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "はたその老齢の故に、白虎と称えらるる偉匠である。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は、白虎隊のひとりで、若くして死んだ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白虎隊は、ちがうね。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さちよの祖父が白虎隊のひとりだったことを数枝は、さちよから聞かされて知っていた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白虎隊は、ちがふね。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さちよの祖父が白虎隊のひとりだつたことを数枝は、さちよから聞かされて知つてゐた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の青龍、白虎等の四神を頭に付けた鋒、錦の旗、榊の枝、其他｜御酒錫、供餅などを持つた人々が嚴肅に石段の上に並ぶ。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『白虎通』に、社稷に樹あるは何の故ぞ、尊んでこれを識して民人をして望んでこれを敬せしむ、これに樹うるにその地に産する木をもってす、とある由。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "『西京雑記』にいう、東海の黄公少時｜幻を能くし蛇や虎を制するに赤金刀を佩ぶ、衰老の後飲酒度を過ぐ、白虎が東海に見れたので例の赤刀を持ち厭に行きしも術行われず虎に食われた、年老の冷水でなくて冷酒に中ったのだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、〈近代｜阿蘭陀の献る遍体黒白虎斑の馬あり、馬職に命じてこれを牧養せしむ、馬職これに乗りこれに載す、ともに尋常の馬に及ばず、ただ美色と称うのみ、あるいは曰く騾の族なり云々〉と。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この墓と会津の白虎隊の墓とは、わたしに取って思い出が多い。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は承知してすぐに「維新前後」（奇兵隊と白虎隊）六幕を書いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の奇兵隊の方は現存の関係者が多いので、すこぶる執筆の自由を妨げられたが、後の白虎隊の方は勝手に書くことが出来た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは一昨年会津へ行って、かの白虎隊の史蹟を多少しらべたことがあるので、それはどうだろうと言うと、川上は結構ですと直ぐに同意して、それを六幕ぐらいの通し狂言に脚色してくれと言った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰義隊と白虎隊では佐幕党ばかりで取合わせが悪いので、前に長州の奇兵隊をかき、後に会津の白虎隊を書いて「維新前後」という題にしてはどうだと言ってやると、川上はまたすぐに飛んで来て、なにぶん頼むと言った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この墓と会津の白虎隊の墓とはわたしに取って思い出が多い。",
              "citation": {
                "source": "春の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "教頭はお得意のいい声で、その郷里の白虎隊の詩を吟じた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "廟に於て女を壻に渡す理由として、『白虎通』に次の如く説明してある。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "故告禰也（清の陳立『白虎通疏證』卷十、嫁娶）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し廟見未了の間に、女が病死すると、その生家に歸葬し、廟見後に病死すると、その新夫の家で死事を行ふ（『白虎通疏證』卷十、嫁娶の條參看）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『白虎通』に杖を用ふる禮制を説明して、所以必杖者。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "故杖以扶身（清の陳立『白虎通疏證』卷十一、喪服）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "女如也（『白虎通』）。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "不學事夫（『白虎通』）。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、ご安心なさい、ぼくは三害をのぞきましょう」　周処は南山へ行って白虎を殺し、長橋へいって赤竜を殺し、自分は品行を正しくして村のために善事をつくした。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "主屋と離なれ別棟があり、白虎造りを為している。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
