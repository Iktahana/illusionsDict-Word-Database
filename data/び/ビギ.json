    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beautiful maiko or geisha",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先斗町の美妓君勇、意外にも小郷殺しを自白……」　こんな見出しだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い美妓もあり、座持ちのうまい年増もあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "美妓の巧笑に接して、だまっていた。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の美妓も数多見えた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて酔が廻り、美妓が舞うにつれ一座は、一段と浮かれ、「とんとろ／＼、とろゝなるかまも、とろゝなる釜も、湯がたぎる、たぎる、たぎるやたぎる」と、謡ったところ、釜の蓋もわきかえり、拍子を合せるようであったと云う。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に北方より五百商人その国へ馬売りに来り、都に名高き五百妓を招きスチャラカ騒ぎをやらかしけるに、商主一人少しも色に迷わず、夥中最も第一の美妓しきりに誘えど、〈我邪念なし、往返徒労なり〉と嘯いたとは、南方先生の前身でもあったものか、自宅によほどよいのがあったと見える。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "東坡曰く、美妓房、象牙床、玻瘡腿、婦人陰、※子嘴と（『続開巻一笑』一）。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蘇小小というのは君も知っているだろうが、唐代で有名な美妓で、蘇小小といえば芸妓などの代名詞にもなっているくらいだ。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、心の中で、金で購った新橋や赤坂の、名高い美妓の面影と比較して見た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は山北の芸妓で、折々違つた男と湯治に来るが、その町では評判の美妓なのに、何故定つた旦那が無いのだらうなどと、女中は不思議がつたりした。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、心の中で、金で購つた新橋や赤坂の、名高い美妓の面影と比較して見た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "樽野は隅の方で稀に見るのであつたが、実父も舅も彼等と同じ位置、気位ひで同じやうに反り身になつて美妓に煽がれながら、口にする金額は悉く万円、千万円といふ巨額を棒片のやうに振り回しながら諸々の手配りに余念がなかつた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの階上の裏側の窓から新橋の美妓諸姉の夕化粧の艶姿がみえるとて、若いものたちが事に託してかいまみたものだとて今日の古老のうちあけ話である。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の姿形は更なりその顔の味からいっても、二た昔前の美妓の写真と今日のモダン美人との顔では美しいということは同じでもその美の味に深浅、渋甘、の大きなへだたりがある。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "某君は酒席などで、酔余の饒舌のうちに、若い美妓なんかに対して、往々変なことを口走る。",
              "citation": {
                "source": "「沈黙」の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、彼の目には、江戸｜生っ粋の美妓たちも映らぬ――耳にいかなる歓語もひびかぬ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は総理大臣が美妓を物にしようとフラれようと生れつき関心の持てない方で、貧乏な大学生が下宿の女中とうまくやつたり八百屋のオヤジが三銭五厘の大根を三銭にまけてやるぐらゐでどこかの女中やオカミさんとねんごろになつたりするのばかりが羨しいタチなんだよ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつにどうも癪に障るが、その晩の芦洲の口演を、ヂッと楽屋で聴いてゐると、その描写の巧さ、義賊も侠客も御家人も美妓もみな宛らの浮彫りで、つい給金を呉れない不平など忘れてしまふ。",
              "citation": {
                "source": "落語家温泉録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "外人専門の米軍許可を得ている美妓のいる堀ハウスにもいって見たのである。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "美妓のお酌に盃は廻され、その飲みっぷりの美事なこと、赤い唇にグイグイと酒は流れ込む。",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の美妓名媛の摘む花われもまた野に行かば同じくこれを摘むことを得ん。",
              "citation": {
                "source": "矢立のちび筆",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "また※郡の元参軍などと、美妓を携えて晋祠などに遊んだ。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大連の電気遊園という美しい遊園地の登※閣という料亭で、満日社長松山忠二郎先生ご夫妻に招待され、Ｔ主筆夫妻やＳ社長秘書夫妻と共に僕達夫妻は北京料理を味わい、大連における中華民国美妓の斡旋を受けその歌を聞いたことは快いことであった。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡弓を弾く男が、一向感興が無さそうに、ウソウソと外見をしながら高調子に胡弓を弾くと、美妓達が一人一人その前へ行って突立ち、これは迚も熱心に、力一杯、咽喉一杯の声を張り上げて――恰度、小学校の生徒が唱歌の試験でも受けているような具合に――歌う様子が僕達には珍しかった。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの酔客通人を乗せて隅田川へ漕ぎいでた屋根舟に、万緑叢中紅一点、婀娜な柳橋の美妓があった。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "と――かの美妓、尾籠な話だが、急に尿意を催してきた。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "美妓だろうが、名妓だろうが、こればかりは仕方がない。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "……水のような夜風と、船べりを洗う川波と、熱い頬と頬を寄せて胸ときめかせながら写し絵の濡れ場に見入っている役者のような若旦那と柳橋に艶名高いうら若い美妓と、その時堅川の方へは星が一つ、青い尾を曳いてながれたろう。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "白面の一書生にして都下第一の美妓を贏ち得た恒川陽一郎も男子の本懐なら、当夜の小山内氏の如きに至つては正にそれ以上のものではないか。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、又次郎は再びぎょっとした。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
