          "literary": [
            {
              "text": "聖ファビオラ―キリスト教の博愛主義　ガレノスその他が記載しているイアトリアとか医学旅館は入院患者の為ではなく外来患者を引き受けるためのものであった。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教時代のローマにおける最初の病院は金持ちの婦人ファビオラが４世紀末に作った。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また少年たちにクラボやビオラを弾奏させて喜んだ。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
