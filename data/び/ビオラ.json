        "examples": {
          "standard": [
            {
              "text": "オーケストラで、ビオラ奏者が深みのある音色を奏で、楽曲に彩りを添えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、幼い頃からビオラを習っており、その繊細な演奏は聴く者の心を打つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ビオラは、ヴァイオリンよりも少し大きく、チェロよりも小さい弦楽器だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "聖ファビオラ―キリスト教の博愛主義　ガレノスその他が記載しているイアトリアとか医学旅館は入院患者の為ではなく外来患者を引き受けるためのものであった。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教時代のローマにおける最初の病院は金持ちの婦人ファビオラが４世紀末に作った。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また少年たちにクラボやビオラを弾奏させて喜んだ。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
