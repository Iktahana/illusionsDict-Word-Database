        "examples": {
          "standard": [
            {
              "text": "季節の変わり目になると、鼻カタルに悩まされて鼻水が止まらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軽い鼻カタルだと思っていたら、その後ひどい熱が出てしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "医師から鼻カタルと診断され、点鼻薬と内服薬を処方された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "医者に診て貰ふと鼻カタルだと言はれた。",
              "citation": {
                "source": "発病",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は元来、甚しく鼻カタルを起し易いタチで、鼻が乾いた時にはテキメンにやられるのが習慣であるから、年中、四半分ぐらいずつ風邪気味に、自然の天恵によって鼻がぬれているような体質なのではないかと思っていた。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻カタルをフランスでは脳カタルと云うそうだが、私には、どうもその言葉の方が適切だ。",
              "citation": {
                "source": "人生三つの愉しみ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
