        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼等は、ビンタを殴ったり、殴られたりはしたことがある。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双方共に立派な男だ、ケチビンタな神経衰弱野郎、蜆貝のような小さな腹で、少し大きい者に出会うと些も容れることの出来ないソンナ手合では無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿面冠者も独眼竜も立派な好漢だ、ケチビンタな蜆ッ貝野郎ではない。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども毒飼は最もケチビンタな、蝨ッたかりの、クスブリ魂の、きたない奸人小人｜妬婦悪婦の為すことで、人間の考え出したことの中で最も醜悪卑劣の事である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人勅諭を日毎夜毎暗誦させて、それが出来ないとビンタを食わしていた将校たちは、遠い島々で、戦局が絶望になるとさまざまの口実をこしらえて飛行機で本国に逃げ帰った。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍隊式というのは、入って来るやいなや、些細なことをきっかけに先ず、ビンタをくわせ、ここをどこだと思っていやがる。",
              "citation": {
                "source": "本郷の名物",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍隊のビンタは、個人の自尊心、個性の自覚、個人の権利の観念を、その頭からはたき出すために行われた。",
              "citation": {
                "source": "誰のために",
                "author": "――インテリゲンツィアと民主主義の課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のインテリゲンツィアは、こういう留置場の皮帯も、軍隊のビンタも、すべてを直接に、或は間接に肉体にうけて生活して来たのであった。",
              "citation": {
                "source": "誰のために",
                "author": "――インテリゲンツィアと民主主義の課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる人民が上官から憲兵から特高からその肉体の上にくらったビンタとちがったビンタが、文学者のために用意されていたでしょうか。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな岡田はある朝、前の野営地に自分の飯盒をおき忘れ、分隊長に両ビンタを食い、その昼、みんなの食事をぼんやり眺めさせられるような刑罰を受けた。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつのビンタを張った時には可哀そうだとも何とも思わなかった癖に。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母はピシッと私のビンタを打った。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ビンタばやろかいッ！",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が、その母の前で、巡査にぴしぴしビンタを殴られていた。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は闇雲に、巡査に、ビンタをぶたれていた。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪で熱が出て扁桃腺が膨れていたところをビンタをくったので耳へ来て、二日ばかりひどく苦痛を訴えた。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に先生はアキ子の両頬をパチパチ二十ほどビンタをくれると、キャアーッと泣きだす。",
              "citation": {
                "source": "遺恨",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな性質だから、ビンタがなきや兵隊ぐらしも捨てたものぢやないなどゝ内々気楽に思つてゐるところへ、特攻隊、まだ死ぬのは早すぎる、まつたく暗い気持になつたが、ヤケ、ヤブレカブレ、飛行機のりになつた時から時々夜中に淋しさ、やるせなさで、ふいに首を突き起して思ひきり怒鳴りたいやうな気持になることがあつた。",
              "citation": {
                "source": "決闘",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろし、オレもやるぞ、さつそく夜陰に窓からぬけだす、ビンタがないから大いに豪快で、淫売宿にナジミもできたが、挺身隊の女工の情婦もでき、女事務員とも仲がよくなり、看護婦にも一人いいのができた。",
              "citation": {
                "source": "決闘",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "色キチガイめ」　若い座員がコッピドク馬吉に往復ビンタをくらわせた。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは元々平和な庶民として育った人で、戦争などが好きな筈はなかったろうが、農村や工場や学校から否応なしに戦野へかりだされて、国民儀礼だの、服従、忠誠などを、ビンタの伴奏で仕込まれた人たちだろう。",
              "citation": {
                "source": "安吾巷談",
                "author": "野坂中尉と中西伍長",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヽ、ちょッと、木村、オレの心臓が、アヽ、いけねえ、ワア、倒れる」　肩幅一メートルの秘書氏がズカズカと歩いて行って、天才詩人氏に横ビンタを五ツ六ツくらわせた。",
              "citation": {
                "source": "カストリ社事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビンタ事件　われわれがアパリへ行った翌日だかに、実に恥しい事件が起った。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病舎を見廻る時には、Ｍ軍医大尉が、ここでの最上級士官としてついて来たが、この朝一つの幕舎から他の幕舎へ行く途中、誠に下らぬことで興奮したＭ大尉は口返答をしたという理由でＡ兵長のビンタを張った。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やってもらいたいね」「おのぞみかい」　四ツ五ツ往復ビンタをくらわせた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の腕がとけたと思うと、往復ビンタを五ツ六ツくらった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンゼルはビンタをくらわせた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
