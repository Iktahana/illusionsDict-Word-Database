        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もとよりニセ物のビザンチン石彫の破片やエトラスカの土焼皿などもあって外人相手の店には違いないがその列んだ品物のなかにこの葡萄の蔓模様の鉄の取手があったのに加奈子は心をひかれた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花に埋められ香をたきこめられてビザンチン型の古い十字架聖像が奥深くすえられてあった。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物｜凡て整ふり、折りめ正しく、ぬめらかに、物の象も筋めよく、ビザンチン絵の式の如。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物凡て整ふり、折りめ正しく、ぬめらかに、物の象も筋めよく、ビザンチン絵の式の如。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬物凡て整ふり、折りめ正しく、ぬめらかに、物の象も筋めよく、ビザンチン繪の式の如。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この下の毛氈だって、これはミシェルがコオラッサンだって持って来てくれたものなんだし、このクションの天鵞絨だって、イギリス人がスキュタリだからどうだとか、ビザンチンがどうだとかいって、かつぎ込んで来てくれたものばかりなのよ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただひとりベニスだけは、ビザンチンの影響をそのまま、十二世紀の姿を残している。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は大理石の石そのままを街としたがごときベニスが、ビザンチンの姿を泛べて海中に突き立っている壮麗な、世界に恐らく類のない街区を見ても、電気のために何の不思議とも感じることが出来なかった。",
              "citation": {
                "source": "北京と巴里（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は多様で燦いているが輪廓が鮮明に動いていないところは、どこやらビザンチン式モザイックの趣があり、過去のロシアの民衆の内部にあった感受性の或る傾向を示すものではなかろうかと考える折があります。",
              "citation": {
                "source": "長篇作家としてのマクシム・ゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立の上で、緑、黄、卵色をよりまぜた有平糖細工みたいなビザンチン式教会のふくらんだ屋根が、アジア的な線でヨーロッパ風な空をつんざいている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "直径が二尺近い盞形をしたもので、外側には露西亜ビザンチン特有の生硬な線で、アイ※ソウフスキーの匈奴族｜馴鹿狩の浮彫が施されていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて見るビザンチン式の建築やモザイクの壁画はゴシツクやルネツサンス式以外に古雅な特色を有つて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとはなれて右手にあるボリス・ゴドノフの寺院のビザンチンのドーム――皆日本人がいつからか知って居る色だ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビザンチン教会の黒い背景、赤い旗。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の美の源泉として最も猛威をふるっているのはギリシャ―ロオマ系と、ビザンチン―ゴチック系との二つであろう。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波が高まるようになだらかに盛りあがっている黄色い枯芝の丘の上に、ビザンチン風の、赤煉瓦の修道院の建物が建っている。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの楼閣のうちには円頂の塔もあるが、これはビザンチンの影響の現われたものといわれている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之によらなければビザンチン芸術も理解出来ないばかりではなく、現代のキュビズムさえが次第に理解出来なくなる。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "広場のつき当りに、一面平らな雪の白さに挑むように、紅白に塗りわけられたビザンチン教会がふくらんだ尖塔と十字架とで立ち、そのかたわらに、こっちの方はしぶい黄と緑で菊目石のようにたたみあげられた古い教会が並んでいる。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "附近の村からはなれて、灌木のしげみにかこまれた小さい空地にある淋しい廃寺で、ビザンチン風のモザイクの壁画が有名だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は城壁内の青草が茂って、ビザンチン式の古風な緑や茶色の尖塔はなかなか趣ある眺望だ。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビザンチン医学　ギリシア医学を現代に運んだ第２の大きな流れは、東ローマ帝国を通っている。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "３世紀からコンスタンティノポリスの陥落（＊1453）までビザンチン医師が絶えることなく続いた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の重要なビザンチンの著者はアエティウスおよびトラレス（＊現在のトルコのアイディン）のアレキサンドロスであった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は５世紀のものとされているディオスコリデスの著作をビザンチンから得ている。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでクリストフは、「ヴォージュ山の彼方のビザンチン式な頽廃的な共和国」にあまり心をひかれなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし繊細な貧血的な身体をし宝石を飾りたててるこのビザンチンの皇后は、軽薄才子、美学者、批評家、などという多くの宦官にとり巻かれていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビザンチン式の論争、永遠にそして単に音楽のことばかりを言う音楽家連中の会話に、彼は悩まされた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマ、アレキサンドリア、ビザンチン、イタリーおよびフランスの文芸復興、大世紀……などの各時代を通ずる放逸のありさまを勤勉に細叙してある小説に、多くの叙情的な称賛の辞が浴びせられていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "第10章　ローマおよびビザンチン時代の後期下降の始まり　ガレノスの死は古代における医学の下降を示しており、この下降はローマ帝国の転覆と同時のものであった。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
