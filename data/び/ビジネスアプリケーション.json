        "examples": {
          "standard": [
            {
              "text": "このソフトウェアは、様々なビジネスアプリケーションとの連携が可能だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クラウドベースのビジネスアプリケーションの導入が、中小企業で進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の会社は、業務効率化のために新しいビジネスアプリケーションを開発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに浜田からは、開発中のＢＰＣ用に本格的なビジネスアプリケーションを書いてくれるソフトハウスの候補を選ぶ作業が加えて指示された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにアメリカでは、八ビットの時代からＯＳへの移行が現実のものとなっており、さまざまな業種、業務をカバーした専門性の高いビジネスアプリケーションが使いこなされてきた事実を、浜田はあらためて突きつけられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本格的なビジネスアプリケーションの開発がすべからくＯＳへの転換を求めるとしても、ユーザー自身にはＯＳを使っていると意識してもらう必要はない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
