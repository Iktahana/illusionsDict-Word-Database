        "examples": {
          "standard": [
            {
              "text": "庭園には、樹齢数百年の立派な柏槙がそびえ立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "柏槙の木材は、香りが良く、建築材や彫刻に使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "盆栽愛好家は、柏槙の美しい樹形を何年もかけて作り上げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "築山の小さな祠や鳥居、赤松や木槲、楓、柏槙、箱根笹、つくばひのそばの土賊、春日燈籠、通草の棚、すべて歌にある。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
