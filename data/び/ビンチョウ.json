        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぜひ備長炭の真っ赤に起こったのを用いるべきだ。",
              "citation": {
                "source": "海苔の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼きのりの専門家は、昔は備長炭であったが、今では電熱器で焼いていることと思う。",
              "citation": {
                "source": "海苔の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は南門の守備長で、いつも鉄槌をひっさげていた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――たッぴつに惜しげなくついだ備長の匂があかるい燈火のなかにうごいていた。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
