    },
    "definitions": [
      {
        "index": 1,
        "gloss": "nimble",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は只コルビエールの敏捷性に驚嘆したばかりであつたので、『詩がない※』なぞと誤つた判断をさへ下したものであつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご承知のやうに、アルテミスは月の女神で、額には青白い三日月が輝き、さうして敏捷できかぬ氣で、一口で言へばアポロンをそのまま女にしたやうな神である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、（見当のつかなかった小僧）が小荷物受渡台の上に彼自身でさえ驚くような敏捷さで、飛び上った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の坑夫たちは、尖ったり、凹んだりした岩角を、慌てないで、然し敏捷に導火線に火を移して歩いた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし外国人の事と云えば、これを紹介し祖述する事に敏捷な人々の多い世の中に、津田君の画を紹介しようとする人の少ないのは不思議である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の行爲は實に敏捷だつた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、まったく翡翠が杭の上から魚影を覗う敏捷でしかも瀟洒な姿態である。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　妾は彼の厚い唇に敏捷に噛みつきながら、「ジョージ、妾の愛の凡てを投げ出しても惜しくない。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "複雑な環境の変化に適応せんとする不断の意識的ないし無意識的努力はその環境に対する観察の精微と敏捷を招致し養成するわけである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　が陳は、敏捷に山崎の前をとびぬけて、猿のように、家と家との間の狭い、暗いろじへもぐりこんでしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、せいが高いので寧ろ痩せて見える敏捷らしい男だった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の悪い、目さきのきく、敏捷な男が、うまいことをやった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、敏捷に、割に小さい、土のついた両手を拡げると、彼の頸×××××いた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きかぬ気で敏捷だった。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻も敏捷な奴で、風が送つて來るものを捕へては貪り食つた。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正確な敏捷さは見ていておもしろかった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警告すると、少年は慌てて向直ったが早いか敏捷に巧い機に竿を上げた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの敏捷さがわれわれの驚嘆の的になるが、彼はまさに前記の侏儒国の住民であるのかもしれない。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれからもきれいとほめられる容貌と毛皮をもって、敏捷で典雅な挙止を示すと同時に、神経質な気むずかしさをもっていた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は夢心地に先程から子供のやんちやとそれをなだめあぐんだ良人の声とを意識してゐたが、夜着に彼の手を感ずると、警鐘を聞いた消防夫の敏捷さを以て飛び起きた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もの馴れた敏捷な所作だった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の横を曲ったお媼さんの俥が、邸をめぐった長い珊瑚樹の生垣に添って走り尽すと、やがて、茫としてつきる処が見えぬほど、広く続いた耕地の中心を一直線に専断した平坦な県道に、敏捷な、軽快な姿を現わすのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "敏捷い事ア狐の様で、どうして喰える代物じゃねえ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　敏捷い、お転婆なのが、すっと幹をかけて枝に登った。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――わッと群集の騒いだ時、……堪らぬ、と飛上って、紫玉を圧えて、生命を取留めたのもこの下男で、同時に狩衣を剥ぎ、緋の袴の紐を引解いたのも――鎌倉殿のためには敏捷な、忠義な奴で――この下男である。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に、自力で起ちあがる腹を決めるのが、夙くから世間へ放り出されて、苦しんで来た彼女の強味で、諦めもよかったが、転身にも敏捷であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子は来る時から、別にここで、根を卸す考えはなく、来た以上は真面目に働いて借金を切り、早く引き揚げましょうと思っていたので、千葉時代から見ると、気も引き締まっており、お座敷も殊勝に敏捷にしていたので倉持にもそこいらの芸者から受ける印象とは一風ちがった純朴なものがあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご承知のやうに、アルテミスは月の女神で、額には青白い三日月が輝き、さうして敏捷できかぬ気で、一口で言へばアポロンをそのまま女にしたやうな神である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このかわいらしい小探偵の、リスのようにびんしょうな活動も、なかなかの見ものでありましょう。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林少年もリスのように、びんしょうでした。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
