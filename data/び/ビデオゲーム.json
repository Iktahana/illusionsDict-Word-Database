        "examples": {
          "standard": [
            {
              "text": "彼は休日のほとんどをビデオゲームに費やし、オンラインランキングの上位を維持している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ビデオゲームの歴史を振り返る展示会では、初期のアーケード筐体が稼働していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「宿題が終わるまでビデオゲームは禁止だよ」とお母さんに厳しく釘を刺された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ジョブスは、アタリ社でやっている単なるビデオゲームには飽き足らぬものを感じていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼネラルインスツルメンツ社がこの年の春からアメリカで売り出していた、ビデオゲームＬＳＩには、テニス、ホッケー、スカッシュ、ライフル射撃、クレイ射撃の六種類のゲームが組み込まれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
