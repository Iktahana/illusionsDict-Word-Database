    "definitions": [
      {
        "index": 1,
        "gloss": "(tear) to pieces",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の正面の壁に子供の小学校の霜降の服と、糊でビリビリの日覆をかけた小学帽とが掛かつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻翼の所はおしろいが剥落ちてゐて、一寸突いたらビリビリと破けさうな感じがする。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲が発射されるごとに、硝子窓は、ビリビリッと震動した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピストルを持った手を壊れた屋根の方へさしあげビリビリッと胴慄いをして、がらくたものが散らばっている街上に重くドシンと倒れた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをジット見ているうちに刹那的に……「嘘を言ってはならぬ」……という気持ちになったので、頭をあげ得ないまま片手を擡げて、今曲って来た横町を指さそうとしたが、その時に、急に胸先がビリビリと痛くなって、全身の血がカーッと顔に上って来るのを感じた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にとってちらと見てビリビリと引き裂いた。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殷々たる――と云うのは都会の雷鳴で――まるで、身体の中で、ひびき渡るような金属的な乾いた雷鳴が、ビリビリと、四辺の空気を震動させた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か書いた物をビリビリ引裂いたらしく、一寸見付からない様な雑木林の根っこへ一面に踏ン付ける様にして捨ててあったものです。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コレコレ……退かんか……」「コラッ……コン外道……」　と二人が声を揃えて怒鳴り付けるうちに一作が、女の襟首へ手をかけると、古びた笈摺の背縫と脇縫が、同時にビリビリと引離れかかった。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう手足の紅色でビリビリします。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　二階の薄汚い彼の居間に入ると、彼は、耐えとおして来た悲しさと口惜しさとを一時に爆発させて、側らの硝子戸がビリビリ鳴り出したように思われるほど、大声を挙げて、泣いて泣いて泣きまくった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日盛りになると彼の焦けた背中は、塩煎餠のやうにビリビリと干からびて水に浸さずには居られなくもあつた。",
              "citation": {
                "source": "スプリングコート",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主は居るか居ないか分らんような人で、お神さん一人で繰廻しているようだったが、快活で、腹の大きい人で、少し居馴染んだ者には、一月二月下宿料が滞っても、宜しゅうございます、御都合の好い時で、といってビリビリしない。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が腰を捉まえた拍子に、ビリビリ音がして単衣羽織が綻びた。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、女はビリビリと声を震わせた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、女はビリビリと声を震はせた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女の手から紙を※り取って、それへ眼を馳せ乍ら、祥子は青白んだ皮膚をビリビリ慄わせた。",
              "citation": {
                "source": "罠を跳び越える女",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それにしても重荷のために背中の皮膚が破れて、ビリビリと焼かるるように水がしみる！",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぞいていた娘はハンケチをビリビリと喰い裂いた。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方が早えや」「アイテテ……又やりやがったな……畜生ッ……こうだぞ……」　って云ううちに、……ギャーッて云う声が室中にビリビリする位響いて来たの。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の全体がビリビリとふるえた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイカの裾が梯子の釘にひっかかって、ビリビリと裂けてしまった。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』って、一字ばっかりの誤字で、ビリビリ目の前で裂いて見せるわ」「……あなた仲よしってないの？",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　狭い室でうしろの窓硝子がビリビリするような大声だ。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法水は眉のあたりをビリビリ動かしながら、「では、古代時計室と拱廊を調べたかね」「ところが、彼処は」と私服は頸を振って、「昨夜の八時に、執事が鍵を下したままなんですから。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船体が、ビリビリ震動して、闇に迫る怪艇の眼から遁れようとした。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、全身にビリビリした神経的なものが現われてきて、それから、瘤の表面をいとしげに擦りはじめた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘田外務大臣はだまってこの通牒を見てしまうと、いきなりビリビリッとまっ二つに引き裂いた。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
