        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――人魚詩社宣言――　遊泳　白日のもと、わが肉體は遊樂し、沒落し、浮びかつ浪を切る。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白日のもと、わが肉體は遊樂し、沒落し、浮びかつ浪を切る。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして胸の鼓動を静めようと考えたわけでもないが、ステッキを両手に突き立て胸を張って深い呼吸をいくたびかついた。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍従は幾たびかつまずきかかって、そのあとを追った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は幾たびかつまずきながらようように駈け寄ると、その勝利者はたしかに半九郎と判った。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆硯益※｜御清適の結果として小生の枕辺に玉稿の山を築きこの冬も大約一万句に達し候事誠に御出精の次第とかつ喜びかつ賀し奉り候。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊長、小頭は配下一同の話を聞いて、喜びかつ悲んだ。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪雲とぢて風冴えぬ、――鳴くねあはれのおとろへに、よろこびかつてあかざりしふしの華やぎ聽きわかず。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜びかつ驚きながら抱擁したが、その唇に最初の接吻をすると、その唇が蒼ざめて死人の色になり、顔つきもみるみる変り、私の抱いていたのは、死んだ母のむくろになっていて、それに屍布が被せてあり、墓の蛆虫がそのフランネルのひだのなかを匍いまわっていた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が波を打って伸びかつ縮んだ。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "武は大声をあげて叫びかつ罵ったが、邑宰は何も聞かないふうで相手にならなかった。",
              "citation": {
                "source": "田七郎",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と刀の束を再びかつぎ上げて本舞台へ）どうなさいました？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大乗起信論を紹介したり、西田哲学を再びかつぎ始めたり、人間学主義を益々徹底して不安の文学を唱え始めたりする。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "親柱は朽ち、針金は錆びかつゆるみ、全体が一方に傾いて、横木や踏板も処々落ち失せた、一髪の釣橋……その蜘蛛の古巣を思わす危橋にゆられて、飛沫を揚げて逆巻く本流を横切れば、路は一転して祖母谷の左岸に入る。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
