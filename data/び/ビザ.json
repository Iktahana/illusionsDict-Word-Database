    "definitions": [
      {
        "index": 1,
        "gloss": "visa",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もとよりニセ物のビザンチン石彫の破片やエトラスカの土焼皿などもあって外人相手の店には違いないがその列んだ品物のなかにこの葡萄の蔓模様の鉄の取手があったのに加奈子は心をひかれた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）併しビザンチニスム、シヨオヰニスム、セルヰリスムなんと云ふのはどうでせう。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大日本帝國ガ國民ト共ニ亡ビザル限リ銀行省ノ預金ニ不安ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "花に埋められ香をたきこめられてビザンチン型の古い十字架聖像が奥深くすえられてあった。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことはない、ラジオでは、ハーパーズ・ビザールの〈フィーリン・グルーヴィー〉が、もうじき終わろうとしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物｜凡て整ふり、折りめ正しく、ぬめらかに、物の象も筋めよく、ビザンチン絵の式の如。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物凡て整ふり、折りめ正しく、ぬめらかに、物の象も筋めよく、ビザンチン絵の式の如。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬物凡て整ふり、折りめ正しく、ぬめらかに、物の象も筋めよく、ビザンチン繪の式の如。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この下の毛氈だって、これはミシェルがコオラッサンだって持って来てくれたものなんだし、このクションの天鵞絨だって、イギリス人がスキュタリだからどうだとか、ビザンチンがどうだとかいって、かつぎ込んで来てくれたものばかりなのよ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただひとりベニスだけは、ビザンチンの影響をそのまま、十二世紀の姿を残している。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は大理石の石そのままを街としたがごときベニスが、ビザンチンの姿を泛べて海中に突き立っている壮麗な、世界に恐らく類のない街区を見ても、電気のために何の不思議とも感じることが出来なかった。",
              "citation": {
                "source": "北京と巴里（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は多様で燦いているが輪廓が鮮明に動いていないところは、どこやらビザンチン式モザイックの趣があり、過去のロシアの民衆の内部にあった感受性の或る傾向を示すものではなかろうかと考える折があります。",
              "citation": {
                "source": "長篇作家としてのマクシム・ゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴィエト・ビザ――旅券の裏書である。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立の上で、緑、黄、卵色をよりまぜた有平糖細工みたいなビザンチン式教会のふくらんだ屋根が、アジア的な線でヨーロッパ風な空をつんざいている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "直径が二尺近い盞形をしたもので、外側には露西亜ビザンチン特有の生硬な線で、アイ※ソウフスキーの匈奴族｜馴鹿狩の浮彫が施されていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "p.279　笞のようにビザンティンの十字架を手にした極悪な狂信的な中世紀の僧侶、恰もそんな風に彼は政治家、宗教的狂信者としてわれわれに向って来るのである。",
              "citation": {
                "source": "ツワイク「三人の巨匠」",
                "author": "――ドストイェフスキーの部（偉大な統一の破壊者、永遠の分裂者としての）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて見るビザンチン式の建築やモザイクの壁画はゴシツクやルネツサンス式以外に古雅な特色を有つて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一朝其品ガ消滅スルニ忍ビザルモノ有ラン。",
              "citation": {
                "source": "阿房山賦",
                "author": "成島柳北",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がややながいこと表紙のいくぶんビザアルな猫の繪に見入つてゐると、「ふふふ、その猫の繪は自分で描いちやつたんだ。",
              "citation": {
                "source": "「青猫」について",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリー語を使ったところ、やっと片言が通じて、私の旅券にはポーランドを通過することが書いてないから、午後一時まで待っていて、チェコのプラーグまで引返して、プラーグの日本公使館でポーランド通過のビザーを記入して来い、というのでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンテはブルネット・ラティーニの記録に從ひ、遷都を三三三年、ユスティニアヌスの即位を五三九年の事とせるなりと〔神の鳥〕鷲〔エウローパの際涯〕ヨーロッパの東端にあるビザンティウム。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "様式はバジリカ風で、エジプト・ビザンティウム式教会の原型的なものである。",
              "citation": {
                "source": "処女の木とアブ・サルガ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとはなれて右手にあるボリス・ゴドノフの寺院のビザンチンのドーム――皆日本人がいつからか知って居る色だ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日やっとビザがもらえた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビザンチン教会の黒い背景、赤い旗。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の美の源泉として最も猛威をふるっているのはギリシャ―ロオマ系と、ビザンチン―ゴチック系との二つであろう。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波が高まるようになだらかに盛りあがっている黄色い枯芝の丘の上に、ビザンチン風の、赤煉瓦の修道院の建物が建っている。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに東の方からはサラセンがはいりこんでくるし、ビザンティン帝国は、変転きわまりないし、自分が作らなくても、考えただけでうんざりである。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの楼閣のうちには円頂の塔もあるが、これはビザンチンの影響の現われたものといわれている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンダア君はビザールという言葉を以てその美しさを形容した。",
              "citation": {
                "source": "墓場",
                "author": "西尾正",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
