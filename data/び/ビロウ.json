        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あすこの坂なら杉の木が昆布かびろうどのようです。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニが斯う云いながらふりかえって見ましたらそのいままでカムパネルラの座っていた席にもうカムパネルラの形は見えずただ黒いびろうどばかりひかっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっくろなびろうどのマントを着て、まっくろなびろうどの股引をはいて居ります。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客はカメラとなって自由自在に空中を飛行しながら生きた美しい人間で作られたそうして千変万化する万華鏡模様を高空から見おろしたり、あるいは黒びろうどに白銀で縫い箔したような生きたギリシア人形模様を壁面にながめたりする。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またわたくしは、はたけや森の中で、ひどいぼろぼろのきものが、いちばんすばらしいびろうどや羅紗や、宝石いりのきものに、かはつてゐるのをたびたび見ました。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またわたくしは、はたけや森の中で、ひどいぼろぼろのきものが、いちばんすばらしいびろうどや羅紗や、宝石いりのきものに、かわっているのをたびたび見ました。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カムパネルラ、僕たちいっしょに行こうねえ」ジョバンニがこう言いながらふりかえって見ましたら、そのいままでカムパネルラのすわっていた席に、もうカムパネルラの形は見えず、ただ黒いびろうどばかりひかっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジヨバンニが斯う云ひながらふりかへつて見ましたら、そのいままでカムパネルラの坐つてゐた席に、もうカムパネルラの形は見えず黒いびろうどばかりひかつてゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（さうだとさ）（蜂雀かが弟なの）（さうだとさ　第一それは女学校だかどこだかの　おまへの本にあったんだぜ）（知らないわ）　　　さてもこんどは獅子独活の　　　月光いろの繖形花から　　　びろうどこがねが一聯隊　　　青ぞら高く舞ひ立ちます（まあ大きなバッタカップ！",
              "citation": {
                "source": "春と修羅　第二集",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり一面まっ黒びろうどの夜だ」「まあ、不思議ですわね。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのきものは草の実でいっぱいですよ」そして王子の黒いびろうどの上着から、緑色のぬすびとはぎの実を一ひらずつとりました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "碧いそら、かがやく太陽、丘をかけて行く風、花のそのかんばしいはなびらや、しべ、草のしなやかなからだ、すべてこれをのせになう丘や野原、王子たちのびろうどの上着や涙にかがやく瞳、すべてすべて十力の金剛石でした。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろのまっ黒なびろうどの幕が両方にさっと開いて顔の紺色な髪の火のようなきれいな女の子がまっ白なひらひらしたきものに宝石を一杯につけてまるで青や黄色のほのおのように踊って飛び出しました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い薄明のなかでびろうど葵の顫へてゐるやうに、やはらかなふらんねるの手ざはりのやうに、きんぽうげ色の草生から昼の光が消えかかるやうに、ふわふわと飛んでゆくたんぽぽの穂のやうに。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳緑のびろうどの河豚責めふくらし昨日も男涙ながしき　こうした歌を校正しているうちにさみどりのちひさ河豚の子上げ潮のしほさゐ安く群るるこの頃という風の歌が出来る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅びろうどのいと黒きつや／＼と胸のあたりに光るとき。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、とちの実を三つ、びろうどのようなつやのある、赤いのと、ぽちぽちのついたのと、牛乳のような白い色をしたのと、その三つをやりました。",
              "citation": {
                "source": "岡の家",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、間もなく、ふは／＼した、緑いろの、びろうどの着物を着た、小さな人が、どこからともなくひよいと出て来ました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお部屋に、長い／＼青いひげの生えた王さまが、緑色のびろうどの着物を着て、帯のかはりに、銀色の蛇をまきつけて、椅子にかけてゐます。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども陛下は、まだおかくれになったというわけではなく、やせほそり、色は青ざめながら、ながいびろうどのとばりをたれて、どっしりとおもい金のふさのさがった、きらびやかなしんだいの上にやすんでおいでになりました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、りっぱなびろうどのとばりの、ひだのあいだには、ずらりと、みなれない、いくつものくびがならんで、のぞきこんでいました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの陛下は、びろうどの玉座に腰をかけて、どうしてなかなかの衣裳もちでしたから、金のかんむりをかぶって、ながいすそを着物のうしろにひいていました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子は、いつまでもじぶんの所にいるようにといって、すぐじぶんのへやのまえの、びろうどのしとねにねることをゆるしました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえの顔がうつくしいように、心もやさしいむすめだったら、わたしはおまえにびろうどと絹の着物をきせて、金のかんむりをあたまにのせてあげよう。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリーザのあつい涙は、お妃の着るびろうどと紫絹の服のうえにながれて、ダイヤモンドのようにかがやいてみえました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までのびろうどや絹のかわりに、エリーザのあつめたイラクサの束がほおりこまれました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日になると、ゲルダはあたまから、足のさきまで、絹やびろうどの着物でつつまれました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅黄絖の引かえしに折びろうどの帯をしめ、薄色の絹足袋をはいた年増姿は、又なく艶に美しかった。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は「石鹸」で洗ったばかりの「かなきん」の襦袢「〔Jiba~o〕」に、「びろうど」Veludo の着物をきていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
