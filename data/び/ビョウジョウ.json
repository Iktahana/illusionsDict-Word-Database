[
  {
    "uuid": "ba3f9081-fb78-537b-aa3e-d241870fd2a5",
    "entry": "病状",
    "reading": {
      "primary": "びょうじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
