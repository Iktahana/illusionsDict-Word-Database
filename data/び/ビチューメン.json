        "examples": {
          "standard": [
            {
              "text": "アスファルトの主成分であるビチューメンは、防水性や接着性に優れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代メソポタミアでは、ビチューメンが建築材料や接着剤として利用されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "石油の精製過程で得られる重質な残留物がビチューメンです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カンバスなどは使わず、黄色いボール紙に自分で膠を引いてそれにビチューメンで下図の明暗を塗り分けてかかるというやり方であった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
