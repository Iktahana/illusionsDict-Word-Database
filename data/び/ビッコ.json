        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しばらくは嘉代吉の肩に凭りかかりながら、徐々と雪田を下った、裾の方へ来ると、水音が雨に伴って、ざわつき出した、くるぶしを痛めたので、跛足をひきながら、石の小舎へ来た。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから毎日日のさす所へとこころざして、市の公園へ跛を引きながら往つて、菩提樹の下のベンチに腰を掛ける。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、叫びながら狂気のように黄は彼女の後を追いかけたが、手擲弾のようなマリの靴を向脛に見まわれて跛をひきながら彼は街路に飛出した。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊場では跛の老夫婦が人形を抱いて踊っていた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローランド・グリーンが南京路を跛をひいてあるいていたと云うものがある。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "憲兵が、横※で跛を引きながら病院へやって来たことを云って面罵してやりたかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "跛や、手なしや、片輪者にせられて、代りに目くされ金を貰うて何うれしいんだ！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっくひょっく跛を引いている者がある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっく／＼跛を引いている者がある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい炭取りくらいの大きさの竹かごを棒切れの先に引っかけたのを肩にかついで、跛を引き歩きながら「丸葉柳は、山オコゼは」と、少し舌のもつれるような低音で尻下がりのアクセントで呼びありくのであった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は、跛を引いて逃げ帰ると、納屋の隅にうずくまって、殴られた足をかばうようにねぶった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二｜馬路通りに、乱れた、元気のない、跛をひくような蹄の音がひびいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬を乗り斃してしまった連中は、跛を引きながら、脚をひきずっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二六　額の禿げ上った、見すぼらしい跛が、炎熱と塵埃にむれている石畳の小路へ這入った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "跛をひきながら、しかも、青年のように元気な足どりで。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　跛の親爺は呼びつゞけた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪らなく痛かったが両親に云えば叱られるから、人前だけは跛も曳かずに痩我慢して痛さを耐えてひた隠しに隠して居ましたが、雑巾掛けのときになって前へ屈んで膝を突くのが痛くて痛くてほとほと閉口しました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様もお母様も花子さんも驚いてみんな表へ出ますと、泥棒のようななりをした大男が犬に食いつかれて跛を引き引き向うへ逃げて行きます。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思ふとけろつとして、お末が帰ると機嫌を取るやうな眼付をして、夕飯前なのも構はず、店に居る力三もその又下の跛足な哲も呼び入れて、何処にしまつてあつたのか美味しい煎餅の馳走をしてくれたりした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒステリーは治つたが、左の口尻がつり上つたきりになつて、底意地悪い顔付に見える母も、頬だけは美しい血の色を見せながら、痩せて蝋のやうな皮膚の色の兄も、跛足でしなびた小さい哲も、家の中に暖かみと繁盛とを齎らす相ではなかつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺の後ろには位牌を持つた跛足の哲が、力三とお末とのはき古した足駄をはいて、ひよこり／＼と高くなり低くなりして歩いて行くのがよく見えた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、肩を持たれたまゝ、右の跛の黒どのは、夫人の白魚の細い指に、ぶらりと掛つて、一ツ、ト前のめりに泳いだつけ、臀を搖つた珍な形で、けろりとしたもの、西瓜をがぶり。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十代の若いときに、劇しい痛風症を煩つて左の足が少し跛となつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方を見せて見物を泣かせる目算のあてはずれ、発奮で活歴を遣って退け、手痍少々負うたれば、破傷風にならぬようにと、太鼓大の膏薬を飯粒にて糊附けしが、歩行たびに腹筋よれて、跛曳き曳き、「あ痛、あ痛。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩が頸より高く聳えて、俗に引傾りと云ふ代物、青ン膨れの腹大なる瓜の如しで、一尺餘りの棚ツ尻、剩へ跛は奈何。",
              "citation": {
                "source": "鑑定",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方へかくれたから、角へ出て見ようと、急足に出よう、とすると、馴れない跛ですから、腕へ台についた杖を忘れて、躓いて、のめったので、生爪をはがしたのです。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の角で、町の角で――　跛ひきひき追えど及ばぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "跛足を曳きながら傍の岩角に跟蹌けかかって、倒れるように腰を卸した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、左の足が不自由らしく、歩くのに跛足をひいてゐた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "横痃の跛足を粧つてゐたのは甚五郎である。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
