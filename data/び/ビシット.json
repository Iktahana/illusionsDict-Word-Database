        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところがこのごろになって浪之助は、何かドカーンと大きなことを、何かビシッと身に泌みるようなことを、是非経験したいものだと、そんなように思うようになった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（上から、花岡の顔や胸をビシッ、ビシッとなぐる。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルリのツルリとキメの細かい青味がかつた頬が、僕の平手打ちの下でビシッ、ビシッと濡れたような音を立てたのを、僕はおぼえています。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩寝る前にビシッと決めてやる」　　　　　＊　古い宮殿のしじまの中に突然、甘く切ない音楽が聞こえた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガイ牧師がビシッと、「来い、なぜ手を貸してくれない」「喜んで手を貸す。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏のふところに、これが、ビシッと応へてるのを知るや。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビシッと衣装を着こなし、絵のように決めている。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、前にビシッと言ったように、お金なしでどうやって逃げるのか。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど刹那には、本能的な一｜鞭がビシッと馬腹を打っていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし太刀と一ツな奮迅も、「死にたいのか、この公卿小僧」　八荒坊がビシッと構えた白木の杖を越えてまでは、どうしても、踏み込めなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊王は、南無三とばかり、そこの境で、牛の尻へもう一ト鞭、ビシッと当てた。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
