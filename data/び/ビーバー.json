          "literary": [
            {
              "text": "――彼女は、隱岐のアメリカの友達から贈られた可成り上等らしいビーバーの外套を持つてゐたが、殆んど手をとほしたこともなく、餘程以前から手もとには無かつた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　ディズニー映画の秘密『水鳥の生態』や『ビーバーの谷』などで代表される、野生動物の中編記録映画には、映画技術の粋がつくされている。",
              "citation": {
                "source": "ディズニーの人と作品",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの日には　みずうみのほとり　ずんぎりやなぎに　お引っこし、　マガモも　ビーバーも　ぶるぶるもの。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六時間後、大変興奮したメッセージが届き、ビーバーのように熱狂的に働いていると伝えてきた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が出かけている間、ピーボディ、シャーマン、ロープス、マクタイ、及びウィリアムスンはレイクの飛行機の中で程度の良い二機を再び飛行可能にしようとビーバーのように働いていた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
