        "examples": {
          "standard": [
            {
              "text": "そのインディーズ映画は、巨大な昆虫と人間が共生する「ビザール」な世界観で一部のカルト的な人気を博した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「なんてビザールな衣装なんだ！これを着こなせるのは世界でもあのアーティストくらいだろう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現代アートの展覧会で、古タイヤを積み上げただけのビザールなオブジェを前に、人々が首を傾げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そんなことはない、ラジオでは、ハーパーズ・ビザールの〈フィーリン・グルーヴィー〉が、もうじき終わろうとしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンダア君はビザールという言葉を以てその美しさを形容した。",
              "citation": {
                "source": "墓場",
                "author": "西尾正",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
