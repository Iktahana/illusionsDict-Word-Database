        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その場合には、甲の頭の中にはちゃんとＡの鋳型のようなものが出来ているので、ＢＣＤの中に、ちょっとでもＡに似たところがあると、その点をつかまえて、Ａの鋳型にあてがって、そうして他の部分をその型に鋳直してしまうらしい。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日に十三日を加えてＡＢＣの数だけねなければ浦潮へ出て行かれない。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（３）ＢＣとＤとの幾分の肖似。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてともかくも、ＢＣという、「次の輪」の見当をつける。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概の場合はＡＢＣやライオンの民衆的なる紅茶で我慢するほかはなかった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もし六五歩と云つたやうな二枚落の定跡のＡＢＣを知らずに、上手と指して勝てる場合があつたら、それは上手がそれだけの力がないので、所謂手合違ひの将棋である。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球滅亡の仕立てとしては、やや情けないこんな出来事から始まる銀河放浪の物語は、もともとイギリスのＢＢＣで、ラジオドラマとして生まれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがベストセラーとなり、ＢＢＣはドラマの続編を作りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校時代の一大イヴェントが、一九七〇（昭和四十五）年の大阪万博で、中学に入ってからは、外国のラジオ番組を聞くＢＣＬのブームにはまります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＢＣの秘密　天気のいい午後であった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＢＣの秘密ってんだよ」「ウン。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍは男のＭで、あべこべにすると女のＷになるってんだ……」「フフフフ、面白いね」「……ね……それからＭはＡＢＣの真ん中にあるから、神様だの、真ん中だの、秘密だの、意味がいろいろあるんだそうだ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＢＣの一件からＭの字の秘密なぞをザッと述べて、もっと詳しくお話を承わりたいと云った。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたの御職業を信じてお話し致しますが……御参考になりますかどうか……」　と田宮先生が話し出した事は、ＡＢＣの話かと思ったら、これこそ又意外千万の話であった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体この興奮曲線の種類に、ＡＢＣ云々と区別することは出来ているのじゃが、Ａは何の興奮、Ｂは何の興奮という風に、全部がハッキリ判っているわけではない。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり手口による犯罪捜査術のＡＢＣを知っている者なら、誰でもそう答えられるのだ。",
              "citation": {
                "source": "探偵小説と犯罪事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――吾等は、月の光の下でも、陽光を浴びながらでも、そしてまた闇の中でも、云ひ得ぬものを持つてゐる、吾等は自らの手で点したる小さな灯火の下でなければ、云ひ得ぬものを持つてゐる――ランプ祭はＢＣ何世紀の頃斯うした人の心持に源を発した若者達の祈りであると伝つてゐる。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美術學校という所は、畫のＡＢＣを教へる所だし、生徒をみんな一様に育て上げるのだから君には向かない。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＢＣＤ包囲陣などを日本に向かってやった所で……　鎧袖一触さ！",
              "citation": {
                "source": "世界の裏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "［第二図］※　　　　　　　８←ハ　　　＿＿＿＿＿＿＿７４Ａ）ＢＣＤＥＦＧ↑↑　　ＨＩＪ２イロ　　　　　↑　　　　　　　ニ　ＡＢＣなどの英字は、まだいくつとも分っていない数字である。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "［第四図］※　　　　　　　８←ハ　　　＿＿＿＿＿＿＿７４Ａ）ＢＣＤＥＦＧ↑↑　　ＨＩＪ２←ニイロ　　―――――　　　　　Ｋ９ＬＭ　　　　　　↑　　　　　　ホ　これについてまず分るのはＤはＪよりも小さいということだ。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十七図Ｓは太陽旋渦、ＡＢＣはそれを囲む球状の固形皮殻。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィタミンＡＢＣでなじみぶかい理研のコンツェルンは、工学博士、子爵大河内正敏氏その他を主として、長野や群馬、新潟などの寒村に、「共同作業場ともいえないくらいの小さな作業場」をつくり都会の大工場で同じ機械を使って造り出す能率の二倍以上の成績を、農村の子女によってあげている。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "読書でも、音楽をきくことでも、演劇、映画を見ることでも、只見聞くという消費的な接触を進めて、自分の心持ちをそのものに向って展いてうけ入れて考えてゆき、自分の生活の実際との結びつきで、いつも咀嚼してゆくということが、大事な心の営養のヴィタミンＡＢＣＤでしょう。",
              "citation": {
                "source": "女性の生活態度",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "森君は、マルクシズムとか、階級闘争とかいろいろの言葉を文中につかっているが、実際はそのＡＢＣさえも理解していない。",
              "citation": {
                "source": "反動ジャーナリズムのチェーン・ストア",
                "author": "――森鶴子君に答える――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月号の『ナップ』に「創作における唯物弁証法的方法に就ての覚え書」を書いた人にとってこんなＡＢＣは理屈としては問題外だろう。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは筆者中條が「無反省的思いあがり」で「ＡＢＣ的観念的批評をやりながら」「おそろしくいい気持で」「傲慢な罵倒」を「小ブル的自己満足」をもってしている。",
              "citation": {
                "source": "前進のために",
                "author": "――決議によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＢＣの関係は計量の関係ではなくして正に順序の関係であるが、それにも拘らずＡＢとＡＣは長さの関係となって現われることが出来る。",
              "citation": {
                "source": "空間概念の分析",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょん髷を剪ったばかりのライブラリアンは、いろは順もＡＢＣ順も、書類の正確な系統さえ念頭に置かなかったように見える。",
              "citation": {
                "source": "蠹魚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
