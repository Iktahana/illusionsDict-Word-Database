        "examples": {
          "standard": [
            {
              "text": "猫額大の絵だが、その中に広大な世界が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の書斎は猫額大のスペースだが、工夫して使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "猫額大の庭に、四季折々の草花が咲き誇る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "吉野川のおほいぬふぐりがその一つだし、今晩帰宅して、猫額大の畑にある高菜に、こまかい蕾がいっぱいついていると聞いたのも、その一つである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫額大にして山中の如し」　ニコニコしている顔に厭味がない。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖国令行われてより以来、我邦と通商するものは、僅かに支那、和蘭にして、その地方もまた長崎の猫額大の天地に限れり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
