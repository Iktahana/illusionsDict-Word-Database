        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白馬岳の又の名を越後方面では大蓮華山といっている、或人の句に「残雪や御法の不思議蓮華山」とあるからは、これも一朶の白蓮華、晶々たる冬の空に、高く翳されて咲きにおうから、名づけられたのかも知れない。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老母は立ち上り部屋の奥に入り、一かかえの白蓮華と一振りの銅刀を持ち出で来り、炉の側に坐る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老女は銅刀で乳房を裂き、白蓮華の一枚々々に乳房の血を塗り、炉の火中にくべる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の池の行水だね、しかし白蓮華は丈高い。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "下山の時の面影は、富士川の清き瀬に、白蓮華の花びらにも似られよとて、切に本腹を祈つたのである。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国境の山、赤く、黄に、峰岳を重ねて爛れた奥に、白蓮の花、玉の掌ほどに白く聳えたのは、四時に雪を頂いて幾万年の白山じゃ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸張を垂れた御廚子の傍に、造花の白蓮の、気高く俤立つに、頭を垂れて、引退くこと二、三尺。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "客人は、堂へ行かれて、柱板敷へひらひらと大きくさす月の影、海の果には入日の雲が焼残って、ちらちら真紅に、黄昏過ぎの渾沌とした、水も山も唯一面の大池の中に、その軒端洩る夕日の影と、消え残る夕焼の雲の片と、紅蓮白蓮の咲乱れたような眺望をなさったそうな。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後を囲つた、若草の薄紫の山懐に、黄金の網を颯と投げた、日の光は赫耀として輝くが、人の目を射るほどではなく、太陽は時に、幽に遠き連山の雪を被いだ白蓮の蕋の如くに見えた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずしも白蓮に観音立ち給い、必ずしも紫陽花に鬼神隠るというではない。",
              "citation": {
                "source": "おばけずきのいわれ少々と処女作",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……白蓮華の莟のように見えました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの白蓮華をまた思いました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あすこだったと思う、紅蓮が一茎、白蓮華の咲いた枯田のへりに、何の草か、幻の露の秋草の畦を前にして、崖の大巌に抱かれたように、巌窟に籠ったように、悄乎と一人、淡く彳んだ婦を見ました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "国境の山、赤く、黄に、峰嶽を重ねて爛れた奥に、白蓮の花、玉の掌ほどに白く聳えたのは、四時に雪を頂いて幾万年の白山ぢや。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死して寺側に埋めし上に白蓮花を生じ、花謝して泉水涌き出づ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女性改造」に出てゐる柳原｜白蓮の『鳳凰天に撲つ』は未完だから、本当のことは言へまいけれども、どういふ作柄かと思つて読んで見た。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑紫の女王白蓮夫人？",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上ではただいま白蓮教をきびしく禁じていられます。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物を洗う水の音がざぶざぶとのどかに聞こえて、隣の白蓮の美しく春の日に光るのが、なんとも言えぬ平和な趣をあたりに展げる。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十吉は白蓮の花四五本を折りて綾衣にわたせば、綾衣は會釋して手に取る。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）綾衣　　花のなかでも白蓮は、氣高い美しい花でござんすな。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、十六堂会の真相を知ろうと思ったら、今回の支那事変以来日本人ともお馴染みの青のことを知りたいと思ったら、その兄弟分の紅※のことや、それらの現世的勢力秘密結社の祖先たる、三合会や哥老会や、白蓮会や、六祖の故事や銅銭会の茶碗陣などを、順を追って調べなければなるまい。",
              "citation": {
                "source": "世界の裏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ橋なくて日暮れんとする春の水罌粟の花まがきすべくもあらぬかなのごときは古文より来たるもの、春の水｜背戸に田つくらんとぞ思ふ白蓮を剪らんとぞ思ふ僧のさま　この「とぞ思ふ」というは和歌より取り来たりしものなり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "心にある除熙の絵が働いて、私は朝靄の裡に開いたばかりの一輪の白蓮の花を思い浮べた。",
              "citation": {
                "source": "蓮花図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前五時、私共は徹夜をした暁の散策の道すがら、草にかこまれた池に、白蓮を見た。",
              "citation": {
                "source": "蓮花図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔ひどれも踊りつかれてぬくい雨ふるさと遠い雨の音がするけふの道はよかつた、汗ばんで歩いた、綿入二枚だもの、しかし、咲いてゐたのは、すみれ、たんぽゝ、げんげ、なのはな、白蓮、李、そしてさくら。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　曾能子刀自の語るを聞けば、此日俳優市川海老蔵と其子市川三升とが、縮緬羽二重を以て白蓮花を造らせて贈つたさうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "放翁は五つの石瓮を埋め、それに泉を貯へて沢山の白蓮を植ゑたと云つてゐるが、私も出来ることなら、さうした水は欲しいと思つてゐる。",
              "citation": {
                "source": "小国寡民",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜燈、旗、天蓋、笙、篳篥、女たちは白無垢、男は編笠をかぶって――清楚な寝棺は一代の麗人か聖人の遺骸をおさめたように、みずみずしい白絹におおわれ、白蓮の花が四方の角を飾って、青い簾が白房で半ば捲上げられ、それを幾町が間か肩にかつぎあげずに静々と柳橋から蔵前通りへと練り歩かれた。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
