    "definitions": [
      {
        "index": 1,
        "gloss": "beautiful boy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おまけに、――美少年だ！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この美少年は不良を衒っているが根が都会っ子のお人好しだった。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の床几で鼠色羽二重の襦袢の襟をした粗い久留米絣の美少年の姿が、ちらりと動く。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう一種の恍惚感に浸って私はまた、茶店の美少年の前を手を振って通り、家の中二階へ戻る。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふにその鏡の中には、君が理想とする容貌――それは君の敍情詩や小説によつて聯想される如き、優にやさしい美少年の顏であらう。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が高等学校の寄宿舎にいたとき、よその部屋でしたが、一人美少年がいましてね、それが机に向かっている姿を誰が描いたのか、部屋の壁へ、電燈で写したシルウェットですね。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那風の美人、美少女、美少年が、あらゆる残忍酷烈な刑に処せられて笞打たれ、絞め殺され、焙られ、焼かれ、煮られ、引き裂かれ、又は猛獣の餌食にあたえられて行く凄愴、陰惨を極めた場面の極彩色密画であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｒは当時有名な美少年であったがＫも相当な好男子であった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其日から數へて丁度一週間前の夜、夜學は無かつた頃で、晝間の通學生は歸つて了ひ、夕飯が濟んで、私の部屋の卓子の上で、燈下に美少年録を讀んで居た。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ美少年録も見着からず、教師は細君を連れて別室に去り、音も其ツ切聞えずに濟んだ。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "續いて一人の美少年、何處より落ちたりけん、華嚴の瀧の底を拔けて、巖の缺と藻屑とともに、雲より落ちつと覺しきが、助けを呼ぶか諸手を上げて、眞俯向けに流れ來しが、あはよく巖に住まりて、一瀬造れる件の石に、はた其の桂の枝まつはりたるに、衣の裾を卷き込まれ、辛くも其の身をせき留めつ。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "里の言葉を知らぬ身も、戀には女賢うして、袖に袂に蔽ひしが、月日經つまゝ、鶴はさすがに年の功、己が頭の色や添ふ、女の乳の色づきけるに、總毛を振つて仰天し、遍く木の葉を掻搜して、男の裾を見出ししかば、ものをも言はず一嘴、引咬へて撥ね飛ばせば、美少年はもんどり打つて、天上に舞上り、雲雀の姿もなかりしとぞ。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いさま摺れ違い、門を入ろうとして振向いて言ったのは、十八九の美少年である。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時｜旅籠町の通の方から、同じこの小路を抜けようとして、薄暗い中に入って来たのは、一｜人の美少年。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっくりと西洋｜鞍置いたるに胸を張って跨ったのは、美髯広額の君ではなく、一個白面の美少年。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に飜って舞上った時に、粉吹雪のごとくむらむらと散って立つ花片の中から、すっくと顕れた一個の美少年があった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも事の行懸りから察し、人の語る処に因れば、この美少年は未見の知己、千破矢滝太郎に相違ない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢中の美少年に憤った色が見え、「おいら、島野とは違うぜ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と自分の顏は自分には見えず、昨日の美少年も、今は日に燒け、潮風に吹かれて、恰も炭團屋の長男のやうになつた事には氣の付かぬ無邪氣さ、只更私の顏を指し笑つたなど、苦しい間にも隨分滑船の煙も見えぬのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが植込を遙かに透し、門の外からあからさまに見えた、と見る間もなく、件の美少年の姿は、大な蝶の影を日南に殘して、飜然と――二階ではないが――窓の高い室へ入つた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯腕で推し、手で拂つて、美少年を、藏すよりも先づ、離さうとあせり悶えて、殆ど虚空を掴む形。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美少年が、何と飛退きもしよう事か。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "剩へ其の扉には、觀世綟の鎖もさゝず、一壓しに押せば開くものを、其の時まで美少年は件の自若たる態度を續けた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と高らかに美少年が言つた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪事、婦人の肩に手を掛けて連理の椅子を並べたのは、美少年のそれにあらず。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聲も一言もまだ出ない内に、霞の色づく如くにして、少女は忽ち美少年に變つたのである。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若旦那の手を、美少年の方から迎へるやうに、じつと握る、と其の手の尖から雪と成つて、再び白衣の美女と變つた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言ふと、齊しく、俄然として又美少年と成つて、婦人の打背く頬に手を當てた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美少年の拔けたあとを、夫婦相對して目を見合せて、いづれも羞恥に堪へず差俯向く。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼろ／＼と霞むまで、暑き日の静さは夜半にも増して、眼もあてられざる野の細道を、十歳ばかりの美少年の、尻を端折り、竹の子笠被りたるが、跣足にて、「氷や、氷や。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
