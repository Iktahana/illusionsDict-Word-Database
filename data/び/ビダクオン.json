        "examples": {
          "standard": [
            {
              "text": "日本語の「が」の音は、場合によって鼻濁音になることがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アナウンサーは、正しい日本語の発音、特に鼻濁音の使い分けに気を使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "方言によっては鼻濁音を使わない地域もあるので、発音の違いが面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "はなす・はがす（がは鼻濁音）などゝ一類の語で、分裂させる義で、ふゆ・ふやすと同じく、霊魂の分裂を意味してゐるらしいのです。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
