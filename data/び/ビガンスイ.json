        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は顔の面皰を気にしながら、こっそりと継母の美顔水をつけたりして、ふらふらと街へ出て行った。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫黄の匂いのする美顔水をつけて化粧してみても追っ付かないと諦めて、やがて十九になった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫黄の匂いする美顔水をつけて化粧してみても追っ付かないと思い諦めて、やがて十九になった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中風で寝ている父親に代って柳吉が切り廻している商売というのが、理髪店向きの石鹸、クリーム、チック、ポマード、美顔水、ふけとりなどの卸問屋であると聞いて、散髪屋へ顔を剃りに行っても、其店で使っている化粧品のマークに気をつけるようになった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女の美顔水を盗んで顔にすりこんだ。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌色美顔水　弐拾八銭。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌色美顔水　　　　弐拾八銭。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中からは、桃谷にきびとり美顔水の藍色の空瓶ばかりが、ごろごろと出て来た。",
              "citation": {
                "source": "突堤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、美顔水とかキレイ水とかいう物が流行的に売れ出していたので、それの類似品を製販していたのでもあろうか。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
