  {
    "uuid": "9901d05c-b160-53cd-b02c-7d082e1a9a95",
    "entry": "美神",
    "reading": {
      "primary": "びしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "god of beauty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奈智と云へば私は唯だ瀧としか聯想しなかつたが、其處には熊野｜夫須美神社といふ官幣か國幣の大きな神社があり、西國三十三ヶ所第一の札所である青岸渡寺とい古刹もあるのである。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一は古事記に八島士奴美神の子に布波能母遲久奴須奴神あり、母遲は大穴牟遲神の牟遲に等しく、貴の義にして韓語の matai 上の義に當り即ち不破の國主なり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いかに人間に近く、この美しい「氣高き姿したる聖なる美神」が立ち現はれたことであらう。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直な文学青年の秋田氏が、美神が急に天下ったように感激したのは当り前だった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らんとならば共に見よ、臥せる美神の肌のごとすべて微笑む入江をば。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーカミイナリの説によると、カナサナ神社もミカ神社も北向明神も総て配下の神で、総本家はオーカミイナリの前身たる大加美神社である。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "大加美神社は大昔はミカ神社のある広木村にあった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉の古歌に現れる曝井がこれであるという村人の伝えはあるが、ここが大加美神社の趾だという伝えはオーカミイナリが自ら称するだけであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが後世に至って、臣下の子孫が児玉党、丹党、猪俣党などを称し、総家たる大加美神社を焼き払い、神たる人の子孫を追った。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽が人間の美魂の直射的表現である点に於て、諸他の芸術に勝る如く、自然の芸術ほど原始的にして直射的な美神の表現は他に存在しない。",
              "citation": {
                "source": "馬鈴薯からトマト迄",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓶山のはずれ、久須美神社と相対して万林寺という寺があって、その裏山のヤブの中に墓がある。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神の登場で、こんな唐突なのは歴史に類がなかったかも知れない。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハは生きている。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハの登場は現世を暴力によって一撃した。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハの創世記。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハの暴力革命的な荒々しい躍動は、うかがう由もなくなったのだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はしかし美神アロハの実力、潜勢力というものを信じていた。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハに激しく敵対したもの、それが全て、実は五列であったのだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハの復活は、実にこの地を選んで、行われた。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハも一応予言者ぶったフリをしてみたかったのだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハの配慮にソツはないのだが、異教徒は酔っぱらうとムヤミに気が大きくなって、翌朝円タクを呪うのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま目下予言者の宿命中で、閑古鳥はなき、美姫は立ち去り、事志とちがって、大いに困っているけれども、美神アロハの大魂胆が全然影を没するということは有りえない。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハは復活した。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "美神アロハは実力の一端を示したのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "天に偽りなきが今更の如く感ぜられ、深く心にそれが刻みつけられ、美神の顕現を心眼に見るであろう。",
              "citation": {
                "source": "芸美革新",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが遊魂いかでか飄乎としてそゝり出で、以て霊境の美神と相通化せざるを得んや。",
              "citation": {
                "source": "松島に於て芭蕉翁を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨も鳩ら先刻にせる姿を改め、美神等｜合唱隊を作し優しき声もて歌を唱へば鳩らそが腕に私を抱きとり、空の方へと連れ去つた三度と呼び、三度我が額を月桂樹もて装うて、空の方へと連れ去つた。",
              "citation": {
                "source": "ランボオ詩集≪学校時代の詩≫",
                "author": "VERS DE COLLEGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "★一度女がかの恐惶、愛の神、生の呼び声、行為の歌に駆り立てられるや、緑の美神と正義の神は顕れてそが厳めしき制縛もて彼を引裂くのであつた！",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゝ美神、おゝ女神！",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸神なる速秋津彦、速秋津姫二神の、河海に因りて持ち別けて、生みし神に、沫那芸神あり、沫那美神あり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
