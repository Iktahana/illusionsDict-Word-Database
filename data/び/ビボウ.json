[
  {
    "uuid": "9075b6c7-37fe-587d-a0dc-96cb6456afb1",
    "entry": "備忘",
    "reading": {
      "primary": "びぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
