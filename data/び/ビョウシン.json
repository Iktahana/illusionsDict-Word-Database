[
  {
    "uuid": "76afc6b9-149e-58eb-92f6-0ac950c0972e",
    "entry": "秒針",
    "reading": {
      "primary": "びょうしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
