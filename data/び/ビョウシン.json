    },
    "definitions": [
      {
        "index": 1,
        "gloss": "second hand (of clock)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秒針はチ、チ、チ、チと音を立てた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が見ている秒針の動きは止まりはしなかった、確実な歩調で動いていた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "実物を出して見ると、六時の所はちょうど秒針のダイアルになっているのである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその心の中では、不斷に時計の秒針を眺めながら、できない仕事への焦心を續けてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が見てゐる秒針の動きは止まりはしなかつた、確実な歩調で動いて居た。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○こんな事を考へて、恰度秒針が一囘轉する程の間、私は凝然としてゐた。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理店の白い壁には大きな電気時計が掛かっていて、黄色い長い秒針が電燈の光を反射させながら、無気味な生物のように廻転している。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、秒針の動きを、じっと眺めている様子である。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自分の靴音を琺瑯質の無限の時間の中に刻まれる微妙な秒針のやうにおもひながら歩いてゐた。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "左腕の黒い文字板の時計に、赤い秒針が動いてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳もとに腕時計を押しつけてみても、その秒針の音が聞えない程、酔つてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその８の処に固まり合っている二本の針と、チッチッチッチッと廻転している秒針とを無意識にジーッと見比べていた……が……やがて如何にも淋しそうな……自分自身を嘲るような微苦笑を、度の強い近眼鏡の下に痙攣させた。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は秒針の運動はよく認識することができる。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、秒針の運動でもちょっとみた瞬間にはわからないもので、だから人は懐中時計が動いているかどうかを試すときに、眼によらないで耳によるのを普通としている。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スミス少佐がじっと時計の秒針を見ている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし山岸中尉は平気な顔で、計器盤にはめこんである、時計の秒針の動きを見つめている。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壇上の博士は時計の秒針を覗き込みながら今正に片手を挙げて九時十二分の合図をしようとする、息詰るような瞬間。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がここにいて、秒針を数えますから、「さあ」といったら射ってください。",
              "citation": {
                "source": "予言",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時五十九分になると、船長はコルクをゆるめた三鞭洒の瓶を高くあげ、事務長は三〇……二〇……と秒針を数えはじめた。",
              "citation": {
                "source": "予言",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "目覚し時計の秒針の音が耳につく。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒々と佇んでいた巡査たちは、再び三階の燈火に異変が起るのを待ちながら、固唾を嚥んで、時計の秒針を胸に数えていた。",
              "citation": {
                "source": "旗岡巡査",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『時計』と題するボードレールの詩の中にも、「刻々の現在を示す秒針は、我は既に過去なりと囁く」とか「昼は減じゆき夜は増しゆく、心せよ」というような言葉があった。",
              "citation": {
                "source": "汝自身を知れ",
                "author": "ベルンにて",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし16世紀末には時計に秒針は無く分針すら無かった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "秒針は取れてしまっていたので火星人が新しいのを物質化した。",
              "citation": {
                "source": "西洋科学は素晴らしい",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
