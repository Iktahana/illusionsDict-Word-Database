    "definitions": [
      {
        "index": 1,
        "gloss": "bhikkhu (fully ordained Buddhist monk)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
