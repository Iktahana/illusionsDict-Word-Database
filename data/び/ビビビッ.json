        "examples": {
          "standard": [
            {
              "text": "初めて会ったのに、彼とは不思議とビビビッとくるものがあり、すぐに意気投合した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議中に突然、画期的なアイデアが浮かんだ。まるで頭の中でビビビッと電球が点いたような感覚だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "直感に従ってその方向へ進んだら、まさにビビビッという偶然の出会いがあり、プロジェクトは新たな局面を迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
