    "definitions": [
      {
        "index": 1,
        "gloss": "bee",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いや、俺のこの宿酔の頭では、一杯ひつかけてから行かなければ、とても相談にはのられやしないぞ」といふやうなわけで私はまたも其処に入り、どうせこんな所の日本酒はまづいからと思つたのでビールを註文。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の景色を私は好きである、坂は段々勾配を増し、酔つて夕陽に照らされてスタコラゆけば、まるで我が身か、我が身が運ぶ箱か分らず、多分今飲んだビールを運ぶ容器であるに相違なからう。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を起こしてそれから僕は近所の乾物屋を探し、コンビーフと福神漬を買つて来た。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の座敷は殿方ばかりにて、ビール又は正宗の空壜を作るによねんなし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "サッポロビールの活動照明、ビール罎の中から光の噴泉が花火のように迸しる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を始めて気づいて驚いている私の鼻の先に突き出た楓の小枝の一つ一つの先端には、ルビーやガーネットのように輝く新芽がもうだいぶ芽らしい形をしてふくらんでいた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "危險この上ないビールの泡だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の豫定の勉強が濟んで、温泉へ入り、それから夕食にとりかかるのであるが、ビールを一ぱい飮みたくなつて女中さんに、さう言ふと、「ございません。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は頬一杯に吹かれてビードロのように、薄青い光を含んで流動している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビールを飲みながら、懐から新聞紙を出して読み始めた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、長い時間を食堂車でつぶして、ビールの汗で体中を飴湯でも打っかけられたように、ネチャつかせながら、彼の座席へ帰った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者の例は（カル）（ビー）（ツ）（ハド）（ヂ）（ツ）（ビー）（ビ）（アン）（ナ）（カ）（ムト）（リ）（フイ）。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーと紫水晶のかけらのスイートピー。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妓はすべてを大して気にかけず、悠々と土手でカナリヤの餌のはこべを摘んだり菖蒲園できぬかつぎを肴にビールを飲んだりした。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ラグビーを見ているときだけ男の魅力を感ずる。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい朝の空気製のビールを考へてゐる。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーよりも赤くすきとほりリチウムよりもうつくしく酔ったやうになってその火は燃えてゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の色には汚れがあり、焔の色には苦熱があり、ルビーの色は硬くて脆い。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の汚れを去り、焔の熱を奪い、ルビーを霊泉の水に溶かしでもしたら彼の円山の緋鶏頭の色に似た色になるであろうか。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばビーカーをアルコールランプで下から熱すると水蒸気が出てそれがビーカーの外側にあたって冷却され、水粒がビーカーに附着する。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て児童はどうして出来るかと質問したときに、教師がそれをいいかげんに答えるのはいうまでもなく悪いが、これを知っている場合に、何でもないことだ、アルコールの燃える際に生ずる水蒸気がビーカーにあたって露になって着くのだといって、あまり無造作に片づけてしまうのは面白くないと思う。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビーカーに水を汲むのでも、マッチ一本するのでも、一見つまらぬようなことも自分でやって、そしてそういうことにまでも観察力判断力を働かすのでなければ効能は少ない。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七五年から七六年にわたる冬の数箇月間ビーチャム・タワー（Beauchamp Tower）というエンジニアーを助手として水力学の実験をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厩の二階の物置を二つに仕切って一方を暗室とし、壁と天井を、煤とビールの混合物で塗った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一片の麩を争う池の鯉の跳躍への憧憬がラグビー戦の観客を吸い寄せる原動力となるであろう。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早慶戦のあった金曜日の夕方例によって友人と新宿の某食堂で逢って連句をやろうと思っていると、○大学の学生が大勢押しかけて来て、ビールを飲んで卓を叩いて校歌を唄い出した。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
