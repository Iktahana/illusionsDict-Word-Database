    "definitions": [
      {
        "index": 1,
        "gloss": "shaking one's legs (usu. unconsciously)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "柿江は腹をぺったんこに二つに折って、胡坐の膝で貧乏ゆすりをしながら、上眼使いに指の爪を噛んでいた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は貧乏ゆすりをしながら園から受取った星野の葉書を手脂だらけにして丸めたり延ばしたりしていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松村は火鉢の前にしやがんで、貧乏ゆすりをして居た。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は肥満っているから遁げられぬ、と鍋釜の前で貧乏ゆすり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少々寒し、不景氣な薄外套の袖を貧乏ゆすりにゆすつて居ると、算木を四角に並べたやうに、クツシヨンに席を取つて居た客が、そちこちばら／＼と立掛る。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いら／＼した貧乏ゆすりが出た。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "割膝で畏まって、耳を掻いて頸を窘め、貧乏ゆすり一つして、「へへへ、口の悪いッちゃねえ、お嬢ッ公。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　間淵が菎蒻のような色をして、懐手の貧乏ゆすりで、「酒だ、酒だ、酒を早く。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "離縁状は横浜の土を踏むと一緒に嬶に向けてぶっ飛ばしてあるんだ」　といってあぐらの膝で貧乏ゆすりをし始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけて私はまた鏡の中で隣りの御面師を見ると、狐のやうな不平顔で、はやく金をとりたいものだが自分が云ひ出すのは厭で、私をせき立てようといらいらして激しい貧乏ゆすりを立てたり、キヨロ／＼と私の横顔を窺つたりしてゐるのが悪感を持つて眺められた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "加けに膝頭をのべつにピストンのやうに機械的な貧乏ゆすりで震動させながら、「私は何うも立つてばかりゐるのが商売のせゐか、凝つとしてゐるのが苦手でして……」　と恐縮してチツチツチツ！",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけて私はまた鏡の中で隣の御面師を見ると、狐のような不平顔で、はやく金をとりたいものだが自分がいい出すのは厭で、私をせき立てようといらいらして激しい貧乏ゆすりを立てたり、キョロキョロと私の横顔を窺ったりしているのが悪寒を持って眺められた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、貴方の本当の奥さんにはなれないやうに生れついてゐるンだわね」　富岡は冷い茶をすゝり乍ら、寒いので、膝を貧乏ゆすりして、ゆき子のヒステリックな口説を聞いてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に――気持ちを云つて……」　残りの酒をぐつと飲んで、富岡は、また思ひ出したやうに、膝小僧を苛々と貧乏ゆすりしながら、「いや、さうぢやない。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は炬燵のなかで膝を貧乏ゆすりしながら、ラジオの小箱を手にとつて、幾度もダイヤルをまはした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅っこに、どういう訳か二脚だけある椅子へこっち向に跨り、粗末な曲木のよりかかりに両腕をもたせて一人は顎をのせ、一人は片膝でひどく貧乏ゆすりをしている。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、椅子に跨って貧乏ゆすりしている三十がらみの従業員の落付かなく人の出入りに注がれる眼くばりの中にも認めることが出来るのであった。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガランと広い出口のところに宿屋の半被を着た男が二人、面白くもない顔つきでタバコをふかしながら、貧乏ゆすりしているばかりで、人影もろくにない。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉氏も今日は、目をパッチリと、ねむそうだった昨日の面影はミジンもない、貧乏ゆすりをしながら、食いこむように、かがみこんで考えている。",
              "citation": {
                "source": "本因坊・呉清源十番碁観戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎は膝を抱いて貧乏ゆすりをしながら、眼の前にある拳銃をじっとながめていた。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売上手の女　マリイ・マドレエヌは白木のテーブルの後で貧乏ゆすりをしている。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　二　一角は、貧乏ゆすりのように、細かく肩を揺すって、口のなかで呟いていた。",
              "citation": {
                "source": "口笛を吹く武士",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田氏は貧乏ゆすりをしながら、神妙な顔で聞いていたが、そのうちに腹がたってきたらしく、「余談は、それくらいにして、用件を先に伺いましょう。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "参事官の隣に投げやりな格恰で胡坐をかいているのは例の川俣踏絵、夜会服の裾から形のいい膝小僧を覗かせ、焦ら立たしそうに貧乏ゆすりをしている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オランウータンには、ずいぶん借りがあるんだから、罪ほろぼしのつもりで、当分、飼ってやろう」　猿の子供は窓框のうえに坐って、頭を掻いたり貧乏ゆすりをしたりしながら、皿の乾杏をもの欲しそうに見ていたが、そばに垂れているカーテンの紐を首に巻きつけると、踊るような恰好でヒョイヒョイと飛びあがった。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏ゆすりをしている。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだかおちつかねえなあ」と又次郎は膝で貧乏ゆすりをしながら云った、「いま宗ちゃんは相談ごとの集まりだって云った、おれんところへ来たのろは、死んだお光ぼうのことで話があるって云ってたぜ、いってえどういうことなんだい、これは」「お光ぼうの死んだわけがわかったんだ」と忠太が云った。",
              "citation": {
                "source": "源蔵ヶ原",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又次郎の貧乏ゆすりが止り、宗吉は自分の盃へ酒を注ごうとしたまま、疑わしげにのろの顔を見まもった。",
              "citation": {
                "source": "源蔵ヶ原",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく動く眼を細めたり、皺のある小さな顔を撫でたり、口をすぼめたり、躯ぜんたいで貧乏ゆすりをしたりした。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな貧乏ゆすりだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
