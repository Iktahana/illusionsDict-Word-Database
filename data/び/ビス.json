    "definitions": [
      {
        "index": 1,
        "gloss": "screw",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶をのんで粗末なビスケットを二つ三つかじる。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は毛布をかけてねたまま手を出してビスケットを取って食っている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに追分辺でミルクの缶やせんべい、ビスケットなど買った。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い芸妓たちは、娘の挑戦を快くは思わなかったらしいが、大姐さんの養女のことではあり、自分達は職業的に来ているのだから、無理な骨折りを避けて、娘が努めるときは媚びを差控え、娘の手が緩むと、またサービスする。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕の少女に九鬼は紅茶とビスケットをくれないかといった。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットってクッキーのことですかと少女が尋ねた。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットという古い言葉がクッキーという新しい言葉に代ってしまっているのを初めて知って、自分の住んでいる古い世界と少女の住んでいる新しい世界との間隔に軽い目まいを感じたのである。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根ホテルでは勘定をもって来てくれと四、五度も頼んで待ち草臥れた頃にやっと持って来たのであったが、熱海ホテルの方ではまだお茶を飲んでいる最中に甲斐甲斐しい女給仕が横書きの勘定書をもって来て、「サービス三十銭頂戴します」と云った。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「煙のビスケット」が生物のように緩やかに揺曳していると思うと真中の処が慈姑の芽のような形に持上がってやがてきりきりと竜巻のように巻き上がる。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし鉱山の煙突から採れる銅やビスマスや黄金は役に立つのである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど西洋の画廊で古い絵ばかり見て、日本へ帰って始めてキュービストやフュチュリストを見せられたような心持ちがする事がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、そのころどこかからもらった高価な舶来ビスケットの箱が錠前付きのがんじょうなブリキ製であったが、その上面と四方の面とに実に美しい油絵が描かれていた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たわいもない幻影を追う目がガラス棚のチョコレートに移ると、そこに昔の夢のビスケット箱の中のメールコーチが出現し、五十年前の父母の面影がちらつき、左団次の知盛が髪を乱して舞台に踊るのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士はマッチをすって火をたき、それからビスケットを出しもそもそ喰べたり手帳に何か書きつけたりしばらくの間してゐたがおしまひに火をどんどん燃してごろりと藁にねころんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットのあるうちは、歩いて野宿して、面白い夢でも見る分が得といふもんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまっくらなとこでもしゃもしゃビスケットを喰べた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士はマッチをすって火をたき、それからビスケットを出しもそもそ喰べたり手帳に何か書きつけたりしばらくの間していたがおしまいに火をどんどん燃してごろりと藁にねころんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットのあるうちは、歩いて野宿して、面白い夢でも見る分が得というもんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は今日のようなグラグラ政府には飽きられただろうと思う、そこでビスマークとカブールとグラッドストンと豊太閤みたような人間をつきまぜて一鋼鉄のような政府を形り、思切った政治をやってみたいという希望があるに相違ない、僕も実にそういう願を以ています、しかし僕の不思議なる願はこれでもない。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶は紅茶で、お茶受けにはパンの薄片にバターを塗ったもの、ビスケット、ケーキ、その時々の主婦の思い付きによります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私に取ってこういう奇蹟的な存在の人が、世間では私の母の廉い仕立もののお得意さまであって、現在、製菓会社の下級社員で、毎日ビスケットを市中に届けて歩き、月給金○○円の方であるとは、どうにも合点がゆきませんです。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンジカリズムの理論体系や、ロオドベルトスの社会主義論や、マルクスとコンミュンの話や、時にビスマルクやブハリンにまで彼女の論説は及んで行きます。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこにデビスさんが、住んでいられるんですね。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　デビスというのは、ご存知の方もありましょうが、私たちの派のまあ長老です、ビジテリアン月報の主筆で、今度の大祭では祭司長になった人であります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分はデビスさんの自分の家だったのでしょうが、ずいぶん大きいことは大きかったのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髯赭顔のデビス長老が、質素な黒のガウンを着て、祭壇に立ったのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "デビス長老は、手を大きく振って又何か云おうとしましたが、今度も声が咽喉につまって、まるで変な音になってしまい、とうとう又泣いてしまったのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
