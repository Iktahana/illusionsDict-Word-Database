    "definitions": [
      {
        "index": 1,
        "gloss": "praiseworthy undertaking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
