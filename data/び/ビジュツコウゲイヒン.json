    "definitions": [
      {
        "index": 1,
        "gloss": "art works, traditional artifacts and antiques",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
