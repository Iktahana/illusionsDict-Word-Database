[
  {
    "uuid": "f966661f-8fbb-5ac8-9a44-851a4406b0f3",
    "entry": "美姫",
    "reading": {
      "primary": "びき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
