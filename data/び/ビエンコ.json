        "examples": {
          "standard": [
            {
              "text": "博物館で、精巧な彫刻が施された、古い鼻煙壺のコレクションを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "かつては、貴族の間で装飾品としても流行した鼻煙壺は、今ではアンティークとして珍重されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "父から譲り受けた鼻煙壺は、祖母が大切にしていたもので、特別な思い出が詰まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "陳列棚一ぱいぎつしりつまつた鼻煙壺のコレクションだ。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻煙壺といふから、まあ嗅タバコの入れ物だらう。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
