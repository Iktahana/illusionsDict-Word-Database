[
  {
    "uuid": "2de4a5d8-4b74-5128-aec7-474fadf3d2a1",
    "entry": "病院",
    "reading": {
      "primary": "びょういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hospital",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「それから少し歩けるやうになると、一寸油断すればあんたは病院に出掛ける。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院は庭続きだつたもんだから。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者も患者も面白がつて、病院中の人気者だつた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後柳樹屯の衛戍病院とかに行つたさうだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーブの上の薬鑵の湯気をみ入つてゐる時、「電車の救助網にでもかゝつて、今怪我をして病院にゆくとすれば、Ｓ子が見舞に来るんだ……」つてな夢みたいなものを鼻の上で小踊りさせた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下から三｜間とはなれぬ往来で、森田屋の病院御用自動車が爆鳴する。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸夜具屋が病院からの電話で持込むところと想定してみる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突当りを右へ廻れば病院の門である。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院で手術した患者の血や、解剖学教室で屍体解剖をした学生の手洗水が、下水を通して不忍池に流れ込み、そこの蓮根を肥やすのだと云うゴシップは、あれは嘘らしい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の東詰の流しの上の明かり窓から病院の動物小屋が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの怪我や片輪は、直るものなら病院で直してくれる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷ついた心、不具な理性を直してくれる病院はないものか。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこれに代わるべき新しい病院はまだ建たぬ。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院も正月で静かである。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無病息災を売物のようにしていた妹婿の吉田が思いがけない重患に罹って病院にはいる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院から引取って形ばかりでも葬式をすませ、妹と姪とを自宅に引取るまでの苦労を今更のように思い浮べてみる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めての他郷の空で、某病院の二階のゴワゴワする寝台に寝ながら窓の桜の朧月を見た時はさすがに心細いと思った。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本文には書いてないが、辻村は病院生活、約一ヶ月後に、漸く退院したが、猶お歩行を禁ぜられ、其後、更に三週間を、とある湖畔に送って、九月二十五日に、伊太利ミラノに出て、マルセーユヘ陸行し辻村は香取丸に便乗、近藤氏は、倫敦からアメリカを通って、故国の土を踏むことが出来たのである。",
              "citation": {
                "source": "「続スウィス日記」発掘の始末",
                "author": "附「スウィス日記」の由来",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人目の子供を産むために、下の児を連れて県病院の施療病室にいる女房は？",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬶が病院に行ってるから、一人は俺が見てやらなけゃ、ならないんだよ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の暮には、東京の某病院の医員だという読者から次のような抗議が来た。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この抗議のはがきの差出人は某病院外科医員花輪盛としてあった。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的新しい方の例で自分の体験の記憶に残っているのは明治三十二年八月二十八日高知市を襲ったもので、学校、病院、劇場が多数倒壊し、市の東端｜吸江に架した長橋｜青柳橋が風の力で横倒しになり、旧城天守閣の頂上の片方の鯱が吹き飛んでしまった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の親戚を見舞うことは断念して松住町から御茶の水の方へ上がって行くと、女子高等師範の庭は杏雲堂病院の避難所になっていると立札が読まれる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは書くのが面倒なのと、もひとつは現場ですぐ工作をする誰かの式を気取ったのと、さう二っつがおれを仕事着のまゝ支那の将軍のやうにその病院の二つの棟にはさまれた緑いろした中庭にテープを持って立たせたのだ。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯うまるで病院の手術室のやうに暖かにしてありますしね。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人の眼と髪　これはスコットランドの話で我邦には応用し難いかも知れぬが、同地の瘋癲病院で調査した処によれば、統計上狂者には普通の人よりも眼の色が薄く髪の色が濃いのが多いという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に僕野戦病院入り、いつかニュース映画で兵隊が褌一ツで川を渡るのがありましたね。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "（詳記するを許されませんがこの六ヶ月はコタエマシタ）　近く病院が移動するらしいですから、その時また、お便りします。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は……野戦の病院に移されました。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
