    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bottle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小さい瓶買いましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶道具と鉄瓶とを持って部屋へかえって来たら、もうすでに馬場と太宰が争っていたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな逆説めいたことを口走って、サイダアを一瓶、頭から僕にぶっかけて、きゃっきゃっと気ちがいみたいに笑った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲店　醉月坂を登らんとして渇きに耐へず蹌踉として醉月の扉を開けば狼藉たる店の中より破れしレコードは鳴り響き場末の煤ぼけたる電氣の影に貧しき酒瓶の列を立てたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵の酒宴の可笑しさよ娘が運ぶ瓶子よりもるる灯影にかしこまる左右の破顏を反り見て七兵衞獨り忻忻たり。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある雨の夜、父は他所の宴会に招かれて更けるまで帰らず、離れの十畳はしんとして鉄瓶のたぎる音のみ冴える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も縁側へ出て新しく水を入れた手水鉢で手洗い口すすいで霊前にぬかずき、わが名を申上げて拍手を打つと花瓶の檜扇の花びらが落ちて葡萄の上にとまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎唇の手術のために入院している幼児の枕元の薬瓶台の上で、おもちゃのピエローがブリキの太鼓を叩いている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍の氷店に入ってラムネ一瓶に夜来の渇望も満たしたればこゝに小荷物を預けて楠公祠まで行きたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の鉄瓶の単調なかすかな音を立てているのだけが、何だか心強いような感じを起させる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁に出した花瓶の枯菊の影がうら淋しくうつって、今日も静かに暮れかかっている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の机上には、有り合せの玻璃瓶に、菜の花が投げ込んである、これは弟に捜させて、採って来たものである、天鵞絨のように、手障りの柔らかな青い葉が、互い違いになって、柱のような茎を取りまいて居る、此柱の頭から、莟みが花傘なりに簇がって、蛹虫の甲羅のように、小さく青く円くなっている。",
              "citation": {
                "source": "菜の花",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になって空に星はあったが、電光が白い柱を、谷の中に投げては、夜営の人々をおどろかした、夜半には、秋雨が音なく注いだ、川縁に転がっている流材を焚火にして、寒さを凌いだ、針葉樹の切崖で囲んだ、瓶のように窄い谷底からは、天も谷川ほどの細さで流れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（紅雪を標品として採集するには、雪と共に瓶の中へ入れ、フォルマリン薬を臭気強いまで滴下して置けば、雪は無論溶けるが、藻は保存が出来る、ただし紅色はやや久しいうちには、全く失われるが、学術標品としては差支えないのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会の終了後は、賞と書いた胴巻きのある酒瓶を中心に、各区の集会所で一同持ち寄りの懇親会が開かれた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、デッキと同じ大きさの、熱した鉄瓶の尻と、空気ほどの広さの、赤熱した鉄板と、その間の、＊＊＊＊＊＊そうでもない。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "土瓶むしの土瓶のつるを持ち上げると土瓶が横に傾いて汁がこぼれた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土瓶の耳の幅が廣過ぎるのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノが台の下の小滑車で少しばかり歩き出しており、花瓶台の上の花瓶が板間にころがり落ちたのが不思議に砕けないでちゃんとしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソーダの瓶と菓子｜麺麭の籠とが縞のエプロンの上で日の光を受け止めている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつめたい水の底まで、ラムネの瓶の月光がいつぱいに透とほり天井では波が青じろい火を、燃したり消したりしてゐるやう、あたりはしんとして、たゞいかにも遠くからといふやうに、その波の音がひゞいて来るだけです。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそのうしろには三本の脚のついた小さな望遠鏡が黄いろに光って立ってゐましたしいちばんうしろの壁には空ぢ〔ゅ〕うの星座をふしぎな獣や蛇や魚や瓶の形に書いた大きな図がかかってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その人はすぐ奥へ行って一本の牛乳瓶をもって来てジョバンニに渡しながらまた云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニはまだ熱い乳の瓶を両方のてのひらで〔〕包むやうにもって牧場の柵を出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心口を鎖してお寢間へ戻り給ひしが再度立つてお菓子戸棚のびすけつとの瓶とり出し、お鼻紙の上へ明けて押ひねり、雪灯を片手に縁へ出れば天井の鼠がた／＼と荒れて、鼬にても入りしかきゝといふ聲もの凄し。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回の見事な実験はそれだけでもう頭の蒸餾瓶の中で出来た公式の二十くらいよりはもっと有益な場合が多い。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかつかと歩み寄つたＫ少尉、いきなりびんたの一つも張るかと思つたらさにあらず、『それ位にして置いて早く集つて下さい、濟まんが』とやつたものだ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋でも花瓶に花卉を盛りバルコンにゼラニウムを並べ食堂に常緑樹を置くが、しかし、それは主として色のマッスとしてであり、あるいは天然の香水びんとしてであるように見える。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い、ほう、天びん棒がひとりでに、磁石のように君の手へ吸い着いて行った。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
