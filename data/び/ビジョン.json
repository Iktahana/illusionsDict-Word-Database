        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてアップルこそ、個人のためのコンピューターのビジョンを高く掲げた旗手だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は知ってやったか知らないでやったか分らぬがこのひどい冒涜の場面は先程からテレビジョンで全国へ放送されていたんだぞ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼女は外出をやめて、早速索敵戦隊長と爆撃戦隊長のところへテレビジョン電話をかけた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで女大臣は早速索敵と爆撃との二戦隊長をテレビジョン電話の前に呼びだした。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレビジョン電話のベルが鳴って、スクリーンの上に再び前の二人の戦隊長の顔が現われた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく室内のテレビジョン電話のスクリーンに一人の人造人間の顔がうつった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋谷先生が三年前に亡くなられて、テレビジョン講座に空席が出来たればこそ、自分のような若い者が教授になれたのである。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋谷博士は当時、優秀な航空テレビジョン機の発明を完成されていた。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "出勤次第、第二号「テレビジョン」機ヲ「スタート」ノコト。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、前日までそこに並べておいたはずの第一号テレビジョン機がなくなって、そのあとが歯の抜けたようにポッカリあいていたから。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、この機会をはずさずに、火星探検のテレビジョン放送をやるから、すぐに世界各国へアナウンスをしてくれたまえ。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "各国の優秀なる新聞記者は、いずれも言いあわせたように、自国のテレビジョン学者をともなって、旅客機をかってはせつけた。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその次には一刻も早く、同型のテレビジョン機をつくって自国の放送局から放送したいためでもあった。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はついに生命を犠牲にしてロケットとテレビジョンとをいかし、世界人類のために貢献しようと決心したのだ。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいま研究ちゅうのテレビジョン機を一日も早く完成したいと思う。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう人々の手によってやたらにキャンプが張られ、郵便所が出来、テレビジョンやラジオの放送塔が建てられた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君の身体がひまなら、無電局長のところへ行って、船長から聞いたが面白いものを見せてくれといってみたまえ」　　テレビジョン傍受　ドレゴは、それを聞くと、猟犬のように甲板を走り、ラッタルを駈上って、無電室の扉を叩いた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はさっぱりだ、この方面のことは……」「これはテレビジョンの受影機なんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "航海中アメリカやイギリスのテレビジョンを受けようと思って、僕が試作中のものなんだ」「テレビジョン？",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画のテレビジョンかなんかを中継して、この映写幕へ出しているんじゃないか」「君が信じなきゃ、それまでだよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドレゴ君、ここを見給え、この籠みたいなもの――上からぶら下っていると見えて鋼条が光っているが、これは海中へ投げこまれた別のテレビジョン送影機だぜ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機がテレビジョンの送影機を投げこんで行ったとは、一体どういうわけなんです。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに代ってテレビジョンの送影機を投げこむと、尊い人間の生命を脅かされることは全然ないんだからね。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにテレビジョンの送影機をあんなにどっさり相手の周囲に投げこむなんてぇ、こんな大掛りなことは、わがアメリカじゃなけりゃ何処の国がやるだろうか。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあの鋼条の中には絶縁されたアンテナ線が海面までつづいていて、海面からそれがテレビジョンの像電波を発射しているんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで受けていたテレビジョンの電波が停ってしまったんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このへんにぶら下っていたテレビジョンの籠がやられてしまった」　そういっているとき、また、ぱぱッぱぱッと幕上の相ついで閃光が二人の目を射た。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角投げこんでおいたテレビジョンの送影機が、今｜片端から破壊されて行くのだ」「ええッ、何だって」「送影機が片端から壊されて行くんだよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレビジョンで見張られていては都合が悪いというんで、どんどん壊しにかかっているんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
