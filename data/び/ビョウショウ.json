[
  {
    "uuid": "799e0af4-cdfb-5317-9d5e-fc0a872a558c",
    "entry": "病床",
    "reading": {
      "primary": "びょうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
