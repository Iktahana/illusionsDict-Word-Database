    "definitions": [
      {
        "index": 1,
        "gloss": "poverty-stricken",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "加ふるに黄熱病が猖獗を極めてゐて、ルモオルは船から船に移されて漸くのことで例の親戚の手に渡されたのだが、その親戚は貧乏になりはてちまつてゐたといふわけだ。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも貧乏暇なしでね」とＢは云ふ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれもこのごろは貧乏でな、どうも、女に惚れると金がかかつていけねえ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに貧乏をしてゐても、夕食の時などには樂しさうに世間話をして笑ひ合つてゐるぢやありませんか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には貧乏を誇るなんて厭味な、ひねくれた氣持はない。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏人根性といふものは、決していいものではない。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひは、私は、貧乏性といふやつなのかも知れない。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天然の実験室でなければこんな高価な「実験」はめったに出来ないから、貧乏な学者にとって、こうしたデータは絶好の研究資料になるのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校は好きにも好きにも遂ひに世話をやかしたる事なく、朝めし喰べると馳け出して三時の退校に道草のいたづらした事なく、自慢では無けれど先生さまにも褒め物の子を、貧乏なればこそ蜆を担がせて、この寒空に小さな足に草鞋をはかせる親心、察して下されとて伯母も涙なり。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐の貧乏士族としての我家に伝わって来た雑煮の処方は、椀の底に芋一、二片と青菜｜一とつまみを入れた上に切餅一、二片を載せて鰹節のだし汁をかけ、そうして餅の上に花松魚を添えたものである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐の貧乏士族の子の雑煮に対する概念を裏切るような贅沢なものであった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしよくよく詮議してみるとやはり貧乏が総ての究極の原因であったという場合もかなり多いようである。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校は好きにも好きにも遂ひに世話をやかしたる事なく、朝めし喰べると馳け出して三時の退校に道草のいたづらした事なく、自慢では無けれど先生さまにも褒め物の子を、貧乏なればこそ蜆を擔がせて、此寒空に小さな足に草鞋をはかせる親心、察して下されとて伯母も涙なり。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はいつも貧乏で食物がなく、十二月の冬空に單衣を着てゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に貧乏になったのかい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んだかこう利用してしまった土地というような風で、寂し気に、貧乏らしく見えている。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私はこれからは、自分の休みなき仕事が、そんな貧乏の苦しみをも取り除いてくれることと信じます。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その家の前には、貧乏人たちが立ちはだかり、そしてそれは貪婪さうに見入つてゐる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いただけでもくさくさするよ」　と、夫は調子に乘りながら、「貧乏畫家の妻として三｜年間で三百｜圓溜めたあたしの經驗か？",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬戸火鉢と西洋婦人と、それは如何にも奇妙な、同時に如何にも貧乏くさい感じを與へる對照だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別な家柄でもなく一介の土木技手上りに過ぎない貧乏な作家と、大地主で大金持で伯爵の名門に生れた作家と、その呟きには何か胸を打つものさへあるが、とにかくドストイェフスキイは時には境遇的にも自分の原稿を讀み返す暇さへ持てなかつた。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏したら石油まで早よ無うなる。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、なんぼ貧乏しても村に居る方がえい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永久の貧乏　百姓達が、お前達は、いつまでたっても、──孫子の代になっても貧乏するばかりで、決して頭は上らない。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼等は、どうして貧乏をするか、その原因も知らない。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、貧乏がいやでたまらない。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏ぐらい、くそ嫌いなものはない。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その貧乏がいつも彼等につきまとっているのだ。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、彼等を貧乏から解放してくれるものは何であるか。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはびんぼうな教師の子どもにうまれて、ずうっと本ばかり読んで育ってきたのだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
