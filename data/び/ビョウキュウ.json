        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "医師から一週間の静養を命じられたため、正式な手続きを経て病休を取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は三ヶ月間の病休を終え、今日から元気に職場復帰を果たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「すまないが、明日から病休に入るので後の業務は君に任せてもいいか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "わたくしは此年の事迹を考へて、当時の吏風が病休中の外遊を妨げなかつたことを知つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "白川道太郎応召、市川光男退座、花井淳子病休と、いろ／＼のところへ、藤山から松平との一日交替をかんべんして呉れとの伝言、大てい参っちまふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木桂介病休と思ひしに泥酔の上けんかして拘留中とあり、保証金持たしてやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愛染」をやる、三益病休仕方のない奴。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者の病休七人もあり、怪しからん。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
