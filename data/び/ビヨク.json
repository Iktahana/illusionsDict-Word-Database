[
  {
    "uuid": "995bc997-ae50-541b-acc3-f6dd0de10db3",
    "entry": "尾翼",
    "reading": {
      "primary": "びよく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tail (of an aircraft)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、尾翼に欠点のあることを発見して、「よくなりますよ。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三枚は、尾翼に縋りつく。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "このロケットというのは、だいたい砲弾に尾翼を生やしたようなかたちをした飛行機の一種です。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また尾翼もいつの間にか胴中からひきだされました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はこっちの機体を怪塔ロケットの尾翼にぶっつけて、舵をこわしてやろうと考えている。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大尉の乗った偵察機は、垂直旋回のまま、怪塔ロケットの尾翼をねらって、みごとに「どぅん」とぶつかりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機の車輪でもって、怪塔ロケットの尾翼を蹴ちらしたのです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はげしい音と共に相手の尾翼はもぎとられ、火花のようなものがぴかりとひかりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴムの車輪は、おもいのほか丈夫で、相手の尾翼をけとばしてへいきでありました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたしてケレンコは、あっけなくつかまり、リーロフは、大きな体をふきとばされまいとして、力のかぎり、尾翼のつけねにとりついている。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世津子は、やつと張り終つた模型飛行機の尾翼を貫太の鼻先につきつけて、「これでいいんでせう、ねえ、駄目よ、ちやんと見てくれなけりや……」　と、主任技師の心細い指導に弱り果てたかたちである。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "折れとんだ破片が、空中で互いに衝突し、その中を尾翼が通ったために、三重衝突をした点まで明らかになった。",
              "citation": {
                "source": "「もく星」号の謎",
                "author": "――白鳩号遭難事件を回顧して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に機はどっと傾いて、すぐ眼の前に、尾翼がぬっと見えてきた。",
              "citation": {
                "source": "海底の散歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "機首からはじまって、窓の列をなぞって機尾へ、そして垂直尾翼ぜんたいへと広がっている、オレンジ色の花模様が、はっきりと見えた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翼の端にフロートがひとつずつ下がり、水平尾翼は垂直尾翼の頂上に一直線だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾翼をこちらに向けた飛行艇は、沖に向かってまっすぐ、海面を滑り始めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、しゅびよく油を一｜合かいました。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、このむすめさんに、十二人りきがついて、しゅびよく雪の女王にかてますよう、のみものをひとつ、つくってやっていただけませんか。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして少し後戻つて、再びよく道標の文字を調べながら文字のさし示す方角へ曲つて行つた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして少し後戻って、再びよく道標の文字を調べながら、文字のさし示す方角へ曲って行った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤になったおつやさんの顔を見ると、少し濃い目ではあるが、のびよく美しく白粉がついている。",
              "citation": {
                "source": "追想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほかた、父親達が置屋へ行つて呼び馴れてゐるその名前を、自分達も何時とはなく覚えて呼びよくなるのでせう、町の男の子達は、ひな子のもうひとつの名を呼んで、「おかめおかめ」と云つてをりました。",
              "citation": {
                "source": "小さい花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "終りに今年もよく学びよく慰とかいて消して力になってと直して書かれている。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、「よく学びよく遊ぶ」といふことも、ごく単純な子供心にはわかり易い訓へでありませうが、これはうつかりすると、「遊ぶために学ぶ」、即ち「楽しみを獲るためにいやな仕事でもする」といふやうな本末を顛倒した考へ方に陥りがちであります。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、しゅびよくそれをしとげれば、わたしの妃にしてあげる。",
              "citation": {
                "source": "ルンペルシュチルツヒェン",
                "author": "RUMPELSTILZCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、夏が来て、ジェハンじいさんが再びよくなったときも、ジェハンじいさんは外に出かける必要はなく、朝は小屋の戸口に座って中庭の戸口から二人が出かけるのを見送り、ちょっと昼寝して夢を見て、少しお祈りをして、そして三時になるとまた目を覚まして二人が帰ってくるのを待つのでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし一般の意見が、たとい外見上だけであれ、ただ使者の侮辱ということだけしか知らないならば、これもまたただ外見上だけのことであれ、もしその使者をなだめることができれば、万事をふたたびよくすることができるはずだ、って。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだに家康はしゅびよく退陣し、旗本の人びとも追躡する敵を撃退しつつ浜松城下までひきしりぞいた。",
              "citation": {
                "source": "死處",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、暗号文の半分だけは、しゅびよく手に入れましたが、どうも半分ではしかたがありません。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "賊がしゅびよく目的をはたすか、名探偵明智小五郎が勝利を得るか、いよいよ死にものぐるいの知恵くらべがはじまろうとするのです。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
