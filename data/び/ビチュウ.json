[
  {
    "uuid": "1485a40b-be2d-50b8-9e7d-49a4c8358845",
    "entry": "微衷",
    "reading": {
      "primary": "びちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's innermost thoughts (feelings)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "辭つたなきを羞ぢつゝ、謹で微衷をのぶ。",
              "citation": {
                "source": "芥川龍之介氏を弔ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "微衷をお汲み取り願い上げます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの高齢、高徳の士、不世出の国粋芸術家梅津只圓翁の真骨頂を世に伝えたい微衷に他ならない事を御諒恕賜わらば幸甚である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本人も決して高くドイツ人を笑い得ず、予が報国の微衷もて永々紀州のこの田舎で非常の不便を忍び身命を賭して生物調査を為し、十四年一日のごとく私財を蕩尽して遣って居るに、上に述べた川村前知事ごとき渝誓してまで侮辱を加え来る者がすこぶる少なからぬからというて置く。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の命数尽きたりといえども、静かに天命を待たずして自殺するは、御身に対する我が微衷なり。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "希くハ微衷を諒せられんことを。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今の御沙汰によれば、お上に置かせられても、我々の微衷をお酌取下されたものと存じます。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今後もし夫人を離婚せられずんば、……貴下は万人の嗤笑する所となるも……微衷不悪御推察……敬白。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "只一片の微衷、國詩の發達に關して纖芥の貢資たるを得ば幸のみ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの我も聊か疲労しかつはまたこの上｜強ひんには礼を失するに至らん事を虞れせめてわが芝居道熱心の微衷をだに開陳し置かばまた何かの折宿望を達するよすがにもなるべしと長々しき論文一篇を草しそつと玄関の敷台に差置きて立ち去りぬ。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "冀くば大方の諸賢、特に遺物・遺蹟を重く扱わるる考古学・人類学の専門大家諸賢、幸いに余輩の微衷を憐み、相提携して学のために尽くし給わんことを。",
              "citation": {
                "source": "遺物・遺蹟と歴史研究",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰ぎ願わくは小生のこの微衷のあるところを諒とせられ、何らの御隔意なくこれに関する御研究或いは御見聞の程、御報告に預り度く、懇請の至りに存じ奉り候う。",
              "citation": {
                "source": "「特殊部落研究号」発刊の辞",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰ぎ希くば、われらの赤心、報国献身の微衷を汲ませ給ひ、袋町住民の安泰無事、加へて、日本全国、近隣友邦の平穏息災のために、広大なる加護の力を垂れ給へ。",
              "citation": {
                "source": "風俗時評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれ願わくば微衷にめでて弟子の一人にお加えくだされ、幻妙不思議の忍術の一手お教え置かれくださいますよう、常陸お願い申し上げます」「ふうむ」と老人は眼を閉じて常陸の言葉を聞いていたが、「それほどまでのご執心老人過分に存じ申す――こなた石川五右衛門殿の、お心持ちはいかがかな？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "周布一派の老練家が委曲｜周旋、またその微衷を諒すべきものあり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志の士その微衷を憐み継紹の人あらば、乃ち後来の種子未だ絶えず、自ら禾稼の有年に恥じざるなり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、先生におかれても、われわれの微衷をお酌みとりになつて、快く、これをご利用あらんことを希望する次第であります」　云ひ終つて、そこへ、鬼頭の用意した目録一封を差出した。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君にして、もしよくこの微衷を知らば、余にとりては誠に願うところの幸いであります。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "迷信の雲深きために宗教の月暗きはわが国のありさまなれば、かの雲を払ってこの月をめぐらし、これによって文運と国運の発展を助けんとする微衷にほかならぬ。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "東去西来知幾年、壮心一片老逾堅、微衷聊欲扶皇運、遥上南洋万里船。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "請う大方の君子、その微衷を察してこれを推恕せよ。",
              "citation": {
                "source": "妖怪学講義",
                "author": "緒言",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども生がこの過激蛮野の行為を辞せず、一身の汚名を堵して、微衷を吐露し、あへて一言を薦むるものは、いささか深厚の知遇に酬ゆるに外ならず。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに我が店員はもとより、かつての我々と同様、新たに商売を営もうとする人には多少の参考にもなろうかと思い、ひとえに後より来る人々への微衷よりして筆を執った次第である。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし同志の士、その微衷をあわれみ継紹の人あらば、すなはち後来の種子いまだ絶えず、おのづから禾稼の有年に恥ぢざるなり。",
              "citation": {
                "source": "留魂録",
                "author": "吉田松陰",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が余の窯場の傍らに陶磁器参考館を設け多数聚集の古陶磁器を一目瞭然に陳列なしたるが如きは即ち温故知新の意を以て窯芸に精進せむことを欲する微衷に外ならない。",
              "citation": {
                "source": "余が近業として陶磁器製作を試みる所以",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "押しつけがましき致し方とお怒りなく、老人の微衷万々お察し願上げ候。",
              "citation": {
                "source": "おもかげ抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兎に角、僕等は僕等で微衷を表したいんだが、何んなものだろう？",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "咫尺へ進んで、直々に、われらの微衷とみゆるしを、おすがりしてはどうだろう」「いいや」柴進は顔を振った――「まずいでしょう、いい機会ではありますが、ここはその場所でない」　すると、このせつな、どこか別な部屋の方で、「あっ、何者だッ」　という大喝と共に、どたんと、床を打ったような響きが聞えた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とぞ、微衷お酌みとり賜わって、お市の方様、ならびにお子様のおん身は、この戦場の外へお放ちくださいますように……。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一節には、――たとへ身は化して土中の白骨となるとも、殿にして微衷をわすれ給はず、おこころのうちに、ふとだにも御想起くださるなれば、重治の魂魄は、いつなんどきたりとも、殿のうつし身のうちに息吹き奉り、草葉の蔭よりの御奉公も決してかなはぬ事とは存じ申さず……　と、書いているところなども見える。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
