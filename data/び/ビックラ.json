        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（笑う）（このとき、次男の着つけも終わる）（花火の音がする）長女　　あら、びっくらした。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに持ってると、びっくらして死んじまうことよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は秘密を人に見られたでもしたようにびっくらした。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アア、びっくらしたよう。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし一つ倉地さんをびっくらさして上げますわ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくらして眼を開いたら夢でした。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな集団耕作だか、びっくらするヨ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだったら、母さんがお願いしてみて……」「そんなこと、母さん」　出しぬけの大声に、母親はびっくらした。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長く寝てしまったが、漸く床の上に起きあがれる日、びっくらしたのは、立派な結納の品々が、運びこまれ、紋付きの人たちが、病気全快のあいさつと一緒に、祝着申しますとあたしに悦びを述べた。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッともスッとも声が出ないで、びっくらして見詰めていると、ニヤとしたように赤い唇を歪めて、上の方についてる片っぽの眉をピクリと動かした。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも私はびっくらした事がある。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの通り晩に一口飲んで、いい機嫌になって鼻唄か何かで湯へ出かけると、じき湯屋の上さんが飛んで来て、お前さんとこの阿父さんがこれこれだと言うから、びっくらして行って見ると、阿父さんは湯槽に捉まったままもう冷たくなってたのさ。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、とうにもうどこへか行ってしまって、隣近所でも分らないと言うものだから、俺はどんなにガッカリしたか知れやしねえ」「私ゃまた、鳥居のところでお光さんお光さんて呼ぶから、誰かと思ってヒョイと振り返って見ると、金さんだもの、本当にびっくらしたわ。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　素麺を滝のように口にしたまま、眼を剥いたのが、黒い顔に、いかにもびっくらしたというふうだった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧問博士もびっくらしたのであろう。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度あ、一番、高座で、びっくらさしてやるんだ」　庄吉が、紐を解いて上りかけながら「師匠は、生きて戻るつもりかい――俺あ、死ぬんだ」　と、呟いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうち、おなかがへって、気がとおくなりそうなので、テーブルにあった若鶏をひときれ、おっかなびっくらたべました。",
              "citation": {
                "source": "ラ・ベルとラ・ベート（美し姫と怪獣）",
                "author": "ヴィルヌーヴ夫人　Madame de Villeneuve",
                "note": "青空文庫"
              }
            },
            {
              "text": "」っちから、つけてやると、それを旨そうに飲んで、急にご機嫌になっちまってね、どれ、姉さん、手の筋見てやっぺ……なんて、こう、ぐいッとおいささんの方へ寄り添っちまってね、おいささん、びっくらして、ぽかんとしているのもかまわず、手のひら引っくりかえして、ふう、ふう、姉さんは……っちわけだっけね。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいささん、はじめてびっくらして、嫌だって逃げると、そんなことはねえ、神様の杯、なんとかかんとかって怒り出しちまってね。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレーギン　びっくらなすったんだねえ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくらするじゃございませんか！",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、びっくらしねえでくだせえよ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "じょうぶ、びっくらした。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしのなざあ、何しろ、ひん曲ったのにはびっくらしました。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやれ、大概びっくらさせましたぞ、嬢さん。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜あたりへえって来るかもしれねえ、そうしたらこんだあおれが見物する番だ、へっ、つんのめったり、踏みぬいたり、どたんばたん独りで暴れて、埃まみれの汗だくんなって、それですっからかんのなんにも無しとくらあ、――へっ、野郎びっくらして馬鹿にでもなっちまうな」　だがその夜はなにごともなかった。",
              "citation": {
                "source": "泥棒と若殿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだったか、こわいもの持ってて、あたし、びっくらした」「びっくらか」　おいらん時分からすると、すっかり老けて見えた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
