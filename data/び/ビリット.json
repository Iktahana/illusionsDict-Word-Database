        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大砲が発射されるごとに、硝子窓は、ビリビリッと震動した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピストルを持った手を壊れた屋根の方へさしあげビリビリッと胴慄いをして、がらくたものが散らばっている街上に重くドシンと倒れた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビリッと布の裂ける音がした。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にパラリと封筒から出た台紙のない手札の半身姿の自分の写真を、ビリッと破っちゃったわ。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一九二二年十一月までが、絢爛たる主教の法服と煩瑣な儀式に守られた神聖な二年間で、その間はこの聖堂から秘密の指令が発せられるごとに、建設途上にあるモスクヴァの神経をビリッとさせる白い恐怖が、社会主義連邦のどこかに現われるのであった。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘田外務大臣はだまってこの通牒を見てしまうと、いきなりビリビリッとまっ二つに引き裂いた。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして誤って触れると、ビリビリッと来て、それでおしまいである。",
              "citation": {
                "source": "電気看板の神経",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと時を同じゅうして、佐々の乗っていたロケットは俄かにビリビリッと震動を始めた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビリッとひびいて、匂ってきたものがありました。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれを神様がお知らせになる女の匂いだナとビリッときましたね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクにだって、その実感がビリッときたですからね」「よせよオ。",
              "citation": {
                "source": "影のない犯人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストリップみたいなもんナンボ見たかてアカンワ、と車券をビリッとちぎって、エイッとすて、なんとなくウラミを骨髄から外すぐらいの寛仁大度に日頃の心得なき方々ではない筈なのである。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "「門から内へ這入られては困る、主人は他出してござる、ご不在と申すになんでも這入るとは、お人柄にも似ぬことでござります」「退け、何で袖を押える、放さぬと痛い目させるぞ」　焦慮気味の慎九郎は、老僕の押えた袖を、癇強く振り払った、袖は綻びてビリッと泣いた。",
              "citation": {
                "source": "討たせてやらぬ敵討",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビリビリッと手ごたえがあった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしやがる」　払いのけようと、矢萩が身体ごと振ったとき、チョッキがビリッと破れ、ボタンがちぎれた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビリッと手紙を裂いて、庭の面へ抛り捨てた御方は、気色ばんだ面を上げてあたりを見まわしたが、ふと壁の釘に掛けてある新九郎の着更、黒羽二重の衣類に目をつけて、手早く、それを自分の身に着け、男帯を上から締めて、いかつい大小まで腰に差した。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾にもあらぬ憤怒の眦、ビリビリッと寸裂した手紙を、蛇のように足に絡めたまま二、三間よろめき出した。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
