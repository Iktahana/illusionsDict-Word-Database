        "examples": {
          "standard": [
            {
              "text": "市場のニーズの変化をいち早く捉えることが、新たなビジネスチャンスに繋がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "展示会に参加したことで、思わぬところから大きなビジネスチャンスが舞い込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "失敗を恐れずに挑戦し続ける姿勢が、いつかビジネスチャンスを掴むきっかけになるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "パーソナルコンピューターの台頭によって、個々のユーザーが店頭で手にとって買う新しいソフトウエアの販売形態が生まれつつある以上、こうした動きに対応した流通経路の確立には大きなビジネスチャンスがあると孫は考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいビジネスチャンスを貪欲につかみにかかる過程で、西はいくつかの問題を積み残しもした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
