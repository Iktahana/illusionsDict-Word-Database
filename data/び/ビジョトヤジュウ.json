          "literary": [
            {
              "text": "もしもこの『美女と野獣』とが結婚したとすれば、じっさい、あまりにもこっけいなことになったでしょう。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間「美女と野獣」をみて、接ぷんを人間の心のあらわれとして芸術的に、深い余韻をもって扱っているのに注意をひかれた。",
              "citation": {
                "source": "さしえ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美女と野獣」、「悲恋」などは多くの観衆をあつめた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女と野獣との混血児、怪しくも美しき半人半獣の妖怪としか感じられなかった。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
