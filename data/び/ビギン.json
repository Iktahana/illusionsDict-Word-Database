[
  {
    "uuid": "cb72f4ef-6f18-5153-9e28-d52b27fcd49c",
    "entry": "微吟",
    "reading": {
      "primary": "びぎん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reciting poetry or singing in a soft voice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山処のひと本すゝぎ朝雨の狭霧に将起ぞ　翁は身体を撫でながら愛に絶えないような声調で、微吟した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西原氏は硝子戸越しに庭を眺めさりげない樣子で例の詩を微吟した。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころがせ　ころがせ　びいる樽とめて、とまらぬものならば赤い夕陽の、だらだら坂を　ころがせ　ころがせ　びいる樽　（北原白秋氏作）　西原氏は、この童謠の微吟を聞いた狂少女の顏に、何か捉へ得る表情の變化が現はれはしないかとひそかに望んだ。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は西原氏の詩の微吟に表情の微動さへ見せず、袂のなかを、しきりに掻き廻し始めたが、やがて何物か取り出して、西原氏の鼻先へ突き出した。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平地を行く時は大得意、馬上ゆたかに四囲の山々を眺め回わし、微吟に興をやって、ボコタリボコタリ進む。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "※の上に舁下されし貫一は頽るる体を机に支へて、打仰ぎつつ微吟せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「瓢空く夜は静にして高楼に上り、酒を買ひ、簾を巻き、月を邀へて酔ひ、酔中剣を払へば光月を射る」　彼は節をかしく微吟を放ちて、行く行くかつ楽むに似たり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "遙かに華街の灯りを望んでわが胸独り寥々……」　微吟しながら行くうしろ影の淋しさ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はひどく嘆息して、そのうちに何か微吟して見ることを思いついた。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢詩人｜森槐南が微吟する。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧野はその光の中へ、時々｜巻煙草の煙を吹いては、さっきの剣舞でも頭にあるのか、「鞭声粛々夜河を渡る」なぞと、古臭い詩の句を微吟したりした。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女もし問ふものに向つてあらはに事の仔細を語る事を欲せずとせんか、代るに低唱微吟以てその所思を託せしむべき歌曲に乏しからざるべし。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら君はここへ来る時詩を微吟していたらしいが、無慾の君のことだから、『｜贈僧』という杜荀鶴の詩でも、暗誦していたんじゃあるまいかな？",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時老人は感慨をこめて杜荀鶴の詩を微吟した。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どっちみち今日は変な日だった）　浪之助はそんなことを思いながら、まだ酔っている熱い頬を、夜に入って青葉の匂いを増した、さわやかな風に吹かせながら、樹木多く人家無く、これが江戸内かと疑われるほど、寂しい凄いお茶の水の境地を、微吟しながら歩いて行った。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうともして本道へ返さなければならない」徳大寺卿は微吟をした。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※｜柳の下のおちご様は、朝日にむこうてお色が黒い……　小｜舞物の古雅な「柳の下」を微吟しながら歩いて行く。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な言葉で吟っている」　こう云うと三太夫は微吟した。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「流星しばしば流るるは」　宗三郎微吟する。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような道を行きつ戻りつ、幾度かやり直しながら進んで行くと、王様はやや広い暗道の苔の褥の上に、だらしなく大の字に寝っころがって、悠々と微吟をつづけていられる。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかだか微吟をやめたばかりだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀でては不二の岳となり巍々千秋に聳え注いでは大瀛の水となり洋々八州をめぐる……　案によって微吟し、そぞろに鬱懐をやるの体。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "興に乗じて微吟が朗吟に変ってゆく。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹く風ならぬ白雪に勿来の関は埋もれて萩のうら葉もうら淋し　白雲はこういって、微吟しながら、その豪快なる胸臆のうちに、無限の哀愁を吸引し来ることにたえないらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹く風ならぬ白雪に勿来の関は埋もれて萩のうら葉もうら淋し　但し、ここで白雲の口頭に上った微吟の歌には、なんらの意義がない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて離れの別室にうつされて、主人の注文に応じて画を作ることになった白雲の微吟の音が、外へ聞えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の人は古時の月を見ざりしかど今の月は曾て古への人を照らしたりき古人今人、流るる水の如く共に明月を見て皆かくの如けんと微吟して、大きな柳の木蔭から、この北上川の沿岸の蒙蒼たる広原の夜気の中へ、のそりと歩き出した黒い人影がある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その広い原の真只中で、さきほど月に向って唐詩を微吟したところの大きい方の黒い影が後ろを顧みて、「君、恐山という山は、よっぽど高い山かね」　その声を聞くと、それは日中、渡頭を徘徊していたところの、下野の足利の貧乏にして豪傑なる絵師田山白雲に相違ありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが微吟となったり、閑話となったりして洩れて来るのは、その目的に達する間の道草に過ぎないと思われる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
