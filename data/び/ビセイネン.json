    "definitions": [
      {
        "index": 1,
        "gloss": "handsome young man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仲間はかならず二十代の美青年たるべきこと。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎の毛皮の外套を着て、ロイド眼鏡をかけた女があったらアメリカ娘と見てよろしい――彼女はタキシードを着たパリジャンの美青年給仕を眼で追いながら、ふかりふかり煙草を吸っている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま大声を発した男は、その一団のリイダア格の、ベレ帽をかぶった美青年である。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは日頃の彼女にしてみれば非常に珍しいことで、しかもその青年はちっとも美青年でもなんでもなくて、むしろうち見たところひどく不器用な感じしかない男なのですが、そんな点がいっそ却って彼女の心をひいたのかも知れません。",
              "citation": {
                "source": "恋",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "モットモット大きい、恐ろしく深刻な事件の予感が、美青年、深良一知の声を聞いた一｜刹那から黒い嵐雲のように草川巡査の全神経に圧しかかって来たのであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄で、顔色のよくない、眼が細く吊り上っていて、鼻の高い、美人というよりは、美青年といったほうがいいくらいの固い感じのひとであった。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖邸にもあまり近づかない復一は真佐子の夫にもめったに逢わなかったが真佐子の夫という男は、眼は神経質に切れ上り、鼻筋が通って、ちょっと頬骨が高く男性的の人体電気の鋭そうな、美青年の紳士であった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美青年も何かしら好意らしく笑った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美青年の笑顔は、まるで子供だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはむす子とは全然面影の型の違った美青年だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは銀座でそのことがあって一日おいて来た、あのナポレオン型の美青年からの手紙であった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柄が二十二の規矩男にしては渋好みで、それを襯衣も着ずにきちんと襟元を引締めて着ている恰好は、西洋の美青年が日本着物を着ているように粋で、上品で、素朴に見えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌のですか」「ふふふふ、歌のよ」　かの女はこのプラスフォーアを着たナポレオン型の美青年と歌の話をするのもどうかと無関心な顔をして、今日の規矩男の気勢を避けるため、さっきから持ち出していた小ノートに尚自分勝手な目前の印象を書き続けて行った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おかあさんは美青年だつたぞ。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長身痩躯、漆黒な髪をオールバックにした三木雄は立派な一個の美青年だった。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかの美青年で、やはり幾子に通っているらしい。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽傷の美青年がいた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の美青年に比べて、遥かに立派な態度と映ったが、彼の容貌は美しくはなかった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の愛人の美沢は、早く父を亡くして母親育ちであるだけに、お洒落な細かい動作が、身体にしみついていて、いかにも美青年らしく見えたが、この青年はいかにも健康な、スポーツででも鍛えたらしい若人という感じがした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな風采の男か、お聞きになりましたか」「スラリとした色の白い……女のような美青年だったそうです。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……美青年当九郎は表面上柔和な人間に見えながら、その底には、やはり実松氏と同様の超自然的な性格を隠し持っていた……しかも大恩ある叔父を執念深く附け狙って殺すというような残忍冷酷を極めた、非良心的な先天性の所有者であり得た事が、科学的に証明されて来るのですよ。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その乗客の一番後から、麻の背広を着た長身｜白皙の美青年が、姿を現わした。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜深く件の黒髪の孩児を抱きて秘かに産室をよろぼい出で、跣足のまま数｜哩を歩行して、翌日の正午親里に帰り着きしが、家人の隙を窺いて玄関横の応接間に入り、その正面に掲げある黒髪の美青年の肖像画の前に来り、石甃の上にたおれ伏したるまま息｜絶えぬ。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "擬い大島を着た二十ばかりの美青年である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者は、この恐ろしく単純な、且つ正直な不良美青年との約束を固く守ってやろうと決心した――神田の駿河台下で本紙を売っている、いないに拘らず……。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行員一同は、アナベル嬢と結婚する、この愛想のよい美青年から挨拶されて、とてもよろこんだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、すばらしい美青年。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は私の眼の前にいるドリアングレーのような美青年で最う一人は酒井男爵家の放蕩息子の忠直であった。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が今しがた此美青年を三度見掛けたと云ったのも、詰り遠乗りに出て行く姿を往来を歩き乍ら見掛けたのであって、そう云えば私も最う一度だけ此青年を見掛けたことがある。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
