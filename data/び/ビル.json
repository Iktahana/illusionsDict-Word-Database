        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな荒寥とした曠野の中に、五階七階のビルヂングがそびえ立つて、悲しい田舍の花火のやうに、赤や青やのネオンサインが點つて居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿の數多いビルヂングは、何かの張子細工のやうに見えるし、アスハルトの街路の上を無限に續く肥料車が行列して居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのビルヂングの林立する新宿の町々に、かうした多くの人物が生棲してゐることを考へ、都會の隅々に吹きめぐる秋風の蕭條といふ響を聞いた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもガードを一つ距てて、淀橋の向ふに二幸や三越のビルヂングが壘立し、空には青い廣告風船があがつて居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下から中央階段を降りようとする途中で窓越しに東を見ると、地下鉄ビルの照明が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸ビルの一階をぶらつく時など、八階のホトトギス社を尋ねて一度昔話でもしてみたいような気のすることがある。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸ビル時代の『ホトトギス』しか知らない人にはちょっとそれが分りにくいのではないかと思う。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の日本人がステンショとかオーフルコートとか称したことを考え、昭和の吾々がビルジングとかブデンとか云っていることを考えればこれくらいはゆるしてもらってもいいであろう。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に、船底にビルジキールと名づくる鰭のような物を着けると、その抵抗でよほど揺れが少なくなる。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが最近のある晩ＴＳ君がやはり丸ビル附近でそれと全く同じような経験をした、と云って話したところによると、やはり同じような子供を背負っていたが、しかしその徒歩での行先は亀井戸ではなくて吉原の裏の方だと云ったそうである。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある河の橋畔に出ると大きなビルディングが両岸に聳え立って、そのあるものには窓という窓に明るい光が映っている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またビルマ語で「コーンダーン」は小さき山脈。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビルマ「ニアジヨーク」も干魚である。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビルマでは「テー」砂。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は、どこか下町のビルヂングに支店を出すことに熱意を持ちながら、小鳥を飼うのを道楽にしていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪からながれてきたチヨダ・ビルのダンサー達が廃れた皮膚をしてアスハルトの冷たい街路に踊る靴をすべらした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾があの土地を買収したのも、妾はこの土地にポール商会のビルデングを建てるつもりなのよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東株ビルデングの石造の大建築が、人物をザンバのように呑みこんでいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "割引電車の青い労働帽の炎のような太陽が燃えて、世が明けわたると、半開のビルデングの鎧戸を汚れた袴をはいた女事務員がくぐり、表情の失せた勤め人たちが、破れたわい襯衣から栄養不良の皮膚をのぞかせて鏡のように磨かれた石造の建物に吸いこまれた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はビルデングの窓のカーテンをひらいた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "向いのＮ万ビルのマネキン事務所には、アメリカン・スタイルの女たちが地面にカードをひろげたように、緋の絨氈の上でお化粧を始めていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春雨」はビルディング街に煙り「秋風」は飛行機の翼を払うだけの包容性を失わないのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の方の空間で何かキラキラ光るものがあると思ってよく見ると、日本橋の南東側の河岸に聳え立つあるビルディングの壁面を方一尺くらいの光の板があちらこちらと這い廻っている。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か旧｜魚河岸の方の側で手鏡を日光に曝らしてそれで反射された光束を対岸のビルディングに向けて一人で嬉しがっているものと思われた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば某ビルディングの某会社のある窓の内に執務している甲某にその友人乙某が百メートルも先の街上から何かしらある信号を送るということがあり得るであろう。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ丸の内に聳えているＭのビルディング――彼はそのビルディングを見てきていた――を肥やしてやるばっかしだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと立派なビルデングになってるんだぜ。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞰下景ビルデイングのてつぺんから見下すと電車　自動車　人間がうごめいてゐる目玉が地べたへひつつきさうだ　高いところから下を見たときの感じがこんなにも生々と表現されたことはないであらう。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ビルマや、タミール、シンガリースなどから、漸次西に向かって、ペルシア、アラビア、トルコ、エジプトへんをあさってみると、やはりいくらかの関係らしいものが認められると思った。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
