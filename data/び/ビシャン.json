        "examples": {
          "standard": [
            {
              "text": "石切場の職人は、熟練の技で「ビシャン」を使い分け、硬い御影石の表面を滑らかに整えていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この壁のザラザラした質感は、ビシャン叩きという手法でわざと石の表情を出しているんです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "街の石材店から、カンカンと石を叩く「ビシャン」の小気味よい音が通りに響き渡っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが、不思議や羽根布団がビシャンコになってしまった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花の後姿は、そこへ一物を投げ込むと、ビシャンとしめて大急ぎでこちらへやって来そうな様子。",
              "citation": {
                "source": "接吻",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
