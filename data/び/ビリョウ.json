[
  {
    "uuid": "1f8c9e68-44e2-5ad6-8d8d-9d30e729dffa",
    "entry": "微量",
    "reading": {
      "primary": "びりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
