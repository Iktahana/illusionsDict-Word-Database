        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "危險なる新光線疾患せる植物及び動物の脊髓より發光するところの螢光又はラジウム性放射線が、如何に我我の健康に有害なるかを想へ、斯くの如き光線は人身をして糜爛せしめ、侵蝕せしめずんば止まず。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼蓋が腫れて顔つきが変ってしまい、そうしてその眼蓋を手で無理にこじあけて中の眼球を調べて見ると、ほとんど死魚の眼のように糜爛していた。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者は糜爛せる文明が生める不幸兒なり。",
              "citation": {
                "source": "女郎買の歌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "糜爛せる文明の不幸兒！",
              "citation": {
                "source": "女郎買の歌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりは體躯はます／＼糜爛して、癩病の如く見ゆるならむ。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕や脚一面に糜爛した腫物がはびこつてゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せた・目の大きい・腹ばかり出た・糜爛性腫瘍だらけの兒である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕や脚一面に糜爛した腫物がはびこっていた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せた・目の大きい・腹ばかり出た・糜爛性腫瘍だらけの児である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って彼、杉山茂丸は、その上海や香港に於て、東洋人の霊と肉を搾取しつつ鬱積し、醗酵し、糜爛し、毒化しつつ在る強烈な西洋文化のカクテルの中に、所謂｜白禍の害毒の最も惨烈なものを看取したに違いない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三｜日過ぎて與吉の火傷は水疱が破れて死んだ皮膚の下が少し糜爛し掛けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "水疱はいつか破れて糜爛した患部を、油は見るから厭はしく且つ穢くして居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の糜爛した横頬はもう火の氓びようとして居る薄明りにぼんやりとした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し傾げた彼の横頬に糜爛した火傷が勘次を悚然とさせた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は復た卯平の糜爛した火傷を見た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は復た糜爛した火傷を見ると共に、卯平の懷へ手を入れて居るおつぎを見た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し然しその人の個性がその事があったために分散し、精神が糜爛し、肉慾が昂進したとするならば、もうその人に於て本能の統合は破れてしまったのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、奥には横浜あり、東京あり、横須賀があつて、其処へ往来の汽船軍艦が始終出入りしてゐるので、常に沖辺に煙の影を断たず、何となく糜爛した、古い入江の感をも与へる。",
              "citation": {
                "source": "岬の端",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋風、支那風、日本風のあらゆる意味で堕落腐敗し糜爛して行きつつある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京人の堕落は、こうして爛熟期が糜爛期に入って行く。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "糜爛する浅ましい姿　記者はこうして、九月初めから十月｜半までの東京市中を、縦横むじんにあるきまわった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "糜爛性ガス、催涙性毒ガス、窒息性毒ガス、あのガラスの筒が投下された瞬間を想像するとぞっとしてしまふのだった。",
              "citation": {
                "source": "稲妻",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ敵の飛行機が糜爛性の毒瓦斯イペリットを落した。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "窒息性のホスゲンは堆肥くさく、催涙性のクロル・ピクリンはツーンと胡椒くさく、糜爛性のイペリットは芥子くさいから、瓦斯のあるなしはすぐわかるのだ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "患部をよく水で洗つて鹽氣を取除くのであるが、何しろ糜爛してゐる患部であるからなかなか鹽氣が拔けない。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "死児はふやけたような頭顱が、ところどころ海綿のように赭く糜爛して、唇にも紅い血の色がなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの糜爛した乳房や右の肘が、この連続する痛みが、痛みばかりが、今はわたしなのだろうか。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "めらめらの火や、噴きあげる血や、捩がれた腕や、死狂う唇や、糜爛の死体や、それらはあった、それらはあった、人々の眼のなかにまだ消え失せてはいなかった。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手片足の捩げた男、血まみれの裸女、全身糜爛の怪物、内臓の裂けて喰みだす子供、無数の亡者、無数の死体がすぐ彼の側を犇めきあひ、ぞろぞろと押されて進んで行く。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、生ではなく焼いたさかなで、あまつさえおしょうゆらしいもののつゆしるがしたたっていたものでしたから、右門のまなこは、ここにみたびらんらんと輝きを呈しました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            }
          ]
        }
