[
  {
    "uuid": "ef94d08b-61a1-5637-acaa-0714300f1f7a",
    "entry": "微分",
    "reading": {
      "primary": "びぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
