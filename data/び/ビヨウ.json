    "definitions": [
      {
        "index": 1,
        "gloss": "beauty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ミミ母娘美容院では、パーマネント・ウェーブの電流が蜘蛛の手のように空中にひらいて小柄なスイス公使夫人の黒い髪に巻きついていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグ美容院で女の肉体を占領した同志は同時に自己の領地を外国に棄てたのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞踊場で未来の墓誌銘に現代の道徳を刻んだ同志と、レムブルグ美容院の舞踊場の楽隊の奏でる哀悼歌に合唱して、米良は柩車のように螺旋をえがいて踊りながら、彼は絶えず東支那海の電信夫がもたらす秘密結社の女シイ・ファン・ユウの恋の便りを受取った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグ美容院の整頓された朝がやってきた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール流行品商会の二階の美容室では、太田ミサコが弟子にからだ中に花粉をはたかせていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから妾、発奮して美容術を習って二、三年後になって君と妾とだけの生活の道をつくっておきたいと思ったので、じつは丸の内の山根さんのところへ二年間内弟子にしてもらうことに決めたわ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――やあだが、承知するが、パパは君が美容術をやることは反対するね。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "父　滋賀県神崎郡八日市町二四四山崎晴弘姉　神奈川県鎌倉市長谷通り二五六　　　マ・ソアール美容院山崎つた友達本郷区森川町九〇加藤郁子淀橋区戸塚町一ノ四〇四宮崎晴子",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で自分を向上させることの出来るものですから、無理に隆鼻術の施行や美容法研究をせずとも、「此に欠くるところも彼に増すこともあれば又以て自ら善くするに足る」道理で、然のみ苦にするには当りません。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の美容術の第一課は、心のたんれんだ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、数日後、二人の行進は、日本橋のあるデパート内の美容室に向って開始せられる事になる。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしゃれな田島は、一昨年の冬、ふらりとこの美容室に立ち寄って、パーマネントをしてもらった事がある。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、すばらしく腕のいい美容師であった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行進　（五）　セットの終ったころ、田島は、そっとまた美容室にはいって来て、一すんくらいの厚さの紙幣のたばを、美容師の白い上衣のポケットに滑りこませ、ほとんど祈るような気持で、「グッド・バイ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親がわが事のように意気込んで、見合いの日室子を美容術師へ連れて行き、特別｜誂えの着物を着せた。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、美容師の蔦谷女史は、心から感嘆の声を放った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもし、美容術のうちはどっちでしたかね。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひなげしはあんまり立派なばらの娘を見、又美容術と聞いたので、みんなドキッとしましたが、誰もはずかしがって返事をしませんでした。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、一寸おたずねいたしますが、美容院はどちらでしょうか。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その美容術の先生はどこへでもご出張なさいますかしら。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このビルは終戦直後は進駐軍専門の土産物のマーケットで「一般の人ご遠慮願います」という貼紙が出ていたが、そんな経営法もいつか立ち行かなくなったか、一階二階はいわゆる「一般人」相手の雑貨店、二階のすみには喫茶店三階は料理店や美容室――というややこしい経営法に変ってしまっていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一日に一ぺんはこれをやりませんと、皮膚があらびましてな」　わたくしは釣り込まれて、見物しながら、「お酒の美容術ね。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしの家出が封鎖のためにオジャンになったと判れば、パパは封鎖賛成論に逆戻りするかも知れないわ」　皮肉だけはつぶやいたが、しかし、たまたまセットに行った美容院で、茉莉と知り合い、相談を持ちかけた時は、全く途方に暮れていたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり美容の目的から出た産児制限ですね。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれながらの聖人で無いのであれば、天然自然に完全純粋で精美容明な人はいない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "相師の一言のおかげで、かかる美容を持ちながら盛りの花を空に過さしむるを残念がって、請わるるままに父が妙光を殺婦に遣った心の中察するに余りあり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはあしたから灰をかぶって街の廣場に座り、おまへとみんなにわびようと思ふ。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下へ延びようとしても出来ないでしょう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絵がまるでほんもののようでしたからキッコの弟のよろこびようと云ったらありませんでした。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の末のみんなのよろこびようといったらありませんでした。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
