          "literary": [
            {
              "text": "Ｂクラスは奥の子供部屋でやるのである。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "北平の陸軍刑務所を振出しにして、南京の中央刑務所、仏印のパクセ俘虜収禁所、昭南の第一拘禁所、泰緬鉄道建設で俘虜大量虐殺の問題を起している有名なタンピサヤ収容所、ジャカルタの蘭印俘虜収容所……Ｂクラスの収容所まで数えたら何カ所だったかちょっと思いだせない。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（床下の声）清水　（床下へ向って）三年のＢクラスの。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴田　うむ――そりゃ、しかし――清水　Ｂクラス全員の希望です。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三〇年代にＢクラスの西部劇を一本つくるには二万ドルあれば充分だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
