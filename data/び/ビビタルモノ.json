[
  {
    "uuid": "e6334b74-aecf-5a05-9e7c-445d5dff4b42",
    "entry": "微々たるもの",
    "reading": {
      "primary": "びびたるもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
