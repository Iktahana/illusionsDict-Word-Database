        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶をのんで粗末なビスケットを二つ三つかじる。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は毛布をかけてねたまま手を出してビスケットを取って食っている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに追分辺でミルクの缶やせんべい、ビスケットなど買った。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕の少女に九鬼は紅茶とビスケットをくれないかといった。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットってクッキーのことですかと少女が尋ねた。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットという古い言葉がクッキーという新しい言葉に代ってしまっているのを初めて知って、自分の住んでいる古い世界と少女の住んでいる新しい世界との間隔に軽い目まいを感じたのである。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「煙のビスケット」が生物のように緩やかに揺曳していると思うと真中の処が慈姑の芽のような形に持上がってやがてきりきりと竜巻のように巻き上がる。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、そのころどこかからもらった高価な舶来ビスケットの箱が錠前付きのがんじょうなブリキ製であったが、その上面と四方の面とに実に美しい油絵が描かれていた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たわいもない幻影を追う目がガラス棚のチョコレートに移ると、そこに昔の夢のビスケット箱の中のメールコーチが出現し、五十年前の父母の面影がちらつき、左団次の知盛が髪を乱して舞台に踊るのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士はマッチをすって火をたき、それからビスケットを出しもそもそ喰べたり手帳に何か書きつけたりしばらくの間してゐたがおしまひに火をどんどん燃してごろりと藁にねころんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットのあるうちは、歩いて野宿して、面白い夢でも見る分が得といふもんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまっくらなとこでもしゃもしゃビスケットを喰べた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士はマッチをすって火をたき、それからビスケットを出しもそもそ喰べたり手帳に何か書きつけたりしばらくの間していたがおしまいに火をどんどん燃してごろりと藁にねころんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットのあるうちは、歩いて野宿して、面白い夢でも見る分が得というもんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶は紅茶で、お茶受けにはパンの薄片にバターを塗ったもの、ビスケット、ケーキ、その時々の主婦の思い付きによります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私に取ってこういう奇蹟的な存在の人が、世間では私の母の廉い仕立もののお得意さまであって、現在、製菓会社の下級社員で、毎日ビスケットを市中に届けて歩き、月給金○○円の方であるとは、どうにも合点がゆきませんです。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を卸して、座りながら、革鞄の中からビスケットを取り出して食っていると、　不思議　洞穴の奥で何やら唸くような声がする※　二人は驚いて、互に顔を見合せていたが、東助は声を潜めて、「あの声は何でしょう。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――土耳古人にお鮨もおかしい、が、ビスケットでもあるまいから、煎餅なりと、で、心づけをして置いて、……はねると直ぐに楽屋で会った。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、おいしいパンやビスケットを、ほしいだけもらいました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の内側には、お砂糖のはいったビスケットが、いっぱいつめこんであって、腰掛けの下にも、果物やコショウ入りのお菓子が、はいっていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットでも持っていれば、たといそれが一つでも、半分ずつ食べることができるのでしょうが。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クロ、出る番だよ」　正坊はクロをおりの中から出すと、れいによって鼻のうえをなでさすりながら、クロの大すきなビスケットを、口の中へいれてやりました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍の正坊は、クロのせなかにまたがったまま、ポケットからビスケットをつかみ出して、口の中へいれてやりました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "正坊はにこにこしながら、ふくろからビスケットをつかみ出して、クロの口の中へいれてやり、なんどもなんども鼻のうえをなでてやりました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "備えたのはビスケットである。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩薩の壇にビスケットも、あるいは臘八の粥に増ろうも知れない。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの宿へ二十年も馴染なのです」　葛岡はと言うと、私たちがこの宿へ入って来てから先生がわたくしにかまけ切ってばかりいるのを見て、結局その方が気楽とでもいうように勝手に褞袍に着換えたり、宿のおかみさんが持出した安ビスケットや山独活の漬ものを撮んだり、コヽアを飲んだり、一人で自分の身を犒っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人ごみを危ながる老女に率いられた幼ない子たちは、小動物園の金網の前で小猿の餌のビスケットを分け与えられています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花のしんにはプリマ・ビスケットを積み上げる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
