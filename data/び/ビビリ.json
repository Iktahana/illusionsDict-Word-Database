    "definitions": [
      {
        "index": 1,
        "gloss": "being easily frightened",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は本当のビビリなので、暗い夜道一人で歩くのは絶対に嫌がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の雷鳴に、一番ビビリだったのは、いつもはおしゃべりなうちの猫だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "肝試しで、ちょっとした仕掛けに悲鳴を上げた。自分でもこんなにビビリだったのかと驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "俺は平和主義者で、ビビリなんだ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなビビリは見たことがない。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "chatter (undesirable vibration in machine tools)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
