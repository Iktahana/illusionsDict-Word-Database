    "definitions": [
      {
        "index": 1,
        "gloss": "fluttering (esp. of thick or heavy material)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんなさびしい風景の中にうきあがつて、白つぽけた殺人者の顔が、草のやうにびらびら笑つてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の気配もないのに、大砲の音が遠くで聴え、城壁の周囲に立てた支那の旗が、青や赤の総をびらびらさせて、青竜刀の列と一所に、無限に沢山連なっていた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒寥地方散歩者のうろうろと歩いてゐる十八世紀頃の物さびしい裏街の通りがあるではないか青や赤や黄色の旗がびらびらしてむかしの出窓に鐵葉の帽子が飾つてある。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街之圖散歩者のうろうろと歩いてゐる十八世紀頃の物わびしい裏町の通があるではないか青や　赤や　黄色の旗がびらびらしてむかしの出窓にブリキの帽子が竝んでゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲を撃つわたしはびらびらした外套をきて草むらの中から大砲を曳きだしてゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱や手すりを白樺の丸太で作り、天井の周縁の軒ばからは、海水浴場のテントなどにあるようなびらびらした波形の布切れをたれただけで、車上の客席は高原の野天の涼風が自由に吹き抜けられるようにできている。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船だねえ、雪のびらびらした顔の船だねえ、さういふものが、いつたりきたりしてうごいてゐるのだ。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪に挿した簪のびらびらが、月を映して揺れなびき烈しい眩ゆさで光りつづけた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面に月をうけて立った舞妓たちの簪のびらびらが、せせらぐ川波の中で揺れていてまだ宵らしくつづいた川向うの灯が、橋を渡る夥しい人の足を浮きあがらせて賑かだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、ここに放つてあるから、ひがんじまつたのよ」「食物でひがむのなら判るけれど、まさか、旦那さまのことでひがむのないわねえ……」　登美子は寫眞を取つて、薄いびらびらの紙も丁寧にかぶせて、杉枝の膝に、「大事になさいよ」　とそおつと置いた。",
              "citation": {
                "source": "婚期",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヤードに新しくあげた信号旗をびらびらさせながら、平靖号の方へ近づいていった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁をふらふらにくっつけ、長い毳のある肩掛をぐるぐる巻きつけ、鍔のびらびらしている帽子をかぶり、泥だらけの脚をして、その馬車の中から体をゆすぶりながら出て来た、乗客のロリー氏は、幾らか、大きな犬のようであった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "若葉が、びらびらと湿っぽい風に揺れている。",
              "citation": {
                "source": "抜髪",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると髪に※した花簪のびらびらが、美しく揺れた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
