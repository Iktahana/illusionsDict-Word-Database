          "standard": [
            {
              "text": "ビタミンB群の一種であるビオチンは、皮膚や髪の健康維持に役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "サプリメントでビオチンを摂取することで、爪の割れやすさが改善されることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このシャンプーには、髪のハリとコシをサポートするビオチンが配合されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "1937年までにパントテン酸、B6【ピリドキシン（ＰＮ）グループ】およびビオチンが水溶性ビタミン（表２）に加わった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
