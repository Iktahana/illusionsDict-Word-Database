    "definitions": [
      {
        "index": 1,
        "gloss": "Bitchū (former province located in the west of present-day Okayama Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "イイシへ守備中隊を出すのは、そこの連絡を十分にするがためであった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "講釈の方は越前国一｜条ヶ｜谷朝倉左衛門尉義景十八｜人の侍大将の中に、黒坂備中守と云ふ、これは私の隣国。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で、此の随筆が出処だとすると、何のために、奥州を越前へ移して、越中を備中にかへたらう、ソレ或ひは越中は褌に響いて、強力の威厳を傷けやうかの深慮に出たのかも計られぬ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の備中、一時越前の領土巡検の役を、主人義景より承り、供方二十｜人ばかりを連れて、領分の民の状態を察せんため、名だゝる越前の大川、足羽川のほとりにかゝる。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "備中馬を立てゝ、「頗る水だな。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "備中驚き嘆じ、無事に渉り果てた按摩を、床几に近う召寄せて、「あつぱれ、其の方、水にせかるゝ大巌を流に逆らひ押転ばす、凡そ如何ばかりの力があるな。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝音にも聞きつらん、予は白山の狩倉に、大熊を撲殺した黒坂備中、此の方も未だ自分に力を試さん、いざふれ汝と力競べをして見やうか。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　うん、と備中、鼻膩を引いた――とある。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宜いか按摩、と呼ばゝつて、備中守、指のしなへでウーンと打つたが、一向に感じた様子がない。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で渋りながら備中守の差出す腕を、片手で握添へて、大根おろしにズイと扱く。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ト傍に控へた備中の家来、サソクに南蛮鉄の鐙を取つて、中を遮つて出した途端に、ピシリと張つた。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "備中苦笑ひをして、「力は其だけかな、さて／＼思つたほどでもない。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときの切支丹奉行は横田｜備中守と柳沢八郎右衛門のふたりであった。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "追って大実業家たらんとする準備中のが、笑いながら言ったのである。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、国漢文中等教員の検定試験をうける準備中であった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐天竺ほどではなくても、せめて備中玉島でもよいのです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "備中玉島なら、この間ここの寺へ泊つてゆかれた、ほら、何とかいふ坊さん……。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「備中へいくことにきめました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから江戸へ出て、それから京都にのぼり、そして目的地の備中の国、玉島へいく、遙かな道のことを思つた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ風にして、良寛さんは備中玉島の円通寺についた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　円通寺で　良寛さんが、これから二十年あまり送ることになつた備中の国、玉島は、瀬戸内海に面した港町であつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「越後の出雲崎といふところですが、もう十五、六年も備中にゐますぢや。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　ふたたび故郷へ　長崎から清へ渡ることに、失敗した良寛さんは、また備中玉島の円通寺に帰つてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど、一つの果物と同じやうに、良寛さんの心を柔かに、ゆたかに、温かに熟さしめた、この明かるい備中の国の自然に、かうして、良寛さんは別れをつげた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗の方の片倉｜備中守が三春の城に居るから、油断のならぬ奴への押えである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高崎中学を終えてから、各地の医専の入学試験を受けている最中、リョウマチにかゝり、少青年期の大事な部分を実家で療養に暮すうち中学生上りともつかず田舎紳士ともつかない鵺の青年になったらしい弟は、せめて生活の業にもと近頃では鍼灸師の資格試験の準備中なのでありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき天皇はそのころ吉備といっていた、今の備前、備中地方の、黒崎というところに、海部直という者の子で、黒媛というたいそうきりょうのよい娘がいるとお聞きになり、すぐに召しのぼせて宮中でお召し使いになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "与力の座を立ったあとへ、城代太田備中守資晴がたずねて来た。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝倉方は、黒坂備中守、小林｜瑞周軒、魚住｜左衛門尉を先頭として斬ってかかった。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時朝倉方の大将、黒坂備中守、前波新八郎、尚左岸にあり奮戦していた。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
