    "definitions": [
      {
        "index": 1,
        "gloss": "good-looking man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、ゆつたりした美丈夫であつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ゆったりした美丈夫であった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美丈夫と艶なる少女は、ふと飛立つように身を起した。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は下賤から身を起して、人品あがらず、それこそ猿面の痩せた小男で、学問も何も無くて、そのくせ豪放｜絢爛たる建築美術を興して桃山時代の栄華を現出させた人だが、一方はかなり裕福の家から出て、かっぷくも堂々たる美丈夫で、学問も充分、そのひとが草の庵のわびの世界で対抗したのだから面白いのだよ。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子があとから連れて来た青年は、むす子より丈が三倍もありそうな、そして、髪も頬も眼もいろ艶の好いラテン系の美丈夫だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はこんな出来上った美丈夫が、むす子の友達だなんて信じて好いのかと思った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんが毎年その都に行はれる荒馬馴らしの競技場へおかあさんの美丈夫を出し度くなつたんだ。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて衝と翳すとともに、美丈夫、秀でたる眉に勇壮の気満つ。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "男、りんりんたる美丈夫であったのである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "許嫁は大学の制帽を被り、頼もしく、美丈夫だと言っても良い程の容貌をしていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は丈高く、均整のよく取れた体格で、色のあさ黒い美丈夫である。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "生年二十三歳の堂々たる美丈夫の返詞としては、不思議ではないか。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇ましいぞ」　不意にうしろの濃い霧の中から、すさまじい笑声が爆発したかと思うと、降って湧いたかのように、ぽっかりと霧の幕を破りながら立ち現れた着流し深編笠の美丈夫がありました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしゃもう知りませんぜ」　水の出ばなの美丈夫右門を、とうとう隠居にこきおろしてしまって、しきりと口をとがらしていましたが、しかし右門は静かに微笑したきりでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鋭くいわれて、女はこわごわ面を上げながら、燃えさかってきたたき火のあかりで、しげしげ右門の姿を下から上に見ながめていましたが、そのみずみずしくも秀麗な美丈夫ぶりに、それとうなずかれたものでありましょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の曲がった腰はまずしゃっきりと若者のごとくに伸び直り、そして悠揚とそこの泉水で面を洗うと、りりしくもくっきりとした美丈夫の姿と変わったのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、若い野獣のような、すばらしい美丈夫の巷の無頼漢「チャア公｜兄哥」に成長していることであろう。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "李もまた白皙の美丈夫である。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その十一　允成は才子で美丈夫であった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "美丈夫允成に肖た可憐児であったものと想われる。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし三村清三郎さんは※斎が美丈夫であつたと云ふことを聞き伝へてゐるさうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "美丈夫であつたが、首を掉る癖があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュピターとジュノーの間に生まれた息子で、美丈夫の典型とされている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛国婦人会を設立した奥村五百子も、美丈夫のような美しさがあった。",
              "citation": {
                "source": "明治大正美女追憶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時他に比肩するもののない美丈夫なのだ。",
              "citation": {
                "source": "書かれざる作品",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "美妙斎は二十七になった美丈夫だ。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの御婦人は、我々の仁義を諒とせられて、目下、下情を御視察中のけなげなる美丈夫というものですよ」「然し、思召しはあるだろう」「それは、あなた、木石ならぬ我が身です」「アッハッハ」　大笑一番、ふと私に盃をさして、「これは面白い。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、自分が、ある美丈夫の心を惹きつけたといふことだけ、彼になんとかして知らせておく方法はないか知ら……。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　半蔵の心に描く平田篤胤とは、あの本居宣長を想い見るたびに想像せらるるような美丈夫という側の人ではなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
