    "definitions": [
      {
        "index": 1,
        "gloss": "temple name (a two-character posthumous name given to Chinese, Korean and Vietnamese royalty)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝鮮王朝の歴代王には、その功績を讃えて「世宗」や「正祖」といった廟号が贈られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史家は古い碑文を解読し、そこに刻まれた廟号から当時の王朝の系譜を再構成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この廟号に込められた意味を知ると、当時の人々が王に抱いていた敬意が伝わってくるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "建文帝の皇考興宗孝康皇帝の廟号を去り、旧の諡に仍りて、懿文皇太子と号し、建文帝の弟｜呉王允を懐恩王となし、除王允※を敷恵王となし、尋で復庶人と為ししが、諸王｜後皆｜其死を得ず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "name given to a mausoleum (or shrine, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "荘厳な霊廟の入り口には、その主を象徴する高貴な廟号が刻まれた扁額が掲げられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "村の古老たちは、今でも先祖代々の墓所を尊崇の念を込めてその廟号で呼んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "観光ガイドは、豪華な彫刻が施された門を指差し、そこに記された廟号の由来を説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
