    "definitions": [
      {
        "index": 1,
        "gloss": "ideal weather (for some action, event, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "永日和讚萩原朔太郎ひとのいのりはみなみをむき、むぎはいつしん、うをはいつしん、われはしんじつ、そらにうかびて、ゆびとゆびと哀しみつれ、たましひはねもごろにほとけをしたふ。",
              "citation": {
                "source": "永日和讚",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな日和見主義であります。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の咏嘆しているものは、時間の遠い彼岸における、心の故郷に対する追懐であり、春の長閑な日和の中で、夢見心地に聴く子守唄の思い出である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが裏街の芥捨場や、雑草の生える埋立地で、詩人の心を低徊させ、人間生活の廃跡に対する或る種の物侘しい、人なつかしい、晩春の日和のような、アンニュイに似た孤独の詩情を抱かせるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅｜遠近南すべく北すべく「遠近」という語によって、早春まだ浅く、冬の余寒が去らない日和を聯想させる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の軒には干魚がかけて乾してあり、薄ら日和の日を、秋風が寂しく吹いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬ざれや北の家陰の韮を刈る　薄ら日和の冬の日に、家の北庭の陰に生えてる、侘しい韮を刈るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "共に冬の日の薄ら日和を感じさせ、人生への肌寒い侘びを思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の暖かい日にはうとうと居眠りをした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "久し振りの好い秋日和で、澄み切った日光の中に桜の葉が散っていた。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穩かな行樂日和に淺草は賑かだつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦播きがすむと、彼等はこんどは、枯野を歩いて寺や庵をめぐり、小春日和の一日をそれで過すのをたのしみとしているのだ。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々は、ブルジョア的平和主義者や、日和見主義者に変ることなく、吾々が階級社会に住んでいること、階級闘争と支配階級の権力の打倒との外には、それからの如何なる遁れ路もないし、またあり得ないことを忘れてはならぬ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは三月なかばの花見｜日和といううららかな日で、ぶらぶら歩いている二人のひたいには薄い汗がにじんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七が身支度をして神田の家を出たのは朝の四ツ（午前十時）過ぎで、会式桜もまったく咲き出しそうな、うららかな小春｜日和であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは高野山に籍を置くものだといった、年配四十五六、柔和ななんらの奇も見えぬ、懐しい、おとなしやかな風采で、羅紗の角袖の外套を着て、白のふらんねるの襟巻をしめ、土耳古形の帽を冠り、毛糸の手袋を嵌め、白足袋に日和下駄で、一見、僧侶よりは世の中の宗匠というものに、それよりもむしろ俗か。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "西部の森林地帯では「火事日和」なるものを指定して警報を発する設備もあるようである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝の日曜は青々と晴れたステキな庭球日和であった。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の日曜とて、青山の通りは人出多く、大空は澄み渡り、風は砂を立てぬほどに吹き、人々行楽に忙がしい時、不幸の男よ、自分は夢地を辿る心地で外を歩いた。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し大庭真蔵は慣れたもので、長靴を穿いて厚い外套を着て平気で通勤していたが、最初の日曜日は空青々と晴れ、日が煌々と輝やいて、そよ吹く風もなく、小春日和が又｜立返ったようなので、真蔵とお清は留守居番、老母と細君は礼ちゃんとお徳を連て下町に買物に出掛けた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく東京に残っていた母が病気になったので皆で引上げて帰って来る、その汽車の途中から天気が珍しく憎らしく快晴になって、それからはもうずっと美しい海水浴日和がつづいたのであった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あれが中日和といふものだつたのでせう』と母は、埋葬を終へた日の宵、私達四人の兄弟がゐる所で云つた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『中日和つて何』と、せきこんで末の弟は訊いた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の午後の陽ざしは、トシオの広い賢げな額や、健康らしく肉付きの引しまった頬に吸い寄りました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの橋でも真新らしい日和下駄の前を橋板に突き当てて、こんと音をさせ、その拍子に後歯を橋板に落してからりと鳴らす必要があった。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とめて虫が内に籠りでもしたら悪い」そういって新しい日和下駄をよく買い代えて呉れた。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそう思いながら、新らしい日和下駄を買ってそっとスーツケースの奥に入れた。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびよりかへれる巡禮のうた萩原朔太郎いすらへるよりかへり　われはゆきのうへにたちぬ",
              "citation": {
                "source": "たびよりかへれる巡禮のうた",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気のよい秋びよりは日がくれると急に寒くなるものです。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのうちは、ひっそりとしていましたが、まもなく、あの小さな女の子が出てきて、そっと、とり小屋にしのびよりました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
