          "literary": [
            {
              "text": "時間内びっちり働いても、アパートに帰り着くのは八時、九時となる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれはナラ、ドロ、イタヤモミジなどの類であったが、その生きの強い樹と生命をあらそうように、下には熊笹がびっちり生えていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生れてから肩の凝るということは未だ知らないのですが、今度十日ばかり続けて朝から夕方までびっちり描いたら、仕舞いには腕が動かなくなってしまって、到頭按摩というものにかかりました」という森田さんの話であった。",
              "citation": {
                "source": "壁画摸写",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い糸の、こまかいびっちりの十字｜繍いなんかそうざらにはないわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
