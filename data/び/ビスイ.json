[
  {
    "uuid": "85ebaa5b-a7e4-5b38-b12b-d19b6450526e",
    "entry": "微睡",
    "reading": {
      "primary": "びすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
