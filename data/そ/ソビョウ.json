    "definitions": [
      {
        "index": 1,
        "gloss": "drawing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の生涯は、素描にしか過ぎなかつたし、彼は喜んで素描の外観を作品に賦与してゐる。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかだか、三枚か四枚で、井伏さんの素描など、不器用な私には出來るわけがないのだ。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以上は匆卒の間に筆をとった一葉の素描のようなものに過ぎないのであって、色々の点で間違いや思い違いがありはしないかと気遣わしい。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜小さい花子の話　ロダンさんは、一九○六年マルセーユに、カムボジヤの触妓の素描をしにやってきたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンブラントの素描めいた風景が散らばっている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者の小品集「怪談」の中にも出て来る「轆轤首」というものはよほど特別に八雲氏の幻想に訴えるものが多かったと見えて、この集中にも、それの素描の三つのヴェリエーションが載せられている。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日と今日は、床のそばに机を出して貰つて、レンブラントの素描を模写した。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」素描一「私はこの父さんと、一度きり大衝突をしたことがあるの。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上が、入江家の人たち全部のだいたいの素描である。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人道主義的なマルキストであり、感傷的な文学少年、数学の出来なかったぼくは、ひどい自涜の為もあったのでしょう、学校に友達なく、全く一人で、姉、近所のＷ大生、小学時代の親友、兄夫婦も加えて、プリント雑誌『素描』を二年続けました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオナルドオのあの鋭くして柔軟な素描を残したジエロニモこそ世にもこよない物である。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前で例の春信型の線の細い輪郭の、例の顏容の女が盥で湯を使つてゐるのであるが、その線は寫實的であつたから不快ではなかつたが、ロダンやマネの素描の知的な冷たさに代へて、柔かく、唯單に肉體の輪郭を仕切るといふ必要以外の艶冶を見せようという作意の爲めに、全體がやや浮世繪的官能的になつたのはやむを得ない。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私は、その謝罪の意味で「探偵小説なるものに対する私の素描」をここに更めて御披露させて頂く事にした。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく妙な災難はインド人の部屋でも起こった――相手は無口で小柄な鉤鼻の男で、我々を訝しげに眺め回したが、ホームズによる建物の素描が終わりを迎えるとあからさまに喜んでいた。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の秋草の花のいろいろに咲き乱れた夕方に、海の見える廊のほうへ出てながめている源氏の美しさは、あたりの物が皆｜素描の画のような寂しい物であるだけいっそう目に立って、この世界のものとは思えないのである。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "素描家としてのゴッホには、驚くにたりない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝展第六回の『斜陽』といふ作品は氏の素描が直ぐ絵の完成された表皮に浮びあがり生かされてゐるといふ意味で、いかにも軟らかい仕事なのである、しかしこの作品は、他の山水風景に較べて柔軟に自由に描かれてはゐるが、却つて暗中模索的な、懐疑的な作品なのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はこの質問者にぶつきら棒に答へた『もし造形性を無視して、僕のやうな絵が描けたらお目にかゝりたいですよ――』と実際に私は本職の洋画家の人よりも、最近では沢山画を書いてゐるのだし、素描もかなりたまつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンナツマラナイ素描帳ヲ見テクダサイト言ウノハタイヘンツライノデス。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねがね彼の細君は、畫を習つてゐて、追々と人體の素描に移つて、彌生をモデルにしてゐることは薄々隱岐も知つてゐたから、裸體像にはさして驚きもしなかつたのであるが、あんまりモデルが大袈裟に仰天して狼狽するので、返つて飛んでもない痴想に攪亂されさうだつた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この手は、ルーベンスの素描を參考にして描いたのだ。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙と汗の音曲４・30（夕）　洋画家の満谷国四郎氏はこの頃謡曲に夢中になつて、画室で裸体画の素描を行る時にも、「今はさながら天人も羽根なき鳥の如くにて……」と低声で謡ひ出すのが癖になつてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "往つてみると、伯耆にも色々山はあつたが、二人が平素描き馴れてゐるやうな珍らしい山は一つも無かつた、二人は落胆して今一つの方へ出掛けた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩から小説への過程を、画家における素描の勉強に等しい散文でのスケッチで鍛錬したことは、修業の方法の最も適当な道であったろう。",
              "citation": {
                "source": "藤村の文学にうつる自然",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なによりもさきに、私は町ぜんたいを受け入れて素描しなければならない――この場合ではコペンハアゲンという対象を。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が自分の空想の小さいはけ口としてその音楽堂の素描を私にまで見せたりした、その望みは十何年か前から既に心に潜んでいたものであったのかと、特に当時は父が大してすきでもなかった文部省の小役人であったとしてみれば、一層この実現したかしないか分らないデッサンにしたしみを覚えます。",
              "citation": {
                "source": "父の手帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような環境の間で十四歳になったとき、ケーテに、初めて石膏について素描することを教えたのが、ほかならぬシュミットの仕事場に働いていた一人の物わかりのいい銅版職人であったという事実は、私たちに深い感興を与える。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伸子」の続篇として、一九二七年以後の二十年間の社会思想史の素描ともなる「二つの庭」、「道標」第一部、第二部がかかれ、目下第三部が執筆されている。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か簡単なもので好い、一寸した素描のようなもので好い。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
