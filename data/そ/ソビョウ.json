  {
    "uuid": "3f911bd8-daf3-55f0-b41b-fc9d44aecf0b",
    "entry": "粗描",
    "reading": {
      "primary": "そびょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rough sketch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、この文章の中で今日の文学の現実の姿を粗描し、文学以外の専門に従事する人々のためにも今日の文学的討論や作品の健全な理解に役立ちたいと思う。",
              "citation": {
                "source": "今日の文学の鳥瞰図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "メモに過ぎず、粗描に過ぎないのだ。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は死から、粗描から、忘却から出てくるのである。",
              "citation": {
                "source": "クロオデルの「能」",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき森の中で一本の樺の枝の網目が彼にこっそりとその粗描をほのめかしただけで、それきり立ち消えてしまっていた何かの影が、そんな殆ど記憶にも残っていない位のとうの昔に死んだ母の顔らしかった事に明はそのときはじめて気がついた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはモティーヴを私が出して、粗描を寿江がして（小さく）そしてたのんだもんで、合作だねって苦笑いしているの、でも傑作よ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ一時代前の東山趣味ともいえる、燻んだ墨と、粗描の線と、多くの余白との中に甚だしく余韻を尊んでいた。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
