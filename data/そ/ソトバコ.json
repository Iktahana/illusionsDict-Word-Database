          "literary": [
            {
              "text": "主上は御手づから外箱と中箱とを取りのけさせられた。",
              "citation": {
                "source": "茶話",
                "author": "昭和五（一九三〇）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "小指の尖で、中身をポンと落しメリメリと外箱を壊して裏をひっくりかえすと、弦吾はポケットから薬壜を出し、真黄な液体をポトリポトリとその上にたらした。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに内箱外箱、御袋など一と通り揃つてゐると、これは大變なことになります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "内箱は桐の白木で、外箱は塗がありました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに内箱外箱、御袋など一と通り揃っていると、これは大変なことになります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞紙や外箱だけが燃え尽きて、あとどろどろなのが残った。",
              "citation": {
                "source": "記憶",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "又外箱にも屡々用ゐたが、今考へるとさう云ふ使ひ方は物体ないと思へる。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これよ、誰かここへ来て、荷箱を造っておくれ」　耀蔵が手をたたくと、ほかの者が、彼女の見ている前で、外箱を造り、二重に入れて、桐油紙づつみに縄をかけた。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
