        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのころ、与一は木綿の掛蒲団一枚と熟柿のような、蕎麦殻のはいった枕を一ツ持っていた。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日村を歩きまわって、貰ったのは蕎麦殻の袋だった。",
              "citation": {
                "source": "とも喰い",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　挽臼の石に挟まれた蕎麦殻は、ぐしゃりぐしゃりと筵に落ちて来た。",
              "citation": {
                "source": "とも喰い",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕というは黒板ふき位の大きさの、蕎麦殻をつめ込んだ小さな袋である。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕は蕎麦殻をつめ込んだ、小さな坐布団みたいなものに、薄い日本紙をかぶせ、軽い木箱に結びつけたもの。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "野に満ち満ちている両軍の精兵は、まるで蕎麦殻をきれいに置いて、大地に陣形図を描いたように見える。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
