      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to turn away (one's eyes, face, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてある種の気質の者だったら、この注意をまた他へ逸らすために、なんとか骨を折ってみなければならんとすぐに感じたろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、凶行の真の現場から注意を逸らす目的で、あの品物が茂みのなかへ置かれたのだという嫌疑には、そのほかにも根拠がないわけではない。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "道理ある言葉でも、廣岡や畑浦などから出たものは、そのまま素直に聞き入れぬ、何か一ぺん脇へ逸らすか、押し戻すかしてもとの形を少しでも變へてからでなくては、受け取ることを肯じないのであらう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は未来を、これからを、よりましな「何ものかであろう」ところの明日から目を逸らすことが出来ない。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゞまを守り遂げることの外には神の語の威力を逸らす方法がなかつた。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもは延若の扮した老乾児の為に泣かうとする情を逸らすのに容易でなかつた。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が古代人の家屋に対する信仰や習癖が、特殊な機会に、古くから外界に向いてゐた眼を逸らす事なく、譬喩化する事なく、人事以外の物を詠む事に価値を認める心を養うて居た。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気合いの悪いところへよけいなことばかりお訊ねして、もう何にも申しますまい」　こう言って、おしおは相手の気を逸らすように、ほかの事に話しを移した。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浪子さん」　千々岩は懲りずまにあちこち逸らす浪子の目を追いつつ「浪子さん、一言いって置くが、秘密、何事も秘密に、な、武男君にも、御両親にも。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アアアアア……」　僕達は、やうやくホッと息をして、表情の死んだ、板のやうな顔を見合はす、その顔を、二人は直ぐに逸らし合ふ、逸らす目の緩く流れた抛物線には、縹渺とした海の遠さが薄く一杯。",
              "citation": {
                "source": "海の霧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一尺のものを目当てに釣るに、三尺なるが懸る故に逸らすなり。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼是一時間かかって痿やしたものを、逸らすなんて、余り気の利かない話しだから、記念の為めに、今夜は帰るよ。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、中途で逸らすようでは、岡っ張で、だぼ沙魚を対手にしてる連中と、違い無いさ。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を逸らすように天井を見た。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの発明は、われわれの注意を真面目な事物から逸らす、うつくしい玩具であるのを常とする。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はなさけの深みにどうしても蹤いてゆかねばならないように出来ていて、それを逸らすことができないようになっているものでございます。",
              "citation": {
                "source": "津の国人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「心をもらって外のものをもらわないということはない、貞時、一生かかってもそなたを逸らすことは毛毫ござらぬ。",
              "citation": {
                "source": "津の国人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとか視線を逸らすと、尖塔に登る梯子に近い奥の方の片隅にどこか変わった埃の山があるのが目に留まった。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "――花も、半兵衛も」　さっきから秀吉も、顔をそむけて、熱い眼のやりばを、床の花に紛らせている容子なので、突きつめた話をそれへ逸らすべく、わざと半兵衛からそういったのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "元真斎はやるせなみ、　　　眼をそらす川のはて、塩の高菜をひた噛めば、　　妻子もこれにならふなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へ、お火鉢」婦はこんなことをそわそわ言ってのけて、忙しそうに揉手をしながらまた眼をそらす。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かえって夫人がさしうつむいた、顔を見るだに哀さに、傍へそらす目の遣場、件の手帳を読むともなく、はらはらと四五枚かえして、「星があっても暗かったろう。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　紫玉は、はじめて納得したらしく、瞳をそらす時、髷に手を遣って、釵に指を触れた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　五十年輩の瀬尾博士は、禿げかかった広い額をてかてかさせていたが、どうしたのか、銀子から目をそらすようにしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もきっかり決裂した感じで気持をそらすことが出来よう。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼がその妻をイギリスへつれかへつたら、人々は、彼女に向つて嘲笑の鼻をそらすでせう。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子は、そのまま立ち竦んでしまったように、夫人から視線をそらすことも、首を下げることも出来ずに茫然としていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と答えながら、目をわきへそらす。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　紫玉は、はじめて納得したらしく、瞳をそらす時、髷に手を遣つて、釵に指を触れた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生は源氏に真正面から見られるととてもきまりわるそうにして、横へそらすその目でじっと良人を見上げているうちに涙がそこから流れて出るのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
