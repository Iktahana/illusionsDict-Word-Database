[
  {
    "uuid": "e3c4a5a2-c1bb-5d1a-b2ac-734ddeb5a41a",
    "entry": "逸らす",
    "reading": {
      "primary": "そらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
