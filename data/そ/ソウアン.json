[
  {
    "uuid": "302a174a-a50a-5b5c-941f-7f08fd6a24a6",
    "entry": "僧庵",
    "reading": {
      "primary": "そうあん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "priest's hermitage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "印度人のやっている僧庵生活に就いて人から聴きました。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そは此處より程｜遠からぬ往生院と名くる古き僧庵に』。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "御身の茲に來られし途すがら、溪川のある邊より、山の方にわびしげなる一棟の僧庵を見給ひしならん。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹苑椒房の音に變り、破れ頽れたる僧庵に如何なる夜をや過し給へる、露深き枕邊に夕の夢を殘し置きて起出で給へる維盛卿。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "御部屋は竹縁をめぐらせた、僧庵とも云いたい拵えです。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧御所の中の編笠をかぶってお化粧した掃除女の群や、清水の茶店を守っている八十幾歳の老婆の昔語りや、円山公園の夜桜、それから大原女の話、また嵯峨野の奥の古刹から、進んでは僧庵や尼僧の生活まで。",
              "citation": {
                "source": "恩人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の娘に尼になられた母もやがて後を追い、ひっそりした尼僧庵の生活に入ったのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな山深く、人の訪れる事もない僧庵暮しである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて静かな僧庵暮しを続けていた女院は、病の床に就く身となった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "灌頂の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "といっても、どこかに落着かないわけにもいかず、北山の雲林院近くの僧庵の一つに漸く身をかくまった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがロシアにおいてことに隆盛を見たのは、あの有名なコゼリスクの僧庵、オプチーナ修道院であった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今着いて見ると吐月峯｜柴屋寺という僧庵だった。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼を憐れむ僧庵の某が、事前に、彼をかばって、喜兵衛の怒りをなだめたが肯かれなかったという説もある。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜兵衛の最期　一説に、武蔵は父の勘気を得て、播磨の一僧庵に身を寄せていたということである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手習の帰途、この高札に目をとめた悪童武蔵は、手習筆を以って墨くろぐろと塗りつぶし、宮本弁之助（武蔵の幼名）が挑戦する旨を大書して、僧庵に帰った。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、喜兵衛の使いが、僧庵を訪れて試合｜応諾を伝えたので、初めて事の次第を知った庵主は胆を消し、「小忰の悪戯ゆえ、なにとぞ深くお咎めなく容赦されたい」　と百方陳謝した。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日二人が会って、山の仕事の話をしているうちに、ふと首くくりを思いだして、ああ、そうそうあんたもあれを見たのか、と語りあって、又、それなり忘れてしまったという。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
