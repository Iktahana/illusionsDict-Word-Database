[
  {
    "uuid": "ac487c41-8fe6-5c7f-86b0-05af88f133f9",
    "entry": "尊称",
    "reading": {
      "primary": "そんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
