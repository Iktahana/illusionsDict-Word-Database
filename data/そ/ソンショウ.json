    },
    "definitions": [
      {
        "index": 1,
        "gloss": "honorific title",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "図書の管理者などはどこでも学生には煙たがられると見えて、いつか同席したクナイペの席上における学生の卓上演説で冗談交じりにひどくこき下ろされていたが、当人は Sehrgemeiner Kerl などという尊称を捧げられても平気で一緒に騒いでいる面白い人であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙といふ字は山の人と書かれてゐるから、何でもかまはぬ、山の奥に住んでゐる人を仙人と称してよろしいといふ、ひどく簡明の学説を聞いた事があるけれども、かりにその学説に従ふなら、この剣山の隠者たちも、その心いかに愚なりと雖も、仙の尊称を奏呈して然るべきものかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思っていたら、果して、その講話のおわりにアナウンサアが、その、あいつの名前を、閣下という尊称を附して報告いたしました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャワでは虎人を苦しめぬ内は祖父また老紳士と尊称してこれを崇める、多くの村に村虎一頭あり、村の某が死んで虎になったとその人の名を充てる、村人が獣を殺すと残肉を食い言わば村の掃除役だが、万一村の人畜を害うと一同これを撃ち殺す（ラッツェル『人類史』一）。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子、孔夫子、夫子と尊称される、子や夫子は先生を意味する。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『和名抄』に蛇和名倍美、蝮和名波美とあれば蛇類の最も古い総称がミで、宣長の説にツチは尊称だそうだから、ミヅチは蛇の主の義ちょうど支那で蟒を王蛇と呼ぶ（『爾雅』）と同例だろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "既く論じた通り、上古の野椎ミツチなど、蛇の尊称らしきより推せば、足名椎手名椎は蛇の手足なきを号としたので、この蛇神夫妻の女を悪蛇が奪いに来た。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那でも初至の天癸から紅鉛を製し、童男女の尿より秋石を煉り、また新産児の胞衣を混元毬など尊称して至宝となし、内寵多き輩高価に求め服して身命を亡うた例、『五雑俎』等に多く見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉蓉の二字を略して御肉と尊称した（『本草図譜』一、坂本浩然の『菌譜』二等に図あり）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は、「竜巻村のジヨーンズ」といふ尊称を享け入れて、陶然と眼をかすめた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かね／″＼村人が私達を称ぶのに、大先生などゝいふ尊称を用ふるのは、それは彼等が私達を目して稀代の剣道士と敬ふてゐたからである。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "官位に付随する尊敬、煩瑣なる階級の差等、「御」とか、「せさせ給ふ」とかいう尊称語を除いてみれば、後世の型に囚われた文章よりも、この方が、よほど、今日の口語に近い語脈を伝えていて、抑揚｜頓挫などという規則には拘泥しない、自然のままの面白味が多いようだ。",
              "citation": {
                "source": "『新訳源氏物語』初版の序",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼は、マメイドに向つて、彼が私を目して、三通りの尊称を使ふのは、「大馬鹿先生」――「自惚博士さん」――「貧棒の大先生」といふ意味なのだ――。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁慶も助六も清正も家康も河内山も説くには及ばない、この仲国ひと役でも団十郎に名人の尊称をあたえていいと、わたしは今でも思っている。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうです、貴方を私がモッケする嘲りの尊称です。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの相模屋という大きな質屋と酒屋との間の長屋は、僕の家の長屋で、あの時分に玄関を作れるのは名主にだけは許されていたから、名主一名お玄関様という奇抜な尊称を父親はちょうだいしてさかんにいばっていたんだろう。",
              "citation": {
                "source": "僕の昔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "厨川白村氏によって「女王」の尊称をたてまつられ、又この名にふさわしい権力を以て生きて居るこちらの婦人は、私の眼に意味深いものとうつりました。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間には、諺にもあるとおり、という尊称で普く知られている人種がある。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおかめさんとは、大旦那に対する、大内儀さんの意味で尊称なのであろうが、自分でいうとおおかみさんになり、出入りの相撲さん×山関がいうとおおかめさんとなる。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父橋が渡しで廓がよいに不便だろうと、遊女屋側からかけたので、遊人それを徳とし、その特志家を――実は商業上手を、おやじおやじと尊称した名が残ったのであると記録にもある。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "十人衆、五人衆、旦那衆と尊称され、髪の結いかたは本田髷細身の腰刀は渋づくりといったふうで、遊蕩を外交と心得違いをしていた半官半商であった。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "陛下と云ふのはアラビアではカリフ（王）だけにつける尊称ですから。",
              "citation": {
                "source": "三つの指環",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし平生はこの通り、初めて卵から這い出した生物のように、ビックリした表情を続けているから、とりあえずアンポンタン・ポカン博士という尊称を奉っている訳であるが……」　正木教授がここまで講義して来ると、学生連中が一度にこっちを見てゲラゲラ笑い出したものである。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸の御隠居様、水戸の老公と尊称して、天下一の人物のように話して居たから、私も左様思て居ました。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼義義家が前九後三の禍乱を鎮めしより以来、東国は其半独立の政治的天地となり、武門の棟梁は、其因襲的の尊称となれり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに雑誌なんかの上で大人が一二度小才のきいた文章が出してあるとすぐ「前途多望の天才」とかなんとか云う尊称がたてまつられる。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "匈奴の酋長の尊称だ。",
              "citation": {
                "source": "沙漠の美姫",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙「老大（初めての幇匪にはこんな尊称を用うる）は門檻に在りますかい」すると甲匪は立って不動の姿勢で答える。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
