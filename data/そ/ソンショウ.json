  {
    "uuid": "42377149-1f4d-5148-8212-4963414c2fd9",
    "entry": "村庄",
    "reading": {
      "primary": "そんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "village",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今は非常手段に訴えるより途はなかろう」この様な論議が各村庄屋の寄合の席で持ち出される。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "島原の南有馬村庄屋治右衛門の弟に角蔵なる者があり、北有馬村の百姓三吉と共に、熱烈な信者であった。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "添島九兵衛、野村庄兵衛が続いて駆け込んだ。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "高見権右衛門は三百石、千場作兵衛、野村庄兵衛は各五十石の加増を受けた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "――幕――　　　　　　　　　　第二幕第一幕より、十日ばかりを経たるある日の夜、弦打村庄屋茂兵衛の家の広間。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "又藩中に居て武芸をせねば人でないように風が悪いから、中村庄兵衛と云う居合の先生に就て少し稽古したから、その後、洋学修業に出ては、国に居るときのように荒い仕事をしないから、始終居合刀を所持して、大阪の藩の倉屋敷に居るとき、又緒方の塾でも、折節はドタバタ遣て居ました。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "北村庄作が天元社に立寄った機会を、佐竹は捉えた。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天元社に勤めるようになってから、北村庄作と識り合い、北村の二階に移転して来たのである。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうしたたか酔っている北村庄作は、立ち上って怪しげな小唄振りをやってのけた。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不忍池のまわりを逍遥しながら、北村庄作は、右のことを頭の中でこね返していた。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　松本家へ行って、北村庄作はちと勝手がちがった。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北村庄作の声の調子は、ずいぶん酔ってるようだった。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手がもし日本人だったら、例えば長谷部先生にせよ、天元社の佐竹にせよ、或は北村庄作にせよ、俺の気持ちはこんなに平らではないだろう。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　北村庄作はしずかに眼覚めた。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北村庄作もそれを感じた。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方ではやや様子が違って、下村庄助という者がこれを支配し、百九石余の高を給せられて、身分は侍であったが、宝永年間に庄助が死して後は、各部落はやはり部落の年寄の自治に任ずることになっていた。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国ですから、回向院の角力場に程近く、これで弱つたのは、ぼくの名が木村荘某とあるところへ橋向うの行司衆が多く木村庄某なので、場所時分には郵便のとりちがへが盛んだつたことです。",
              "citation": {
                "source": "私のこと",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は川向うの行司木村庄某あてのハガキや手紙が番地が不完全だとぼくの家へ舞込むと同時に、ぼくへの通信がまた一応両国橋を向うへ渡つて附箋をつけて戻されたことなどあつた。",
              "citation": {
                "source": "両国今昔",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "和歌山県西｜牟婁郡北｜富田村庄川に牛屋谷という滝がある。",
              "citation": {
                "source": "穀神としての牛に関する民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山川村庄はさらなり、凡物の名の訓かた清濁によりて越後の里言にたがひたるもあるべし。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは湘南｜鵠沼の海岸、中村庄右衛門という老子爵の別荘である。",
              "citation": {
                "source": "海浜荘の殺人",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江州甲賀の山奥｜木賊村庄屋｜家記によると、弦之丞は両刀をすて、農となってその地で終っている。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "鳴門の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
