[
  {
    "uuid": "7990f3d1-231a-58a0-aa2e-0796af08fc54",
    "entry": "それよりも",
    "reading": {
      "primary": "それよりも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
