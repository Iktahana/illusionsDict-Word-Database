        "examples": {
          "standard": [
            {
              "text": "彼は自分のミスによる損失を償うため、懸命に働いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社は顧客への損失を償うため、全力を尽くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の失敗で生じた損失を償うのは、容易なことではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしは、読書の効果はとうていこの損失を償うにたらないと考える者の一人である。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆったりとした腹中にその損失を償うて余りある或る成算がすでにできたかのような感を周囲の旗本にもいだかせた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
