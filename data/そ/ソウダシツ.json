        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新式水雷發射管の構造と、其猛烈なる作用とは略右の如くであるが、更に海底戰鬪艇の全部を見渡すと、艇は中央の軍機室より前後十｜敷個に區劃されて、海圖室もある、操舵室もある、探海電燈室もある。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "操舵室も海図室も同じように暗く、内部も外部も、闇夜のような船であった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い鳥は、しばらく操舵室の屋根の上にとまってあたりを見まわしていました。",
              "citation": {
                "source": "船の破片に残る話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥歯をぐっと噛み、影のように操舵室に忍び込んだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対入れるもんか……　操舵室の扉に手がかかった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ち着け、時間は充分ある、あわてるな」　グライドは操舵室に隠れてこっそり見ていた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か一人、操舵室へ上がれ、ずた袋と弔弾を一発か二発持っていけ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "船体の中央にブリッジがあり、そこに操舵室が乗っている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
