        "examples": {
          "standard": [
            {
              "text": "葬列が墓地へ向かう道すがら、参列者たちによって悲しげな葬送歌が静かに歌われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "教会の古いパイプオルガンが、故人の魂を天へ導くかのような葬送歌を奏でた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "映画の悲劇的なラストシーンで流れる葬送歌が、観客の涙を誘い深い余韻を残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あそこでござりまするな」　じっと目を光らせて見ながめていたかと見るまに、「アハハハ……もっともなお話でござります」　からからとうち笑うと、来るそうそうからすでにもう、すばらしい右門流でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、親愛なるその伝六が、来るそうそうから少しよろしくないことをいったのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の声を聞くそうそうからもうお花見気分で、八百八町の町々は待ちこがれたお花見にそれぞれの趣向を凝らしながら、もう十日もまえから、どこへいっても、そのうわさでもちきりでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、はじめからおっしゃりゃ、泣くがところはなかったのに、正月そうそうからつれなくなさるから、つい愚痴が出たんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケシは入学そうそうから、この集まりの輪に加わった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、来たそうそうから、碁の話ばかりです。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
