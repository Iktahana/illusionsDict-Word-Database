    "definitions": [
      {
        "index": 1,
        "gloss": "noise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "御院殿坂に鳴く蜩の声や邸後を通過する列車の騒音を聞くような心持がする。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平の夢はこれらのエンジンの騒音に攪乱されてしまったのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ミサコは二人を送りだすと、暈を感じたが、そのまま都会の火事の騒音のなかに巻きこまれてしまった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "工業的騒音を好まざれど精米所の音響と、投機的熱狂を繰りかえす。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はベグノニアの花園を踏んで商業的騒音に生きる、商権の雑音を愛した。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の病室でも、やかましく呻きわめく騒音が上りだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その騒音がどこからともなく、空気を泳いで伝わって来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の騒音をつんざいて、う――うッと唸る声がする。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "器械の動く騒音だけはつづいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の方では、大勢の荒々しい足音と、罵る叫び声と、破壊の騒音が渦を巻いていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳にもその騒音が伝わって来るように思えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それももちろん結局は生理的であるとも言われようが、しかし、あらゆるいろいろの類似の「コトリ」という騒音の中で、特別な一つの種類であるところのさかな屋の盤台の音を瞬時に識別する能力はやはり驚くべきものである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイデルベルヒの学生歌」（俗名、若きハイデルベルヒ）でも窓下の学生のセレネードは別として、露台のビア・ガルテンでおおぜいの大学生の合唱があって、おなじみのエルゴ・ヴィヴァームスの歌とザラマンダ・ライベンの騒音がラインの谷を越えて向こうの丘にこだまする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく注意してみると、窓の外の街上を走る電車の騒音の中に含まれているどんどんというような音を自分の耳が抽出し拾い上げて、それを眼前の視像の中に都合よく投げ込んでいたものらしい。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを売っている露店商は特製特大の赤ん坊の頭ぐらいのを空に向けてジャンボンジャンボンと盛んに不思議な騒音を空中に飛散させて顧客を呼んだものである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそこではびっこがなんの役にも立たないむしろ目ざわりなうるさい木靴の騒音発声器になっているだけである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくもわれわれ目明きの世界においては、一つの雑音あるいは騒音の聴覚によって喚起される心像は非常に多義的なものである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パリの屋根の下」で二人の友がけんかをしようとするときに、こわれたレコードのガーガーと鳴り出すその非音楽的な不快な騒音が異常に象徴的な効果をもって場面のやまを頂上へと押し上げる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前掲「灰汁桶」の句ではしずくの点滴の音がきりぎりすの声にオーバーラップし、「芭蕉野分して」の句では戸外に荒るる騒音の中から盥に落つる雨漏りの音をクローズアップに写し出したものである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れな姫君の寝姿がピアニシモで消えると同時に、グヮーッとスフォルザンドーで朗らかなパリの騒音を暗示する音楽が大波のようにわき上がり、スクリーンにはパリの町の全景が映出される。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その騒音をくぐりぬけて鐘の音が五つ冴え冴えと園の耳もとに伝わってきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ」　と小供達は声をあげて、今迄の騒音を、すっかり静めた。",
              "citation": {
                "source": "動かぬ女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての生命を冷眼視し、度外視して、鉄と火との激闘に熱中させる地獄の騒音……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の隣の家では、朝から夜中まで、ラジオをかけっぱなしで、甚だ、うるさく、私は、自分の小説の不出来を、そのせいだと思っていたのだが、それは間違いで、此の騒音の障害をこそ私の芸術の名誉ある踏切台としなければならなかったのである。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオの騒音は決して文学を毒するものでは無かったのである。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は飯茶碗の鳴る音や、子供たちが泣いたり笑ったりする賑かな騒音の中で物を考えて行くのが好きらしいのです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少々野卑ではあったが、耳を叩き破る程の騒音と強烈なウイスキーが市内に居残った人々を無暗と弾ませた。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "声をも立てられなかったのに、其処には劇しい騒音があった。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなホールの中へ、こおろぎが一匹、何にあこがれたのか、さまよい込んで、ピョンとはねた途端、クイックターンのダンスシューズの先に蹴られて、チリチリと哀れな鳴き声のまま、息絶えたが、その声はバンドの騒音に消されて、たれも気がつかなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンドの騒音が、ホールの入口に近づいた二人の耳に、いきなりかぶさって来たのである。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
