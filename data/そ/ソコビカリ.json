        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども東の空はもうやさしいききょうの花びらのようにあやしい底光りをはじめました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲はうす黒く、ただ西の山のうえだけ濁った水色の天の淵がのぞいて底光りしています。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども東の空はもう優しい桔梗の花びらのやうにあやしい底光りをはじめました。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷たい桔梗色の底光りする空間を一人の天［※10］が翔けているのを私は見ました。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷たい桔梗色の底光りする空間を一人の天が翔けているのを私は見ました。",
              "citation": {
                "source": "インドラの網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生意気な』と老人は底光りのする目を怒らして一喝した。",
              "citation": {
                "source": "初恋",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがほの暗いそうして底光りのする雰囲気の中から浮き出した宝玉のようなものであった。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光の綾を織り出した星々の地色は、底光りのする大空の紺青だった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かやはどこに居たのか」と、お爺さんが厚いべっこう縁の眼鏡の下から、底光りのする眼をじっとかやの方へ据えると、太く揃った真白な眉と眉の間に深い皺が二筋ほどありありと表われた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲はうす黒く、たゞ西の山のうへだけ濁つた水色の天の淵がのぞいて底光りしてゐます。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔には無精鬚が茫々と伸び、頬がゲッソリと痩せこけて、眼ばかり、奥深く底光りするようになった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、妙に底光りのする眼でまた車内を一わたり見廻したが、ふと我に返つたやうにパラソルを腰掛の奥に、鞄を右脇に置き換へて、草履を揃へながら敷物の上に坐り込んだ。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると鯱に似て、彼が城の天守に金銀を鎧った諸侯なるに対して、これは赤合羽を絡った下郎が、蒼黒い魚身を、血に底光りしつつ、ずしずしと揺られていた。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼやけて底光りのする月光が地上のものを抑え和めていた。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "睫毛の長い眼は青味勝ちに澄んで底光り、無口な女であった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも御殿女中は御殿女中で、薄ら蒼いにどこか黄味がかった処のある衣物で、美しゅう底光りがしたと申す。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "えいと杖の尖で捏ねる内に、何の花か、底光りがして艶を持った黄色いのが、右の突捲りで、薄なりに、ゆらゆら揺れたと思うと、……」「おお！",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "刃はおろか、稲妻とも何とも云ひやうもない霹靂で、底光りを湛えた物凄さであつた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　底光りのする雲母色の雨雲が縫い目なしにどんよりと重く空いっぱいにはだかって、本牧の沖合いまで東京湾の海は物すごいような草色に、小さく波の立ち騒ぐ九月二十五日の午後であった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物すごく底光りのするまっさおな遠洋の色は、いつのまにか乱れた波の物狂わしく立ち騒ぐ沿海の青灰色に変わって、その先に見える暗緑の樹林はどんよりとした雨空の下に荒涼として横たわっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手堅くしかも底光りのするあいつの技巧が、またぐんぐん俺をやっつけてしまった。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうときの名人は、いつもそうなんですが、ことばをかけるまえにまず、じいっとはいってきたそのお武家の姿を、底光りする鋭いまなこで、静かに見ながめました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっぺりと白すぎるほどに白いその顔を見迎えながら、名人はじっとまずあの底光りする視線をそそぎかけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "――当然のごとくに、名人右門の眼がぎろりと鋭い底光りを放つと、いまだにぼうぜんとたたずみながら、まるできつねにでもつままれたように、黙々と考え沈んでいる町奴たちのところへ、じつに伝法な、だが、むしろぶきみなくらいに物静かな尋問の矢が向けられました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも四十まえの年配で、秩父名物のさるまわしなんですが、それぞれ、一匹ずつのさるをひざにかかえながら、しきりといなりずしをつまんでいるのに、眼光が少しばかり烱々として底光りがありすぎるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鷲鼻の痩せた老体でギロリと底光りのする眼玉と、枯薄のやうに貧弱な頤鬚を貯へてゐたが、それを恰も豊かな関羽のと木剣があつたならば、どちらが主人であるか見境ひもつかぬであらうと見えた程、彼と私の挙動は酷似したものであつた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が手にしたときには、見すぼらしい平凡な土器に過ぎなかつたものが、今主君の掌面に載せられてゐるのを見ると、うつとりと珠玉のやうに底光りを放つてゐます……「天下一の瀬戸とはこれぢや。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか種類がございましょう」　どれも、これも、その光はそこびかりがして、何か人の血をすうようなけはいがするではありませんか。",
              "citation": {
                "source": "花模様女剣戟",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
