[
  {
    "uuid": "605bf8c5-b4a1-5701-b1cc-093b754a2691",
    "entry": "側近",
    "reading": {
      "primary": "そっきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "close aide (of a powerful person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "清逸は園が側近く来たのを知ると、なぜともなく心の中が暖まるのを覚えて、今までの物臭さに似ず、急いで窓から戸口の方に寝返った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく躊躇していたがファニーはやがて私の命ずるままに私の側近くすわった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、彼の側近く寄つて来て彼の顔を覗いて行く無遠慮ものさへあるではないか。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄ったウェーターが私を出張りの硝子囲いの側近くの卓に導いて呉れて、間もなく皿を運んで来た。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人も客も湯帷子に着更へて、縁側近く据わつて、主人と背の高い赭顔とが棋を打つのを、小男の客が見てゐる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "將軍家のお側近う召さるゝなどと、夢のやうな事をたのみにして、心ばかり高う打ちあがり、末はなんとならうやら、わたしは案じられてなりませぬ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつら　お戲れかは存じませぬが、そのお詞が冥加にあまりて、この願かならず叶ふやうと、百日のあひだ人にも知らさず、窟へ日參いたせしに、女夫の桂のしるしありて、ゆくへも知れぬ川水も、嬉しき逢瀬にながれ合ひ、今月今宵おん側近う、召出されたる身の冥加……。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "行親　おん謹みの身を以て、素性も得知れぬ賤しの女子どもを、おん側近う召されしは……。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした刻苦精励が翁の終生を通じて変らなかった事は側近者が皆実見したところであった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "側近の者皆｜宝祚長久の嘉瑞なりと奉答したが、只万里小路藤房は、政道正しからざるに依り、房星の精、化して竜馬となり人心を動揺せしめるのだと云って、時弊を痛論した。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると氏政は側近の者に、あれで直ぐ麦飯を作って持って来いと命じた。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいに掃除の届いた庭に臨んだ縁側近く、低い机を出してくれる。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすこし往ったところで、女郎は侍女を車の側近く呼んで言った。",
              "citation": {
                "source": "瞳人語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長政罪人を誅するに諸士に命じて見逢に切り殺させらる、長政側近く呼んでその事を命じ命を承けて退出する、その形気を次の間にある諸士察して仕置をいい付けられたと知った、しかるに政利に命じた時ばかり人その形気を察する能わず、この人天性勇猛で物に動ぜなんだからだと貝原好古が記し居る。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "長十郎はまだ弱輩で何一つきわだった功績もなかったが、忠利は始終目をかけて側近く使っていた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやくから忠利の側近く仕えて、千百石余の身分になっている。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて側近する人は男女の別なしに困ったことであると歎いた。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれも何の気もつかなかったが、翌朝その餠の箱が寝室から下げられた時に、側近している女房たちにだけはうなずかれることがあった。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は、瑠璃子の右側近く腰を降した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、側近くに仕えている家来の一人が、慌てて紀州侯の前へ出て来た。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき、殿様からのいいつけで、お側近く仕えている小役人の一人が記内を訪ねて来て、鶏の鍔を注文した。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さような嫌いのある品を御側近うお置きになりますのはいかがかと存ぜられます。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一事だけでもがよくよく事件の重大事であるのを物語っているうえに、密事の漏れるのをはばかってか、側近の者をすらも従えず、ただご一人でお待ちうけしたので、名人の声はいよいよ震えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家のお側近う召さるるなどと、夢のようなことをたのみにして、心ばかり高う打ちあがり、末はなんとなろうやら、わたしは案じられてなりませぬ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつら　お戯れかは存じませぬが、そのお詞が冥加にあまりて、この願かならずかなうようと、百日のあいだ人にも知らさず、窟へ日参いたせしに、女夫の桂のしるしありて、ゆくえも知れぬ川水も、嬉しき逢瀬にながれ合い、今月今宵おん側近う、召し出されたる身の冥加……。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "行親　おん謹みの身をもって、素性も得知れぬ賤しの女子どもを、おん側近う召されしは……。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "起居注は天子の側近の日記。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝自らもいかにも気持がよささうだつたが、側近くに居並んで聴いてゐた侍臣達も、ほとほと感に堪へてゐる様子だつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の會見は、縁側近く四つ五つ實を持つた橙の樹のある、竹山の室で遂げられた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
