        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「それでは　今日から　そうじゅん　と　名前を　かえろ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "米がない「そうじゅん、さっそくだが　でしいりと　きまったら、めしを　たいて　もらおう。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの日、おしょうさまは、一休さんを　へやに　つれていって、「そうじゅん、これを　よめ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうじゅんは　いくつに　なったな。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが、「そうじゅんさん、おしょうさまの　あとを　ついで、さいごんじの　じゅうしょくに　なって　ください。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは　そうじゅんと　いったな。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうじゅんが　いのちがでけで　でしに　してくれと　たのんで　いることを　しって　いました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで　そうじゅん　と　いっていた　一休さんは　それから　名を　一休　と　あらため、それを　いっしょう　かえなかったと　いわれます。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
