        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ソウルノン街三十三番地。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに早くても、『ラバー・ソウル』の一曲目を聴けるのは、四月二十八日午後一時五〇分だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビートルズの新作『ラバー・ソウル』、そして、ラディックのドラム・スティックをもちながら、慶一は、さらにシングルの棚で三〇分ほど逡巡した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そうした憂鬱も、『ラバー・ソウル』の素晴らしさをすこしも損ないはしなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいね」「おれのほうは、『ラバー・ソウル』を買った」「どうだった」「うん、面白い。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈ハート・フル・オヴ・ソウル〉といってほしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえ、なに聴くんだよ」「ビートルズ」「『ラバー・ソウル』？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へい、ただいま」　慶一が『ラバー・ソウル』をのせ、回転を三三にセットし、スタート・ボタンを押しながら、「お母さん、それから、うすらデカイ、おっかない不良少年もいるのです」とつづけると、「もォー」と、全員が不満の声をあげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれ、コンパクトもってるから、こんどもってくる」　柾生のいうとおり、『ラバー・ソウル』はジョンのアルバムだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョンがあの声で、慶一の魂の奥深くに呼びかけるのは、この『ラバー・ソウル』が最後になる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中近東みたい」　慶一は、ヤードバーズの〈ハート・フル・オヴ・ソウル〉といい、これといい、ビートルズといい、このところ中近東ばかりだ、と考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「べつに、かけたっていいけどさ……うん、四月にかけるよ、〈ソウル・アンド・インスピレイション〉」「〈ラヴィン・フィーリング〉にしろよ」「じゃ、あいだをとって、〈ジャスト・ワンス・イン・マイ・ライフ〉」「ま、いいや」　突然、ヴェランダのドアを叩く音がして、服部が素早くポータブルの針をあげる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『ラバー・ソウル』か……」「おまえ、最近、これを聴いたことあるか？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビートルズは『ラバー・ソウル』まではそろっています。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソウル駐在の憲兵は、大鳥圭介大使が帰国するのを警護するように命じられたため、戦線に出られないことを口惜しく思って自死した。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ボクソウルはぶらりと這入って来て、今氷山に衝突しましたと静かに言いました。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだね、何かに衝突したらしいことは僕も知っていたよと、私が笑いますと、ボクソウルは続けてＦ甲板まで水が来て、郵便室は大洪水だ。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞くと私は、毛布を※ね退けて飛び起きていました」　このボクソウルも、こんな風に妙に、糞度胸のある人間だけに見事に助かっている。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライトラアの眼は、約五哩の距離――これは実際よりも遙かに短い観察だったが――と測定して、それからボクソウルと緒に、このキャリフォルニアン号を対象に、死に物狂いの発火信号を続けたのだった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクソウルは、タイタニック号でこそ四等運転士だったが、主席舵手として最長年の海上生活の経験を有する実際家上りの腕っこきだった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクソウルは一応スミス船長に報告して、直ちに狼煙の打揚げ方に掛ったのだが、キャリフォルニアンからは何の応答もないが、気の故か段だん近づいて来るようにも思える。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だか灯りを振ってるようだぜ」　傍で双眼鏡を手にしているライトラアがそう言うので、ボクソウルもモウルス燈を持出して求援の意味の閃火を送った。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一つ朝鮮の食い物で記憶に残っているのは、京城（ソウル）から新山へ行く途中に大きなせりがつくってある。",
              "citation": {
                "source": "美味放談",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　デイノソウルスの卵　これもある夜の応接間での話の中の一つである。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のタイムスを見ると、例のゴビの砂漠でデイノソウルスの卵を見付けたアンドリウスが、また中央｜亜細亜へ二年とかの計画で、何百頭とかの駱駝と途方もない人数の人とを引連れて出かけたようだ。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、辞して帰る時、玄関まで送ってこられて、私が靴の紐を結んでいるのを立って見ておられながら、「デイノソウルスの卵が見付かったって人間がどうなるというのじゃないが、……それだから益々面白いんだなあ」と独言のようにいっておられた。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十二時過ぎまで、ディノソウルスの卵の話や、パブロワの踊りの話をきく。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただわれわれは彼のあの物静かで慇懃な態度とともに、次のような人物を見るだけである――公務に非常に忠実だった末に、ついに、幸運にも人臣の位を極めた人、大きな仕事を果たして、イングランド最高の伯爵ソウルスベリとなった人を見るのみである。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側の腎臓、”生命の門”、には特に精液（力の座）を作る役割があり、肝臓は心（ソウル）の座であり、肺は体温を調節する。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "五歳でギターを自由にこなし、教会、ラジオでソウルフルなゴスペルからフランク・シナトラまで、全身でうけとめた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
