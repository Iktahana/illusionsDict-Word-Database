[
  {
    "uuid": "ff5dfd9d-ff84-53fd-8f96-63c2c9c017b3",
    "entry": "走路",
    "reading": {
      "primary": "そうろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "race track",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はその私財をもって方々に劇場や音楽堂を建てたり、競技場や競走路をつくったり水道や温浴場をこさえたり、ギリシャ各地の滅びた都市を復旧再興させたり、実にさまざまの驚くべき大規模な公益事業をしているが、もってその富のいかに巨大であったかが察せられる。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがドレゴの運が強かったわけか、旅客機は滑走路のはずれまで行っても離陸しないでぐるっと方向転換をし、元の出発点に引返してきた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きさは、ドイツの大飛行船ヒットラー号よりも何十メートルか大きいというから、東京駅がそのまま載って、まだ両端へ百メートルずつ出るという長い滑走路を造るのだそうだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから飛行甲板を走りきるまでには、甲板の長さの幾層倍かの長い滑走路を走ったと同じことになる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行甲板から重爆がとびだすのに、滑走路が短すぎるから、甲板は戦車の無限軌道式になっていて、そいつは飛行機のとびだす方向と逆に動くとかいいましたね」「そのとおりです」「いやそれがインチキだというのです。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全戦隊に呼びかけたものらしいが、はて何ごとが起ったのかしら」　と、いぶかる折しも、下の飛行甲板から叩きつけるような爆音が起り、一台の飛行機がぶーんと滑走路を走りだした。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも三機の偵察機が、白線の滑走路にそい、戦闘機の前をすりぬけるようにして、爆音勇ましく暗の夜空に飛びだした。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "善かさもないものはただちに悪と、固定された、ただふたすじのみちが、もし、特定のものの便宜のために日本の人民の理性の上に敷設されるなら、それは、人を生き埋めにした上につくられた滑走路のようなものになるだろう。",
              "citation": {
                "source": "地球はまわる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒縦走路は少しも危険なところがなく案外だった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦走路は割に急な登り下りとなっています。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして再び飛びあがるため、氷の上に滑走路を作ることに取りかゝりました。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機で飛びあがるために必要な、長さ五百メートル幅十二メートルの平らな滑走路を作るのです。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして作つては壊れ、壊れてはまた作つてゐるうちに、たうとう七回目に、五百メートルの滑走路が出来上りました。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機は五百メートルの滑走路をぎりぎりまで滑り、氷塊の丘を巧みにさけて、首尾よく空中に浮きあがりました。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "うわさによると、敵はＢ29を発出させるために、サイパン島の外まで埋め立て、滑走路を長くして、実施しているそうである。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると敵の奴よろこびやがって、それからのこりの戦車へ来るわ来るわ……」などという朗らかな話や、近く敵襲の警報が入ると、滑走路に小屋を運搬していって建て、村落と化して敵の目をごま化す話など、たいへん面白かった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大仕掛な動く滑走路であった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "細長い鉄片を組立ててこしらえた幅五メートルの滑走路で、動力によってこれはベルト式｜運搬機のように横にすべって動いていく。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく、動く滑走路は停った。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ床だけは、迷彩をほどこした鋼材の動く滑走路がまん中をつらぬいているので、異様な気分をあおりたてる。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん鉄の枠の上に鉄板が張ってあり、その上に滑走路用の舗装材料が平らにのせてある。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐるりと裏へまわり一側むこうに出たら例の練馬の大滑走路が坦々としてある。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "助走路は五対一にドロンコとなり、五人は水タマリの中でふみきるが、私はそうでないところでふみきるから、楽々と勝った。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボイラーも何もはいっていない正味一万二千トンの重さを、約八〇平方フィートの二台の承船架が、がっちりとのっけて、さらにその承船架を支えて河中まで、たっぷり油を引いた幅八十フィート長さ二百フィートの滑走路が、十四フィートに一フィートの傾斜でのびていた。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "走り幅飛の助走路よりも長そうだわ」「なるほど。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "積雪地の飛行場では、滑走路及び誘導路の除雪が、一番の問題であるが、それも実際に役に立たせるためには、迅速にやる必要がある。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍下は冗談事ではなく、北満地方の飛行場に大規模な滑走路を作る時などは真剣な問題になるであろう。",
              "citation": {
                "source": "凍上の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大規模なことはとても望めないが、せめて飛行場の滑走路の上だけでも、あの霧をはらそうというのである。",
              "citation": {
                "source": "硝子を破る者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五昼夜橇でゆられてはたまらないので、皆飛行機に乗りたがるが、向うには飛行場がないので、雪を固めた滑走路に、スキーで着陸する。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を持たない秋が深うなつた霜夜の寝床が見つからない　そうろうとして歩きつづけていた私は、私相応の諦観は持っていたけれど、時としてこういう嘆息を洩らさずにはいられなかった。",
              "citation": {
                "source": "寝床〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
