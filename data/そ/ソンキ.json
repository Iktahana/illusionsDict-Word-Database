[
  {
    "uuid": "c92237b2-7349-5787-8a72-7f759b26cfe1",
    "entry": "尊貴",
    "reading": {
      "primary": "そんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
