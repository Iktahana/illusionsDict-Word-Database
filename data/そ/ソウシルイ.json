        "examples": {
          "standard": [
            {
              "text": "ハエやカは、身近な双翅類昆虫の代表だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "双翅類の多くは、幼虫の時に水中で過ごす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "衛生上問題となる双翅類もいるため、対策が重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "双翅類をば猟り集めまだ明けやらぬ晨のけはひを花々の密の槽へと飛ばすのか？",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ人を刺す双翅類の悪虫が四、五種はある。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山蝶や双翅類が、その甘く香ぐわしい蜜に酔って、花にも劣らぬ麗わしい翅をひるがえす。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
