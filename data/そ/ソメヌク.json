        "examples": {
          "standard": [
            {
              "text": "深みのある黒を出すため、職人は布地を徹底的に染め抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼らは、背景を白く残し、旗に複雑な紋章を染め抜く技法を用いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スカーフ全体を鮮やかな深紅に染め抜きたい。一滴残らず染めたいんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
