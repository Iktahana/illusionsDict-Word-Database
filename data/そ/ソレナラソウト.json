    "definitions": [
      {
        "index": 1,
        "gloss": "even so (expressing frustration, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それならそうと早くいってくれればよいのだ。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜそれならそうと明らかにいってはくれないのだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、あっさりおっしゃって下さりましたらよろしかったのに、何もかも、もう分りましてござります。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと早く顔を見せりゃいいのに、頭をかかえて震えてばかりいなすったんで、すっかりあぶら汗をかかされましたよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうとぬかして逃げりゃ、腰の骨まで痛くしやしねえのに、いまいましいね」「今ごろごまめの歯ぎしりやったっておそいや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと早くいやいいじゃねえかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと早くいやいいんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと早くいやいいのに、道理でね、さっきの使いめ、いま一本お差し紙をわしづかみにしていましたよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、出がけからいやいいのに、草香流が湯気をたてているのなんのと荒っぽいことをおっしゃったんで、あっしゃてっきりおどし文句の本尊の根城にでも乗り込むんだろうと肝を冷やしていたんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、変に気を持たせねえで、はじめからおっしゃりゃいいんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと早くいやいいじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、最初からはっきりいやいいじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、はじめからおっしゃりゃ、泣くがところはなかったのに、正月そうそうからつれなくなさるから、つい愚痴が出たんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと早く云えばいいに、「文化」だとか何とか今道心見たような名を付けるからわけがわからなくなる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "成、成、それで……それならそうと早く一言云えばいいのに……なンだろう大方かく申す拙者｜奴に……ウ……ウと云ッたような訳なンだろう？",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんな馬鹿なことがあるもんか、それならそうと何故さっきそう言わないんだ、といろいろに抗弁して見たが、要するに何とも仕方がない。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、注意しておいてくれればいいのに……。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうとはっきり断言するがいい、男らしくもない。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それならそうと、初めから仰言ればいいのに。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、初めから云ってくれれば……何も大したことではないし……。",
              "citation": {
                "source": "人間繁栄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと、なぜ早く僕に云わないんだ。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうと云って、家へ来て下さればいいのに。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうといっそハッキリ言ってくれればいいのに。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "村子　そりゃ、なんだけどさ……（白いくびを見せて、ウィスキイをのむ）……けど、それならそうと前にいってくれりゃ、そのつもりでなにして来るのに。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙には、どうせ修造のことだから、人のいいなりにはなるまいが、それならそうといってくれたら、こちらで式ぐらいはあげられたのに、早まったことをした。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "〉　それならそうとはっきり言えばいい、と五郎は思った。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ようすをうかがっていたのなら、また来るに相違ないと思ったんです、それで弁天谷の口のところを注意していたんです」「それならそうと云えばいいじゃないか、なぜ黙っていたんだ」「云ったって同じですよ」　万三郎は少しばかりさっきの仕返しをするように答えた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それならそうと早くきけ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
