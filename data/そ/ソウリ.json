[
  {
    "uuid": "ab851d43-e242-5b59-9704-2cc6a8fd05b5",
    "entry": "総理",
    "reading": {
      "primary": "そうり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
