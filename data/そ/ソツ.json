[
  {
    "uuid": "b0485fad-0626-5962-a7e3-159b4b7f4515",
    "entry": "そつ",
    "reading": {
      "primary": "そつ",
      "alternatives": [
        "ソツ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slip-up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一つには非常に寡作のせゐもあるのだが、『そつとしておいてくれ』といふ気持の強い男だといふことがその主な理由だと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論かういふことは、一々の短歌作品、一々の俳句作品に就いてそつくりそのまま当箝まることではないけれども、夫々の様式を規範的に観た場合そのやうに言ふことは先づ間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて使ひ終つてその妻楊子を彼の前にある灰皿の中に放つた時、フツと彼は彼の死んだ父親を思ひだした、その放る時の手付や気分やが、我ながら父親そつくりだつたやうな気がした。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場のガードをくぐつて坂を登ると、暗い煤ぼけた古道具や、安物の足袋など店に竝べた、昔の宿場そつくりの町がある。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲がもうだいぶ高くなつて、路にそつてる箇所はズツとホコリで殆んど黒くなつてるのが、熱い上に熱くした。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がその詩を読んで驚いたことには、それが川路柳虹君の詩そつくりの模倣であつた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花、梅吉、喜三郎ことし十五の小性とて娘お蝶がませぶりをさげすみしたる樣もなく家代代の重寶をそつと小縁に運ぶ哉。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はその地図を蘭人に示して「もそつと、前に進んでこれを説明して呉れぬか」と言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さし向つて話すときでもお互ひにそつぽをむいて話した。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな輕い微笑をＫ君は絶えず人々に、そつと投げかけてゐた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と旦那は怒り、ぎよろりと妻子を睨んですつくと立ち上り、奧の薄暗い部屋に退却して、そつと鏡を覗き、がつかりして、「これは、駄目だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その草庵の垣根越しに、そつと覗いてみた者は、なあんだ、とがつかりさせられる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは、青竹の狹い縁を滑らぬやうに、用心しながらそつと渡る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鈴さんは、そつと席をはづした。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま私は、戰災のため田舍暮しを餘儀なくされてゐるが、ちやうどいまの日本の津輕地方の生活が、そつくりチエホフ劇だと言つてよいやうな氣さへした。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人に接するのにも、わきの方からそつと寄つて行つて、じろりと横目で見て、「ああ、あれは變態だ！",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ特に私が宇都野さんに望む所は、時々はもう少し不用意な、読みっ放しの云わばもっとそつのある歌をよんで見せて頂きたいと思う事である。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たいが、小づくりで、薄皮膚の色の白いやはらかに素直な毛をそつとわけて声もほそぼそと、歴史といふ遠い昔の夢をロマンチツクにおどおどと語る――ただ、すこしほんのすこしではあるけれども、見栄坊に気どつて年頃の女生徒への多少の対感意識はあつたやうでした。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子夫妻のそつの無い歓待振りはまことに十二分の親孝行に違いなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな太郎の為に…………太郎の美くしいお嫁さんに着物を買ふため麻のハンカチ古い革手袋、昔はやつたお高祖づきんの布つ片へ、そつと貯めて置かうとするお金なんです。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、これをそつとしておくですな。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕はそつと眼を盜んで、君の机の側にある書状を見た。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、そろそろ歩きはじめた、みんなそつとしてくれ、そつとしてくれ、おれは心配で心配でたまらない、たとへどんなことがあつても、おれの歪んだ足つきだけは見ないでおくれ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは指と指とにはさんだ卵をそつと日光にすかしてみた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今丁度内証で、そつとパンの欠を湿つた指で撮んで口へ持つて行つてゐるオスワルドに目を移して、「我々の懐かしい祖父」と云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "女主人は、アウグステをばさんがこんな日に世間話をするのを、不都合だと思つて、少佐夫人にそつとその心持を話した。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリツツはそつと保護するやうに、臂を娘の背に廻して抱いて云つた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうやつて、そのうちの一人が語りだすと、誰もかもがそれをそつくりその儘に感じた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
