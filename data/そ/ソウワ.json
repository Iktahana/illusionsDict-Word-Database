  {
    "uuid": "9bf70cdc-7d86-5a8d-a273-753aa0b8df83",
    "entry": "送話",
    "reading": {
      "primary": "そうわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
