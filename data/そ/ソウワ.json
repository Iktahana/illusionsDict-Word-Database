[
  {
    "uuid": "23d28bab-5b1e-5a65-85f7-fb3e9dc5cef0",
    "entry": "挿話",
    "reading": {
      "primary": "そうわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
