        "examples": {
          "standard": [
            {
              "text": "台湾の山地には相思樹の森が広がり、春になると黄色い小さな花々が山肌を優しく彩る風景が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "相思樹の木材は非常に硬く、かつては農具の柄や上質な木炭の原料として地元の人々に重宝されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭に植えた相思樹が南国の風を受けてさわさわと音を立てるのを、彼はベランダの椅子に座って眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "○相思樹の老樹　なかなか風情のあるものだな、相思樹ってものは。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という鳥だか知らないが、相思樹のかげで「｜私はお前が好きだ」と、そんな風に啼いているのもあった。",
              "citation": {
                "source": "蝗の大旅行",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
