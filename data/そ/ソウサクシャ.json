  {
    "uuid": "5d420bcf-19be-5c8e-8dce-e991b6c1fb99",
    "entry": "創作者",
    "reading": {
      "primary": "そうさくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
