        "examples": {
          "standard": [
            {
              "text": "お正月には、鏡餅の代わりに大きな備え餅を飾る家もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神棚に備え餅を供えて、家族の健康と豊作を祈願した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの風習で、年末に備え餅を作る家庭が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "○おかしいおそなえ餅が組合から来ました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそなえ餅だって、栄介の家のものにくらべると、四倍ぐらいの容積があった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
