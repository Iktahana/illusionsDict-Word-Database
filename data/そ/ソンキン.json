        "examples": {
          "standard": [
            {
              "text": "会社の決算では、損金として計上できる経費がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年の事業は赤字で、多額の損金を出してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "税務上、どこまでが損金として認められるかが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "其喜は「京師書肆河南儀平損金刊余詩、戯贈」の詩にも見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "青服の紳士などという、ありもしない人物を登場させたのは、そうでもしなければ、損金の補填に窮し、夫人を殺したのだろうという嫌疑がかかるかと、ひたすらそれを恐れたためであった。",
              "citation": {
                "source": "悪の花束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
