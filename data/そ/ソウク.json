[
  {
    "uuid": "553d3c4f-94fe-5546-b6d3-d6c1986ba321",
    "entry": "走狗",
    "reading": {
      "primary": "そうく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
