    "definitions": [
      {
        "index": 1,
        "gloss": "hound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "革命的左党は右党派軍隊に絶滅され、国民党は共産分子を除外して孫文の国民党はブルジョワ階級の走狗となった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社直属の特務機関であり、最も忠実な利潤の走狗である監督は、表面現場の親玉である係長の次について働いてはいるが、しかしその点、技師上りの係長にも劣らぬ陰然たる勢力を持っているのであった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次席警部は武藤君に対して、「警察は如何にも君等の言う通り、資本家の走狗だ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実は日本の政府が、一貫して財閥の走狗であり、財閥の利益を擁護することによって自分の利益をも擁護している人間の集りであるという事実を、告白しているものだと思う。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来ならそうした抗戦運動の指導者になる筈の知識人たちが、日本の場合は隠遁的ポオズだったり反って軍閥の走狗となった例が圧倒的に多い。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の汎アメリカニズムと×××××××の矛盾は益々増大しつつあると、中国国民党の走狗どもは云っているが、これは間違いである。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のやうに学校を卒業したものは、卒業したときにはもう完全な資本家の走狗の標本になり切つてしまつてゐるのだから。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アインシュタインを、長岡半太郎を、ブレリオを、パストゥウルを、誰かブウルジュアジイの走狗と呼ぶものぞ。",
              "citation": {
                "source": "新劇界の分野",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "直義の家臣、逆臣の走狗、淵部伊賀守義博であった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……差し添えを抜いた逆賊の走狗の、その差し添えで御胸元を二太刀！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史的必然を無視して、徒らに資本主義の走狗を養成する大学になんの権威が認められるでせう。",
              "citation": {
                "source": "計算は計算",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人達は皆御史の家の走狗であった。",
              "citation": {
                "source": "田七郎",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "（早口に）市川・朝比奈などの走狗、書院番士にいた例の吉村の軍之進なあ、小策士め、彼奴などが中心になって策謀の結果、いよいよ武田先生｜下野、尚、吉村は江戸薩摩屋敷などにも出入している。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパ大戦に於てはヨーロッパの交戦国の女性は、男性の手不足のために生産労働にかり出されたが、併し狡兎死して走狗烹らるの譬えの通り、資本の必要から見て不用になった彼女達は、忽ち家庭へたたき戻された。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "（早口に）市川・朝比奈などの走狗、書院番士に居た例の吉村の軍之進なあ、小策士め、彼奴などが中心になって策謀の結果、いよいよ武田先生｜下野、なお、吉村は江戸薩摩屋敷などにも出入している。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭田たちの報告によると、吾妻村附近はこの派の走狗が出没して村長の亀田佐平以下がすでに示談説に傾いているという。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "一隊は舟で渡良瀬川を下って人数の糾合に出かけ、また一隊は日頃古河の走狗を働いて欺瞞をこととしてきた者たちを、再び村々へ足ぶみさせぬように難詰し糾問すべく押しかけた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "政界も、大小官吏も、学者も、教育家も、このために毒せられて却って古河の走狗となり、馬足となり果てていた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "その四　走狗　根室から札幌に出て、札幌から函館に行き、青函連絡船で青森へ渡り、それから上野まで――こうながい汽車の旅では、いくら急行でも、おやじの死に目に会うことができなかった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて他の将校が、「東洋の平和のためだ」「支那ではそれをどう見てるんでしょうね」「支那では……」　慷堂がひきとって、「支那で金儲けをしたい資本家の言いなりになって、日本の政府も軍部も、資本家の走狗となっているからだと見ている」「けしからん！",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と異口同音に言う将校たちに、慷堂は、「国内改革がどうしても日本は必要なのだ」「資本家の走狗として死ぬんでは、死にきれない」　低いが強い声で北槻中尉が、「兵隊を資本家の走狗として死なせることは、断じてできない」「――走狗」と慷堂は中国語で言って、「その通りだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "誘わない中から撃退です」「ハッハヽヽ」「僕はこんなに邪魔にされる積りで奔走したんじゃありません」「狡兎死して走狗煮られ……」「はあ？",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙しいんだ」「狡兎死して走狗煮らる」「何だい？",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつも改進党の走狗になったか」。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなれば、木曾の木曾義昌、きゃつも昔は武田家の忠族であったが、いまでは徳川家の走狗となっている、かならず若君に弓をひくやつであろう。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると妻はいつそうくつろいだ樣子をして、くるしい？",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ですと伺ったら「そりゃそうくさい、おどんが、汝いよか詩の出来るごつ、いつでん金光様にお願いしとるけんくさい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓はひとつしかなく汚れていたため、部屋中がぼんやりと薄暗く、埃にまみれているせいか、何もかもがいっそうくすんでいるように思われた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そっちがそうくるなら、こっちにも考えがあるもんね」と、そんな気分がわいてきたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし吉本氏がそうくるなら、こっちにも考えがある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
