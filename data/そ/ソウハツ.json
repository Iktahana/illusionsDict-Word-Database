    },
    "definitions": [
      {
        "index": 1,
        "gloss": "two-motored",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "機体のあらゆる部分を純白に塗った、双発のヴァイカウントが、建物からそれほど遠くないところに停まっていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　双発のアイランダーは、昼間に見ると美しく可愛い。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "双発のＤＣ―３が、その明るい陽ざしのなかに登場した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "18　ディランがコンサートまわりをやっていたころは、ロード・マネジャーと共に、双発の一三人乗りの飛行機で近距離をとび、長距離は民間航空のジェットだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大なる双発偵察機が一機、二機、三機、古代の怪獣のごとく唖黙って、銀色の翼を拡げていた。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい霜が来ますと、根が浮いてしまって、たんぽぽのような草でも、そうはつぼみを持てません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、昨夜、この宿に案内するまでは勿論、今朝、まだ早くから駐在へ顔を出して百万べんも頭をさげ、お蔭さまで命びろいをしましたと繰り返すその男に向つて、いや、君の命を救つたのは、この自分ではない、そうはつきり言うべきであつたと、彼は、あとから、後悔の念がむらむらと起つた。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことははつきりさせておくといゝ」「警察で、そうはつきり言うんですか。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十めんそうはつかまるでしょうか。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、二十めんそうはつかまるでしょうか。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こばやしさん、二十めんそうはつかまったよ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
