          "literary": [
            {
              "text": "われわれは遊びに対して速成科を望まない。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "速成科といふものは働いて急いで金を儲けようとする思想の人間が起した後の教育法だ。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "年も押しつまった暮の二十八、九日頃、瀬川は簿記の速成科を終えたといって帰って来た。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "速成科を四ヵ月やって、あと九月一日から又その上の課程をやります（研究科か裁断科か）そしたらこの年いっぱいでいくらかまとまりましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
