    "definitions": [
      {
        "index": 1,
        "gloss": "sidetrack",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軌条と挟接鉄板と目釘とはすべて用意した、それらは皆その引込線の側線から取って来たものである。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは言へ、私の提出した問題の最も根本的な部分は、依然として未解決のまゝに残されてゐるし、問題自体が、前記諸氏の大部分の人々によつて、私の当初の目的とは全く別な方向へ展開せられ、いはゞ側線へ導かれて、一見簡単に片附けられてしまつたやうな観を呈した。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「車止めのある避難側線です。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、『｜鷹の城』がトリエステを去った日の朝、貴女が、『ニーベルンゲン譚詩』に側線を引いて、Leaf（葉）と Crosslet（十字形）という二つの文字を示されたでしょう。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "区の警察から係官が出張し、一等車を側線へ入れ、夕方までかかって検証した。",
              "citation": {
                "source": "悪の花束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人たちは、ヘンデル先生の教えてくれた薬草を、さっそくせんじて、病人にのませました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
