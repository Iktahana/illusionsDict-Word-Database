        "examples": {
          "standard": [
            {
              "text": "自然災害による農業の損失額は甚大だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最終的な損失額は、まだ確定していない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "保険会社は、事故による損失額を査定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "損失額は一般資本のより不利な分配によって埋合されているから、それが内国から奪い去るすべてのものを外国に与えない故にそれは最悪の課税である。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスについては、損失額は上に述べたとおりである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョージ卿は自分の馬に大金を賭けているけど、損失額は小さいだろう。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
