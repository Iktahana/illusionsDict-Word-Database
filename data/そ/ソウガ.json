    "definitions": [
      {
        "index": 1,
        "gloss": "(book) illustration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "The Yellow Book の故智にならい、ビアズレイに匹敵する天才画家を見つけ、これにどんどん挿画をかかせる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不折、黙語、外面諸画伯の挿画や裏絵がまたそれぞれに顕著な個性のある新鮮な活気のあるものであった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のようなジャーナリズム全盛時代ではおそらく大多数のこうした種類の挿画や裏絵は執筆画家の日常の職業意識の下に制作されたものであろうと思うが、あの頃の『ホトトギス』の上記の画家のものはいかにも自分で楽しみながら描いたものだろうという気のするものばかりである。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人雑誌の巻頭挿画らしい色刷の絵が一枚貼ってある。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は子供の時から絵が好きで、美しい絵を見れば欲しい、美しい物を見れば画いてみたい、新聞雑誌の挿画でも何でも彩色してみたい。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "動力工場の成り立ち、機関車、新聞紙、書籍、色刷挿画はどうして作られるか、発電所、ガラス工場、ガス製造所にはどんなものがあるか。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々の美しいタチングな場面が丁度そのお伽噺の挿画のように順々にめくられて行く、そうした美しい挿画が数え切れないほど沢山あるのである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い旅路と季節の推移を示す短いシーンの系列など、まさに挿画を順々にめくって行く気持である。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コローの絵を想い出させるようなフランスの田舎の幻像がスクリーンの上を流れて行く、老人と子供が雪夜の石段を下りて来る図や、密航船の荷倉で人参をかじる図なども純粋に挿画的である。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またなんという画家の手に成ったものか、角のないその字体と感じのまるで似た、子供といえば円顔の優等生のような顔をしているといったふうの、挿画のこと。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　巡査の靴音が橋の上に留んで、背後向のその黒い影が、探偵小説の挿画のように、保険会社の鉄造りの門の下に、寂しく描出された時、歎息とともに葛木はそう云った。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つれは、毛利｜一樹、という画工さんで、多分、挿画家協会会員の中に、芳名が列っていようと思う。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、当日、小作の挿画のために、場所の実写を誂えるのに同行して、麻布我善坊から、狸穴辺――化けるのかと、すぐまたおなかまから苦情が出そうである。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は逸作の所蔵品で明治初期の風俗を描いた色刷りの浮世絵や単色の挿画を見て知っていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが挿画画家さんにお気の毒ですね。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後のスタンドプレイ　ダヴィンチの評伝を走り読みしていたら、はたと一枚の挿画に行き当った。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぞと取留めもなく思い乱れて、凝とその大吉を瞻めていると、次第次第に挿画の殿上人に髯が生えて、たちまち尻尾のように足を投げ出したと思うと、横倒れに、小町の膝へ凭れかかって、でれでれと溶けた顔が、河野英吉に、寸分違わぬ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は、ベッドから降りて、自分の砂糖水を、そのおじいさんに全部飲ませてやる、というだけのものであったが、私はその挿画さえ、いまでもぼんやり覚えている。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突俯して、（ただ仰向けに倒れないばかり）であった――　で、背くぐみに両膝を抱いて、動悸を圧え、潰された蜘蛛のごとくビルジングの壁際に踞んだ処は、やすものの、探偵小説の挿画に似て、われながら、浅ましく、情ない。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女用文章の中の挿画が真物だか、真物が絵なんだか分らないくらいだった。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しっかりして、お聞き、恐くはないから、私が居るから、」と謙造は、自分もちょいと本堂の今は煙のように見える、白き戸帳を見かえりながら、「私がそれを見て、ああ、肖たようなとぞっとした時、そっと顔を上げて、莞爾したのが、お向うのその※さんだ、百人一首の挿画にそッくり。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "挿画　挿画の十七葉は葛飾にゐた時描いた片端から版に廻はして印刷して了つたものである。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "挿画はわたくし自身で葛飾時代から描きためて置いた十七葉を以てした。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の中の四枚の挿画は一年前に画いて置いたものである。",
              "citation": {
                "source": "雲母集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の集の挿画にある庚申薔薇の中門には真萩や山吹がしだれかかり、その中門から門庭へ出入りができ、そこにはまた木槲の植込があり、応接室の窓には八つ手や松ヶ枝が透かして見えた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反古は俳文の紀行で、文字と挿画とが相半している。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "上木し得るまでに浄写した美麗な巻で、一勇斎国芳の門人国友の挿画数十枚が入っている。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て何かの挿画で見た路易王朝式というのであったろう……緋色の羅紗に黄金色の房を並べた窓飾や卓子被、白塗に金銀宝石を鏤めた豪華な椅子や卓子がモリモリ並んでいる。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おじいさんは霧の中に立っていて、「ああそうが。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごちそうが、つくの？",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
