        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――「益友に三種、損友に三種ある。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "形式家、盲従者、口上手、これが損友である。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
