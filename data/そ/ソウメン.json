[
  {
    "uuid": "66ba9bb3-78a7-5c10-a51e-9a6c7da88709",
    "entry": "素麺",
    "reading": {
      "primary": "そうめん",
      "alternatives": [
        "ソーメン"
      ],
      "is_heteronym": false
    },
    "grammar": {
