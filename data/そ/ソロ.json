[
  {
    "uuid": "ff70d0f5-5e77-59cf-84ad-3429404eeaf9",
    "entry": "ソロ",
    "reading": {
      "primary": "ソロ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "solo",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ソロモン王の底知れぬ憂愁をうかがひ知り得る唯ひとりの人である。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ソロモン僕はもうバッハにもモツアルトにも倦果てた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウ・レ・トアド・パリの唄から“C'est pour mon papa”の唄へ――巴里の感情は最近これらのはやり唄の推移によってスイートソロから陽気な揶揄の諧調へ弾み上ったことが証拠立てられた。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロモンの栄華も一輪の百合の花に及ばないという古い言葉が、今の自分には以前とは少しばかりちがった意味に聞き取られるのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにまた近来ニューヨークのソロモンという人が同じ考えを起して大仕掛けに資本をかけてこの法を用いる事になったそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から晩まで、ソロバンばかりはじいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ――も、Ｏ鉱山、Ｓ鉱山、Ｊ鉱山では、昔通りのべラ棒なソロバンが取れなくなってしまった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友達というのは手相を見る男で、それも西洋流の手相を見る男で、僕の手相を見たとき、君の手にはソロモンの十字架がある。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ死ぬ程息苦しくなって、張り裂けるほど胸が轟いて、唖のように何の返事もし得ないまま立ち上りますと、ソロソロとアヤ子から離れて行きました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずその右の前足の一本だけを伸ばしてソロソロと動かしかけているようである。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに連れて煤けたお面を冠った、奇妙な着物を着た人間が、ノロマが蜘蛛の巣を取るような恰好でソロリソロリとホツキ歩くのだから、トテモ退屈で見ていられない。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの森の奥の方角で、何とも知れぬ気合いの声がタッタ一声「エイッ」と聞こえただけで、アトは又森閑としてしもうたけに、不思議な事と思うてソロソロ起上って、あの墓所まで来てみると、思いもかけぬ無残い姿の仏様じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにも何かの慈善音楽会というようなものもあって、そんなおりには私にとっては全く耳新しかったいろいろのソロなどを聞く事もできた。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南洋のソロモン群島中のある島に存する竹製の縦笛にププホルと称するのがある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "めいめいがソロをきかせるつもりでは成り立たないのである。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロモンと榮華を競へりとか、白百合の花も恥づべき哉。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はソロモンの栄華と野の花のよそおいを対比して考察したりなんかしない。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロモンの栄華は人間文化の一段階として、それはそれでよいではないか。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "吸殼は火鉢の隅に目立つやうに堆になツて、口が苦くなる、頭もソロ／＼倦くなツて來て、輕く振ツて見ると、后頭が鉛でも詰めてあるやうに重い。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーッと音もなく開いたので私は新しいゴム靴を脱いで買い立ての靴下の塵を払って、微塵も音を立てずに思い出の多い裏二階の梯子を登り切って、板の間に片手を支えながら襖をソロソロと開いた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わからん……そうかそうか……そんならその女に金を貰うたのはどこいらか教えてくれんか……エエ……コラ……どこで貰うたんか……今、お前が左手に握っている……その金を……」　昂作は白いホコリにまみれた左手の拳をソロソロと開いて見た。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは眼の前に重なり合った草の茎の隙間から見るテニスコートの白い一直線の上を、ソロソロと後しざりして来る薄茶色のセイラアパンツであった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がソロソロあるかせるから」「ウン、それはいい思い付きだ」　と豚吉もよろこびました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
