        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうすりゃ、今日、行かなくてもすむじゃないか。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれを今、学校をやめさして、働きに出しても、そんなに銭はとれず、そうすりゃ、あれの代になっても、また一生頭が上がらずに、貧乏たれで暮さにゃならんせに、今、ちいと物入れて学校へでもやっといてやったら、また何ぞになろうと思うていない。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうすりゃえいわ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃちっとあ念ばらしにもなって、いくらか彼奴らが合点しよう。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飛つくお千世を葛木に縋らせて、ひとり褄を挙げて、悠然と前へ立って、「大丈夫、そうすりゃ、途中で、誰かに逢っても安心でしょう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫、そうすりゃ貴下の上へ、屏風に倒れて背になって、私が突かれる、斬られて上げるわ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうすりゃ死んでも可い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児二　そうすりゃこのお菓子なんか、家へ帰ると、榧や勝栗だ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃまた引上げて下さるだろう。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうすりゃきっと名僧知識になれたんだ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、この倍くらい暗くったって、平気なんだがなあ」　このとき、どぶ板の下に住んでいる大きなドブネズミが、姿をあらわしました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、おまえさんのしっぽはちぢんでしまって、足ってものになるよ。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、やつらの腕や指は、みんな粉々に飛んじまうから」　でも、そんなことをするまでもありませんでした。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、とけちまうさ」　けれども、おばあさんは、男の子の髪の毛をなでながら、ほかのお話をして聞かせました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だってそうすりゃ、とってもおもしろいもの。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、とってもりっぱに見えて、ひとからもうやまわれるんですよ！",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、あの男の子たちの言ったことが、すくなくとも一つは、ほんとうになるじゃないの。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、死んでからリンゴとスモモをつめて、ミイラにしてもらえるのよ」　こう言うと、ポルトガル奥さんは、日なたに寝ころんで、かたほうの目をパチパチやりました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下らないことをお言いで無い、そうすりゃあ汝はどうするというんだエ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ遊蕩も留みます。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、まるで天狗が寄合いをつけるようです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ大概、河野家は支離滅裂、貴下のいわゆる家族主義の滅亡さ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三「ねえ、今に内の人が帰ったら、菜のものを分けてお貰い、そうすりゃ叱られはしないからね。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ世間の人はみんな聴いてくれただよ。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃもう死ぬより他はないじゃないかね。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ世間も恐しくはなかろうに、何だって、あんなにびくびくするのかなあ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃもう私ゃ死んだって怨はないよ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「児が出来て、ぴいぴい泣かれちゃ困るが、君は、お媽さんをもらうといいと思うね、そうすりゃあ気もちがかわって、いいよ、今晩だって、沙利の上なんかに寝てて、体をこわすよ」思いだして、「夢を見てたのか、ひどくあわててたじゃないか」　広巳の唇に微笑いが浮んだ。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃなにも心の悩み、紙にかくにもあたらない。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「牡家鴨でさえなけりゃいいんだがねえ、そうすりゃ家鴨の卵が手に入るというもんだ。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
