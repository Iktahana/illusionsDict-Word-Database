[
  {
    "uuid": "2caf4aac-b8cc-5af5-8545-c18fb32f4ceb",
    "entry": "尊厳",
    "reading": {
      "primary": "そんげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
