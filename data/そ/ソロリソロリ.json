    "definitions": [
      {
        "index": 1,
        "gloss": "slowly and quietly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「庭へ出たらどこか逃げ路が見付かるかも知れない」　お蝶は一生の勇気をふるい起して、息を殺しながらそろりそろりと滑っこい畳の上を忍んであるいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　竜巻がそろりそろりと立ちあがりました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上下左右、うしろにまで気をつけながら、そろりそろりと進んでいきます。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてからだをかがめて、そろりそろりと、そっちに近よって行きました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "進んで行った鹿は、首をあらんかぎり延ばし、四本の脚を引きしめ引きしめそろりそろりと手拭に近づいて行きましたが、俄かにひどく飛びあがって、一目散に遁げ戻ってきました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこでまた一疋が、そろりそろりと進んで行きました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "進んで行った一疋は、たびたびもうこわくて、たまらないというように、四本の脚を集めてせなかを円くしたりそっとまたのばしたりして、そろりそろりと進みました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「行ってみろ」　三番目の鹿がまたそろりそろりと進みました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども鹿はやっとまた気を落ちつけたらしく、またそろりそろりと進んで、とうとう手拭まで鼻さきを延ばした。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　五番目の鹿がまたそろりそろりと進んで行きました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いまや楢ノ木大学士はそろりそろりと後退りして来た方へ遁げて戻る。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとテねずみはぶるるっとふるえて、目を閉じて、小さく小さくちぢまりましたが、だんだんそろりそろりと延びて、そおっと目をあいて、それから大声で叫びました。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてからだをかゞめて、そろりそろりと、そつちに近よつて行きました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "進んで行つた鹿は、首をあらんかぎり延ばし、四本の脚を引きしめ引きしめそろりそろりと手拭に近づいて行きましたが、俄かにひどく飛びあがつて、一｜目散に遁げ戻つてきました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そこでまた一｜疋が、そろりそろりと進んで行きました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "進んで行つた一｜疋は、たびたびもうこわくて、たまらないといふやうに、四｜本の脚を集めてせなかを円くしたりそつとまたのばしたりして、そろりそろりと進みました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「行つてみろ」三｜番目の鹿がまたそろりそろりと進みました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども鹿はやつとまた気を落ちつけたらしく、またそろりそろりと進んで、たうたう手拭まで鼻さきを延ばした。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　五｜番目の鹿がまたそろりそろりと進んで行きました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭にはピジヤマを着たノリ子さんがお姉さんに手をひかれて、そろりそろり歩いてゐました。",
              "citation": {
                "source": "チユーリツプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "上下左右、うしろにまで気をつけながら、そろりそろりとすゝんでいきます。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "上下左右、うしろにまで気をつけながら、そろりそろりとすすんでゆきます。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをしおに、徳一君がげんしゅくな表情になって、そろりそろりと岸の方へ動きだした。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳一君がしたように、そろりそろり岸の方へ歩みよって、草にすがって上にあがった。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を出ると、急にむずかしき顔して衣紋をつくろい、そり身になってそろりそろりと歩いて、物持の大旦那がしもじもの景気、世のうつりかわりなど見て廻っているみたいな余裕ありげな様子である。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて目※む間も無く朝早く目が覚めると、平生の通り朝食の仕度にと掛ったが、その間々にそろりそろりと雁坂越の準備をはじめて、重たいほどに腫れた我が顔の心地｜悪しさをも苦にぜず、団飯から脚ごしらえの仕度まですっかりして後、叔母にも朝食をさせ、自分も十分に喫し、それから隙を見て飄然と出てしまった。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "息を殺し、背をかがめてそろりそろりと横切って、生け垣にさっと隠れる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにくと新月なんだから、もうとっぷりと暮れきった真のやみで、職掌がらとはいい条少し気味のわるい道筋なんですが、そこを通らねば四谷へは出られなかったものでしたから、右門は先へたってそろりそろりと坂を上ってまいりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」　聞き流しながら、知恵も才覚もつき果てたようにややしばしぐったりとなったままでいましたが、しかし、そのうちに名人の手がそろりそろりと、あごのあのまばらのひげのところへ持っていかれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
