        "examples": {
          "standard": [
            {
              "text": "二つの異なる文化の間には、意外な相似点が多く見つかりました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼らの提案には、私たちのアイデアとの間に明確な相似点がありました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この小説と映画の間には、プロットやキャラクター設定に多くの相似点があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "帝展派の画家の行き詰まりと、最も進歩的でなければならない筈のプロレタリア・リアリズム画家の行き詰まりの状態に相似点のあることは、この種の客観主義者が多いからである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "両者の間に相似点がある。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜とか柘榴とか梨とか松とか樟とか樅とかいうものと比較したら、やはり草花としての相似点を持っているといわねばならぬ。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この題材とタンホイザーの問題とのあいだには確かに相似点がある。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
