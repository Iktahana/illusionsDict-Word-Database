          "standard": [
            {
              "text": "ロケットの総質量は、燃料を含めて計算される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このシステムの総質量は、各部品の質量を合計したものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "惑星の総質量は、その引力の大きさに影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何となれば、この破片の総質量の大部分（約七五パーセント）を占める木星の比重はほとんど太陽のと同じで、その大きさにおいてその次に来る土星のは少し小さいのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
