    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the side",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今も玄関の側部屋で仕事にかかって居たのだ。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドクトルはやはり寒い側部屋で酒に餓えさせ乍ら獣の黄色い牙を磨かせて置く方が興味価値があったのだのに。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも三、四十年たっている株でも外側部はほとんど腐植土になってしまっていても芯はちゃんとしていた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分ほど早めに着いたのに、ミス・プラットは、いつも彼女らの坐る側部屋の長椅子で、もう伸子を待っていた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体は７日のあいだ水の中に寝かせておき、ふやけた外側部分は樹皮によって擦りおとし、内部を調べる。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
