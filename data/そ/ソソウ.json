[
  {
    "uuid": "fdcd4130-224b-572d-8cab-4e94785ed38f",
    "entry": "鼠巣",
    "reading": {
      "primary": "そそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rat's nest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれど今日となつてみると、鼠巣を燒くために家まで燒いてしまつた觀がないでもない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方の騒賊を掃っても、社稷の鼠巣を掃わなかったら、四海の平安を長く保つことはできぬ。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊びに来て下さるも可し、夜伽とおっしゃるも難有し、ついでに狐狸の類なら、退治しようも至極ごもっともだけれども、刀、小刀、出刃庖丁、刃物と言わず、槍、鉄砲、――およそそういうものは断りました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの方が仙妃であらせられる、そそうのないように」　青年はそれを聞くとそのままそこへべったりと這いつくばってしまった。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お客さんがいらしたから、俺は旦那様に申しあげてくる、それまでお前は、お客さんのお相手をするがいい、いいか、そそうのないように気をつけろよ」　痩せた男は女房と擦れ違うようにして外へ出て往った。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし四、五百両ぐらいで、そっと八橋の身請けができるものならば、いっそそうした方が無事かも知れないと考えた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、醤油つぎを引っくりかえしたのはまさに母のそそうである。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のそそうの責任を私に塗りつけるのはひどい。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そそうのないように、はよう持参さっしゃい」　うやうやしくさし出したのを受け取って、目あての太田五斗兵衛の人別を巨細に調べたが、しかしいない！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かそそうを致しましたかい」「これをみろ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥へ通るぞ」「あの、ちょっと、どなたさまでござります、薬のご用ならこちらで承りまするが、何品でござりましょう」「これ、勇吉、何をそそういたしまする！",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの世の生活の幸不運に関係なく、死後はおおよそそうなっているかと思われる。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は凡そそうして宵からもう四五里も歩き続けて来たであろうか。",
              "citation": {
                "source": "時間",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰か死にかけているなら、いっそそうなった方がましだと思うがね」　万右衛門は、私の意地悪な言葉を払いのけるかのように、両手で突然、慌ただしく三度も身振りをした。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はしずかに言葉をつづけ、「もちろんそそうでこわしたのはわかっています。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそそうであって呉れればいい――心の何処かで、そんな気もするのである。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "飼うには素人にも骨が折れず、生き虫と時々の新しき水を怠らねば誰れにもそそうはなく、鳴きも然るべき鳥屋が売ったのなら請合いである。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの気の毒な婦人こそそうです。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中が悲しくなったればこそそうした寺へ来て隠れていたのだろうからね。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、今こそそういう余事はさておいて、ひたすら我等の主人公の前身を語ることにしよう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出られてはたまらない――彼の方が一目散に飛出すと、おばあさんが後から、「もしもし貴下、おわすれものですよ、なんておそそうな――」　そう言って着せてやったのは、毛皮のついた外套だった。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "時とすると、とんでもない場所にそそうをする。",
              "citation": {
                "source": "父と子供たち",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭なら厭と事がきまればほかに捜すよ」「いっそそうなすった方がいいでしょう」「だがその辺が判然しないからね」「だから判然させるの。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしの方こそそうなの。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸太郎　うん、いっそそうした方がいろんな面倒が却って少ないかも知れないな。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳沢こそそうじゃないか、私は柳沢を友達と思っているから、お前のことばかりじゃない。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには――というのは、姉さん、あなたの前ですが僕は、僕以前の航海者たちをかなり信じておればこそそう言うのですが――そこには雪も霜も見られません。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子をかぶっていないので、ななかまどの樹のあいだから射していたお日さまの光が長い髪に光って、悲しそうな灰いろの眼がびんぼう人らしく心ぼそそうだった。",
              "citation": {
                "source": "漁師",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十度圏の彷徨中に起ったことは、あとで思いかえすと、みな緩慢な動作の物憂い幻だったとしか思えない」　八十度圏は、おおよそそういったところなんだろう。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、あたし、いっそそうしようかと思うのよ」「おい、お美夜ちゃん！",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
