        "examples": {
          "standard": [
            {
              "text": "奥歯のあたりに添い歯が生えてきて、舌に当たって痛い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乳歯が抜けないうちに永久歯が生えてきて、添い歯の状態になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "添い歯が気になって、歯科医に相談しに行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "残忍な生れつきの祖父と、財産あらそいばかりしている小父たち。",
              "citation": {
                "source": "マクシム・ゴーリキイについて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなたなどでは夜おそいばかり。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいばかいか彼女が死んだと聞いたから、弔儀に田崎をやって、生花をなあ、やったと思いなさい。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
