[
  {
    "uuid": "5928783d-8b4a-51d7-9afc-dac3dcc4ca88",
    "entry": "創造力",
    "reading": {
      "primary": "そうぞうりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
