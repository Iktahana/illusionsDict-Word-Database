        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「やあい、モクモク」「モクネンジンやあい」「モク兵衛やあい」　だがかれは少しもひるまなかった、かれの鉄砲のごとき速球はまたたく間にふたりを三振せしめた、つぎは柳光一である。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "光一はボックスに立ってきっと投手を見やった、かれは速球に対して確信がある。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛速球スモークボールで昨年プロ入りするや三十勝ちかく稼いだ新人王で、スモーク・ピッチャー（煙り投手）とうたわれている。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "癖のついていない、きれいなフォームで、のびのある速球を彼女は常にまっすぐに投げた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
