[
  {
    "uuid": "750d52fc-ae19-5b34-843b-33a1cf377f73",
    "entry": "疎通",
    "reading": {
      "primary": "そつう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
