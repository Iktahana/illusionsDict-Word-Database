[
  {
    "uuid": "eacd4d00-f90d-570f-b30f-9ea012cad23c",
    "entry": "尊卑",
    "reading": {
      "primary": "そんぴ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "high and low",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然るに南方の文帝、元嘉の年中、京洛の婦女子、皆悉く愁眉、泣粧、墮馬髻、折要歩、齲齒笑をなし、貴賤、尊卑、互に其の及ばざるを恥とせり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供に交って遊んだ初から大人になって社交上尊卑種々の集会に出て行くようになった後まで、どんなに感興の湧き立った時も、僕はその渦巻に身を投じて、心から楽んだことがない。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家トハ父妻子女及ヒ直系ノ尊卑族ヲ一括シテ云フ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪信法印の筆跡としては花園天皇の宸影殘れり、それに天皇の宸筆にて奧書せられし所と、豪信の系圖として傳はる所との間には、信實の子孫としての代數の相違を見出すも、尊卑分脈によりて其疑問は決せられ得べし。",
              "citation": {
                "source": "日本の肖像畫と鎌倉時代",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾後病牀｜寧日少く自ら筆を取らざる事数月いまだ前約を果さざるに、この事世に誤り伝へられ鉄幹子規｜不可並称の説を以て尊卑軽重に因ると為すに至る。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは自己の敬愛している抽斎と、その尊卑二属とに、香華を手向けて置いて感応寺を出た。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "逍遙子とても、固有、折衷、人間の三目を立てゝ流派とせしは、あながち尊卑を其間に置かざりしにはあらざるべし。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此に竹里の直接尊卑属を挙ぐれば、「伝五郎惟宣、千蔵公遷、常太綱」であつて、諸書の載する所と何の異なる所も無い。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ人間社会における強弱優劣の関係より来る、西洋に奴隷制の存せしはなお東洋に乞丐制の存せしごときのみ、その彝倫の道にありては上下尊卑を主とせずして、つねに左右平等を主とす。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして社交には智愚貧富の差を免れず、政事には君臣上下の別自ら必要たらざるを得ず、ここにおいて貴族の制を生じ僧族の制を生じ、族制なるものはついに無限の権力をもって公衆に臨む、その社交原則たる左右平等は日に衰縮して上下尊卑の事弊はまた抑うべからず、世運ここに至りていわゆる自由主義なるもの起これり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "西人かつて左抵右抗のもって社会平和を保つに足らざるを知り、貧富強弱の差よりもって貴賤尊卑の別自然に起こるべきを知り、ホッブスのごとき専制論者出でたり、また個々平等の事実に存するなくついに下等人類の牛馬と同じきものの実際に存するを知り、アリストートのごとき奴隷論者さえ出でたり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間を見ると、容貌と性情は尊卑の階級によって自然に備わるものらしい。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "江ノ島のこなたの片瀬は、菩薩の夫人の病を養ふ處、生死尊卑の別はあれど、これやこの、碓氷峠ならぬ高尾山、大正の日本武尊と、裸男馬鹿ながらも、人に背いて、涙ほろ／＼留めもあへず。",
              "citation": {
                "source": "夜の高尾山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "親が子供の不行届を咎めて遣れば、子供も亦親の失策を笑うと云うような次第で、古風な目を以て見ると一寸と尊卑の礼儀がないように見えましょう。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女、性を異にするも其間に高低尊卑の差なし。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に上士の常に心を関するところは、尊卑階級のことに在り。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府の官途に奉職すればとて、その尊卑は毫も効なきものと知るべし。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合には、その犯罪者の家族又は親屬間に於ける、尊卑長幼の位置如何によつて、同一の犯罪も、寧ろ同一の刑罰を受けぬことが多い。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "加害者と被害者との、尊卑長幼の關係如何によつて、刑罰が非常に違ふ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "若破骨者徒一年――事件が、家族や親屬の間に起つたと假定し、この場合に加害者と被害者との、尊卑長幼の關係如何によつて、同一の事件に對する罰の相違を圖示すると、左の如くである。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "重きは斬衰の親から、輕きは※麻の親に至るまで、苟くも喪服を着くべき關係に在る者は、法律上必ず特別の規定を設けて、一言一行と雖ども、その尊卑長幼の關係如何に應じて、犯罪に對する刑罰を、普通一般の他人の場合と同一に取扱はぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪服の制の外に、尊卑の關係や、正服と義服の關係や、出來得るならば事理の曲直をも、併せて考慮すべしといふのである。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "今かりに一歩を譲り、倫理教科書中、私徳のことに説き及ぼさざるに非ず、「一家の間は専ら親愛をもってなる云々、一夫一妻にしてその間に尊卑の幣を免かるるは云々」等の語さえあれば、私徳の要ももとより重んずるところなりと説を作すも、本書をもって学校の教科書となすにおいては、なお不可なるものあり。",
              "citation": {
                "source": "読倫理教科書",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人が此所に之を記し置く所以の者は夫の局量狭隘の徒、自尊卑他なる文学的「パリサイ」人が紛々｜喧々たらんことを恐れて、予め彼等が口を塞がんが為のみ。",
              "citation": {
                "source": "明治文学史",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、「献身」は必ずしも尊卑の関係から生れるものではなく、私を滅した愛の悲壮なすがたでもあり得るからです。",
              "citation": {
                "source": "日本文化の特質",
                "author": "――力としての文化　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊卑を弁へて、礼儀正しいわりには、自由思想がありましてね。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "二八　道を行ふには尊卑貴賤の差別無し。",
              "citation": {
                "source": "遺訓",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう貴賤も尊卑もない。",
              "citation": {
                "source": "暗黒星",
                "author": "シモン・ニューコム",
                "note": "青空文庫"
              }
            },
            {
              "text": "新平民と云い、特殊部落と云うも、その内容から尊卑の意味が定まるのであります。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは尊卑を主とする道徳であり、したがって貴族主義的である。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
