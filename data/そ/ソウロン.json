[
  {
    "uuid": "a28a7414-52ee-5480-8bea-2fafbde97a48",
    "entry": "争論",
    "reading": {
      "primary": "そうろん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
