[
  {
    "uuid": "a933a32d-7315-5980-a580-7acffe8af0a7",
    "entry": "束髪",
    "reading": {
      "primary": "そくはつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
