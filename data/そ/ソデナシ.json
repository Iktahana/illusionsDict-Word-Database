    "definitions": [
      {
        "index": 1,
        "gloss": "sleeveless (garment)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この祖母の「思い出の画像」の数々のうちで、いちばん自分に親しみとなつかしみを感じさせるのは、昔のわが家のすすけた茶の間で、糸車を回している袖なし羽織を着た老媼の姿である。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿媽が小舷から蟹ぢやあありませんが、釜を出して、斜かひに米を磨いでるわきを、あの位な娘が、袖なしの肌襦袢から、むつちりとした乳をのぞかせて、……それでも女氣でござんせうな、紅入模樣のめりんすを長めに腰へ卷いたなりで、その泥船、埃船を棹で突ツ張つてゐますから。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄で、袖なしなどを色気なく着て、こそこそ背中をまるめ、所帯じみて見えた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄で、袖なしなどを色気なく着て、こそこそ背中をまるめ、びっくりしたような眼をしていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（布子の袖なし、よごれくさりし印半纏とともに脱ぎ、痩せたる皺膚を露出す。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　娘は、紅麻の肌襦袢の袖なしで、ほんの手拭で包んだ容子に、雪のような胸をふっくりさして、浴衣の肌を脱いで、袖を緋の扱帯に挟んでいました。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう冬が来るぞい」　花子のおばあさんはそう言って、真綿のはいった袖なしを膝のうえにかさねて、背中をまるくしました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ご用心」　振り返って見ると一人の男、浅黄のずきんにうこんの袖なし、伊賀袴をはき一本差し、人形箱を胸へ掛けた、古風の傀儡師がうつ向き加減に、足のつま先を見詰めながら、すべるように右手を通って行く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何枚も重ねて着た上に、何かけものの皮を鞣して裏打ちにした袖なしを着てゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寒、袖なしを出して着た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "気持がよくないほどあたゝかい、師走といふのにぬくすぎる、袖なしを脱ぎ足袋を脱ぐ、火燵もいらない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "深山の妹たちにそやされながら、子供は縮緬の袖なしなどを着て、広い庭を心持よさそうに跳ね廻っていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　洗いざらしだが、さっぱりした半股引に袖なしの××君は、色のいい茄子の漬物をドッサリ盛った小鉢へ向って筵の上へ胡坐を掻き、凝っときいている。",
              "citation": {
                "source": "飛行機の下の村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い毛糸で編んだ袖なしを着てゐる。",
              "citation": {
                "source": "夜福",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御信者の方は、どなたも、御神服をおつけ下さい」　信者は膝に持つてゐた紫の袖なしのやうなものをてんでに拡げて、肩へ羽織つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅黄の石持で柿色の袖なしに裁布をはいて、腰に七輪のアミを提げて、それを叩いたり三味線を引いたりして、種々な音色を聞かせたが、これは芝居や所作事にまで取り入れられたほど名高いものである。",
              "citation": {
                "source": "梵雲庵漫録",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "能などでは袖なしの前のあいてる側継、あれがちはやである。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "入れ替つて帰つて来たのは熊の膏薬の伝次郎、やち草で編んだ笠を冠り狸の毛皮の袖なしを被て、糧切は藤づるで鞘が出来てゐる。",
              "citation": {
                "source": "鰍沢雪の夜噺（小室山の御封、玉子酒、熊の膏薬）",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれ共十四五から上のにもなれば、まさか、手拭で作った胴ぎりの袖なしだの、黒い単衣を着てなんか居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真白い袖なしの絹のブラウス。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼前に働いていた男の子は稲村に預けて置いた袖なし半天を着た。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖なしのワンピースの方がいゝわね。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人　　袖なしのワンピースの方がよからう。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖なしのワンピースはあたしには似合はないのよ。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーシチクは薄いラシャの袖なし胴着に、だぶだぶのズボンをはいている。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖なし外套を着込んだペンギン鳥。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎはぎだらけの縦縞の長半纏の上から、夏だというのに袖なしを羽織って、キチンとならべた両の膝がしらを、しきりに裾を合わせて包みこみながら、「ヘイ、なにがなんだか、おっしゃることがいっこうにわかりませんで、ヘイ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀糸を束ねた白髪、飛瀑を見るごとき白髯、茶紋付に紺無地｜甲斐絹の袖なしを重ねて、色｜光沢のいい長い顔をまっすぐに、両手を膝にきちんとすわっているところ、これで赤いちゃんちゃんこでも羽織れば、老いて愚に返った喜の字の祝いのようで、まるで置き物かなんぞのように至極穏当な好々爺としか見えない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さてかくのごとく主人に尻を向けた細君はどう云う了見か、今日の天気に乗じて、尺に余る緑の黒髪を、麩海苔と生卵でゴシゴシ洗濯せられた者と見えて癖のない奴を、見よがしに肩から背へ振りかけて、無言のまま小供の袖なしを熱心に縫っている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は喧嘩を後日に譲って、倉皇針箱と袖なしを抱えて茶の間へ逃げ込む。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
