    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Strategic Arms Limitation Talks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして一二年経ったときには、ソルト・レイク・シティの中でも五指にはいるまでになった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネヴァダ山脈の中で銀を求め、そして富を増やそうとソルト・レイク・シティに戻った。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三章　ジョン・フェリアと預言者の対話　ジェファースン・ホープとその仲間たちがソルト・レイク・シティを去り、三週間経った。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章　決死行　モルモンの預言者と話をした次の朝、ジョン・フェリアはソルト・レイク・シティへ下りていって、例の友人を捜し当てた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面はいたるところ馬の足跡だらけ、どうやら追っ手は大規模の騎馬隊、跡の通る方向からすると、そのあとソルト・レイク・シティへと引き返したようだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョン・フェリア元ソルト・レイク・シティ住民一八六〇年八月四日没　わずか前に別れたばかりのあの不屈の老人は、そのときすでに逝っており、これが彼の墓碑銘なのだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "変装し、偽名を使ってソルト・レイク・シティへ戻り、おのれの命も省みず、ただおのれの知る正義をなす一心だった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソルト・レイク山地で陽に曝されすぎたことと栄養不足とがあだとなりました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ソルト・レイク・シティからサンクト・ペテルブルクまで追いかけたが、いつも逃げおおせたな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者は両名とも若年の頃末日教徒の一員であり、このたび死んだ被疑者ホープはソルト・レイク・シティ出身であるそうだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヨウユウライスよりもソルトライスがうまい！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌の輸出　日本からホノルル、ソルト・レークなどにいる在米邦人を対象として十九点約五千冊の輸出が正式許可された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って速力が半分に減じまするから、至急、隣に居りますソルトレーキへ御移りを願います」「なに、本当に潜水艦か！",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一八、モルモン宗の本寺　米国ソルトレーク都府には、モルモン宗の本寺あり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "繊維実業家サミュエル・マサム男爵、綿工場主タイタス・ソルト卿、銀行家ジョージ・ピーボディ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この会社は、エプソム・ソルト、サラン・ラップ、ハンディ・ラップ、雑草除去剤……」　と、日常生活でよく知られた、つまらない製品の名を列挙し、「……そしてナパームを、製造しています。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
