    "definitions": [
      {
        "index": 1,
        "gloss": "minced meat or fish that is seasoned and fried (usu. served on top of rice)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "譬へば敵の毛羽艶やかに峨冠紅に聳えたる鶏の如く、此方は見苦しき羽抜鳥の肩そぼろに胸｜露はに貧しげなるが如くであつたが、戦つて見ると羽ふくよかなる地鶏は生命知らずの軍鶏の敵では無かつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日日暮れに停車場へ急ぐとちゅうで、自分は落ち稲を拾ってる、そぼろなひとりの老婆を見かけた。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十になってもしりのおちつかない、落ちぶれはてた花前は、さだめてそぼろなふうをしているかと思いのほか、髪をみじかく刈り、ひげをきれいにそって、ズボンにチョッキもややあかぬけのしたのを着てる。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そぼろな、旅窶れのした姿の旅人が、美しい錦の袋を大切さうに胸に下げてゐるので、胡麻の蠅が二人すぐ後に附いた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはそぼろ料理のような小さく切ったものは塩湯で湯煮て油で炒りつけてそれから二時間も煮抜くのだ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでにそぼろと角煮もモー一皿ずつ召上ったら如何です。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十八　豚のそぼろ飯　は豚のロース肉を糸切りにして塩でよく揉んでザット湯煮て牛蒡に木クラゲに糸蒟蒻にその他時の野菜物の細かく刻んだものと一緒に醤油とお酒と少しの砂糖とで二時間ほど汁沢山に煮ます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六日の日に東京から、菓子と果物と「鳥そぼろ」がついて、同じ日に十二月分の国民文庫が届いた。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚肉なしの竹の子そぼろ煮、竹の子かにんじんがあれば、細かくきざんで、豚肉代わりに海糠か、生節ぐらゐ入れる。",
              "citation": {
                "source": "ともしい日の記念",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銚子では酒の肌が荒れるから、錫のちろりで、ほんのり人肌ぐらいに願います」「かしこまりました」「……最初は、まずお吸物だが、こいつは鯛のそぼろ椀ということにいきましょう。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんは、今でこそぼろ小屋の隅っこで、乾燥した木の葉っぱをしきつめたベッドに寝たきりになっていますが、世間のやり方というのがどういうものかを、完全に忘れた訳ではありませんでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯の上へ、そぼろのように叩いた鳥の肉と葱を煮込んだ汁が掛けてある。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終り四時半頃、外出する暇なし、ふた葉のそぼろ親子と汁。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平晃が今日迄、浅草と掛持ち、その待ちや、米食時間でないと食事が出来ないので、大分無駄があったが、僕はふた葉のそぼろ丼ですませ、夜の九時頃には終ると思ったのが、十二時迄かゝってしまった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終りには外出せず、ふた葉のそぼろ親子をとって食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食はふたばのそぼろ丼。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終り来訪の正岡容と馬楽と喋り、ふた葉のそぼろ丼をかき込むと、もう五分前が鳴る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食は、ふた葉のそぼろ親子。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食は、そぼろ丼一個。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とその注意にうなずいた孫兵衛は、血脂は古く錵の色は生新しい、そぼろ助広の一刀をギラリと抜いて鞘を縁側へ残し、右手の雫の垂れそうなのを引っさげて、しずしずと椎の下へ歩みだした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そぼろ助広の大刀が、椎の樹の下――万吉の頭の上に――きらりと三尺の虹を描いた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、屋根から斜めに落ちてきた今の小鳩、何かに狂いだしたように、そぼろ助広の切っ尖に飛びまとって離れない――。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがお十夜さん、妙な所で落ち合ったねえ」「そッちは不意に思うだろうが、この孫兵衛は、ぬきや屋敷のあの騒ぎから後、どんなに跡を探していたか知れやしねえ」　何か一｜物ありそうなお十夜――あのそぼろ助広の鉄色のようにトロリとした眼でお綱を視る……。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして五十三｜次の泊りの間に、この女を生れ変ったようにしてやったら……こりゃ、そぼろ助広の刃に、辻斬りの血をぬるような快さの比ではない……と、孫兵衛の魔情はニッタリとするのであった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――たとえば、京橋口で、斬るべき万吉を斬らずにフン縛ったり、ぬきや屋敷の椎の下で、そぼろ助広の切ッ尖でなぶってみたり、それはみな孫兵衛の粘りッこい悪の悦楽で、助広の刀をかまえる時も、女の肉をむさぼるにも、人に恨みを酬いるにも、かれのやり方はどこまでも暗く陰険である。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そぼろ助広へ気合がかかれば、お綱の胴か細首かは、ただ一｜閃に両断される。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪以来ここしばらく、そぼろ助広にもうまい生血を舐めさせない。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と――思うといつの間にか、万吉の後ろへ、ぬウと立ったお十夜が、そぼろ助広に手をかけて、据物斬り！",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おのれッ」と叫んでそぼろ助広を振りかぶった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どいつだ、酒代がほしいのは」と、さなきだに、弦之丞を討ち損じた腹立ちまぎれ、そぼろ助広を抜いて脅しにふりこむと、頼まれて来たあぶれ者は、胆をつぶして逃げだしてゆく。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
