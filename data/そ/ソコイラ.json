    "definitions": [
      {
        "index": 1,
        "gloss": "around there",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕も帰らうと思つてゐたんだから、どこか其処いらでお茶でも飲んで別れませう。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か其処いらにあるものを持出して行くのは、あの男ばかりではないらしかつた。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも唯、一週間か其処いら待つて貰ふだけの話だもの。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其の上でまあ其処いらが落著どころと決つたわけであつた。",
              "citation": {
                "source": "復讐",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「え、どこか其処いらのカフエでも何でもいゝんですよ。",
              "citation": {
                "source": "復讐",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い塵のポカポカ立つ、粗雑なペンキ塗の目に痛く反射する其処いらの路を想像致します。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『えゝ、私ももう其処いらであきらめとかうと思ふの、自分でももう心配するなつて云つてるし。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "にわかに人の出入の多くなった台所へ行って追いやられたり表座敷へ行って叱られたりして居るうちに、門の方にガヤガヤと人声が仕出すと、奥から出て来た母は其処いらをうろうろして居た私に、「其処へ入っておいで。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで煩い他人のやうに其処いらに煩い自分がふさがつてゐて、厭らしくてうんざりした。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処いらは小路の両側の、築土も崩れがちで、蓬のはびこった、人の住まっていない破れ家の多いようなところだった。",
              "citation": {
                "source": "曠野",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは小屋の前の火山灰質の地面を削って其処いらを泥流と化していた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで煩い他人のように其処いらに煩い自分がふさがっていて、厭らしくうんざりした。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ちょうど其処いらが、月江の落ちて行った辺だろう」「なるほど、そいつは妙案だ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の火事ならば大勢の人が集まっているであろうに、あたりには人影もなくただ野良犬が一匹そこいらにうろうろしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそこいらを歩いている普通十人並の娘達と同じような着物に、やはりありふれたようなショールを肩へかけて、髪は断髪を後ろへ引きつかねている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこいらにある本で好いなら。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに爺さん、手間は取らさねえからそこいらまでいっしょに歩びねえ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし一プロセントの中毒率があるとすればその実例が一つや二つぐらいそこいらにありそうな気がするであろう。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か不安な予感のようなものがそこいらじゅうに動いているようであった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして声のある限り、アヤ子の名を呼びながら、砂浜の方へ馳け出して、そこいらを見まわしました…………が…………。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "指定された通りに裏門の潜り戸から這入ると、そこいらのベンチに待っていたらしい訪問着姿の未亡人が出迎えた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであの死骸を蔵元屋から担い出いた大風呂敷か何かが、そこいらに棄てて在りはせんかと一所懸命に探しまわったが、怪しい縄一筋、細引一本見当らんじゃった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈甲屋や、衣裳屋、指物屋なぞの出入りが間遠になって来たのは、どうも怪訝しいと言う近所界隈の取沙汰じゃ……吾々もドウモそこいらが臭いような……事件の起りはその辺ではないかと言いたいような気持がするが、それから奥の深い事情が一つも判然らんけに困っとる。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずそこいらかも知れんがなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこいらの話がダイブ臭いのう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとそこいらに類のないドエライ疵が……」「ふうむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでガックリとなった奴を蹴返やいて、縄の端を解いてそこいらに在った道標の角石を結び付けた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその「能」なるものは、そこいらにありふれた専門家が舞台の上でやるソレよりも、はるかに緊張充実したものだから面白いではないか……と言ったとて、決して眉に唾するような話ではない。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の汗を拭き拭きそこいらを見まわした。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だろうとそこいらを見まわしますと、そこの白壁によせかけてあったサイダーの瓶に一匹の虻が落ち込んで、ブルンブルンと狂いまわりながら、「ドウゾ助けて下さい。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
