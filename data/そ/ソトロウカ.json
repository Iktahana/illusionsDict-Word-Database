    "definitions": [
      {
        "index": 1,
        "gloss": "exterior hallway (esp. of an apartment building)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
