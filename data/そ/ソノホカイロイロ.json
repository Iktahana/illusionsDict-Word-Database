    "definitions": [
      {
        "index": 1,
        "gloss": "and various other things",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その他いろいろ六かしい事があって普通の人の手に畢えぬ方法である。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時でも水蒸気が露のごとく水滴になるには何か塵のごとき微細ないわゆる凝縮核が必要であるし、ガラスの表面の性質によってつきかたにいろいろ異なった状態があったり、その他いろいろこの水に聯関した面白い問題があるのである。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤでも黴臭いものを捻くらなければ、いつも定まりきった書物の中をウロツイている訳になるから、美術だの、歴史だの、文芸だの、その他いろいろの分科の学者たちも、ありふれた事は一通り知り尽して終った段になると、いつか知らぬ間に研究が骨董的に入って行く。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルキシズムその他いろいろなイズムの立場から蜜蜂に注文をつけるのは随意であるが、蜜蜂はそんな注文を超越してやっぱり同じように蜜を集めるであろう。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば五穀の収穫や沿海の漁獲や採鉱｜冶金の業に関しては農林省管下にそれぞれの試験場や調査所などがあって「科学的政道」の一端を行なっており、疫病流行に関しては伝染病研究所や衛生試験所やその他いろいろの施設があり、風水旱害に関しても気象台や関係諸機関が存在しているようである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新調するとなると、同時に靴もシャツもその他いろいろの附属品が必要らしいから百円以上は、どうしてもかかるだろうと思われる。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――刃物、縊死、鉄道往生、その他いろいろ自殺の方法を、このあまりに感情的だった動物は考え出した。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この体験から、私は子規の歌がわかり、自然派小説がわかり、その他いろいろな事が解つて来た。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤高、清貧、思索、憂愁、祈り、シャヴァンヌ、その他いろいろございました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他いろいろ働いた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他いろいろあるが、三年待て云々の話は多分嘘だろう。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいときの涙、うれしいときの涙、その他いろいろな涙のほかにこうしたような不思議な涙がまだほかにもいろいろありそうな気がする。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝の中からたんぽぽやほおずきやその他いろいろの雑草もはえて来た。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他いろいろ深く観察と理解とが到る処にかゞやいてゐるのを見る。",
              "citation": {
                "source": "西鶴小論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他いろいろに区別ができる。",
              "citation": {
                "source": "写生文",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他いろいろのものを注文に応じて彫りましたが、その代り今年七十一（大正十一年十二月）になりますが、ついに道具屋へ自作を持って売りに行くことはしないで終りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "牙彫りを排し木彫りに固執したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆柱には赤、青、黄、紫、その他いろいろの彩紙が一面に懸け渡されて、秋の朝風に飛ぶようにひらめいている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……つまり、常連の傍聴人になり済まして、傍聴しつつある窃盗事件や詐欺事件や、その他いろいろの事件に就いて、有罪か？",
              "citation": {
                "source": "あやつり裁判",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると極寒の海に俄然常春が訪れるじゃないか、漁業や交通やその他いろいろの事業に関して……」「ほう、これは面白い想定だ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "清三は思わず興に乗って、理想めいたことやら、家庭のための犠牲ということやらその他いろいろのことを打ち明けて語って、一生小学校の教員をする気はないというようなことまでほのめかした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ等の生活上の科学を、次の世界を夢想する科学を、われ等の生命を脅かす科学を、その他いろいろな科学を土台として、科学小説はいまや呱々の声をあげようとしている。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非共細君を呼んで死んでるという自覚を起さしたり、その他いろいろやってやらないと、死んだ細君は浮ばれないぞ、と叱るのです。",
              "citation": {
                "source": "あの世から便りをする話",
                "author": "――座談会から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他いろいろなものであらう。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの本は、農業の技術と經營に關するもの、通俗的な所謂修養書、歴史物語とか偉人傳の類、その他いろいろだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その写真は乃木大将の少年時代からのことが仕組まれてあつて、まだ前髪をつけた乃木大将が淋しい田舎道を歩いていると、大入道や傘の一本足のばけものやその他いろいろのばけものが趣好をこらして入りかわり立ちかわり現われた。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方法を使って鉄砲のたまが空中を飛んでいるときに、前面の空気を押しつけているありさまや、たまの後ろに渦巻を起こして進んでいる様子を写真にとることもできるし、また飛行機のプロペラーが空気を切っている模様を調べたり、そのほかいろいろのおもしろい研究をすることができます。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたをあけて見ると腐ったような水の底に鉄釘の曲がったのや折れたのやそのほかいろいろの鉄くずがいっぱいはいっていて、それが、水酸化鉄であろうか、ふわふわした黄赤色の泥のようなものにおおわれていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゆんべはおっかなかったよ、先生、酔っぱらいのおやじが、両手を拡げて追ってくるんだもの」「なあ」「先生は今夜わしの方へと廻っておくれよ」そのほかいろいろな言葉が一度に、不思議な後ろめたさに興奮している柿江の耳に騒々しく響いてきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では栄蔵も小さい子供ではないので、弟や妹の守をしたり、お使にやらされたり、そのほかいろいろ仕事があつたけれど、少しの暇を見つけては勉強した。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかいろいろの方面のそう難者について、さまざまのいたいたしい話を聞きました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
