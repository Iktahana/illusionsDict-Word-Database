    "definitions": [
      {
        "index": 1,
        "gloss": "hidden reserves of strength",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それにランプの焔はどこかしっかりした底力をもっているのに反して、蝋燭の焔は云わば根のない浮草のように果敢ない弱い感じがある。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声は低いけれども底力があって、なんだか私を命令するようでした。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうせ何んでも自分でやらないじゃならない学校だからかまわないといえばかまわないことだが……今日は少しはいいの」　澄んで底力のある声が、清逸の眼にだんだん明瞭な姿を取ってゆく園の方から静かに響いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの強い烈しい底力、それはもうこの家には、どの隅にも塵ほども残っていない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢本　　そうすると、俺たちはうんと飯を食って底力を養うことができるぞ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今頃、何をしておいでなさります、お一人でこんな処に……ははは、」　と底力の無い愛想笑で、「いや、もう、人様の事をお案じ申すという効性もござりません。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その細い、幽な、空を通るかと思う雨の中に、図太い、底力のある、そして、さびのついた塩辛声を、腹の底から押出して、（ええ、ええ、ええ、伺います。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいかにも無邪気な子供らしい声が、呼んだり答えたり、勝手にひとり叫んだり、わあと笑ったり、その間には太い底力のある大人の声もまじって聞えて来たのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "况んや此海底戰鬪艇は、波威に沈降する事三十｜呎乃至五十｜呎、其潜行を持續し得る時間は無制限であるから、一度此軍艇に睥睨まれたる軍艦は、恰も昔物語の亞剌比亞の沙漠の大魔神に魅られたる綿羊のごとく、遁れんとして遁るゝ能はず、鬪はんか、速射砲もガツトリング砲も到底力及ばぬ海底の此大怪物を奈何せん。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "出合はせた女中に、聞きなれない、かう少し掠れたが、よく通る底力のある、そして親しい聲で音づれた人がある。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「力は入るね、尾を取って頭を下げ下げ、段々に糶るのは、底力は入るが、見ていて陰気だね。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五百円や三百円、）と大な声して、（端金子、）で、底力を入れて塗りつけるように声を密めて……（な、端金子を、ああもこうもあるものかい。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "客たちは後から骨身も融けるほど打ち解けさせられた中に人情の機微を学ばせられ、世路に勇み立つ底力を与えられた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元二千六百年頌朗誦詩　盛りあがる盛りあがる國民の意志と感動とを以て、盛りあがる盛りあがる民族の血と肉とを以て、個の十の百の千の萬の億の底力を以て、今だ今だ今こそは祝はう。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一齊にとどろかす跫音を以て、個の十の百の千の萬の億の、靜かな底力を以て。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……幽霊だあッ……ウワア――ッ……」「幽霊じゃない……」　白坊主が底力のある声で云った。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、そんな世話を続行するのは日本亡国の原因を作るようなものだとつくづくこの頃思い当ったせいでもあるんだがね」　こうして縷述して来ると彼の法螺の底力は殆んど底止するところを知らない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい目の前を、足に絡んだ水よりは色の濃い、重っくるしい底力のあるのが、一筋、褐色の鱗を立ててのたっているのが、向う岸の松原で、くっきりと際立って、橋の形が顕れたんだ。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝りや何欲しいつちんだ」小柄な爺さんは底力の有る聲を低くしていつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の容子を見ると心に何か蟠りがあるやうでもあるが其活々した底力のある容貌は決して愁あるものではないといふことを知らしめる。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い襟卷をした彼は「馬車屋さん少し待つておくんなさい」　ゆつたりと底力のある聲で馬車を留めさせた。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "底力のこもった鈍い空気が、音もなく重苦しく家の外壁に肩をあてがってうんともたれかかるのが、畳の上にすわっていてもなんとなく感じられた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分のからだがずっと高まってやがてまた落ちて行くなと思わしいころに、窓に近い舷にざあっとあたって砕けて行く波濤が、単調な底力のある震動を船室に与えて、船はかすかに横にかしいだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何しに来た」　底力のある声にもう一度どやし付けられて、仁右衛門は思わず顔を挙げた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文人は好い加減な処で忽ち人生の見巧者となり通人となって了って、底力の無い声で咏嘆したり冷罵したり苦笑したりする。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "口の先きで喋べる我々はその底力のある音声を聞くと、自分の饒舌が如何にも薄ッぺらで目方がないのを恥かしく思った。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭は忽ち底力のある声で「明月や……」と叫って、較や暫らく考えた後、「……跡が出ない。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮健な時と同様にガラガラしていたが、底力が抜けていて、一緒に声を合わして笑う事が出来なかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも一｜揆が、かりそめの百姓一揆とちがって、手強い底力を持っていることが知れるに従って、一藩の人心はいよいよ猛り立った。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
