    "definitions": [
      {
        "index": 1,
        "gloss": "(command) headquarters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
