    "definitions": [
      {
        "index": 1,
        "gloss": "exterior",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "云わば、彼の神経は彼の体の外側へ飛び出して、彼の眼を透して、彼の体の中を覗いているのだった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞西あたりの山のホテルを想はせるやうな帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルといふ宿屋に泊つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "單調な東京音頭は嵐か波の音と思つて聽き流すことが出來ると假定しても、可愛い子供の片言は身につまされてどうにも耳朶の外側に走らせることの出來ぬものである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイスあたりの山のホテルを想わせるような帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルという宿屋に泊った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおのおのには、内側のものと外側のものとの脈帯の襞が違っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外側をためてばかりいると、内側の生命が萎縮してしまう。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の鉄扉の外側に子守が二、三人立って門内の露人の幼児と何か言葉のやりとりをしていると、玄関から逞しいロシア婦人が出て来て、逞しいむき出しの腕でその幼児を軽々と引っかかえて引込んで行った。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばビーカーをアルコールランプで下から熱すると水蒸気が出てそれがビーカーの外側にあたって冷却され、水粒がビーカーに附着する。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）スリートとして挙げられているものの中には、以上のようなものの外に雪片のつながったのが一度溶けかけてまた凍った事を明示するようなものや、氷球の一方から雪の結晶が角を出しているのや、球の外側だけが氷で内部は水のままでいるのもある。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと外側から見ると恐ろしく窮屈そうに見えるような天地に居て、そうして実は、最も自由に天馬のごとく飛翔しているような人も稀にはあるようであり、一方ではまた、最も自由な大海に住みながら、求めて一塊の岩礁に膠着して常に不自由を喞つ人も稀にはあることはあるように思われる。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでその形状なども充分に研究されていた訳であるが、この頃仏国のある高山の天文台で観測していたら従来人の知っている輪の外側にもう一つボンヤリした輪のある事を発見した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では、土壁の外側に羽目板を張ったくらいが防寒防暑と湿度調節とを両立させるという点から見てもほぼ適度な妥協点をねらったものではないかという気がする。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもはや外側に向けた目だけではできない仕事である。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道明寺の餡入り餅であったがその外側に糯米のふかした粒がぽつぽつと並べて植え付けてあった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒の外側はアルミニウムペイントで御化粧をしてあるが、金属製だかどうだか見ただけでは分らない。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の一隊は、どこからか徴発して来た丸太を打ちこんで、土嚢塁の外側へ、四重に鉄条網を張りめぐらした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――壁の外側に取りつけた戸袋に、二枚の戸を閉めると丁度いゝだけの隙があった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳の木のなかといふわけは、葉の落ちてカラッとなった柳の木の外側には、すっかりガラスが張ってあるやうな気がするのです。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏に銅の壺に水を入れ壺の外側を水でぬらしたきれで固くつつんでおくならばきっとそれは冷えるのだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対に、茶わんのまん中のほうでは逆に上のほうへのぼって、表面からは外側に向かって流れる、だいたいそういうふうな循環が起こります。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の後方の扉があいている外側には、このへんの貧民がいっぱい立って騒々しく話している。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤熱した岩片が落下して表面は急激に冷えるが内部は急には冷えない、それが徐々に冷える間は、岩質中に含まれたガス体が外部の圧力の減った結果として次第に泡沫となって遊離して来る、従って内部が次第に海綿状に粗鬆になると同時に膨張して外側の固結した皮殻に深い亀裂を生じたのではないかという気がする。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙の柱の外側の膚はコーリフラワー形に細かい凹凸を刻まれていて内部の擾乱渦動の劇烈なことを示している。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳の木のなかというわけは、葉の落ちてカラッとなった柳の木の外側には、すっかりガラスが張ってあるような気がするのです。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又それに連れて図書館の外側の手入れが不充分になったらしく、スレート屋根の上にタンポポだのペンペン草だのがチラチラと生え始めた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……がしかし……仕事のむずかしいのはここまでで、アトは何でもありません」「そんなものですかねえ」「その水雷の外側をランチのバスケットか何かに見えるように籠で包んで、籤取りできめた五、六人がボートに乗って、舟遊びみたいな恰好でズット沖に出てしまいます。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイオイ」　と言うて耳を澄ますうちに、今たたいた雨戸が外側へバッタリと外れかかるのを、良助は慌てて両手で受止めながら小舎の中を覗き込んだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の目から見るとただ自分の心の中へ中へと引っ込んで行く亮を、どうでも引き立てて外側へ向け直してやる事が自分の務めのように思っていたので、機会あるごとに口をすくして説法のような事を聞かせた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して罪悪の外側のゆがんだ輪郭がいたずらに読者の病的な好奇心を刺激し、ややもすれば「罪の享楽」を暗示するだけであったらその影響ははたしてどうであろう。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして残った部分の輪郭をだんだんに外側へ外側へと広げて行くうちに適当な目標が見つかるのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
