        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すぐ女中の案内で、大く宿の名を記した番傘を、前後に揃へて庭下駄で外湯に行く。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧みると温泉の外湯の煙は濛々と軒を包んでたち騰ってる。",
              "citation": {
                "source": "白菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小使はふろを立てない日に坊ちやんをつれて外湯へ行つたりなぞする外には、おくみの手で使ふ費りが少しもないやうな日があつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "外湯に入りつけないお増は、自身湯殿へおりて、風呂の湯を焚きつけたり、しばらく手にかけない長火鉢に拭巾をかけたりして働いていた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯は炭酸泉だ、外湯で、大きな共同の浴場が出来ていて、皆下駄を穿いてその湯に這入りに行く。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "外湯で、大きな共同の浴場が出來てゐて、皆下駄を穿いて其湯に這入りに行く。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川と言う其流れについて下って、高瀬とか言った宿屋数軒、外湯一棟と言う処も見て、湯沢温泉へ出た。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯沢で一泊、こゝの温泉は駅から一寸離れた丘の上にあり、従って家の建て方などに面白い点もあるが、惜しいことには外湯なので、気分が落つかない。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の温泉に来るのかと思つたら、川中に在る外湯に這入つて行つた。",
              "citation": {
                "source": "落葉降る下にて",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内湯もある、外湯もある、蒸湯もある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
