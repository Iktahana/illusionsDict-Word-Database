        "examples": {
          "standard": [
            {
              "text": "予算が足りないため、その場しのぎの修理しかできなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この計画は、その場しのぎの対策であり、長期的な視点に欠けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はいつもその場しのぎで物事を解決しようとする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "里子は何時までたつても、別れませうとは云はなかつたけれども、身についた仮装で、その場しのぎに、獣と化した直吉をあしらつてゐる。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失業保険の要求も、解雇手当の要求も、ただその場しのぎのことで、資本主義の経済組織が根本的に改造せられなければ失業問題を解決する道はない。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場しのぎに慈悲を与えてやるのは、かえって法を乱すもと。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
