    },
    "definitions": [
      {
        "index": 1,
        "gloss": "transmission (of a television picture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "機銃と毒｜瓦斯弾をもった監察隊員が、テレビジョンの送像器の前を、うろうろしています。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして各国でも（米国のＲ・Ｃ・Ａビクター会社、英国のマルコーニＥ・Ｍ・Ｉ会社、独逸のテレフンケン会社、その他ソヴェートの研究所など）、最近発明された電気的送像器（アイコノスコープ）の研究に競争的だ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その啼き声が夜昼そうぞうしいと云うので、南隣りの人はとうとう引っ越してしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「何じゃ、そうぞうしい。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしはそうぞうしいパリを見おろしていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うう、うう、ううん」「ううんじゃありません、火事です、たいへんです、起きてください」「やかましい、たれだ」「たれもかれもありません、そんなことを云ってる場合じゃありません、起きてください、たいへんです」「雉か」「雉ですから、早く起きてください、たいへんです」「なにがたいへんだ、そうぞうしい。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外はいよいよ日盛りになって来たらしく、油蝉の声がそうぞうしく聞えた。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃わたしは神田に下宿していたんですが、何分にも周囲がそうぞうしくって、いよいよ神経を苛立たせるばかりだと思ったので、さらに小石川の方へ転宿して、その翌年に第二回の試験を受けると、これも同じ結果に終りました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、そうぞうしい。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前はずいぶんそうぞうしくて、水の音よりも蛙の声の方が邪魔になるぐらいでございました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候はやはり五月のはじめで、同じことを毎度申すようですが、川の岸では蛙がそうぞうしく啼いていました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉の一件は嘉永六年の三月三日、その年の六月二十三日には例のペルリの黒船が伊豆の下田へ乗り込んで来るという騒ぎで、世の中は急にそうぞうしくなる。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの田では蛙がそうぞうしく啼いていた。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りが料理屋で芸者も一人かかえてあるので、時々客などがあがっている時は、随分そうぞうしかった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、たれにもよういにそのばあいがそうぞうされて、おもしろかろうとおもうのでございます。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心のなかでどのくらい不愉快に感じているか、きみたちにはそうぞうもつかんだろう。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "中島はちょっと見るとそうぞうしい男だが、弁護士より裁判官がいい、新聞記者よりは学校の教員のほうが安全だというぐらいだから、その気風も知れてる。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは鬼のような人だ」「そうぞうしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり世の中がそうぞうしくなったせいで、もうその頃から江戸も末になりましたよ」　老人は昔を偲び顔に話し出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "社内にも松杉がおい茂っていて、夏なんぞは蝉の声がそうぞうしい位です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、お寒うございます」「冬場所はたいそう景気が好かったそうだね」「世間がそうぞうしいのでどうだかと案じていましたが、お蔭でまあ繁昌でした」「いいところでおめえに逢った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんです」「なんだか家じゅうがそうぞうしいようだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか世間がそうぞうしいから、いっそ今年はお見あわせにしようかと云っていたんですけれど、やっぱり若い衆たちが納まらないので、いつもの通り押し出すことになったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "柾木の生垣を取りまわした人家がまばらにつづいて、そこらの田や池では雨をよぶような蛙の声がそうぞうしく聞えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうぞうしい」　わざと落ち着き払って、半七は階子を降りてゆくと、熊蔵は摺り寄ってささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は気分も快くなったので、きのうの通りにあるき出すと、路ばたに蛙の鳴く声がそうぞうしくきこえた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷に撃たれた銀杏の木は、大きい枝を半分折られたのですが、その幹には蝉が飛んで来て、ゆうべの事なんぞはなんにも知らないように朝からそうぞうしく鳴いていました。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仕方がなしにすごすご引揚げて、もとの長徳院のあたりまで帰って来ると、なにかそこらがそうぞうしくって、大勢が駈けて行くようですから、ボヤでも出しゃあがったかと思って、通りがかりの者に訊いてみると、いやどうも驚きました。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "観世物小屋のそうぞうしい鳴物の音も、彼の耳へは響かなかった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにそうぞうしいので、雨戸をあけてみると、隣家に住んでいる英国公使館の書記官マクラッチという人の飼犬が、わたしの家の庭にはいって来て無暗に吠えたけっているのであった。",
              "citation": {
                "source": "父の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
