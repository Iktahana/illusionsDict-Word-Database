[
  {
    "uuid": "89b3090e-8c8c-58d9-9934-96290157e33b",
    "entry": "創造",
    "reading": {
      "primary": "そうぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
