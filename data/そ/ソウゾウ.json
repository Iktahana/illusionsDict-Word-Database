  {
    "uuid": "6c619016-c4b5-5f3c-a7f2-e4d35658e099",
    "entry": "送像",
    "reading": {
      "primary": "そうぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
