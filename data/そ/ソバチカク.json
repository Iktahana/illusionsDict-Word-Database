        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "清逸は園が側近く来たのを知ると、なぜともなく心の中が暖まるのを覚えて、今までの物臭さに似ず、急いで窓から戸口の方に寝返った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく躊躇していたがファニーはやがて私の命ずるままに私の側近くすわった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、彼の側近く寄つて来て彼の顔を覗いて行く無遠慮ものさへあるではないか。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄ったウェーターが私を出張りの硝子囲いの側近くの卓に導いて呉れて、間もなく皿を運んで来た。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人も客も湯帷子に着更へて、縁側近く据わつて、主人と背の高い赭顔とが棋を打つのを、小男の客が見てゐる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいに掃除の届いた庭に臨んだ縁側近く、低い机を出してくれる。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすこし往ったところで、女郎は侍女を車の側近く呼んで言った。",
              "citation": {
                "source": "瞳人語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長政罪人を誅するに諸士に命じて見逢に切り殺させらる、長政側近く呼んでその事を命じ命を承けて退出する、その形気を次の間にある諸士察して仕置をいい付けられたと知った、しかるに政利に命じた時ばかり人その形気を察する能わず、この人天性勇猛で物に動ぜなんだからだと貝原好古が記し居る。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "長十郎はまだ弱輩で何一つきわだった功績もなかったが、忠利は始終目をかけて側近く使っていた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやくから忠利の側近く仕えて、千百石余の身分になっている。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は、瑠璃子の右側近く腰を降した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、側近くに仕えている家来の一人が、慌てて紀州侯の前へ出て来た。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき、殿様からのいいつけで、お側近く仕えている小役人の一人が記内を訪ねて来て、鶏の鍔を注文した。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝自らもいかにも気持がよささうだつたが、側近くに居並んで聴いてゐた侍臣達も、ほとほと感に堪へてゐる様子だつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の會見は、縁側近く四つ五つ實を持つた橙の樹のある、竹山の室で遂げられた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の会見は、縁側近く四つ五つ実を持つた橙の樹のある、竹山の室で遂げられた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君から電話が掛つて来る時分には彼は、酒徳利の載つた朝飯の膳を縁側近くに用意して、新しく取り寄せた箱根細工の脇側などに凭りかゝりながら深刻な眼つきでＡ・Ｂの活躍を視守つた。",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きの縁側近くに師の机は据えてあった。",
              "citation": {
                "source": "旧師の家",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、いつの間にか椅子を離れて、恰も相手の狙いを正しくしてやるように、電燈の側近く立っていた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は久しぶりで騒々しい都会の轢音から逃れて神経にふれるやうな何の物音もない穏やかな田舎の静寂を歓びながら長々と椽側近くに体をのばして、甘つたるい洋紙の匂や、粗いその手ざはりさへ久しぶりな染々した心持で新刊書によみ耽つてゐました。",
              "citation": {
                "source": "白痴の母",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "色彩ある生活の背景として、棚の葡萄は大きな美しい葉を房々と縁側近くまで垂らして涼風に揺れた。",
              "citation": {
                "source": "毛の指環",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉親の側近くにたどりついたと思ううれしさと、敵地に足をふみ入れたような険しさが、同時に彼の胸を圧迫していた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが物語をする主人公は自分の閲歴を語るより、自分の側近く居た人の閲歴を語る方が普通である。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は、神の側近く仕へて居た人が、後には替り、宗教的に物語を伝播する為、諸国を廻つて歩くやうになる。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度などは御二人で、私を御側近く御呼びよせなさりながら、今昔の移り変りを話せと申す御意もございました。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は暗い小径を左へ折曲って、コルトンとエリスの姿を探し求めているうちに、たちまち側近くに拳銃の音を聞いた。",
              "citation": {
                "source": "Ｐ丘の殺人事件",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "其を感じたのは、東側の奧の妻戸が、一枚送つてあつて、もう早い朝の來てゐることを示してゐたから、却て南面の西側近く寢てゐると、やつと自身の手の動くのが、見える位であつた。",
              "citation": {
                "source": "死者の書　續篇（草稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の側近くへ坐ったまま伏目になって黙っていた。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、お話ししましょう」　一同は好奇の目をみはって、婦人のそばちかくよった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
