          "literary": [
            {
              "text": "帯は空解け一「オイッ、駕籠屋ッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仰天した萩乃の胴から、その時、なんのはずみか、サラサラと帯が空解けて――。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "空解けの帯は、待ち人……源さまきたるの先知らせか。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして紐は空解けのしないように、結び目を左右に分けてはさんでおく。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
