        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "校庭宮沢賢治さ霧する白き木柵幹彫れる桐のいくもと剥げそめし白きペンキの木柵に人人は倚りそのペンキあるいは剥げあるものは庭をのぞめり一鐘のラッパが鳴りて急ぎ行く港先生白堊城秋のガラスはひらごとにうつろなりけり",
              "citation": {
                "source": "校庭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよや眠れる、くらき土壌にいきものは、懺悔の家をぞ建てそめし。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝より吹きそめし風しだいに荒らく磯打つ浪の音すごし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職技手こぞりてひとを貶しつゝ、　　　わかれうたげもすさまじき、おのれこよひは暴れんぞと、　　青き瓶袴も惜しげなく、籾緑金に生えそめし、　　　　　代にひたりて田螺ひろへり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲紫に日は熟れて、　　　　　青らみそめし野いばらや、川は川とてひたすらに、　　　八功徳水ながしけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　その次が十一月二十二日の夜『月の光、夕の香をこめてわずかに照りそめしころ河岸に出ず。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は窮みなき空高くながめ、胸さくるばかりの悲哀をおさえて、ひそめし声に力を入れ、『必ず手紙を送りたまえ、今こそわが望みは君が心なれ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然はひつそりと息をひそめしだいにふしぎな　大きな山のかたちが襲つてくる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ髮の毛もみだれみだれし暗い土壤に罪びとは懺悔の巣をぞかけそめし。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後拾遺集恋一、「恋そめし心をのみぞうらみつる人のつらさを我になしつゝ」、続千載集恋五、「つらくのみ見ゆる君かな山の端に風まつ雲のさだめなき世に」も兼盛の歌である。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "転づるは French か、角ぐみそめし桜の二列の並木の間の人道を、枯草の辺りを青くして低きかなめ垣の長き径に添ひて、ハリエニシダの花黄なる彼方へとぞゆく。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "角帽子雪かとばかりわななけど、声さへ立てず、緑玉、息をひそめし瞳こそ精霊の日本の秋の啜泣吸ひ取る如し、泣く如し。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "転づるは French か、角ぐみそめし桜の二列の並木の間の人道を、枯草の辺りを、青くして低きかなめ垣の長き径に添ひて、ハリエニシダの花黄なる彼方へとぞゆく。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人と我が交りそめしは、まだ久しからぬほどなれど、善き性とおもはれぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人とわが交わりそめしは、まだ久しからぬほどなれど、よき性とおもわれぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の事ありしより、我が夫人を見る目は昔に同じからで、その豐なる肌、媚ある振舞の胸騷の種となりそめしぞうたてき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞奈が遂に手古奈の兄なる人を思ひそめしは其動機が極めて自然である。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この村の名も、国神塚といえるがこのあたりにあるより称えそめしなるべし。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なだれたち雪とけそめし荒山に雲のいそぎて雨降りそそぐ　上野榛名山上榛名湖にて。",
              "citation": {
                "source": "樹木とその葉",
                "author": "なまけ者と雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は、やがて尼ごろも魂ぞ着そめし日のはじめ、齋きし「戀」のゆまはりは、寂しかりきな人知れず。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "片かづら相見そめしは初夏の空も夢みる御生の日、冠にかけしもろかづら、記念にこそは分ちしか。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほの青きほの青き幻燈の雪の夜景にわれはまた春をぞ思ふ、マンドリン音をひそめしそのあとの深き恐怖に、ふりつもる雪、ふりつもる雪、…………ゆゑわかぬ性の芽生は青猫の耳の顫へをわが膝に美くしみつつ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠れる蝶けさ立ちそめし秋風に、　　「自然」のいろはかはりけり。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "目覚めて窓の戸、おしあけ庭の面見やれば、色つきそめし叢、咲乱れし千草不残にも野分にふき乱され「つらぬき留めぬ玉ぞちりける」。",
              "citation": {
                "source": "月",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある思ひ出思ひ出を哀しきものにせしは誰ぞ君がつれなき故ならずたけのびそめし黒髮を手には捲きつゝ言はざりし戀の言葉のためならず嫁ぎゆく日のかたみとて忘れてゆきし春の夜のこのくすだまの簪を哀しきものにしたばかり　　　　　夕餉時夕方になつてひもじくなると母親のことを思ひ出します。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "二その夜は、やがて尼ごろも魂ぞ着そめし日のはじめ、齋きし『戀』のゆまはりは、寂しかりきな、人知れず。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
