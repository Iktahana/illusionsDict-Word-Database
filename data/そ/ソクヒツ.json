      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "painting with the body of a brush's bristles (to create a thicker line than possible with the tip)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「筆が直筆の時、線を引張りますと、筆の毛先が線の真中に入る、筆の穂先を横に腹の方で書くと側筆となって弱い。",
              "citation": {
                "source": "芸術的な書と非芸術的な書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨線に淡彩だが、その線はすこぶるするどく、しばしば側筆を用いて、山や岩のひだを片隈どりに浮き出させるあたり、たいした筆力である。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
