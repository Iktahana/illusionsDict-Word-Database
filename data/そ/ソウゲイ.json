[
  {
    "uuid": "ad2070a1-1e7a-52d2-a0fe-ce36e2bcb65d",
    "entry": "送迎",
    "reading": {
      "primary": "そうげい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
