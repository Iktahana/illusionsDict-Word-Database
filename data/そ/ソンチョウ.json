  {
    "uuid": "492484ec-a99c-5e28-9507-f27f0663ce38",
    "entry": "村長",
    "reading": {
      "primary": "そんちょう",
      "alternatives": [
        "むらおさ"
      ],
      "is_heteronym": false
    },
    "grammar": {
