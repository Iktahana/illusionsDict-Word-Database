  {
    "uuid": "a2d6904f-ac36-5854-9189-d1033db7d0c7",
    "entry": "総覧",
    "reading": {
      "primary": "そうらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
