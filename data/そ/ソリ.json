    },
    "definitions": [
      {
        "index": 1,
        "gloss": "warp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宵の酒宴の可笑しさよ娘が運ぶ瓶子よりもるる灯影にかしこまる左右の破顏を反り見て七兵衞獨り忻忻たり。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて禿頭の大坊主で、いつも大きな葉巻を銜えて呑気そうに反りかえって黙っていたのはプリングスハイムであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土ほこりを浴びた板壁の板がひどく狂って反りかえっているのが多い。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると簑は主に紅葉の葉の切れはしや葉柄を綴り集めたものらしかったが、その中に一本図抜けて長い小枝が交じっていて、その先の方は簑の尾の尖端から下へ一｜寸ほども突き出て不恰好に反りかえっていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウツボグサの紫花の四本の雄蕊は尖端が二た叉になっていて、その一方の叉には葯があるのに他の一方はそれがなくて尖ったままで反り曲っている。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初七日落雁と黒き反り橋、　　　　　かの児こそ希ひしものを。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりかすかに舌打てば、　　ひとりは古きらしゃ鞄、黒きカードの面反りの、　　　わびしきものをとりいづる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に差し置いた大鉢には血の滴る大鯛が一匹反りかえって、側に御酒代、襟屋半三郎と書いた紙包一封。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、飲めないもの」　酌をしながら、美しい眼が下向きに、滴り落ちる酒にそそがれて、上瞼の長い睫毛のやや上反りになったのが、黒い瞳のほほ笑みを隠した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "面長く髪の白きが、草色の針目衣に、朽葉色の裁着穿いて、草鞋を爪反りや、巌端にちょこなんと平胡坐かいてぞいたりける。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二度まで、同じ人の名を、ここには居ない人の名を、胸を貫いて呼んだと思うと、支えた腕が溶けるように、島田髷を頂せて、がっくりと落ちて欄干に突伏したが、たちまち反り返るように、衝と立つや、蹌踉々々として障子に当って、乱れた袖を雪なす肱で、しっかりと胸にしめつつ、屹と瞰下ろす目に凄味が見えた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一心に写生をやっている未醒画伯を指して「あれはなんだ」と聞かれ、将軍反り返り、得意になって曰く、「ヒー、イズ、アクター」　西洋人、目を丸くして未醒氏の顔を見る。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と互に銃を身構える折しも、不意に一発の銃声とともに、秋山男爵は、「しまった※」と一口叫んで反り返った。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾丸が当ると、ガタリざらざらと蛇腹に伸びて、天井から倒に、いずれも女の幽霊が、ぬけ上った青い額と、縹色の細い頤を、ひょろひょろ毛から突出して、背筋を中反りに蜘蛛のような手とともに、ぶらりと下る仕掛けである。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と微酔も醒めて蒼くなれば、下男は何事やらんと外を望み、泰助を見ると斉しく反り返りて、「旦那々々、あれは先刻病院に居た男だ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と大喝一声、怯む処を附け入って、拳の雷手錬のあてに、八蔵は急所を撲たれ、蹈反りて、大地はどうと響きけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と後へ反り前へ俯し、悶え苦しみのりあがり、紅蹴返す白脛はたわけき心を乱すになむ、高田駄平は酔えるがごとく、酒打ち飲みていたりけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……八蔵は覗き込みて反り返り「ひゃっ、高田｜様が自殺をしたッ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と反りかえった掛声をして、（みどり屋、ゆき。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将か提督かに聞いておくれ」　オング君が、そう鰾膠もなく云って、お菓子を喰べてコーヒーを飲むのを、娘は少しばかり慍ったような顔で眺めていましたが、やがて、ふと思いついたように、反りかえった鼻のさきに皺を寄せて薄笑いを浮かべました。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "生来ぶっ切ら棒の銀子は、別に返辞もしなかったが、彼女は彼女でそんなことよりも、もっと細かいところへ目を注いでいて、車のなかに反りかえっている女たちの服装について、その地や色彩や柄のことばかり気にしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰一という郁子の兄で、三村家の相続者である均一の伯父が、彼を監視することになり、その家へ預けられたが、泰一自身均平とは反りが合わなかったので、均一の父への感情が和むはずもなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神は裏木戸の瀬川に余分の祝儀をはずみ、棧敷の好いところを都合させて、好い心持そうに反り返っているのだったが、銀子もここへ来てから、ようやく新聞や画報で見ていた歌舞伎役者の顔や芸風を覚え、お馴染の水天宮館で見つけた活動の洋画から、ついに日本の古典趣味の匂いを嗅ぐのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は得意らしく反り身になった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も喰い物を与えなかったせいか、美しかった肉付きがスッカリ落ちこけて、骸骨のようになって仰臥していたが、死んだ赤子の片足を半分ばかり生み出したまま、苦悶しいしい絶息したらしく、両手の爪をボロ畳に掘り立てて、全身を反り橋のように硬直させていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの話ですか」　と遠藤博士は、肥った身体を反り気味にして苦笑した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処らでの高級酒場たる酒場の中はひつそりして、客がゐないので小さな窓はみんな開放つてある。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしヘルンが仕事をしている時は、家人が皆神経質に注意しているので、家中がひッそりとして閑寂に静まり返っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ暗いところに、こっそり坐って、誰にも顔を見られない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、こっそりあなたの枕もとに置いといたの。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
