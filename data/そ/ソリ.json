[
  {
    "uuid": "ac8e5cee-3fb4-5690-8ca2-ed3cc6336168",
    "entry": "反り",
    "reading": {
      "primary": "そり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
