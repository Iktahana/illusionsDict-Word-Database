      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "imitated cry (of an animal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さては空音ではないらしい。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下戸塚を二軒訊ねて、それから戸山ヶ原を横切つて大久保へ渡つたが、そこで更に、彼は高円寺の先の何某といふ寺に移つたと聴かされた時には、私もがつかりして、耳の底に追ひ切れない彼の車のごろごろと鳴る轍の空音を感ずるばかりだつた。",
              "citation": {
                "source": "奇友往来",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この那美という女の姿は、短篇「琴の空音」の中の女主人公にも似ており、「虞美人草」の藤尾とも血脈をひいている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆には言葉はなくとも直観があつて、火薬のやうに火のつけられるのを待つてゐるが彼等一部の人間は内容が空虚で、たゞ論理と形式の空音ばかりしかもつてゐない。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春院いたずらに更けて、花影欄にたけなわなるを、遅日早く尽きんとする風情と見て、琴を抱いて恨み顔なるは、嫁ぎ後れたる世の常の女の習なるに、麈尾に払う折々の空音に、琵琶らしき響を琴柱に聴いて、本来ならぬ音色を興あり気に楽しむはいよいよ不思議である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "作曲云々のことで言ひ遁れはしたくないのですが、音樂といふものの内の方にはたくさんの女のうつくしさが平常はただの空音となつてゐて、それを動かす作曲者の手によるとそれらは美事な肉體となつて現はれてくることもあるのです。",
              "citation": {
                "source": "帆の世界",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは席を変える、伊東から戻ったらまいれ、誓紙を待っているぞ」琴の空音　伊東新左衛門が危篤だと聞いたとき、甲斐は的場で、式部（宗倫）と弓を引いていた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、ありえぬ空音のように聞えたのである。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "落日と共にあらゆる虚空音も雲の果てに吸い込まれたような一ときだった。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらね、あれだから。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらね、こんなふうに。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、こいつだ、そらね。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いいえ、少しね、心当りな事があるもんだから、そらね。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらね、聞こえるでしょ。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白くもねえ」「そらね、二人が心中したというと直ぐ怒る」「てめえこそもすのこととなると嫌にしつこいじゃねえか。",
              "citation": {
                "source": "舞馬",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――これは、そらね、これをこう折ッて、ここをこうすると、そうら、一つの鶴が出来ますよ、そら今出来ますよ、そうら出来た」　娘は鶴を折るとそれから舟、香箱、菊皿、三方などを折ッてくれた。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木偶が踊つてゐようが、雲霧が轉じてゐようが、將又かのピヤノの上に蹲つた猫がそらねぶりをしてゐようが、そんなことには一切お構ひなしであらう。",
              "citation": {
                "source": "虚妄と眞實",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、さうぢやないつていふことになると、そらね、今まで大きな顔をしてたのが可笑しくなるだらう。",
              "citation": {
                "source": "留守（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらね……（ピストルを出して見せる）シャルロッタ　やっと済んだ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そらね、こう、こうするものさ」と、カテリーナ・リヴォーヴナは囁きざま、情夫のからだをぎゅっと抱きしめて、情熱に身もだえしながら唇を押しつづけた。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そらね……」　彼は一枚のドアを開けた。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらね、いくらだって持たしてやるから、飽きるほど……」　兄貴のフェリックスがいう。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、やがて、にんじんは、駈け出しながら、うきうきと叫ぶ――「そらね、父さん、僕、もう蠅の音が聞こえなくなったよ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらね、先生だ」――わたしは言った。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫡子タルト庶子タルトヲ問ハス、生存セル丁年未満ノ七子ヲ有スル父及母ニシテ十フラン以下ノ人頭動産税ヲ課セラルルモノハ、此ノ課税ヲ免除セラルルモノトス』「そらね、なるほど、九フラン五十サンチームの税金を納めるので、つまり十フラン以下だ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、はっきりした声で、「そらね、あたしの、縁までいっぱいよ」――マリイが言う。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青ちやん、どうだい、そらね、お蜜柑出てこいぽんぽん、大きい兄ちやんはお団子が好きなんだね。",
              "citation": {
                "source": "打出の小槌",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "観察の下卑て皮肉なところから云っても、言動の無遠慮で、粗野なところから云っても」「そうしてそれが君の軽蔑に値する所以なんだ」「もちろんさ」「そらね。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらね、わたしがおまえを引き取ったのはずいぶんいいじょうだんであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上に美しい一輪の花と写真でもおいて、そらね、見ていらっしゃい、やっぱり私たちよく勉強しているでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
