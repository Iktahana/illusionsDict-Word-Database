          "literary": [
            {
              "text": "それ御覧なさいまし。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）それ御覧なさいましな。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんもやって来てこの有様を見ると、「それ御覧なさい。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、それ御覧なさい。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、あんたの言ったように、先生はずいぶん変っているわね」「だろう、それ御覧。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "判事気色打ち解けて書記を顧み、それ御覧世間の口は不実なものだ、被告も正直過ぎて人に悪まれると見えると言い、更に被告に向い汝はいまだ死犬のために祈祷せぬらしいからわれらと一緒に始めようじゃないかと言ったとある。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "四谷から病人の事でも何か云って来たのか」「それ御覧遊ばせ、そんなに御嬢様の事を心配していらっしゃる癖に」「何と云って来た。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは心配して来たに相違ないさ」「それ御覧遊ばせ、やっぱり虫が知らせるので御座います」「婆さん虫が知らせるなんて事が本当にあるものかな、御前そんな経験をした事があるのかい」「あるだんじゃ御座いません。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一間に合わぬ事があったら、それはお前が女に生れた不肖だと、諦めてくれるより外ない」「それ御覧遊ばせ。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は少し微笑をして、「それ御覧なさいませ。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それ御覧なさい、阿母さん！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ御覧なさい、お前さま、まだ馬車の支度は出来てやしませんに。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人は私の方を信じて「それ御覧、間違ってるだろう」と看護婦に言います。",
              "citation": {
                "source": "臨終まで",
                "author": "梶井久",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、いわないけど……」「それ御覧、大丈夫だよ、それで勘三叔父さんは、啓ちゃんと仲良しだものねえ」　体操の組では綱引きが始まった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "序だから、みんな打ち散けて御しまいなさい」「そりゃ、或点では馬鹿にしない事もない」「それ御覧なさい。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、それ御覧、言いあてたろう。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだったら、私もタダだったわ」「それ御覧なさい。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンリエツトの声　　それ御覧なさい。",
              "citation": {
                "source": "落葉日記（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈緒子　　それ御覧なさい。",
              "citation": {
                "source": "ヂアロオグ・プランタニエ（対話）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あや子　　それ御覧なさい。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ御覧なさい、震えてるじゃないの。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進は鶴子が洋行する胸中を推察して今更引留めても既におそいと思ったので、未練らしい様子を見せて、「それ御覧なさい。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "とね　　それ御覧なさい。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬい子　　それ御覧なさい。",
              "citation": {
                "source": "昨今横浜異聞（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "町子　　それ御覧なさい。",
              "citation": {
                "source": "ママ先生とその夫",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻　　（惶てて夫の肩より離れ）それ御覧なさい、また遅れたわ。",
              "citation": {
                "source": "ぶらんこ（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　　それ御覧なさい。",
              "citation": {
                "source": "恋愛恐怖病（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマノ　　それ御覧なさい……。",
              "citation": {
                "source": "チロルの秋（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好夫人　　それ御覧なさい。",
              "citation": {
                "source": "写真（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中　　（かすかに首を振る）三好夫人　　（ここぞとばかり）それ御覧なさい。",
              "citation": {
                "source": "写真（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
