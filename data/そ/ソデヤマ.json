    "definitions": [
      {
        "index": 1,
        "gloss": "top crease of a sleeve (of traditional Japanese clothing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "着付けの先生は、着物の袖山を綺麗に整えることの重要性を説いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞妓さんの着物の袖山は、優雅な曲線を描いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い着物を手入れする際、袖山の縫い目を丁寧に確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "火事場頭巾のような風変りの頭巾、縞の筒袖山袴、手に小鎌を持っている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いところでは、袖山富吉さん・小池元男さん・小林謹一さん・向山武男さん・岡本佐※雄さん等の講演のうとも、貸して貰うた。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
