        "examples": {
          "standard": [
            {
              "text": "銀座にあるこの店舗は、世界展開している有名アパレルブランドの総本店だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日のご飯はどこに行く？」「せっかくだから、近くの老舗寿司屋の総本店に行ってみようよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "総本店では他店にはない限定商品が販売されており、連日行列が絶えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大阪の住友総本店では今年も例のやうに五六人手に入れたが、それが揃ひも揃つて、擬ひつ気なしの東京大学製だつたのは重役の身にとつて嬉しい事の一つだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一空さまが、通新石町から馬鞍横町へ折れて、小柳町、鍋町東横丁と過ぎて不動新道へはいると、和泉屋の総本店はすぐ眼についた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
