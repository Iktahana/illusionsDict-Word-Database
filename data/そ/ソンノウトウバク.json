    "definitions": [
      {
        "index": 1,
        "gloss": "reverence for the emperor and the overthrow of the shogunate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
