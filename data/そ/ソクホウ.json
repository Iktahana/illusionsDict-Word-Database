[
  {
    "uuid": "50aacb6d-99ba-5bc7-b7e7-8c13d871106f",
    "entry": "速報",
    "reading": {
      "primary": "そくほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
