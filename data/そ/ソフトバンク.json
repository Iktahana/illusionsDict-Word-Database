    "definitions": [
      {
        "index": 1,
        "gloss": "SoftBank (Japanese telecommunications company)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ＤＴＰは本作りの専門家だけの技術なのか　一九八七年の夏、私はソフトバンクが創刊する、『ザ・コンピュータ』という雑誌の編集作業に関わっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書はソフトバンク刊の『パソコン・マガジン』に「インサイドウォッチャー」と題して連載した時評コラムを、まとめ直したものだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで「何とかこいつを復活できないか」とあがいているところを、ソフトバンクの稲葉俊夫さんに救われた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフトバンクから出していただいた単行本「電脳王日電の行方」で、薬でもやったんじゃねえかと疑われるほどＷｉｎｄｏｗｓを持ち上げた小生としては、「トッテン師匠に座布団一枚」で今回はここまで。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど人間は本来、二十四時間机にへばりついているソフトバンクの編集者のような存在ではない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念ながらソフトバンクは、思い付きの文句に対価を支払うほど文化コンプレックスに犯された会社ではない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぽう新しい会社でコンピューター物など出しているところ、つまりいかにもＤＴＰをやりそうなところ（ソフトバンクなどその典型ね）は、そんなルールは一切無視である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんソフトバンクの中にも経験と伝統的美意識を持った編集者がいないわけではない（はずだ、多分）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこの種のユーティリティは、ＭＳ―ＤＯＳに対応したものがアスキーやソフトバンク方面で使われている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この締め切り違反の連続の中で、妥協なく注文を付け、しかも辛抱強く励まし続けてくれたのは、ソフトバンク書籍編集部の沖山克弘さんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★『ザ・コンピュータ』（ソフトバンク）一九九〇年六月号、「ＫＥＹＭＡＮ ＵＳＡ　次世代のコンセプターが考えている明日」所収のアラン・ケイへのインタビュー。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★『パソコンビジネスの巨星たち』（ティム・スキャネル著、日暮雅通訳、ソフトバンク、一九九一年）所収、第一七章ＨＰの項。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同書はソフトバンクが刊行していた『ザ・コンピュータ』誌の連載企画、「ＫＥＹＭＡＮ ＵＳＡ」をもとにしている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ソフトバンクの松田辰夫は、ベーシックの現実とＯＳの理想を、古川とは対照的な角度から見ていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッケージソフトの流通卸として設立された日本ソフトバンクに籍を置く松田には、理想や夢や期待を削ぎ落とした日本の市場の実体が、ありのままに見えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八一（昭和五十六）年九月、孫は日本ソフトバンクを設立し、松田はコンサルタントとして同社のビジネスにかかわることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ビットのゲームソフトの伸びに支えられて日本ソフトバンクは急成長を遂げていったが、松田も孫も、ビジネス分野こそがパーソナルコンピューターの拡大に決定的な弾みをつけると信じていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初は社外にあった松田も、会社設立の翌年にはソフトバンクに籍を置いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "話題を集めがちな日本語ワードプロセッサーにしても、首都圏でごく一部売れているにすぎないという事実に、松田は日本ソフトバンクの日々の業務を通じて向き合っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術室長という肩書きで、ソフトバンクのすべての雑誌を技術面から統括していた松田は、『Ｏｈ！",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ』編集部はフロッピーディスクに収めたフライトシミュレータをソフトバンク系列のショップに流しはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★ジャストシステムの誕生から一太郎の開発にいたる経緯は、『パソコンウォーズ』（田原総一朗著、富田倫生構成、日本ソフトバンク出版事業部、一九八八年）「第八章　パソコンを大人の道具に変えた、ジャストシステム一太郎誕生物語」に詳しい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフトウエア卸のソフトバンクがこの時期、各社の製品を平等に扱う中立主義からこれぞと狙いを定めた製品への重点化に方針を変更しようとしていたことは、ｊＸ―ＷＯＲＤ太郎にとって追い風として機能した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプリケーションの中心がゲームからビジネスへと移行していく中で、現場の担当者が高価な業務用ソフトを売るために必要な商品知識をあらゆる製品に関して持つことは、不可能だろうとソフトバンクは考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
