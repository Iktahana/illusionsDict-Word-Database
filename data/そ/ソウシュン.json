        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ことしの早春に、私はこの甘酒屋で異様な男を見た。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の淡紫に湿つた土の上で、独楽はチリチリヽヽといふ微かな音を立ててシンミリ廻つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺骨を拾う人と対照して、早春の淡い哀傷がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅｜遠近南すべく北すべく「遠近」という語によって、早春まだ浅く、冬の余寒が去らない日和を聯想させる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "莟みの集団の下から、房になった黄色い四弁花が、いま電燈の蒼い光にきらびやかに匂っている、茎は一皮下には、青い血が通っているのではないかと思われるほど透き通って、有らゆる春の緑の中で、最も練り抜かれた緑である、見つめていると、早春の名残といったような淡い哀愁に加えて、物の末期の惨酷を思わせる姿である。",
              "citation": {
                "source": "菜の花",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の蜜蜂　（尾崎一雄氏）　全篇清新な筆觸で書かれてゐる。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春黒雲峡を乱れ飛び　　技師ら亜炭の火に寄りぬげにもひとびと祟むるは　　青き Gossan 銅の脈わが索むるはまことのことば雨の中なる真言なり　　来々軒浙江の林光文は、　　　　　　かゞやかにまなこ瞠き、そが弟子の足をゆびさし、　　凛としてみじろぎもせず。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "峡野早春夜見来の川のくらくして、　　斑雪しづかにけむりだつ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬から早春にかけて、人は一度ならずそんな蠅を見たにちがいない。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ある日、空は早春を告げ知らせるような大雪を降らした。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子戸越の早春の朝の陽差しを眩しい眼ざしで防ぎながら海を眺めていました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある早春の晴れた昼である。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の芽と太陽とは惜気もなく早春の彩光を撒き散らして時間はまたたく間に経つ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の日向に床をひかせて起上り、食べ度いと思うものをあれやこれや食べながら、くめ子に向って生涯に珍らしく親身な調子で言った。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一年｜経って、昭和十八年の早春に、アス五ジ　ウエノツクという君からの電報を受け取った。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他にも、私には三つ、四つ、そういう未発表のままの、謂わば筐底深く秘めたる作品があったので、おととしの早春、それらを一纏めにして、いきなり単行本として出版したのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか早春の夜と記憶するが、私が古谷君の宅へ遊びに行ったら古谷君は、「君、酒を飲むんだろう？",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは初冬ながら、もはや早春が訪れでもしたような爽かさであった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに料理は最高の芸術だといえる性質があるのだ」　お絹は屑箱の中からまだ覗いているアンディーヴの早春の色を見遣りながら「鼈四郎の意地悪る」　と口惜しそうにいった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年の早春、葉子は、一寸した病後の気持で、熱海の梅林が見度くなり、良人と、新橋駅から汽車に乗った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車から降りてはっきりした早春の外光の中に立った氏の姿を葉子は更に傷ましく見た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ氏と最後に逢った早春白梅の咲く頃ともなれば……そしてまた年毎に七八月の鎌倉を想い追懐の念を増すばかりである。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの早春に、私はこの甘酒屋で異樣な男を見た。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちどは二十五歳の早春。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春のころに、私はここで、しばらく仕事をしていたことがある。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみの自殺から、ひと月くらい経って、早春の或る宵に、笠井氏は、あの夜以来はじめて、トヨ公の屋台に、れいの如く泥酔してあらわれました。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐伯五一郎の友人として、きょうは佐伯が病気ゆえ、代りに僕が参りましたと挨拶して、「早春の北海道」というその愚にもつかぬ映画を面白おかしく説明しなければならなくなった。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の或る日、黄村先生はれいのハンチング（ばかに派手な格子縞のハンチングであるが、先生には少しも似合わない。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春の夜の事でありました。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村先生の戸籍名は河内山そうしゅんというのだ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
