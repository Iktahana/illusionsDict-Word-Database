[
  {
    "uuid": "ca3b412a-581f-5169-a2cb-43f44f743e09",
    "entry": "相対性",
    "reading": {
      "primary": "そうたいせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
