        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「奈良丸を千円で三日買うて来て、千円上つて、損得なしの元々やつたのが、福造の興行物の一番上出来やつたんやないか。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奈良丸を千圓で三日買うて來て、千圓上つて、損得なしの元々やつたのが、福造の興行物の一番上出來やつたんやないか。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻煙草の長い喫ひさしでも拾や、損得なしだ。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君も君のおのろけを云えば、それで差引損得なしじゃないか」などと自分を冷かした。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸のうちで、期待しているようなはなしでなくても、損得なしに、どんなことでも――と誠意を見せて、彼も膝を改めた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
