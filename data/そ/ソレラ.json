    "definitions": [
      {
        "index": 1,
        "gloss": "those",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夢のうちなる遠近法、夏の夜風の小鎚の重量、それ等は既になし。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともそれ等の事情の取合せに因つてであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等諸特質が彼女の詩をなすものであつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等のみんなが、意識によつて幸福であり、意識によつて不幸なのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて近代の諸主義が生れるのであるが、要するにそれ等の数々は、要するに根柢に於て一括されるかと思ふ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等さへまた倦怠に入りつゝある昨今、芸術界が経済学だの歴史だのといふことを気にしはじめてゐることは、随分ありさうなことで、そして同情さるべき事情である。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の者が、彼が渡り廊下に掛かるや「頼むぞ」といふ眼差を一斉にさし向けた時に、彼の頭の中では「よろしい！",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面の窓から差込む朝日が、それ等の机の上の硝子で出来た印肉皿や、罫紙の上を薄く班らに流れてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞は眩しいほど、それ等の事を並べたてた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長、機関長、を初めとして、水夫長、火夫長、から、便所掃除人、｜石炭運び、に至るまで、彼女はその最後の活動を試みるためには、外の船と同様にそれ等の役者を、必要とするのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の可也に不規則な平面的分布が透視法といふ原理に統一されて、其處に美しい幾何學的の整合を示して居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は山々を愛するがゆえに、それ等の山々の美醜長短を、人間の性格才能のように感じ取った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがいま、模索した程度に過ぎないものの、福慈岳の存在に出遇ってみると、それ等のものは一時にけし飛び、自分なるものを穴に横匍う蘆間の蟹のように畸形にも卑小に、また、経めぐって来た永い歳月を元へ投げ戻されてただ無力の一｜孩児とにしか感じられない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の山には背があれば必ず山隈や谷があった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等はみなわたくしを母のようにしております。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山寄りの道を行く方が山の岳神を探すに便利は多いようなものの、それ等の山は多く未開の山で、ちょっと人に訊いただけでも、山の主は、百足であるとか、猿であるとか、鷲であるとか、気の利いた山の神ではなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子夫妻が父の祖神の翁に顔を合すとき、大体話は山の生産の模様、山民の生活の状況、それ等を統ねて行く岳神としての支配の有様、そのようなものであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の山や岳神を詮議して、とかくそれ等に不足を見付け出した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野に雲の海があるとき、霞棚引けるとき、それ等を敷莚にして、幽婉な寝姿が影となって望まれる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の空骸に向って女神は、涙をぽたぽた垂しながら、撫でさすり「可哀相に、いのちの愛までは届かぬ方」というというが、誰もその意味を汲取ったものはない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の人の中には思いがけない素人や芸人もあった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は、好きな道を役立てて歌舞伎の小道具方の相談相手になり、デパートの飾人形の衣裳を考証してやったり、それ等から得る多少の報酬で学費を補っていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煎じ詰めた、而も、たまらなく美感と滋味のこもった言葉が小癪なほど豊富に飛び出し、而もそれ等が一つ残らず（画面）の底にとけて流れて行く。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆や鉛筆でもつて抱擁し、愛撫し、手ばなさぬやうにする、さういふ愛の絆によつてのみ、それ等のデッサンや繪は價値があるやうに思へる、とあなたは仰言られて居ましたけれど。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の上に小さな木札をひつかける、と、もうそれを引つ込めません。",
              "citation": {
                "source": "夢",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃、大きな、心臟をしめつけるやうな驚きが、私を掴へてゐたのと同樣に、巴里でもまた私は、それ等の何とも言ひやうのない混沌が人生と呼ばしめてゐるかのごとき、あらゆるものに對する恐怖に捕へられてゐたのでした。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はそれ等を藏つて置かう。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして本の新鮮なのや褪色した黄色、裝幀本の菫がかつた褐色、それからアルバムの幅の廣い緑色など、それ等すべてのものが調和し、效果を上げ、それぞれの役割をしつつ、何一つ缺くるところのない全體を形づくつてゐるのだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さみだれの季節になると子供は都会の中の丘と谷合にそれ等の実の在所をそれらを啄みに来る烏のようによく知っていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の人間が急行列車桜、高速力巡航船、ホテル、トーキー常設館、オフィス、レストラン、冬期競馬場、少女歌劇場、それらの場所にいたあらゆる階級人が、驚愕するような事件が勃起した。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
