        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おのが心も魂も、忘れはて棄て去りて悪酔の、狂ひ心地に美を索むわが世のさまのかなしさや、おのが心におのがじし湧きくるおもひもたずして、人に勝らん心のみいそがはしき熱を病む風景ばかりかなしきはなし。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "下部いそがはしく燭をみぎひだりに立つれば、メエルハイムは「いづれの譜をかまゐらすべき、」と楽器のかたはらなる小卓にあゆみ寄らむとせしに、イイダ姫「否、譜なくても」とて、おもむろに下す指尖木端に触れて起すや金石の響。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だんな、くそがはねますよ、すこしどうかこっちへきてください」　そういう兼吉は、もはや飼い葉をすませて、おぼれ板の掃除にかかったのだ。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "※秧いそがはしき頃なれば、舟の往來、殊にしげし。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "近藤君は、漢洋の學に通明におはするものから、その教授のいそがはしきいとまに、かゝる著作ありつるは、敬服すべきことなり。",
              "citation": {
                "source": "ことばのうみのおくがき",
                "author": "大槻文彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みみずの脳には少ししか脳みそがはいっていない」「それはデマ（うそっぱち）だ※」と言いたいのだが残念ながら本当だ。",
              "citation": {
                "source": "みみず先生の歌",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達は顔を見合はす、僕達は探り合ふ、そして僕達は、今僕達が純粋な真実ばかり述べ合つたことを相手の心へ押し付けやうと試みる、僕達はいそがはしく深い満足の笑ひ顔をつくり出すのだ。",
              "citation": {
                "source": "海の霧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥なる木母寺の鉦鼓に日は暮れ、真崎稲荷の赤き祠に降る雪の美し（下巻第六図）と見る間もなく、神明の社に来れば（下巻第七図）烏帽子の神主三人早くも紅梅の咲匂へる鳥居に梯子をかけ注連飾にいそがはし。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋後の水田を望むに農婦三※秧にいそがはし。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日全集の校正にいそがはし。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "近鄰いづこも洗濯にいそがはしく、水汲みては流す音止む時なく、安石鹸の悪臭あたりに漲りわたりて胸わろし。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日全集の校正にいそがはし。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "師はいそがはしく凌雲院を出で三枚橋の傍に至りし時、左右の小路より人数多く出来り尋問ふべき仔細あり町奉行所へ参り候へとて引連れて候と告ぐ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田にかひ出しす、明日は二の酉なれば店の用事いそがはし。",
              "citation": {
                "source": "「樋口一葉全集第二卷」後記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
