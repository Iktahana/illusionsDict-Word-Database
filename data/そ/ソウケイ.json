[
  {
    "uuid": "3cd33d84-45cc-51c6-aa02-92e90f6fc63e",
    "entry": "早計",
    "reading": {
      "primary": "そうけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
