    "definitions": [
      {
        "index": 1,
        "gloss": "to treat shabbily",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
