[
  {
    "uuid": "4d163f6f-f0a1-52f4-b2c2-2a2c933aa30e",
    "entry": "僧衆",
    "reading": {
      "primary": "そうしゅう",
      "alternatives": [
        "そうしゅ"
      ],
      "is_heteronym": false
    },
    "grammar": {
