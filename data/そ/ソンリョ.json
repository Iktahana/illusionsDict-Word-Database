        "examples": {
          "standard": [
            {
              "text": "この件につきましては、何卒ご尊慮を賜りたく、お願い申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の提案は素晴らしいものだったが、最終的には社長のご尊慮によって決定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ご尊慮を拝察し、私ども一同、精一杯努力する所存でございます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「嘉平は二十五歳にして薩摩守樣の召すところとなり、當時齊彬公樣は歐文書類を版本としてあまねく御藩中に學ばしめんとの御尊慮によつてひそかに嘉平に御洩談あらせらる――」。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            }
          ]
