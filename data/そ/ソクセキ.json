    "definitions": [
      {
        "index": 1,
        "gloss": "impromptu",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "即席の手真似だが、娘には通じたのか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言われて見ると成程又そうでもあると、其晩即席に自説を撤回して、又文学者になる事に一決した。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "根のいいロシヤ人の即席似顔画描きが、隣のキャフェ・ル・ドームを流した後らしく、入って来て、客の気分を見計いながら、鉛筆の先と愛想笑いで頼み手を誘惑しているが、誰も相手にしない。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヤの肩に手を置いて、やつと半分くらゐ渡りかけて、あとは川も浅いので、即席の橋から川へ飛び降りて、じやぶじやぶと水の中を歩いて渡つてしまつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お笑ひ草ついでに、今の懷を即席の詩に述べて見ようか。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お笑い草ついでに、今の懐を即席の詩に述べて見ようか。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨宮傭蔵君の為めに画帖に即席に写したことはあるが、本の表紙の為めに画かうと思つたことは嘗て無かつた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイパーカードに文章を流し込んで作った即席の電子本が、計画に本腰を入れるきっかけでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君、露悪家という言葉を聞いたことがありますか」「いいえ」「今ぼくが即席に作った言葉だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の両側には、「即席御料理」「きそば」と書いた暖簾の家が並んでいた。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は其頃兄に教はつて居た白文の八家文の難解の処を読み下し、又は即席に七｜絶を賦して、大いに二人を驚かした。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この牢に投ぜられたものは大概三日目には白痴になつてしまふのである――そんな即席のお伽噺を彼は、いつか子供に聞かせて、その先はまた出たら目に、こゝに投ぜられた一人の青年が如何してこの牢を破つたか？",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼び出されたら、父の顔色と相談の上、又何とか即席に返事を拵らえる心｜組であつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこここの救命艇のかげ、船艙の横が彼らにとって船上の即席らんで※うだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　私はじぶんが単なる即席の思いつきでこの個人的な会話を切り出したのではないという立場を守護するために、すこしばかり顔を赤くして粘着した。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームページから文章を横取りし、即席の電子本に仕立てる仕掛けを作ったのだ。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "持参の瓢酒で即席料理、魚が新鮮だから、非常に美味い。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを通奏低音期と呼んだのは通奏低音（一名数字附低音）と云う略譜を見て即席に和音的伴奏をつける事が行われた時代だからで、この命名はリーマンに従ったものである。",
              "citation": {
                "source": "総説　西洋音楽史の時代",
                "author": "乙骨三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはただ寝ころんで、空を眺め、海を眺め、煙草をふかし、雑談にふけり、鳥か魚かを珍らしがり、手で弄び、或は即席に料理して酒の肴にするのもよい。",
              "citation": {
                "source": "女人禁制",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が愚図々々云うなら即席に叩倒して先生の処に引摺て行て遣ろうと思ったその決心が顔色に顕れて怖かったのか何か知らぬが、お前はどうもせずに引込んで仕舞た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "待て／＼、塾中に誰か江戸に行きたいと云う者はないか、江戸に行きたければ連れて行くが如何だ、実は斯う云う訳けで金はあるぞと云うと、即席にどうぞ連れて行て呉れと云たが岡本周吉、即ち古川節蔵である（広島の人）。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "――寄席の舞台で、即席記憶の実演をやってみせる者が、以前はよくあった。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹と樹のあいだに菰を張った即席の屋根から、溜った雨水がごぼりと落ちた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も教師以外に何をしやうと云ふあてもなかつたから、此相談を受けた時、行きませうと即席に返事をした。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シヤツから話があつた時、断然断はるか、一応考へて見ますと逃げればいゝのに、あの弁舌に胡魔化されて、即席に許諾したものだから、あとから御母さんが泣きついても、自分が談判に行つても役に立たなかつたと非常に残念がつた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼び出されたら、父の顔色と相談の上、又何とか即席に返事を拵らえる心組であった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君、露悪家といふ言葉を聞いた事がありますか」「いゝえ」「今僕が即席に作つた言葉だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも教師以外に何をしようと云うあてもなかったから、この相談を受けた時、行きましょうと即席に返事をした。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれなら即席に寄宿生をことごとく退校してしまう。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
