[
  {
    "uuid": "97436f93-b622-5065-9b4f-cf0260fd5744",
    "entry": "僧服",
    "reading": {
      "primary": "そうふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "priest's garb",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "瞳｜据ゑつつ身動かず、長き僧服爛壊する暗紅色のにほひしてただ暮れなやむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴は黒い僧服をまとって、堂々とこの船に乗りこんだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴は黒い僧服をまとって乗り込み、箱のなかにじゅうぶんな金を入れてて、それで竜骨から大檣までまるごと買収できる。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "物貰ひかなんどのきたない僧服の老人を想像しながら私は玄關に出て行つた、一言で斷つてやらう積りで。",
              "citation": {
                "source": "樹木とその葉",
                "author": "青年僧と叡山の老爺",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時たちまち故郷を懐うて死ぬべく覚えたので、王宮を脱走してアラビヤに帰り、名を変じ僧服し徒歩｜艱苦してカウカバン市に近づき還った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだに、下のかたよりホルトガルの宣教師モウロ、四十余歳、旧教の僧服をつけ、頚に十字架かけて出で来り、柳の木かげに身をよせて窺いいると、おいよはやがて合掌して川へ飛び込もうとする。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "物貰いかなんどのきたない僧服の老人を想像しながら私は玄関に出て行った、一言で断ってやろう積りで。",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "薔薇の花のまだ萎れぬ間を、白砂を敷きつめた径が方形に通っていて、僧服を着た宣教師の静に歩くひまにも、ばさりばさりと響く音は、大理石の面から辷り落ちて来る玉虫の甲の音である。",
              "citation": {
                "source": "静安寺の碑文",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が思わず鼻を覆ったら、車の主の、焦茶色の僧服みたいなものを着た、ベトウヴェンのような顔の老人がひどく私に make-face のして行った。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧服を捨て、僕が残していった学生服に着かえ危地を脱走した。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "七僧の法服をはじめとして、以下の僧へ等差をつけて纏頭にする僧服類をことに精撰して夫人は作らせてあった。",
              "citation": {
                "source": "源氏物語",
                "author": "御法",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い僧服の下からきりりと締った白衣の裾の見える姿で悧発な眼鼻立ちも美しかったが、矢代への挨拶も固苦しく、押し黙ったままひょこりとお辞儀をするだけだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "先客は二人でいずれも僧服を纏っていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "むらがり立った緑樹の驟雨にうたれて雫する下に、黄色な僧服の隠見した島で、霽れ間に空に立のぼった夕茜のひとときの麗しさ、紫金色のむら雲舞い立つその凄じい見事さにあッと愕き仰ぐ幻に似た荘厳幽麗な天上の色、今も彼には忘れがたかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、紫の花のむらがつた畑の柵の中で、黒い僧服に、つばの広い帽子をかぶつた、南蛮の伊留満が、しきりに葉へついた虫をとつてゐる。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "修道院の僧服も軍隊の軍服もこれから来たものだ」と云うのを見る。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "傳へ曰ふ、ドミニクス未だ胎内にありし時、その母夢に一匹の小犬を生む、これに黒白の斑あり、口には燃ゆる炬火をくはへゐたりと（黒白の斑はドミニクス派の僧服を表はし、炬火は聖者の熱情をあらはす）六一―六三〔聖盤〕洗禮の水を容るゝ器。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "せまい俗家の区切りかたや、模様ある襖は、僧服の濃い色彩とひどく相殺する結果になり、ほの暗く、大きく、宏い寺院の本堂で見る美、宗教的優美が全然欠ける。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒衣の僧服に振分荷物を担いで杖をついてゐたが、荷物の中からウヰスキーの角瓶をとりだした。",
              "citation": {
                "source": "朴水の婚礼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は黒衣の僧服をきてポプラの並木をぶらついてゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い僧服をきて、僧院の階段を走り降りて現れてきましたね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……僧服の、釦は既に外されてゐた、多くの罪過を赦してくれた、その長々しい念珠をば心の裡にて爪繰りながら、聖タルチュッフは真ツ蒼になつた。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は黒い僧服のようなものを着て、白い首飾りをかけている。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも、彼女の蒼白い顔や黒い僧服を見てひどく感動していた。",
              "citation": {
                "source": "大ヴォローヂャと小ヴォローヂャ",
                "author": "ВОЛОДЯ　БОЛЬШОЙ　И　ВОЛОДЯ　МАЛЕНЬКИЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "河口氏はチベットの僧服を着し、純然たるチベットラマの風あり。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の僧侶は筒袖の着物を着ることを許されないけれども、警護僧は筒袖の僧服を着け、長い棒を持って居るです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "で私は法王の御装束　の御様子を見まするに通常の僧服とは違って居ります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は荷持を連れ僧服を着けてぼつぼつラサの町を出て、釈迦堂の少し前の所へ来ると気の知れぬ巡査　巡査が一人居りましてずかずかと私の前へ走って来まして、時が時ですから何か変な事でも発覚して捉えに来たのじゃないかと、ちょっと私も注意を惹き起したです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が始めてラサ府に着いた時は、正規の僧服でなくて旅服を着けて居たものですから、じきに巡査に銭をくれといってぐずられたから早速一タンガー遣りましたが、それで事が済んだです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ばかりたったとき、僧服のような黒いなりの男が素焼の骨壺に納められた子供の骨を捧げて現れた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
