        "examples": {
          "standard": [
            {
              "text": "登山家は、現在地の標高を測高器で確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "測高器は、気圧の変化を利用して高さを測定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "森林調査で、木の高さを測高器で測る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、今日ばかりは、そんな長閑な光景は見えず、貸し望遠鏡はどこかへ姿を隠し、その位置には代りあって、精巧を誇る測高器と対空射撃算定器とが、がっしりした三脚の上に支えられ、それからやや距ったところには、巨大な高射砲が金網を被り、夕暗が次第に濃くなってくる帝都の空の一角を睨んでいた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
