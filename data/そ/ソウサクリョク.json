[
  {
    "uuid": "851ef66e-d0f7-5655-9fcf-4ddc4f3dabdd",
    "entry": "創作力",
    "reading": {
      "primary": "そうさくりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
