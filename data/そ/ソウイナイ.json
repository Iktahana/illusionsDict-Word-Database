[
  {
    "uuid": "e1d1ccbf-d0fc-51fe-ba0a-f30f68e5c8ab",
    "entry": "相違ない",
    "reading": {
      "primary": "そういない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
