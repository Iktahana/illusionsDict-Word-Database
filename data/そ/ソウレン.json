[
  {
    "uuid": "fe4896b6-9163-5bc4-acb9-a232aced198c",
    "entry": "操練",
    "reading": {
      "primary": "そうれん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drill (esp. military)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "平素｜端艇操練を行う場合には、予めお知らせ致します。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "過酷な自己犠牲や、没我的美的陶酔や、世相的卑近感や、又倫常の線を逸する心中もののようなものがあっても、全体としては人間の、人間らしき感情の操練として、いささかも頽廃、麻痺、歪曲したところがなく、まっすぐな、健やかな、浪曼的精神の基調に立っているものだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば私の恋愛の感情の操練がこうした少女達との交友とすさびの間に行われていったのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女はその感情を操練しつつ成長して行かねばならぬ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日同じやうにしなくてはならぬ操練に飽きてゐるので、こんなことも楽みになるのである。",
              "citation": {
                "source": "猿",
                "author": "AFFENPSYCHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "築地海軍操練所で算数の学を修め、次で塾の教員の列に加わった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め麹町八丁目の鳥羽藩主稲垣対馬守｜長和の邸内にあったのが、中ごろ築地海軍操練所内に移るに及んで、始めて攻玉塾と称し、次で芝神明町の商船黌と、芝新銭座の陸地測量習練所とに分離し、二者の総称が攻玉社となり、明治十九年に至るまで、近藤自らこれを経営していたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "石亀村に於て大操練御覧有之。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵制で申せば西洋流の操練を採用したことがある。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "海陸軍の医士、法学士、または会計官が、戦士を指揮して操練せしめ、または戦場の時機進退を令するの難きは、人皆これを知りながら、政治の事務家が教育の法方を議し、その書籍を撰定し、または教場の時間、生徒の進退を指令するの難きを知らざる者あらんや。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれはインテリゼンスの階層である読書青年が今その旺盛な知識欲をもって、その知的胃腑を満たし、また思考力を操練せねばならないとき、知性の拡充よりもその揚棄を先きに説かんと欲するものではない。",
              "citation": {
                "source": "学生と読書",
                "author": "――いかに書を読むべきか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい彼らにとって当面には、そして現実身辺には、合理的知性の操練と、科学知の蓄積とが適当で、かつユースフルであろうとも、彼らの宇宙的存在と、霊的の身分に関しては、彼らが本来合理的平民の子ではなくして、神秘的の神の胤であることを耳に吹きこんでおきたいのである。",
              "citation": {
                "source": "学生と読書",
                "author": "――いかに書を読むべきか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が子供を抱いて行こうとすると、門の左の所には妻が立っていて、腰骨を真直ぐにして両手を腰に置き、怒気憤々としてさながら体操の操練でも始めそうな勢。",
              "citation": {
                "source": "幸福な家庭",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幼少より老大に至るまで、武芸に従事したるはこれ今日の常備兵が操練演習に従事するものなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス伝習の陸軍所が建設せられ、御軍艦操練所は海軍所と改められ、英仏学伝習所が横浜に開かれたのも、その結果だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "中濱萬次郎は漂民として嘉永三年日本へ歸着、後二年間は自由の身ではなかつたが、安政の開港以後その語學と海外知識を買はれて後幕府の軍艦操練所教授となつた人で有名である。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　御軍艦操練所に寄った肴店のとある露地、一軒の前まで来ると、甚右衛門は動かない。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、ただいま御操練の最中でいらっしゃるかも知れぬ、一応御様子を伺って来るからお待ち召されよ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "航海測量練習所と称した芝新銭座の攻玉舎は、勝海舟などの育成していた幕府海軍操練所の遺産といっていいようなもので、初めは近藤塾と共に、鳥羽藩の邸内にあったのを、後に、芝新銭座に移し、やがてこれが海軍兵学校の嚆矢をなしたものである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりものじゃ、ゆうて、おまえを、しんようしていても、そうそう、おとこさんのなまえがちごうては、わしもくるしいけに、さっち五円おくってくれとあったが、ばばさがしんで、そうれんもだされんのを、しってであろう。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
