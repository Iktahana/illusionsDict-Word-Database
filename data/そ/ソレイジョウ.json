[
  {
    "uuid": "1692fcec-4e9d-51fc-845d-2d0ac4ac8997",
    "entry": "それ以上",
    "reading": {
      "primary": "それいじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
