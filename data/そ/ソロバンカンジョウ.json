        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "どんなビジネスでも、正確なそろばん勘定が成功の鍵となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は常に冷静なそろばん勘定に基づいて行動を決める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この計画は、そろばん勘定の結果、費用対効果が低いと判断された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
