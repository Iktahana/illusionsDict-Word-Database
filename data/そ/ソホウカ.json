    "definitions": [
      {
        "index": 1,
        "gloss": "wealthy person or family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "安都玉村の素封家、輿水善重氏の宅で小休みする。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も其の日は、午前の中、爪皮の高足駄、外套、雫の垂る蛇目傘、聞くも濡々としたありさまで、（まだ四十には間があるのに、壮くして世を辞した）香川と云ふ或素封家の婿であつた、此も一人の友人の、谷中天王寺に於ける其の葬を送つたのである。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の鏡子は土地の素封家の娘だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は同じ近郊の素封家の息子で、覇気のある青年だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ――学園の校長さんは地方の素封家出の文化人で、子供が多いところから一つ自分の手で思うような教育をしてみようと思い立ったのが始まりで、世間の子女たちも預る学校に発展さしたのですが、通って来る講師には著名の芸術家なども多く、男女共学なども行って一風変った学校でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めは見っともないというので川上のＦ――町の素封家のＯ――家に融通を頼んでいた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処には元の次郎兵衛の邸宅を思わすような、千頭という素封家の邸がある。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道度はその日も朝から水以外に何も口にしていないので、物をくれそうな素封家の家を物色して歩いた。",
              "citation": {
                "source": "黄金の枕",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お婆さんは、自分がこの老衰の床に就く一月ほど前、町の方へ嫁に行くことに話が纒まりかけていたお美代を、無理矢理に新田へ、土地の素封家だと言うことだけで、いろいろと口説き落とした自分であったことを、ぼんやり思い出した。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人達のチャセゴは、軒々を一軒ごとに廻るのではなく、部落内の、または隣部落の地主とか素封家とかの歳祝いの家を目がけて蝟集するのであった。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　吉田家は近郷一の素封家だった。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　森山は、世間の人達から、自分が素封家の道楽息子として育ち、その延長に過ぎない生活をしているように思われるのをひどく嫌がっていた。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて東牟婁郡高池町の素封家、佐藤長右衛門氏を訪ねた時、船を用意して古座川を上り、有名な一枚岩を見せられた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "知事令夫人も、名だたる素封家の奥さんたちもその集会には列席した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄鶴楼というはその頃区長をした小石川の素封家佐藤氏の邸で、氏の子息が硯友社員であった関係から借りたのである。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から三十年も前、或る懇意な田舎の素封家に所望されて名士の手紙を十数通与えたところが、一年ほど経って偶然その家を訪問した或る男から、私に宛てた紅葉の手紙が錦襴表装の軸となって床の間に掛けてあったと知らせて来た。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくその素封家から「紅葉先生と露伴先生のだけは早速表装しました、お庇で自慢の家宝が二幅｜出来えました、」と、慇懃な礼手紙が来た。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやうにして街に殘されたものは眞菰｜臭い瀦水に釣を好む樂隱居か、ただ金庫の前に居眠りをして一生を過ごすあの蒼白い素封家の John−John（良家の息子、やや馬鹿にしていふ言葉である。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやうにして街に殘されたものは眞菰｜臭い瀦水に釣を好む樂隱居か、ただ金庫の前に居眠りをして一生を過ごすあの蒼白い素封家の John‐John（良家の息子、やや馬鹿にしていふ言葉である。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の素封家などにはよくある事で、何も珍しい事のない単調な家庭では、腹立しくなるまで無理に客を引き留める、客を待遇さうとするよりは、寧ろそれによつて自分らの無聊を慰めようとする。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舍の素封家などにはよくある事で、何も珍しい事のない單調な家庭では、腹立しくなるまで無理に客を引き留める、客を待遇さうとするよりは、寧ろそれによつて自分らの無聊を慰めようとする。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸な畫工には、父も財産も無かつたが、郷里には素封家の一人に數へられる伯父と、小さいながら病院を開いてゐる姉婿とがあつた。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどう見ても弱冠の素封家の、あまやかされすぎた、給事らしい男であった。",
              "citation": {
                "source": "あいびき",
                "author": "イワン・ツルゲーネフ　Ivan Turgenev",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は村の素封家の一人息子と、貧乏な綿打屋の小町娘との恋物語に始まる。",
              "citation": {
                "source": "血の盃",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "素封家のこととて、結婚の準備は可なりに大袈裟なものであった。",
              "citation": {
                "source": "血の盃",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里の素封家である秋本は、トルストイやガンジーの崇拝者で、何か文学に関する著述もあったが、もともと歌人で、数ある葉子の歌をいつでも出版できるように整理してくれたのも彼であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　県の議員なんかをやってる素封家の子息である従兄はそう言って、顔を赤くしている新夫婦に目を丸くした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから東といえば、それが当然素封家の詩人秋本でなければならなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本氏が、急になくなられた許婚の愛人栄子さんと岳父の代人で結婚の盃をあげられた行為は、氏の年齢や学歴やその地方での素封家であるというような条件と対照して、私共の注意を一層呼び起したと思われます。",
              "citation": {
                "source": "私も一人の女として",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の男は田舎の素封家の主人、真中はワイフ、左は職業婦人。",
              "citation": {
                "source": "帝展を観ての感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
