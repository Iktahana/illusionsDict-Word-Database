  {
    "uuid": "aeb18af8-f4cc-532e-b606-e51d82830234",
    "entry": "宋儒",
    "reading": {
      "primary": "そうじゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
