[
  {
    "uuid": "e266328c-b8f4-5ede-942f-f9b0d34f1bd0",
    "entry": "訴訟",
    "reading": {
      "primary": "そしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
