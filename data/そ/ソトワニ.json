        "examples": {
          "standard": [
            {
              "text": "彼は歩くときに少し外鰐になる癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "外鰐で歩くと、足に負担がかかりやすいので注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バレエダンサーは、美しい姿勢を保つために外鰐にならないように訓練する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「まあ、こちらにおあがり」　ろくは、やっぱり何だか手間のかかる外鰐の歩きつきで、帳場の傍へ上った。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "云いつけ、誰かが引廻しさえすれば、彼女はその後にくっついて、のたのた外鰐の足どりで何でもした、泥仕事でも、台処でも、苦情などは些も感じないらしい。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
