[
  {
    "uuid": "ef256dae-2cea-58b1-b2b3-03ffed44f5d1",
    "entry": "僧形",
    "reading": {
      "primary": "そうぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the form of a Buddhist priest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――その軒の土間に、背後むきに蹲んだ僧形のものがある。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（定重は奧へゆかんとする時、奧より佐々木高綱は頭髻を切りたる有髮の僧形。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかとは思う……ことにその言った通り人恋しい折からなり、対手の僧形にも何分か気が許されて、（御坊、御坊。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などと生意気なこと言つて、煙草をふかし、そのうちに、友人は、ふと、「おや、あの僧形のものは、なんだね？",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど心の清い尼さんが僧形をした貪婪の惡魔の前にゐるかと思はれるのである。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧形に見えた有りたけの人数は、其も是も同じやうな案山子の数々。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟の合せ目から燃えるような緋無垢の肌着をちらと覗かせ、卵色の縮緬の着物に呉絽の羽織、雲斎織の袋足袋、大脇差、――ざっとこういう伊達な服装の不良紳士たちが沢山さまようという色町の通りに、僧形の二人がぶらぶら歩く姿は余程、異様なものであったろうと思います。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ流沙河で最も深い谷底で、上からの光もほとんど射して来ない有様ゆえ、悟浄も眼の慣れるまでは見定めにくかったが、やがて、薄暗い底の台の上に結跏趺坐したまま睡っている僧形がぼんやり目前に浮かび上がってきた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎馬の将軍というより、毛皮の外套の紳士というより、遠く消息の断えた人には、その僧形が尚お可懐い。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」どうも、そういう外道は、速かに疎遠して、僧形の餓鬼大将を迎えるに限る。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――其の軒の土間に、背後むきに蹲んだ僧形のものがある。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "都に上った厨子王は、僧形になっているので、東山の清水寺に泊った。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の祖母と相談をいたしましてお返辞をするといたしましょう」　こんなふうにてきぱき言う人が僧形の厳めしい人であるだけ、若い源氏には恥ずかしくて、望んでいることをなお続けて言うことができなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父の愛によく馴染んでいる姫君を入道は見て、「僧形の私が姫君のそばにいることは遠慮すべきだとこれまでも思いながら、片時だってお顔を見ねばいられなかった私は、これから先どうするつもりだろう」　と泣く。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『日吉社神道秘密記』に、〈大行事権現、僧形猿面、毘沙門弥行事、猿行事これに同じ、猿田彦大王、天上第一の智禅〉。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは家来の横井弥兵衛を呼んで、袈裟や法衣や珠数や蓮葉笠や、僧形に必要な品々を取り揃えてまいれと命じた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "故あつて髪をおろした貴人の若い僧形といつたところがある。",
              "citation": {
                "source": "秋草と虫の音",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、幾人もの人を殺しながら、たとい僧形の姿なりとも、自分が生き永らえているのが心苦しかった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れた法衣によって、僧形とは知れるものの、頭髪は長く伸びて皺だらけの額をおおっていた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「了海とやら、いかに僧形に身をやつすとも、よも忘れはいたすまい。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実之助は、市九郎と群衆とを等分に見ながら、「了海の僧形にめでてその願い許して取らそう。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば、左衛門、僧形に改めて、袈裟どのゝ菩提のため、諸國修業に出る前に、もう一度訪ねて來よう。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもなく、もしそれなる永守熊仲が、僧形の身をも顧みず殺生戒を犯したとしたら、その場に力をかして少年僧黙山のために、兄のかたきを報じてやろうと思いついたからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "わははは、身共はひとりで退屈致そうからな」　あい、とばかりに泣き濡れて、いと珍しい僧形の花嫁花聟が、恥じらわしげに寄り添いながら、横取りの三公の手引で渡し場目がけつつ闇の道をおりようとしたとき。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その僧形の人間は、僕の村はずれの小さい堂を守っている地蔵尼という尼僧らしく思われたのであった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧形になっている身で、人を殺すことはできない。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦、還俗した後、僧形になっている敵を討ってめでたく帰参しようというのか。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰参のときに、一旦、僧形になったいい訳が立つわけではない。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧形なれども子細はござらぬ。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "オンドリは、きょうは、失礼なふるまいをしないように、たいそうぎょうぎよくしていました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
