        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこへ持ってきて、高い炉口に上っている梯子は薄暗く、上にゃ職工が一人きゃいないで、こいつが小さい車を押してあっちへ行ったりこっちへ行ったりしている。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて、倍音以外にもう一つ、鐘鳴器の音に異常なものがあったからだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も我が米軍の警戒も、完全にやっているせいもあるが、そこへ持ってきて、此の海戦地点たるや日本の海岸を去る七百キロという近さじゃ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて、大あゆなるものが東京人士には珍しい。",
              "citation": {
                "source": "インチキ鮎",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて当の三遊派の家元で圓朝取り立ての師匠たる二代目圓生が、双手を挙げてその打倒論へと賛意を表した。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて、武士の生活にようやく落着きと余裕ができかけているから、ちょっぴり風流気もまじって、多勢集まって刀を捻くって、たがいに鑑定眼を誇りあうことが流行る。",
              "citation": {
                "source": "寛永相合傘",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて、若松屋惣七にも、何やかや用事ができてきて予定どおり二人の女のあとを追って旅に出るわけにはいかなくなったので、その旨をしたためた書状を持って、ただちに金剛寺坂から飛脚が飛んで、おせい様と歌子を追いかけた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて村方一同が命の綱と頼みまする荒地沼地開墾の新田に竿入れ仰せつけられる段おふれでごぜましたので、そうなればこのあたり百姓何千何万と申す者が、かつえて死なねばならぬ始末、それで私ども兄きなんど、この由御願い出て見ようでねえかと寄り寄り相談していたばっかりでごぜます。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて、私の女房は、彼女にして見れば無理もないことでしょうが、病気と称して一間にとじ籠ったきり、顔も見せないのです。",
              "citation": {
                "source": "覆面の舞踏者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて、貴さまたちの醜い冷酷な根性を見せつけられては、なおさら、嫌になってしまった」手がつけられない怒り方である。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて、毎日の稼ぎ以上に、おめえは大酒を食らっているじゃねえか。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきてのこの話でさ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持ってきて、このとき、官船の横ッ腹へどんとぶつかって来た小舟がある。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、船一艘でマンマと何拾万円が手に入る蟹工船、――彼等の夢中になるのは無理がない。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、戦争後の不景気だ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、このような裏切的な行為だ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて清川と熱田とかはモットそれを分らなくするために努力しているのだから、益々むずかしい。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり太陽の黒点が急に増えたとか、そこへもってきて、噴火の煙で、太陽が遮られて、気温が下るとか……」「そうです。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、あまりに唐突な終局なんだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、彼女と平賀との一件だ。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきてかならずエロ、グロな話が出る。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、うわての善良さが現われて来た。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、松本が、どういうつもりか、おかしいことを言い出しました。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに俺等が献納した愛国号も百台ほどあるしサ、そこへもってきて、日本の軍人は強いぞ、天子様のいらっしゃるこの東京へなんぞ、一歩だって敵の飛行機を近付けるものか。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先の連合に嫁いたのだって、傍の者や、向うがヤイヤイ言ってくるし、そこへもってきて、自分は、もう、あんな女房を取るとすぐ女房に巻れて、妹を袖にするような、あんな兄の世話には一生ならぬ。",
              "citation": {
                "source": "雪の日",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、氷上においてあった地底戦車が、紛失してしまった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、折悪しく暮方になりました。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、正確な小作米、畑年貢などが予期されないとすれば、信用組合、銀行、無尽会社への利払いでさえ容易のことではない。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて、一方からは神社修復の割当寄付だ、特別税戸数割だ、村農会費の追徴だとはてしがなく、しかもそれらは親父の代と比較すると倍に近い数字をもって現れてくるのである。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもってきて後年のように石炭供給所が到るところにあったわけでないから、いよいよもって尨大な炭庫を必要とした。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
