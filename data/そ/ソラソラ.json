        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……そらそら、はじめたはじめた、お株が出たぜえ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そらそら海を海を、もうしめた、海を見ろ、海を』と叔父さん躍り上がって叫んだ。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうら、そらそら、きれいなむすめ、みんなでそろって、踊ろうよ。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そらそら、すぐ色を失うくせに、……嘘なもんですか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そらそら、その尼様だね、その尼様が全体分らないんだよ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらそら、言ううちに怪しくなったようじゃな、みろ、みろ、左の奴が先にやられるぞ」　呟いたとき、果然若衆の前髪がばらばらと額先で揺れ動いたと見えたが、ひらりと蝶のように大振袖が翻った途端――言葉のごとく左翼のいち人が、長々と地に這いつくばりました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらそら、次郎松！",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらそら、Ｚの腹に圧し潰されるよ。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらそらあの焚火の傍で何か叫んでいるらしい赤鬼のような老人が指揮者の丸源だよ。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらそら、気をお付けなね。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらそら、それだもの、だから鰻男だということさ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳と松そらそらお庭を見てごらん柳はやさしいおぢやうさん松はがうじやうおぼつちやん。",
              "citation": {
                "source": "歌時計",
                "author": "童謠集",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろめくやうに、忙しげに、子供たちの周圍を歩きまはつて、「そらそら、レン子ちやん」とか、「危いよ、走るところぶよ」とか叫ぶ。",
              "citation": {
                "source": "南方",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マネキン　そらそら御主人様かららしいことよ。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュガよチュガよチュガ公よそらそらそちらを行っては海へ落っこちるもう少しこちらをあゆびな竜燈の松が見えるよ洲崎は近いよお嬢さんが待っている金椎君も待っているチュガよチュガよチュガ公よ　　　　　　　　　十二　かくて、まだ朝といわるべき時間のうちに、早くも洲崎の、駒井の陣屋まで帰って来てしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらそら、ブロム・ボーンズの一党だよ」近所の人たちが彼を見る目には、恐怖と、讃美と、善意とがまじりあっていた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "消防にしたところで、いきなりエレクトロンの真弾を窓からびゅうびゅう火花の噴くまま投げ込んで、そらそら消さねば本当の火事になるぞと度肝をぬかれたっけ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人　　そらそら、さういふ風に、すぐ語気を荒らげるのはなんのためだ。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらそら、また来た！",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルピック夫人――そらそら！",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらそら気をつけないと卓子から転げ落ちますよ！",
              "citation": {
                "source": "恢復期",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生ッ、……脇差を……、早く脇差を……そらそら、逃げてしまうから」　脇差を捜そうとするのか、急にムックリと起きあがってあらぬかたへ匍い出そうとする。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蠑※",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらそら、あなたの手が顫えて来ました。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらそら、その罪のないやうな表情が、僕には信じられないんだ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（笑いながら軽く咳く）五郎　そらそら、もう黙つて。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そらそら、又笑ひはる！",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらそら奥さん……（立つて五郎の方へ行く）お帰りやす。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎　ハハ、そらそら――（と涙を拭いてやりながら）……なんでもいゝから、もう口を利くのは、よしなよ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
