      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "instant death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その上、坑内で即死した場合、埋葬料の金一封だけではどうしてもすまされない。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、先生、この森と柴田の死亡診断書にゃ、坑内で即死したと書いて呉れますね。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「先生が見て即死なら、見られたその通りを書いて呉れりゃいゝじゃありませんか。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと昔、たしか南米で生玉子の競食で優勝はしたが即死した男があった。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それを食べたら、肥料桶が、早桶になって即死じゃぞの、ぺッぺッぺッ。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、其の御総領の若様が五歳になった時、ある日アノ窓の側で遊んでいる中、どうした機会か其の窓の口から真逆さまに転げ墜ちて、敷石で頸の骨を強く撲ったから堪りません、其のまま二言といわず即死して了ったのです。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸にそれは劇毒で、政宗の毒味番が毒に中って苦悶即死したから事｜露われて、政宗は無事であったが、其為に政宗は手ずから小次郎季氏を斬り、小次郎の傅の小原縫殿助を誅し、同じく誅されそこなった傅の粟野藤八郎は逃げ、目上の人即ち政宗の母は其実家たる最上義光の山形へ出奔ったという事がある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の猟銃でのど笛を射って、即死した。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の猟銃でのど笛を射つて、即死した。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの毒は大変です、その卵のくッついた野菜を食べると、血を吐いて即死だそうだ。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がもし、ひょっとアル中ででも即死して、もしこの蓮の糸が無かったら、こんなにも好きな蝶ちゃんをも永遠に見失い、暗い死の闇の中で右往左往して夢中で探し廻す自分の姿が今も眼に見えるようなのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩もいつもの夫婦喧嘩から、一杯機嫌の権七は、店にならべてある商売物のなかから大工道具の手斧を持ち出して、女房の脳天を打ち割ったので、おいねは即死した。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと共に親実の小高坂の邸や木塚村の墓所には、怪しい火が燃えたり、弾丸のような火の玉が飛んで、それに当った人は即死する者もあれば、病気になる者もあった。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即死てしまうぞ』　大惣の落ち凹んだ眼の色が変りました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "北窓から飛び込んで南側の庭へ抜けるつもりでガラス障子にくちばしを突き当てて脳震盪を起こして即死したのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、たとえ幸運が我々の側を見すてずに、スレーターが頸骨を挫折して即死してしまったとはいえ、この一事あるがため、もしさもなければ犯罪上の最大な傑作として、人々を言葉もないほど嗟嘆させたでもあろうほどの玉に、一つの瑕をつけてしまったのである。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その弾丸と云うのは、先端の柔かな弾丸のように、茸のように張れ上った、明かに即死を思わしめる致命傷を与えたものに相違ないと思われるものであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の死はたしかに即死で、しかももう苦痛さえも無いものであったろう。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "即死で苦しむ暇もなかったはずだ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "南アメリカの矢毒から抽出したもので、強力すぎるあまりごく微量でも即死するとか。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "陪臣の分を仕つて、御先祖様お名をかたります如き、血反吐を吐いて即死をします。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、お絹は乳の下を突かれて即死。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "突かれたものこそ実に災難で、即死するものも随分ありました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭へ釘を打ち込まれたら即死の筈です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがそこに何も支うるものがなかったならば怪我人は即死した筈である。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "又或者は彼の即死せざりしをも物足らず覚ゆるなるべし。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊者また太鼓を打ちてアイルランドから毒虫を駆り尽くすに余り力を入れ過ぎて太鼓中途で破れ、その挙また破れかかった時神使下ってこれを繕い目出たく悪虫を除き去り、爾来永久この国の土に触れば蝮が即死する。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "下半身もしどけなく取り乱してはいたが、別段ひどい格闘の行われたようなあともなく、急所をねらったただの一突きで即死したものらしかった。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの太い鉄の框で頭から胸部を滅茶滅茶に打たれて、きゃっともすんとも言わずに即死してしまったらしいのです。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "不快だ……」　母は掛軸を掛け換へるなどゝいふ実生活にそくした生活の潤ひなどゝいふものには分らないのではないが妙に気の付かない性だつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
