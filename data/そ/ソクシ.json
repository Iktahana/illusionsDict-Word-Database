[
  {
    "uuid": "ba337e12-b1bc-5405-8ba9-242254e3fcc7",
    "entry": "即死",
    "reading": {
      "primary": "そくし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
