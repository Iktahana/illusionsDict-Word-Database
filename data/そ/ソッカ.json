    "definitions": [
      {
        "index": 1,
        "gloss": "at one's feet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（男一足下つて首をクネクネ廻して、頸の凝りを直す）夢だ…………常識主義者だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『喧嘩だ、喧嘩だ、』背中を突かれて驚く男、袂をくぐられて間誤付く女、跳ね飛ばされて泣くは子供、足下を攫はれて轉ぶが年寄、呆氣に取られた人人の間を縫て、矢の樣に走つて行く一人の男。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バッタが驚いて足下から飛び出した。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の通る足下では木曾川の水が白く泡を噛んで、吠えていた。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピークは、病人の入る処じゃねえや」「ピークにゃ、船長だけが住めるんだ」　彼等は、足下から湧いて来る、泥のような呻き声に苛まれた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "下って行く途中、ひょいと、二人の足下から、大きな兎がとび出した。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "内山君足下、先づ此位にして置かう。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがある極点にまで達しようとするとき、突如ごおっという音が足下から起こる。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん彼は幸福に雌の足下へ到り着いた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一と足下りかけた瞬間から、既に、自分はきっと滑って転ぶにちがいないと思った。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "懼れて慎み、慎みて誠ならば、修省の道はおのづから目前に在り足下に現はるべきである。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵元屋の秘密が洩れてはならぬと存じて斬り棄ててくれようと存じたに……」　良助はその足下の庭石に両手を突いてヒレ伏した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく思いつづけて青年が手はポケットの中なるある物を握りつめたり、その顔にはしばらく血の上るようなりしが、愚かなると言いし声は低ければ杖もて横の欄打ちし音は強く、足下なる犬は驚きて耳を立てたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "足下には、男の造った三つの行李と、最後に手がけていた蓋のしかけた行李が一つ。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青磁色に金銀の刺繍をちりばめた、細鼻緒があっさりと喰い入った白足袋の爪先を、つつましく揃えた足下へ瞳を落して、中形に結上げた束髪の首を、据えたなり、ついぞ口一つ利くのを見うけなかった。",
              "citation": {
                "source": "動かぬ女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　盲人は数多渠の足下に叩頭きたり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と艦長の許可を得て、水兵はやをら武村兵曹に眼を轉じ『久濶や、兵曹、足下は本國で名高い櫻木海軍大佐閣下の部下の武村兵曹ではないか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言ひながら、額を叩いて『濟まない、すつかり忘れた、足下は誰だつたかな。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、水兵は膝を進ませ『今、松島海軍大佐閣下は、英國テームス河口の造船所から、新造軍艦「日の出」の廻航中で、本艦は昨曉アデン海口を出で、今しも此印度洋を進航して來ると、丁度輕氣球が天上から落ちて來たので、急ぎ助けて見たら足下等だ、實に不思議な縁ではないか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹も其仲間に入つて、頻りに愉快だ／＼と騷いで居つたが、何時何處から聞知たものか、例の轟大尉の虎髯はぬつと進み出て『これ、武村兵曹、足下はなか／＼薩摩琵琶が巧い相な、一曲やらんか、やる！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "とお録の心前に突附くれば、足下に踞りて、「何でそんな事をいたしましょう。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "足下のようでもないじゃないか」「眩くってうなだれたね、おのずと天窓が上がらなかった」「そこで帯から下へ目をつけたろう」「ばかをいわっし、もったいない。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉とやら、みずからは、とあの姫様が、言いそうもないからね」「罰があたらあ、あてこともない」「でも、あなたやあ、ときたらどうする」「正直なところ、わっしは遁げるよ」「足下もか」「え、君は」「私も遁げるよ」と目を合わせつ。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はすでに前後を忘じて、一心死を急ぎつつ、蹌踉と汀に寄れば、足下に物ありて晃きぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩むにつれて、足下の叢より池に跋ね込む蛙は、礫を打つがごとく水を鳴らせり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、足下自身も或は其一人であるかも知れぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、僕は足下に対して、単にこの材料の調書を提供するに過ぎない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を小説風に潤色して、更に読者の前に提供するのは、即ち足下の役目である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠のような怪しい鳥が飛んで来て、蝋燭の火を危く消そうとしたのを、重太郎は矢庭に引握んで足下の岩に叩き付けた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "重太郎も足下を覗いて流石に悚然した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
