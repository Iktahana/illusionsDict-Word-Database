  {
    "uuid": "7c58afff-1511-5964-9c41-88cc65675746",
    "entry": "そっか",
    "reading": {
      "primary": "そっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "oh",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これはそそっかしい熊蔵一人にまかせては置かれないと思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは、いかにも不機嫌そうに眉をひそめ、それから仕方無さそうに笑い出し、「話にも何もなりやしないんですよ、あの子のそそっかしさったら。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女は少しそそっかしい銀子に言うのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らず、そそっかしいねえ、君は。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が、そそっかしいんだよ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もそそっかしい、考えたって解りますのにねえ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそそっかしいので、あなたの音楽会の広告が出ていても、うっかり見逃しそうですから……」「はあ。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれほど大事そうに言っていながら、年寄りのくせにそそっかしいな。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっか、今日はおおみそかなんだ、と少女は思いました。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "THE LITTLE MATCH-SELLER",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり手を曳いて連れ込んだ、そのひき方がそそっかし屋で荒いので、私と顔を会わせた時は、よろけ加減で、お絹の顔が、ほんのりとなって、その長襦袢のしなやかな裳をこぼれた姿は、脊は高し、天井の黒い雲から糸桜がすらすらと枝垂れたようで、いや、どうも……祇園の空から降って来たかと思われました。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうにそそっかしい人ですね。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今のオルノーコの話だが、君はそそっかしいから間違えるといけないからついでに言うがね」と先生の煙がちょっととぎれた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、おれ達がいくらそそっかしいにしたって、以前のように騙かされようがないじゃないか。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲が深いくせに、むやみとこのとおり、やることがそそっかしいんだからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちっと、どうもやることがそそっかしいように思われますが、ねえ、だんな、だんなはまさか、今度の仕事の相手に、どんなやつが向こうに回ったか、お忘れじゃござんすまいね」「知らないでどうするかい、あばたの敬四郎じゃねえか」「そうでがしょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、たったあれだけの調べ方じゃ、ちっとどうもそそっかしいように思われますがね」「じゃ、おれの目は節穴だというのかい」「ど、どういたしまして――、だんなの目のくり玉は、天竺までにも届いていらっしゃるこたあよっく心得ていますがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は小供が可愛くないのか、何故飲まない」　がたがたとそそっかしい下駄の音がして野本が入って来た。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお糸が黒船のマドロスと出来合って逃げたらしいな」「それを自分の馴染の女と間違えるというのは、巳之助という奴もよっぽどそそっかしい野郎だ」「野郎もそそっかしいが、女も女だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、両方ともにそそっかしいには相違ないが、薄暗いところで見違えたのが始まりで、両方の名が同じであるために、いよいよ念入りの間違いを生じたらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そそっかしいは昔からだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにリンピイのそそっかしいのが悪いのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分どこからかの脅迫状でもあろうと思いましたが、たった一人生き残った母親へ心配を懸けたくないと思ったので、それはそそっかしい親友Ａ――の筆蹟にちがいないと話して安心をさせました。",
              "citation": {
                "source": "三角形の恐怖",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そそっかしく下駄を鳴らして歩く内地人（日本人、以下同じ）や、口をぽかんとあけて店先を眺める白衣のお上りさんや、陳列窓に出した目玉の動く人形にびっくりし合う老婆達や、買物に出掛ける内地婦人、ベルの音もけたたましく駆けて行く自転車乗りの小僧に、僅か十銭ばかりの運賃で荷物の奪い合いをする支械軍などで。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ御所の建て替えをやって、天子さまのお休みになる御殿の柱を立てた時に、大工がそそっかしく、東北の隅の柱の下に蛇と蛙を生き埋めにしてしまったのだ。",
              "citation": {
                "source": "葛の葉狐",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどきそそっかしく鼻へあてる近眼鏡の蔭にさまよう眼付なんか、ほんとうに静かで柔和だった。",
              "citation": {
                "source": "無駄骨",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻銀器を取りこむときに、そそっかしく叩きこんだので、それが衣嚢の中で鍵束とこんぐらかってしまったのだ。",
              "citation": {
                "source": "空家",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくわれらあらん限り、御身のみ心をおのれとし、み栄を高くかかげて、異端者の悪しき思いやあまたの人の心なき業、また、そそっかしき心もて受けさせ給う侮辱をも、そそぎまつらんことを希う。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの狭山という男は、課長とか何とか偉そうな肩書を振りまわしているが、案外だらしのないそそっかし屋だ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
