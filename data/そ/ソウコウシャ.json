    "definitions": [
      {
        "index": 1,
        "gloss": "armoured vehicle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神は在る、装甲車と駛る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤な装甲車の背中が、血痕やガラスの破片を踏みにじりながら、穴を開けて静まってしまった街区の底をごそごそと怠るそうに辷っていった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜剣したまま駈け違う騎馬隊の間を、装甲車が辷っていった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から新製の装甲車が試射慾に触角を慄せながら辷って来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道栓に縛りつけられたホースの陣列の間を、静に装甲車が通っていった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんどは装甲車を五台出動させることができる。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから上陸班は十分に活動ができると思う」「装甲車というと、どんなものですか」「一種の自動車さ。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、装甲車だ」「なぜこんな乗物を使うんですか。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからそんなことのないように装甲車に乗って上陸するんだ。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "装甲車が用意されているそばに、彼は立っていた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "装甲車に乗る者は、それを着ないでいいのだ。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん用心のために持っているが、それは装甲車の中が、気密になっているからである。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "装甲車は、みんなで十台あった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "正吉少年が乗りこんだ装甲車は、一号車であった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの装甲車が外に出るまでに、このようなことが数回くりかえされる。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて九台の装甲車は、みんなロケットの外に出た。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、一号車を先頭にして、九台の装甲車は月の上を走り出した。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "意外な発見　二時間ばかり走って、装甲車は停った。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "装甲車の戸があいた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとへ六台の装甲車がついてくる。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄扉へ、装甲車の中にある発電機から、電気が通じられると、洞門の扉はぎいぎいと上へまきとられて、入口はあいた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四台の装甲車は、その中へはいっていった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルナビゥムについて、正吉はもっと話を聞きたいと思ったが、そこへ四台の装甲車がしずしずとはいって来て、カコ技師がたいへん忙しくなったので、もう話しかけられなくなった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "装甲車を一台と四、五人を私にかしておいて下さい。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその間に他の装甲車でもって、ルナビゥムを掘りに行って下さい。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが決って、隊長以下は三台の装甲車に乗り、いそいでこの倉庫第九号から出ていった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつぜん、外に待たせてあった装甲車が発した警報が、カンノ博士たちのところへ届いた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルモ隊長など九台の装甲車が、トロイ谷のところで、かいぶつの一団にとりかこまれてしまって、危険におちいっているとの無電がはいりました。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐこの装甲車へ帰って来て下さい」　運転手の声は不安にふるえていた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロイ谷へ向ったのは、マルモ探検隊長のひきいる二十五名の隊員で、九台の装甲車にのっていた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
