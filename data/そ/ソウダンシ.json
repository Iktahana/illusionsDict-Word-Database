          "literary": [
            {
              "text": "いたずらずきの子どもたちは、顔をみあわせながら、目と目で、神さまをつかまえようよ、とそうだんしました。",
              "citation": {
                "source": "子どものすきな神さま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、まあ、それをどうするか、まあ、わたしのいいなずけにそうだんしてみましょう。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしには、そうだんしてくれないのかしら。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じつは、あなたにぜひごそうだんしたいことがありますので、あちらまできてくださいませんか」　エキモスはニコニコしていいました。",
              "citation": {
                "source": "銀の笛と金の毛皮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから一たん船をかえして、パリ大学に滞在中の長良川博士にそうだんした方がいいと思う。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く、どうしてそれをぬすみだすか、その方法をごそうだんしようじゃありませんか」「いや、トニーの言葉だけれど、いくらぬすむといっても、かりにも潜水艇一｜隻だ。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、武夫は二人にそうだんしました。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほかの人にも、そうだんしてみましたか。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまってしまって、　ホテルの　しはいにんに　そうだんしてみると、　ありがたいことに　じぶんの　むすこが　かよっている　がっこうの　せんせいの　おうちを　おしえてくれまして。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どうしよう」　ひたいをあつめてそうだんした。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かいい薬はないだろうかと、いろいろそうだんしたが、これはたぶん、胆汁のふそくからきた病気にちがいない、にがい薬をのませたらいいだろう。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユウ子ちゃんは、すぐにその紙をもって、電車に乗って麹町の明智たんていじむしょをたずね、小林しょうねんにそうだんしました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかたがないので、小林くんとそうだんして、おくの方へ行ってみることにしました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌一君とそうだんしようにも、まっ暗な中では、字を書いて見せるわけにも行きません。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、よくそうだんしよう。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから帰って、親分とそうだんして、また出なおしてくる。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蛾次郎、さだめしたいくつであったろう」「ううん、そんなでもなかったよ、だけれど、菊池さんはいままでいったいどこへいってたのさ」「その方をりっぱな侍に取り立ててやりたいと、城主周防守さまとそうだんしてまいったのだ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
