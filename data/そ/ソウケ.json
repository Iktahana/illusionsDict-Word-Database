        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一方女は水無瀬女と獣の神の若者との間から生れ出て多くの門裔がこの麓の地に蔓ったその宗家の娘であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖先の水無瀬女から何代か数知れぬ継承の間に、宗家は衰え派出した分家、また分家の方が栄えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の落葉のままが風雅なら、どんな田舎家にも千家茶道宗家の看板は掲けられましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の宗家も、本山も、当国古市において、一人で兼ねたり、という勢で、自ら宗山と名告る天狗。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……按摩の分際で、宗家の、宗の字、この道の、本山が凄じい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗家の宗、本山の山、宗山か。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥の檜垣の家が宗家で、伯母はその家より出て分家へ嫁に行ったものである。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母はいった、自分の家は廃家しても関わぬ、しかし檜垣の宗家だけは名目だけでも取留めたい。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば自分に取っては宗家への孝行となるし、あなたにしても親友への厚い志となる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸王にして悦ばざるときは、宗家の枝柯、皇室の藩屏たるも何かあらん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵜匠鵜匠の宗家長良川の山下幹司君に篝火の朱にはゆる君こそは鵜匠なれ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜多流宗家｜六平太氏未ダ壮ナラズ、嘱セラレテ之ヲ輔導ス。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや宗家の記録と甚しい時代の相違があり、引例考証らしいものすら絶無であるから、ただ何かの参考としてここに記載しておくに止める。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その能静氏の追善能に就いては只圓翁にも上京してくれるように喜多宗家から度々掛合って来たので、翁は無上の名誉として上京したが、早速藩公長知公の御機嫌を伺い、喜多家へも伺ったところ、その後、千代造氏（六平太氏幼名）と、翁と同行にて霞が関へ出頭せよという藩公からの御沙汰があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）をつとめた筈であるが、その当時の記録は今、喜多宗家に伝わっている事と思う。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今四谷の喜多宗家に居られる梅津兼邦君の父君であるが、翁の歿後は脇方専門のようになっていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "応仁の乱の時、斯波家も両方に分れたとき、朝倉は宗家の義廉に叛いた治郎｜大輔義敏にくっついた。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "織田家は宗家の義廉に仕えて、信長の時まで、とにかく形式だけでも斯波の家臣となっていた。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、宗家のかしらは第一等の船の親柱に任命されたが、その船はいつでも世界じゅう漕ぎまわれるというりっぱな船だ。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は呼んで、宗家同格と渠を称える。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥の身の上は自業自得の因果で是非ないとしても、自分の宗家たる藤枝の家をこのまま亡ぼしてしまっては、先祖に対しても申し訳がない、死んだ兄に対しても申し訳がない。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三河は、人も知る十八松平、葵宗家の発祥地、御領主様は智慧者でござる。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことぐずり松平の御前とは知る人ぞ知る、この東海道三河路の一角に蟠居する街道名物の、江戸徳川宗家にとっては由々しき御一門｜御連枝だったからです。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お墨付を蔑ろに致すは、即ち葵御宗家を蔑ろに致すも同然、必ずともに御気分の晴れまするよう、御手伝い仕りましょうが、一体いかほどばかりござりましたら？",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも御身、江戸宗家に弓引く所存でござるかッ」「滅、滅、滅相もござりませぬ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その水一つ隔てた高い土手のかなたの大江戸城を永劫に護らせんために、副将軍定府の権限と三十五万石を与えてここに葵柱石の屋敷をも構えさせたのに、今はその水一つが敵と味方との分れ目となって、護らねばならぬ筈の徳川｜御連枝たる水藩が、率先勤王倒幕の大旆をふりかざし乍ら、葵宗家に弓を引こうとしているのだ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "年取った祖母と幼い自分とで宅の垣根をせせり歩いてそうけ（笊）に一杯の寒竹を採るのは容易であった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ、そうけえ。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうけえ、新郷へ行くけえ、あそこはどうもな、吝嗇な人間ばかりで、ねっかららちがあかんな」と言って声高くその中年の男は笑った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚兵衛　はあ……そうけ、嫌か。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
