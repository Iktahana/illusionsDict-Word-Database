          "literary": [
            {
              "text": "天国に上昇してゆくような爽快感。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "一分二分と失われた意識が次第に霞を払いながら戻ってくると、一時はいくらかの爽快感にひたる何分何秒かがあるのである。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ声が、――さて、なんと形容したらいいだろう、さよう、山葵のきいたのを口にふくむと鼻の裏側をキュッとくすぐられる、あの一種の快さ、あれにちょっと似た不思議な爽快感を与える声で、少なくとも私には少なからず魅力的であった。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
