          "literary": [
            {
              "text": "「ぼくほんたうはよく知りません、けれどもそんなんでなしにほんたうのたった一人の神さまです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あゝ、そんなんでなしにたったひとりのほんたうのほんたうの神さまです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうして、そんなんじゃありません」と、源次は少しおびえたように眼を据えてささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくほんとうはよく知りません、けれどもそんなんでなしにほんとうのたった一人の神さまです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、そんなんでなしにたったひとりのほんとうのほんとうの神さまです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそんなんでなしに、ほんとうのたった一人の神さまです」「ほんとうの神さまはもちろんたった一人です」「ああ、そんなんでなしに、たったひとりのほんとうのほんとうの神さまです」「だからそうじゃありませんか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそんなんでなしに、ほんたうのたつた一人の神さまです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、そんなんでなしにたつたひとりのほんたうのほんたうの神さまです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなんでないんです。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなんぢやありません。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はその時期です」「人間にもそんなんじゃない」「まあそんな傾向がないとは云えませんがね。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまからそんなんじゃ、末が思いやられるね。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そんなんじゃない。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなんじゃないのよ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、そんなんじゃない。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなんぢやないのよ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、そんなんぢやない。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、そんなんじゃない。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなんじゃあない。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ごめんなさい、そんなんじゃありません。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな、ただ思いつき、趣向ですか、そんなんじゃありません。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀ちゃん、そんなんかね。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまあ思っちゃあ見たものの、千ちゃん、常々の御気象が、そんなんじゃあおあんなさらない……でしょう。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなんぢやねえのとれな」勘次は大きなのを選んで三つとつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなんだから亭主は此がね餘ツ程大きく成つてからだといふんですが出つちやつたんですと、そこへ行くと身元の知れねえ遠國者は思ひ切が能うがすかんね。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だめねえ、そんなんじゃないのよ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と僕が笑いながら言ったら、「いや、そんなんじゃない。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなんぢやないよ。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなんぢやないんだつてエば――」「そんなら起きてしまひなよ。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
