        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "都市の防衛のため、阻塞気球が空に浮かべられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "阻塞気球は、敵機の侵入を妨害する目的で使われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "第二次世界大戦中、ロンドン上空には多くの阻塞気球が配備された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「われ等の、戦闘機隊は、何をしているのだ」「阻塞気球の中へ、引っぱり込まれたらしいです。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "半数は、気球から垂れている綱に、機体を絡めつけられ、進退の自由を失っているらしいです」「なに、阻塞気球※」「ほら、御覧なさい。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グランド君が、敵の阻塞気球に……」「航空長、本船を、浦塩へ、向けろ」大佐は、皺枯れ声で、叫んだ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、リバプール港へいそぐ阻塞気球隊だったが、彼は、そんなことを知る由もなかった。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には、夢のように、阻塞気球が、ぷかりぷかりと浮んでいた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（さて、これから自分は、いかにして、わが家に戻るべきであろうか）　阻塞気球は風に揺れていた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、ロンドンの空一杯に打ちあげられた阻塞気球を、ひどく信頼しているのか、それとも、自分だけには、ドイツ軍の爆弾が命中しないと信じているか、どっちかであるように見えた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "阻塞気球が、敵機をひっかけようとヌーッと浮んでいるのが、チラリと見えた。",
              "citation": {
                "source": "空襲下の日本",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
