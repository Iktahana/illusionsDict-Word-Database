        "examples": {
          "standard": [
            {
              "text": "彼は自信満々にそっくり返って、ステージに現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "偉そうにそっくり返っているが、実際は何もできない男だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "将軍は戦場で勝利を収め、堂々とそっくり返って帰還した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ちょいと手がさわるが早いか、どいつもこいつも思い切りよくそっくり返る。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと何かを見つけた蟹は、慌てて芝土に力足を踏みしめ、黒みがかった緑色の甲羅がそっくりかえるばかりに、二つの真赤な大鋏を頭の上に振りかざしている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "初日に校歌演奏」　ワラが、そっくりかえるようにして、大笑いする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "産み月の近くなったころ、特別製の大きなオーバーをきて、そっくりかえるような堂々さで歩いていた姿は実に立派だった。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
