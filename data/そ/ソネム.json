[
  {
    "uuid": "099408d3-c518-560c-9f9e-d7552d9fbca9",
    "entry": "嫉む",
    "reading": {
      "primary": "そねむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
