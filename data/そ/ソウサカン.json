[
  {
    "uuid": "b2662016-c308-58d4-a215-08b2fb09bfce",
    "entry": "捜査官",
    "reading": {
      "primary": "そうさかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
