    "definitions": [
      {
        "index": 1,
        "gloss": "plain clothing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かなり名の知れた名僧でありながらいつも貧乏たらしいにび色の粗服で、何処かよぼよぼして見えるのが、無信心の宗右衛門にむしろ平常は滑稽にも思はれた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "予の今覺えて居る處は、そんな大きい店なのにも拘らず家は狹く汚く、主人も粗服だと云ふ事を賞讚したことである。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あたかも、この時、粗帽粗服の一高生らしいのが通りかかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に、窓の方に寄りて坐りたるは、暗褐色の粗服したる媼なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい肌に粗服をまとって、質素な仲平に仕えつつ一生を終った。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬頭粗服、風采あがらざる一老書生なりしに、それを蜀山人とは、如何にして知り給ふぞと問へば、凡そ天下ひろしといへども、今の世、蜀山人ならで、かゝる句を咏み得るものあらむやと言はれ、吉原第一も今日限りと、齒をくひしばり、わつとばかり泣き伏す。",
              "citation": {
                "source": "牛經",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬頭粗服の三人、旅に優待せられたる例しなきこととて、互に顏見合せて、これは／＼と打驚く。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等程度の学生としては、粗服に過ぎて居た。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして豪放と云う看板の下に、自分の粗服を少しも気に掛けまいとした。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の活動を妨げず養育法は着物よりも食物の方に心を用い、粗服はさせても滋養物は屹と与えるようにして、九人とも幼少の時から体養に不足はない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児遊戯の年齢には粗衣粗服、破れても汚れても苦しからぬものを着せて、唯活溌の運動を祈る可し。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる粗食と粗服と陋屋とを余儀なくされても、なおその生活には張があり力がある。",
              "citation": {
                "source": "都会に於ける中流婦人の生活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉のジナイーダは寝台の下にある屎瓶を布片で覆うてから、悠然と上って来たが、二七、八になるらしい彼女の神々しい美しさには、粗服の中にも聖ベアトリチェの俤があった。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はその粗服と風雨に曝された皮膚以外、何等の表情をも持ってはいない。",
              "citation": {
                "source": "砂漠の情熱",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「沈黙は金なり云々」の格言は、遂に、東洋流の解釈によつて、「咄弁は美徳なり」と同義になり、やがて、「月並な文句は粗服を纏へる真理なり」と敷衍せられ、遂に「退屈な話は人類を堕落より救ふ」とまで進んで来た。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、粗服のなかに顔面だけが明朗に輝いてる玄元禅師が来た。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "織目の見える古生地の粗服を着ていたが、それと対照に、ふっくらとした頬が如何にも瑞々しかった。",
              "citation": {
                "source": "塩花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに紳士だから世のつねの紳士のごとく、いかに身に粗服をまとうとも靴の先だけは木賃宿の寝布で拭いて光らせている。",
              "citation": {
                "source": "字で書いた漫画",
                "author": "谷譲次",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年も昔に流行ったような紋付羽織を祝儀不祝儀に着用して、それを恥ともせず、否むしろ粗服を誇りとするが小諸の旦那衆である。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "士は身命を捨てて奉公を致す故にそれぞれ禄を貰い、農は粗服を用い粗食を喰い汗を流し耕作をぎ歩役を勤め、工はそれぞれ加役に用いられ、商人は武具の外に調うる物なく、その時に至りて渡世なく如何よう致し候心得か。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ、お渡しを願いたい――」　これが町奉行の大岡越前守とは知る由もない栄三郎、よし零落れて粗服をまとうとも、面識のない武士には対等に出る。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "勞働者と區別できない粗服をひよろ長い体に※［「纏」の「广」に代えて「厂」、25-左-26］うて　泰然自若であつた。",
              "citation": {
                "source": "プランク先生の憶い出",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗服の女だちとあとに心配のない程度で金を分けあつた。",
              "citation": {
                "source": "巷の子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は長い旅の果て、泥まみれになり、粗服に乗馬靴、乱れた姿だった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩主が、粗服を着たり朝夕の食膳の菜を減らしたりして範を示してみせる事も、何の効いもない。",
              "citation": {
                "source": "鬼",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は、多衆の行動だから静粛に穏かに行かねばならぬが、決心だけは十分堅固にして進もうといい、或は、途中で買食いや飲酒をせずに品行方正にといい、粗服まとい防寒具を忘れぬようにといって、前日から本堂の事務所に貼紙されていた注意をくり返して、万全を期した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の一隅には粗服の群集がいた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗服だが、どこか気稟の高い風が見える。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主の粗服は、廂のやぶれと同じ程度の古さである。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆山の尼院から密かに移って来た政子も至って粗服であった。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
