        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大渡橋ここに長き橋の架したるはかのさびしき惣社の村より　直として前橋の町に通ずるならん。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所に長き橋の架したるはかのさびしき惣社の村より直として前橋の町に通ずるらん。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "府中はいまさら説くまでもなく、古昔の国府の所在地で、六所明神は府中の惣社。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ここに問題なのは、ヒダには国造、つまり朝廷の任命したヒダ長官のすむ都が今の高山市内の七日町というのに当っていて、ここにはこれを無言で証明する如くに国分寺趾や惣社がある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、そうじゃない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八釜しくて仕様がないや」「八釜しい奴あ、耳を塞いどけよ」「そうじゃねえんだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺達の教会」では思わず吹き出し、そして感心しちまった――何とおめえ達そうじゃあねえか、信ぜよ、そして働けよ、だ。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから女の方の傾向もそうじゃないかね。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうじゃないこれは苔だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前等二人が余り仲が好過ぎるとて人がかれこれ云うそうじゃ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれァ都田村の吉兵衛親分じゃねえか」　「そうじゃねえんだ、吉兵衛親分と将棋をさしてる男よ」　「このあたりじゃ、見かけぬ顔だが……誰でえ」Ｓ＝二階の一室　離れ座敷と庭を隔てた二階の座敷。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人も「そうじゃ」と云う。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「デハ貴殿が　宮本先生」　そうじゃ、と団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「偽札をこしらえた者が掴まったそうじゃないか、見てきたかい？",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、「お主の賃銀もその話が片づいてから渡すものは渡すそうじゃ、まあ、それまでざいへ去んで休んどって貰えやえゝ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、そうじゃアないか満谷の大将」と中倉先生の気炎少しくあがる。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう明日あたりは涼み台を出そうじゃないかという事が誰かの口から云い出される。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誤魔化そうと思ったんですか、そうじゃないですか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつを持って行ったかな」と、半七は少し迷ったように蛇のゆくえを見つめていたが、「いや、そうじゃあるまい」と、又すぐ打ち消した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が考えてもそうじゃねえか」「そうですねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、もう少し深入りして訊きてえことがあるんだが、師匠はどうせここへはいるつもりなんだろうから、おれ達も附き合ってもう一度引っ返そうじゃあねえか」「でも、それじゃあんまりお気の毒ですから」「なに、構わねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、そうじゃあねえか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうじゃろうか。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それでも、あいつを棄てるんは可愛そうじゃし……」　おりくの家には風呂がなかった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「捨てる云うたって、家に生れて育った猫じゃのに可愛そうじゃの」「うらあもう大分風呂イ入らんせに垢まぶれじゃ」　四五日、捨てる、捨てないで、云いあった後、ばあさんは、一日をつぶして、猫を手籠に入れて捨てに行った。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殺されたら可愛そうじゃせに、よそイ出て行かんように、家につないどこうかいの。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「めった、今度は去年あたりよりゃあいつらの景気がいいと思ったら、独逸が新しい武器を提供しとるそうじゃありませんか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度、ＫからＳまで電車がつくんで、だいぶ家の土地もその敷地に売れそうじゃ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ、さようで……」「それそうじゃ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうじゃないわよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
