    "definitions": [
      {
        "index": 1,
        "gloss": "shrine enshrining several gods",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
