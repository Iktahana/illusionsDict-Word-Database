        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "母はつぎものをする時もある、歌舞伎（芝居雑誌、二六通や水魚連という連中から贈ってきた）の似顔絵を見ている事もあるが、かき餅を焼いたり蕎麦がきをこしらえてくれたりした。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレラは門並といってよいほど荒したので、葛湯だの蕎麦がきだの、すいとんだの、煮そうめんだの、熱いものばかり食べさせられた。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉の留守には乙女が、祖母ちゃんが才覚してもって来た粉でそばがきぐらいをこしらえ皆を食べさせた。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒注である「ちょか」とか、汁を煮たり御飯を焚いたりする「山ちょか」とか、「そばがき」と呼ぶ碗だとか、他国にないものを色々と作ります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
