        "examples": {
          "standard": [
            {
              "text": "大相撲の本場所では、初日に横綱の揃い踏みが披露される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "力士たちは気迫のこもった揃い踏みで、会場を沸かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝統的な揃い踏みは、力士たちの力強さを象徴する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「現場に警部とレストレード、両者揃い踏み。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとひとつ、パラダイスという雑誌があれば、揃い踏みですよ。",
