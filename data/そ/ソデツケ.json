    "definitions": [
      {
        "index": 1,
        "gloss": "attaching a sleeve to the body of a shirt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "両脇から頂上の砦へのぼっている山襞は袖付の裂け目に似ていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い洋服はきっかり体躯についた仕立て方で、襟の折返しの工合か肩の袖付の工合か、それとも淡色の編みネクタイの影響か、へんに伊達好みな気味がある。",
              "citation": {
                "source": "秦の憂愁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の袖付は二、三寸もほころびてゐた。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖付や袵の皺が苔でも置いたようなしっとりした青味の谷をつくって、いうにいえないいい味わい……帯はね、蝦夷錦の金銀を抜いて、ブツブツの荒地にしたあとへ、モガルの色糸で、一重蔓小牡丹の紋をいたずらでもしたようにチラホラ散らしたという……お話中……わからないひとねえ、お話中だと言ってるじゃありませんか。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "模範的な撫で肩で、ポロ・シャツの袖付の線が、へんなところまでさがっている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖付や衽の皺が、苔でも置いたようなしっとりした青味の谷をつくって、いうにいえないいい味わい。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして裾と袖付けとの中に、紙の厚みが感ぜられるように思った。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のせいであったと分ると、お通はさびしさに囚われて、もう袖付と襟さえ縫えば仕立てあがる縫物にも、つい身が入らなくなってしまう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
