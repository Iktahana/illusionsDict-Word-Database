    "definitions": [
      {
        "index": 1,
        "gloss": "Waseda University (abbr)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
