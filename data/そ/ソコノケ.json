    "definitions": [
      {
        "index": 1,
        "gloss": "superior to (e.g. a professional)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
