        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこ退け、下賤の者。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこ退け、踏んでくれう。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ぺつと唾を吐いて、急いで十字を切ると共に、両手を泳ぐやうに振りながら、その思ひもかけぬ土産物から逃れようとして、彼は一目散に駈け出したが、その速いこと速いこと、血気の若者そこ退けといつた歩調で忽ち群集のあひだへ姿を消してしまつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなやつ、殺してしまうんだ、とめるな、そこ退け」　阪井は上衣を脱ぎ捨てて荒れまわった、このさわぎの最中に最敬礼のらっぱ卒がやってきた、かれは満身の力でもって阪井を後ろからはがいじめにした。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "『たとえ、おくれて参ったからとて、ひとの釣り場へ無断で足を踏み入れるとは、釣りの仁義をわきまえぬ不束者――そこ退け！",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病者め、そこ退けっ！",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（a）そこから、カエサルがその船頭にいった言葉、彼をおびやかす大海もそこ退けのあの言葉、が出たのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お師匠さまを殺して、どこへ」「そこ退けッ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木っ葉どもめ、花栄さまのお通りだ、そこ退け、そこ退け」　蹴ちらしつつ自陣へもどって来る途中だった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこ退け、そこ退け」　躍り立つ馬の下から、勝助は身を避けたが、彼の手は、その口輪を取って、「いざ、そこまで、御案内仕りましょう」　と、勝家の意志とは反対に、戦場をあとに、柳ヶ瀬村の方へ駈け出した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこ退けい」「やわ退こうか。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸く盆踊を見つけて参ります、と反対に西洋人が来たと云うので踊りそこのけにして、いたずらに砂をかける者がある。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで爺さん、新らしい靴を脱ぐと、雨にあてて反曲してなるものかと、手拭にくるんで、まるで旦那衆の乗る※足の馬そこのけの、韋駄天走りに駈け出した。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ぎつぎと矢鱈に話がはずんだものだから、祖父はすつかり自分の旅の用向きも忘れてしまつてな、二人は早速、大精進期前の婚礼そこのけの、飲めや唄への大酒宴をおつぱじめたものぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でもその番頭が、片手に算盤をひつ掴みの、薬罐頭から湯気を立てて、忌々しさうに何か云ふのを聞きや、「ほんによ、こんな胡麻の蠅も、今に劫羅を経て見さつし、鼠小僧なんぞはそこのけの大泥坊になるかも知れ無え。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもさんは大割引のたった十円」　観音堂のうらにあたる空地に、本堂そこのけの背の高い大きな小屋がけをし、サーカスそっくりのけばけばしいどんちょうやら大看板、それに昔のジンタを拡大したような吹奏楽団が、のべつまくなしに、ぶかぶかどんどん。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "太閤そこのけの大人物に見立てられて、気のいゝ御両人の御奉行が度胆をぬかれて讃嘆したに相違なく、白石はてれたふりをして、御奉行にきかれるのも片腹痛い限りで失笑したなどゝ書いてゐるが、大いに気を良くしたに相違ない。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄水母は、潜水艇であると同時に、陸上をはしらせても自動車そこのけの働きをしめすのであった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はオリンピックの選手もそこのけという風に、大きな幅とびでどんどんおいかけていく。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては近所の生臭坊主が、俗人そこのけに目尻をさげて追いすがるていたらく。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "正規兵の代りに全朝鮮の虎猟師を駆集めたなぞは、楠正成そこのけの戦術家だった。",
              "citation": {
                "source": "撥陵遠征隊",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "生白い顔してる癖に圓朝て意気な野郎だなあ」「意気だともよ、圓朝、圓朝しっかり泳げ」　我も我もと花火そこのけで圓朝を声援しだした。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "圓朝圓朝しっかり泳げ」　われもわれもと花火そこのけで、彼らは圓朝を声援しだした。",
              "citation": {
                "source": "圓朝花火",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お絲と別れて自棄になった時分の圓朝なら、あの脂の乗りきった出戻りのお嬢さまに、名僧知識そこのけのお説教を聞かすような、もったいねえ真似はしなかったはずだ。",
              "citation": {
                "source": "圓朝花火",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのけじめをはつきりと附けてゆくといふのが、ここの建前だ。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "復讐の場の〈エレクトラ〉そこのけという氷のような微笑をうかべながら、あたしがいった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボナールとデュアメルのときは荘重ないいフォルムだったが、フレッドさんはゲーリー・クウパアそこのけというのっぽだから、抱きついたところは腰線もずうっと下のほうで、蛙の木のぼりのようなへんな恰好になった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えいッ、小僧、そこのけッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴のまにあったのをさっそく水へおろして、河風に裾をまかせた泰軒が、船宿の若い衆そこのけの艪さばきを見せているのだった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのけ」「どかねえよ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
