    "definitions": [
      {
        "index": 1,
        "gloss": "freshly shaven",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "剃りたての、頚条も手頸もどこもかしこもそはそはと、寒かつた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "次のは、剃りたての頭の青々とした綺麗な出家。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃りたての青い頭で、まだ着なれぬ衣を着た栄蔵は、翌朝、風呂敷包を一つ下げて家へやつていつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後の冬ははやく訪れるので、海から来る風はもう道や畑を白くして吹き、良寛さんの剃りたての青い頭は、雪をふくんだ雲の下で寒かつたのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の食堂で、黄色い袈裟を着た日本の老いた坊さんが、剃りたての真蒼な頭をした小僧をつれて、巧みにナイフとフォオクを操りながらビフテキを喰べていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃りたての顎はモスリンの包帯でしっかり結え上げてある。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十前後の頭を剃りたての住職は、顔色を変えて走りだしてきました。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃りたての綺麗な頭に、燭台の灯がうつって、チラチラと動いた。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして剃りたての青眉はたとえていえば闇夜の蚊帳にとまった一瞬の螢光のように、青々とした光沢をもっていてまったくふるいつきたいほどである。",
              "citation": {
                "source": "眉の記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "最前列には、口髭と房髪をたくはへて、頤を剃りたてた、頸の太い貴族や普通の百姓たちが、ずらりと立ち並んでゐた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "口の中へ一ぱいに大福餅を押込まれたり、あの肥った体で踏んまたがれて、青坊主に剃りたてられるのが愁いのだった。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃りたての襟筋が青々としてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い眉と眉との間をテラテラ光らせ、剃りたての顎、長めな鼻の下へ小さく髭を立ててる。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹前のふところ手で、苅りたての頸筋のあたり、剃りたての顎のあたりに軽い風をうけながら猛之介は改正道路を、うちの方へ横切った。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　紀さんの剃りたての蒼白い顔とちぢれた髪と黒い目の光。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに頭は剃りたてで、僧貌も一層柔和に見える。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれがのうては、肝腎の芝居がわやになってしまうがな」　剃りたての松江の眉は、青く動いた。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中からは、のっと、月が出るように、剃りたての坊主頭が伸びあがっていた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぷーんと、麝香松子の香が立つ剃りたての青い頭から、色の小白い唇もとすこし下がったところの愛嬌黒子など、尼かとも見紛うばかりな美僧であった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃りたての頭に庭木のみどりがてらてら映って見える。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため、夜陰に乗じ、恥をしのんで、おすがりに参った次第で……」　と、こもごも、剃りたての頭を、床にすりつけて、信雄に頼んだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "本通りの大まがきの方からは、拍子をはずませて打ちだす太鼓の音が、変に肉感と冒険心とをそそりたてて響いてきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この剃刀で、貴方を、そりたての今道心にして、一緒に寝ようと思ったのよ。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると急に気も軽く、窓さきに濡れながらそよいでいる痩せ痩せたコスモスの花も、遥か下に煙って見ゆる渓の川原も対岸の霧のなかに見えつ隠れつしている鮮かな紅葉の色も、すべてみな旅らしい心をそそりたてて来た。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、雨戸をあけな」　あけさせてみると、いかさま座頭仙市がそりたてのくりくり頭をかかえるようにして、こちらに背を向けながら、じつに必死と震えているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりたての御弟子頭のそのみずみずしさ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "手が動くにつれて盛りあがった乳房が生まなまとした感覚をそそりたてるようである。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの土地は、なにか踏みいれば驚天動地的なものがあるだろうと、聴くだに探奇心をそそりたてる神秘境なのである。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ赤なつやつやした色が、食欲をそそりたてずには、おかなかった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ彼はうづくやうなものを、そそりたてられる思ひもした。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
