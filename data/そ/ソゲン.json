[
  {
    "uuid": "0ace2878-aa8b-5912-952e-6f9f5aa795a5",
    "entry": "素元",
    "reading": {
      "primary": "そげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prime element",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おばあさんは、孫の久助君を甘やかすのが癖だつたので、「そげん慌てて出かけでもええだ。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そげんかこついうたっちゃでけん、あげなさい、何か書いてもろうてやるけんよかたい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そげんか支那服いつでん金ば出しゃ買わるっじゃろが。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そげんすぐ欺されなはんならでけん。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそげんか事いわんちゃよか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしあ、そげん卑俗きこつ知らん。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん先の、そげんに遠くなかですけん。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠いとこさ、一人で行ってしまいたか」「お前は、めんめさえよければ、ええとじゃけに、バナナも食うつろが、蓮根も食いよって、富限者の子供でも、そげんな食わんぞな！",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そげん山の芋の好きな男がおりますか？",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な人に紹介して上げます」「真平ご免だ」「胃病が癒りますばい」「癒らんでも差支えない」「そげん頑固張りなさるならやむを得ません。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりしなさいよ」「そげんこというたって、世間には、オンテレ・メンピンが、多かとばい。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "……フン、自分で勝手にきめたって、あたしの知ったことか」「そげんこつかい？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そげんかことしたら、お京さんに叱られます」「いかん、いかん。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばって、そげん、敵味方の親分衆が集まって、なんごとも無う、すむじゃろか？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そげんとこで、なんごとば、しよるとな？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、口約束だけで、結納を取りかわしちゃ居らんらしいけん、そげん、むずかしか問題も起るまい。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そげんいやあ、あんたのお父ッあんと、おッ母さんも、昔、好きあうて夫婦になりござったごたる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "糞う、そげん何時もかつも、柳の下に泥鰌が居るもんか。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そげんこた、初めからわかっちょる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この左股、……なんか、ブリキ缶の切片のようなもんがありまして……」「そげんか足どりじゃあ、沖の現場にゃ行かれんばい。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そげんこつぁ知らん」。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何じゃい、――的野（来島の旧姓）じゃなかか、そげんとこで何しよっとか？",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解せんことをいうのう、――去年は福岡で井上を追っかけ廻しとった貴様が、どうしてそげん変ったんじゃろ？",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこんとこが肝腎じゃなか、――今に見ろ、反対論はますます上下を圧倒してくる、伊藤が枢密院をやめたのは、そげんときの来るのを見越したからじゃ」。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
