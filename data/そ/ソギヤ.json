        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "根こそぎやられて、それこそ玉なしだア」　ひろ子は全身の注意をよびさまされた。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦災で根こそぎやられた分を取りもどしたうえその二年間の進歩に追いつかなきゃならぬ私らです。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　そぎやんした相談ばもちかけられたばツてん、わしや断わつた。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そぎやん云ふつてちや、今から、いくらなんでもなあ……。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　いつそ共（みんな）そぎやんいうとるけんたい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　ほうら、そぎやんいうて、あんたが喋舌つてしまふけん、好かん……。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そぎやんむつかしかこといはんてちやあ、一枚写しておきなはりまつせ。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　そぎやん威張るなら、お千代さんの写真ば見せちみなはり。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　そぎやんこというとつて……。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡　　そぎやん顔して、なんたいな、とつけむにやあ。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてそぎやんこついはるツとな？",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　そぎやんこつ云ふても、しよんなかもね。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "よね　　（岡を見て）そぎやんところで、あんた、なんばしよツと？",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "金田　　奴こそなんか、そぎやん太か脚ば、出やあち……。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "とみ　　そぎやんこつ、わしに云ふたてちや知らんけん。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やす　　（鵜瀞に）なして人の顔ば見とつとな、そぎやん眼つきばして……。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そぎやんこつ云ふた奴の顔ば見たか。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（うるさくつてね）やす　　ピポオつて好かんやつ、そぎやん時ばつかり、役人｜顔して……。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そぎやんだろもん、今までこぎやんこた、なかつた。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "よね　　そぎやんこつていふもな、わからんやうで、何時の間にだいろ、知れるもんばい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月や二月、そぎやんこつしてみたとこツで、幾りやんもなりやせんぢやなツか。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、きまつた男があつてえ、そぎやんこたあ、己にやでけん。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　そぎやんこと云ふと、また悲しうなるぢやありまつせんか。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　そん話しや知らんだつたばツてん、おつ母さんな、いつでん、男をもつなら西洋人に限るて、そぎやん云ふとつて……。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの前でん、平気でそぎやん云ふとばな。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "よね　　どうしたと、そぎやん苦しかかい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やす　　ところが、そぎやん早うはなほらんとだるけん……。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やす　　そぎやんばつかりも云はれんたい、こツでもな。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "よね　　お前も、そぎやんした気になつたかい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、本人は、そぎやんまぢや、喜うどらんとばい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
