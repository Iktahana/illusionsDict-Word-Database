        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例のポオラの町の若い連中は、公園のあるあたりから水を渡ってひびいてくる軍隊の号音にも、おそらく愛国的に心をひかれたのであろうが、甲板にあがってくると、アスティ酒のいきおいで、対岸で調練をしている狙撃兵たちにむかって、万歳をとなえた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらでは僕は部下の狙撃兵をもっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊はスペイン兵四百、土人兵二百であるが、スペイン兵のうちで小銃狙撃兵は僅かに十三人、弩狙撃兵さえも三十二人に過ぎなかった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "と突然、高地の頂には砲兵と狙撃兵とのほか何も見えなくなった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "優秀な狙撃兵に射たれでもしたように、突然がくっとなり、しばしば地面にぶっ倒れる者もある。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿を見られないうちに三発撃った腕前は元狙撃兵仕込みだ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
