        "examples": {
          "standard": [
            {
              "text": "背景画像を固定せず、親要素からの相対位置でボタンを配置すると画面サイズが変わっても崩れません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "潜水艦のソナーは、自艦を起点とした敵艦の相対位置を常に計算し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卓球のダブルスでは、パートナーとの相対位置を把握していないと同士討ちの危険がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "まず最も分明な差別はこれらの視覚的対象と観客との相対位置に関する空間的関係の差別である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの物が中にあると、右下にしたり、左下にしたりすると、その目方で胃袋が垂れ下がらねばならないのに、あなたの胃袋は、周囲の臓器との相対位置が、ちっともかわらないんです。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
