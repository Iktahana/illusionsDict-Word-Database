    "definitions": [
      {
        "index": 1,
        "gloss": "to chip (off)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうせ日本服があるなら、羽織を何時でも着て、折角の着物の趣を削ぐ風俗も少し改まればいいと思う。",
              "citation": {
                "source": "働くために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会に出品する画材は、前もって発表するということは興を削ぐので、それだけは私の胸中にそれを制作する機運の来るまで発表は出来ないけれど、いまここで語っていいものに楠公夫人の像がある。",
              "citation": {
                "source": "楠公夫人",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これを変えることに致しましょう」　皮膚を鞣す音、肉を削ぐ音、骨を削る音が聞こえて来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角の楽しい気分を削ぐ憎い奴だと思って、帆村は活動函から顔をあげてその方を見た。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の後蝦夷は着々山背大兄王の勢力を削いで、遂に之を弑し奉つたが、其の經過を觀ると太子が生前に蘇我氏の勢力を削ぐ爲に、自分の親信する者をとりたてゝ居られたことがわかる。",
              "citation": {
                "source": "聖徳太子",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の契約を妨害し、林の勢力を削ぐためにやった仕事のようにも考えられるのだが、すると大金剛石の方はどうなる。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその土掻の刃で、土の上かわを三寸ぐらいずつ削ぐように掻いて、籠へ土を盛りこんだ。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って、耳を削ぎ鼻を削ぐ一寸だめし五分だめしも、その苦しみの時間は知れたものです。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければこう鮮やかに、頸動脈を狙って、貝の肉を削ぐように抉れている筈はない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、魂はにがい深淵だぞといふやうなことを我々日本人が云ふと、一寸そぐはない感じがしよう。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外には程近い山王台の森から軒の板庇を静かにそそぐ雨の音も佗しい。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しほだる花や水の音や、家路をいそぐ人々や。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬上を住家とした古人の旅を思いながらも、樹下石上に眠らずに、木口新しく、畳障子の備わった室とはいえない屋根の下に、楽々と足を延ばし、椎の葉に盛った飯でなく、御膳つきで食事の出来る贅沢を、山中の気分にそぐわぬと思いながらも、その便利を享楽した。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山葡萄は矢張り人家にはそぐはないと見える。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって職業上の名の小そのとだけでは、だんだん素人の素朴な気持ちに還ろうとしている今日の彼女の気品にそぐわない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜仙台の新聞で欠食児童何百という表題の記事を見て来たばかりの眼には、この目前見渡す限りの稲の秋は甚だそぐわない嘘のような眺めであった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その凝固した空気の中から絞り出されるように油蝉の声が降りそそぐ。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚一枚に眼を晒し終つて後、さてあまりに尋常な周圍を見廻すときのあの變にそぐはない氣持を、私は以前には好んで味つてゐたものであつた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ほお‥‥‥』と、我知らず答へた時、私は總身の緊張感もほぐれたやうな、またお前の身に迫る次の危急な瞬間も忘れてしまつたやうな、その場合には餘にそぐはない心の弛みを感じて、水島の顏を見返した。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それは二人の今密かに感じてゐる或る心持にそぐはなかつたやうに見えた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お正月も過ぎてしまえば、たのしみとして待ったほどのことはなく、あまりにあツけなく過ぎて結局又一ツ年を取って老いて行くのだが、それでもなにか期待の持てる張りあいのある気持で、藁をそぐってかざりを組み、山へ登って、松を伐ってくる。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先をいそぐ身は今更引っ返して詮議もならないので、彼女は娘をそのままにして先方へ行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚一枚に眼を晒し終わって後、さてあまりに尋常な周囲を見廻すときのあの変にそぐわない気持を、私は以前には好んで味わっていたものであった。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ああ、そうですな」少し間誤つきながらそう答えた時の自分の声の後味がまだ喉や耳のあたりに残っているような気がされて、その時の自分と今の自分とが変にそぐわなかった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅びた主家の家臣らが思い思いに離散して行く感傷的な終末に「荒城の月」の伴奏を入れたのは大衆向きで結構であるが、城郭や帆船のカットバックが少しくど過ぎてかえって効果をそぐ恐れがありはしないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウンラートが気が狂ったのを見て八重子のポーラが妙な述懐のようなことを述べるせりふがあるが、あれはいかにも、ああした売女の役をふられた八重子自身が贔屓の観客へ対しての弁明のように響いて、あの芝居にそぐわないような気がした。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、なぜ僕はすべてに斷定をいそぐのだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り淋しそうに道をいそぐ女の足音。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（蓮月、偈を繰り返し乍ら香湯を盥の仏にそそぐ。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
