[
  {
    "uuid": "12ac3683-1f64-5f90-96ae-23fc6ac7dffb",
    "entry": "総量",
    "reading": {
      "primary": "そうりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
