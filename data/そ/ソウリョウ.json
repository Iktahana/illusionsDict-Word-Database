    "definitions": [
      {
        "index": 1,
        "gloss": "cool and refreshing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旧弊で煩瑣なものは、みんなぶちこはされて、一種の革命のあとのやうな、爽凉な気がゆき子の孤独を慰めてくれた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "爽凉の気、外苑あたりの叢園に漂ふ昭和二年の秋の一日である。",
              "citation": {
                "source": "呉清源",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
