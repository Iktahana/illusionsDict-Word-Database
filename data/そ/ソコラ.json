  {
    "uuid": "2f7c13b4-e566-5e11-ae83-869f8acac6dd",
    "entry": "其処ら",
    "reading": {
      "primary": "そこら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
