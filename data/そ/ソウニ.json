    "definitions": [
      {
        "index": 1,
        "gloss": "monks and nuns",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "又印度でも僧尼は獨身者で、乞食は淨行であつた。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの僧尼達は、自分が手を動かさずして世を渡り、そのうえ戒律を守らないで、婬を貪り、葷を茹い、酒を飲んだので、牛馬にして人に報いをさすところだ」　三人はまた次の処へ往った。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舍内の靜けさ、僧尼の房の如くならんは、人々の願なるに、このベルナルドオあるがために、平和はいつも破られき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その調はかの笛ふきが笛にあはせし搖籃の曲に似たり、又或時は野邊送の列、窓の下を過ぐるを見て、これをおくる僧尼の挽歌を聽き、昔母上を葬りし時を思ひ出しつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬葉集の中には、博通、通觀、滿誓、惠行、妙觀、その他の僧尼の歌をも納めてあるが、いづれも生き、愛し、死ぬる存在に、まともにぶつかつて行つた歌のやうである。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "千一百年に、僧尼嫁娶せん、僧｜毘尼を毀謗せん。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "千二百年に、諸僧尼らともに子息あらん。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかれば穢悪濁世の群生、末代の旨際をしらず、僧尼の威儀をそしる。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昔、慈覚大師仏法を習ひ伝へんとて、唐土へ渡り給ひておはしける程に、会昌年中に、唐の武宗、仏法を亡して、堂塔を毀ち僧尼を捕へて失ひ、或は還俗せしめ給ふ乱に逢ひ給へり。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く　上林み寺の禅尼放胆に物はいへども知らず山の名　僧尼をからかふ気持は昔からあるが元来笑談のすきな晶子さんにこの種の作のあることもとよりその所である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど僧尼が家族の羈絆の外に超脱するが如き、支那人の孝道第一主義から觀ると、飽足らず思はるる點が尠くない。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "六朝時代を通じて、僧尼は離俗出家といふので、その父母を拜せず、却つて父母の禮を受くるを例とした（唐の彦※「集沙門不應拜俗等事」【『縮刷藏經』露帙七册所收】）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧尼不得受父母及尊者禮拜。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の如くして唐以後僧尼は、歩一歩と支那人の所謂孝道主義の埒内に追ひ込められて來た（『唐明律合編』卷九參看）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち支那の僧尼は、全然家族主義孝道主義の約束の下に立ち、この點では何等俗人と區別がなくなつた。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたり一帯、人煙稀薄、枯すすきの原さえつづいているのだが、寛永寺末の、院、庵のたぐいが、所まだらに建っていて、おおかたの僧坊は、信心深そうな僧尼によって住みなされていた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁和寺、大覚寺をはじめ、諸｜門跡、比丘尼御所、院家、院室等の名称は廃され、諸家の執奏、御撫物、祈祷巻数ならびに諸献上物もことごとく廃されて、自今僧尼となるものは地方官庁の免許を受けなければならないこととなった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い寺院に肉食妻帯の厳禁を廃し、多くの僧尼の生活から人間を解き放ったというのも、虚偽を捨てて自然に帰れとの教えから出たことである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体僧侶の肉食妻帯は、我が僧尼令の厳禁するところで、酒を飲み、肉を食い、五辛を服するものは三十日苦使せよ、僧寺に婦女を停むる一宿以上ならば十日苦使せよ、五日以上ならば三十日苦使せよ、十日以上ならば百日苦使せよとある。",
              "citation": {
                "source": "特殊部落と寺院",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば我が大宝令にも、僧尼乞食の規定があり、「霊異記」には真の修行者が加賀で浮浪の長からその配下たる事を強いられた談もある。",
              "citation": {
                "source": "特殊部落と寺院",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　在家の法師　法師に関する厳格なる規定は、大宝令中の僧尼令に詳しくみえている。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち令外の僧尼である。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらはいずれも自度の沙弥で、養老の詔に指摘したる、僧尼令にいわゆる僧尼以外の俗法師ではあるが、ともかく奈良朝において、すでに僧侶としての存在が認められていたのであった。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時宗に尼を妻とするは此故にや」という話があるが、僧尼の夫婦の由来はさらに久しいものであった。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　浮浪の法師　大宝の僧尼令に規定してある僧尼は、必ず寺院に住するということが一つの条件であった。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "元正天皇の行基厳戒の詔にも、僧尼は寺家に寂居して、教えを受け道を伝うとある。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "欽明天皇十三年に仏法が伝わって後も、僧尼・律師・呪禁師・沙門等の称はあるが、法師の通称はみえておらぬ。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　菩薩と声聞――浄行僧と声聞師　法師が本来いかなる者であるべきかということは、すでに前号「俗法師考序論」に述べた通りで、今さらここに言うには及ばぬが、わが大宝の僧尼令の規定はかなり窮屈なもので、戒律を持することを厳重に命じたものであった。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこれだけです』と煩わしそうに言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が佳境に入って来ると、ヘルンは恐ろしそうに顔色を変え、『その話、怖いです、怖いです』といっておののきふるえた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
