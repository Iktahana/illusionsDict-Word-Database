        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうでないかも知れない。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないものは塵塚に捨てられ、存在をさえ否定された。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岳に登ったことのない人は、山の頂点に行けば行くほど、寒いから雪が多量に積むものと考えているらしいが、事実はそうでない。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような場合に、短期の材料から得た週期が単に偶然的のものである場合もあるが、またそうでない場合がある。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし作者によってその顔が非常にはっきり出て来るのと、そうでないのとがある。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないと信じたくなかったのであろう。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なら、早くそれをやればいいじゃないか」　柚木は老妓の顔を見上げたが「やればいいじゃないかって、そう事が簡単に……（柚木はここで舌打をした）だから君たちは遊び女といわれるんだ」「いやそうでないね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると老妓は「いや、そうでないねえ」と手を振った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのような矛盾のままで性格が固定し切っているかと思えば、そうでない。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "釘に引っかける札の穴の周囲を疵だらけにしている人と、そうでない人との区別もあるらしい。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないと往々重要なものを見落す虞がある。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでない場合には浅墓な三面記事と選むところはないのである。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通に批評家がある作物を見て、不自然であるとか、そうでないとかいうのはすなわち如上の意味においてである。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際は幸か不幸かそうでない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、もしもわれわれが音源の距離方向を判断する能力が非常に鋭敏であったら、トーキーというものはたいへんやっかいな問題に出会うであろうが、そうでないのは幸いである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでない場合でも、何かしら考える事の種子くらいにはならない事はあるまい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその他のものにおいては、必ずしもそうでない。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、「う」と書かれたものの大部分は、後に鼻音を脱却して純粋のウ音になったが、そうでないものは、後までもン音として残っただけの相違であろう。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風に、『古事記』には清濁を書き分けてあるけれども、たまたまそうでないものもあるように見えることもある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであとからあとから縫い手が押しかけてくれればともかく、そうでないとすると一分に一針平均はよほど六ヶしいであろう。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような消極的な思想は現代の青年などにはおよそ縁の無いもののようにも思われるが、しかしよく読んでみると必ずしもそうでないようである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと考えただけでは動物園の実物の方がよさそうに思われるであろうが、実は必ずしもそうでないのである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論個人個人についてではなくただ平均の上でそうでないかと思われるだけである。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと考えると、大学教授などというものは、正しくそういう立場にありそうに見えるが、事実は必ずしもそうでない。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは無論三日月に象ったものだろうと思われていたが、だんだん調べてみるとそうでない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の遠泳会にも出られそうでない……。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでない、これらの人々を見た時の周囲の光景の裡に立つこれらの人々である。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "動かぬもののたとえに引かれるわれわれの足もとの大地が時として大いに震え動く、そういう体験を持ち伝えて来た国民と、そうでない国民とが自然というものに対する観念においてかなりに大きな懸隔を示しても不思議はないわけであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでもしこの世の中に「善い事」が一つそしてただ一つしかなかった場合には事がらは誠に簡単であるがたぶんそうでないとなるとめんどうになって来る。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないところを見ると、紅の花はやはり紅でなければならない理由があるように思う。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
