    "definitions": [
      {
        "index": 1,
        "gloss": "collection of stories",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（鉄囲山叢談）　　　古御所　洛陽の御所は隋唐五代の故宮である。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二宮尊徳に似た手段は先哲叢談続編に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "叢談に此人の字を子幹に作つたために、世に誤が伝へられてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先哲叢談續編に「先生後獲罪、謫在越之高田、（中略）無幾王室中興、先生嘗得列官于朝」と書してある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のベルリン駐※公使なる西園寺侯は新たに仏国より帰りて、二、三の同志を糾合し、たとえ暫時なりとも『東洋自由新聞』を発行せしこと、および今の兆民居士、中江篤介氏が帷を下して徒を集め、故田中耕造氏らとともに仏国の自由主義を講述しもって『政理叢談』を刊行せしことは、これ実に自由論派の嚆矢というべきか。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "中江氏らのおもに崇奉せしはルーソーの民約論なるがごとく、『政理叢談』はほとんどルーソー主義と革命主義とをもってその骨髄となしたるがごとし。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "その説は深遠にしてかつ快活なるがごとく、一時は壮年血気の士をして『政理叢談』を尊信せしむるに至れり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "南宋初期の蔡絛の『鐵圍山叢談』卷三に、「｛柳｝開喜生膾人肝。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる不面目を避くる爲め、徽宗は宰相の蔡京と相談の上、典獄に旨を傳へ、その嫌疑者を獄中で自殺せしめ、親殺し事件を暗から暗に葬り去つたことが、南宋初期の蔡絛の『鐵圍山叢談』（卷二）に、下の如く記載してゐる。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの上は旧藩地について個人の家々に残っているものを探し出す外はない、尤もこれらも、明治の初年に久松家から当時の老人連に嘱托して旧藩代々の君侯はじめ臣下や人民の特種な事蹟を調べさせられたものが、松山叢談という三十巻ばかりのものになっている。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は火災保険生命保険の必要を論述せんとして曲亭馬琴の夢想兵衛を引き、日本に於ける金銀価格の歴史を論ぜんとして先哲叢談に朱舜水が日本金価廉也、中国百倍之といへるを引けり。",
              "citation": {
                "source": "明治文学史",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕元に有朋堂文庫本の『先哲叢談』が投げ出されてあった。",
              "citation": {
                "source": "梅雨晴",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伝は原念斎の『先哲叢談』に審である。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "撃剣叢談巻の二、微塵流のくだりに。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤井懶斎が凶宅に住せし話は『先哲叢談』にあるも、その源は『閑際筆記』より引用したるものである。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "常山紀談などによると、所司代｜板倉勝重が、薙刀を持って出たり、撃剣｜叢談では勝重の家来太田忠兵衛が働いたり、いろんなことになっているが、話の脚色はともかくとして、いったいこれがあった事件か。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずらずきの子どもたちは、顔をみあわせながら、目と目で、神さまをつかまえようよ、とそうだんしました。",
              "citation": {
                "source": "子どものすきな神さま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでちょうちょうたちはみんなでそうだんをして、木のところへやっていくことにきめました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、まあ、それをどうするか、まあ、わたしのいいなずけにそうだんしてみましょう。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしには、そうだんしてくれないのかしら。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処でも小作争議が起りそうだんだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大きな大人のくせに、僕に何だってそうだんするんだぜ」「僕のおとうさんだってしからないよ。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんとそうだんをして、東京で給仕でもして、夜学に行って勉強したいのだそうです。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じつは、あなたにぜひごそうだんしたいことがありますので、あちらまできてくださいませんか」　エキモスはニコニコしていいました。",
              "citation": {
                "source": "銀の笛と金の毛皮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから一たん船をかえして、パリ大学に滞在中の長良川博士にそうだんした方がいいと思う。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "國民ぜんたいが、ひとところにあつまって、そうだんすることはできません。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "おだやかにそうだんをして、きまりをつけようというのです。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンドリヨンも、やはりそういうことのそうだんに、いちいち使われていました。",
              "citation": {
                "source": "灰だらけ姫",
                "author": "またの名「ガラスの上ぐつ」",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く、どうしてそれをぬすみだすか、その方法をごそうだんしようじゃありませんか」「いや、トニーの言葉だけれど、いくらぬすむといっても、かりにも潜水艇一｜隻だ。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、武夫は二人にそうだんしました。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
