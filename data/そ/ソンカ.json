          "literary": [
            {
              "text": "之を以て轉定の異前と爲し、是が動陽儀を天體と爲し、靜陰儀を地體と爲し、天地を二と爲し、上尊下卑の位を附す。",
              "citation": {
                "source": "安藤昌益",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――『パーヴェル・アンドレーヴィチ様尊下。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんか化け物が出るのか。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんかわり、人がなんと云ふたてちや、好いたこたあ、すツたい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
