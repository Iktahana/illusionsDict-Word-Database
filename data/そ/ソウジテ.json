        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "総じて陰気くさくつて而もバラ／＼だ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて氏の物の見方、感じ方が甚だ冷かであると非難されるのは、さうした処に起因してゐるのだと私は思ふ。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて寝ていても口を結んだ奴は、蓋をした貝だと思え。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "句が総じてダレています。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて、獣よりも鳥が好き、人間は人間にヨリ遠いものほど反感をうすらげますね。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の野花のいろは総じて紫か黄、白で、精々華やかなものでは淡紅色がある。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山手は総じて樹木が多いが、其中でも赤坂は町の少いかはりに樹木が多く、青山南町、丹後町、氷川町、新坂町辺は庭に樹木が植ゑてあるといふよりも樹木の中に家が建つて居ると言つた方が適当で、此樹木の中に紳士の立派な邸宅が奥ゆかしく潜んで居るのです。",
              "citation": {
                "source": "夜の赤坂",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣けもせずキョトンとしているのを引き取ってくれた彦根の伯父が、お前のように耳の肉のうすい女は総じて不運になりやすいものだといったその言葉を、登勢は素直にうなずいて、この時からもう自分のゆくすえというものをいつどんな場合にもあらかじめ諦めておく習わしがついた。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の文庫版は、この後のに従ひ、それまでを総じて原版と見なすことにした。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛に溺れ惑ふ者を見て、粋は之を笑ふ、総じて迷はざるを以て粋の本旨となすが如し。",
              "citation": {
                "source": "粋を論じて「伽羅枕」に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲劇は総じて荘重なる調子を要する者なり、因と果との照応、尤も緊切なるを要する者なり、冗漫なる舞蹈は悲劇に対する風情を損することあるも、之を増すことはあらじ。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二　文字の発明は疾くに人間世界から伝わって、彼らの世界にも知られておったが、総じて彼らの間には文字を軽蔑する習慣があった。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じてポナペには顔立の整った島民が多いようだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて私は人から物を呉れるとき遠慮はしない。",
              "citation": {
                "source": "私の日常道徳",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて北向きの風が吹いてきたので、シエラレオネに行くのが最善と考え、船首をその方角に向けた。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いかがでございましょう、ちょいとお目に、」と御身分柄、お家柄、総じては日本の国風を心得ないことを言うのである。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて寝て居ても口を結んだ奴は、蓋をした貝だと思へ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "福田氏の作品で色彩の濃厚な出来栄へのものには、総じて平面的変化でない、立体的な生々しい物質感がでたものが多く、この質的昂揚に接するとき、若い時代的な画学生は、また一人前の画家も、福田氏の仕事の研究的対象となることを痛感するのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "福田氏の最近の作品ではその色彩の淡い物に、色のマンネリズムに陥つたものも少くない、また同時に氏の作品の特徴として、その作品が総じて図様化されたものが多く、この模様のやうな方法が度がすぎた場合は迫力にとぼしく、質感もまた形の制約性の中に閉ぢこめられて、生々しい所謂清新なる色彩はでゝゐない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて色彩の飽和に乏しいのが難だが真剣さが何より心強い。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "旺玄社の作品は総じて審査の上に、個々の作家の個性尊重の立場にある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事が今年は丹念になつてきたのでいゝ『孔雀』がいゝだらう、テーマはこの作者のものは総じて弱い。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "色彩は総じて良くない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて複雑した脚色は当の作者自身といえども往々混錯して往々迷路に彷徨するは、あたかも自分の作ったラビリンスに入って出口を忘れるようなものだ。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く見つけなよ」「いいえ、物事は総じてこまかく運ばねえと、とかくしりがぬけるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨となるか、あらしとなるか、いかなる遺恨子細によってかかる封じ手を用いようとするにいたったか、事は疑問の慓悍児秀の浦の告白にすべての興味がつながれることになりましたが、しかし総じて物事というものは、とかくいま一歩ひと息というところで蹉跌しがちなものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一｜太刀、二｜槍、三｜鎖鎌、四弓、五馬の六泳ぎといってね、総じて武芸というものは、何によらず、恥ずかしがっていると上達しねえものなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "総じて渋い装幀の学術的なものが多い。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『歎異抄』に「念仏はまことに浄土に生るゝ種にてやはんべるらん、また地獄に堕つべき業にてやはんべるらん、総じてもて存知せざるなり」といえる尊き信念の面影をも窺うを得て、無限の新生命に接することができる。",
              "citation": {
                "source": "我が子の死",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父よ、もしみこころにかなはばこの杯を我より離したまへ、されど我が意のままをなすにあらず、唯みこころのままになしたまへ」とか、「念仏はまことに浄土にむまるるたねにてやはんべるらん、また地獄におつべき業にてやはんべるらん、総じてもて存知せざるなり」とかいう語が宗教の極意である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
