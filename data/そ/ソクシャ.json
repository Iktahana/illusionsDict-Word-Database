        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "side car",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｎ女（Ｂの令妹）を徒歩にて帰らしめＢの側車に搭乗して病院へ送らる。",
              "citation": {
                "source": "五月のはじめ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と僕は空の側車を指差した。",
              "citation": {
                "source": "センチメンタル・ドライヴ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と云ふがいなや、側車に腰をかけた。",
              "citation": {
                "source": "センチメンタル・ドライヴ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この側車に彼女をのせて花々しく帰つて来ようと思つてゐたところなのだ。",
              "citation": {
                "source": "センチメンタル・ドライヴ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "達ちゃんは石津隊の本部付の側車です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "にゃごとこくきゃ、こんちくしょう、あらいやばん、こなたのそくしゃあか、ぞうだんしんさんな」　とお芳さんが一｜瀉千｜里で言った。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あら厭ばん、此方のそくしゃあか、冗談しんさんな」「成程、分る。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談しんさんなは優しくて好い」「こなたのそくしゃあかとは何ういう意味だね？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
