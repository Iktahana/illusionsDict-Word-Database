[
  {
    "uuid": "2ada49a1-9833-5de5-9263-fec1cbba2e27",
    "entry": "其れ処",
    "reading": {
      "primary": "それどころ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
