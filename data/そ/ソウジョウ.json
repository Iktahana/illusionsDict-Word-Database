[
  {
    "uuid": "6e43bb84-1c5e-50e3-a519-3ef3d48fd9be",
    "entry": "僧正",
    "reading": {
      "primary": "そうじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "high Buddhist priest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は鳥羽僧正の戯画を見る時に、そこに描かれた動物の群から人間の痴愚をさしつけれれる。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邸宅はもとノリッチ僧正（Bishops of Norwich）の宮殿であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな空想にふけりながら自分は古来の日本画家の点呼をしているうちに、ひょっくり鳥羽僧正に逢着した。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし僧正｜遍照は天狗を金網の中へ籠めて焼いて灰にしたというが、我らにはなかなかそのような道力はないから、平生いろいろな天狗に脅されて弱っている、俳句天狗や歌天狗、書天狗画天狗｜浄瑠璃天狗、その上に本物の天狗に出られて叱られでもしたら堪らないから筆を擱く。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に挙げた僧正遍照も天狗の化した鴟を鉄網に籠めて焼いたのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この祈祷をここですれば大僧正から百日間のアンジュルジャンスを与えるとある。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "イサーク寺では僧正の法衣の裾に接吻する善男善女の群れを見、十字架上の耶蘇の寝像のガラスぶたには多くのくちびるのあとが歴然と印録されていた。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の、きっと大僧正か僧正でせう、坊さんの講義が又はじまりました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の、きっと大僧正か僧正でしょう、坊さんの講義が又はじまりました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥羽僧正の鳥獣戯画なども当時のスポーツやいろいろの享楽生活のカリカチュアと思って見ればこの僧正はやはり一種のカメラをさげて歩いた一人であったかもしれない。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この僧正にアメリカ野球選手との試合を記録させなかったのは残念である。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は阿弥陀仏の化身親鸞僧正によって啓示されたる本願寺派の信徒である。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事柄は敢て議論ではない、吾等の大教師にして仏の化身たる親鸞僧正がまのあたり肉食を行い爾来わが本願寺は代々これを行っている。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私から見れば黄石公――壁に脱いだ、緋の外套は……そのまま、大天狗の僧正坊……」　多津吉は銅像の腰を透かして、背後に迫って、次第に暮れかかる山の寂寞さを左右に視たが、「燕尾服の口上が、土地の新聞社という処で、相当にあしらってくれる。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧正ともあるべきが、女のために詩人に成つたんだとね。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本尊の観世音は行基僧正の作で、身長一尺八寸であるといふ。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもザバタスが或時停めた馬車の中にアリバヤ侯爵夫人とグアスコの僧正とが乗っていたのだ相ですが、ところで、ザバタスが一体どんなことをしたとお考えです？",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ザバタスは先ず僧正に向って「坊さま、あなたのよき祝福を下さいませ」と云ったのです。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論僧正は彼の望むものを授けてやりました。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "花嫁と花婿はたがいに手をとりあって、僧正さまの祝福をうけました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋にもやはり畫家の方でさういふ議論も澤山あるし、日本の鳥羽僧正などの畫でも、別に些しも精細といふ點はないが、一寸點を打つても鴉に見え、一寸棒をくる／＼と引つ張つてもそれが袖のやうに見える。",
              "citation": {
                "source": "「自然を寫す文章」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日、己亥、晴、将軍家聊か御病悩、諸人奔走す、但し殊なる御事無し、是若し去夜御淵酔の余気か、爰に葉上僧正御加持に候するの処、此事を聞き、良薬と称して、本寺より茶一盞を召進ず、而して一巻の書を相副へ、之を献ぜしむ、茶徳を誉むる所の書なり、将軍家御感悦に及ぶと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、僧正さまが御坐禅の余暇に御自身でお書きになつた御本だとか、めづらしい本をお書きになつたものだと、けげんさうにお首を傾けて居られたお方もございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日、丙※、晴、阿闍梨公暁、園城寺より下著せしめ給ふ、尼御台所の仰に依りて、鶴岳別当の闕に補せらる可しと云々、此一両年、明王院僧正公胤の門弟となりて、学道の為に住寺せらるる所なり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の師の慈慧が僧正に任ぜられたので、宮中に参って御礼を申上げるに際し、一山の僧侶、翼従甚だ盛んに、それこそ威儀を厳荘にし、飾り立てて錬り行った。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧都だの僧正だのというのは、俗界から教界を整理する便宜上から出来たもので、本来から云えば、名誉でもなく、有るべき筈もないものだが、寂照が僧都にされたことは、赤染集に見えている。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今より六代の前、報恩寺に住持たりし偉運僧正が浄書したりと云ふ西行法師の山家集、これは我が財産中、おのれの詩稿と共に可成盗まれたくなしと思ふ者なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "モルジアナは大そうじょうずにおどって、みんなにかっさいされました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "メグは、もう一隻のボートにのっていましたが、ブルック先生とネッドにとって、よろこばしい存在で、この二人の青年は、メグがいるので、いつもよりいっそうじょうずにボートをこぎました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "雌牛もたいそうじょうぶで、相変わらずいい乳を出しますから。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
