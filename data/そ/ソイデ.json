        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」山田君は、何よりも先に、その箇所に目をそそいで言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬杖ついて、ぼんやり書物に眼をそそいでゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな、脆い器具類は、手にとり上げると、すぐ壞れるので、いそいで元の場所に置かれた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時には正午過ぎの「太陽」の強い光がくまなく降りそそいでいた。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」李はいそいで遮った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工夫がうしろからいそいで通りこす。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいでぁうなだ、この人さ随ぃで家さ戻れ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬をひいた人は炭俵をすっかり馬につけてつなを馬のせなかで結んでから「さ、そいでぃ、行ぐまちゃ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、そいでぁ、まんつ、」その人は牽づなを持ってあるき出し鈴はツァリンツァリンと鳴り馬は首を垂れてゆっくりあるきました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ポウセ童子も沓をはいてしまっていそいで大烏のうしろにまわってしっかり押えました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せ小さい釘のことであるから、ちからの容れどころが無く、それでも曲った釘を、まっすぐに直すのには、ずいぶん強い圧力が必要なので、傍目には、ちっとも派手でないけれども、もそもそ、満面に朱をそそいで、いきんでいました。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その不健康な、悪魔の許にいそいで出掛けた。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤兵衛は持ち合せの器に水を汲んで、草原の上にさし置き、いそいで後ずさりした。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その刑事たちが立ち去つてから、眞野は、いそいで葉藏の室へ歸つて來た。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　葉藏になにも臆測されたくない心から、言葉をえらばずにいそいで言つたのであるが、それはかへつておのれの耳にさへ無邪氣にひびいた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉藏と飛騨とは、ソフアに並んで腰かけて、トランプをしてゐたのであつたが、ふたりともいそいで立ちあがつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかなくさくて、ドロドロのものを着て、モンペにゴム長、男だか女だか、わけがわからず、ほとんど乞食の感じで、おしゃれの彼は、その女と取引きしたあとで、いそいで手を洗ったくらいであった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいで、もう、もどってきやしん？",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎はいそいでごはんをたべて、ひとり谷川に沿ったこみちを、かみの方へのぼって行きました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士はいそいでたきゞを入れる。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」老人は食器をしまい、屈んで泉の水をすくい、きれいに口をそそいでからまた云いました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士はいそいでたきぎを入れる。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいでおいらア四合ずつ毎晩｜逆上薬を飲むが鉄道往生する気になんねえッて言ったら、お神さんにそう言ってもう二合も買ってもらえッてやアがる。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての物の上に慈悲のような春雨が暖かく静かに降りそそいでいた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いのししむしゃのかぶとむしつきのあかりもつめくさのともすあかりも眼に入らずめくらめっぽに飛んで来て山猫｜馬丁につきあたりあわててひょろひょろ落ちるをやっとふみとまりいそいでかぶとをしめなおし月のあかりもつめくさのともすあかりも目に入らず飛んでもない方に飛んで行く。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎は早く仕度をして学校へ行ってみんなに又三郎のさようならを伝えたいと思って少しもどかしく思いながらいそいで家の中へ入りました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにね、朝は二時ごろから起きて薬を飲ませたり、おかゆをたいてやったり、夜だって寝るのはいつもおそいでしょう。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又五六日たって、フウねずみが、いそいで鳥箱先生のそばをかけ抜けようとしますと、先生が叫びました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道具仲間は、みんな順ぐりにこんなめにあって、こりてしまいましたので、ついにはだれもツェねずみの顔を見るといそいでわきの方を向いてしまうのでした。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とのさまがえるはそこでにやりと笑って、いそいですっかり店をしめて、お酒の石油缶にはきちんと蓋をしてしまいました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
