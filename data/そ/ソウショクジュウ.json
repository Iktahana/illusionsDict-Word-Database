        "examples": {
          "standard": [
            {
              "text": "サバンナには、シマウマやガゼルなどの多くの草食獣が生息している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "肉食獣に狙われないよう、草食獣は群れで行動することが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "動物園では、草食獣のエリアが特に広々と作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "蕈の類かと思って二つに割ってみたら何か草食獣の糞らしく中はほとんど植物の繊維ばかりでつまっている。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草食獣にある臼歯もあれば肉食類の犬歯もある。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さまが、「牛についていってごらん」と、おっしゃったので、僕は「四足獣、草食獣、複数の胃で、はんすうする」と、いった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらと見せた真白な草食獣のような歯。",
              "citation": {
                "source": "菊",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
