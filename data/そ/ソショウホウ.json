    "definitions": [
      {
        "index": 1,
        "gloss": "procedural law (as opposed to substantive law)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
