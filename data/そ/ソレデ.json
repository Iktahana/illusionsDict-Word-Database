        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其れでも私に取つては矢張面白くない事はなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同乘の小學生を注意して見ると、勿論みんな違つた顏であるが、其れで居て妙にみんなよく似た共通の表情がある。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始終居所が変るので其れで道庁でも知れなかつたのだから。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな立派な宝物がありゃア其れで可いじゃアないか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "又更に低きになると唯一時代に稱賛を博して、生活状態の不滿さへなければ、其れで滿足とするものもある。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は其れでも良心の苛責に對して編笠で其の顏を隔てた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れでも彼等が心に深く互の情を刻むまで猜忌の目を※つて居る勘次を欺きおほせることは出來なかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れでありながら些の威嚴も勢力もない彼は凡ての若者から彼を苛立たしめる惡戯を以て報いられた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで彼等は少しでも異つた出來事を見逃すことを敢てしないのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで彼は時々村落の店へ行つて豆腐の一｜丁位に腹を塞げた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れでも足らないで、お八ツにお煎を三枚貰ったのを、責って五枚にして貰って、二枚は喫べて、三枚は又ポチに遣る。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで他の文士諸君の作は如何かと、紅葉、風葉、天外其の他二三の人の作を読んで見たが、何の人も／＼、縦横自在の筆を以て、巧みに明治現代の生活を描いて居らるゝ、中にも風葉氏の青春を読んで、大に感服した。",
              "citation": {
                "source": "未亡人と人道問題",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、雨にそぼぬれた獣物が、一つところにじっと団り合って、お互の毛の臭い、水蒸気に混って漂う息の臭いを嗅ぎ合うような親密さ、その直接な――種々な虚飾や、浅薄な仮面をかなぐり捨てて、持って生れた顔と顔とで向い合う心持は、私の今まで知らなかった、其れで居て知らなければならない事だったのでございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯樣な譯で、銅山に毒があれば動植物に害を與へると云ふことは古來學者の定論で、農商務の官吏が皆正直でさへあれば其れで宜しいのである。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで賣買値段を申しますると灌漑用水の方は賣買が安い。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れでも百姓と云ふものは、綺麗な地面であるから菜を蒔いたら生へるだろう、芋を植へたら出來るだろうと迷つて居る。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも地方の無頼漢或は郡吏等を頼んで拇印を取れば其れで用が濟んだと思ふて居るのか。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで世間からは、那珂といふ人は我武者で、偏屈人で、常識を缺いて居るやうに誤解された。",
              "citation": {
                "source": "那珂先生を憶ふ",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで二万円｜乃至二万五千円の資本が無くては百エエカアの植林は出来ないと云ふ事に現在は相場が極つて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで土曜から日曜の両親や監督者の暇な日に一時に公園へ伴れて出る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで平生の入場料は三フラン（一円二十銭）だが、其晩に限つて六フラン取る事に成つて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで和睦の握手を交換する事なく武装を解くに到らずして各自動車に乗つて別れて仕舞つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで全く今晩は物に成つて居なかつた」と云つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで裳には改良の余地が一寸見付からないが、盛装の裾に幾段も襞を附けたり、又｜其裾に異つた切目を附けたりするので一｜生面を開くであらう。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで飛行は試みないが矢張毎日イツシイ・レ・ムリアウにある飛行場へ出掛けて行く。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで仏蘭西政府は本人に退去命令を下すと、ナルヂニイは「宜しい」と云つて、即日ドユペル・ドユツサンと云ふ単葉式五十馬力の飛行機に乗つて、巴里の郊外※ロン・グブレエから英国のロンドンへ「雲を霞」とお手の物で飛んで仕舞つたのは人人を一寸痛快がらせた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで馬車代｜丈は僕等三人で負担する事に決めて同行を約した。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで僕は無駄に時を費した上に某かの銅貨を其風来者に与へて礼を述べざるを得なかつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生際の好い人は其れでも好いが、さうでない人は何とか工夫を施したいものである。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで土地が変れば少しは気の紛れる事もあらうと良人に勧められて不順な天候の中に強ひて独墺及び和蘭陀の旅を思ひ立つのであつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
