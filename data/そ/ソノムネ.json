    "definitions": [
      {
        "index": 1,
        "gloss": "(words to) that effect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
