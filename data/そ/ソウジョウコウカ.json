        "examples": {
          "standard": [
            {
              "text": "チームワークにより、個々の能力以上の相乗効果が生まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "二つの企業が提携することで、大きな相乗効果が期待できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "異なる分野の専門家が集まることで、予期せぬ相乗効果が生まれることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "煙との相乗効果で、鉄の心も揺るがせる。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして音楽とモルヒネが相乗効果を及ぼした時、ワルマ卿の言動も話した。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして活発な観念は激情に新たな影響を及ぼし、その番になって（相乗効果で）その勢いと激しさを増大させる（正帰還増幅）。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
