    "definitions": [
      {
        "index": 1,
        "gloss": "selfless devotion to justice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
