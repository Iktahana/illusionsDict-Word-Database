        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フランスでは、ガストン・ルルーとモーリス・ルブランとが、恐らく同国探偵小説界の双璧でありましょう。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが舞踊の名手であったことは有名の事実で、その点においては団十郎と芝翫とが劇界の双璧とたたえられていたが、やはり頭が悪かったせいであろう、かれは江戸時代から台詞の記憶が悪い点においても有名であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛利先生と狩尾博士とは、日本精神病学界の双璧であったばかりでなく共に世界的に有名な学者であった。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から見ればそれが一時的のものであって、毛利先生はその後更にはげしい憂鬱に陥られたが、若し、先生の論敵で、先生と共に、日本精神病学界の双璧といわれて居る狩尾博士が脳溢血で頓死されなかったら、あのまゝ従前の活動状態に復帰されたかも知れぬ。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人が日本精神病学界の双璧だったことはすでに述べたが、毛利先生を堂上の人にたとえるならば、狩尾博士は野人であった。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者と後者とはカントが自然乃至自然科学に関して著した書物の内、その中心的な意味に於て、その独創に於て、従って又その後世に与え又与えるべきであった影響に於て、双璧をなすものと云ってよい。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず青野季吉と森山啓とは或る意味での双璧だろう。",
              "citation": {
                "source": "文芸評論の方法について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで世の人は津軽家の留守居は双璧だと称したそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "法水の友人で、胎龍と並んで木賊派の双璧と唱われた雫石喬村の家が、劫楽寺と恰度垣一重の隣にあって、二階から二つの大池のある風景が眼下に見える。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点では品川の三徳と双璧だが、三徳の方は深夜になると戸を閉めるのに反し、小林の方は夜通し表戸を開け放しなのである。",
              "citation": {
                "source": "或る夜の武田麟太郎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座裏の四辻は、虎ノ門事件と共に秦啓源についての双璧の逸話だった。",
              "citation": {
                "source": "秦の憂愁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代作家のものは多少は読んでゐたが、ロスタンとヱルヴイユウを当代の双璧と思ひ込み、或は思ひ込まされてゐたものゝ、本場の消息を探つてみると、少くとも、一癖ある批評家は、この二人を問題にしてゐないことがわかり、大慌てに慌てた。",
              "citation": {
                "source": "芝居と僕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹岡と鴨居は、東京湾口鯛釣場の双璧と称されているだけに、近年ここへ遊ぶ素人の釣師が夥しく増えて来た。",
              "citation": {
                "source": "葵原夫人の鯛釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいしくない点では※の卵と淡水魚中の双璧であるといわれている。",
              "citation": {
                "source": "鯰",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "松は豪壮勇偉な男子、竹は貞節ある淑徳な女子、これは誠に相応しい双璧ではありますまいか。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恵美須屋さんまた伊藤君と双璧ともいうべき熱心な金沢通で、ことに丹彩の技に長じて、神社の宝物その他を一々絵にあらわした帖を作られたり、伊藤君と謀って『後三年絵巻』の残欠を補うべく、研究考証の末に補遺十数巻を描いておられる。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "会津藩と薩藩がその双璧で二朱金が最も多くつくられたが、太政官札の不融通にくるしんだ明治政府が東京大阪の金銀座で濫造させた一分銀貨も、贋貨というにちかい品質のものだった。",
              "citation": {
                "source": "明治の五十銭銀貨",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "国表｜里見無念斎の道場において、師範代の遊佐銀二郎とともに無念流双璧とうたわれた篁守人、帰雁の柄をたたいて肩をそびやかした。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、小山内薫水野葉舟の二人は文壇に於ける好男子の双璧と云はれ、又小栗風葉の小説「青春」の主人公「欣哉」と云ふ大学生は、小山内氏をモデルにしたのだと云ふ風説があつたくらゐで、氏は真に秀才型の美青年であつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く彼の文才といふものは互に相許した友、檀一雄のそれと双璧をなすもので他にはちよつと見当らないと思ふ。",
              "citation": {
                "source": "稀有の文才",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本における新興コンツェルンの双璧。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本における新興コンツェルンの双璧、林謹直の林コンツェルンと小口翼の日興コンツェルンが、安南のボーキサイト礪山の採掘権を回って劇しい争奪戦を演じていることも、皇帝と林の間にまた新たな契約が結ばれかかっていることも、かねて加十は知っている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代日本における新興コンツェルンの双璧。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "受付から一転して平社員に、再転して課長心得に、五年目にはもう、笠森仙太郎と並んで、若手社員の双璧と云われるようになっていたのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両公左右の□臣たれども才徳年齢双璧をなさず、故に心｜齟齬して相｜和せず。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、五百名の門人の多くは諸侯の家士であったが、図書のもとで子飼から育った者の中に、松林甲子雄、仁木兵馬という二人は、門中の双璧といわれ、男ぶりも腕前も群を抜いた秀才同志だった。",
              "citation": {
                "source": "初午試合討ち",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病躯は重い鎧にも耐えぬほど弱々しかったが、官兵衛孝高とともに、秀吉の双璧といわれ、智略の嚢と恃まれていた彼でもあった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水崑の河童漫畫と双璧といへよう。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイオリン・ソナタ　六曲の無伴奏ヴァイオリン・ソナタ（並びにパルティータ）は、チェロの組曲と共に、バッハの器楽曲の双璧であるが、そのうちの優れたレコードは、「第一ソナタ＝ト短調」のメニューイン（ビクターＪＤ一二四七―八）を挙ぐべきであろうか。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
