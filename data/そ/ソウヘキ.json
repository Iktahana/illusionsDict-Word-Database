    "definitions": [
      {
        "index": 1,
        "gloss": "(two) matchless things",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
