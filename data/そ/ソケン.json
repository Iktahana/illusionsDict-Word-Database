    "definitions": [
      {
        "index": 1,
        "gloss": "coarse silk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは皮膚に触れると淡雪のように溶ける素絹のように濡れて薄く包む。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流は橋架に激して素絹の絡ツたやうに泡立ツてゐる。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、朝凪の浦の渚、潔き素絹を敷きて、山姫の來り描くを待つ處――枝すきたる柳の中より、松の蔦の梢より、染め出す秀嶽の第一峯。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫛の痕なき頭髮の蓬々たるに、寺の贈なる麗しき素絹の上衣を纏へり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は輕げなる寢衣を着て、素絹の長椅の上に横はりたりしが、我が入るを見て半ば身を起し、左手もて被を身に纏ひ、右手を我にさし伸べたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの貧人たちまち身のほどを顧み、恥じかつ恐れ入って人の見えぬような所に坐しいると、たちまち見る一人素絹と錦襴を被せ金の頸環、銀の鎖を付けた四疋の犬を牽き来り別室に維ぎ、去って金の皿四つに好肉を盛ったのを持ち来り、毎犬一皿を供えて出で行った。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、美奈子は周章てゝ、打ち消したが、彼女の素絹のように白い頬は、耳の附根まで赤くなっていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌に素絹の襦袢を着て単衣を着ている姿は、国持大名の小姓であることを語っている。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い素絹の寢衣を着た渡が、太刀を握りしめながら、馳け付けて來る。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪は地味な束髪ですが、ポッテリした丸顔で、皮膚は蝋燭の様に白く透通り、鼻は低いが口元は小さく、その丸い両の眼玉は素絹を敷いた様に少しボーッとしてはいますが、これが又何と言いますか、恐ろしく甘い魅力に富んでいるんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十に近い信西入道も我にもあらで素絹の襟をかき合わせた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛は、ふと鳥羽で別れるとき、妻の松の前から形見に贈られた素絹の小袖を、今もなおそのままに、持っているのに気がついた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、美奈子は周章てゝ、打ち消したが、彼女の素絹のやうに白い頬は、耳の附根まで赤くなつてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の方よりは足助の二郎重景とて、小松殿恩顧の侍なるが、維盛卿より弱きこと二歳にて、今年｜方に二十の壯年、上下同じ素絹の水干の下に燃ゆるが如き緋の下袍を見せ、厚塗の立烏帽子に平塵の細鞘なるを佩き、袂豐に舞ひ出でたる有樣、宛然一幅の畫圖とも見るべかりけり。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "力を養わずばなるまいぞ」「お言葉有難く存じます」「よいよい」　と云って信玄は、素絹の袖を左右に張ると、トンと軍扇を膝に突いた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして森や野や遠くの山まで一面に青白い素絹を投げた。",
              "citation": {
                "source": "湖水と彼等",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂やかな若衆すがたは、今、まるで生きているその人のように、生彩｜奕々として素絹の上にほほえみつつ、その日の思い出を永劫に生かそうとてか、片手にかざした白つつじの花ひと枝――　片里はながめ入りながら、酔ったような目つきをしました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "素絹のような少女の声と、楽器の単音が、傾いた金緑色の外景とともに、微かな寂寥を漂わせる。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　けれども朝に、こわれた古｜櫛で素絹のように流れたきれいな髪をとかす時には、おめかしの一瞬を楽しむのであった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵌玉のかぶと、磨銀のよろい、花の枝を繍い出した素絹の戦袍すずやかに、「宋江とやらのおからだを戴きましょうか」　と、言い払い、ホホとその白い花顔が闇を占めて笑っているかのよう。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪に紫紐金鳳の兜巾をむすび、裾長い素絹の衣を着し、どこか高士の風がある。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大江の水は、素絹を引いたように、月光にかすんでいた。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、趙子龍が振り向いてみると、雪のような素絹をまとった美人が楚々と入ってきて、「お呼び遊ばしましたか」と、趙範へいった。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおよそけんとうはずれな彼の解釈でした。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東地方では茨城県の筑波とか、遠くは福島県の会津地方のような、田畠がすくないか、または秋の農作のはやく片づく村から、群れをなしてその屋根葺き職の者が出てきて、大よそけんとうをつけ、または前の年からやくそくをして、今年葺きかえる家々を廻っていた。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
