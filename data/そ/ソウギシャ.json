[
  {
    "uuid": "7a7fad80-d081-5074-92e8-458dfde99a27",
    "entry": "葬儀社",
    "reading": {
      "primary": "そうぎしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
