[
  {
    "uuid": "94ad1d74-1cc9-5041-a76a-d608bd5d3bbd",
    "entry": "創作的",
    "reading": {
      "primary": "そうさくてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
