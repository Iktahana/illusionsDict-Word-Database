    },
    "definitions": [
      {
        "index": 1,
        "gloss": "creative",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頻繁なる対人圏にあつて、各人が各人で朗らかであり得ぬ程度に比例して人々は互の「顔色を覗ふ」こと盛となる、即ち相対的となる、即ち創作的気心より遠ざかるわけである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう考えれば科学者の欲求は芸術家の創作的欲望と軌を一にする訳である。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、胸には貴い感動がまた強く蘇り、一種の快い創作的興奮が私のすべてを生き生きさせた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一體私は有島氏のその作品｜竝に作者の心の世界に對して共鳴も有ち、その眞摯な作風に對して頭を下げてゐる者ですが、時に人が、有島氏は僞善者ではないか、非常にその創作的態度に於て、進撃的で、意志の強さうなところがあり乍ら、どつか臆病なところがあるではないかといつたやうな言葉を聞かされた事があります。",
              "citation": {
                "source": "三作家に就ての感想",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の冗漫弛緩の筆を徒らに伸ばしたやうな、所謂勞作を見れば見る程、その一字一句も苟しない氏の創作的態度に頭が下らずには居られません。",
              "citation": {
                "source": "三作家に就ての感想",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うにこの老人は一千一夜物語の著者のごとき創作的天才であったらしい。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、一方には、およそ有りふれた陳套な題材と取り扱い方をした小説の「創作」と、他方では、最独創的な自然観人生観を盛った随筆の「中間物」とを対比させて見れば、後者のほうが前者よりもより多く創作的であり、前者のほうがひと山｜百文の模造物への中間にあるものと考えられるであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際における創作的過程は映画監督のそれとかなりまで類似した点をもつであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし小説は、人生に於ける或る物語を描くのであるから、言語の広い意味に於て、一種の創作的な歴史、もしくは散文の叙事詩と思惟することができるだろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この編の記者は、教頭氏、君に因って、男性を形容するに、留南奇の薫｜馥郁としてと云う、創作的｜文字をここに挟み得ることを感謝しよう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、彼は既に一箇の小説として格好な題材を捉へ、且つそれを表現すべき格好な形式を作り出しながら、それを小説として完成すべく、その創作的態度の上に餘りに露骨に批評家としての野心を見せ過ぎてゐる。",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは永年の劇しい創作的努力と英国紳士としての対外的妥協の生涯から来た全身的疲労の一部だとも考えられる。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて精神的なもので、それは創作的なものだそうだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いもの等が三人互ひに奪ひあつて、立派な粒から先きへうまさうに喰つてゐるのを見て、義雄は、「それだけになるまでの間の、おれの創作的努力と苦心をも知らないで」と思つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧劇の芝居を見たつて、作者の創作的燃焼力が、あうんの彼方に感ぜられるものでない限り凡ての観客の夢を潤さぬではないか。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "講談師でもあれほどには話さないであろうと思われるほど、一切を創作的に述べるのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が前に述べた作品に漂ふ不安感や、焦燥感は、さうした創作的態度から滲み出たものであり、或は作者自身は、それを目的として描いてゐないだけに、本人が気づかないこと柄であるかも知れないのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの吉岡的な創作的苦悶は、一言にして言へば日本画的な或は日本人的な『線』に対する新しい理解が伴ふところの新時代的な苦悶のそれであろう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから『岩野を残して先に死にたくない』かう独歩が言つたのは事実だが、それを『渠の創作的態度に公けの疑問をさし挟んだのを気にして』はそれはウソだ。",
              "citation": {
                "source": "エンジンの響",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "理其者は創作的であって、我々はこれになりきりこれに即して働くことができるが、これを意識の対象として見ることのできないものである。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはある年、京都にゐたころ祇園から若王子へぬける道の道具屋にあつた、歌麿筆｜鐵※をつける女の圖がやはり墨と淡墨と緑の色調で、その繪を欲しいと思つてとうとう手に入れそこなつたので、その繪から受けた暗示が創作的な版畫の夢になつたらしくも思はれる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "坪内逍遙の「当世書生気質」は、日本の近代文学の第一歩の導きとなって彼の近代小説論「小説神髄」の創作的実験であったが、その作品の世界は書生という姿に於て踏襲されている昔ながらの遊蕩の世界であり、その遊蕩というものに対する作者の態度も、戯作者的現実追随の域を脱していなかった。",
              "citation": {
                "source": "作家と教養の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者には田舎者の句老人には老人の句山頭火には山頭火の句┌素質┐│年齢┼個性└環境┘┌創作的活動│　　　量よりも質└批判、沈潜、表現　一月十二日　晴――曇――時雨。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊三は久しぶりで、頭脳が冴えてゐたので、次ぎの間で、切迫して来る創作的興奮に駆られながら、せつせとペンを働かせてゐたが、どうかすると、先刻の兄の述懐が、頭脳に浮んで来た。",
              "citation": {
                "source": "籠の小鳥",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "発展する階級の複雑多岐な歴史とのつながりにおいて、自分をふくむこれら一団の作家群のなまなましい行状記を眺め直すと、私はある創作的衝動を心に感じるほどである。",
              "citation": {
                "source": "近頃の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会主義的リアリズムの立場に立って性格、心理を描くという課題も、この作品の創作的実践においては未だ解決されたといえないのである。",
              "citation": {
                "source": "作家への課題",
                "author": "――「囚われた大地」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合、松田氏は、自身の創作的態度をますます今日の現実の核心に触れ、作品を通じて更に現実に働きかえす力をもつものとするよう、階級的な作家として必要な鍛練を自身に課す気組みにおいて云っておられるのは明らかなことと思う。",
              "citation": {
                "source": "見落されている急所",
                "author": "――文学と生活との関係にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "創作的批評は反創作的批評（と云うのは作品に何等の理解も同情もない批評）とでもいうべきものに対しては意味を有つ言葉だが、クリティシズムというものを個々の作品又は一定限界の芸術ジャンルから自由として之にクリティシズムそのものとしての世界の独自性を賦与することをば、妨げる。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
