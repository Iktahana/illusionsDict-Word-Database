        "examples": {
          "standard": [
            {
              "text": "引っ越しの際、不要になった家具を粗大ごみとして出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "粗大ごみを捨てるには、事前に自治体に連絡して回収を依頼する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ああ、また誰かが粗大ごみを不法投棄している。困ったものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
