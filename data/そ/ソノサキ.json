[
  {
    "uuid": "7792cd4b-4cdf-556f-a737-9dc378d6b587",
    "entry": "その先",
    "reading": {
      "primary": "そのさき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
