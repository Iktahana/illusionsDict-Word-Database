      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "temple meditation hall or certain other temple structures",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "慧鶴も朋輩十二人と一緒に僧堂に入って座禅に努めたが慧鶴はよい便宜とばかりに熱心に掟通り行い澄したが、外の朋輩はそうは行かなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右は東西の僧堂になって居て、多少遠近法のついた窓々より灯がほのかに洩れて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西僧堂にて頗る大きな鼓を鳴らす音。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "市の上なる山の左手に、深き洞穴に隣れる美しき大僧堂あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行は僧堂の前に留りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは情に堪へずして、僧堂を出で、海の方へ降り行きぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧堂に歸りしは恰も晩餐の時なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "たつまき　僧堂を辭し去る朝、大空は灰色の紗を被せたる如くなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとし、満洲から帰って海清寺に落ちついた甚斎は、僧堂に自分の気に添わない雲水が二、三人いることに気がついた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟念にも、僧堂の生活がようやく慣れてきた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は僧堂の生活に入って以来、両腕に漲ってくる力の過剰に苦しんでいた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四間四面の広い僧堂のかしこからもここからも、安らかな鼾の声が高くきこえてきた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "托鉢の途中なので、胸には南禅僧堂の頭陀袋をかけ、足には草鞋を穿いてゐた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "しとしとと春雨の降る日、つとにおきて僧堂に禅師を訪ねました。",
              "citation": {
                "source": "芸術三昧即信仰",
                "author": "生きることに悶えた四十代",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶人が松風の音を聞きながらせまい茶室に座しているのも、禅を行なう人がうす暗い僧堂で無念無想の境に静座しているのも、画家が画室で端座しているのも、その到達する境地はひとつである。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧俗の未だ悟らず悟りなばすさまじからん禅堂の床　円覚寺の僧堂で居士を交じへて雲水達の坐禅をしてゐる処へ偶※行き合せたものらしい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常でも石の様に冷い僧堂が寒中のこととて凍りつく許りに見えたことであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロムボで名高い釈迦｜仏陀寺を訪ふたが、近年スマンガラ僧正の歿後は僧堂の清規も振はないらしく、大勢の黄袈裟を着けた修行僧は集まつて居るが、寺内の不潔に呆れる外は無かつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大樹の蔭に淡黄色の僧堂と鬱金の袈裟を巻きつけた跣足の僧、この緑と黄との諧調は同行の画家のカンバスに収められた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度夕の勤行が始まる所で本堂の扉が開いて鐘の音が山に響き、全寺の僧が十余人、僧堂から出て本堂の中へ入つて行く。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に広い僧堂、厨房、客堂は近く修繕を終つた所で、厠を除く外は皆比較的清潔である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "此居士は顏が坊さんらしいので、時々僧堂の衆に交つて、村の御齋抔に出掛ける事があるとか云つて宜道が笑つてゐた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この居士は顔が坊さんらしいので、時々僧堂の衆に交って、村の御斎などに出かける事があるとか云って宜道が笑っていた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだのは腹膜炎だが、腹膜炎になった原因は僧堂で麦飯や万年漬を食ったせいだから、つまるところは間接に独仙が殺したようなものさ」「むやみに熱中するのも善し悪ししだね」と主人はちょっと気味のわるいという顔付をする。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この僧堂に住みこの礼拝堂で仏を礼讃した人々も、恐らく官能断離の要求を強く感じてはいなかったであろう。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟子たちもこの長老とともに僧堂の内に坐するのである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして卒時に普説していう、「僧堂の内で眠って何になる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時近仕の侍者たちが長老に言った、「僧堂裡の衆僧、眠り疲れて、あるいは病にかかり退心も起こるかも知れぬ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道心のないものは、片時の間僧堂に居ても眠るだろう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道元はこのことについて言っている、――浄和尚は僧堂において眠る僧を峻烈に呵嘖したが、しかし衆僧は打たれることを喜び、讃嘆したものである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
