[
  {
    "uuid": "0aa464ae-8358-535f-accf-097b24b31c9c",
    "entry": "僧堂",
    "reading": {
      "primary": "そうどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
