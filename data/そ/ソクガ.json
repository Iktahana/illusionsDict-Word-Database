[
  {
    "uuid": "35f18634-93d8-5826-b85a-9a55d200a754",
    "entry": "側芽",
    "reading": {
      "primary": "そくが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lateral bud",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから、いすとテーブルがもち出されて、ろうそくが、それは千本という数ものろうそくがともされます。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤や青や白の小さなろうそくが、百以上も、枝のあいだにしっかりとつけられました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "何千本とも、かぞえきれないほどの、たくさんのろうそくが、緑の枝の上で、燃えていました。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間のぜんそくが鐘にうつるというところが変だ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年間受け持っていただいた、年よりの石黒先生が、持病のぜんそくが重くなって、授業ができなくなり、学校をおやめになった。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そのまに土壇のまわりは、数本の百目ろうそくが立て廻されて、赤々と輝くばかり――。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどきはこういうのに出会わねえと、ぜんそくが起きるからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀台に輝かしく輝いているおろうそくが、そのまに文机の左右に並べられた。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪からは早く来るやうにと幾度もさいそくがきます。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎の中には、電灯がついていたのか、それともろうそくがついていたのか、それは覚えていない。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "置かれた燭台では、すすの多い黄褐色の百目ろうそくが赤く燃えていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろうそくが惜しいので、ランターンを消してしまって、この昨日踏み固めに来た終点で、ひいて来たロープの上に腰をおろして一休みした。",
              "citation": {
                "source": "登山の朝",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "持病のぜんそくが起ったのである。",
              "citation": {
                "source": "空気男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜人の子供らは、よく祖母や、母親から、夜ごとに天からろうそくが降ってくるとか、また下界で、この山の神さまに祈りをささげるろうそくの火が、空を泳いで山の嶺に上るとかいうような不思議な話を胸の中に思い出しました。",
              "citation": {
                "source": "不死の薬",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうろうそくがなくなったから、さあ休みましょう。",
              "citation": {
                "source": "ろうそくと貝がら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれでも、その絵を見ると、ろうそくがほしくなるように、その絵には、不思議な力と、美しさとがこもっていたのであります。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろうそく屋では、ろうそくが売れるので、おじいさんはいっしょうけんめいに朝から晩まで、ろうそくを造りますと、そばで娘は、手の痛くなるのも我慢して、赤い絵の具で絵を描いたのであります。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことには、その後、赤いろうそくが、山のお宮に点った晩は、いままで、どんなに天気がよくても、たちまち大あらしとなりました。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どこからともなく、だれが、お宮に上げるものか、たびたび、赤いろうそくがともりました。",
              "citation": {
                "source": "赤いろうそくと人魚",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "くわの葉は、正ちゃんが、もうちゃんと野村くんからもらうやくそくがしてありました。",
              "citation": {
                "source": "正ちゃんとおかいこ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くわの葉は、もらうやくそくがしてあるんだよ。",
              "citation": {
                "source": "正ちゃんとおかいこ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、大きなろうそくが、ともされていました。",
              "citation": {
                "source": "うずめられた鏡",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、ろうそくがなくては、いけないね。",
              "citation": {
                "source": "二百十日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　　＊　ろうそくが短くなると、いまにも消えるか？",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ゆつくり退場）イガ　　お袋のぜんそくがひどくなつたと思つたら、今度は嫁が産気づきやがつて、やれやれ、おちおち眠つちやいられないや。",
              "citation": {
                "source": "椎茸と雄弁",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原の中に、いくつもろうそくがついていなかったかい？",
              "citation": {
                "source": "大きなかに",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうこうするうち、清盛からは、しきりに、少将を同道せよというさいそくが来る。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
