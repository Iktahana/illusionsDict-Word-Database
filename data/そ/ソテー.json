          "standard": [],
          "literary": [
            {
              "text": "ポークソテーが店の自慢になつてゐたが、ほかの料理もみな美味く、ことに野菜は全部｜酢漬けで、セロリーはいつもただで食べさせてくれ、なほ、毎月新譜のレコードを購入して聴かせてゐた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒラメは嫌いではないが、ヒラメのソテーとはどういうものか、わからなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "親愛なるシャーク殿はソテーになっていて、グリルしたカイザー・ロールの上に乗っている。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトポタアジュ、ラビオリ・ニコアス、松茸ソテーベーコン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
