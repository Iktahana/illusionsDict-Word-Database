        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "raw oil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　と、よそゆきの言葉でお答えになった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏目がふつくりとする……而して、緋無地の背負上げを通して、めりんすの打合はせの帶の間に、これは又よそゆきな、紫鹽瀬の紙入の中から、横に振つて、出して、翁に與へた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつきり男ぶりのいゝ處へ、よそゆきから歸宅のまゝの、りうとした着つけである。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　旅に反対する理由もありませんでしたので、私は夫のよそゆきの麻の夏服を押入から取り出そうとして、あちこち捜しましたが、見当りませんでした。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵主さんは、よそゆきの茶色のけさを着て、鐘のまえに立つと、手にもっている小さい鉦をちーんとたたいて、お経を読みはじめた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、よそゆきの単衣としては、紺絣のもの一枚しかないのである。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の光のとどかない深い海の、ゆらゆら動く昆布の森のなかにおとなしく眠り、龍宮の夢でも見てゐる態度こそゆかしいのでせうけれども、蟹は月にうかされ、ただ濱邊へとあせるのです。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、美智子はよそゆきの洋服を着ていないのを見ると、彼女が乗るのではないらしい。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心づかいがいっそゆかしいじゃねえかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちこそゆうべからいずれを泳ぎおった」「恐れ入ります。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は早や、麥の青みを――鈴鳴らし朝の祷りに、――白ぎぬに摺りもこそゆけ、白ぎぬに摺りもこそゆけ、野の寺へ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳もきこえず、目も見えず、かくて五月となりぬれば、微かに匂ふ綿くづのそのほこりこそゆかしけれ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにそのおかみさんの運の悪いことは、子供を外へ連れて出ようとして、着物を着換えさせてやる時に、よそゆきの帯に迷子札を着けかえるのを忘れてしまって、そのままで出てしまったもんですから、なんにも証拠が無いんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でよそゆきの女帯を締め直した時は次第に心の昂奮を覚えた。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の人は皆よそゆきで、とりすましている。",
              "citation": {
                "source": "京都人の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ毛織のショールでもよそゆきのをかぶり、祭日らしい身なりをした女が二人三人とつれ立って、電車を待っている。",
              "citation": {
                "source": "ソヴェト同盟の三月八日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は、然し、変によそゆきな顔をしたまま何も見なかったようにすまして廊下を曲ってしまった。",
              "citation": {
                "source": "部屋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなは今のやうに丸帶ははやらない、丸帶はよつぽど大よそゆき――つまり儀式ばつた時にばかり用ふるので、片側帶があたりまへだつたから、腹合せの片側の上等品は、唐繻子だつた。",
              "citation": {
                "source": "日本橋あたり",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大よそゆきの旦那に限られた。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれこそゆるがせにならぬ六次元の夢の厳しさ、みやびやかさだと思い、飛び起きると薄霧に包まれて朧ろにぼやけている太陽に向って礼拝した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見学団は停車場から一露里の道中でうっすり埃をかぶった大よそゆきのエナメル靴の上から、草鞋のようなカバーを麻紐でくるぶしにくくりつけ、静かに力づよく押しあいながら、エカテリナ二世宮殿の毛氈の上を歩いた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの――ちょっと」と云っているサワのよそゆきの声が聞える。",
              "citation": {
                "source": "だるまや百貨店",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、落付いてみるときょうの乙女は何となしいつもとちがうよそゆきの座りかた喋りかたで、時々柱時計の方を見上げては、下唇をなめている。",
              "citation": {
                "source": "日々の映り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイが新聞包からよそゆき下駄を出していると、遠くの闇を衝き破るような勢で始発間もない省線が通る音が風にのって来た。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだよそゆきらしい夫婦仲を、先輩が後輩にのぞむ態度で面白がっていた。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
