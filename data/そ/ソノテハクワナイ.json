          "standard": [
            {
              "text": "「またお金を貸してくれって？その手は食わないぞ！」と友人に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "セールスマンの甘い言葉を聞いても、「その手は食わない」と心の中で唱えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "何度同じ手を使っても、私はもうその手は食わない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "きょうはその手は食わないぞ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "若様にごらんにいれて、羨ましがらせてさしあげるつもりでした」「その手は食わない。",
              "citation": {
