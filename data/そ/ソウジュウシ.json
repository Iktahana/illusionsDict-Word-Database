        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはとにかく、亀さんが鳥人になったらおそらく人並以上の離れ業を演じ得る名操縦士になったことであろう。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ操縦士はハンドルに、Ｔ機関士はエンジンにそれぞれ全神経を集めていた。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お客さんは一人か）　その時Ａ操縦士がちらと後をふりかえった。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ機関士は鉛筆を執ってメモに何か書いていたが、やがてそれを前にいるＡ操縦士に渡した。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとＡ操縦士は前方を向いたまま軽く頭を揮った。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、二人か」　Ａ操縦士の頭がまた左右に動いた。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（やっぱり一人だ）　Ｔ機関士がそう思った時、Ａ操縦士の右手が動いて、前の防風ガラスに指が往った。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なし」　Ａ操縦士は明らかに客はなしと書いたのであった。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことはない、左側二番目の椅子に、たしかに一人いる」　その紙片を受けとってちらと眼をやったＡ操縦士は、これもはじかれたようにして後を見た。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日たしかに乗客のないことを知っていたＡ操縦士はぞっとした。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ操縦士は頭がぐらぐらとした。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくたってからＡ操縦士はやっと心をおちつけた。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "操縦士心はいつも泣いてゐたさ、心は眼には反映しなかつた、ソビヱットの現実に追従してきたのだ。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "操縦士私は知らない――。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "操縦士私にとつて試練の日であつた――、出発の時、隊長は燃えるやうな激しい眼をもつてじつと私の眼の中をみたやうに思ふ。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "友よ、君は父の死を解決せよ、雲の中の、追想の糸を断ちきれ、理解しろ、ソビヱットのあらゆる事件を、操縦士ドミトリー君、親切な友よ、だが、すでに遅い、私の操縦士は、破れた胸から二つの翼をひきだしたのだ、精神の均斉のない鳥がどうして満足に自分のネグラに帰れるだらう。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "操縦士赤い土地から、白い風穴へ、おちこんだ私だ、北から南へ押しながされる私だ。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "操縦士私はやぶれた。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "操縦士ドミトリーよ、こゝはもう満洲国だよ、光つてゐるのは、興凱湖だらう、私は理解しがたい君の愛情を乗せたまゝ、私の白鳥は羽を湖の上に降さねばならない。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろいたのは飛行列車の三人の試験操縦士です。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者も作家ではない操縦士である。",
              "citation": {
                "source": "文学のひろがり",
                "author": "――そこにある科学と文学とのいきさつ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械的な仕事に没頭している操縦士が、この北極飛行のような滋味ゆたかな報告を書いたということが、先ず、私たちに何かの感想をおこさせるのである。",
              "citation": {
                "source": "文学のひろがり",
                "author": "――そこにある科学と文学とのいきさつ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺はブリノフでなく、ベスファミーリヌイにならなくちゃならない」そう思いながらヴォドピヤーノフは、書きつづけて、北極征服の空想小説「操縦士の空想」をかき上げた。",
              "citation": {
                "source": "文学のひろがり",
                "author": "――そこにある科学と文学とのいきさつ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミハイル・※シーリッチ『操縦士の空想』の中にある高緯度地帯の描写と現実の間に、何か類似点がありましたか？",
              "citation": {
                "source": "文学のひろがり",
                "author": "――そこにある科学と文学とのいきさつ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、ルドルフ島の天候も私の本にあるのと、全く同じです」「操縦士の空想」を現実のものとして彼等が北極に学術探検隊をおくることに成功したとき、遙かかなたの首府では、この小説が劇場に上演されていることをラジオで知るそのこともよろこびをもってかかれているのである。",
              "citation": {
                "source": "文学のひろがり",
                "author": "――そこにある科学と文学とのいきさつ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、当時あの新聞をよんだ一般市民は、阿佐操縦士の妹きくえさんの言葉をどう受けとっただろう。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の懐にしのばせた短刀には、既に松風号の操縦士、風間真人の血潮がしみついているのではなかろうか。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "風間操縦士は生きているのか？",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "風間操縦士が一周機の運用能率上、松井田の下機を突如命じた。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智たんていは、小林くんのでんわをきくと、いそいで新聞社とうちあわせ、新聞社のヘリコプターを、自分でそうじゅうして、とんできたのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
