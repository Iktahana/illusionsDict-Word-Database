          "literary": [
            {
              "text": "空鼾をかき、ことさら寝返りを打ち、そっちへちょうど背中を向けてしまうようにする。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして間もなく、「もう寝るわよ」と、ぐうぐう空鼾をかき出しましたが、やがてほんとうに寝入ったようでした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は細君が髭の存在を認めたことが分ると、早速向きを転えて、二度と髭に触らせない様に、蒲団を被って、グウグウ空鼾をかき出したものだ。",
              "citation": {
                "source": "一人二役",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "空鼾をかきながら、彼はもうビクビクものだったというね。",
              "citation": {
                "source": "一人二役",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
