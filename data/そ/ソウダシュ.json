          "literary": [
            {
              "text": "舵がよくききませんが……」　操舵手がうしろでさけんだ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は何年舵をとっているんだ」　と、船長は操舵手を叱りつけながらも、なんだか背すじに寒さがはしるのを感じた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには船長と運転士と操舵手の三人がいたが、誰も隆夫のたましいがそこにはいってきたことに気のつく者はいなかった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "操舵手は舵機のところへ、魚雷射手は発射管のところへ、飛んでゆきました。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "操舵手がうっかり者か、無視したのか。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "グライドが刃物で心臓を的確に一突きすると、操舵手は床にドタンと倒れ、ひといき長くうめき、静かになった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿な操舵手が間違えやがったから、やむを得なかった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
