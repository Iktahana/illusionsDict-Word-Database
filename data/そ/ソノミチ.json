    "definitions": [
      {
        "index": 1,
        "gloss": "that road (path, street, way, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり、絵といふからには絵具や画布、大工といふには槌や鉋、まづその道具ですることが面白いのでない限りそのこととはならないのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわけを聞いてみればその道理もないことはない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ分相応にその道に精進すべきは人間の職分として当然のことであるとだけは言った。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二は、夢中で、短い笑い声をあげて、その道をぐんぐん歩きました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この法で作った宝石をその道の目利きに見せたら真贋の区別が出来なかったという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理にその道へ追ひ込まれたのだ。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道は無限に遠く、地平線の涯に續いて消え去つてゐる。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明りの處を右に折れてまた大通へ出ると、Ｍホテルなのであつたが、人通さへないその道へ足に任せて何氣なく飛び込んで、私は思はず水を浴せられたやうにぞつとした。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも角も思ふ処は思ふ処として、私は氏のその道程の行手を静に見守つてゐたいと思ふ。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道省で出来た英文のモーターロードマップがあって、これは便利であるが、あまりに簡単でその道路と他の地物との関係が不明であり、また最近のところまでアップ・ツ・デートにはなっていないらしい。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道楽が遂に二人を禁断の釣り場所へ導くようにもなったので、お徳は自分の亭主の罪を棚にあげて、その相棒の為さんを悪い友達としてひそかに怨んでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとの主人が易学を心得ていたので、その道のことも少しは聞きかじっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は最後の安堵とともにその道を歩いてゆく。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道でとうとう私は迷ってしまい、途方に暮れて暗のなかへ蹲まっていたとき、晩い自動車が通りかかり、やっとのことでそれを呼びとめて、予定を変えてこの港の町へ来てしまったのであった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして振り返って見るとその道は彼が知らなかったほどの傾斜をしているのだった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の街道から深い溪の上に懸つた吊橋を渡つてその道は杉林のなかへはいつてゆく。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉の梢が日光を遮つてゐるので、その道にはいつも冷たい濕つぽさがあつた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草を喫うも喫わないも、その道具の手の届くところへ行きつくだけでも、自分の今のこの春の夜のような気持は一時に吹き消されてしまわなければならないということは吉田も知っていた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分は三度に二度というふうにその道を通るようになった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからいつもの市中へ出てゆく自分だとは、ちょっと思えないような気持を、自分はかなりその道に馴れたあとまでも、またしても味わうのであった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道筋に、夥しく沈めたる材木は、恰も手を以て掻き退ける如くに、算を乱して颯と左右に分れたのである。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事でも目的を達し意を遂げるのばかりを楽しいと思う中は、まだまだ里の料簡である、その道の山深く入った人の事ではない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "連歌はさまで心を入れたでもなかろうが、それでも緒余としてその道を得ていた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道具を彼は遠慮なく昔の数学者や友人のところから借りて来た。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道具の使い方がどこまで成効しているかはおそらく未決の問題ではあるまいか。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々その道の学者たちに話してみたこともあるが、だれもいっこう相手になってくれない。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出歩く道がわかればわなを掛けるといいそうであるがその道がなかなかわからないと言う。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二は、夢中で、短い笑ひ声をあげて、その道をぐんぐん歩きました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉助は夢中で短い笑い声をあげて、その道をぐんぐん歩きました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある谷を下った所で、曲がりくねった道路と、その道ばたに榛の木が三四本まっ黄に染まったのを主題にして、やや複雑な地形に起伏するいろいろの畑地を画布の中へ取り入れた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
