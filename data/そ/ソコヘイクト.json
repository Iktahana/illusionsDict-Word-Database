    "definitions": [
      {
        "index": 1,
        "gloss": "on the other hand (esp. when the latter is positive)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこへ行くと人間などはだらしのないものである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くとさすがに都会の人の冷淡さと薄情さはサッパリしていて気持ちがいい。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこへ行くと、堅気さんの女は羨しいねえ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くともう生きて帰れないものゝように思われるからだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、無産政党の演説会は、たいていどの演説会でも、既成政党を攻撃はするが、その外、自分の党は何をするか、を必ず説く。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと数字の差違は実に明確である。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、どうもアメリカの映画人のほうがよほど進んでいるといわれても弁明のしようがないようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それに第一にね、そこへ行くと誰でも上手に歌えるようになるって。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそこへ行くとさっき空で遭った鷹がすきだねえ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと外国のは簡単なもので私が紐育へ行った時分に、メーテルリンクの『ベルジュームの市長』という芝居を見ましたが、これは朝、昼、夕方という三幕になっているけれども、三幕が三幕とも、舞台は同じ市長の部屋で、ただ窓から来る光線によって、朝とか、昼とか、夕方とかいうことを現すだけなのです。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くとパパは話せる。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそこへ行くと、いい運が待っているような気がした。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと男の方は五割も十割も割がよい。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと三馬だ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこへ行くと、君は罪が深い。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、多少｜軽薄ではあっても常に才気と活力とに充ちている子貢の方が、子路の性質には合うのであろう。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、自分の家から少しばかり離れた所に親戚があって、そこへ行くといつも書物を出しては、手当たり次第に読んでみた。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなんだから亭主は此がね餘ツ程大きく成つてからだといふんですが出つちやつたんですと、そこへ行くと身元の知れねえ遠國者は思ひ切が能うがすかんね。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこへ行くと大山だの、小林だのの、世帯持ちは、生活の両側に紐がついていて、それが首に捲きついているのであった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこへ行くと妾なんぞは、心が拡いことよ。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが実は男だと思ふと落胆するが、僕はそこへ行くと君知るが如く大のロマンチシストだから空想を食物にして生きられるんだ。",
              "citation": {
                "source": "思ひ出した事（松竹座）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと母の方は、いくらか諭し甲斐がある。",
              "citation": {
                "source": "親孝行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと感心なは俺の旦那だ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこへ行くと、あなたや山内のお嬢さんの美しさは……」「およしなさいませ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと写真班の連中です。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論もう客止めの大門は閉じられていましたが、そこへ行くと三とせ越しのお顔が物を言うのだから叶わない。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと女といふものは気が小さいものですから、一寸したものでも、また要るかと思つて取つといては、そこらが汚ならしいと言つて叱られたりね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいくと、だれもかれもが、まるで、かぎタバコをおなかにのみこんだようになって、ぼんやりしてしまう、しまつなのさ！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいくと、どんなにすばらしいか。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいくと、人間にはたましいというものがあって、それがいつまででも生きている、からだが土にかえってしまったあとでも、たましいは生きている。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
