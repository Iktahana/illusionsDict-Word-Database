        "examples": {
          "standard": [
            {
              "text": "現代社会では、ソーシャルメディアが人々の情報収集源として大きな影響力を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の新しい研究は、ソーシャルワーカーの倫理的な問題に焦点を当てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イベントの成功には、ソーシャルな繋がりをいかに活用するかが鍵となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あす着港というので今日は大分ソーシャルルームで手紙をかいている人が多い。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのいわばソーシャル・エンジニーアがなければ、現代の複雑な社会は運転することができなくなっている。",
              "citation": {
                "source": "調査機関",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際労働局次長のモーレット氏によれば、最近の日本製品の世界的進出は、日本のソーシャル・ダンピングに基くのではなくて、日本に於ける産業合理化と技術の優秀と、それら日本国民従って又日本労働者の特殊な生活の簡易にあるのだという。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "相川氏側によると、少なくともソーシャル・ダンピングのことが顕著に理解出来そうだ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師は科学者、ソーシャルワーカー、教育者として公僕となり医学はますます病気から健康へ重点を移すことになるであろう。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「懇親会ってのはソーシャル・ガザーリングかい？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケット・ビリアードとソーシャル・ダンシングだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を握りあうことすらまれで、かつてのグレン・ミラーやベニー・グッドマンの演奏にあわせて踊られたソーシャル・ダンスのように、男女が一定のフォームで触れあうことは、なかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
