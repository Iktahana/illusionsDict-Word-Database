    "definitions": [
      {
        "index": 1,
        "gloss": "buckwheat (Fagopyrum esculentum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その中の銀一枚はこれで蕎麦をおごろうと御竹さんの帯の間へ。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根の鉄橋を越えて行くに夏｜蕎麦をつくる畑｜干瓢をつくる畑などあれば埼玉や古河のあたりの夏蕎麥のなつみこめやもおほに思はゞ麥わらをしける廣畑瓜の畑葉かげに瓜のこゝたく見ゆるなど口ずさむ。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "タウコギは末枯れて、水蕎麦蓼など一番多く繁っている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝は気がつかなかったが、道の西手に一段低い畑には、蕎麦の花が薄絹を曳き渡したように白く見える。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の先七八間の所は木の蔭で薄暗いがそれから向うは畑一ぱいに月がさして、蕎麦の花が際立って白い。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山畑の蕎麦の花に月がよくて、こおろぎが鳴くなどは実にえいですなア。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだ、昼間があまり忙しいので、夜なべに蕎麦をこなしたのだと母は話している。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪友と言っても藪蕎麦へ誘うだけの悪友であった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名代の藪蕎麦や向畊亭はもう跡方もなくなったので、二人は茗荷屋へ午飯を食いにはいった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには蕎麦や、飯が供えてあった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合室で白い服を着た車掌みたいな人が蕎麦も売っているのはおかしい。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいつも影の形に添ふやうな小笠原氏のゐなかつたのは、土地の名物とて、蕎麦切を夕餉の振舞に、その用意に出向いたので、今頃は、手を貸して麺棒に腕まくりをしてゐやうも知れない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの絵で見ると白木屋の隣に東橋庵という蕎麦屋がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は白木屋の階上で蕎麦が食われる。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん奇抜な句が飛び出して愉快であったが、そのときの先生の句に「つまずくや富士を向こうに蕎麦の花」というのがあったことを思い出す。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをそっと小わきにかかえ、ちかくの支那蕎麦の屋台へ、寒そうに肩をすぼめながらはいって行った。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして蕎麦と稗とが播かれたようでした。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうさうこのときは丁度秋に蒔いた蕎麦の花がいちめん白く咲き出したときであの眼の碧いすがるの群はその四っ角な畑いっぱいうすあかい幹の間をくぐったり花のついたちひさな枝をぶらんこのやうにゆすぶったりしながら今年の終りの蜜をせっせと集めて居りました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋、僕が蕎麦団子を食べて、チブスになって、ひどいわづらひをしたときに、あれほど親身の介抱を受けながら、その恩を何でわすれてしまふもんかね。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋、僕が蕎麦団子を食べて、チブスになって、ひどいわずらいをしたときに、あれほど親身の介抱を受けながら、その恩を何でわすれてしまうもんかね。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒、酒、何であの時、蕎麦屋にでも飛込んで、景気よく一二本も倒さなかったのだろう。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃の痛むのによく蕎麦や汁粉を食ったりしては、さらに自分に対する不満を増していたように見える。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新井田の方はあと廻わしだ」そう彼はまた独りごちて、狸小路のいきつけの蕎麦屋にはいった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは寺院の森の霧つた空……その時子供は父母の膝下で蕎麦を食うべ、その時銀座はいつぱいの人出、浅草もいつぱいの人出、その時子供は父母の膝下で蕎麦を食うべ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに引越し蕎麦を大蒸籠で配ったのが、微酔のお孝であった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お待遠様と持込んだのが、天麩羅蕎麦に、桶饂飩。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "権兵衛茶屋のわきから蕎麦ばたけや松林を通って、煙山の野原に出ましたら、向うには毒ヶ森や南晶山が、たいへん暗くそびえ、その上を雲がぎらぎら光って、処々には竜の形の黒雲もあって、どんどん北の方へ飛び、野原はひっそりとして人も馬も居ず、草には穂が一杯に出ていました。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからはかうして部屋に籠つて煖炉のそばにゐるのが一等好いわね、あなたは幸福だわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の女の顔は不思議な美しさに輝いて、涼しい眼の中に燃ゆるような光は自分の胸を射るかと思ったが、やがて縁側に手をついて、宜しくば風呂を御召しあそばせと云った時はもう平生のお房であった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯はかたわらのフィンを呼んで「あの帆柱のそばの背の高いやつを射よ」と命ずる。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
