    "definitions": [
      {
        "index": 1,
        "gloss": "ornament",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "くつもないし、着物もないし、すべて人間を人間らしくみせる装飾品がたりないのです。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その贔屓の仕方が結局はいま言うわたしの性格の弱さをハンドルに握って、わたしを自由自在に自分の好みに叶う装飾品に仕立てるに外ならなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、考えてみれば、無理は無理でも、装飾品のほかに百円の薬がただで貰えるというのだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果集まった金が六千円、うち装飾品の実費一軒あたり七十円に無代進呈の薬の実費が十円すなわち三十軒分で二千四百円をひいたざっと四千円が、丹造の懐ろに流れ込んだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて些末なる装飾品までも、何が故に人生に要ある。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "（梅桜と東洋文学の関係に就きては他日詳論することあるべし）これと同じく家具家材の実用品と共に或種類の装飾品も亦た、多少実用の性質あるなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し此議論には、詩其物を高価なる装飾品の如く、詩人を普通人以上｜若くは以外の如く考へ、又は取扱はうとする根本の誤謬が潜んでゐる。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの議論には、詩そのものを高価なる装飾品のごとく、詩人を普通人以上、もしくは以外のごとく考え、または取扱おうとする根本の誤謬が潜んでいる。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が見覚えのある装飾品だって、三、四点あるんですもの……」と、征服者のように笑いながら、「新子さん、貴女、お腹ン中で、私のウカツさを笑ってらしったでしょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、奈良に現存せる正倉院は、聖武天皇の御遺物を初め、当時の家具、楽器、武具、装飾品等三千点を、千数百年後の今日まで、その儘伝へてゐるが、わが国工芸品の粋を集めてゐるばかりでなく、唐、西域、印度、ペルシャ、東ローマあたりの品物まで網羅され、その立派さは、世界に比を見ないと云つてもよいくらゐだ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "古めかしい油絵の額や、カメオや七宝の装飾品などが目についた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわい褐色のベストからは太い真鍮製のアルバート型時計鎖が垂れ下がっていて、先には四角く穴のあいた金属の小片が装飾品としてついていた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらすべてのほかに、非常にたくさんの純金の装飾品があった。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が見るようにと思って作らせておいてくだすったに違いないのだから、それをつまらない家の装飾品になどさせてよいわけはない。",
              "citation": {
                "source": "源氏物語",
                "author": "蓬生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西向きの座敷が姫君の居間として設けられてあって、小さい室内の装飾品、手道具がそろえられてあった。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子と、その恋人とを思い知らせるために、悪魔は、瑠璃子を奪って、自分の妻に――名前｜丈は妻でも、本当はその金力を示すための装飾品に――しようとした。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、結婚の式場に列るまで、彼は瑠璃子を高価で購った装飾品のようにしか思っていなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "女四　装飾品のように、手奇麗に美しく出来ている。",
              "citation": {
                "source": "世評（一幕二場）",
                "author": "A morality",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女たちが決して出放題にこんな頭を発明したものでない事は、その恰好や装飾品の取合わせをよく気をつけて見ているとわかる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子と、その恋人とを思ひ知らせるために、悪魔は、瑠璃子を奪つて、自分の妻に――名前｜丈は妻でも、本当はその金力を示すための装飾品に――しようとした。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、結婚の式場に列るまで、彼は瑠璃子を高値で購つた装飾品のやうにしか思つてゐなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "数寄屋河岸に事務所をもち、かつて骨董癖のある英人弁護士の事務所に働いたこともあるので、自分でも下手ものの骨董品や、異国趣味の室内装飾品などが好きであったが、庸三はある連帯の債務を処理してもらったことから、往来するようになったものだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｏ氏は二階の手摺り際へ籐椅子を持ち出して、午後からの創作に疲れた頭を安めていたが、本をぎっしり詰め込んだ大きな書棚や、古い装飾品のこてこて飾られた部屋が入りつけている笹村の目には、寂しい自分の書斎よりも一層懐かしかった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにも内地では見られない装飾品が幾個かあつた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日の午後、僕等は勧工場の中に這入つて、装飾品の売場から薫物の売場へ、反物の卓から置物の卓へとあちこちうろついた。",
              "citation": {
                "source": "不可説",
                "author": "UNERKLARLICHT!",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、障子の内側には妻の病床をとりかこんで、見なれた調度や、小さな装飾品が、病人の神経を鎮めるような表情をもって静かに呼吸づいているのだ。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "謁見の年には、当時の抽斎の妻山内氏五百が、衣類や装飾品を売って費用に充てたそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで玩具か装飾品のようだ。",
              "citation": {
                "source": "ピストルの蠱惑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "只そんなものが、色々の贅沢な装飾品で、如何にも巧みに釣合を取られているからちょっと気が付かないので、そのためにこれだけは昔のまま、室の隅に置いてある火の気のない瓦斯ストーブまでも引っ立って、勿体らしいものに見えているに過ぎないのである。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
