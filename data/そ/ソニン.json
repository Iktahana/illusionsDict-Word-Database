    "definitions": [
      {
        "index": 1,
        "gloss": "a suitor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "太郎左衛門、Ｔ「お上では昨夜逃げた者をきつい御詮議」Ｔ「わしが奉行所へ訴人すれば」Ｔ「伊吉もお前さんも後ろへ手が廻るぜ」　その時、Ｔ「ついでにお前さんもなァ」　と云う声に振り返ると右門と伝六です。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その方が心持が可い、命を取ったんだと、そんなにせずともの事を、私が訴人したんだから、怨みがあれば、こっちへ取付くかも分らずさ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、このどろぼうの風采に就いては、なんにも知らないということになっているのであるから、まさか、私がかれの訴人の一人である、などということは、絶対に有り得ないのである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けンどもが、何も旦那様あ、訴人をしろという、いいつけはしなさらねえだから、吾知らねえで、押通しやさ。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ伏見の船宿の水六の亭主などは少し怪しい者が泊ればすぐ訴人したが、登勢はおいごと刺せと叫んだあの声のような美しい声がありきたりの大人の口から出るものかと、泊った浪人が路銀に困っているときけば三十石の船代はとらず、何かの足しにとひそかに紙に包んで渡すこともあった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "金に眼のくれた百姓達は訴人となって出た。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「めっそうもない、比江山の女房小供が隠れておるなどとは、存じもよらんことでござる」「云うな、比江山の女房小供六人が、此処へ入ったところを、植田の者が見ていて、訴人に出たのじゃ、それでもおらんと云うか」　討手の頭は住職を叱りつけた。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この者が、訴人があると申しております」　役人はその前に平伏しながら己の背後におる僧侶に指をさした。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにか、宗門に係わる訴人か」　忠隣は鼠色の法衣を来た僧侶に眼をやった。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世を害するものなりといって訴人に及ぶは情において忍ばるる処ではあるまい。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにこれを訴人して、後にざまあ見ろをくらって、のり血になって悶くのは、芝居でも名題の買って出ぬ役廻であろう。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代、足利時代、降って徳川時代に至っては、その禁令がいよいよ厳重になって、ひそかに鷹を飼うものは死罪、それを訴人したものには銀五十枚を賜わるということになっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国はいよいよ躍起となって、どうしても男と手を切らなければ与次郎殺しの一件を訴人するから覚悟しろという、おそろしい手詰めの談判になって来たので善昌もいよいよ困った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "訴人の男の云う通り緋の緒でくくった袴も、長刀も出て来た。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "くやしくてならんから、いっそのことに訴人してやろうかとも思ったが、それじゃおれの男がすたるから、それだきゃがまんしておいてやらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "声が飛び、人が飛んで、訴人はたちまち近侍の者たちが高手小手。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "――騒ぎもまたぴたりと静まって、押えつけていた近侍の面々が手を引くと同時に、はじめて直訴人の姿が雪の中から現われました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ひざまずいたまま烱々とまなこを光らして名人は、ややしばし老直訴人の姿をじいっとうち見守っていたかと見えたが、さすがは慧眼無双、そちひとりおらばと名宰相が折り紙つけただけのことがあって、せつなのうちにもうあの眼がさえ渡りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "必死の覚悟とみえまして、まさしく訴人は切腹しておりまするぞ」「なにッ」「みるみるうちに顔色の変わりましたが第一の証拠、直訴を遂げて気の張り衰えましたか、五体にただならぬ苦痛の色が見えまするでござります」「いかさまのう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより事は急、壮烈きわまりない訴人のその覚悟を見ては、ちゅうちょしている場合でないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "名宰相伊豆守と名人右門との胸から胸へ、腹から腹へ、言外になぞを含ませた直訴お聞き届けのその応対をきいてにわかに気力がうせたか、年老いた訴人は、最後の悲痛な、しかし満足げな微笑をただ一つ残すと、がっくり雪の道にうっ伏して、そのまま落ち入りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずともにお力となってしんぜまするぞ」　見ながめるや、時を移さずにじり寄って叫びささやきながら、すばやく訴人の手から直訴状をぬきとって懐中すると、待ち構えていた小者たちのところへ目まぜが飛びました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を訴えた訴状であるか、直訴の的はどこにあるか、なぞを解くならまず第一番に訴人が住まいの入舟町へはせつけて、そこから先に手を染めるのが事の順序であろうと思われたのに、奇怪にも目ざした道はまがうかたなく数寄屋橋のあのお番所なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方法、この悲劇の社会的な原因を排除するのではなしに、かえってそれを掩護し、不合理の率直な告訴人となれないで、心ならずもそのかかしとしてつかわれながら。",
              "citation": {
                "source": "権力の悲劇",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは東町奉行に宛てて、当方にも訴人があつた、当番の瀬田、小泉に油断せられるな、追附参上すると書いたのである。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ陰謀に就いて西奉行所へも訴人が出た、今日当番の瀬田、小泉に油断をするなと云ふ手紙である。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "訴人するという脅かし文句をチラつかしたので。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六十五條　申掛いたし候者御仕置の事一、主人親重き惡事有之由、僞を申懸、訴人に出候もの　磔一、主人親之惡事、訴出候時之捌公儀へ懸り候重き品は、可遂詮議。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "若訴人申處、僞無之おいては、本人之御仕置相當より、一等輕く可相伺之。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
