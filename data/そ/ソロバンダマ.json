        "examples": {
          "standard": [
            {
              "text": "古いそろばんは、木製のそろばん玉がすり減っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供がそろばん玉を指で動かしながら、真剣に計算している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "黒く輝くそろばん玉が、彼の熟練した指先で軽やかに踊る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人民はまるでそろばん玉みたいだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろばん玉のかちかちという合い間合い間に、ルージンの口から漏れる簡単な抗弁と批評はあまりにも見え透いた意識的な侮辱と嘲笑にみちみちていた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
