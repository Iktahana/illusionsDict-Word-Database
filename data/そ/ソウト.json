[
  {
    "uuid": "2cdcb68e-3cda-5fab-b831-062f91b069b8",
    "entry": "僧徒",
    "reading": {
      "primary": "そうと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
