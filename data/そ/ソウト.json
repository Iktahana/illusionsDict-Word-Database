      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "priests",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "聖十字の銀にくちづけ、僧徒の列座を超え、雲雀料理の皿を超え、汝の香料をそのいますところより注げ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（此日法皇老若の僧徒十三人の足を洗ひ、僧徒は法皇の手に接吻して、おの／＼「マチオラ」の花束を賜り退くことなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど僧徒の群に引かれてつくゑの前に跪き給へる、天使の如き姫君の、色白く優しげなる面のみは、我心の上に殊に明かなる印象を與へて、年經ての後も消ゆることなかりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから昔尖塔の頂上に板を雄鶏に造って立て、僧徒にこの板が風に随うて動きやまぬごとく少しも懈らぬよう訓えたとジュカンシュは言ったが、グラメー説には、塔頂に十字架に添えて鶏の形を設くるは、ゴット人が雄鶏の武勇にあやかるためこれを軍旗とした遺風という。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "街既に落ちて、家を囲むに、閉ぢたる戸毎に不順の色見え、鉄火、窓より降りしきれば、「憎つくき僧徒の振舞」とかたみに低く罵りつ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "街既に落ちて、家を圍むに、閉ぢたる戸毎に不順の色見え、鐵火、窓より降りしきれば、「憎つくき僧徒の振舞」とかたみに低く罵りつ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょせんは三井寺の僧徒を煽動して叡山に敵対させ、かれらを執念く啖い合わせて、仏法の乱れ、あわせて王法の乱れを惹き起こす巧みであろう。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども彼は僧徒の横暴を抑へむが為に、然かせるにあらず。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が此破天荒の痛撃は、久しく平氏が頭上の瘤視したる南都北嶺をして、遂に全く屏息し去るの止むを得ざるに至らしめたりと雖も、平氏は之が為に更に大なる僧徒の反抗を喚起したり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "啻に僧徒の反抗を招きたるのみならず、又実に醇篤なる信仰を有したる天下の蒼生をして、仏敵を以て平氏を呼ばしむるに至りたりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧徒らの衣形は、誤ち求めて山に入りたる若僧を除き、ことごとく蓬髪裸足にして僧衣｜汚れ黒みたれど、醜汚の観を与うるに遠きを分とす。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一段誤ち求めて山に入りたる若僧と僧徒妙信とあり。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二段若僧はもの言いもてなお下手に歩み出づる時、あわただしげに走せ来たれる僧徒妙海と妙源とに行きあう。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の三人　（いささか高低を違えてほとんど同時に）え――僧徒らはあたかもくらげの浮動するがごとき怪しき姿して物の音をたずねてあり。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（僧徒らの方を顧みつつ）物の音は三度目に、この根元あたりできこえたのでございますけれど。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧徒らは中辺より下手の方にたたずみて背をなしたれば知らであり。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま僧徒らの斉しく森の方を眺め入れるを見、にわかに恐怖を見出でたるがごとく歩みを止む。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若僧の顧み知りて怪しく叫ぶや、僧徒ら掴むがごとく相｜集う。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "場に残れる三人の僧徒らは、ことごとく生色を失い、なすことを知らざるさまにおののきてあり。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧徒らはそのさま一つ腹より出でたる犬の子らのごとく、われともなしに退り行き、上手二路の岐るるほとりに止まる。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この時にわかに僧徒らの姿がいかなるかに気づけるもののごとく、容想たちまちにして忿恚を現わし、声調また激しく変ず）お前たちは何だ、なぜそんな風をして物を言わずに立っているのだ。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧徒らものいらえんとするも、舌｜硬ばりで能わざるがごとし。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ僧徒らに何らの抗意なく、いたずらに戦慄けるのみなると、さきには陰地に立てりし妙念の、今ところを異にして月色の中に輝けると異る。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお身と同じこの山の僧徒たちでございます。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）僧徒たちの姿にのりうつって、この鐘へ取り付こうとするにちがいないわ。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙信――三人の僧徒ら　（斉しく）妙海――　　　　　　　　　　　　妙源――三者同じき頭音はほとんど高低と不調となく、区々なる尾音おののき乱る。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "など叫喚して手がつけられず、私なども、雑誌の小説が全文削除になったり、長篇の出版が不許可になったり、情報局の注意人物なのだそうで、本屋からの注文がぱったり無くなり、そのうちに二度も罹災して、いやもう、ひどいめにばかり遭いましたが、しかし、私はその馬鹿親に孝行を尽そうと思いました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く「われは横綱らしく強いところを見せようとして左の腕を大きくぶるんと振って相手を片手で投げ飛ばそうとしたが、相手は小さすぎて、われの腕はむなしく相手の頭の上を通過し、われはわが力によろめき自ら腰がくだけて敗れたのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "危機一髪、団子鼻に墮そうとするのを鼻のわきの深い皺がそれを助けた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂家の玄関に於いて颯っと羽織を着換え、紺足袋をすらりと脱ぎ捨て白足袋をきちんと履いて水際立ったお使者振りを示そうという魂胆であったが、これは完全に失敗した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
