        "examples": {
          "standard": [
            {
              "text": "借金が多額だったため、相続放棄の手続きをとった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "相続放棄をすれば、亡くなった人の債務を引き継ぐ必要はない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "相続放棄は、家庭裁判所での手続きが必要となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "不動産相続放棄の書類を書いた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしその相続人が不動産相続放棄手続きをしたら、当然、現所有者は財産を好きなように処分できる。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "先々代の遺書だよ、それと先代の相続放棄証書だ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
