          "literary": [
            {
              "text": "優秀なサーファーであるマイケルは、シンガー・ソングライターとしても、ハワイではその名を知られている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポールはソングライターのような顔であり、ジョージは、これはちょっと問題だ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "シンガー・ソングライターとして自分のＬＰを一枚つくり、デビューしてみないかという話なのだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
