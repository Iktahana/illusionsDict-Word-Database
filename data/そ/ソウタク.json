[
  {
    "uuid": "c2fae64c-5df9-5353-88cd-bd5fc7ec87e7",
    "entry": "藪沢",
    "reading": {
      "primary": "そうたく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
