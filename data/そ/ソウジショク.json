        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "総監以下｜速時総辞職せよ。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "総監の遺書の委しいことは私も存じませんが、それが内閣の総辞職の導火線となったことは事実であります。",
              "citation": {
                "source": "外務大臣の死",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何日ぶりかで新聞を読む、斉藤内閣が総辞職して大命が岡田大将に降下したことを知つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、数日ぶりに新聞を読んで政界の風雲急なるに驚いた、たうとう軍部と政党とが正面衝突して、解散か総辞職かで緊張しが、脆くも広田首相は辞表を捧呈した、まことに日本の現在は『疾風怒濤時代』である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "近衛内閣総辞職、大命、平沼男に降下するらしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……内閣総辞職とは驚いた、日本もいよ／＼更始一新だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "片山内閣は難航の末、一九四八年二月十日総辞職をした。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高橋文相は四月総選挙の結果吉田内閣が総辞職するまでの僅か数ヵ月の文相であった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片山内閣はこれらの統制的な社会成人教育の方向を示しただけで総辞職した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが謂はゆる虎の門事件なるものであり、その責を負うて、約三ヶ月前の九月二日、大震災の惨禍の真只中に成立した山本権兵衛内閣は、その日のうちに総辞職をなし、時の警視総監湯浅倉平（後の宮内大臣、内大臣）は懲戒免官に処せられた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月六日（火曜）晴　内閣総辞職　原首相が殺されてから、高橋是清が総理大臣となり、始めは人気があったが、追々不信任案が生じ、二ヵ月ほど前、元田、中橋をぬいて改造案を起したが通らず、ずるずるで、ともだおれ、今日となったのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦争に依て寿命を延ばした桂内閣は、戦争の終局、媾和条約の非難に堪へ切れず、明治三十九年の元朝、媾和全権大使小村寿太郎の帰朝を待ち受けて総辞職に及び、一月七日、政友会総裁西園寺公望が立つて総理大臣となりかくて原敬が内務大臣となつた。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "幣原内閣も改造か総辞職の外なく一嵐なり。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃こんな書きにくいものにぶつかったことなし　平沼内閣総辞職。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、内閣総辞職のニュースをきく。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡倉さんが美術学校を辞める時、父も一旦総辞職と共に学校を出たのだが、暫くして又学校に戻った。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃学校の方では校長岡倉覚三先生がやめさせられ、教員も総辞職をするという仕末になり、親父も辞職をしたので僕も退学した。",
              "citation": {
                "source": "美術学校時代",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　東条内閣総辞職の報が伝はつた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十日（木）　東條内閣総辞職す。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ半歳ならずして内閣総辞職の止む可からざりし所以なり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど山県内閣は、侯の成算未だ熟せざるに早くも総辞職の挙に出でたり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "総辞職を主張するものもあれば、全吏員のゼネラル・ストライキを宣伝して回るものもある。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣ならとうに総辞職というところだが、そんな事は誰も咎めない前にかれはあやまった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六九条　内閣は、衆議院で不信任の決議案を可決し、又は信任の決議案を否決したときは、十日以内に衆議院が解散されない限り、総辞職をしなければならない。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七〇条　内閣総理大臣が欠けたとき、又は衆議院議員総選挙の後に初めて国会の召集があつたときは、内閣は、総辞職をしなければならない。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに恐れてかどうか知らないが、或いは寧ろ之を利用してであろうが、関西支部出の協会幹部は総辞職して協会の心胆を寒からしめているようだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "近衛さん総辞職の号外をもって来たおっさんが帽子とって、こちらも御出征でとあいさつしてゆきました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "総辞職を求めて来た四党代表に向って、首相が自由にものをいったら、そして、その場での誠意を表明しようとしたら、彼は、国を憂えているという自身の心を証明するために、更にどう話をつづけたであろうか。",
              "citation": {
                "source": "一票の教訓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその夕刻には、内閣もまた総辞職を行わねばならなかった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち二十五日総辞職があって同日大隈、板垣が官邸に招かれて伊藤から政権授与の相談をうけた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
