          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに引き替えて、母のおまきは近所の評判がだんだんに悪くなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引き替えて、あの人たちは自由である。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、久安四年から仁平二年――この足かけ五年のあいだに、自分の身の上はどう変わったか。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、今の自分の満足は、ただ何事も考えない放心の境に入るだけの満足で良いのであるが、それを容易に出来ぬ自分を感じると、一時も早く雪路を抜けて湖の見える山面へ廻りたかった。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく今まで積まれてあった鹿の小山の褐色の色が、麻の葉叢の上からだんだんに減ってくると、それにひきかえて、珊瑚色の鹿の小山が新しく晴れ渡った空の中に高まってきた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の好んだ題目について記された書物はじつに悲しむべきほど少く、それにひきかえて、年とったオランダ市民たちはもちろんだが、ましてその細君たちが、真実の歴史にはなくてはならない貴重な口碑伝説をたくさん知っていることがわかったからである。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝うるところによると、前年尾州の御隠居が総督として芸州まで進まれた時は実に長州に向かって開戦する覚悟であった、それにひきかえて今度の進発は初めから戦わない覚悟である。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、草には、朝から晩まで、ちょうや、あぶや、みつばちが訪ねてきました。",
              "citation": {
                "source": "小さな草と太陽",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、私は、なんという醜い姿で、生まれてきたでしょう。",
              "citation": {
                "source": "木と鳥になった姉妹",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、二十の娘は徹底的にウスノロに見えるんですな。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、『社交室』の連中は、いったい、どうしたというのだろう。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "その元気で茶屋を立って下りにかかりましたが、上りに懲りて無言の行を続けると言った肥満の与力は、渋面を作って口を噤んで歩きましたが、それにひきかえて能登守が今度はいろいろの話をやり出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、この池は女ばかりでございます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、あのお内儀さんの元気なことは――お湯に入っているところを見ますと、肉づきはお相撲さんのようで、色艶は年増盛りのようで、それで、もう五十の坂を越しているのですから驚きます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて臼杵では、精悍な元宗麟夫人がまた勢力をもり返して来た。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それにひきかえて、このごろの座敷の客のおもしろさ、みんな、生きてる人間だよ、ぴちぴちしたお侍だよ、江戸生まれの私も、宗旨変えして、勤王方の肩持ちになりたくなる。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、武蔵という名はとんと聞かない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わ、わしだッ」　それにひきかえて、襲った者の声は割れていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それにひきかえて、この治郎右衛門忠明は、早くも、老いの兆しを現し、きょうのような敗れをとったこと、師弥五郎先生に対しても、なんの顔があろうか。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それにひきかえて、鎚の打ち方の、火加減の、湯の秘伝のと、一本の刀にも、血を吐くような苦しみをして、あげくに、折れ易いとか、曲がるとか、死んだ末代の先までも、とやかく云われる刀｜鍛冶と――』　彼は、ふと、『止そうか』　と、嘆息ついた。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、数右衛門は長屋の一室に、平日の面影もなく、俯向いたきりで畏まっていた。",
              "citation": {
                "source": "※かみ浪人",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて燕作のほうを見ると、さすがはこいつ足馴れたもので、少しもあせるようすがなく、まるで平地を歩むように、スラスラと十二、三｜町の登りを踏みすすんでゆく。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、夫人の座所からは、「いつなと、心に懸ることもない、……それにあるは、岩見か少斎か、はや介錯をしてたまわれ」　と、ふだんと少しも変らない声が洩れた。",
              "citation": {
                "source": "日本名婦伝",
                "author": "細川ガラシヤ夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それにひきかえて、半兵衛ごときは」　と、また病躯を責めて、詫び入るらしい気ぶりを抑えて、秀吉は彼のことばを不意に奪った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて光秀は少なからず狼狽の容子であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それにひきかえて月江の方は、もう血色も呼吸も苦しげに迫っている。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それにひきかえて、今、涙をのんで、彼の人々に死を賜うならば、その生命の光は、日月と同じである。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて、今夜の又八は、必死だった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえて紐の方は、自力を労さず他力主義に、お米の足の向くほうへ、ズルズルついて行くだけである。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
