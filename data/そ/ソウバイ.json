[
  {
    "uuid": "75511c5e-d542-5924-9aaa-4996d4899ef7",
    "entry": "早梅",
    "reading": {
      "primary": "そうばい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
