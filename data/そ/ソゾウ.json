    "definitions": [
      {
        "index": 1,
        "gloss": "plaster image",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二科の彫刻塑像には帝展などのとちがって何となく親しめるものが多い。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつき体操をするやうに肩を動かした填合せと見えて、今は神の塑像のやうに凝坐してゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "着色の塑像の如くで、生きているものとも思えぬ位であった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ美術学校の塑像科に在籍中だった三男が、それを編輯いたしました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この兄は美術学校にはいっていたのですが、からだが弱いので、あまり塑像のほうへは精を出さず、小説に夢中になって居りました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉藏は洋畫を勉強してゐたが、飛騨は、わざと塑像科をえらんだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事にも几帳面で、怒らない時には柔順な敏夫は、私の父の塑像の前に行つて、「おぢいちやま御機嫌よう、おばあちやま御機嫌よう、ママ御機嫌よう」　一々頭を下げて誰にともなく云つてから、私の所に來て、「パパ御機嫌よう」と挨拶した。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の勢に乘つて、私は夢中で駈上つて、懷中電燈の燈を借りて、戸袋の棚から、觀世音の塑像を一體、懷中し、机の下を、壁土の中を探つて、なき父が彫つてくれた、私の眞鍮の迷子札を小さな硯の蓋にはめ込んで、大切にしたのを、幸ひに拾つて、これを袂にした。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の兄は美術學校の塑像科へ入つてゐたが、まいにち中庭の大きい栗の木の下で粘土をいぢくつてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着色の塑像の如くで、生きて居るものとも思へぬ位であつた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大谷光瑞師の寄贈にかかるといふ、支那トルキスタン庫車内トングスバス發掘の塑像佛頭といふ土の首は予の心臟を破らむほどに美しかつた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁の塑像製作中、津上氏は古賀氏、佐藤氏、筆者等が傍で語る只圓翁の逸事を聞きながら、「愉快ですなあ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達がこの室に来てから、もう二時間になるが、ハドソン夫人はその間に八回、あの塑像に変化を与えていてくれるのだ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この珠はもう死んでいるから、役に立たない」　そこで、塑像を作る人に廉く売って、仏像のひたいの珠に用いるのほかはなかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "録異記",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその顔色は見る見る蒼褪め、額口には一層激しい困惑の色を浮べて今までの元気はどこへやら、下唇を堅く噛みしめながら、顫える指先で盛んに顳※のあたりをトントンと軽く叩きながら、塑像のように立竦んでしまった。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "服部長八の漆喰細工の肖像館という見世物に陳列された椿岳の浮雕塑像はこの写真から取ったのであった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とよ子の嫂は塑像のように、肩も、垂れた両腕も動かさずに、爪先だけでそっととよ子の方へ歩み寄って行った。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう云うと、とよ子の泣き声をあとにして来る時と同じ塑像の動いて行く足どりで、私のベッドの傍らをもすぎ、扉の外へ姿を消して行った。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上妻君との間にはさまれたら、私は慌てたりあせつたりするばかりで、折角出来かゝつた塑像が台なしになつてしまふやうに、私の夢も姿も紙屑となつてしまふであらうと怕れはぢめた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士コハクは灰白色の毒ガスの中に、まるで塑像のように立っていた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の記者たちはその隅に塑像の如く停止し、ワーナー博士たちの観測を出来るだけ邪魔しまいと控えていた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸記者は塑像のように硬化している。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことが繰り返されて、三度目に法王は塑像用の粘土を不思議さうに見まもりながら、「これは何かね。",
              "citation": {
                "source": "茶話",
                "author": "昭和五（一九三〇）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん写真や肖像画があれば、時として頭蓋骨などなくても立派に塑像を作ることができますけれど、肖像画や写真が無くとも、頭蓋骨さえあれば、立派に生前どおりの顔を作ることができるのであります。",
              "citation": {
                "source": "頭蓋骨の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "またハントがカーライルの細君にシェレーの塑像を贈ったという事も知れている。",
              "citation": {
                "source": "カーライル博物館",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子が庸三の近くに家を構えていた時分、よく北山を訪ねて来て、清純な恋愛を葉子にも訴え訴えしていた若い塑像家の噂も出た。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその踊り場が、この市の唯一のダダイストである塑像家Ｍ―氏の経営（さう大袈裟なものではないだらうが）に係るものだことを、昨日坊さんから聞いてゐたので、その点でもいくらか興味があつた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金色をした大きな外国の軍人の塑像が、アトリエの隅の方に聳え立つてゐるのが目につくきりで、テイプやシェードの装飾はしてなかつた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
