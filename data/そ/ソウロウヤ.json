    "definitions": [
      {
        "index": 1,
        "gloss": "I wonder if ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
