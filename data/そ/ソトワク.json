          "literary": [
            {
              "text": "ところがあの家の第四層の窓の外枠はこの土地でフエルラアドと云ふ構造になつてゐるのに、己は気が付いた。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであの家のあの窓の外枠だが、あれは幅が少くも三尺五寸位ある。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "電球はいきなりむき出しに、廊下に向う金網の鉄の外枠から下っているのだが、それにはどういう訳か、駒込警察署と、字だけクモリで入れてあるのだ。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八角形になった外枠の中に、アラビヤ数字で書かれた、丸い文字盤がある。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
