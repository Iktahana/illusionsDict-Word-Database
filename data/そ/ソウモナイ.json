        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕なんか、首でも吊らなければおさまりがつきそうもないのに」「そうして、君がいちばん長生きをするだろう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩石の大崩れがあって、左の方に石を囲んだ坊主小舎がある、小舎の中は未だ雪が多くて、泊まることは出来そうもない、鍋が一枚蔵してあった、冠君は既に槍ヶ岳登りを終られて、雪を辷り落ちるようにして、下りて来られた、二言三言話を交えて、さっさと下りて行かれる。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼の周囲には、萌黄にぼかされた穂高の峰々が、神経の電線に燃えついて、掻き消されそうもない、私は眼球の上へ、人さし指を宛てて、グリグリとやって見たが、一、二尺の先を見つめるのが精々で、森の梢は、その燃えさかりの※の中に、暗を縦横に引っ掻き廻し、入り乱れて手を突き、肱を張っている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人間の両眼が耳の近所についていない限り、いくらこういう実験をしてみたところで自分の疑問は解けそうもない。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような六ヶしい問題は私には到底分りそうもない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一代前の云い置きなどを歯牙にかける人はありそうもない。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁天の前に電車が一台停まったまま動きそうもない。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹名を書いた札のついているのは有難いがなかなか一度見たくらいでは覚えられそうもない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方法も理論上面白い法であるが、出来上がった板をそのまま見るのではなく、かなりに面倒な器械で覗いてみなければならぬので、到底一般には行われそうもない。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう大概にしないか、ばかだな」と言ってみたが、なかなかやめそうもないから便所へはいる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら探してみてもこれ以上の慾が自分に起りそうもない、妙に中和されてしまった自分を発見して柚木は心寒くなった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "草はいくら食ってもとても食い切れそうもないほど青々と繁茂しているのである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく科学者には随筆は書けるが小説は容易に書けそうもない。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ取締規則がこれを許しても、また二、三の変り者が実例を示して鼓吹したにしてもあまり流行はしそうもない、してもあの緊張した空気の中で好い声が楽に出ようとは思われない。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "否方則といえばただ偶然の方則が支配するばかりであって要するに科学は成立しそうもないのである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ここで私がせっかく苦心して定義をこしらえても、それは結局甲某の定義にしかなりそうもない。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震だけを調べるのでは、地震の本体は分りそうもない。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにどんな風が吹き出すか、神様以外には誰にも分りそうもない。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時母に送った手紙に「あんなに不器用では実験家として成効しそうもない」と云ってこの政治家の余技を評している。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大した実用にはなりそうもない」と云っているのは面白い。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高射砲など常識で考えても到底頼みになりそうもない品物である。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国製でなかなか丈夫に出来ていて、ちょっとくらい投り出しても壊れそうもない、またどんな強い風にも消えそうもない、実用的には申し分のなさそうな品である。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューインガムを噛む税関吏の顔は日本人から見れば俳諧があるかもしれないが税関吏の胸の中には一滴の俳諧もありそうもない。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に、連句三十六景のコンチニュイティは容易に暗記が出来るが、レビューの二十八景の順序は到底覚えられそうもないのである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな理由だけからでも、映画によってすべての文字を駆逐することは出来そうもない。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしゆるゆる見たいと思う絵は容易に見つかりそうもない。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそういう処でも「絶対の自由」などという夢のようなものはおよそ有りそうもないようである。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際先生のような句を作り得る人でなければ先生のような作品は出来そうもないし、あれだけの作品を作り得る人でなければあのような句は作れそうもない。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
