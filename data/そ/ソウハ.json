[
  {
    "uuid": "e317246e-e84f-50d2-9ff5-10ace02bb9f6",
    "entry": "争覇",
    "reading": {
      "primary": "そうは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
