[
  {
    "uuid": "f4a2de6f-bf0a-5f07-917e-57eea379bde5",
    "entry": "掻痒",
    "reading": {
      "primary": "そうよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
