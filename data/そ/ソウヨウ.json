      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "itch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三　内田百間君の「掻痒記」を読んで二三日後に偶然映画「夜間飛行」を見た。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その座談会の記事は多分の省略があり、前後の脈絡がなく、隔靴掻痒の嘆はあつたけれども、ともかく、ねらひの正しい、鋭い企画である。",
              "citation": {
                "source": "感想",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "疼痛、掻痒は伴わない。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔靴掻痒そのものである。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風俗についても大体いはゆる「隔靴掻痒」でなくかいたものを集めたと思ふので、「人」についてもさうして書いたものを交へておきたかつた、ぼくの「本をこしらへる神経」が為せる業だつたらう。",
              "citation": {
                "source": "東京の風俗　序",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は世界を以て家とするの大規模ある空気を呼吸し、我は日本の外日本あるを知らざる鎖国的の小籌に齷齪たる情趣、隠約の間に出没し、ために隔靴掻痒の感なき能わざらしむ。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の研究に体験のない人の科学論には、時々隔靴掻痒の感を伴なうことがあって、それがこの種の問題に対する科学者の関心を低めさせる原因となる場合がかなり多かったようである。",
              "citation": {
                "source": "救われた稀本",
                "author": "――寺田寅彦著『物理学序説』",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの胃腸のわるい原因がやっぱり胃腸から吸収されるものによって癒されるしかないことを思い、まことに隔靴掻痒の感です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田さんはいままでは北海道の学校におられたのですが、きょうからみなさんのお友だちになるのですから、みなさんは学校で勉強のときも、また栗拾いや魚とりに行くときも、高田さんをさそうようにしなければなりません。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、そんな、気味の悪い、物凄い、死神のさそうような、厭な濠端を、何の、お民さん。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二｜羽のこの美しい水鳥はお互いに心いっぱいに愛の喜びを感じているとみえて、小さい二つの尾羽はきそうようにふられていた。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "又万一然様いう企をしたとすれば、鶺鴒の印の眼球で申開きをするほどの政宗が、直接自分の臣下などに手を下させて、後に至って何様ともすることの出来ぬような不利の証拠を遺そうようはない。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛にさえ馬にさえ悲憐の涙を惜まぬ保胤である、若い女の苦しみ泣いているのを見て、よそめに過そうようは無い。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人　何と申そうようもない。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下に出ると、私は東屋氏に寄りそうようにして云った。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤枝は幾分緊張した顔で私の方をさそうように見たが、ふと傍らの壁にかけてある美しい色の額をさしながら私にささやいた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落着きをよそうようにして検事は書類を手にとった。",
              "citation": {
                "source": "殺人迷路",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが長い間為朝になついて、影身にそうように片時もそばをはなれない二十八｜騎の武士が、どうしてもお供について行きたいといってききませんので、為朝も困って、これだけはいっしょに連れて都に上ることにしました。",
              "citation": {
                "source": "鎮西八郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるかに脚下には三十尺の支柱の土台となっている円形のコンクリートの地盤が、私をさそうように冷たくよこたわっている。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心もち上半身を起してみると、諸口さんの向うにマダム、その横臥椅子にぴったり寄りそうように青木の痩せた体をのせた椅子があった。",
              "citation": {
                "source": "※の囁き",
                "author": "――肺病の唄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご家老さま」と彼女は、あたりを見まわして寄りそうようにした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれはナラ、ドロ、イタヤモミジなどの類であったが、その生きの強い樹と生命をあらそうように、下には熊笹がびっちり生えていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを博士が見たものと見え、とぶようにかけて来て、ハンドルをまわして戸をあけると、五人はあらそうようにして、外へとび出した。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "航路は三日以後は熱帯に入り、それからのちはほとんど赤道にそうようにして、西へ西へと船脚をはやめていたのだ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを書いている最中に変身の苦しみが私をおそうようなことがあれば、ハイドはこれをずたずたに引き裂いてしまうだろう。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村と正太は、あらそうようにして、この光のそばにくっついて、はなれない。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、中毒するほど、のんでみると、この薬の作用が、人を中毒にさそうような要素を含んでいることが分ってくる。",
              "citation": {
                "source": "安吾巷談",
                "author": "麻薬・自殺・宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしと致しましては、それに不服を申そうようはございませぬ、快く夫の申出でに同意を致しまして、妾を内へ入れるようにと申しましたが、それは夫が気兼ねを致しまして……」　お絹はそこで、自分の苦しい立場を、言葉巧みに住職に訴えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "重態ではありましたが、もっともすぐれた看護婦がつきそうようになってから、その効果はすでにあらわれました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして神の思し召しにそうように霊魂も肉身も潔く保ってくださいね。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
