  {
    "uuid": "c0be3ff4-741d-51ef-8771-75fbfcc7089f",
    "entry": "総長",
    "reading": {
      "primary": "そうちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "president (of a university)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "総長の演説があったが何を云っているか自分にはちっとも分らないので少々心細くなった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから新入生一人一人に総長が握手をするというので、一列に並んで順々に繰出して行った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カール総長の握手の力の強いのにびっくりした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "総長にでもなる人にはやはりそれだけの活力があるのかと思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学証書と云ったような幅一尺五寸｜長二尺ほどの紙に大きな活字で皇帝や総長の名を黒々と印刷したものを貰ったが文句はラテン語で何の事か分らない、見ていると気の遠くなるようなものであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日附の所に D. Berolini d. 19. mens. とあって下に総長の署名がある。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十二年関東大震災以前から既に地震学に興味をもっていたが、大震災の惨害を体験した動機から、地震に対する特殊の研究機関の必要を痛感し、時の総長｜古在由直氏に進言し、その後援の下に懸命の努力をもって奔走した結果、遂に東京帝国大学附属地震研究所の設立を見るに到った。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず自分で五〇〇ポンド、当時の名誉総長デヴォンシャヤー公が五〇〇ポンド出した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇八年ケンブリッジで名誉総長デヴォンシャヤー公が死んで、その椅子がレーリーに廻って来た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇九年のダーウィン百年祭はレーリー総長の司会で行われたが、その時の彼の追懐演説に現われたダーウィンの風貌は興味が深いものであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一九一一年に出た版権法修正案が大学の権利を脅かすものであったので、総長レーリーは上院で反対演説をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ウェストミンスター・アベーに記念の標石を納めようという提議が大学総長や王立協会会長などの間に持出され、その資金が募集された。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだ○○帝大総長が帰る時は八挺艪の漁船を仕立てて送ったのだという。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝大総長の引き合いに出るのもどうも解釈がつかない。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは電気総長だよ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　恭一も少し安心して「電気総長というのは、やはり電気の一種ですか。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　恭一も少し安心して「電気総長といふのは、やはり電気の一種ですか。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　黙って瞬でうなずいた目が消えると、たちまち井戸端へ飛んだと思う、総長屋の桝形形の空地へ水輪なりにキャキャと声が響いた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑※この学園たる沢柳政太郎博士総長たり。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "同博士死後、新総長小西重直博士の下に校長小原氏専らその経綸を尽す。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年初夏、総長の辞任と共に、つづいて校長を引責せしむ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "川村の事は只今グラスゴウ市の版元から頼まれて編み居るロンドン大学前総長フレデリク・ヴィクトル・ジキンス推奨の『南方熊楠自伝』にも書き入れ居るから外国までの恥｜曝しじゃ。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三年目がエエリヒ・シュミット総長の下に、大学の三百年祭をする年に当ったので、秀麿も鍔の嵌まった松明を手に持って、松明行列の仲間に這入って、ベルリンの町を練って歩いた。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロスの奴滅茶々々かも解らん」とあたかも軍令部長か参謀総長でもあるかのようなプライドが満面に漲っていた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外が博物館総長の椅子に坐るや、世間には新館長が積弊を打破して大改革をするという風説があった。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳列換えは前総長時代からの予ての計画で、鴎外の発案ではなかったともいうし、刮目すべきほどの入換えでもなかったが、左に右く鴎外が就任すると即時に断行された。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "別当というのは、検非違使の長官をも云うのだが、神社仏寺の事務総長をも云うのである。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さていよいよ衆議一決の暁は、総代を選んで学長の所へ行く、また総長の所へ行く。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先はもう一ぺん寄って、委員を選んで、学長なり、総長なりに、我々の希望を述べにやるばかりである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ああそうそうちょうど幸い、お菊が泣いておりますので、あなた様の明るいご気象で、慰めてやってくださりませ。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
