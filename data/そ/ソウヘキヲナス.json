        "examples": {
          "standard": [
            {
              "text": "決勝戦では、二人の若きチャンピオンが双璧（そうへき）をなす激しい戦いを繰り広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "チームの攻撃陣は、この二人のベテラン選手が双璧（そうへき）をなすことで、さらに強力になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の才能と彼女の努力は、まさに双璧（そうへき）をなすものであり、互いを高め合っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "前者と後者とはカントが自然乃至自然科学に関して著した書物の内、その中心的な意味に於て、その独創に於て、従って又その後世に与え又与えるべきであった影響に於て、双璧をなすものと云ってよい。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く彼の文才といふものは互に相許した友、檀一雄のそれと双璧をなすもので他にはちよつと見当らないと思ふ。",
              "citation": {
                "source": "稀有の文才",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
