        "examples": {
          "standard": [
            {
              "text": "特に目的もなく、駅前をそぞろ歩いて時間を潰した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は考え事をしながら、庭をそぞろ歩いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あぁ、今日も一日中、家の中をそぞろ歩いてただけだよ」と彼はため息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "まだ明るいのに華やかな銀座の店々には電燈がついて、そぞろ歩く人々の顔も何となく晴やかであった。",
              "citation": {
                "source": "凍るアラベスク",
                "author": "妹尾韶夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　山里の朧に乗じてそぞろ歩く。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューシャテルの酔に乗じてそぞろあるく。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
