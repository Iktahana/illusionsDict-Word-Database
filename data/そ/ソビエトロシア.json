        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ソビエトロシアの映画監督が「日本」のフィルムを撮って露都で公開したとき、猫の額のような稲田の小区画に割拠して働く農夫の仕事を見て観衆がふき出して笑ったという話である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は変わるが先日｜銀座伊東屋の六階に開催されたソビエトロシア印刷芸術展覧会というのをのぞいて見た。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ　だけどソビエトロシアには教祖じみた芸術家はいませんね。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に現在までのソビエトロシアのように一つのイデオロギイが絶対力として支配しているところでは、弱いのです。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
