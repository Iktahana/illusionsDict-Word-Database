        "examples": {
          "standard": [
            {
              "text": "「ソビエトロシア」という言葉は、革命初期のロシアを指すことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "第一次世界大戦後、ソビエトロシアは内戦を経て、ソビエト社会主義共和国連邦へと移行した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "当時の国際社会は、ソビエトロシアの出現に大きな関心を寄せていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ソビエトロシアの映画監督が「日本」のフィルムを撮って露都で公開したとき、猫の額のような稲田の小区画に割拠して働く農夫の仕事を見て観衆がふき出して笑ったという話である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は変わるが先日｜銀座伊東屋の六階に開催されたソビエトロシア印刷芸術展覧会というのをのぞいて見た。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ　だけどソビエトロシアには教祖じみた芸術家はいませんね。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に現在までのソビエトロシアのように一つのイデオロギイが絶対力として支配しているところでは、弱いのです。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
