[
  {
    "uuid": "96e52adb-2dba-5ec6-97e0-55508ca4efac",
    "entry": "送信機",
    "reading": {
      "primary": "そうしんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
