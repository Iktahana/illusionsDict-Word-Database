[
  {
    "uuid": "0d57c59a-2175-59c1-814a-7d9e7c4380bd",
    "entry": "操守",
    "reading": {
      "primary": "そうしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
