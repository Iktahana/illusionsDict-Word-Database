[
  {
    "uuid": "d75e717c-d726-5682-b702-aac5f0cc6e3a",
    "entry": "その辺",
    "reading": {
      "primary": "そのへん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
