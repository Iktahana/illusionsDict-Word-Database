    "definitions": [
      {
        "index": 1,
        "gloss": "around there",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新しく出来た六間道路とその辺の者が呼んでゐる通りには、まだギャレッヂと雑誌屋と玉突場とがあるきりだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし著者の意はその辺の些事になくして、蕪村俳句の本質を伝えれば足りるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、ああした山の中に、電車の停車場といふやうな者があると、その辺の空気を奇体に明るくする。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことによるとちょうどその辺を今電車が走っているのかもしれないのである。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の植物はもとより、金峰山から移した高山植物などがその辺に試植されている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺の農家の石垣は、氷河の推し流した堆石を使ったりしているのが、私たち富士山で、万年雪を物色したり、日本アルプスで、「カアル」の痕を、氷河時代の遺蹟か否かと、論じ合ったりしている手合いに、いかに珍しかったろうか。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺から又道路が川の水面に近くなる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがすむまで吾々の車は待たなければならないので車から下りて煙草を吸ひつけながらその辺に転がつてゐる岩塊を検査した。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分の経験によると、暴風の夜にかすかな空明りに照らされた木立を見ていると烈風のかたまりが吹きつける瞬間に樹の葉がことごとく裏返って白っぽく見えるので、その辺が一体に明るくなるような気のすることがある。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺からまた道路が川の水面に近くなる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがすむまでわれわれの車は待たなければならないので車から下りて煙草を吸いつけながらその辺に転がっている岩塊を検査した。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、ここにも女神のために出来た奇妙な怪我人が一人いるのかと、久振りに伯母に対する義憤を催して、弟はその辺の狩に出し遣り、自分は洞穴の中へ入って行った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は、見当り次第の商家の前に来て、その辺にある箒を持って店先を掃くのである。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく役人たちは私たちのやった萱の穂をすっかりその辺に植えて上にみんな蕈をつき刺しました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺へかくしておいてあとで我われがとったということにしてお嬢さんにでも上げればいいじゃないか。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより以前は、その辺からずっと眺め渡すことが出来るかも知れませぬけれども、直接に知るということはむずかしいのであります――先ず推古天皇の頃まで溯っても、五十の音がことごとく別々に使われ言い分けられておったということはなかったと思うのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論翻訳をするものが、原作の思想に同意しているか、いないか、同意しているなら、全部同意しているか、どこまで同意しているか、それは分からないのですが、製作をするとなっても、その辺を考えて見ると、妙なもんです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草が幻よりは少し明るくその辺一面浮んで咲いてゐる。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく野原のその辺は小さな瑪瑙のかけらのやうなものでできてゐて行くものの足を切るのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来その辺はむやみに坂の多い、丘陵と谷とに富んだ地勢であった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその辺りに転っている鉋屑を見、そして自分があまり注意もせずに煙草の吸殻を捨てるのに気がつき、危いぞと思った。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後追いおいに気づいていったことなのであるが、この美しい水音を聴いていると、その辺りの風景のなかに変な錯誤が感じられて来るのであった。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑な線で、発車するまでの間を、車掌がその辺の子供と巫山戯ていたり、ポールの向きを変えるのに子供達が引張らせてもらったりなどしている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその辺りの地勢や人家の工合では、その近くに電車の終点があろうなどとはちょっと思えなくもあった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時どき烟を吐く煙突があって、田野はその辺りから展けていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて背戸と思う処で左に馬小屋を見た、ことことという音は羽目を蹴るのであろう、もうその辺から薄暗くなって来る。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、果して御期待にかなひますか、如何か、その辺の処は御寛容を願ひたう存じます。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西袋も今はその辺に肥料会社などの建物が見えるようになり、川の流れのさまも土地の様子も大に変化したが、その頃はあたりに何があるでもない江戸がたの一曲湾なのであった。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その実態が、かくの如きものである以上、とてもそれは恥かしくて、口に出しては言えない言葉であるべき筈なのに、「恋愛」と臆するところ無くはっきりと発音して、きょとんとしている文化女史がその辺にもいたようであった。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の痛い仁も、その辺にいるようである。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
