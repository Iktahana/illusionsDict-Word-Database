[
  {
    "uuid": "76542615-5810-5989-b775-9a811b41c0c7",
    "entry": "疎開",
    "reading": {
      "primary": "そかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
