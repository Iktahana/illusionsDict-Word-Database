    "definitions": [
      {
        "index": 1,
        "gloss": "match between Waseda University and Keio University (esp. baseball)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
