        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ソプラノがベースに聞こえたりうぐいすの声が鵞鳥のように聞こえるのでは打ちこわしである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、妾が踊子でありソプラノの唄手、イクラ座のプリ・マドンナである天分を認めること。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカの砂漠を進出するモスクワの夜の娘、驚歎した私踊りながら黒い両足が、ニコロの太腿を包囲して、混乱した男女の頭脳に、メゾ・ソプラノの鼻歌が巻きついてくる、私ニコロの前に日本紙幣束にして棄ててしまった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "会堂内で葬式のプログラムの進行中に、突然堂の一隅から鋭いソプラノの独唱の声が飛び出したので、こういう儀式に立ち会った経験をもたない自分はかなりびっくりした。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれつたなきソプラノは、　　　　ゆふべの雲にうちふるひ、灰まきびとはひらめきて、　　　　　桐のはたけを出できたる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンディトライには家庭的な婦人の客が大多数でほがらかににぎやかなソプラノやアルトのさえずりが聞かれた。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと青きソプラノの沈みゆく光のなかに、饐えて病むわかき日の薄暮のゆめ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食後甲板で読書していたら眠くなったので室へおりて寝ようとすると、食堂でだれかがソプラノでのべつに唱歌をやっている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この常に異なる技は、聽衆の大喝采を受けたるが、就中姫が最低の「アルトオ」の聲を發し畢りて、最高の「ソプラノ」の聲に移りしときは、人皆物に狂へる如くなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは漁父の妻子と共に歌ひ出せるにて、子どもらしき「ソプラノ」の音は低き「バツソオ」の音にまじりたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "―一八四九）――イタリアの有名なソプラノの歌手。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしはソプラノよ。",
              "citation": {
                "source": "心配な写真",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の洋楽流行時代に居合わして、いわゆる鋸の目を立てるようなヴァイオリンやシャモの絞殺されるようなコロラチゥラ・ソプラノでもそこらここらで聴かされ、加之にラジオで放送までされたら二葉亭はとても助かるまい。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹き馴れし銀のソプラノ身にぞ沁む。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）さて二号室は「歌姫」と呼ばれ、いい髯面の男だてらに女の着物を着て可憐なソプラノを張りあげ、発狂当時覚えたものであろう古臭い流行歌を夜昼なしに唄いつづけては、われとわが手をバチバチ叩いてアンコールへの拍手を送り、送ったかと思うとケタケタと意味もなく笑い出したりした。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも朝早くから唄いつづける「歌姫」のソプラノが、そう云えば、今朝は少しも聞えない。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歌姫」のソプラノどころか、あれほど執拗でこうるさい「トントン」さえも、どうしたものか聞えない。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "松永博士の推断通り興奮の鎮まった「歌姫」は西の空が茜色に燃えはじめると、火葬場裏の雑木林の隠れ家から例のせつなげなソプラノを唄い出したのだ。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二号室の前を通ると、部屋の中から、帰って来た「歌姫」のソプラノが、今夜は流石に呟くような低音で聞えていた。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に、量のある了輔の聲と、榮さんのソプラノなのが際立つて響く。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスの音とソプラノの音とが、即かず離れずに縺れ合つて、高くなつたり低くなつたりして漂ふ間を、福富の肉聲が、浮いたり沈んだりして泳いでゐる。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に、量のある了輔の声と、栄さんのソプラノなのが際立つて響く。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスの音とソプラノの音とが、着かず離れずに縺れ合つて、高くなつたり低くなりして漂ふ間を、福富の肉声が、浮いたり沈んだりして泳いでゐる。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツとソプラノで、多数の若い女が只動物的な活力を横溢させている一方、少し頭脳型のひとは口づたえの呪文のように空虚感や無目的感を誇張するとすれば、それは今日の文化がいかに本質的に低いかを語る悲しい滑稽の一つなのである。",
              "citation": {
                "source": "私たちの社会生物学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のアルトであり、若々しいソプラノであるだろう。",
              "citation": {
                "source": "「女らしさ」とは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の喉しかソプラノの声は出さない。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいソプラノの出る、または味のあるアルトの出るよい女性の喉を持ってさえおれば、声楽家として第一の必須条件は生理的に具わっている。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで日本に唯一のオペラ団であった藤原義江の団体が「ラ・ボエーム」と「タンホイザー」などを上演したほかソプラノの歌手長門美保歌劇研究所が新しく組織されて活動を始めた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女らしい女心、女の心ですから女心になりますけれども、同じことをいっても女の声は自然にソプラノになるのだから。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
