[
  {
    "uuid": "075e2637-85fd-5398-b3ca-cd6988b2dae0",
    "entry": "速記",
    "reading": {
      "primary": "そっき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
