[
  {
    "uuid": "0ce1d8ea-5743-5fe4-a29b-6dad103d39b2",
    "entry": "惻々",
    "reading": {
      "primary": "そくそく",
      "alternatives": [
        "しょくしょく"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "keenly felt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女性には柔軟な優しみ、惻々たる慈悲心、風雅な淑かさ、繊細な可憐さなどの情緒が蓄積されて来ます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻に侮辱と嘲笑とに価する特色を発見出来るようになって始めて惻々たる憐れみと愛とが蘇るというのだ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其言惻々として人を動かす、東京といはずして江戸といふ、何ぞ其朴訥なるや、朴訥なるものは世情を知らず、世情を知らざれば則ち悲しむこと多きなり。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年前｜臨終の床で自分の手をとり泣いて遺命した父の惻々たる言葉は、今なお耳底にある。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いうちにこの切先が、私の手の内で何人かの血を吸うであろう……と思うと一道の凄気が惻々として身に迫って来る。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その筆致の、悠々として迫らざる、その態度の清澄を極めたる着実さ、その微妙な人心の生むいとも朗らかな自然の飄逸味に、私は惻々と、胸を打たれながら読了した。",
              "citation": {
                "source": "推賞寸言",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "惻々として、上等なる感慨に迫られたものであつた。",
              "citation": {
                "source": "月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辞｜惻々読む者の心をうたねばやまぬ。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮相手が、“Serpent of eternity”である限り惻々泣路岐の感からは逃れ得ぬに定つてゐるのだ。",
              "citation": {
                "source": "浪曼的時評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑え抑えている葉子の気持ちが抑えきれなくなって激しく働き出して来ると、それはいつでも惻々として人に迫り人を圧した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ともいい知れぬ暗黒を予想さす年ではあったが、どこからともなく惻々として心に迫るものがあった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "感動をとおして心に迫る慰安は、立派な悲劇をよんだとき、一層惻々と私たちの精神をゆすってよろこびの感覚にまでたかめるではないか。",
              "citation": {
                "source": "作品のよろこび",
                "author": "――創作メモ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その路々王龍が青い桃を阿蘭にやり、歩きながら阿蘭がそれをかじってゆくところ、赤い辻堂の場面、更に子供のために布を買う阿蘭の姿など、作者の女としての同感、同情、思いやりというものが惻々と底にながれ、感傷をおさえた描写の中に脈うっている。",
              "citation": {
                "source": "パァル・バックの作風その他",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち女の心にある慰問は、もっと歴史の相貌に根ざしたところから惻々と発しているのである。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きながら埋められた生命が無限の思いを惻々と息づいている口である。",
              "citation": {
                "source": "女靴の跡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ今日になって昔を追憶するときに、人間の遭遇と、その別れの運命とが惻々として哀愁を私にそそるのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中人物の心持が惻々として迫って来るというところに筆が到るには、花圃の人生は、未だ浅くあった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時など、廣瀬川といふ川のほとりに坐わつて、エメルソンを讀んだが、秋の日はもう沈んだあとで、閑寂のうちに川水の響が何となく奧ゆかしく聽え、ゆふぐれの景色は惻々われに迫つて來た。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かしら惻々と胸の中を伝わって来る悲しみを覚える。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは作者が榛名山上で野焼を眺め今にもわが心につくかの如き思ひで涙をこぼしてゐる姿を自ら憐むで作つたもの、惻々として人心を打たずには置かない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ先生の文章の常に真気惻々人を動かす所以であって、而も陽春白雪利する者少き所以である。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の腕力だけでふるわれた昔の素朴な武器にふさわしいそういうお守りを、今日もやっぱり縫って、せめては身につけて行かせようとする家族の心持というものが、道子に惻々と迫って来て、それがただ心持の上だけのものとなっているだけ一層切ない街上の風景なのであった。",
              "citation": {
                "source": "築地河岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことによるとそのあとで、「竜華寺に詣ずるの記」くらいは、惻々たる哀怨の辞をつらねて、書いたことがあるかもしれない。",
              "citation": {
                "source": "樗牛の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は明の遺臣であって今更清朝に仕えようとは思わない、自分は他日明朝が再興する日を待って身を託そうとするばかりである、という意味が自ずから窺われて、惻々とその風格に接するの思いがあるのである。",
              "citation": {
                "source": "画室の言葉",
                "author": "藤島武二",
                "note": "青空文庫"
              }
            },
            {
              "text": "又これこそ彼らの新たな戦場にほかならぬ――と、問わず語りに胸にひびく惻々たるものもあったのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その惻々として悲しい声の中に、菩提樹の念珠を手頸にかけた丈艸は、元の如く静に席へ返つて、あとには其角や去来と向ひあつてゐる、支考が枕もとへ進みよつた。",
              "citation": {
                "source": "枯野抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう大した歌でないようでも、惻々とした哀韻があって棄てがたい。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の娘に宛てた惻々たる母の声だ。",
              "citation": {
                "source": "戯曲及び戯曲作家について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や早やも土は凝りて、岩角の犬羊歯が下、枯れ枯れの雑木の根ごと、そくそくと氷柱さがれり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思って龕燈を用意していると、それとも知らずに、予想どおり、いとも奇怪な一道の妖気が、突如右門の身辺にそくそくとおそいかかりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
