    "definitions": [
      {
        "index": 1,
        "gloss": "song",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ツバメは二人の頭の上の巣の中で、じっと動かずにウェディングソングを歌いました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、フォークソングの人気を押し上げたＰＰＭ（ピーター・ポール＆マリー）というグループを案内役にボブ・ディランを聞き始め、そこからピート・シーガー、ウッディー・ガスリーとさかのぼっていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカのフォークソングの伝統に学びながら、視野を広くとって自分たちのうたを見つけようとする、いわゆる関西フォークには、どっぷりはまった口です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギターを抱えて自分でも歌い始めると、気持ちはいっそうフォークソングに傾きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビートルズもフォークソングも、学生運動、そしてパーソナルコンピューターも、確かに自分の目で見てはきたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくとピート・シーガーの「若者と老人」なんてレコードを引っ張りだして、このオレは「♪ブリング・ゼム・ホーム〜」とベトナム反戦のプロテスト・ソング（ああ、こんな言葉を十七年ぶりに思い出しちまったぞ！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などゝいふ合唱が繰り返されるジヤズ・ソングを歌ひながら、マメイドといふ、ちよつと美しい娘がゐる居酒屋を出発点にして賑々しく発足した。",
              "citation": {
                "source": "喜劇考",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォークソングとか」　これは予想外の答だったが、すくなくとも歌謡曲ではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽に興味がないならともかく、じつによくヒットソングを知っているワラが、シルヴィー・ヴァルタンも、〈アイドルを探せ〉も、同題の映画も知らないというのは、慶一には信じられなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォークソング・ファンには、『ヘルプ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつら、これをやってたんだ……」　長田が立ちあがって、これから、練習したクリスマス・ソングをみんなで歌う、まず〈ジングル・ベル〉をもういちど、とみんなに説明し、腰をおろして、高志を見て、頭を動かし、出だしをそろえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウェル、ゴナ・ビー・ザ・ラスト・ソング・フォー・トゥナイト……ウー、ベイビー、アイ・ラヴ・オンリー・ユー、〈ユー・ベイビー〉」　ワラが、ドラムとスレイ・ベルをバックにささやく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び半分にクリスマス・ソングでもやるなら、平和でいいけどな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いつも、いろんな歌を聴いたり、うたったりしててさ……ああいう歌詞がいってるのが、なんのことかわかったんだ」　もちろん、ラヴ・ソングは一種類ではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ディス・ソング・イズ・デディケイティド・トゥ・ザ・レイト・グレイト・ジーン・クラーク。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三中年が寮への坂道をくだっていく、俯瞰気味の引きの絵、オーケストラがＧ、Ｆとさがってくる、Ｃでドーンとフォルテシモになって、画面溶暗、テーマソングがかかって――〈イエス・アイ・ウィル〉かな――でもって、タイトルが縦スクロールをはじめる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "Casi me he caido,Traigame algo mas,No es nada no toque,　歌にまでまだ飲みたいと、日頃自慢のスパニッシュ・ソングを歌う甲谷を見ていると、参木は立ち上らずにはいられなかった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンドレッド・ベスト・ホームソングスというような厚い四角い譜ももって来た。",
              "citation": {
                "source": "きのうときょう",
                "author": "――音楽が家庭にもたらすもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし健全な家庭で親も子供も歌ってよろこぶようなホーム・ソングは生れていない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の歌の中にラフイング、ソング（笑歌）と題するのがあつて何の事だかわからぬが、調子は非常な急な調子で、ところどころに笑ひ声が這入つてゐる歌であつた。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六〇年代の音楽的潮流の一つに、フォークソングがありました。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、ビートルズの代表する音楽とフォークソングとは、使用する楽器がエレクトリックかアコースティックかから始まって、景気のいい恋の歌かそれとも社会性を帯びた歌かなど、さまざまな点で対立的にとらえられていたように思います。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォークソングの代表的な旗手であるボブ・ディラン。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七五（昭和五十）年暮れ、クリスマスソングが師走の賑わいをあおる中で、加藤は実験の詰めに余念がなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォークソング自体が日本で聞こえはじめたのは、タケシの高校入学の時期よりもさらに二、三年前にさかのぼる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギターを抱えての弾き語りというスタイル、あるいはギターの奏法などにおいて、一九六〇年代半ばから広がりはじめたフォークソングには復古的なにおいも入りまじっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし年若い世代は、フォークソングをまったく新しい種類の音楽として受け取った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽のプロたちによって作られ、演奏される、他人からの供給物ではなく、自らをとらえなおすための道具、自己表現の手段として、フォークソングを利用しようとしたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの多くは、音楽の専門性を否定したところからスタートしたにもかかわらず、自らがプロになっていくという自己矛盾にその後悩まされることになるが、そのことは逆にこの時期のフォークソングの持っていた一種の新しさを示しているともいえよう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの時期、フォークソングは直接に政治の場に登場してきたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
