    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rustic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けだし室生君の眼からみれば、禮節身にそなはり、教養と學識に富む文明紳士の芥川君は、正に人徳の至上觀念を現はす英雄であつたらうし、逆に芥川君の眼から見れば、本性粗野にして禮にならはず、直情直行の自然兒たる室生君が、驚嘆すべき英雄として映つたのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は独り息子であるから、ずいぶん可愛がられて、十年ほど前にお母さんが死んで、それからは厳父は、何事も大隅君の気のままにさせていた様子で、謂わば、おっとりと育てられて来た人であって、大学時代にも、天鵞絨の襟の外套などを着て、その物腰も決して粗野ではなかったが、どうも、学生間の評判は悪かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は知性の人でなくして感性の人であり、江戸ツ子的神経の都会人でなくして、粗野に逞しい精神をもつた自然人であり、不断に燃焼するパツシヨンによつて、主観の強い意志に生きてる行動人である。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「粗野で逞しいポーズ」と、そのポーズの背後に潜んでゐる「優しくいぢらしいセンチメント」とは、彼のあらゆる小説と詩文学とに本質してゐるものなのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽井沢に似て、も少し感じが粗野であるが、それが如何にも処女地といふ新鮮な響をあたへる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲食も、コーヒー、シトロン、紅茶などの近代的芳香の飲料と、阿倍川もち、力もち、葛湯、麦粉などの中世的粗野なる甘味が供給される。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は全くの田舎風ではあったが、決して粗野ではなかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧水氏はそれを憤慨してゐたけれども、あの粗野な風采と態度を考へ、僕はユーモラスの微笑を禁じ得なかつた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち一言にして言へば、「粗野」といふ言語が君の一切を盡してゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今、僕の前に對座してゐる、この如何にも田舍文士然たる粗野の人物が、果してあの青白い貝のやうな詩を作つた、高貴な優しい室生犀星であるだらうか？",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん君は、依然として粗野であり、依然として垢ぬけない田舍の投書家臭味をもつてゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの魅力は、君の荒々しき粗野の性格から、最も強くはつきりと響いてきた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも君は、君自身の性情する「粗野」を惡んでゐる。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば君は、實にその粗野な心の一面に、女のやうな優しい羞恥を持つて居たからだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の室生君の一場は、昔の粗野な書生的友情が囘想されて、取りわけ私にはなつかしかつた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこのピューリタンといふ奴が、元來文化的情操のデリカを知らない粗野の精神に屬してゐる。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に粗野で感覺のデリカを缺いてる。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗野にして滑稽なる相貌をもち、遅鈍にして大食であり、あらゆるデリカシーというものを完全に欠如した性格であった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処となく荒涼とした粗野な自由な感じ、それは生面の人を威脅するものではあるかも知れないけれども、住み慣れたものには捨て難い蠱惑だ。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道を奥の方へと荷馬車の通うのにも出逢ったが、人里がありそうにも思えない荒寥たる感じで、陰鬱な樹木の姿も粗野であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆のもつ粗野で原始的なリズムは、牧歌や民謠の中に現はれた、あの拍節の明晰な、力の強い、筋肉の強健な、あの太くがつしりとしたリズムである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舍の粗野な老婦が居て、側の人にたのみ、手紙の代筆を懇願してゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世界の實景實情を語るためには、人間の言葉はあまりに粗野であまりに感情に缺けすぎてゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして或る他の別な詩人等は、強いて言語に拳骨を入れ、田舎政治家の演説みたいに、粗野ながさつな音声で呶鳴り立てている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その始めは彼等の国語も、殆ど文学的に使用できない粗野の蛮人語にすぎなかったのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の粗野な老婦が居て、側の人にたのみ、手紙の代筆を懇願してゐる。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の祭日の粗野な賑わいを追っ払ったあとから本然の姿を現わして優雅に返った巴里の空のところどころに白雲が浮いて居る。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生粋の津軽人といふものは、ふだんは、決して粗野な野蛮人ではない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり水が低きにつく如く、花がひそやかであるが如き気持がなければ、詩は駄目だと思つた。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という上品で甘やかなメロデーだと賞めそやしました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
