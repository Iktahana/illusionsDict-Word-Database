[
  {
    "uuid": "ea1f2452-d99f-5c32-b5cd-adf5a42d69e3",
    "entry": "壮烈",
    "reading": {
      "primary": "そうれつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heroic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この頃活動写真で色々な空中戦の壮烈な光景を見せられる。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛別離苦の悲しみと偉大なものに生命を賭ける壮烈な想いとで翁の腸は一ねじり捩れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その愛別離苦の悲しみや壮烈な想いで、わしの腸はこんなに螺の貝のように捻じ巻いたのじゃないか」と山の祖神の翁は負けん気の声を振り立てていった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は寝床に起きあがると中年女の壮烈な教練を始めた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこれがこの地球に響いた最初の生の合唱だと思うといくらか壮烈な気がしないでもない。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と橋田氏は引き取り、「とにかく壮烈なものでしたよ。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もののはずみ」で、つい、女性の繊手を握ってしまった事も無かったし、いわんや、「ふとした事」から異性と一体になろうとあがく特殊なる性的煩悶、などという壮烈な経験は、私には未だかつて無いのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モトモトテニスらしいものが出来るのは、正直のところ一滴も酒の飲めない筆者の一組だけで、ほかは皆、支那の兵隊と一般、テニスなんてロクに見た事もない連中が吾も吾もと咽喉を鳴らして参加するのだから、鬼神壮烈に泣くと言おうか何と言おうか。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲日清戦争に於ける戦勝の結果、我は当然得べき遼東半島を奪取せられしも、同時に臥薪甞胆なる壮烈の意気を得たり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず彼の様な詩を作るものに限つて決して壮烈の挙動を敢てし得ない、即ち単なる自己広告のために作る人が多さうに思はれるのである。",
              "citation": {
                "source": "艇長の遺書と中佐の詩",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も、うっかり、レヤチーズの壮烈な最後に熱狂し、身辺の悶着を忘れていた。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」これは、ベートーヴェンの言葉だが、壮烈な覚悟だ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に壮烈なものである。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月の事件の日、女の寝巻について語っていたと小説にかかれているけれども、青年将校たちと同じような壮烈なものを、そういう筆者自身へ感じられてならない。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々にはなんの奇異もなく見える事柄も、悟空の眼から見ると、ことごとくすばらしい冒険の端緒だったり、彼の壮烈な活動を促す機縁だったりする。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里ではその子の禎介氏の記念図書館の館長をしていられ、老後を全く壮烈な忠死を遂げた、その子の名誉を己れの円光として生きている人である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前の壮烈な恋喧嘩の結果を見れば、優しく強いリメイがついている限り、幾らエビルが攻寄せて来ても恐れることはない。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（下）　月明の霜朝に、自分等に代って断頭場に向った大先輩、武部小四郎先生の壮烈を極めた大音声、「行くぞオーオ」　を聞いて以来、奈良原到少年の腸は死ぬが死ぬまで腐らなかった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井勢の中に於て、其の壮烈、朝倉の真柄直隆に比すべきものは、遠藤喜右衛門尉だ。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜右衛門は、信長と戦端を開く時には、浅井家長久の為めに極力反対したが、いざ戦うとなると、壮烈無比な死に方をしている。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "真田一党の壮烈な最後は「日本にはためし少なき勇士なり。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼前脚下は一大傾斜をなして下っていて、其の先に巍然として雄峙している穂高は、其の壮烈｜儼偉な山相をムンズとばかりに示していた。",
              "citation": {
                "source": "穂高岳",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いきり立つ」は即ち人が意気壮烈なので、「いきまく」は即ち人の気が風動火燃しようとするのを云い、「いきざし」は心が向い目指す所を心ざしと云うのと同じく、人の意気の向うところを云う。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人の女は、優に一人の男をだまりこませる程に仲間の力をもつて、しやべり捲くるものだ、プロレタリア詩人よ、我々は大いに、しやべつたらよい、仲間の結束をもつて、仲間の力をもつて敵を沈黙させるほどに壮烈に――。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "水軍の策戦は『三国志』の赤壁をソックリそのままに踏襲したので、里見の天海たる丶大や防禦使の大角まで引っ張り出して幕下でも勤まる端役を振り当てた下ごしらえは大掛りだが、肝腎の合戦は音音が仁田山晋六の船を燔いたのが一番壮烈で、数千の兵船を焼いたというが児供の水鉄砲くらいの感じしか与えない。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより事は急、壮烈きわまりない訴人のその覚悟を見ては、ちゅうちょしている場合でないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲痛な声もろともにすっくと立ち上がりざま、そこのたな奥にあった素焼きのかめをかざし持って、頭から五体一面に中の水液をふりかぶったかと思うと、泥斎の覚悟また壮烈です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮烈と申しますか、悲壮と申しますか、いっそ御覚悟の程が涙ぐましい位で厶ります」「そうぞ。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は松林を脱けて白い砂原が一望の下に見渡せる砂丘の上に来た時に、恰度私の眼下で、それはもう実に壮烈な運動――跳んだり駆けたり、もんどりを打つたり――の最中であるパンツ一つの人影を見出すと、何故か見てはならぬものを見てしまつたやうに愕然として砂に突ツ伏してしまつた。",
              "citation": {
                "source": "サロメと体操",
                "author": "ヘツペル先生との挿話",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方を屏風のやうな丘に囲まれた私達の村は、秋口から初冬へかけての南風が襲ひはじめると、どつとばかりに津波の勢ひで村外れの河口から吹きあげてくる速風は周囲の丘に行手をさへぎられて、唸りを挙げて天に沖し、壮烈な風巻を巻き起すのが常であつた。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
