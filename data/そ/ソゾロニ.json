[
  {
    "uuid": "3216af84-40d2-54aa-8af0-cbd266c5d9a2",
    "entry": "漫ろに",
    "reading": {
      "primary": "そぞろに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
