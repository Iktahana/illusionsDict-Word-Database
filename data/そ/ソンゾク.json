[
  {
    "uuid": "3a8cba85-66f8-5db0-8701-6ee6ad42485d",
    "entry": "存続",
    "reading": {
      "primary": "そんぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
