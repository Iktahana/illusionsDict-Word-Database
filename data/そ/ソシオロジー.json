          "literary": [
            {
              "text": "ウォド著ソシオロジー（社会生理学）、ヘッケル著（人類史、原名は忘れた）以上英文。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、ソシオロジーをよむ。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "墺居斯多・坤度嘗て五學の模範を著はし、天上理學（天文學）、地上理學（格物學、化學）、生體學（バイオロジー）、社會學（ソシオロジー）と爲す。",
              "citation": {
                "source": "尚白箚記",
                "author": "西周",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
