[
  {
    "uuid": "6f6745b5-8f36-59f3-8bf2-16c080883edd",
    "entry": "想像に難くない",
    "reading": {
      "primary": "そうぞうにかたくない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
