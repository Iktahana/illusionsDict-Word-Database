        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毒茸も「それ見ろ」と威張っておりました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ見ろ」といわんばかりの顔をして子供達は憎らしそうに僕の顔を睨みつけました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ見ろ、萩原に縋って離れやせん。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　それ見ろ、弱虫。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ見ろ」「何がそれ見ろなの？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "轡虫は大威張りでそこいらの露をヤタラに吸いながら、「それ見ろ。",
              "citation": {
                "source": "がちゃがちゃ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ見ろ、この通りだ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ると無茶先生は大威張りで、「それ見ろ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それ見ろ、早瀬、」「何だ、お前、」「いいえ、貴下、この花を引張るのは、私を口説くのと同一訳よ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ見ろ、それ見ろ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ見ろ」　と庄之助は呟いた。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディオニシアスは、それ見ろと笑いました。",
              "citation": {
                "source": "デイモンとピシアス",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその刀折れ矢尽きて現社会から敗退して行った翁の末路を見てホッとした連中が「それ見ろ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ見ろな怒られつから、そら此處にえゝものが有つた」おつぎは田圃にある鼠麹草の花を※つて筵へ載て遣つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それ見ろ、お麗さん逃亡さ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ見ろ、猫や犬の方がまだ健気な処がある。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは賢こいお方が王様になっておいでになる方が、この国の仕合わせで御座います」「それ見ろ。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『それ見ろよ、あれが栗橋の鉄橋だと』　かう主婦が二人の少年に指して見せた。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ見ろと、喜平は銀蔵にささやいて、猶もぬき足をしてそのあとを尾けようとする時、突然にどこからか大きな手のようなものが現われて、ふたりの横っ面を眼がくらむほどに強く引っぱたいたので、あっと叫んで銀蔵は倒れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも貴様はなにか、あの飛行島をこしらえるわけをくわしく知らにゃ許さんというのか、たかがああいう馬鹿げた無用の不時着場を、――」　川上機関大尉はにやりと笑って、「それ見ろ、気にしていないなんていっていながら、貴様はちゃんと飛行島のことを考えているじゃないか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると予審判事は、それ見ろというような顔をして云った。",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親　それ見ろ、知らないじゃないか。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れてから戻つた、そしてお茶漬さら／＼いたゞいて寝た、飲みすぎて少し苦しかつた、それ見ろ、罰があたるぞ、いや、あたつてゐるぞ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ見ろ」というので、その後二人は島田の喜びそうなものを選んでは読ましていたが、島田は浪六の『五人男』がすっかりお気に召して、「俺は黒田だ、大杉貴様は倉なんとかだ」というようなことを言って一人で喜んでいた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ見ろ、結婚しないなんてことは人間の仲間に入れないことだ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ見ろ、本なんぞ読むからこんなことになるんだ」　彼は五十哥をゴーリキイに握らせ、念を押した。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私下のお神さんに、それ見ろ、間代も払えないと思われるの癪なんだもの」「あなた、ちっともお裁縫もしない罰よ」「そうなの。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鮹の燐火、退散だ」　それみろ、と何か早や、勝ち誇った気構えして、蘆の穂を頬摺りに、と弓杖をついた処は可かったが、同時に目の着く潮のさし口。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それみろ、旨そうだろう。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、てめえだって何年となく牧場にいるんだから、安い馬か高い馬かぐらいは知っているだろう」「それは……」「それみろ！",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
