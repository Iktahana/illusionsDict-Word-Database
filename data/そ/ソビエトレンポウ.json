        "examples": {
          "standard": [
            {
              "text": "スパイ活動の捜査で、「ソビエト連邦」という言葉が頻繁に登場した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史の授業で、ソビエト連邦の崩壊とその影響について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "旧ソビエト連邦の国々では、今も当時の名残が見られることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これぞ赤きコミンテルンの国、ソビエト連邦の密使であって、元海軍人民委員長という海軍大臣と軍令部長とを一しょにしたような要職にいた軍人であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一はソビエト連邦。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "潜水将校リーロフは、ソビエト連邦にその人ありと、外国にまで名のきこえた大技術者だ。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
