  {
    "uuid": "fb81f929-cf73-56d0-965f-a4646da53bea",
    "entry": "俎豆",
    "reading": {
      "primary": "そとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ancient altar of sacrifice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幼にして俎豆をならべ礼譲を学ぶ者あり。",
              "citation": {
                "source": "読書弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのいずれにも関係のない個所を拾い上げると、（一）　孔子は子供の時、俎豆を陳ね礼容を設けて遊んだ。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俎豆の話を想像し出した人々は、右の句を味わうことのできなかった人々であろう。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子｜対えて曰く、俎豆の事は則ち嘗て聞けるも、軍旅の事は未だ学ばずと。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子対えて曰く、俎豆の事は則ち嘗て之を聞けり。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかはあれど、寒きほのほに黄の入日さしそふみぎり、朽ちはてし秋の※オロンほそぼそとうめきたてぬる。",
