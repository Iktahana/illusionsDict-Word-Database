[
  {
    "uuid": "b3745647-9cfd-52b1-b385-8b816feeb272",
    "entry": "鼠盗",
    "reading": {
      "primary": "そとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pilfering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかはあれど、寒きほのほに黄の入日さしそふみぎり、朽ちはてし秋の※オロンほそぼそとうめきたてぬる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして只圓翁の凜烈の気象は暗にこれに賛助した事になるので、翁の愛嬢で絶世の美人といわれた到氏夫人千代子女史が、夫君の後を趁うて雪中を富士山頂に到り夫君と共に越冬し、満天下の男女を後に撞着せしめた事実も、さもこそとうなずかれる節があるやに察せられる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごろすけ二山家そだちの五郎助が、町へ出てから九年目に、寶の數を背に負うて、峠の道へ來かかれば、いたづら好きの梟が、「五郎助よくも奉公」と、寺の和尚の口眞似を、「さうでもない」と五郎助は、山をこちらへ、いそいそとうまれの里へ初見舞。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのお化けは、いつもやぶけた提灯だの、墓場のそとうばと関係があり、そのそとうばは、昼間日のよくさしている養源寺の墓地にもやっぱりいっぱい古いのや新しいのが立っているのだった。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "取りしらべはそのくらいにしておきましょう」　検事は、そういって、警官たちと、ひそひそとうちあわせを始めた。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度こそとうとうこんなことになった。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、エキモスを神さまのお使いだとおもっていましたので、おもてだってお礼にいくこともおそろしいような気がして、ただかげで、ありがたがって、ひそひそとうわさするだけでした。",
              "citation": {
                "source": "銀の笛と金の毛皮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその島々の自然的配置が面白く、恐らく火山島だろうと思われる、奇石怪岩がいたるところに散在して、後で聞いたが、天草松島といわれているのも、さこそとうなずかれる風景であつた。",
              "citation": {
                "source": "天草の春",
                "author": "長谷健",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これから、どこへいくのじゃ、どうせ殺されるものならば、都には余り遠くないこのあたりで殺して欲しいものを」　大納言の気持もさこそとうなずかれても、命令のない者を勝手に殺すわけにはゆかない。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬のみにあらず、童どもゝ雪のはじめより外遊する事ならざりしに、夏のはじめにいたりてやう／＼冬履稿沓をすてゝ草履せつたになり、凧などにかけはしるはさもこそとうれしさうなれ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二つにでも、三つにでも、わけて見ねえな」　世間とは何で、出世間とは何だと、野暮な追究を試みるようなことをしないで、三つにでも、四つにでも、千万無量にでも、分けられるものなら分けてみねえなという度量を示したものですから、弁信もさもこそとうなずきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり最初は遠廻しにごくくだらないことか、それとも、よしまじめな問題にもせよ、まるで関係のない事から始めて、それでもって被｜訊問者に元気をつけ、いやむしろ注意をそらして、その警戒心を眠らせておき、その後でふいにそれこそとうとつに、のるかそるかという危険な質問をまっこうから浴びせかけるんです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
