        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大体、戦前から戦後にかけて彼の筆役勤務の現役を終えた文人であって、この付近に雑誌社、新聞社の巣窟があった時代の習慣で足はおのずとここへ向く。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにパルチザンの巣窟があることは、それで、ほぼ想像がついた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊長は、そのパルチザンの巣窟を、掃除することを司令官から命じられていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ユフカは、たしかに司令官閣下の命令通り、パルチザンばかりの巣窟でありました――そう云います。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いろ／＼委しい事を承りたいが、最早暮るゝにも近く、此邊は猛獸の巣窟ともいふ可き處ですから、一先づ我が住家へ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が普通の塲所なら、かゝる死地に落ちても、鐵車をば此處に打棄てゝ、其身だけ免れ出る工夫の無いでもないが、千山萬峰の奧深く、數十里四方は全く猛獸毒蛇の巣窟で、既に此時數十の獅子、猛狒の類は此穴の周圍に牙を鳴し、爪を磨いて居るのだから、一寸でも鐵檻車の外へ出たら最後、直ちに無殘の死を遂げてしまうのだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "区々たる藩閥の巣窟に閉籠り、自家の功名栄達にのみ汲々たる桂内閣ごときでは、到底、永遠に日本の活力を増進せしめる事は出来ない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師はこの街道筋が追剥の巣窟だったと云う事実を思い出したのに違いない。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めはラテン区が彼等の巣窟だったが、次にモンマルトルに移り、今ではモンパルナッスが中心地となっている。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "攝州の住吉だの、茨城、埼玉の某地だのの如きは、十二指腸蟲の巣窟で、そこの蔬菜井水を飮食すれば、危險至極で、其の附近には同患者の多いのは爭ふ可からざることである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狐狸の巣窟を発いて初めて拓いたのが三ツ家の漂流民だと伝えている。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何だかここいらに伯父の巣窟がありそうに思えたので、その印度人に握手する振りをして十円札を一枚握らせると、印度人は私の気前のいいのに驚いたらしい。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、漸く辿り着かれた大和も、群敵の巣窟であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宮は貧民の街であり、ルンペンの巣窟である。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と答え、肩から銃器を吊して谷の方へ大股で歩いていき、野獣どもの巣窟たる山脈のさなかへと消えてゆく。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはやはり汚穢の巣窟にしても、それほど不調和ではないためにそれほど不快なところじゃないからね。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、山賊の巣窟かな。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれどもこの小児的の感念は遠からずして破砕せられたり、余は基督教会は善人のみの巣窟にあらざるを悟らざるを得ざるに至れり、余は教会内においても気を許すべからざるを知るに至れり、しかのみならず余の最も秘蔵の意見も、高潔の思想も、勇壮の行績も、余をして基督教会に嫌悪せしむるに至れり。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の住吉だの、茨城、埼玉の某地などは十二指腸虫の巣窟で、そこの野菜や井水を飲食すると危険至極で、その附近に同患者の多いことは争えないことである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "師直の一家中もその数には洩れないで、かれらが生い立った武蔵野の芒をそのままという髭面をそらせて、坂東声を遠慮｜会釈もなしに振り立てるいわゆる「猛者」の巣窟である中に、かの采女ばかりは都びとにも笑われないような優美の風采を具えていた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お白州へかけるまでもなく、一団は右門のいったとおりのにせ金使いで、のみならず火にかけたあの一軒家こそは、それなる一味の巣窟であったばかりではなく、にせ金を鋳造していた場所だったのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなの知恵じゃ、すぐとそいつが一味の巣窟にも穴倉にも見当がつくんでがしょうが、あっしゃぺったり生き血を首筋へやられたときゃ、五年ばかり命がちぢまりましたぜ」「じゃ、きげん直しに乃武江でも招いて、いっしょにところてんでも食べるかな」　すると、伝六が急にくつくつ笑いながらいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした学校の付近の飲食店やミルクホール、カフェーなぞは不良学生の巣窟となった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず神田辺から相生町、深川の木場、日本橋の裏通り、京橋の八丁堀、木挽町、新富町あたりの彼等の昔の巣窟を探検して見ると、どうしたことか彼等の巣窟らしい気分がちっともない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかして東京市内に居る江戸ッ子の行衛を探る方法はないかと考えた末、納豆売りの巣窟を探しまわって売り子の話を聴いて見た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあここは××会の壮士の巣窟だな。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは真っ暗な草原で、野犬の巣窟、追剥ぎの稼ぎ場である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると妻はいつそうくつろいだ樣子をして、くるしい？",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
