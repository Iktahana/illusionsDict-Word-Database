[
  {
    "uuid": "36d09596-1043-54a1-9783-a32371f33fb6",
    "entry": "損になる",
    "reading": {
      "primary": "そんになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
