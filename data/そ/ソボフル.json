[
  {
    "uuid": "9bb723c5-2da9-58bd-89af-b44b6422ddb0",
    "entry": "そぼ降る",
    "reading": {
      "primary": "そぼふる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
