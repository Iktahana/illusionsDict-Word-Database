        "examples": {
          "standard": [
            {
              "text": "庭の雑草が育ちすぎて、どこに道があるのか分からない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この盆栽は、少し枝が育ちすぎているから剪定が必要だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "植物が育ちすぎると、他の植物の成長を妨げることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「甲子太郎も坊っちゃん育ちすぎるよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "――幹の上を切ったのは、育ちすぎると、断崖に張った根が、それを支えきれなくなるからで、そのずんぐりした不恰好なすがたは、甲斐にとって馴染のふかいものであった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
