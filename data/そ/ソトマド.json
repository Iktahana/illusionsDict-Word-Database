        "examples": {
          "standard": [
            {
              "text": "古い日本家屋には、雨戸の内側に障子の外窓があることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結露防止のため、断熱効果の高い二重の外窓を取り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カフェのテラス席からは、開放的な外窓越しに街の景色が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その器にふたがないから、風雨にて外窓を開くことのできぬ場合には、ずいぶん臭気、鼻を襲い来たる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な建てかたで、数の少い外窓の内側が窮屈な廊下になっていて、その中に広間があった。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
