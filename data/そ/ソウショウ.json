    "definitions": [
      {
        "index": 1,
        "gloss": "master",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俳壇のいわゆる俳人たちは、彼らの宗匠的主観に偏して、常に俳句を形態上のレトリックでのみ皮相な手法的技巧観で鑑賞するため、句が詩情している本質のポエジイと、その背後にある主観の貫ぬく哲学とを、ややもすれば閑却無視することになるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした輪廻の道程がもう一歩進んで堕落と廃頽の極に達し俳句が再び「宗匠」と「床屋」の占有物となる時代が来ると、そこではじめて次の輪廻の第一歩が始まるのではないかという気もする。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは高野山に籍を置くものだといった、年配四十五六、柔和ななんらの奇も見えぬ、懐しい、おとなしやかな風采で、羅紗の角袖の外套を着て、白のふらんねるの襟巻をしめ、土耳古形の帽を冠り、毛糸の手袋を嵌め、白足袋に日和下駄で、一見、僧侶よりは世の中の宗匠というものに、それよりもむしろ俗か。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "法橋紹巴は当時の連歌の大宗匠であった。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論秀吉は小田原陣にも茶道宗匠を随えていたほどである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論利休を幇けて当時の趣味の世界を進歩させた諸星の働きもあったには相違ないが、一代の宗匠として利休は恐ろしき威力を有して、諸星を引率し、世間をして追随させたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼うだ御方と、今一人の富豪と筆者と、三人歴行して自動車を降り、二月末の曇雲の下を藁葺のお寺じみた門に進むと、益田翁は黒い背広に宗匠頭巾庭穿靴でニコニコと出迎えた。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ当の芋倉長江画伯が、死人のような青い顔に宗匠頭巾、灰色の十徳という扮装で茫々然と出社して来た。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保より明治子規に至るいわゆる月並み宗匠流の俳諧は最も低級なる川柳よりもさらに常套的であり無風雅であり不真実であり、俳諧の生命とする潜在的なるにおいや響きは影を消した。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」スルト側から水戸の川又子、俳号を五｜茶と申す、宗匠気取りで、　ああら天狗一夜の宿を貸し給えと駄句れば、「アーメン」と誰か混ぜ返した者がある。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、路次裏のいかさま宗匠が、芭蕉の奧の細道の眞似をして、南部のおそれ山で、おほかみにおどされた話がある。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若竹や――何とか云う句で宗匠を驚したと按摩にまで聞かされた――確に竹の楽土だと思いました。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉で、見知越で、乗合わした男と――いや、その男も実は、はじめて見たなどと話していると、向う側に、革の手鞄と、書もつらしい、袱紗包を上に置いて、腰を掛けていた、土耳古形の毛帽子を被った、棗色の面長で、髯の白い、黒の紋織の被布で、人がらのいい、茶か花の宗匠といった風の……」　半ば聞いて頷いた。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗匠頭巾をかぶって、『どうも此頃の青年はテニヲハの使用が滅茶で恐れ入りやす。",
              "citation": {
                "source": "或る忠告",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の風流宗匠たちが、この句に愕然としたわけも、それでよくわかる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "織部は今に織部流の茶道をも花道をも織部好みの建築や器物の意匠をも遺して居る人で、利休に雁行すべき侘道の大宗匠であり、利休より一段簡略な、侘に徹した人である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い油筒を花生にするなんというのは、もう風流に於て普通を超えて宗匠分になって居なくては出来ぬ作略で、宗匠の指図や道具屋の入れ智慧を受取って居る分際の茶人の事では無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧連歌の催しを仕て居る商人が、俳諧連歌の最中に商用の生じたのに會つた時、古の宗匠が、商賣の御用を濟ませられて後また連歌をさるゝが宜敷、と云つたのは實に面白い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論秀吉は小田原陣にも茶道宗匠を随へてゐたほどである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論利休を幇けて当時の趣味の世界を進歩させた諸星の働きも有つたには相違ないが、一代の宗匠として利休は恐ろしき威力を有して、諸星を引率し、世間をして追随させたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其代り所謂宗匠に視せると、宗匠は苦い澁い顏をするもので、其の又宗匠のイヤな顏をするのを面白がつたものであつた。",
              "citation": {
                "source": "淡島寒月氏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "むべなるかな、君を、作中人物的作家よと称して、扇のかげ、ひそかに苦笑をかわす宗匠作家このごろ更に数をましている有様。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は高野山に籍を置くものだといつた、年配四十五六、柔和な、何等の奇も見えぬ、可懐い、おとなしやかな風采で、羅紗の角袖の外套を着て、白のふらんねるの襟巻を占め、土耳古形の帽を冠り、毛糸の手袋を箝め、白足袋に、日和下駄で、一見、僧侶よりは世の中の宗匠といふものに、其よりも寧ろ俗歟。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧派の宗匠や、新傾向の俳人が浜町の寮に招き寄せられた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我｜庵を隔つること杜ひとつ、名宗匠｜其角堂永機住めり、一日人に誘はれて訪ひ行きつ、閑談｜稍久しき後、彼の導くまゝに家の中あちこちと見物しけるが、華美を尽すといふ程にはあらねど、よろづ数奇を備へて粋士の住家とは何人も見誤らぬべし。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保十三年三月の頃から五｜分月題の子之助は丁稚兼吉を連れて、鳥羽屋を出で、手習の師匠松本、狂歌の宗匠梅屋鶴寿等を訪うことになったが、その帰途には兼吉を先に還らせて、自分は劇場妓楼に立ち寄った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話は浪人になつて大阪にゐた時、点取と云ふことを人に勧められてしたが、宗匠に不服なのと、どうも無学な人にかなはないのとで、すぐに廃めたと云ふことであつたさうだ。",
              "citation": {
                "source": "俳句と云ふもの",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉見て、温泉に這入って、ゆっくり晩の御飯食べて、―――」「そうしょう、そうしょう、もうそれにきめたわ。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "儀十　　じゃそうしょう。",
              "citation": {
                "source": "一本刀土俵入　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぼせるといかんせに帰なんか」「そうじゃなあ、そうしょうか」　いねは素直に帰る方へ向いて立ち上った。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
