        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "半だ」　と騒々しい。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客は愈々騒々しい。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処彼処の弥次馬連ワイワイ、ワイワイ騒々しい事！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと云ってあまり騒々しいぷろれたがり屋の酒呑み客も来なかった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこには、騒々しい雑音と、軋音が、気狂いのように溢れていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな貧しそうな子ばかりで、中には風邪を引いたのがだいぶあって、かわいそうに絶えず咳をして騒々しい。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし昼間は、あの遠い所でする妙な音はいろいろな周囲の雑音に消されてしまうのか、ただすぐ自分の室のすみでガチャンガチャンと鳴るきわめて平凡で騒々しい、いくらか滑稽味さえ帯びた音だけが聞こえる。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の夜嵐吹きすさぶころとなっても、がさがさと騒々しい音で幽遠の趣をかき擾している。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの物静かな唱歌はもう聞かれなくなって、にぎやかなむしろ騒々しい談笑が客車の中に沸き上がった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなければ柿江も西山もあんな騒々しい声を立てるはずがない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ夕方は昼間にひきかえて騒々しいまでに賑やかだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜一夜踊りおって騒々しいわ、畜生ども、」　とハタと見るや、うしろの山に影大きく、眼の光｜爛々として、知るこれ天宮の一将星。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と口々に呼ばわれば、「何だ何だ騒々しい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）どうも騒々しいな。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにか騒々しいことが出来したそうで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてバタバタという騒々しい足音と共にお前がひどく狼狽しながら息を切らして姿を現わすと、再び別荘の方へ走って行くのが木の間がくれに見られた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐいとその石油鑵ぐらゐの大きさのお弁当箱に鼻先を突込んで、むしやむしや、がつがつ、ぺつぺつ、といふ騒々しい音を立てながら、それこそ一心不乱に食べてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていま迄、下手に謙遜に学び取っていた仕方は今度からは、争い食ってかかる紛擾の間に相手からのような騒々しいものを混えることに於て、却って知音や友情が通じられる支那楽のような交際も無いことはない。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶筌でお茶を掻き廻しているような音でもあるが、どうも、それにしてはひどく乱暴な騒々しい音である。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、もう笑ってら、今泣いた烏が、」　と縁端に遠慮して遠くで顔をふって、あやしたが、「ほんとに騒々しい烏だ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は余り騒々しいので、そこを遁げて参ったのです。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人　秀吉時分から、見馴れていながら、何だねえ、騒々しい。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ野暮ったくもったい振り、何の芸も機智も勇気も無く、図々しく厚かましく、へんにガアガア騒々しいものとばかり独断していたのである。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「騒々しいじゃないかね。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、しばらく土間に立って、また、騒々しい嫌な催しが始まっているとくさ／＼して、靴も脱がずに立っていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒った顔二つ暫時にらみ合って、やがて仲人の帰ったあと、勝手元で騒々しい物音や叫声がして、おどろいておたかが出て見ると、義枝と定枝が掴み合い掴み合っているのだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時には職人が帰ってしまいますから、お食事中騒々しいようなことはございません。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「騒々しい奴だのう。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきも申す通り、ただ騒々しいのは蛙の声でございました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その啼き声が夜昼そうぞうしいと云うので、南隣りの人はとうとう引っ越してしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
