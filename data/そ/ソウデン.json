  {
    "uuid": "fd81a117-59ef-53be-9c57-f6db2685c669",
    "entry": "相伝",
    "reading": {
      "primary": "そうでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
