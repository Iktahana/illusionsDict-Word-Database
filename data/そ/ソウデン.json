[
  {
    "uuid": "4a230929-f522-5a86-962f-ed1dfbe63442",
    "entry": "桑田",
    "reading": {
      "primary": "そうでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
