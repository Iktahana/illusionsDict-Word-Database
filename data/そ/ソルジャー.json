          "literary": [
            {
              "text": "ニュー・ヴォードヴィル・バンド〈ウィンチェスター・カテドラル〉、ナンシー・シナトラ〈シュガー・タウン〉、彼女の父親の〈ザッツ・ライフ〉、ロニー・ダヴ〈クライ〉、ボビー・ヴィントン〈カミン・ホーム・ソルジャー〉、サンディー・ポウジー〈シングル・ガール〉。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＤのタイトルは『ウクレレ・ソルジャー』だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二世部隊についての多くの本のなかで、ウクレレ・ソルジャーは何度も言及されて来た。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ウクレレ・ソルジャー』の「ソルジャー」の部分に関しては、絵解きは必要ではない。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
