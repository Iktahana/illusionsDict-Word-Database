        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四　流行言葉の中でも「ソートーナモンジャ」と「ドーカと思うね」には、どこか科学的なスケプチシズムの匂いがある。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立って見ていた二、三人連れの大学生の一人が運転手の方を覗き込んで、大声で、「ソートーなもんじゃー」と云った。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　前夜のこと、………更けるとすこしばかし溝をつたうクレオソートの臭いが鼻に滲みたが、築地河岸附近にあるダンシング・ホールで僕はその夜、踊っていた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレはベーシックと格闘しながら、辞書流の配列ルールに従って語句をソートするプログラムを書いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事が済んでから、おくみはその痛む虫歯へ、婆やに買つて来て貰つたケリヲソートを附けたりして、やうやく坊ちやんを泣寝入りに寝せつけて、一人枕もとに坐つてゐた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつと默んだ嘴にケレオソートが沁むかいな。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの從兄弟がいふことに青い小鳥よ、樫の木づくり、おなじ寢どこに三人まで死ぬる命の贐に鳴いて暮らすか、籠の鳥、ケレオソートにや馴染みもしよが、いつも馴染まぬ人の眼が今ぢやそなたも厭であろ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレカラ、君チャンハヨナカニ目ヲサマスト、ブルブルフルエナガラ、何ンダカオッカナクテ、オ母ッチャトコエモ出セズニ、ソート手ダケヲノバシテヤッテ、ユスルノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は給仕しながら、そこに坐りて膠嚢にクレオソート液を入れ居り。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "食了りて、クレオソート三嚢を呑む。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤色陸海軍作家連盟からはポドソートスキーが挨拶した。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこんな哲學や宗教からは、新文藝がます／＼發展して行かうとするパツシヨネートソート（熱想）が出て來やう筈がない。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマチュアのパイロットの資格を持っていたドンピアは、低い周波数の電波を受信できる小さなトランジスターラジオで天気情報を聞きながら、入力した数値を大小の順に従って並べ替える、ソートと呼ばれる作業のためのプログラムをスイッチから入れていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マシンが数値をソートするたびに、ラジオはジーッ、ジーッと鳴った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソートプログラムを何度か走らせて、間違いなくアルテアがラジオを鳴らしていることを確認している最中、ドンピアの脳裏に稲妻のようにアイディアが走った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しわぶき一つない会場に、アルテアの奏でるソートの音楽が響き渡った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "記事を読んでアルテアを歌わせることを試みた連中は、次から次へとドンピアに電話を入れては、さまざまな曲を「ソートの音楽★」の創始者である彼に聞かせようとした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお「ソートの音楽」に関しては、ＴＫ―80の開発中に後藤富雄氏もまったく同じ経験をしたという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは集めたデータをルールに従って並べ替えるためのスーパーソート。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアはそれゆえ、ソートの音楽を奏でることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソート・ロシアの若きゼネレーションから必然的に起ったのである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人のボーイもゐれば、日本娘のサーヴィスも受けられ、帳場のお神さんはひつきりなしに電話にかゝり、食堂のテーブルには、三度々々クレオソートの瓶が出してある。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学の方でも種々な新薬が出たが、要するにケレオソートかゴヤコール剤にすぎないと云うじゃないか。",
              "citation": {
                "source": "生あらば",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカに『ニュー・ソート』という光明運動がありますが、それを解析するのが目的だったのでね。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京からクレオソート丸を千粒ほど、キニーネを二百粒、クリームとなっている一寸した消毒薬を三チューブ買って来て持たせました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時すぎでしたから、ずっと西練兵を突切って歩いて、福屋デパートへ行って、先ずクレオソート丸やその他の薬品を買い、六階の食堂でおひるを三人でたべました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三人は縁起をかつぐから）　薬や何かやはり少しは持ってゆけるということが十六日に会ってわかったので、早速クレオソート丸その他消毒石鹸まであるので、「班でこんだけ用意せちょるものはない云いよります」という状態になりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
