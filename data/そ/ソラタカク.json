        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雀は、はたはたと空高く飛び去る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コメット・ヌマタは夜の空間、花火吹散らして空高く、飛行ズボン脱いで牡鶏の真似をしている。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄風は轟々と空高く唸った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」暴っぽいラクシャンの第一子が金粉の怒鳴り声を夜の空高く吹きあげた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夕は空高く晴れて星の光もひときわ鮮やかなればにや、夜に入りてもややしばらくは流れの潯を逍遙してありしが、ついに老僕をよびて落ち葉つみたる一つへ火を移さしめておのれは内に入りぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は窮みなき空高くながめ、胸さくるばかりの悲哀をおさえて、ひそめし声に力を入れ、『必ず手紙を送りたまえ、今こそわが望みは君が心なれ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひばりが空高く啼きお陽さまの裳裾がゆらゆらとゆれかがやいて居ます。",
              "citation": {
                "source": "花子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴よ、來いよ、と呼びたまへば、折から天下太平の、蒼空高く伸したりける、丹頂千歳の鶴一羽、ふは／＼と舞ひ下りて、雪に末黒の大紋の袖を絞つて畏る。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと気がつきますと遠くの白樺の木のこちらから、目もさめるような虹が空高く光ってたっていました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ黒な森の向こう側から、虹は空高く大きく夢の橋をかけていたのでした。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして声をそろえて空高く叫びました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの青空高くひびきわたるかたつむりのメガホーンの声でした。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――天才のほまれはどろにまみるれど、凡庸のわざは空高くかかげらる！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "空高く野の白鳥の群れが飛んでいました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上を見ても、下を見ても、どこもかしこも青い空ばかりで、かえって、空高くに浮んでいるような気がしました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、若い王子が出てきますと、花火が百いじょうも空高く打ちあげられました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、花火は空高くあがって、大きな音をたてて、爆発しました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、女王はカイを連れて、空高く黒い雲の上までとんでいきました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの心のやさしさを、大空高く飛びながら、いつもわたしはうたいます。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまが見ていると、まりは、鳥のように、空高くはねあがりました。",
              "citation": {
                "source": "いいなずけ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "商人よふたたび椰子の葉の茂る港にかへり君のあたらしい綿と瑪瑙を積みかへせ亞細亞のふしぎなる港々にさまよひ來り青空高くひるがへる商業の旗の上にああかのさびしげなる幽靈船のうかぶをみる。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空高く登る榮達と、名譽と、勇氣と、健康と、天才と。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、鶴は羽をばさばさとやりながら松から放れて空高く飛んだが、すぐまたぐるりと引返して来て元の枝へとまった。",
              "citation": {
                "source": "怪人の眼",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹が空くと、電信の針がねに一座ずらりと出て、ぽちぽちぽちと中空高く順に並ぶ。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い森も、白い家も、目の下に、たちまちさっと……空高く、松本城の天守をすれすれに飛んだように思うと、水の音がして、もんどり打って池の中へ落ちると、同時に炬燵でハッと我に返った。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "光りかがやく何物かまた飛びめぐる、雲母摺なる空高く、また、低く、恐怖は銀の翼より響を拡げ、声なき舟は一心に波に燦めく。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかすがに、大寂静の空高く濃霧をわけて東より霊智の光しらしらと見え、かつ、消えぬ、大鳥の強きはばたき。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大ふうせんは、ふわふわと、そらたかくのぼっていきます。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
