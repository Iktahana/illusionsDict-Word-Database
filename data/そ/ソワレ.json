        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞踏会のために、彼女は特注のソワレを新調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このソワレは、背中のデザインが特に美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クローゼットには、いつか着る日のためにとっておきのソワレがしまってある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
