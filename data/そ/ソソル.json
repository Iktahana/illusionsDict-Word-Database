[
  {
    "uuid": "f0c317b7-c3ac-57c2-bc11-2f2b75235d30",
    "entry": "唆る",
    "reading": {
      "primary": "そそる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
