    "definitions": [
      {
        "index": 1,
        "gloss": "to lie down languidly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
