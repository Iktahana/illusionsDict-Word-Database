    "definitions": [
      {
        "index": 1,
        "gloss": "made entirely of paulownia wood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
