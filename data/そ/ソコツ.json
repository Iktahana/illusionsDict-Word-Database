        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大変元気で粗忽が自慢でもある、甚だ罪のない男がその夜の進行係をやつてゐて、一人で大声で喋舌つてゐたが、大部分の者は聴いてもゐなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人の衣食住を模し、西洋人の思想を継承しただけで、日本人の解剖学的特異性が一変し、日本の気候風土までも入れ代わりでもするように思うのは粗忽である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と粗忽ッかしく絶叫した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "己れだって粗忽な真似はし無えで、兄弟とか相棒とか云って、皮のひんむける位えにゃ手でも握って、祝福の一つ二つはやってやる所だったんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗忽にも鏡の見当を間違えて、自分の頭や顔を鏡の中へ映し入れなかった。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "演若は自分の粗忽から、自分で自分の頭を失うたと思った。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵ならば落しながら、（な、なんぞ粗忽でも。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははははは、拙者うまれつき粗忽にいたして、よくものを落す処から、内の婆どのが計略で、手袋を、ソレ、ト左右糸で繋いだものさね。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○某君は一體に粗忽しい人なのだらうか？",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、老人｜粗忽千万。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に、満右衛門は頭を畳に付けて、「――田舎者の粗忽許して下され」　と、煮えくりかえる胸まで畳につけんばかりに、あやまった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあながちに辻番人の粗忽や伊平の臆病とばかりは言われまい。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の空似か、あるいはやはり妖怪の仕業か、いずれにしても粗忽に立ち騒ぐこと無用と、役人は人々を堅く戒めて置いて、さらにその次第を奥家老に報告した。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もっともお手前の今度の過失は、ほんの仮初の粗忽ぐらいのものじゃが、それでもお手前のためには何よりの薬じゃったぞ」「……と仰せられますると……」「まま。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども乳母の粗忽とか聞きぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の粗忽はわが不念より起りし事なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日の光栄ある舞台の上で、つまらない粗忽をしないように、シテの品位と気位を崩させないように特に翁が細心の注意を払ったものではないかとも思える。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「は、てまえは萩原新三郎と申す粗忽ものでございます、まことにどうも」　平左衛門は憤って肩で呼吸をしていた。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの粗忽を、大に陳謝したが、しかしこの珍本たるや、この所有主には、はなはだ貴重なものであったと見えて、その老人は憤然として、自分に罵詈の言葉を投げかけて、踵を返して立ち去った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の例の性急さが、彼の本来の持ち前の智的聡明さにもなく、粗忽なようであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほい、こりゃ違ったそうな、すれば、大方、だろうぐらいに考えて風説をいたしますのを、一概にそうと心得て粗忽千万な。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに河童だ」　粗忽しい武士はほんとうの河童だと思ったかも知れないが、それは河童の長吉に相違ないと半七は思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はよほど粗忽かしい男で、ときどきに飛んでもない間違いや出鱈目を報告するので、湯屋熊のほかに、法螺熊という名誉の異名を頭に戴いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失敗つた／＼、用向きをうけたまはらないで駆け出すとは、何といふ粗忽な事であつたらう……」稍暫く駆けた時、ふと私はさう気附きましたが、「今更、引き戻すわけにもゆくまい、そんな事をしたら王に粗忽を叱責されるばかりか、慈悲深い王はアハテ者の兵士を持つたことを嘆くだらう、それには忍び得ない。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "王様の命令をよく承はらぬうちに、粗忽な私はオリンピツクのチヤムピオンの如くに駆け出しました。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で道節が短気で粗忽で一番人間味がある。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く手前どもの粗相から、お数寄屋には他のお軸を掛けましたような次第で……」　愚しい粗忽者をいくら叱ったところで、さしあたっての間違をどうすることも出来ないのを知っている頼宣は、長くは二人を相手にしていなかった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけものかね、これはボスといってね、おいおい、そこつるはしはよしたまへ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけものかね、これはボスといってね、おいおい、そこつるはしはよしたまえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大二郎や閑吉の意中の想像もつかないのが、嘆かはしくもあつたが、たゞ、いつそこつちも泣いたからには見得好く振舞つて、舞台の効果を努めようといふ風な芝居気にも手つだはれてゐたと、強ひても思ひたかつたのである。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
