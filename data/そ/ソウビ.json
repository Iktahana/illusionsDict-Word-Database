[
  {
    "uuid": "0d2d8c48-1a89-5650-9b8a-e655b6787baf",
    "entry": "装備",
    "reading": {
      "primary": "そうび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
