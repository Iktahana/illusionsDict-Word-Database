    "definitions": [
      {
        "index": 1,
        "gloss": "each time it happens",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いい加減な文章だ」と馬鹿正直に、その都度私の感想を書いて送つたのであります。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都度おまきも詫びた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "楚歌一身に聚りて集合せる腕力の次第に迫るにも関わらず眉宇一点の懸念なく、いと晴々しき面色にて、渠は春昼｜寂たる時、無聊に堪えざるもののごとく、片膝を片膝にその片膝を、また片膝に、交る交る投懸けては、その都度靴音を立つるのみ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいちばん面食らわされるのは、東京付近などで年々新しく開設される電鉄軌道や自動車道路がその都度記入されていないことだけである。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな化け物みたいなものに、ついてこられて、たまるものか、とその都度、私は、だまってポチを見つめてやる。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そのようなむだな試みを幾度となく繰り返し、その都度、失敗した。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葬式の翌る日、学校へ出たら、先生がたも、みんな私にお悔みを言って下さって、私はその都度、泣きました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君のれいの商売で、儲けるぶんくらいは、その都度きちんと支払う。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても「誰かがあの風呂敷の事を白状したら」と意地になって、四人の苦痛を問題にしていなかった私の卑怯さを思い出すとその都度に、大声で叫びたいような気持になる。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "引掴んでまで、撫でつけた、鬢の毛が、煩くも頬へかかって、その都度脈を打って血や通う、と次第に烈しくなるにつれ、上へ釣られそうな、夢の針、汀の嫗。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都度｜死装束として身装を繕ったろう、清い襦袢の紅の袂は、ちらちらと蝶の中に交って、間あれば、おのが肩を打ち、且つ胸のあたりを払っていたが、たちまち顔を顰めて唇を曲げた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都度秘蔵娘のお桂さんの結綿島田に、緋鹿子、匹田、絞の切、色の白い細面、目に張のある、眉の優しい、純下町風俗のを、山が育てた白百合の精のように、袖に包んでいたのは言うまでもない。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその都度、「先生の威徳廣大、先生の威徳廣大。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落人のそれならで、そよと鳴る風鈴も、人は昼寝の夢にさえ、我名を呼んで、讃美し、歎賞する、微妙なる音響、と聞えて、その都度、ハッと隠れ忍んで、微笑み微笑み通ると思え。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも型ばかりの硯箱を違い棚に置いてある家はいいが、その都度に女中に頼んで硯箱を借りるような家もある。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、「赤と黒」を読み直すことがその都度の結論だが、僕は「ジュリアン・ソレル」という小説を書こうと思う。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、伝三郎の妻もその都度、相手に負けぬ程丁寧に挨拶するのだった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々気にしていてはやり切れぬのか、嫁さんはその都度いたって平気な顔で、出て行けという彼の言葉を受け流す。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、Ｈ――氏のロマンティスト的厚意から、私自身の真価に分をつけるために、私がその都度勘定を支払ったせいもあったのであろう。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都度にそこの交換局の監督や、主事を呼び出して注意をしたり、手厳しく遣っ付けたりするのが愉快で愉快でたまらなかった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとその都度に胸が微かにドキドキして、顔がポーッと火熱るような気がしたのは今から考えても不思議な現象であった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、私は、幾度同じことを繰返しても、その都度、全く新奇なことにぶつかつたやうに思へて、全意識を傾倒しなければならない。",
              "citation": {
                "source": "私の書に就ての追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そののちも私はときどき「牛盜人」や「皿屋敷」や「俊徳丸」などの芝居をやつたが、祖母はその都度にがにがしげにしてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と思い出したようにふっと言い、嘉七は、その都度、心弱く、困った。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渚は浪の雪を敷いて、砂に結び、巌に消える、その都度音も聞えそう、但残惜いまでぴたりと留んだは、きりはたり機の音。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは、その都度、どんなに痛い苦しい思いをするか、そんなものは、てんで、はねつけている自分だ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不流行の、無名作家なのだから、その都度たいへん恐縮する。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度、ながい手紙をさしあげて、その都度、あかるい御返事いただいた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代わり、一つ一つの経験の与えた教訓はその都度、彼の血液の中に吸収され、ただちに彼の精神および肉体の一部と化してしまう。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "楚歌一身に聚りて集合せる腕力の次第に迫るにもかかはらず眉宇一点の懸念なく、いと晴々しき面色にて、渠は春昼寂たる時、無聊に堪えざるものの如く、片膝を片膝にその片膝を、また片膝に、交る交る投懸けては、その都度靴音を立つるのみ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
