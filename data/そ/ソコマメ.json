        "examples": {
          "standard": [
            {
              "text": "新しい靴を履いたら、かかとに底豆ができてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長時間歩いたせいで、足の裏に大きな底豆ができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "底豆が痛くて、まともに歩くことができなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あなたは、自分の足をいためたことを怒つて、あなたの底豆をけとばしたやつを掴へてやらうと思つてゐるんぢやないか。",
              "citation": {
                "source": "虹猫の話",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれは名古屋を過ぎ池鯉府に行って遂に底豆を踏み出し、行こうか帰ろうかと刈谷の停車場で思案した末遂に新橋までの切符を買ってしまった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
