        "examples": {
          "standard": [
            {
              "text": "保育器の中で眠る小さな早産児の手をそっと握ると、その力強さに生命の逞しさを感じずにはいられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "体重が1000グラムに満たない超低出生体重の早産児でも、NICUの適切なケアによって健やかに成長できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "早産児の母親たちは、病院の搾乳室で互いの不安を分かち合いながら、我が子の退院を待ちわびている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "美妙斎はあたかも欧化熱の人工｜孵卵器で孵化された早産児であった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "美妙斎は恰も欧化熱の人工孵卵器で孵化された早産児であつた。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "魯庵が「早産児」と言つてゐられるのは、生れはしたが育たなかつた月足らずの児といふ意味にとりたいと思はれるほどである。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            }
          ]
        }
