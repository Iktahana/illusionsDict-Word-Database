          "standard": [],
          "literary": [
            {
              "text": "軽い双眼鏡　今度ロンドンのネグレッチ・アンド・ザンブラで売り出した新形の双眼鏡「ミニム」というのは従来の双眼鏡中で最も軽いものである、その倍率は八倍で重量七十五匁くらい、柔らかい皮袋に入れて隠袋に収めるように出来ている。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は双眼鏡か何かで見て肉眼で見たのと比較し、もし肉眼で見る方がよく見えればその灯色は赤光で、そうでなければ青か白だという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "埠頭に碇泊している船舶のマストにセイラーが双眼鏡をもってよじ登っていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　副官は双眼鏡を出してみた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の大尉は夜間双眼鏡を手早く取って、きっとそっちを見ました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに役所の大きな写真器械や双眼鏡も借りました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何氣なく衣袋を探つて、双眼鏡を取出し、度を合せて猶ほよく其甲板の工合を見やうとする、丁度此時先方の船でも、一個の船員らしい男が、船橋の上から一心に双眼鏡を我が船に向けて居つたが、不思議だ、私の視線と彼方の視線とが端なくも衝突すると、忽ち彼男は双眼鏡をかなぐり捨てゝ、乾顏に横を向いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "初の間は矢張頭が妙で、先刻と同じ樣にいろ／＼の妄想が消しても消しても胸に浮んで來て、魔の日魔の刻――亞尼の顏――微塵に碎けた白色檣燈――怪の船――双眼鏡などが更る／＼夢まぼろしと腦中にちらついて來たが、何時か晝間の疲勞に二｜時の號鐘を聽かぬ内に有耶無耶の夢に落ちた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦橋には艦長松島海軍大佐をはじめとし、一團の將校は月に燦爛たる肩章に波を打たせて、隻手に握る双眼鏡は絶えず海上を眺めて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも手に／＼双眼鏡を携へ、白巾を振り、喜色を湛えて、諸君の好意を謝する事であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方も爵位を持っているほどの人物だから……」と話しあっている中に文彦は雲の間から何やら認めて、「おや、」と早速双眼鏡を取り出して見たが、「月だ！",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ一まず安心と、今度は双眼鏡で前の洞の附近を見回すと、「難有い。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の大尉は夜間双眼鏡を手早く取つて、きつとそつちを見ました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人は、上衣の下へ斜めに懸けた革のサックから双眼鏡をとり出して下界を眺めた。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人は矢張り双眼鏡ばかり覗いた。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "は、は、は、は……」　彼はそれからふいと慍ったような顔をして、くるりと背中を向けると、再び双眼鏡を覗きはじめた。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もう殆ど三月も前のことですが、故国から訪ねて来た友達を案内して、瀬戸内海の方へ見物旅行に出かけるつもりだったので、Ｍ百貨店へ行って買物をして序に双眼鏡を一つ買いました。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その買いたての双眼鏡をもって、私はＭ百貨店の屋上から初覗きに東京中の景色を眺めまわしてみました。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　西洋人はサックから双眼鏡を取り出しながら、そう去った。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人は平常の倍も亢奮して、双眼鏡を覗いた。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミハエルは漸く私に双眼鏡を手渡しながら早口に説明した。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそこで危く双眼鏡を取り落とすところであった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は先ず、お前の病室や裏庭のよく見晴らせる松林の中に入って、そこから双眼鏡で様子を窺った。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆の隙から斜めに見えるオペラの辻の角のカフェ・ド・ラ・ペイには双眼鏡を肩から釣り下げたり、写真機を持った観光の外人客が並んで、行人に鼻を突き合せるほど道路にせり出して、之れが花の巴里の賑いかと気を奪われたような、むずかしい顔をして眺めて居る。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "円の、双眼鏡の端から端まで、　黒上衣の、白｜胴衣の、佇立した、密集した、幾段々になった、　鳥鳥鳥鳥鳥鳥鳥鳥なのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は涙が流れかけた、双眼鏡の下からだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
