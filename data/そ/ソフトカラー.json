        "examples": {
          "standard": [
            {
              "text": "彼女はソフトカラーのセーターを身につけていて、優しげな印象だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この部屋の壁紙は、心を落ち着かせるソフトカラーが選ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "流行のソフトカラーを取り入れて、春らしいコーディネートを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どうしたのかと仔細に博士の身体を見れば、ネクタイが跳ねあがったようにソフトカラーから飛びだして頸部にいたいたしく喰い入っている。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフトカラーをしているお互いは、ネクタイで締められないように用心が肝要だとナ。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々階級のサラリーマンはよく経験するが、出がけになってソフトカラーに鏝がかかっていないことを発見し、急いで電気アイロンを出すと停電で駄目だなんてことがある。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
