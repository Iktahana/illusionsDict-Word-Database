    "definitions": [
      {
        "index": 1,
        "gloss": "graduation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕達は今卒業して、二人ともそれぞれの郷里に帰つてゆく。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか卒業できない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この校長のときに、私たちは卒業したのである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅忠太郎君は、私と大学が同期で、けれども私のように不名誉な落第などはせずに、さっさと卒業して、東京の或る雑誌社に勤めた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学を卒業して雑誌社に勤務するようになってからも同じ事で、大隅君は皆に敬遠せられ、意地の悪い二、三の同僚は、大隅君の博識を全く無視して、ほとんど筋肉労働に類した仕事などを押しつける始末なので、大隅君は憤然、職を辞した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大隅君は大学の美学科を卒業したのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業の時恩賜を貰つて自分と母との前でそれを出してみせた親族の男の顔が浮んでゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京帝国大学の卒業証書も検閲のために差出したが、この日本文は事務の役人にとって自分の場合のラテン語以上に六かしそうであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにその頃郷里でただ一人の東京帝国大学卒業医学士であったところの楠先生の御厄介になることになった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中に於ける位置は、諸君が學校を卒業すれば、いやでもそれは與へられる。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼が二十六の歳に学校を卒業してどうやら一人前になってから、始めて活版刷の年賀｜端書というものを印刷させた時は、彼相応の幼稚な虚栄心に多少満足のさざなみを立てたそうである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい時から苦学をしてやっと電気学校を卒業はしたが、目的のある柚木は、体を縛られる勤人になるのは避けて、ほとんど日傭取り同様の臨時雇いになり、市中の電気器具店廻りをしていたが、ふと蒔田が同郷の中学の先輩で、その上世話好きの男なのに絆され、しばらくその店務を手伝うことになって住み込んだ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業の証書も生活の保証も命さへも要らないと云ってゐるこの若者の何と美しくしかも扱ひにくいことよ　扉がまたことことと鳴った。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いその学校の卒業生の教授が校旗を先導しに入って来た。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅虫温泉は車窓から見ただけで卒業することにした。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在ある限りの学校を卒業したところで、それで一人前になれるはずがない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学卒業者はその専門では先ず社会一般の権威となり得るはずである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学でも卒業した人間なら取ろうと思えばおそらく誰でも取れる学位である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし中等学校を卒業しないうちに学校生活が一時中断するようになったというのは、彼の家族一同がイタリアへ移住する事になったのである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後彼をどこかの大学の助手にでも世話しようとする者もあったが、国籍や人種の問題が邪魔になって思わしい口が得られなかった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日でも一切の練習の最後の目的は卒業試験にあるような事になっている。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業試験は正にこの原則に反するものである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教案が生徒を圧迫する度が少なければ少ないほど、生徒は卒業の資格を得やすいだろう。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に中学卒業試験全廃を唱えたのは、つまりこうして高等教育の関門を打破する意味と思われる。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一高等学校を経て東京帝国工科大学造船学科へ入学し、明治三十三年卒業した。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校時代厳父の死に会い、当時家計豊かでなかったため亡父の故旧の配慮によって岩崎男爵家の私塾に寄食し、大学卒業当時まで引きつづき同家子弟の研学の相手をした。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後長崎三菱造船所に入って実地の修業をした後、三十四年に帰京して大学院に入り、同時に母校の講師となった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後物理学科の聴講に出たり、ベルリン留学中かの地の若い学生の中に交じってブラジウス教授受持の物理実験の初歩のコースを取ったりした事実は、この特徴の由来を想像させるものである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生の卒業論文などについても指導甚だ懇切であった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後の就職などについても労を惜しまず面倒を見た。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
