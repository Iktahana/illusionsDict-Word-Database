          "literary": [
            {
              "text": "ぐるりと裏へまわり一側むこうに出たら例の練馬の大滑走路が坦々としてある。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、（きらりと佩刀を抜きそばむると斉しく、藁人形をその獣の皮に投ぐ）やあ、もはや陳じまいな、婦。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）『母よ、明日よりいづこにてあそばむ』と、また女の童、――母は『猛火も沈みぬ』と。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
