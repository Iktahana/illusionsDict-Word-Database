        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お前………其れも毎晩飮むといふんじやなしさ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れも長屋で、褓襁の干してあるのも見えれば、厠も見えて、此方では向ふの家の暴露された裏を見せつけられてゐるのであツた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡るい教育でも、あれば宜しいが、其れも無し。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れも小説物語の戯作ならば或は妨なからんなれども、家庭の教育書、学校の読本としては必ず異論ある可し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れも下女の不行届、其れも下男の等閑など、逐一計え立て徒に心配苦労して益なき事に疳癪を起すは、唯愚と言う可きのみ。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板球戯は我我に最も好く時間を費させ且つ運動にもなるが、昼間に限られた遊戯であつて其れも倦き易い日本人には二時間以上続け得ない様である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モリエエルに取つては其れも亦悲痛の種である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸から和蘭へかけて旅行しようと思ふが雨天の為に其れも延び勝ちである。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇異を以て人を刺激する所があれば其れも新しい価値の一種でないか」と僕が答へたら、ヌエは苦痛を額の皺に現して「わたしには解らない絵だ」と云つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲望彼れも取りたし、其れも欲し、飽かぬ心の止み難し。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れもわたしの幸福と思ひ返せど気が滅入る。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬる際の肉の苦痛を怖れるのかと云ふと、多少は其れもあるが、度度の産で荒瀬に揉まれて居る自分には、男子が初陣の戦で感じる武者ぶるひ程の恐怖は無い。",
              "citation": {
                "source": "産褥の記",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人も此頃は嫌な事ずくめで、自分の立てて居る目算がバタバタとわきから崩れる有様なので、当分気を抜くに其れも好かろうと云うので、僅かの着換えを持って旅立つ事に成った。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此両趣味の結婚は何ものを生み出したか、若くは生み出すか、其れも疑問である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラめは其れも鵜呑にして了うた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れも工程の捗取ると共に、何時しか他所に流れて往って了うた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつけば、あの癇高い争ひの声は益々劇しく響いてくるが、深く耳を澄してゐると、其れも撒かれた霧のやうに明るい空の百方へヂンヂンとして掠れてしまふ。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "注射――もちろん其れもある。",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮒釣鮒釣と申しまして、此の寒いに、いつも暗い内から出まして、其れも、好く釣れますならようございますが、中々さうも参りません。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の仕事は、恁く永久に賞美されない料理人の外に、一寸触つても破れさうな書画骨董の注意と、盆栽の手入で、其れも時には礼の一ツも云はれゝばこそ、何時も料理と同じ様に行届かぬ手抜りを見付出されては叱られて居られた。",
              "citation": {
                "source": "一月一日",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れも軽妙で、清洒で、すね気味な強みを持つてゐる美人でなければならぬ。",
              "citation": {
                "source": "虫干",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてもピアノ一臺が四五百圓、其れも少くて二三臺は無ければなりませんし。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して程なく或人の世話で郡立學校の教師となつたが、其れも暫時、同僚とは折合はず、生徒とは親眤まず、此をも亦辭して了ふ。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "家主の女主人の處に見知らぬ人が來さへすれば其れも苦になる。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、其れも此れも直に彼を疲勞らして了ふ。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭には漸く此の頃片言交りに喋り出した子供を抱いて若い妻は私の帰るのを待つてゐたし、其の頃私のやりかけて居つた事業も予想したよりは都合よく運びかけてゐたので、其れも此の際一発展すべく私の帰京を待つてゐるやうな始末であつた。",
              "citation": {
                "source": "落葉降る下にて",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れも尤もの事であつた。",
              "citation": {
                "source": "落葉降る下にて",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れも木版二册もの先生の洋行前の著述で、最後に此の講義の續きは三宅雄次郎君に托して外遊するとのことが記してあつたと記憶する。",
              "citation": {
                "source": "巽軒先生喜壽の祝辭",
                "author": "中島徳藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れも小学校や中学校の生徒のように多勢景気よく練って来るのではない。",
              "citation": {
                "source": "The Affair of Two Watches",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が自殺した時、それも作家が自殺した時、その原因を簡単に云つてしまふなぞはよくないことである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
