[
  {
    "uuid": "aec8d1d4-f405-5e8a-9fd2-ac7471b5bb7e",
    "entry": "壮語",
    "reading": {
      "primary": "そうご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
