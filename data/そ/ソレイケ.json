        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども其を話すとなると、それ行け、救へで、松明を振り、鯨波の声を揚げて騒ぐ、騒いだ処で所詮駄目です。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで若い連中は勢をもりかえし、「それ行け。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ行け、ワ――ッ」と走り出した。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ行けそれ行け、助太刀助太刀！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先だ、先だ」「それ行け」　と口々に叫びかわして立ち去った模様。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ行け、と谷中へ驅けつけた時は、何も彼もおしまひ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "飛ぶ若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度百兵衞のところには、若けえのが五六人集まつて、無駄話をして居たから、――それ行けツ――といふ騷ぎでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "萬兩分限",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品のところから通知があると、「それ行け、――八」　ガラツ八と一緒に驅け出した平次は、いきなり途中から道を變へて、鳥越の方へ外れます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "双生兒の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ行け、八」　飛込むと、それは大きな材木の間に、左手を突つ込んだまゝ、拔き差しもならずうめく人間の姿ではありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "九百九十兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ行けツ、あの野郎だツ」　平次とガラツ八は小柳町に飛びました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品のところから通知があると、「それ行け、――八」　ガラッ八と一緒に駆け出した平次は、いきなり途中から道を変えて、鳥越の方へ外れます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "双生児の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ行け、八」　飛込むと、それは大きな材木の間に、左手を突っ込んだまま、抜き差しもならずうめく人間の姿ではありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "九百九十両",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ行けッ、あの野郎だッ」　平次とガラッ八は小柳町に飛びました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度百兵衛のところには、若えのが五、六人集まって、無駄話をして居たから、――それ行けッ――という騒ぎでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "万両分限",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ行け※」と一隊は更に船室の奥深く突進した。",
              "citation": {
                "source": "危し※　潜水艦の秘密",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八五郎が胴間聲を張り上げると、「何處だ、何處だ」「それ行けツ」　人足を交へて二十人ばかり、遠慮もたしなみもなく、どつと坂田屋の離屋に押し寄せたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鐘の音",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ行け」　とばかり、雲をつかむような相手を追って、夕方の往来の者の眼をそばだたしめて行く一群の男どもがここにある。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ行けっ」　だが、道を急ぐだけでも、百難の思いがあった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、真っ先の一騎が、「火急の際、無断、まかり通る」　と、いきなり馬の背から降りて、そこの閂を勝手に外し、さっと押開いて、「それ行け」　と、すぐまた鞍の上に跳びつくやいな、まるで弾丸のように駆け抜けて行った。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ行けッ」　藤吉郎が先に駈けると、「わあッ」　今まで、人心地もなかった足軽たちも、突然、　――われ生きたり。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この孟獲にも劣るまいと思うものはみんな俺について来い」　と、突如、銅鈴を振り、鉄笛をふかせ、鼓盤を打ち叩いて、出陣を触れると、寨中の蛮将はみな血ぶるいして、「それ行け」　と各※、一隊をひきいて、孟獲のあとから駈けて行った。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それいけ、それ、それ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
