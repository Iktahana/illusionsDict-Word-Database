[
  {
    "uuid": "64d320bd-4128-5b9c-8699-35b31c38b58b",
    "entry": "育て上げる",
    "reading": {
      "primary": "そだてあげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
