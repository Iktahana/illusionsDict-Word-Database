[
  {
    "uuid": "d047b427-222a-5eed-a05a-ecfc67da3790",
    "entry": "尊兄",
    "reading": {
      "primary": "そんけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elder brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "龍馬尊兄大乙姉於ヲやべどの追白、乙大姉ニ申奉ル。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年九月七日　坂本権平、乙女、おやべあて",
                "note": "青空文庫"
              }
            },
            {
              "text": "寅極月四日龍馬尊兄膝下",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十二月四日　坂本権平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日直柔尊兄左右",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月八日　坂本権平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば湧き上るリズムをも尊兄はその気禀をもって中途で斬ってしまう。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "又多く尊兄に依って馳駆される詩句のごときもまったく尊兄の創造になるものである。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊兄にとっては女人の胴体のみが卓上に輝いていることを常に不審としないところである。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人が見て奇蹟呼ばわりするものも尊兄にはふだんの事だ。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊兄の愉楽はもはや官能や感覚上の遊技ではない。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊兄は曾て昆虫に眼をあたえてからもう久しくなった。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、尊兄は怪しき金属の内部にある最も緻密な幽暗な光と相対している。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、尊兄は癲癇三角形の上に登っている。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに尊兄の見るところに依れば珈琲茶碗はへし曲り、テエブルは歪んでいる。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊兄は自然人間に対して充分に厳格なまなこを持っている。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は尊兄の詩品におどかしを見るときほど不愉快なことがない。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき尊兄に憂鬱が腐れかかっている。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊兄の芸術について難解であるというのは定評である。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしきり私でさえ世評に動かされて、尊兄を不快におもった。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私には言えないことを尊兄は言っている。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には見えないものを尊兄は見ている。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の所持しないものを尊兄はもっている。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊兄の詩が愈々苦しくなり、難解になり、尊兄ひとりのみが知る詩篇になることを祈っている。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "解らなくなればなるほど解るのだという尊兄の立場を私は尊敬している。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊兄はその夏の夜に起る悩ましい情慾に似た淫心を磨いて光を与えることである。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊兄の理解者が一人でも殖えるのは尊兄の侮辱とまで極端に考えてもよいのだ。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉を尊兄のまわりに呟くものに与えてやりたく思う。",
              "citation": {
                "source": "聖ぷりずみすとに与う",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば湧き上るリズムをも尊兄はその氣禀をもつて中途で斬つてしまふ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "聖ぷりずみすとに與ふ",
                "note": "青空文庫"
              }
            },
            {
              "text": "又多く尊兄に依つて馳驅される詩句のごときもまつたく尊兄の創造になるものである。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "聖ぷりずみすとに與ふ",
                "note": "青空文庫"
              }
            },
            {
              "text": "安雄さんは小さい友達からとくべつにそんけいされてゐました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "安雄さんは小さい友だちからとくべつにそんけいされていました。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『曾呂利物語』四には伊予の出石の山寺で足利の僧が妖怪を鎮めたとし、主怪をえんひょう坊、客怪をこんかのこねん、けんやのばとう、そんけいが三足、ごんざんのきゅうぼくとす。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
