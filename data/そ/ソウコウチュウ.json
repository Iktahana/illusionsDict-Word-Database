          "literary": [
            {
              "text": "「またまた、よぼよぼの老婆が走行中の馬車から飛び降りただなんて。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーアの妄想が鮮明で強烈だろうが、走行中、通りの混乱状態は見逃さなかった。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "走行中に不意に背後から、今何｜粁か、と訊ねても容易に答えられない。",
              "citation": {
                "source": "指導物語",
                "author": "或る国鉄機関士の述懐",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険な錯覚なのだが、高速走行中の大排気量オートバイが持つ魔力のひとつであることは、たしかだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
