          "literary": [
            {
              "text": "前門の経済通報社の万事相談室には早朝から夥しい人がつめかけていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、山村の中学教師が東京の私立学校、明星学園の教師に転じ、「子ども電話相談室」というラジオ番組の名物回答者となる経緯の一切を知りませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして水色の服を着た受付の若い娘の後について育児相談室、職業相談室その他を見て廻った。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
