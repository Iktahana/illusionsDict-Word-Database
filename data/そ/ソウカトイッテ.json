[
  {
    "uuid": "4d97ef72-03b9-561c-924e-f3884420d43e",
    "entry": "そうかと言って",
    "reading": {
      "primary": "そうかといって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接続詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "but still",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は相手の今までの話を、そうおもしろがってもいないが、そうかと言って全然興味がなくもないといった穏やかな表情で耳を傾けていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言ってみずからこれらの多くの問題のどれもに手を着けることは到底不可能である。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言って陶器の需要のない所には陶土の要求もあるはずはないのは言うまでもないことである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そうかと言ってその結果がいくぶんか科学知識普及に役立つことになってもそれはさしつかえはないであろうと思っている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこれは大風が吹いて桶屋が喜ぶというのと同じ論法ではあるが、そうかと言ってそういうことが全然ないということの証明もまたはなはだ困難であることだけは確かである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで案内記ばかりにたよっていてはいつまでも自分の目はあかないが、そうかと言ってまるで案内記を無視していると、時々道に迷ったり、事によると滝つぼや火口に落ちる恐れがある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言って邦楽の大部分や俗曲の類は子供らにあまり親しませたくなし、落語などというのは隣でやっているのを聞くだけでも私は頭が痛くなるようであった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそうかと言って虫食いや黴菌のために変色した葉ばかりを強調した表現主義にも困る、ドイツあたりの近ごろの絵画にはそんな傾向が見えるのもありはしないか。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそうかと言っていわゆる音楽者のほうでは楽器や人間の声帯の発する音以外のものはいっさい取り扱わないのであるから、連句はもちろん音楽者からも顧みられない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言っていつまでも手をつけずにおくべきものでもない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言ってまた短歌連作の多数のものは連句とあまりに距離が大きい。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると学校を卒業して役所へはいって属僚になってもあまり一生懸命にまじめに仕事をするとかえっていけない、そうかと言ってなまけても無論いけないのだそうである。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言って死ぬのを嫌がっても、人間は死ななければならないので、何とかして諦める理由を考え出します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時には、肌が蕩けるのだって言いますが、私は何んだか、水になって、その溶けるのが消えて行きそうで涙が出ます、涙だって、悲しいんじゃありません、そうかと言って嬉しいんでもありません。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうかと言って、こう張っちゃ、身も皮も石になって固りそうな、背が詰って胸は裂ける……揉んでもらわなくては遣切れない。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平はこの年になっても持前のわがままがぬけず、別にこれと言って希望もなく、今後の生活の設計があるのでもなかったが、そうかと言ってそこに全く安住している気にもなれず、絶えず何か焦躁を感じていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、きざに大先生気取りして神妙そうな文学概論なども言いたくないし、一つ一つ言葉を選んで法螺で無い事ばかり言おうとすると、いやに疲れてしまうし、そうかと言って玄関払いは絶対に出来ないたちだし、結局、君たちをそそのかして酒を飲みに飛び出すという事になってしまうのである。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井伏さんが、歩いていると、右から左から後から、所謂「後輩」というものが、いつのまにやら十人以上もまつわりついて、そうかと言って、別に井伏さんに話があるわけでも無いようで、ただ、磁石に引き寄せられる釘みたいに、ぞろぞろついて来るのである。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬鹿な人間は困っちまいます――魚が可哀相でございますので……そうかと言って、夜一夜、立番をしてもおられません。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そうかと言って、先生の言う通りあんたを思い切るなぞということは、どんなに努めても出来ることではない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そうかと言って、自信するだけの客観的内容のないただ主観的なだけの自信をふり回す芸も困ることはもちろんである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言ってこのような重大な現象を無感覚に観過させないまでもそれを直視させるのをしいて避けるのもどんなものであろうか。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言って安心して京にいることも、全然無視された車争いの日の記憶がある限り可能なことではなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そうかと言って、あんまり執拗い、急迫した手段で、臼杵家に交際の手蔓を求めるのも、こっちが狼狽しているようでおかしい……と言ったようないろいろな気兼から、いよいよ形容の出来ない、馬鹿馬鹿しく不愉快な不安に陥って行った。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人がまさかこんな物を贈ろうとは信じられませんでしたが、そうかと言って、まるで見ず知らずの人が、匿名で妾に花環を贈ってくれるはずもなし、外には心当たりは誰もなかったのですから。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二月、三月はまア好いが、そうかと言って、女房と子供をかかえて遊んでなんかいられない。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だか言った、電車で女を見るのは正面ではあまりまばゆくっていけない、そうかと言って、あまり離れてもきわだって人に怪しまれる恐れがある、七分くらいに斜に対して座を占めるのが一番便利だと。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、喜んでついて行った様子だと答えると、三人はそうかと言って、再びボートに乗って引返して行ったというのである。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の姿のちらちらする日には竹村君は面白そうに一時間の余も話し込んでいるが、娘の顔を見せぬ日は自然に口が重くてそうかといって急に帰るでもなく、朝日を引切りなしに吹かして真鍮のしかみ火鉢の片隅へ吸殻の山をこしらえる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって職業上の名の小そのとだけでは、だんだん素人の素朴な気持ちに還ろうとしている今日の彼女の気品にそぐわない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
