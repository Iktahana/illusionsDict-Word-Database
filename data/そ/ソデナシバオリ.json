        "examples": {
          "standard": [
            {
              "text": "粋な着こなしの男性が、袖無し羽織をさりげなく羽織っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏祭りでは、多くの人が浴衣に袖無し羽織を合わせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝統工芸品として作られた袖無し羽織は、手触りも素晴らしかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おいよは押入れをあけて袖無し羽織を取出し、弥三郎に着せる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ半蔵の父吉左衛門も茶色な袖無し羽織などを重ねながらちょっと挨拶に来て、水戸浪士のうわさを始める。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しい以前、やはり秋に来た折のこと、この店に枯木のようなお婆さんが袖無し羽織を着て、蹲るように坐って居たが、今はもう其の人の姿も見られない。",
              "citation": {
                "source": "六日月",
                "author": "岩本素白",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
