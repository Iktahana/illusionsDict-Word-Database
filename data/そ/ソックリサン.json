        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "巡業と言えば、エルヴィス・プレスリーのそっくりさんのバンドで、姉はリード・ギターを担当していたこともある。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十代のなかばには、彼女はエルヴィス・プレスリーのそっくりさんのバンドで、専属のギタリストを務めていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのそっくりさんは、サン・レコードでレコードを作っていた頃のエルヴィスから、アメリカ陸軍に徴兵されて入隊するまでのエルヴィスを、再現してみせる人だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大役だと僕は思うが、ごく気楽な様子でスコティの再来のようにギターを弾き、姉はそっくりさんとともにステージを楽しんでいた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀でた額、というものが人の世にはあるけれど、そっくりさんの額はまさに秀でたとしか言いようのない、鋭い頭脳の切れ味を感じさせる、かたちの良い額だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
