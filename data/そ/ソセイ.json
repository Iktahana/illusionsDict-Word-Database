[
  {
    "uuid": "f10ecae9-1686-5ad7-80d2-54b3af062d7d",
    "entry": "組成",
    "reading": {
      "primary": "そせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
