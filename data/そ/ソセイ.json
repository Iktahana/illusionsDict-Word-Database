    },
    "definitions": [
      {
        "index": 1,
        "gloss": "composition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五　幕末ものの映画をその組成要素に分解してみると、割合に少数なエレメントで大抵の用を便じていることが分かる。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学的の言葉を借りて云えば、各個人、市民、あるいは国民がある現象に対して利害を感ずる範囲は時間と空間とより組成されたる四元空間中において、ある面にて囲まれたる部分にて示す事を得べし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳と目の比較をする時に考えられる著しい差別は、耳が複雑な異種類の音響の複合物をその組成要素に分析する能力をもっているのに、目には視像を分析する能力がないという点にある。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って白色光を組成する各種の波のうちでも青や紫の波が赤や黄の波よりも多く散らされる。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに云う味いは、芸術組成上の諸種の要素の、調合融合上から起る味いを云い、要素とは芸術組成上に必要なる、思想材料言語句法の各要素を云うのである。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "合金などの性質も一般にその組成金属の性質から推して知られぬ妙な事がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの事実は植物に関することであるが、しかしまた、日本国民を組成しているいろいろな人種的民族的要素の出所とその渡来の経路を考察せんとする人々にとってはこの植物界の事実が非常に意味の深い暗示の光を投げかけるものと言わなければならない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、まず、言語、国語という一つの体系は若干の語根元素から組成されていると仮定する。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には、この元素が化合して種々の言語や文章が組成されているが、これらの間にはその化合分解の平衡に関するきわめて複雑な方則のようなものがあると想像する。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の描き出した元子の影像がたとえ現在の原子の模型とどれほど違っていようとも、彼の元子の目的とするところはやはり物質の究極組成分としての元子であり、これの結合や運動によって説明せんと試みた諸現象はまさしく現在われわれの原子によって説明しようと試みつつある物理的化学的現象である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし無限大の空間にただ有限の物質があるとしたら、物質はすべてその組成元子に分解し尽くして、もはや何物も合成され得ず、従って何物も存在し得ない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも原子から微晶、微晶から多晶金属の組成、あるいはまたコロイドから有機体の生成等の機巧と相通じる考えである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元子が動いているのにその組成物体が静止しているように見える事のあるのは何ゆえか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物の性能が複雑であればあるほど、その物の組成元子は多種多様である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神を組成するものは、「精」、「熱」、「空気」、とそれに第四のある「名のない者」とである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の言葉の音波列を分析して、その組成分の中からその基音ならびに低いほうの倍音を除去して、その代わりに、もとよりはずっと振動数の大きい任意の音をいろいろと置き換えてみる。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、人間の肉も骨も血もいっさいの組成物質の屈折率をほぼ空気の屈折率と同一にすれば不可視になるというのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "種々な楽器の音や特に昔から問題となっている人声母音の組成要素を分析し研究するに適当な材料としてこの蝋管記録が種々に利用された。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋管に刻まれた微細な凹凸を巧妙な仕掛けで郭大した曲線を調和分析にかけて組成因子の間の関係を調べたりして声音学上の知識に貢献した事も少なくない。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず母音の組成に関する秘密はまだ完全に明らかにはならない。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに日本人にとっては日本語の母音や子音の組成、また特有な音色をもった三味線や尺八の音の特異な因子を研究するのはずいぶん興味のある事に相違ない。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらを一々引き合いに出して連句の場合に付会しようとしても、それはおそらく始めから無理であるにきまっているが、しかし連句の相次ぐ二句の接触によって甲句に含むいろいろの組成要素と乙句に含むそれらとの関係から、いわゆる付き過ぎたり離れ過ぎたりする現象が起こって来る。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、肝腎の芸術的興味が既くの昔に去っていて、気の抜けた酒のような気分になっていたから、苦辛したのは構造や文章の形式や外殻の修飾であって、根本の内容を組成する材料の採択、性格の描写、人生の観照等に到っては『浮雲』以後の進境を見る事が出来なかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがこの室にある立体分解電子機と、もう一つ立体組成電子機の縮図だ。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは十五年かかって、この器械を発明し、そして実物をつくりあげたのだ」「なんです、この立体分解とか立体組成とかいうのは」「うん、そのことだ。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、やっと気がついたようだね」と博士は頤髯をごそりとうごかし、「君の察したとおり、あの怪物は、実は、今月はじめて立体組成電子機をうごかしてみたところ、いきなり器械のはたらきでもって、台の上に現われてきたんだ。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ古代支那哲学の通覧を著わした鈴木の説に従えば『道は宇宙に形を与える原理であると同時に、また「天と地の未生以前に存在した渾沌たる組成のある物」、すなわち原始物質を意味するもののようである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある物体がなくなるように見えるのは、ただその物の組成（この四元素の混合関係）が変るためにすぎない、というのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の体躯はかの四元素から組成されたものだから当然のことである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、女房を逐出し得てからは、それこそせいせいした心持になって、渾身の情を傾けて力寿を愛していたことであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
