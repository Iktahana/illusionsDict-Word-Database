        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の頭は大きいから、灰色のソフト帽は、ちょこんと頭に乗っかって悲惨である。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は泳ぐように手を前へ出してその車の後を追ったが、バックグラスに透けて見えたのは僅かに乗客のソフト帽だけだった。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "開きて見よとすゝめらるゝまゝに紐を解くと空色のソフト帽なり。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　若者はソフト帽の前をおろしながら云つた。",
              "citation": {
                "source": "パンアテナイア祭の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "空色のソフト帽なり。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の他には、彼の中古のソフト帽と金時計とステツキが見あたらなかつた。",
              "citation": {
                "source": "露路の友",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人の服装はよくは覚えていないけれど、セルの着物にセルの羽織を着ていたが、相手の男はやはりセルの着物に黒の単衣羽織を着て、二人とも鼠色のソフト帽をかぶっていたとのことでした。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "車掌は背広のひどく背の高い若い男で、灰色っぽいソフト帽をかぶっている。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶色のソフト帽子の下に強度の近眼鏡があって、その部厚なレンズの奥にキラリと光る小さな眼の行方は、ペイブメントの上に落ちているようではあるが、そのペイブメントの上を見ているのではないことは、その上に落ちていたバナナの皮を無雑作に踏みつけたのをみていても知れる。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな荷物を赤帽に持たせて、改札口へ歩いて行くと、人混みの中からツバのヒラヒラしたソフト帽をかぶった若い男が現れた。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう社会的状勢は知っているが、どうもソフト帽の若者にゴマノハイをやられる気にはならない。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、驚いたことには何時のまにかもう、さっきのソフト帽の男が玄関に待っていて、わたしたちが馬車を出るや否や、荷物に手をかけた。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装などもちゃんとしていて、黒のソフト帽を被り、黒い長い外套を着ていた。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ははでな仕立の背広服をつけ、チョコレート色の短靴、薄茶色のソフト帽、籐のステッキという、すきのない身装をしていた。",
              "citation": {
                "source": "楊先生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから氣がついて見ると、私のソフト帽も、こいつはずゐぶん使ひ古した代物だが、今にもその折目がやぶれかかつてゐる。",
              "citation": {
                "source": "手紙",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして黒のソフト帽だけだが、昔の通りだった。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを私は思い出して、むず痒いような気持になり、構内の高い円い天井の下で、自分の黒いソフト帽を思いきり投げてやった。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀鼠色のかなりにいゝ品らしいソフト帽が見えた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下を見ると、心持｜阿弥陀に被つた練吉のソフト帽が、もう小さく桑畑の間を走つてゐるところだつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭字入りのソフト帽が現場に残っていたのと、お清やお新や母の証言があった。",
              "citation": {
                "source": "黒点",
                "author": "――或る青年の「回想記」の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだい、顔を出したら……」と沢屋は禿げ上った額をつるりと撫でるようにしてソフト帽をかぶり自転車に片脚をかけて、「みんな来るはずになっているんだが、あんたもひとつ……」「そうよな、でも、どうせ、俺なんか酒はあんまりやらんし、瘤のエロ話も若干ぞっとせんからな。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、絵具や画筆やカンヴァスや、凡てを新らしく買い求めるために、青いソフト帽を眼深にかぶって家を出た。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄っぺらな蒲団、二三枚の着物、セルの袴、七八冊のノート、粗末な古机、前年から持ち越しのソフト帽、などが彼の所有の全部だった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の手先に軽くソフト帽を抱えて、足を心持ちふんばり加減につっ立ち、引緊めた浅黒い顔の皮膚の下には、晴々とした笑みが溢れていた。",
              "citation": {
                "source": "白血球",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寔に色の真白な女の如き優男ではありましたが、五尺三寸にも足らぬ小柄な華奢な肢体を真黒なモジリで包み襟元から鼻の辺迄薄色のショオルで隠し灰色の軽々しいソフト帽子を眼深に冠った、一見して旧派の女形然たる千代三とは似ても似つかぬ別人物ではありませんか？",
              "citation": {
                "source": "陳情書",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、「まだかえっていませんよ――せっかく来たのに残念だなあ」と、黒川隆三が、脱いだ黒いソフト帽を片手にふりながら伸子たちのところへもどって来た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが、あなたはタワーリシチじゃないと云ったとき――それは、ほんとのことだのに」　黒いソフト帽をぬいで、またかぶって、蜂谷良作は、苦しい表情をした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る早朝、ひろ子がたった一人そのベッドに寝ていた二階の屏風越しに、ソフト帽の頭がのぞいた。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は型のくずれたソフト帽をやにわに頭から取って、そのさきを左手で握って、右手でぐいとしごいた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
