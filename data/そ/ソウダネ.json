        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「なるほどねえ、そりゃそうだねえ。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遠そうだね」「あそこに木がこんもり茂っているだろう。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がそれを指さして「さびしそうだねえ」と言ったら、友人の哲学者は「どうも少し病的のようだ」と答えた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに可哀そうだねえ、穂吉さんは、けれども泣いちゃいないよ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『おいしそうだね、お父さん』『待て待て、もう二日ばかり待つとね、こいつは下へ沈んで来る、それからひとりでにおいしいお酒ができるから、さあ、もう帰って寝よう、おいで』　親子の蟹は三疋自分｜等の穴に帰って行きます。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかがお前この頃｜情人が出来たそうだね、お目出度いことよ位なことを謂われるばかりさ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はね、馬は大佐にしてやろうと思うんです」　おっかさんが笑いながら、　「そうだね、けれどもあんまりいばるんじゃありませんよ」と申しました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又三郎はじっと空を見ていましたが「そうだねえ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだね全くそうだ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと大きくなるよ」　「ああ、ほんとうにそうだね、大きくなったねえ。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと大きくなるよ」「ああ、ほんとうにそうだね、大きくなったねえ。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何しろ談話の種になりそうだね。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ、泊りに行ったのかねえ、ここに、書いてあるのがそうだね。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と莞爾して、「おいしいついでに、何と、それも甘そうだね、二ツ三ツ取って下さい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……劫の経た奴は鳴くとさ」「なんだか化けそうだね」「いずれ怪性のものです。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見給え、実に面白そうだね」と友人がいう。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうに可哀そうだねえ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の筋はまあそうだね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのお駒は実物はあんなに綺麗じゃないそうだね。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たち青蛇団はみんな、針助の針にひっ掛って、背中に蛇の刺青をしているそうだね」「…………」　豹吉は唸っていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「なんだか、していそうだね」　莫迦々々しい質問だと、信吉はわれながらあいそが尽きた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まア、そうだね」　と、信吉はしぶしぶ相槌を打った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宴会のときは、軍服を着ていたほうが、スマートに見えるからね」「うん、そうだね」と、ヤルマールが言ったとたん、もう、このうえなくかわいらしいすずの兵隊さんのように、ちゃんと軍服を着ていました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "時評に依ると、お前の心境いよいよ澄み渡ったそうだね、あはは。",
              "citation": {
                "source": "或る忠告",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは、道場からの帰りに、大幹部の沢村嘉右衛門と市電の停留場まで一緒だったが、「君は毎日毎日、ちがう本を、ポケットにいれて来るそうだね。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、時おり、「かず枝も、かあいそうだね。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それもそうだねえ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、そうだね、」と困ったような顔をして、「或る意味では、むしろ、都会人とでも言いたいのであるが、」といよいよ窮して、「そうだ、君は支那人だ！",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ打たれたのだい、痛そうだねえ。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
