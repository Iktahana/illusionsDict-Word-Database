      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "illustration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてそれらの挿図の説明はというとほとんど空っぽである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く挿図のレビューである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、是れシラギントワイトの『西蔵探険記』の挿図に非ず哉。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ高価を支払われて外国へ流出したものも沢山あるらしいから、追付けクルトやズッコのお仲間が日本人の余り知らない傑作の複製を挿図した椿岳画伝を出版して欧洲読画界を動揺する事がないとも限られない。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "挿図において０と記した点が現在を示し、従って過去への時間は負、未来へは正の値で表わされる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、過去における温度の不同は現在よりは大きかったとしても、その不同の減じ方が今よりは緩やかであった、と言うよりもむしろあり得る限りの緩やかさであって、挿図の曲線のＤＡの部分に相当するものであったと、こう考えることもできはしないか。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "『富士見十三州図』や『利根川図志』の挿図には、藤原の手前から大小烏帽子の間に向けて、途中まで路が書き入れてあるが、これは明に宝川温泉への道であるべきものが誤記されたものであるというを憚らない。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『因幡志』巻十四の挿図に平地と書いて「ナルジ」と振仮名をした所があった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はなぜかその話が面白くて、今でもその挿図の子供の姿が眼に残っている。",
              "citation": {
                "source": "九年母",
                "author": "青木正児",
                "note": "青空文庫"
              }
            },
            {
              "text": "岳初夏（西岳より）のキャプション付きの挿図（fig58704_49.png、横600×縦515）入る］槍※岳初夏（西岳より）　ここから白檜の間を、笹と灌木をふみわけて、下り加減に南へたどると、次々に大小の池があらわれる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「背の高い硬砂岩の自然石の三面に線彫されたこの三尊法来迎の形式になつてゐること本文の挿図の如くであるが、その内最もよく保存され佛容の比較的明瞭な勢至像の面をこゝに掲げた。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に御懇志かたじけのうこそ候え、明朝参りて御礼を申そうず、というのであった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
