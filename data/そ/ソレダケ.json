        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "内儀さんは復た被害者の家へ行つて其れ丈の筋道を聞かせたが、どうしても今度はうんといはない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幾らもしないね、其れ丈ぢや」「そんでも大凡まあどの位したもんでがせうね」勘次は又反覆して促した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し其れ丈でさへ卯平は始終財布の錢の出入するのを心丈夫に思ふのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して僕にも其れ丈の活力タリテ」は底本では「※リリテ」］があるか、何うか。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し其れ丈で滿足することが出來ぬ。",
              "citation": {
                "source": "支那古典學の研究法に就きて",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち其れ丈けの程度に於て必ずヘーゲルの所謂｜擧揚されたる契機として將來の人文中に永久に生きて行くべき者であると私は信ずるのであります。",
              "citation": {
                "source": "懷疑思潮に付て",
                "author": "朝永三十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち此處に入れられた者は入つてゐるのであるし、入れられん者は自由に出歩いてゐる、其れ丈けの事です。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞそれだけだとみせては職業の態がなくなるから、『陽気な交遊を！",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらそれだけである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ努力のし甲斐があろう。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ、閉口なものである。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのところ、それだけが、僕の力で、わけなくできる奉仕です。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京だなあ」というたったそれだけの言葉の感傷に。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけで、何もかも、判るだらう。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝めざめて、きょう一日を、充分に生きる事、それだけを私はこのごろ心掛けて居ります。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ナストウリ、モノサシトハサミ、カガミガアリマス、イケニフネ……」大急ぎでそれだけ読んだが、そこで息が切れた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が耕二の間の障子を開けると、「負けちやつた」と耕二はいきなりそれだけ言つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それだけだと思つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども（義理の）祖母の手前何時も母は「それだけはお止しなさい」と言つて今迄止めて来てゐるわけだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　妻君も亦快よく唯それだけ云つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、それだけでも何だか、彼は客として来る者に対する責任を感じてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶の舌ゼンマイに似る暑さかな暖かや蕊に臘ぬる造り花臘梅や雪うち透かす枝のたけ「蝶の舌」の句は、ゼンマイに似ているといふ目付け所が山であり、比喩の奇警にして観察の細かいところに作者の味噌があるのだらうが、結果はそれだけの機智であつて、本質的に何の俳味も詩情もない、単なる才気だけの作品である。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳者に、もしそれだけの資格がなく、原作者との比較に於て、問題にならないヘツポコ詩人であるとすれば、むしろ全然さうした翻訳を読まない方が利口である。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれだけまた友が恋しく、稀れに懐かしい友人と逢った時など、恋人のように嬉しく離れがたい。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しその特別の奇がないだけ、それだけ感じの落付いたおつとりした所でもある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯や駒鳥はいつも鳴いてゐるし、樹陰の深い緑は所々にあるし、それだけで山間の別天地をなした鮮新な温泉町としてゐる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "総長にでもなる人にはやはりそれだけの活力があるのかと思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも南国の旅の正月であったが、単にそれだけのことであるのか。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけにその印象はかえって一倍強烈であったのかもしれない。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟妹とちがって風采もよくてハイカラでまたそれだけにおしゃれでもあった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
