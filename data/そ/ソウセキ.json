    "definitions": [
      {
        "index": 1,
        "gloss": "transfer of legal domicile",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
