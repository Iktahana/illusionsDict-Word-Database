        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "電波の遭難船とでも申しましょうか。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方も正規の航路を離れる訳だから遭難船の無線だけを唯一の頼りに、遮二無二急いで来る。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう、なん世紀前かしれぬボロボロの船、帆柱にもたれる白骨の水夫、それを、死ぬまで見なければならぬ新遭難船の人たち。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遭難船なんてめずらしい観物だ。",
              "citation": {
                "source": "沈没男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、どうした」「ソノ、つまりこの地底戦車が、遭難船の船底をぬけおちまして、海底ふかく沈没しましたときから、自分は敢然、先頭に立って、この戦車を操縦しつづけたのであります。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "遭難船からのＳＯＳだ！",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "遭難船の姿は、なかなか入らなかった。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると遭難船の姿を発見しなければならぬことになるが、さて探照灯を動かしてから見渡したところ、ボート一隻浮んでいないではないか。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、肝腎の遭難船の姿は、どこにも見えない。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "遭難船の破片か、あるいは油とか、積んでいた荷物などが漂流していないかと気をつけたが、ふしぎにも、それすら眼に入らないのであった。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきまでは、こっちが遭難船を助けに急いだのに、今はその逆になって、こっちが助けを呼ぶ身となった。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平洋の遭難船で、半年以上も漂流していた例さえあるんだ。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎゃくの海流と、風とを乗りきって、二千カイリにちかい航海のできる小帆船が、遭難船といえますか。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
