  {
    "uuid": "83881450-f986-5c6d-b60a-468035beafa1",
    "entry": "宗廟",
    "reading": {
      "primary": "そうびょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ancestral shrine (temple)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恐懼修省の工夫が有れば、以て宗廟社稷を守り、以て祭主と為るべきである。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬の権、他人の手に落ち、金穀の利、一家の有たらずして、将帥外に傲り、奸邪間に私すれば、一朝事有るに際しては、都城守る能わず、宗廟祀られざるに至るべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "方孝孺に語りたまわく、燕王は孝康皇帝｜同産の弟なり、朕の叔父なり、吾他日｜宗廟神霊に見えざらんやと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れまことに天、朕が不叡、且つ国の不平たるを愍みたまひて、天業を経綸め宗廟を絶たざらしめたまふか」　とまでに仰せられた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは道士等が王室の李姓であるのを奇貨として、老子を先祖だと言い做し、老君に仕うること宗廟に仕うるが如くならしめたためである。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "身分ある者は、家屋を造る際に、先づ祖先を奉安すべき宗廟から着手する（『禮記』曲禮下）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗廟に供へる穀物は、天子・諸侯と雖ども皆自身で耕作する（『穀梁傳』桓公十四年）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗廟に奉仕する祭服は、王后・夫人の手で親しく紡織する（同上）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "……莫重於祭」（『禮記』祭統）といひ、「修宗廟。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "令宗廟血食也」（『漢書』霍光傳）がそれである。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその宮城の南西の方に社稷、南東の側に宗廟があります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮城から南面して宗廟の方は左に在つて社稷の方が右に在る、宗廟とは歴代祖先の御靈舍で、御靈を祀つて居りますが、社稷の方は御靈舍ではありませぬ、壇を拵へて、その上で天のお祭りをするのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）謀大逆といふのは、謂謀毀宗廟、山陵、及宮闕と註せられて居ります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "大祀神御之物とありますが、支那には大祀・中祀・小祀とあつて、この大祀とは天地宗廟の祭りを指します。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "上以事宗廟即ち夫は相手の妻と云ふものが出來て、その妻と共に宗廟のお世話をし、下以繼後世即ち世話する者をば絶やさぬやうに子孫を作る、さう云ふ目的の爲めに昏禮をするのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗廟で斯の如き儀式を行ふと云ふことは、結婚が家と家との間の儀式であるからであつて、婚禮と云ふことを非常に鄭重に行ふべきことになつて居るのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『禮記』には「上以事宗廟。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は既に問名の禮が終ると、今度は壻の家で、何某の家の何番目の娘の何某といふ者を今度嫁として娶らうと思ふと云ふのでそのことの可否を宗廟で占ひをします。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗廟に占つて吉と決まつたら、愈※納徴といふ順序になり、それには仲人になるものが禮物を嫁の家に持つて行つて宗廟に於て渡すのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ是から時刻だから、お前は出て行つて、嫁の家に往つて爾の相手を迎へて來たれ、そして我が家の宗の事を承けよ、宗廟の事務を疎かにしないやうにせよといふのです。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗と云ふのは自分の家の宗廟のことであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "父から是から出て行つて我が家の宗廟のお世話をする相手を迎へて來いと云はれるのでありますから、壻たるものは、承知しました、必ず父の仰せに從ひますと云つて出て行く。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁の家に達すると先づ嫁の父が壻を導いて、自分の宗廟に迎へて、其前で自分の娘を、其祖先の見て居る前で壻に渡すのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "壻さんは嫁の家の宗廟で嫁を受取つて出ようとする。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "是で結婚の儀式は一通り終つたのでありますが、もう一つ重大なことは、その後滿三月經つて、愈此嫁ならば大丈夫と云ふに至ると、それから宗廟にお目見えし、此の廟見が終つて始めて正式の妻といふことになるのであつて、それからはその結婚は動かすことが出來ませぬ。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "貰つた時には少しも分らなかつたが、此病氣は家の血統を惡くすると云ふ恐れもありますし、又癩病でありますならば、夫と共に宗廟の祀をする時に穢れると云ふ恐れもありますから、七出の中に入れたのでありませう。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで明治三十九年に、從來中祀とて、二等祭祀の待遇を受けて居つた孔子の祭典を、急に大祀に昇格させ、天地・宗廟と同等の待遇をすることとなつた。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
