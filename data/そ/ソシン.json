[
  {
    "uuid": "0f338828-db01-524d-b362-9f9bbdf68ac6",
    "entry": "祖神",
    "reading": {
      "primary": "そしん",
      "alternatives": [
        "そじん"
      ],
      "is_heteronym": false
    },
    "grammar": {
