        "examples": {
          "standard": [
            {
              "text": "彼女は、このシャツを花柄で、袖を本体とは違う色に染め分けるつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのテキスタイルアーティストは、複雑な多色模様で生地を染め分けることに特化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「袖を本体とは違う色に染め分けよう」と彼は提案した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "薄い靄が横に棚引いて、富士の上半を濃い桔梗色に、下半を淡い水色に染め分ける。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間の淡靄は、その光りに飽和して、大｜柄の段だら縞に、山谷を染め分ける。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
