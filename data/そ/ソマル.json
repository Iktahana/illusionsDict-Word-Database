    "definitions": [
      {
        "index": 1,
        "gloss": "to be dyed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ソビエトの幼児が函館の町っ児の感化に染まることを恐れるのであろう。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ている自分もほーっと染まる。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服を着て帶を〆めて、やがて尻を端折らうと云ふ頃、ふと橋の上を見ると、堅氣も多いが、賣女屋のある小さな宿、何となく自墮落の風が染まると見えて、宿中いづれも朝寢らしい。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……処々巌蒼く、ぽっと薄紅く草が染まる。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫へ這上りそうな形よ、それで片っぺら燃えのびて、おらが持っている艪をつかまえそうにした時、おらが手は爪の色まで黄色くなって、目の玉もやっぱりその色に染まるだがね。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫のその姿が、正面の格子に、銀色の染まるばかり、艶々と映った時、山鴉の嘴太が――二羽、小刻みに縁を走って、片足ずつ駒下駄を、嘴でコトンと壇の上に揃えたが、鴉がなった沓かも知れない、同時に真黒な羽が消えたのであるから。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、顔の色が真蒼になるとともに、垂々と血に染まるのが、溢れて、わななく指を洩れる。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに土曜日の京都は、沼の底に妖しく光る夜光虫の青白い光のような夜が、悪の華の巷にひらいて、数々のいまわしい出来事が、頽廃のメシベから放つ毒々しい花粉の色に染まる――というこの形容は誇張であろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "断り無しに持って来た荷物を売りはらった金で、人力車を一台｜購い、長袖の法被に長股引、黒い饅頭笠といういでたちで、南地溝の側の俥夫の溜り場へのこのこ現われると、そこは朦朧俥夫の巣で、たちまち丹造の眼はひかり、彼等の気風に染まるのに何の造作も要らなかった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "長唄　元寇長唄　元寇第一段天に連る玄界の際涯はいづく壱岐対馬、夕浪千鳥群れかへる蜑の小舟のそれならで、山かと高き兵船の満々と張る真帆の数、櫓に撓むる石火矢に軍皷の調旌旗とどよもし、舳艫相｜接ぐ九百余艘、入日に染まる船脚やとどろと洗ふ潮の手を、しや、ひた押しの陣がまへ松浦さしてぞ押し寄せたる。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向うの空のぬれた黝朱の乱雲、それがやがては褐となり、黄となり、朱に丹に染まるであろう。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで例の一合足らずの硝子燗瓶が傾いて翁の顔がイヨイヨ海老色に染まる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と二人で見ているうち、夕日のなごりが、出崎の端から※と雲を射たが、親仁の額も赫となれば、線路も颯と赤く染まる。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木の葉があんなに染まるのでございますから、朝晩お寒くなりましたのも無理はございませんね」　姉娘が突然弟を顧みて言った。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気に染まる人また立所に命を殞さざるなし、道南鼠死行一篇を賦し、奇険怪偉、集中の冠たり、数日ならざるに道南またすなわち怪鼠病で死んだも奇だとある。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜がおりて葉が染まる、落ちる、程なく雪がやつて來るのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "老松の間に在つてこの木の漸く染まる頃からこの松原はよくなつて来る。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向うの空の濡れた黝朱の乱雲、それがやがては褐となり、黄となり、朱に丹に染まるであらう。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばてんは、初夏の比、麦の茎が黄ろに染まる比に好く出て、野に遊んでいる村の少年をたぶらかした。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへの緑の髮の毛の波は、貝の音が斧の刻を告せると、眞紅に染まる。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "染まるべからざるものに染つて行く可能性を賦与した自然は？",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の足は和尚のそれとは異つて、色が黒く、きめが粗いやうだが、やはらかい若草の葉を踏むと、すぐに緑の色に染まるので、私はそれを見て自分の足の裏からも若やかな春を感じ、春を味はふことが出来ようといふものだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭ひでふけば拭いた手拭ひが黄いろに染まる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の足は和尚のそれとは異つて、色が黒く、きめが粗いやうだが、やはらかい若草の葉を踏むと、すぐに緑の色に染まるので、私はそれを見て自分の足の裏からも若やかな春を感じ、春を味はふことができようといふものだ。",
              "citation": {
                "source": "春の賦",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその三角に包んだ筍の皮が梅酸の色に染まるのを樂みにして、よく吸ひました。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "空に聳えている山々の巓は、この時あざやかな紅に染まる。",
              "citation": {
                "source": "木精",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬時に染まる血紅色。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "単純な繰り返し作業は、コンピューターに任せるという健全な常識をすでに身につけていたブリックリンにとって、時代の歯車を巻き戻してこうした悪習に染まることは耐えられなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "平日は重い口が、顔が赤銅色に染まると、「××屋は、すっかり殿さまぶっちまやがって、芸妓が来ても、おお、来たか、近う近うなんていやがる。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い色は許さぬぞよと威張つてみても、御所柿の實が自然に赤く染まるのを、將軍樣だつてどうすることも出來ぬぢやないか。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
