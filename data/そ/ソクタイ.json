    "definitions": [
      {
        "index": 1,
        "gloss": "old ceremonial court dress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
