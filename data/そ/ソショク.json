    "definitions": [
      {
        "index": 1,
        "gloss": "simple diet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "粗食故に長寿して居た生命が、美食に遇ってたちまち破損して仕舞ったのだそうです。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から、粗食が長寿の一法だとの説がある。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、粗食それ自身がいいのではなくて喰い過ぎないことがいいのかもしれない。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "革鞭と樫の棒との間斷なき脅威、粗食と過勞と濕氣のための病氣――反抗の氣力も、性格さへもなくしてしまつた人夫達が、最後に解放されて吹雪のなかへ出てゆき、死物狂の復シユウに立ち歸るまでのことが重々しい印象で書かれてゐる。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある地方の倹約な商家では平日雇人のみならず主人達も粗食をしていて、時々「贅沢デー」を設けて御馳走を食ったという話もある。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田山花袋の「一兵卒」は、日露戦争に、満洲で脚気のために入院した兵卒が、病院の不潔、不衛生粗食に堪えかねて、少しよくなったのを機会に、病院を出て、自分の所属部隊のあとを追うて行く。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗食を与えられ、虐待され、身体中こづき廻され、番兵の命令によってこき使われる。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗食故に長寿していた生命が、美食に遇ってたちまち破損してしまったのだそうです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで、じだらくにして、粗衣粗食してをれば、周囲がしづかで、すゞしくて、のんきでゆつたりしてくる。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来からの茅葺、柾葺、杉皮葺は、とにかくとして、現在多くの民は、トタン葺の家に住み、ふろしきを被つて、もんぺいをはき、中流以下悉く粗食に甘んじてゐる、といふ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃病だけではない、粗食を常にして諸病に犯され易い薄弱体を持って苦しんでいる人もある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "形式と精神とを分離して考えるのは形式を破棄するには好都合であるが、口に精（栄養）を取り粗食をやめて内（自分）を尊んで外（形式）を忘れて、先ず律儀（義理）を破るのは大坂城の外濠を埋めたようなものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二ノ理由ハ其ノ中食ニ一塊ノ「パン」薩摩芋麥ノ握飯等ノ簡單ナル粗食ヲナサシメ、以テ滋養價値等ヲ云々シテ眞ノ生活ヲ悟得セザル科學的迷信ヲ打破スルニアリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戰國又ハ亡國ノ將校ガ常ニ兵卒ノ粗食飢餓ヲ冷視シテ己レ獨リ美酒佳肴ヲ列ベシハ一ノ例外ナキ史實ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に上帝｜驢を招き、汝は苦労せにゃならぬ、すなわち、常に重荷を負い運び、不断｜笞うたれ叱られ、休息は些の間で薊や荊の粗食に安んずべく、寿命は五十歳と宣う。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "立身出世をする人物は子供の時分から粗衣粗食に甘んじて常に楽しく励む者である、といふ風なことをいつも祖母から教へられてゐた。",
              "citation": {
                "source": "鞭撻",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗食と運動不足がすぐ身體に變調を來たさした。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て行くとき彼女は長い廊下を見送る看護婦たちにとりまかれながら、いささかの羞ずかしさのために顔を染めてはいたものの、傲然とした足つきで出ていった、それは丁度、長い酷使と粗食との生活に対して反抗した模範を示すかのように。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一つは粗食した結果だ」　この考えが私の胸に浮んだ。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝苦しく胸苦しかつた、粗食大食のためか！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして睡眠不足、粗食が守るべき女の規則として提出されている。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天香師は強い信仰から、仏によりて養われるならば粗食でも仏の加護で壮健を保たれるといわれます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず自己の墓を築いて置いて粗衣粗食で激しく労働しつつ無言の行をやるというあの修道院の内の僧侶達に自分の身を譬えて見たこともある。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "為山氏は善き衣善き駒下駄を著け金が儲かれば直に費しはたすに反して不折君は粗衣粗食の極端にも耐へなるべく質素を旨として少しにても臨時の収入あればこれを貯蓄し置くなり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽侮する者はまた恐るという通り、一方にはむやみに支那農民の食物は粗食でついてゆけぬと考えていると同時にまた反面、包米ビーンズに高粱飯を食わねば満州農業移民は成立せぬなどといっています。",
              "citation": {
                "source": "蕎麦の味と食い方問題",
                "author": "村井政善",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こんな粗食で健康が保たれるはずはないなどと思ってはいけない。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "按摩｜按腹をしても餓えて死ぬ気遣いはない、粗衣粗食などに閉口する男でないと力身込んで居るような訳けで、私が経済上に不｜活溌なのは失敗の極端を恐れて鈍くして居るのですが、その外直接に一身の不義理にならぬ事に就ては必ずしも不活溌でない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の小民の子が粗食大食勝手次第にして却て健康なる者多し。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
