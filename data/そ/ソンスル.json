[
  {
    "uuid": "85d68877-079e-548d-b57e-268dddc804d4",
    "entry": "損する",
    "reading": {
      "primary": "そんする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
