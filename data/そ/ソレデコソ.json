    "definitions": [
      {
        "index": 1,
        "gloss": "just what you'd expect from ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
