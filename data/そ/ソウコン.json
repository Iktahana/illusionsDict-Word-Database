[
  {
    "uuid": "05158d19-a0ea-51ad-bcb2-911eb8d28370",
    "entry": "創痕",
    "reading": {
      "primary": "そうこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
