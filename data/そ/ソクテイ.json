[
  {
    "uuid": "a12aad60-269e-5182-a962-5015c66b9e50",
    "entry": "測定",
    "reading": {
      "primary": "そくてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
