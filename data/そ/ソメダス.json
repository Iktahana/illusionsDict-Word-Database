        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見よ、朝凪の浦の渚、潔き素絹を敷きて、山姫の來り描くを待つ處――枝すきたる柳の中より、松の蔦の梢より、染め出す秀嶽の第一峯。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の末の晩稻を刈る頃から、夕日の射し加減で筑波山は形容し難い美しい紫を染め出す。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の末の晩稻を刈る頃から夕日のさし加減で筑波山は形容し難い美しい紫を染め出す。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "流るる星の数々は、枝の間に散り落ちて、　千万億の葉をふるう、今年の秋の真夜中の、　霜に染め出す文字の数、繋ぎ繋がる物語。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば子持縞に錠を染め出すとか、温州の種なしみかんの絵とか、山吹の花を表したものなぞである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、庭の石灯籠の袋に火が入り部屋の火影が竹林の足を染め出すころになって、女中に伴われ千鶴子たち二人が廊下を渡って来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お信は細身ないつもは蒼白い顔で頼りない寂しい風をしていたが、何かの機会には情熱に燃えて美しく頬を染め出す女であった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旗は算木を染め出す代りに、赤い穴銭の形を描いた、余り見慣れない代物だった。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃からなる廂に遮ぎられて、菜の花を染め出す春の強き日を受けぬ広き額だけは目立って蒼白い。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂であろう、黄色い落葉が灰色の岩の上に鮮かな斑紋を染め出す。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元に落ち重っている新しい笹の枯葉の上に青葉の繁みから日光が洩れて、豹紋のような斑点を染め出す、糸のように痩せた蔭草が青白い茎を抽き出して其上を匐っている。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義と云い人道と云うは朝｜嵐に翻がえす旗にのみ染め出すべき文字で、繰り出す槍の穂先には瞋恚の※が焼け付いている。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには私自身の姿の上にも、青白い月が松の葉影をくっきりと染め出すようになる。",
              "citation": {
                "source": "母を恋うる記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "150夕映を意味深い色に染め出すのです。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
