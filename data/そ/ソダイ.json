        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また地球は恒星や諸遊星よりももっと粗大な物質からできている、そのために遊星系の中心に位しなければならないというその説もまた彼の考え方に特異な点である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の元素は最小な粒子から、第三のものは最も粗大な分子からできている。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに「空襲恐るるに足らず」といった粗大な指導方針が事をここに至らしめたのだろう。",
              "citation": {
                "source": "一つの世界",
                "author": "――私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう種類の文章のもう一つの特徴は、文章が粗大の傾きをもっていることである。",
              "citation": {
                "source": "今日の文章",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗大な概括をすることを深く警戒するものであるが、今日までのところ、現れている作品は多く手法の上で何かの問題を持っていることを第二として、人間というものの捕え方に於て、先刻触れた二元性に陥っている傾向が見られる。",
              "citation": {
                "source": "ヒューマニズムへの道",
                "author": "――文芸時評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋の作品であるが、この粗大な、民族的類型化を卓抜な科学者であるという沼田博士に云わしめているのである。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最もいつわりのなかるべき芸術の仕事をしている女のひとの感情でさえ、たとえば近頃の岡本かの子氏の時局和歌などをよむと、新聞でつかうとおりの粗大な形容詞の内容のまま、それを三十一文字にかいていられる。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆人醉へる中に獨り醒むる者は容れられず、斯かる氣質なれば時頼は自から儕輩に疎ぜられ、瀧口時頼とは武骨者の異名よなど嘲り合ひて、時流外れに粗大なる布衣を着て鐵卷の丸鞘を鴎尻に横へし後姿を、蔭にて指し笑ふ者も少からざりし。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑翹は額の低い、頤の短い※子に似た顔で、手足は粗大である。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の色どりとか着こなしとかの外には、どうした、こう云ったという、粗大な事実の記憶ばかりが残っているのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頗る粗大な、脳髄に余計な要求をしない事柄で好い。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "却て愈々粗大なだけ愈々適当であるかも知れない。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　Ｓ城の軍兵はその粗大さの故に遂に破れた。",
              "citation": {
                "source": "静かなる羅列",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その滑かな饒舌の臭を帶びた臺詞も古いし、感情の誇張、粗大なところも古い。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "○いのちさ　此さは、粗大な、奴詞めいた、遊女の語づかひで、捨鉢な気持ちを表してゐる。",
              "citation": {
                "source": "地唄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毒喰はゞ皿まで」など言ふ、粗大な諺の源も、或はこんな処に、存外なひつ懸りを持つてゐるのかも知れぬ。",
              "citation": {
                "source": "まじなひの一方面",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩なぞは天下国家をどうするとかこうするとか、無闇に粗大な迂闊な問題にばかり空騒ぎをして自分の腹の中を治める事が出来なかったのです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども之を夫の鮒※を釣る織細の釣具に比する時は、都人士の夢想にも及ばざる粗大頑強のものたるは言うまでもなし。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の自慢はそれが極上の布地で拵へてあることで、一見したところ粗大な風體のやうであるが、見別ける段になると、殆どイギリス人の天性と云つていい、あの身だしなみが判る。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "御笑留被下度、外粗大なる冬瓜一つ御目にかけ申候。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお粗大な冬瓜とありますのは、全く珍しく見事な物で、親類中に分配していただきました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば春信の板画は過去の粗大と将来の繊細との中間に立ちて独り温雅優美の情を恣にするものといふべきなり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "このムラサキ科のチサノキは何等風情の掬すべき樹ではなく、樹は喬木で高く、葉は粗大で硬く、砕白花が高く枝梢に集って咲き観るに足る程のものではない。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本品は強壮な常緑多年生の硬質植物で、茎は粗大で短く、あまり高くならない。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳かな手つきで、あくまで荘重に、粗大な衣布の襞を掻き上げ、胸へとって肩からうしろへ投げかける。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは精神的生活の末梢に位する、粗大な、外面的な價値を表示するに過ぎない。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "体はなくつて大小だけ橋の下に落ちてのこつてゐたこともあるんだもの……』『うそだい……』もう好加減大きくなつてゐる順吉は、容易にさうした嚇かしを信じなかつた。",
              "citation": {
                "source": "花束",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うそだい」かっちゃんは元気らしくそう言いました。",
              "citation": {
                "source": "誰が・何時・何処で・何をした",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うそだい、喰べらあ。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそれを読んで順番に喋ったにすぎないんだ」「うそだい。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
