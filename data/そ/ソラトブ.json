    "definitions": [
      {
        "index": 1,
        "gloss": "to fly in the sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
