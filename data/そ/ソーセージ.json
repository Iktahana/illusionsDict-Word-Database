        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ソーセージくらいの大きさである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はフォークの尖にソーセージの一片と少しのシュークルートの酢漬けの刻みキャベツをつっかけて口に運びながら食卓に並んだ真中の新吉を越して夫人に快濶に話している。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キング・ジョージが二つ、それからソーセージが二つ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、ハムとソーセージが並んでいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "買ったばかりのソーセージに、おじさんはさっそくかぶりつきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛肉の大和煮、コンビーフ、ウィンナソーセージ、オイルサーディン、シャケの水煮、桃やミカンやパイナプルといった果物類、オレンジジュース、コカコーラ、そういった缶詰がほとんどだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい、あの中身はビールにちがいない」「ソーセージもだろ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が彼に、鼻曲りといふ形容詞を冠したのは、彼の野蛮な皮肉味を抽象的に指さしたのであつて、実物の彼の鼻は、いつも私に昔噺の中にある業慾者の鼻にぶらさがつたといふソーセージを想像させる態の、赤味の滲んだ肉附き豊かな、何とも憎たらしいごろん棒であつて、決して曲つてゐるといふわけ合ひではない。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は朝起きぬけに、ソーセージを肴にして迎い酒を二、三本やったのだ。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、彼奴はソーセージを鼠の肉で作っているのか。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも怪しからん奴じゃ」「いやァ旦那、そう云うけれども、鼠の肉を混ぜたソーセージと来た日にゃ、とても味がいいのですぜ。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから鼠の肉入りのソーセージは、なかなか値段が高いのです。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午すぎ、樹明君から態々人を以て野菜即売会への案内を受けたので、農学校へ出かける、見事な野菜が陳列されて、如才のない主婦たちが盛んに買ひ込んでゐる、私も大根、京菜、鶏肉、ソーセージを頂戴したが、とても重かつた、しかしその重さはありがたい重さだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、パン、ビフテキ、ローストビーフ、ソーセージ、オムレツ、ハム、サーディン、マカロニ、サラダ、キャフェ、チョコレート、バター、ジャム、砂糖、塩、米というように、普通の食品を二十ばかりならべた上に、なお数種の果物と葡萄酒とビールとまでがはいっている。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝るまで、せめて茶とソーセージののっかったパン位は食べたい。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスク※文化象徴である｜石油コンロ、薬カン、人別手帖で買ったところの貴重なパンの塊、ソーセージ、――つつましき人生の全必需品がもち込まれて居るのだ。",
              "citation": {
                "source": "無題（七）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方から約束通りに学校の宿直室で樹明君と飲んだ、飲みすぎた、ソーセージはうまかつた、理髪して貰つてうれしかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君が朝早く来た、微醺を帯びてゐる、昨夜の残りをひつかけたのださうな、ソーセージがうますぎて少々あてられたといふ、談笑ちよつとで別れる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君は苦労人である、よい意味での、――だから、今、彼がさげてきた包が、木炭とソーセージであつても、ちつとも不自然でない、わざとらしくない、ちやんとイタについてゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして、千鶴子がアスパラガスやソーセージを持って客間に戻って来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に、紅茶、林檎を十個、梨五個、キャラメル、ソーセージ三種、牛鑵二個、レモン二個、バターに角砂糖一箱、パン二個、ゼリー、それからヤカンや、肉刺、匙、ニュームのコップなど揃へました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十分もして、鷄介は、卵やソーセージや、コッペパンを買つて來た。",
              "citation": {
                "source": "あひびき",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソーセージ、食べてみない……」「えゝ、もう澤山です。",
              "citation": {
                "source": "あひびき",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "博覧会の中で見たことのあるソーセージ製造器械なんです。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが平べったいソーセージの缶なんで……。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもマサカと思いながら今のソーセージの切口をよく見ると、薄桃色の肉の間に何だか白い三角｜型のものが挟まっているようです。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしに惚れていたフイ嬢が、あっしの身代りにソーセージになって、ここまで跟いて来たんじゃねえか……ナンテ考えておりますと、最早、ビールの肴どころじゃ御座んせん。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの頭がソーセージみたいにゴチャゴチャになっちまいました。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
