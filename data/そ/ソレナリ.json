[
  {
    "uuid": "a2747086-56a3-52dc-8cba-0661823e64d9",
    "entry": "其れなり",
    "reading": {
      "primary": "それなり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
