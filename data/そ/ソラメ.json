    "definitions": [
      {
        "index": 1,
        "gloss": "thinking one saw something that wasn't actually there",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
