[
  {
    "uuid": "10426ca6-0116-5482-b34b-b67ce73a36e9",
    "entry": "素因",
    "reading": {
      "primary": "そいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
