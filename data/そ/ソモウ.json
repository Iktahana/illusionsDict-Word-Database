    "definitions": [
      {
        "index": 1,
        "gloss": "combed wool (yarn)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
