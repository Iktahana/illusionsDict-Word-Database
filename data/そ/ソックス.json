        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「靴下がグジュグジュなんだよ」　高志は笑って、「これ履けよ」と、ソックスを脱ぎはじめる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっき、風呂入って履きかえたばっかだからさ」　と、脱ぎ終わった｜ダイア柄のソックスを、慶一にわたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソックスを履いても、そのクツは慶一にはすこし大きい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "金ボタンの紺のブレザー、紺のボウタイ、タータンチェックのスカート、白いハイソックス、茶のローファーというかっこうの令子は、母親にうながされ、玄関のほうに足を向けた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより最初に一ぺん水につけるとか、ソックスをはくとかすることで、現実にいくらかでもその靴下の寿命がのばせる。",
              "citation": {
                "source": "人生を愛しましょう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "りよは濡れたソックスをぬいだ。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "羚羊のやうなすんなりした脚で、何時もネビイブルウのソックスに、白い靴をはいてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　短いソックスで畳の上をすべるような勢でかけ出した。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宏子は、ベージュ色のスウェータアの下のところを、組み合わせた手へ巻き込むような工合にして、頭を下げ板の目かずを数えるように靴下の上にソックスを重ねてはいた自分の足のたけだけを一直線の上にかわるがわる踏んで狭い場所をゆきつ戻りつしている。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａの洋傘、ソックス。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじょうさんはそれからも長いあいだ悲しそうにしていたが、だんだんジェミイの家の生活になれてくると、ぶたの世話をしたりにわとりのえをやったり、古い毛糸でソックスをあんだりするようになって、一年の月日がすぎた。",
              "citation": {
                "source": "ジェミイの冐険",
                "author": "片山広子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソックスは母の同盟の小母さんが編んでくださった。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いすじの入ったソックスもしきりに気になるらしい。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり暑い日、つや子はソックスをはいて行って、ひどくマ・スールに怒られ、早びけして来たことなどあった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は、ソックスをはいた白い棒のような細くながい脚を、退屈げにぶらぶら動かしている。",
              "citation": {
                "source": "十三年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリーム色の毛織のソックスを穿いた可愛らしい脚が四本｜列んだ。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さな生物を入れた錠剤箱をソックスの下に何週間も飼っていたら誇張ではなく親しみを感ずるようになる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、木綿のソックスだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手に、白いテニス・シューズとソックスとを持っていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソックスをはき、続いてテニス・シューズをはいた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "トモのソックスは赤、ハチミのソックスは黒、そしてリカのソックスはグリーンだった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソックスに蛍光ペン、そして小さなドルフィンの縫いぐるみだった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いスニーカーに淡いグリーンのソックス、そしてカーキ色のショート・パンツに黒い半袖のシャツを、今日のハツキは着ていた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
