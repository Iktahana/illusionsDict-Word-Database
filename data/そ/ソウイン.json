[
  {
    "uuid": "73734882-ec64-5403-995e-92125e8d056b",
    "entry": "僧院",
    "reading": {
      "primary": "そういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
