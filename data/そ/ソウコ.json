[
  {
    "uuid": "a6777d72-5925-5145-a977-2946a264d4c8",
    "entry": "倉庫",
    "reading": {
      "primary": "そうこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "storehouse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "倉庫は、街路に沿うて、並んで甲羅を乾していた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "前は、秋になると、大倉庫五棟に入り切れないほどの、小作米になる青田に向っていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自分から動く火吹き達磨のように、のたうちまわった挙句、船首の三角形をした、倉庫へ降りる格子床（グレイチン）の上へ行きついた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォアピークは、水火夫室の下の倉庫の、も一つ下にあった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水火夫室から、倉庫へ下りる事は、負って下りると云う方法で行われた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉庫から、ピークへは、「勝手に下りて貰う」より外に方法が無かった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、倉庫から、水火夫室へ上った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸壁が海の方へせり出して、その内側が陥没したので、そこに建て連ねた大倉庫の片側の柱が脚元を払われて傾いてしまっている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方のバックには構内の倉庫の屋根が黒く聳えて、近景に積んだ米俵には西日が黄金のやうに輝いて居り、左の方の澄み通つた秋空に赤や紫や色々の煙が渦卷き昇つて居るのが餘りに美しかつたから、いきなり繪具箱を柵の上に置いてＷＣの壁にもたせかけ大急ぎのスケッチをしようとした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の影には他の工場の倉庫らしい丹塗りの單純な建物が半面を日に照らされて輝いて居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝の此方に畫架を据ゑて對岸の榎と赤い倉庫と薄との三角形を主題にして描き始めた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこの灯の利益な点を挙げてみれば、第一前記のごとく室の隅にまで明るくなる故、倉庫の中などにこれを点ずれば、貨物の出し入れに暗さを喞つ心配はなくなる。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その設備のごときずいぶん大きなもので、例えばその倉庫には三十万貫に近い穀物を貯える事が出来る。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、電鈴が私の耳に亀甲町にある、綿花綿布倉庫会社の事業停止による賃金不払のため、従業員のストライキを報らせた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "商店の倉庫らしい建物の立ち並んだ、高い、じめじめした煉瓦塀の兩側から迫つた、二三間幅の道。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　倉庫にしまってある実弾を二人はひそかに持ち出した。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの品々は、一時、深沢洋行の倉庫の中で休息した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉庫の鍵を外套から氷の上へガチャッと落した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、倉庫に休んでいる品々を別の橇に積みこませた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きなまっかな張り抜きの唐辛子の横腹のふたをあけると中に七味唐辛子の倉庫があったのである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨にぬれた弁天島という島や、黒みかゝった海や、去年の暴風にこわれた波止場や、そこに一艘つないである和船や、発動機船会社の貯油倉庫を私は、窓からいつまでもあきずに眺めたりする。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御蔵橋これに架りて陸軍倉庫の構内に入る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景だと思っていたコンクリートの倉庫も見慣れると賤が伏屋とはまたちがった詩趣や俳味も見いだされる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鬱々として楽しまず、ついに立ってその着物を或る種の倉庫にあずけに行くのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは全部、むかし母から送られ、或る種の倉庫にあずけていたものを必要に応じて引き出して着ているのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、いずれも以前に母から送ってもらったものなのであるが、この二つだけは柄もこまかく地味なので、私は、かの街の一隅の倉庫にあずけずに保存しているのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、これを、あの倉庫に永いこと預け放しにして置いたのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが昨年の秋、私は、その倉庫の中の衣服やら毛布やら書籍やらを少し整理して、不要のものは売り払い、入用と思われるものだけを持ち帰った。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた浴衣は、汚れたままで倉庫にぶち込んでいたのだし、尻の破れた丹前も、そのまま丸めて倉庫に持参していたのだし、満足な品物は一つとして無いのだ。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで見ても、そうこの建物の震動は激烈なものでなかったことがわかる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
