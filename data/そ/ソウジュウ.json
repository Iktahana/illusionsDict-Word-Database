        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じ団体にはいってヘッベルの劇場の楽屋見学をしたときは、奈落へ入り込んでモーターで廻わす廻り舞台を下から仰いだり、風の音を出す器械を操縦させてもらったりした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、亀さんが鳥人になったらおそらく人並以上の離れ業を演じ得る名操縦士になったことであろう。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神の事である、山に棲めるほどのものを自由に操縦できないいわれはない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう飛行機の操縦をするいわゆる鳥人の神経は訓練によって年とともに次第に発達するであろう。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は緑の窓硝子を透いて地平線の彼方、数理的な朝の太陽に銅鑼湾の火薬庫の壁が傾いて見えるなかを、露国飛行家の操縦するらしい単葉機が空中に水のような光を発して広東の方角に引返して行くのを見た。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マツイがこの小型フォードを操縦する手並を想像してスマ子女史は愉快になっていた。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関銃の使い方も、野砲の使い方も、重砲の使い方も、また飛行機の操縦法も、戦車の操縦法も学ばなければならない。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれでは肝心の事故の第一原因はわからないのでいろいろ調べているうちに、片方の補助翼を操縦する鋼索の張力を加減するためにつけてあるタンバックルと称するネジがある、それがもどるのを防ぐために通してある銅線が一か所切れてネジが抜けていることを発見した。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教室の中では飛行機を操縦するまねや、活動写真の人殺しのまねばかりしてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安なら君操縦したまえ、君操縦出来る？",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショッファーと僕こっちに乗るから君ママを側へ乗せて操縦したまえ」　婦人を傍へ坐らせて操縦しながら青年は後の紳士に話しかける。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで宜い自動車を操縦させて頂きました。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と紳士はショッファーが自分の側の座席から操縦席へ戻った時いま一度青年達を呼び止めた。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "操縦席から下りたヘルメットの若い紳士を、社長は護謨園の経営主だと紹介した。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく君はひとりで操縦が出来るね。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "横須賀航空隊のＮ大尉とＳ中尉は、それぞれ陸上偵察機を操縦してＡ飛行場に向けて長距離飛行を行い、目的地に到著して機翼をやすめるひまもなく、直ちに帰還の途についた。",
              "citation": {
                "source": "空中に消えた兵曹",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「○○機が墜落しました」「なに、○○機が」　○○機は今までＮ大尉とともに練習飛行を行っていたＳ中尉の操縦していた飛行機であった。",
              "citation": {
                "source": "空中に消えた兵曹",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、これが大ぜいの若者たちを自由自在に操縦もし叱※もしたあの気嵩で美しく張のあった母かと、呆れもし暗涙に噎びながら、身震いが出るほど嫌味なものを感じますが、粗末にはできません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外へ出かける折りなど蓄音器を積み込んで交代に操縦して行った。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "●　三月の或日、一新聞紙上にクロイドン陸軍飛行場で英国婦人にも飛行機の操縦法を練習させると言う記事が載って居た。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴物としての鳴物、即ち一塲の始め終り、若くは押韻的要句等に際してのみ之を用ふる鳴物ならば、如何に複雑なりとも此は論外なれば妨げなし、唯だ舞台にありて活動する演者の技の上に大なる操縦の力を捉れるが如き今の鳴物の有様は、之を整合の弊と言はざるを得ざるなり。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方公卿の方にも、此等の粗野ではあるが単純な武家に対して、寛容さを欠いて居たし、之をうまく操縦する方略にも欠けていた。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さん一人を、操縦できないくせに、私のお姉さんを、どうかしようって、ムリよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで気の早い連中が機体によじ登って操縦席から機関室を探してみたがやはりいない。",
              "citation": {
                "source": "人のいない飛行機",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ人間の乗っていない飛行機が、操縦者でもあって操縦しているかのように悠悠と着陸したことであるから、人びとはまるで狐にでもつままれたように不思議がっていた。",
              "citation": {
                "source": "人のいない飛行機",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでぼくはしぶしぶべつのしごとにきめて、ひこうきのそうじゅうをおぼえた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターの、すきとおったそうじゅう室のとびらが開いて、明智たんていがおりてきました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "めいたんていは、ひこうきでもヘリコプターでも、そうじゅうできるのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智たんていは、小林くんのでんわをきくと、いそいで新聞社とうちあわせ、新聞社のヘリコプターを、自分でそうじゅうして、とんできたのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときのよういに、そうじゅう室には、小がたのサーチライトがそなえつけてあります。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
