        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは地中海で獲れる蝦で、塩茹にしてマヨネーズソースをつけて食べる。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理の献立を見てもソースのことをテウンケなどと書いてあった。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボリビアでは馬鈴薯に粘土のソースをかけて食う。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "残骸はスロウンソースと共に器械で血を絞られる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、ソースはどうしたらいいの？",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱とチーズを壺焼にしたスープ・ア・ロニオンとか、牛舌のハヤシライスだとか、莢隠元のベリグレット・ソースのサラダとか、彼がふだん好んだものを註文したので鼈四郎は慥え易かった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソースがわが家の自慢と来てゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近、ある化学的薬品を使えば、酢、醤油、ソース、いや酒までつくれるという簡単な醸造法の特許権を、安く買い取りました。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といっているうちに、女中はトマトにマイナスソースをかけたのと、蟹のコキールとを二皿持って来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い二つの皿には水っぽい新鮮なサラダの緑を、白い三つの皿にはやや薄黄のマイナスソースをかけた羊の蒸肉を盛ってあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親が給仕にソースを取ってくれと命ずると、おばあさんが意外にも敏捷に腕を延ばして、食卓のまん中にあったびんを取っておかみさんの皿の前へ立てた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＵＲＬ（ユニフォーム・リソース・ロケーター）は、その番地です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "策定チームは、小学校から高校までの教科書や、ＮＴＴ電話帳、地名に関する行政資料、現行法令、文部省学術用語集をはじめさまざまなソースをカバーして文字選定を進めていたが、文学に関しては、より広範な資料にあたってデータを取りたいと考えていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとてつもない大風呂敷を広げて、ＴＲＯＮチップの開発という大仕事に各社を引きずりだした風雲児坂村健の手並みには、３８６からはセカンド・ソース（これがどんな味のソースであるかは、次項で書く）を認めないというインテルの方針も有利に作用しただろうが、オレは実際肝をつぶした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "チップ界の松田聖子とでも言えばいいのかな、とにかくはでなエピソードだらけのサンダース率いるＡＭＤは、これまで思わず大笑いの奇抜な広告や超特大クリスマス・パーティなんぞで話題を集めてきたが、基本戦略は地味にセカンド・ソースにおいてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＸ８６を業界標準に据えることに成功したインテルは、誰もここから逃れられないと見るや３８６からはセカンド・ソースを置くことを拒否した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一九七六年にインテルと広範な技術の交換契約を交わしていたＡＭＤは、３８６の市場独占の打破を狙ってセカンド・ソース戦略を攻撃的なものへと一変させた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "８０２８６まではセカンド・ソースを置いていたインテルは、３８６からはこれをライセンスしないとした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまや私は決闘の時間だ、私に悠々閑々たるたたかひの時間を与へよ、いまや私は食事の時間だ、舞台の上のレストランだ、ビールはほんものだし、ブクブク泡の立つた奴だ、私はこいつをグイとひつかけて幾分酔ふ、滑稽なコロッケに憂鬱なソースをかけて喰ふ私の演技のこまかいところを買つてくれよ。",
              "citation": {
                "source": "小熊秀雄全集-5",
                "author": "詩集（４）小熊秀雄詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "例によって、映画館のすぐそばの中華料理屋でも、焼きそばを食べたい、という慶一に、カイリの呪いをかけて、三枚肉を柔らかく煮こんだものと、エビのチリソース炒めにしろと強制し、最後に、骨付き肉を唐揚げにしたものがのったラーメンを食べさせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさはスパゲティ・ミートソースだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生で好かつたら何でもあるぜ――」「キヤベツをむしつて、ソースをかけて喰べようか――」「キヤベツなら素晴らしいのがある！",
              "citation": {
                "source": "パンアテナイア祭の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "イワン・フョードロ※ッチは書物の話が出たなと思ふと、てれかくしに、せつせとソースを自分の皿へよそひ始めた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから詰め物をした鳩をソースに浸けたのだの……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼前にあるソースや辛の入物だの、ごちや／＼置べた洋酒の瓶だの、壁紙で貼りつめた壁だの、その壁にかゝる粗末の額、ビイルの広告などは、反つて私の身を置く場所に適しかつた。",
              "citation": {
                "source": "犬",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私台所で女中を手伝つてマヨネーズソースを自分で作りましたが、料理を作る女中がおりますから、なんでしたらその女中をよんで聞いて見ましようかしら」「いや、それではそのほうはあとできいて見ましよう。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またペーチカの床の上には、脂ぎつた肉のシチュー皿、鱈の耳のスープ皿、ハム、犢肉、松※の肉、粥、バタ、ソース等々が、ずらりと並んでゐた。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中での住所を示すのが、ＵＲＬ（ユニフォーム・リソース・ロケーター）だ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピューターの生産においては、セカンドソースの奨励という、いわば二番煎じを積極的に認める方針がとられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
