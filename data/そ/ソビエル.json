    "definitions": [
      {
        "index": 1,
        "gloss": "to rise (of a building, mountain, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕暗に聳える恵那山は真っ白に雪を被っていた。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際の籐椅子に腰かけて、正面に聳える六百山と霞沢山とが曇天の夕空の光に照されて映し出した色彩の盛観に見惚れてゐた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際の籐椅子に腰かけて、正面に聳える六百山と霞沢山とが曇天の夕空の光に照らされて映し出した色彩の盛観に見惚れていた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤丸平家に帰ってからもいたずらに空中に聳える時計台の白い針のみが部屋の窓に侵入して私をいらいらさせた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秋」は濃茶の色に二三株のさび赤んだ杉の梢が山のはざまに聳えるところである。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中、公孫樹は黄なり、紅樹、青林、見渡す森は、みな錦葉を含み、散残った柳の緑を、うすく紗に綾取った中に、層々たる城の天守が、遠山の雪の巓を抽いて聳える。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小名木川口の上に聳える国技館の大きな丸屋根。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕の霧の中から浮び上る丘々や、その上に屹然として聳える古城郭から、遥か聖ジャイルス教会の鐘楼へかけての崎嶇たるシルウェットが、ありありと眼の前に浮かんで来た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、地上には無限に肥った一人の成人と、蒼空まで聳える轢殺車一台とが残るのか。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉や松の大木は天に聳えるものもある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、川の左に聳える荒削りされたような山が、山国川に臨むところで、十丈に近い絶壁に切り立たれて、そこに灰白色のぎざぎざした襞の多い肌を露出しているのであった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　聞えて来た方角は鎮守の森の奥の、こんもりと空高く聳える木立ちに囲まれた、社殿のうしろと覚しきあたりです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ僅に残つて、今に聳える天主閣の正しい均斉、その高欄をめぐらし、各層に屋根をつけた入母屋作りの甍、その白堊の城。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、松の樹はどうだ、雨風に打たれながら老い寂びて高く聳える樹の姿を想ひ浮べた。",
              "citation": {
                "source": "蠅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に聳える氷河の峰々。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから其｜光の細くなつた先の方に、高く聳える目白台の森を見上て見る。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな、空に聳える樅の樹と、庭に吊した駕籠とが古めかしい家柄を語るように名残を止めていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして川べに聳える比叡尾、日熊、高谷の山々がまたこの川の美しさに応えるように秀でた姿をしている。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、輪太郎の怪塔は有りや無しやと仰いで見れば、あったぞ、あったぞ、夜目にも屹然と聳える見覚えある高塔――窓についた灯も、この前見たとおりだった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "右からは二千五百万人の失業者を含む勤労階級の攻勢に押され、左に彼等の敵として聳えるソヴェト同盟に圧され各国のブルジョア支配者たちは、死物狂いになって来た。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽の明るみが何時か消えて、西岸に聳えるプロスペクト山の頂に見馴れた一つ星が青白く輝き出すと、東の山の端はそろそろと卵色に溶け始めます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも吃水の深い貨物船がすっかり積荷を終って、果しない船隊が春の流水と一緒に、一列縦隊で出帆するまでは、少しはなれた広場一帯には、まるで砲弾でも積みあげたようなピラミット形の袋の堆積が見え、穀物の山が聳えるように姿を見せているのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲穂の実り豊かに垂れている田の彼方に濃藍色に聳える山山の線も、異国の風景を眼にして来た梶には殊の他奥ゆかしく、遠いむかしに聞いた南無阿弥陀仏の声さえどこからか流れて来るように思われた。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宗麟や千鶴子の信じたカソリックのふるさとの、フィエゾレ聳える西方の国国も、矢代は見て来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の中央には、九州地方第一の高山、宮の浦岳、一九三五｜米が聳える。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その高く聳える円屋根にはイルミネーションが飾られ、それがすぐ前の川の水に映っていた。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの崖に亭々と聳える松の枝は、無言でゆれている。",
              "citation": {
                "source": "※の囁き",
                "author": "――肺病の唄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の新しい赤煉瓦の会堂の、青空に聳える渋紅い尖塔、大理石の石柱の重厚さと雄渾さ、窓の色硝子に映る日光のゆらぎの美しさ。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の心は透明になつて空中に聳える高い富士やその他の山々の姿を恐ろしく感じた。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラリーメンの洪水のために死骸のような建物の堰が破られて、空にそびえる高楼の窓が花のようにひらくと、女事務員の青と赤の色彩が花粉の媒介の役目をした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
