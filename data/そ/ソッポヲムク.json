        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勝手にしやがれと、そっぽを向くより致し方がない。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "客商売である帳場の者はもちろんこういう時の心得は知って居てそっぽを向く。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒ったようにそっぽを向く女もあった。",
              "citation": {
                "source": "無法者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことを話しかけても、なぜ誰もそっぽを向くんですか。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浩平はおっかぶせるように叫んで塚屋をにらみ、それから、ぷいとそっぽを向く。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のほうもまた、人間のすぐれた美しさに比べて、男を嫌ってそっぽを向くかもしれないし、男を捨てるかもしれない。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "とそっぽを向くと、こめかみに貼った頭痛｜膏が、これ見よがしに栄三郎の眼にはいる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそっぽを向くと、もう如何なる質問にも唖のように沈黙した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現代人は、とくにこの文壇人は、とかく宗教に対してこの意識に対して、そっぽを向くんです。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "千両富なんぞが、私たち風情のところへ……」と、相手にしないで、そっぽを向く。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、友田に気がねする者、組合の外にあって仕事を狙う野心家、組合の必要性に、まったく理解と関心とを持たない無知な者、などであったが、聯合組自体の中にすら、新参者である玉井金五郎の擡頭を快く思わず、そっぽを向く者があった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察から呼び出しがあっても、おれは関係がない、かつ子はおまえの姪だ、と云って京太はそっぽを向く。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の方で懐しがって近寄って行くと、相手は忠臣蔵の師直の様に、ついとそっぽを向くかと思われた。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはどちらへ」　ルダンさんは光太郎の手提鞄をじろりと見てそっぽをむくと、「きまってるじゃないか。",
              "citation": {
                "source": "黄泉から",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
