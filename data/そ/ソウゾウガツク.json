[
  {
    "uuid": "6d2b451d-9a92-5a12-91e9-635e49ff661f",
    "entry": "想像がつく",
    "reading": {
      "primary": "そうぞうがつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-カ行"
      ],
