    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be imaginable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は芭蕉の俳句中でひらひらと上る扇や雲の峯　を第一等の名作として推賞してゐたが、上例の如き自作の句を観照すると、芥川氏の芭蕉観がどのやうなものであつたかが、およそ想像がつくであらう。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ていると当時の地盤の揺れ方がおおよそどんなものであったかという想像がつくような気がした。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お前たち、その頃、おかあさんが、どんな男でゐたか想像がつくか。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしにも大概、事の成行の原因に就ては想像がつくけれども、しかし、念のためあなたの口で一応説明して呉れない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の頭脳のたよりなさはこの一例からでもおおよそ想像がつく。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちにもたいていは想像がつくだろう。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし従軍作家の顔ぶれを見ると、消費文学の作家丹羽文雄氏のやうな、又それと類型の作家が参加してゐるのは、自ら戦地お土産の如何なるものであるかといふことは大体想像がつく。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後になったと思うまもなく、どんどん暮れかかる北海道の冬を知らないものには、日がいち早く蝕まれるこの気味悪いさびしさは想像がつくまい。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君にはちょっと想像がつくまい。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は十七歳で父が二十四歳で、彼等は熱烈に恋し合つてと云ふ噂だが――然し多分母の方はそれ程でもなかつたらう、純七郎の容貌に比べたら彼女の方が数等優つてゐたであらうことは、現在でも一見して想像がつく――十七歳の母を想像すると、私は極めて快い幻に恍惚とする……私は様々な情景を想像した。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、あんたがもう少し利口だったら、妾がドルガンに何んな事をしたか想像がつく筈よ。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなれば後はどんなことになるか君にも容易に想像がつくだろう」「ウーム、貴様という貴様は……」　と、首領は全身をブルブル震わし、銃口をグイグイと帆村の肋骨に摺りつけたが、引金を引くと一大事となるので、歯をギリギリ云わせて射撃したいのを怺えた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "の記述は省くが、あの「親不孝な男」を読んだ人にだけは想像がつくかも知れない。",
              "citation": {
                "source": "冬の風鈴",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからどんなことが行われたかは、皆さんにもほぼ想像がつくと思いますから、詳しくは申しません。",
              "citation": {
                "source": "塵埃は語る",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "といえば、大てい皆さんにも想像がつくだろうと思いますが、頭髪には一本の黒い毛もなく、顔には深い皺が縦横に刻まれて居て、どことなく一種のすご味がただよい、いわば、神々しいようなところがありました。",
              "citation": {
                "source": "血友病",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文句は庸三にも大抵想像がつくので、わざと見ぬふりをしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その騒然雑然たるさまはとても世間の人たちには想像がつくまいとおもう。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のわけでどうなったかと推理してゆくことができずに、ただ騒いでいる時、浮舟の秘密に関与していた右近と侍従だけには最近の姫君の悲しみよう、煩悶のしようの並み並みでなかったことから、川へ身を投げたという想像がつくのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "蜻蛉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それが実に穿った表現であったことは、その百姓の姿がもう疾っくに見えなくなってしまい、馬車がずいぶん先きへ進んでからまで、チチコフがまだ馬車の中で独りクスクスと笑っていたところから容易に想像がつくだろう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　常人にとっては、狂人は異常であるが、狂人にとっては、常人がみな異常に見えるであろうことは、たやすく想像がつく。",
              "citation": {
                "source": "奇怪な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがたんなる巨大な渦雲にすぎないということは、ただその一言だけでも容易に想像がつくことだ。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、村松正俊氏がギリシア語の用で来訪、玄関に入ると鼻を突くヘアトニックの香と春帽の鼠色と靴の様子で、大体の風采の想像がつく。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、伊勢湾に集合した艨艟を見たら、およそ想像がつくだろう。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜木林をチヨビチヨビ並べて一と筋につらなる村々の低空に、遠眼にもてらてらと白い艶を放して田打櫻の咲く見事さは、奧の日本を未だ知らぬ人には想像がつくまい。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』この答が私にとって、さらにまた意外だったのは、大抵御想像がつくでしょう。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぼ前途の想像がつくからである。",
              "citation": {
                "source": "鴎外を語る",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼等が小六の事に關して取つた態度に就て見ても略想像がつく。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、此も「……雨欲しやに、水欲しやに、おぼつ通ちへ、かぐら通ちへ、にるやせぢ、かなやせぢ、まきょにあがて、くたにあがて……」などあるのを見ると、此語のなりたちも、大体は想像がつく。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう男に対して、僕がどんな感情を懐いたか、君にも想像がつくだろう。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山男のようなきこりが、気をうしなうほど驚いたというのですから、いかにおそろしいできごとだったか、そうぞうがつくではありませんか。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
