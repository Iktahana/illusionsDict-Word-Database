    "definitions": [
      {
        "index": 1,
        "gloss": "in the meanwhile",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
