        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……だって先生がそう言ったよ、六さんは空を飛ぶつもりで天主台の上から飛んだのだって。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅を右に出ると、もう心細いほど、原野荒漠として、何とも見馴れない、断れ雲が、大円の空を飛ぶ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき須利耶さまの愕ろきには、いつか雁がみな空を飛ぶ人の形に変っておりました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（魔の睫毛一毫の秒でしたわね、）浪を行く魚、中空を飛ぶ鳥に、なごりを惜むものではありません――流星は宇宙に留っても、人の目に触るるのはただ一度ですもの、と云って、……別れました。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　空を飛ぶ――火事の激しさに紛れた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士　こりゃ、地獄の門を背負って、空を飛ぶ真似をするか。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を飛ぶ仲間では、鷲、鷹、みさごぐらいなものか、餌食を掴んで容色の可いのは。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に搖れるフラフ、または空を飛ぶ鳥を見るやうな心地で、冷々として看過した。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったんちかったことは、かならずやりとげてみせる」　王さまは、今度は、七年もかかって、空を飛ぶための船を作らせました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当に、」と勝太郎は素直に首肯いて、「人間も鳥のように空を飛ぶ事が出来たらいいと思う事がありますね。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」丹三郎はせせら笑い、「空を飛ぶ必要はないが、」駕籠に乗りたいのだ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空を飛ぶ必要はないが、｣とまた繰返して言い、「眠りながら歩く、という事は出来ないものかね。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿たちの空を飛ぶ鳥は、私等が足の下を這廻る、水底の魚が天翔ける。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……和郎たち、空を飛ぶ心得があろうものを。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "西諺に、空を飛ぶ鷲と、岩を這ふ蛇と、大海を渡る船と、男が入れた此四つの跡は知れ難いとは十分の道理あり（Mouchot,‘Dictionnaire de l'Amour,’ Troyes, 1811, p. 21）。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "後は御存じの通り、空を飛ぶような心持で、足も地につかず、夢中で手を曳合って駈出した処を、あっと云う間もなく、終汽車で刎飛ばされた。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士　こりや、地獄の門を背負つて、空を飛ぶ真似をするか。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を飛ぶ仲間では、鷲、鷹、みさごぐらゐなものか、餌食を掴んで容色の可いのは。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲をつかむ尋ね物というが、これは空を飛ぶ尋ねものである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を飛ぶ神の白絹の御衣のお裾に触れて散るのである。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一三三〇年頃仏国の旅行僧ジョルダヌス筆、『東方驚奇編』にいわく、エチオピアに竜多く、頭に紅玉を戴き、金沙中に棲み、非常の大きさに成長し、口から烟状の毒臭気を吐く、定期に相集まり翼を生じ空を飛ぶ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年　空を飛ぶ鳥でもかならず射落します。",
              "citation": {
                "source": "蟹満寺縁起",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "久米の仙人は空を飛ぶものの用意として、雀のやうに質朴な考へを持たなければならない事も知つてゐた。",
              "citation": {
                "source": "久米の仙人",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "首領が改めて僕の姿を探し求めたときには、僕は同志林田と共に、上海の上空を飛ぶ飛行艇の内にあった。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この神丹を服用すると、その人はいつまでも不老不死で、そしてまた生身のままで鳥のやうに空を飛ぶことが出来るといふことだつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この神丹を服用すると、その人はいつまでも不老不死で、そしてまた生身のままで鳥のやうに空を飛ぶことができるといふことだつた。",
              "citation": {
                "source": "春の賦",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を飛ぶ鳥がいきなり大気の波動にまかれて、後から後から落ち始めた。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空を飛ぶ人工の翼こそは、まことに現代を象徴するものの一つであらう。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動場であるベース・ボールの練習も、空を飛ぶ球の動きも、廊下から見物するものを直に飽きさせた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
