        "examples": {
          "standard": [
            {
              "text": "外交交渉において、自国が相手国に与える権利を自国民にも求める相互主義が適用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ビザの免除措置については、相互主義に基づき相手国の対応を見て判断することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国際法上の相互主義を理由に、同等の対抗措置を講じることが発表された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "然るに個人の社会的覚醒が発達し、政治にも産業にも学問にも分化（分業）作用が行はれるにつれて、強権的刑罰法が吾々の日常生活に干渉することは漸く減少し、之に反して協同主義的或は相互主義的法規が益々多く広く吾々の生活を規定するやうになつた。",
              "citation": {
                "source": "社会的分業論",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人の自由は相互主義の道徳によつてのみ保持されるのである。",
              "citation": {
                "source": "社会的分業論",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
