          "standard": [
            {
              "text": "刑事が玄関先で「捜査令状だ」と宣告し、拒む容疑者を押し退けて家宅捜索を開始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裁判所から捜査令状が出るまでの間、捜査員たちはパトカーの中で容疑者の自宅を監視し続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "捜査令状には、差し押さえるべきパソコンやスマートフォンのリストが具体的に明記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "押鐘博士に召喚状を出す事と、もう一つは、予審判事に家宅捜査令状を発行してもらう事なんだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
