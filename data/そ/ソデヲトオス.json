        "examples": {
          "standard": [
            {
              "text": "急いでいたので、コートにさっと袖を通した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいスーツに袖を通す時、彼は特別な気持ちになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お待たせしました」と言って、彼女は丁寧にワンピースに袖を通した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一つこれを着て下さい」といって、岡倉氏は自分でその服をひろげ、強いて私を起たして背後から着せてくれましたが、袖を通すと、どうも妙なもので私は驚きました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "学校へ奉職した前後のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いうちに袖を通すべきぴかぴかする反物も彼の心のうちにあった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれに袖を通すときの黒羽二重の冷たさが今からおもいやられている。",
              "citation": {
                "source": "紋付を着るの記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
