          "literary": [
            {
              "text": "カードに穴をあける穿孔機（パンチ）、穴によってカードを仕分けする分類機（ソーター）、そしてカードに記録されたデーターを計算処理する作表機の三つの要素からなるパンチ・カード・システムを、ＩＢＭはレンタル制で供給し、保守やカードの販売でも収益を上げていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、ソータン小壜を三分の二ほど飲み、ほろ酔ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂へ、ソータン小壜、一本あけ、色々食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
