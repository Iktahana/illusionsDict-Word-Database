        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その機械は、やがて送信所に据えつけられ、全世界へ向って電波を出し始めるであろう。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壕の一番奥は送信所になっていて、発電機とか送信機がごちゃごちゃ置いてある。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "送信所に到る通路が、いわば居住区の形で、寝台や卓子が並んでいた。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉良兵曹長は急に横をむくと、送信所の方に急ぎ足で入っていった。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
