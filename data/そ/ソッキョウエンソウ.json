        "examples": {
          "standard": [
            {
              "text": "ライブハウスでは、毎晩のように即興演奏が繰り広げられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の即興演奏は、聴くたびに新しい発見がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "音楽学校では、即興演奏の授業が人気を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それらの無考察な即興演奏は、意識の眼をのがれてるものであり、あたかも動物の叫びのように、思想からよりもむしろ肉体から迸り出たものであって、魂の不平衡、未来の深みの中で準備されてる雷鳴を、示しているように見えた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショパンとサンドとの最初の会合は、リストの茶会であったとも言われ、ショパンが即興演奏を試みたとき、ピアノに凭れて熱心に聴き入る、大きな燃える眼であったとも伝えられている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十分間ばかり即興演奏を試みた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や彼らは照応の曲を即興演奏しはじめていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
