    "definitions": [
      {
        "index": 1,
        "gloss": "former visit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "園が曾遊の地であつた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが曾遊の地に來たる樂しさをば、君もおもひ遣り給へといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一窓の風雨、曾遊の跡をたどりて、記して同好の士に示すもの也。",
              "citation": {
                "source": "東京の近郊",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾遊の蹤を辿りて、丸屋にやどる。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分にとって生涯関係のありそうにもない土地の紀行など興味もなし、読んで見たところで全然知らぬ土地が生き生きと感ぜられるような筆は稀だし、あるなつかしさから曾遊の地に関したものを読むが、それはまたこっちが知っているだけにアラが眼につく、そういうのが共通の意見であるようだった。",
              "citation": {
                "source": "黒猫",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィスの山は我々にも曾遊を思ひ起させる際やかさをもつて描かれてゐて無限の懷しさを感ぜしむるのであるが、スコットランドと同じ日本の高原地との比較にも別種の興味が湧いて來る。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏亭氏はこれは殆んどイギリス湖水地方の風景と同じだと云つて、ダアエント・ヲオタアを見物した曾遊の話をした。",
              "citation": {
                "source": "道學先生の旅",
                "author": "戸川秋骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この邊は私一個としては曾遊の地で、この河口湖の横斷も嘗て試みた處であるが、恁ういふ靜かな渡し船は幾度くりかへしても快いものだ。",
              "citation": {
                "source": "道學先生の旅",
                "author": "戸川秋骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は既に曾遊の跡を忘れてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東叡山看花」の絶句に、「劉郎不復曾遊態、扶病漫追芳候来」の句がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬助は諸国を遍歴して、偶然茶山の曾遊の跡を踏んで行つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもＡ川の上流が、七八里余り渓山の間を流れつづいて、べつだん村落が展けるでもなく、両岸には蒼潤の山が迫り、怪石奇巌｜駢び立つて、はげしい曲折の水が流れては急渓、湛へては深潭――といつた具合で、田山先生も曾遊の地らしく、耶馬渓などおよびもつかない、真に天下の絶景であると言つてゐられた。",
              "citation": {
                "source": "故郷に帰りゆくこころ",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "亂後曲江　　　　　王駕憶昔曾遊曲水濱未春長有探春人遊春人盡空池在直至春深不似春（憶ふ昔し曾て曲水の浜に遊ぶや、未だ春ならざるに長へに春を探るの人有りしに、春に遊ぶの人尽きて空く池在り、直ちに春の深きに至りて春に似ず。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "惆悵我歸君未復　　惆悵す我帰りしも君未だかへらず、不知與誰話曾遊　　知らず誰と共にか曾遊を話せむ。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "片隅に柿浸されし上つ毛の古笹の湯の思はるる秋　静かに病床に横たはる長い病人が、大分薄れた意識で曾遊の地を思ひ出す場合、印象の強く残つたものだけが浮び上つて来ることだらうと推定される。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆくてに高きは、曾遊の八ヶ岳――その赤岳、横岳、硫黄岳以下、銀甲つけて、そそり立つ。",
              "citation": {
                "source": "雪の武石峠",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍れる朝を長野にいって、Ｋを驚かし、やまやという感心もせぬ旅宿に昼餐したため、白馬山におくられ、犀川よぎり、小諸のあたり浅間山を飽かず眺め、八ヶ岳、立科山をそれよと指し、落葉松の赤きに興じ、碓氷もこゆれば、曾遊の榛名、赤城の山々は、夕の空に褪赭色ににじんでいた。",
              "citation": {
                "source": "雪の武石峠",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ、僕と親しい中川紀元氏が、その闊達自在な筆を以て、曾遊の地朝鮮の「色」を出してくれることになつた。",
              "citation": {
                "source": "内村直也君の『秋水嶺』",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾遊の地ではあり、さまざまな印象が空想の手がかりになつてゐることはたしかだが、人物の一人一人に、実在の誰彼の面影はさらにないのである。",
              "citation": {
                "source": "「歳月」前記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏領印度支那は曾遊の地であり、「牛山ホテル」は一字だけ変へた実在の旅館であり、登場人物のいくたりかは完全なモデルといふほどではないが、例の植民地的な風貌をもつたそれぞれの典型をとらへたつもりである。",
              "citation": {
                "source": "「風俗時評」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾遊の夏の山水風光を、かうして今都會の中にゐて追憶して見るさへ懷かしさに堪へないで、魂飛び神往くの思ひがするのである。",
              "citation": {
                "source": "箱根の山々",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "この入院中、病院の先生たちをムリにひッぱりだして、曾遊のパンパン街へ酒をのみに行った。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、駒井にとっては、この地は曾遊の馴染があって、その当時、藩の要路にも充分の懇意があったものですから、相当の気安さで旅行もできるし、また石巻、松島、塩釜、仙台の間は、通学の往復路のようなものでしたから、少し立入れば、今でも顔馴染がいくらもある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな山村の夜――河水の氾濫を避けてこの高原の裾へ移住したという家々――風雪を防ぐ為の木曾路なぞに見られるような石を載せた板屋根――岡の上にもあり谷の底にもある灯――鄙びた旅舎の二階から、薄明るい星の光と夜の空気とを通して、私は曾遊の地をもう一度見ることが出来た。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧い橋本の家は、曾遊の時のままで、未だ彼の眼にあった。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのために、わたくしは今年昭和十一年の春、たまたま放水路に架せられた江北橋を渡るその日まで、指を屈すると実に二十有二年、一たびも曾遊の地を訪う機会がなかった。",
              "citation": {
                "source": "放水路",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが或日偶然六阿弥陀詣の旧道の一部に行当って、たしかにそれと心付いたのは、この枯れかかった桜の樹齢を考えた後、静に曾遊の記憶を呼返した故であった。",
              "citation": {
                "source": "放水路",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "啻に曾遊の地を愛したのみではあるまい。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治や森永なども皆試験部とか研究室を持っているが、中村屋としても、そうゆう意味で、研究室を設けて、材料の吟味、出来上がったお菓子の検査、新しい製品の企画、研究をやっている。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうゆう意味で、他の店で私のところの製品の真似などをして作って売り出しても、ちっとも怖しくない。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
