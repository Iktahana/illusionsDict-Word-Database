[
  {
    "uuid": "81f6af43-c3f5-58bf-8f29-0a35fd93b84a",
    "entry": "素読",
    "reading": {
      "primary": "そどく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
