      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reading (a text) aloud without trying to understand it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしヘルンは、素読される書物の記事には、何の興味も持たなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "習字と漢籍の素読と武芸とだけで固めた吾等の父祖の教育の膳立ては、ともかくも一つのイデオロギーに統一された、筋の通り切ったものであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手習いの傍、徒士町の會田という漢学の先生に就いて素読を習いました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる際にお花と源造に漢書の素読、数学英語の初歩などを授けたが源因となり、ともかく、遊んでばかりいてはかえってよくない、少年を集めて私塾のようなものでも開いたら、自分のためにも他人のためにもなるだろうとの説が人々の間に起こって、兄も無論賛成してこの事を豊吉に勧めてみた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "例年の通りに、お茶の水の聖堂で素読吟味が行なわれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "素読吟味というのは、旗本御家人の子弟に対する学問の試験で、身分の高下を問わず、武家の子弟が十二三歳になると、一度は必ず聖堂に出て四書五経の素読吟味を受けるのが其の当時の習慣で、この吟味をとどこおりなく通過した者でなければ一人前とは云われない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを受け取った何十人、年によっては何百人の男の児が、当日打ち揃って聖堂の南楼へ出て、林図書頭をはじめとして諸儒者列席の前に一人ずつ呼び出され、一間半もある大きい唐机の前に坐って素読の試験を受けるのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわせてその性質や行状をたずねると、彼は五歳から手習いを始めて、七歳から大学の素読を習った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "素読吟味のときにきっと仕返しをするぞ」　玄関へ転げ込んだ大三郎の顔色はまっ蒼であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの子供たちはみな来月の素読吟味に出るのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "大津は梅子の案内で久しぶりに富岡先生の居間、即ち彼がその昔漢学の素読を授った室に通った。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父様のお仕込みで、小学校入学前に四書の素読が一通り済んでいた私は、その振仮名無しの新聞を平気でスラスラと読んだ。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは書物を読んでも、文意も解らずただ声を出して読む素読であり、字を書いても手本を書き写すだけのものであるが、それが身体が大きくなり心が発達して成人となると、意欲が出て、智慮も盛んになって来る。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一意意味もわからず、素読するのであるが、よく母から鋭く叱られてめそめそ泣いたことを記憶している。",
              "citation": {
                "source": "私の父と母",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問はない方の人で、四書の素読くらいはやったのだろうが、ついぞ漢学なり国学なりの話をしたことがなかった。",
              "citation": {
                "source": "私の父",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また余の叔父なる人にも就きて素読を修めり。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢学の素読の仕方がまた非常に可笑しかつた、文章軌範の韓退之の宰相に上るの書を其時分我々は読んで居つたが、それを一種｜可笑しい、調子を附けずには何うしても読めぬので、それが始まるといつも教場を賑はすの種とならぬ事は無かつたのである。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は町の役場に出るようになったのでよしたが、三年前までは、町や屋敷の子弟に四書五経の素読を教えたものである。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの先生は漢那大佐の外戚の叔父に当る玉那覇某という人であったが、私達はこの人から始めて「大舜」という素読を習った。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二、三年の間、ここで四書の素読を習った。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪なども長くして、それを紫の紐で束ねて後へ下げ、古い枝ぶりの好い松の樹が見える部屋で、幼い藤村に「大学」や「論語」の素読を教えた。",
              "citation": {
                "source": "藤村の文学にうつる自然",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その漢学者からは捨吉もまだ少年の時分に詩経の素読なぞを受けたことのある人だ。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの先生に就いて、いわゆる四書の論語と孟子と中庸と大学との素読を終えた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が九つの歳に東京へ出て来た時、初めて身を寄せたのはこの人の家であって、よくこの人から漢籍の素読なぞを受けた幼い日のことを思出すことが出来る。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は学校の書籍を習うよりも前に、父が自身で書いた三字文を習い、村の学校へ通うように成ってからは大学や論語の素読を父から受けた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような読書の仕方は、かつて先ず四書五経の素読から学問に入るという一般的な慣習が廃れて以後、今日では稀なことになってしまった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "習字や素読さへも、最初は兄に、後には姉婿に教はつたのみであるから、教へるはうも不規則、習ふはうは尚ほの事、互ひに気儘や我儘が勝つので、厳しく叱られて泣面になつたことの多い割合には、習ふことが身に沁みず、只ぶら／″＼と月日を過し、閑さへあればたわいもない、くだらん本ばかり読み耽つてゐたものである。",
              "citation": {
                "source": "十歳以前に読んだ本",
                "author": "――明治四十五年六月『少年世界』の為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃目に触れた本で、今尚ほおぼえてゐるのは、第一に『実語経』、『孝経』、『大学』、『論語』、無論、これらは厭々素読を教はつたばかりだが、何百度と読まされたので、文句には今なほ微かに其頃の記憶が残り、『実語経』だけは粗ぼ意味も解してゐたと思ふ。",
              "citation": {
                "source": "十歳以前に読んだ本",
                "author": "――明治四十五年六月『少年世界』の為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そを如何にと尋ぬるに自分は幼少の時より学校へも行き多少漢書の素読もなしたるが、其時分より読書を面白いと思ふたことは一度もなく、随て帰宅の後復習したる例もなし、現に観山翁に孟子の素読を学ぶ時なりけん、翁は自分に向ふて余の幼時は汝の如く不勉強にはあらざりしよと宣ひたるを八九歳の子供心にも記憶し居れり。",
              "citation": {
                "source": "読書弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
