[
  {
    "uuid": "c07960e0-67eb-5c0c-963e-da9f80dfd682",
    "entry": "素子",
    "reading": {
      "primary": "そし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
