    },
    "definitions": [
      {
        "index": 1,
        "gloss": "element (esp. component in electronics)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "両者が共にお世話になっているマイクロコンピューターは、半導体素子にマシンの頭脳をまるごと作り付け、大量生産できる部品にしてしまったものだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは一つの写真面を、小さな素子に走査して、電流に直して送りだすのだ。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は一九二八年に書いた「風」の中でそれについて、素子にこういう意味を云わしている。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピュータの回路上に置かれる記憶用の半導体素子のうち、書き込んである情報を読みだすだけのものを指す。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気のコンピューターへの取り組みは、一九五四（昭和二十九）年ごろから始まった、論理回路用の素子に関する基礎的な研究にさかのぼる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このころ東京大学理学部で電子計算機に取り組んでいた高橋秀俊の研究室に入った後藤英一は、新しい論理素子を考案して注目を集めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁石を作る素材として広く使われていたフェライトを利用したこの素子は、パラメトロン★と名付けられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この研究室のテーマに知恵を絞っているとき、オキサイドコアの性質が素子として利用できるのではないかと閃いたという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方でトランジスターに比べるとスピードが上がらないという欠点もあったが、一時期パラメトロンは真空管に代わる次世代の素子の有力な候補と目された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この専門セクションではさらに、もう一つの次世代素子の候補であるトランジスターを用いた機種の開発も進められた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "次世代素子のもう一つの候補であるトランジスターには、電気試験所（通産省電子技術総合研究所の前身）が開発を終えていたＭＡＲＫ※の技術をもとに、開発作業に着手し、一九五八（昭和三十三）年の九月には早くも、ＮＥＡＣ―２２０１と名付けたトランジスター型の第一号機が動きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五〇年代後半、コンピューターの素子は寿命の短い真空管から、半永久的に使えて処理速度も高いトランジスターへと移り変わっていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい素子としてのトランジスターの実用性確認と、大容量の磁気コアメモリーのテストを公式な提案理由としてかかげたＴＸ―１プロジェクトを、研究所の上層部は却下した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターの論理回路は、命題論理学の演算をエレクトロニクスの素子によって実行させたものである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分野を専攻して以来、さまざまな素子をはんだごてを使って一つ一つつなぎ合わせ、石田は実験用のコンピューターをいくつも作ってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレクトロニクスの魅力に引きずられて、真空管からトランジスター、ＩＣと素子の変化を体験してきた松本にとって、マイクロコンピューターはあくまでデジタルＩＣにすぎなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "平素子供達のことは多く妻に任せきりで、余り気にかけない私ではあるが、父母のことを思う時だけは、ただ子供達のことばかりが頭に浮んでくる。",
              "citation": {
                "source": "父母に対する私情",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一昨日の宵からきょうまでの間は、ぼっとなってい、朝子に思い出せるのはその間に一度いつだったか素子に抱きおこされてベッドの上で何かのスープをのまされたことだけである。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "待っていた電報であり、待っている間の落着かなさから、その午後も素子と二人きりで草臥れるほど遠くの原っぱの方へまでも行ったのであった。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝子は無言のまんま、一足おくれに食堂を出て来た素子にその電報をつきつけるように渡した。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひき搾られるような朝子の顔つきに駭いて素子が電報に目を落した。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙で顔をよごした素子が、ああいい、わかってる、わかってる、と云いながらベッドに入れた朝子のまわりをきつく掛けものでつつんだ。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足許のドアがそっと開いて、素子が入って来た。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがとう」　その昼、朝子はすこしおくれて素子に扶けられながら食堂へ出た。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒沢の奥にあった素子と二人住の家を畳んで、本をつめたビール箱を、佐々の家へ運んで来た。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配してさがしに来た素子の手を握りしめて、朝子はきれぎれに云った。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝子と素子とヴェルデル博士と三人で、二｜哩ばかりはなれた野の中に建っている廃寺へ壁画を見に行って、ぐるりとその堂の裏手へまわったら、思いがけない灌木の蔭でその技師とエレーナと腕を組み合った散歩姿で来るのに出くわした。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月初旬の日曜で、表側の朝子の部屋は人通りがうるさく、素子の室で、朝子は読み終った分から一枚ずつ書簡箋を素子にまわした。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕舞の一枚を素子に渡してしまうと、朝子は沈鬱きわまる相貌で、窓の前まで枝垂れて来ている中庭の楓の葉の繁りに凝っと目をやった。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヒステリーは現実よりも表現を名称を吟味したがるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
