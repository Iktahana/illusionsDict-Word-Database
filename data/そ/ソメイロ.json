        "examples": {
          "standard": [
            {
              "text": "この着物の染め色は、落ち着いた紺色で上品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、季節に合わせて染め色の違うスカーフを使い分けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝統的な染め色は、見る人の心を和ませる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "時服一と揃えとあれば、その反物の名柄から染め色、原価と売価、仕立て賃などまで問い詰めるので、要屋主従はたちまち返答に窮した。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど高価なよい品だった、妹の好みらしく、染め色も縞柄もおちついた、ひんの良い選みで、少しはでだというほかには難のない支度である、すっかり着付け終ると、晋太郎はおどろくほどおとなびて凛々しくみえた。",
              "citation": {
                "source": "菊屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
