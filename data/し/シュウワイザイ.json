        "examples": {
          "standard": [
            {
              "text": "彼は、**収賄罪**で起訴され、懲役刑が科せられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政治腐敗の根絶のため、**収賄罪**に対する罰則強化が議論されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "贈賄側だけでなく、**収賄罪**を犯した側も厳しく罰せられるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「収賄罪にならんかネ」　木介はキゲンをなおして乾杯した。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には同じく政治上の確信犯だと云っても、例えば之が左翼の諸事件の主人公達だったとすると、「社会の通念」から云って、収賄罪の主人公達よりも、もっともっと社会的に虐待されることは当然なことなのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
