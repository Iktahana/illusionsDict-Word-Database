          "literary": [
            {
              "text": "小満の季節らしく、三味線の音のようなものが遠くから聞えて来る。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「小満四月、中の節。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "参考までに、うなぎ屋としての一流の店を挙げると、小満津や竹葉亭、大黒屋などがある。",
              "citation": {
                "source": "鰻の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは柳枝さんの元のお神さんの小満之助という音曲師が大阪から帰って来て、三代目｜都々逸坊扇歌となった。",
              "citation": {
                "source": "初看板",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに鉱毒被害深さ八九寸より三尺に渡り候田圃には、さらに陽気の立ち登るを見ず」二月の啓蟄、三月の穀雨と読みたどって、「小満四月、中の節。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
