  {
    "uuid": "4bea9cee-b87f-56b7-9ae5-5c15ca424e82",
    "entry": "示差",
    "reading": {
      "primary": "しさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
      "ctype": null,
