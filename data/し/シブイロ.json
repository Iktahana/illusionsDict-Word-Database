        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "渋色をした小さな身体が精悍の気ではち切れそうに見えた。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどんな花であっても純白の卓布と渋色のパネルによくうつって美しかった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その渋色の橋を渡ると、岸から板を渡した船がある、板を渡って、苫の中へ出入をするので、この船が与吉の住居。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」六「あい、」といいすてに、急足で、与吉は見る内に間近な渋色の橋の上を、黒い半被で渡った。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物は何処かの小使のお古らしい小倉の上衣に、渋色染の股引は囚徒のかと思われる。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋色の逞しき手に、赤錆ついた大出刃を不器用に引握って、裸体の婦の胴中を切放して燻したような、赤肉と黒の皮と、ずたずたに、血筋を縢った中に、骨の薄く見える、やがて一抱もあろう……頭と尾ごと、丸漬にした膃肭臍を三頭。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡麻塩頭で、眉の迫った渋色の真正面を出したのは、苦虫と渾名の古物、但し人の好い漢である。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "床にはずっと渋色の油紙が敷かれていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "這入って見ると鉄渋色の鉱泉で、それも沸し湯だった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻製渋色の胸当て（金太郎式の）は夏冬共に離さなかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」母は、うれしそうに、膝の上に置いてあった渋色になった、みの紙の書付をひらひら出して見せた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋色の樹肌には真っ赤な蔦紅葉が絡んでいた。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の上に伸びた樹木の渋色の幹には真っ赤な蔦が絡んでいたりした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉は干び、皮｜萎びて見るかげもないが、手、胸などの巌乗さ、渋色に亀裂が入つて下塗の漆で固めたやう、未だ／＼目立つのは鼻筋の判然と通つて居る顔備と。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園町友禅の　赤く燃えたつ祇園町銀の糸の雨は斜に降りしきる渋色の　蛇の目の傘に降る雨も上に下にと降りしきる鴨川の　河原に啼いた河千鳥君と別れた路次口に雨はしきりと降りしきる。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "この幟の色について兼ねて疑があったから注意して見ると、地の色は白、藍、渋色などの類、であった。",
              "citation": {
                "source": "車上の春光",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母の鏡立ては木目のくっきりした渋色の艷のある四角い箱のようなものであった。",
              "citation": {
                "source": "この初冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはわたしの普段着にしたいのですけれど、どちらがよろしいかお決め頂こうと思いまして」　柿渋色の地に小さな緋のあるのと、もうひとつは黒とねずみの細かい横縞であった。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋には渋色の紙が敷いてあるだけだったが、同様に暗い隣室では彼には分らぬ二三の話声だけ高く聞えた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋色に塗った低めの長い食卓には、鉢から移された前菜の、生海胆、琵琶湖産の源五郎鮒の卵巣、日向産の生椎茸の油煮、熊の掌の煮付に添えたひじき、鴨のロース、仙台産の味噌で包んだ京の人蔘、など、これらが織部の小皿に並んでいる。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋色の、光つて冷たさうな服を着た、ニウが、広い庭隅の花畑に立つてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその上には、蛇の目蝶が、渋色の翅を合せた儘、何羽もぎつしり止まつてゐた。",
              "citation": {
                "source": "槍ヶ嶽紀行",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と見るよりも早く、蠅男の隙を狙って寝台の下からパッと投げつけた渋色の投網！",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは質のいい生ゴムでつくられてあり、例の汐ふきのような顔になっており、そして生ゴムの表面は渋色に染めてあった。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに小さん、渋色の表現ゆゑに名人とされ、春団治、派手の表現ゆゑに邪道とされる。",
              "citation": {
                "source": "初代桂春団治研究",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥白根の渋色のドームが南の空に半ば雲に包まれている。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る限り褐色や渋色をなすりつけた黒白斑の大岩塊が、縦に欹ち横に伏して、頭上二、三尺の高さに不恰好な階段を築き上げている、私達は取りつき端もない階段の下に立って、未練らしく手足を掛けて見たりなどした、夫でも水の鉋に削られた岩の屑が堆く積って、易々と乗り越せる所もあった。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋色の美しい骨格が波の上を流れて行く。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりは南の国の面白い話でもしょう」とシワルドは渋色の髭を無雑作に掻いて、若き人を慰める為か話頭を転ずる。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋色の濃いなかにぽつりと穴があく。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
