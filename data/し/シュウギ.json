[
  {
    "uuid": "76431d44-2237-550c-8b66-58a003d4d291",
    "entry": "祝儀",
    "reading": {
      "primary": "しゅうぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
