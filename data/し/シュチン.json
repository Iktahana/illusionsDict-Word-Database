[
  {
    "uuid": "23c8aa9b-6153-57d6-a0f1-62a8ddc2f90d",
    "entry": "繻珍",
    "reading": {
      "primary": "しゅちん",
      "alternatives": [
        "しちん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "satin with raised figures",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼処に、尾花が十穂ばかり、例のおなじような兀げた丘の腹に、小草もないのに、すっきりと一輪咲いて、丈も高く莟さえある……その竜胆を、島田髷のその振袖、繻珍の帯を矢の字にしたのが、弱腰を嫋やかに、白い指をそらして折って取った。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子はぞろりと外出の装、繻珍の丸帯を今｜〆めて、姿見に向いたるが、帯留の黄金金具をぱちんと懸けつつ振返りて、「おや、照子｜様。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜿蜒として衣桁に懸る処、恰も異体にして奇紋ある一条の長蛇の如く、繻珍、西陣、糸綿、綾織繻珍、綾錦、純子、琥珀、蝦夷錦、唐繻子、和繻子、南京繻子、織姫繻子あり毛繻子あり。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装は、将棊の駒を大形に散らしたる紺縮みの浴衣に、唐繻子と繻珍の昼夜帯をばゆるく引っ掛けに結びて、空色｜縮緬の蹴出しを微露し、素足に吾妻下駄、絹張りの日傘に更紗の小包みを持ち添えたり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから繻珍の夏帶とお召の單衣と綾絹の蝙蝠傘とを強請られて購はせられたが、これは彼の消極的經濟に取ツて、預算以外の大支出で、確に一｜大打撃であツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "背きがち、首だれがちに差向ったより炉の灰にうつくしい面影が立って、その淡い桔梗の無地の半襟、お納戸｜縦縞の袷の薄色なのに、黒繻珍に朱、藍、群青、白群で、光琳模様に錦葉を織った。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "文金の高髷ふっくりした前髪で、白茶地に秋の野を織出した繻珍の丸帯、薄手にしめた帯腰｜柔に、膝を入口に支いて会釈した。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の衣物は相變らず雨に笹の白縮みだが、帶だけは換はつて、牡丹色の繻子と青みがかつた綿繻珍らしいものとの腹合はせになつて、帶あげは繻絆の袖と同じとき色のメリンスだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋羽二重や、鼠縮緬の衣物――繻珍の丸帯に、博多と繻子との昼夜帯、――黒縮緬の羽織に、宝石入りの帯止め――長浜へ行った時買ったまま、しごきになっている白縮緬や、裏つき水色縮緬の裾よけ、などがある。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜荷というのは今でいう密貿易品のことで、翡翠、水晶、その他の宝玉の類、緞子、繻珍、羅紗なぞいう呉服物、その他禁制品の阿片なぞいうものを、密かに売買いするのであったが、その当時は吉宗将軍以後の御政道の弛みかけていた時分の事だったので、面白いほど儲かった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　頭は籐表を打った、繻珍の鼻緒で、桐の柾という、源次が私生児を引放して、片足打返して差出した。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "着つけは濃いお納戸地に、金で乱菊を織出した繻珍と黒繻子の打合せの帯、滝縞のお召縮緬に勝色のかわり裏、同じ裾を二枚｜襲ねて、もみじに御所車の模様ある友染に、緋裏を取った対丈襦袢、これに、黒地に桔梗の花を、白で抜いた半襟なり。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と気を変えたか、宗匠、今夜は大いに侠って、印半纏に三尺帯、但し繻珍の莨入に象牙の筒で、内々そのお人品な処を見せてござる。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもその大輪を被いだよう、絽の羅に紅の襦袢を透して、濃いお納戸地に銀泥をもって水に撫子を描いた繻珍の帯を、背に高々と、紫菱田鹿の子の帯上を派手に結んだ、高島田で品の可い、縁側を横にして風采｜四辺を払うのが、飛石にかかると眩くお夏の瞳に映じた。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の中央に、漆の色の新しい、黒塗の艶やかな、吾妻下駄を軽く留めて、今は散った、青柳の糸をそのまま、すらりと撫肩に、葉に綿入れた一枚小袖、帯に背負揚の紅は繻珍を彩る花ならん、しゃんと心なしのお太鼓結び。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思切って緞子か繻珍に換え給え、」（その頃｜羽二重はマダ流行らなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "）というと、「緞子か繻珍？",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは繻珍、こちらの品はつづれ織りでございます」　声と同時に十八、九ごろから二十がらみのはで向きを、ずらずらとそこへ並べましたので、さあ一大事とばかりに伝六がいっそう目を丸くしていると、だが、買うものは余人ならぬわれわれのむっつり右門です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫地に白矢絣の飛んだ振袖を着て繻珍の帯を立矢の字に結び、鈴のついた墨塗の木履をはいてゐた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯色のリボン、繻珍の鼻緒、おろし立ての白足袋、それを見ると、もうその胸はなんとなくときめいて、そのくせどうのこうのと言うのでもないが、ただ嬉しく、そわそわして、その先へ追い越すのがなんだか惜しいような気がする様子である。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "銘仙｜矢絣の単衣に、白茶の繻珍の帯も配色がよく、生際の美しい髪を油気なしのエス巻に結つて、幅広の鼠のリボンを生温かい風が煽る。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "銘仙矢絣の單衣に、白茶の繻珍の帶も配色がよく、生際の美しい髮を油氣なしのエス卷に結つて、幅廣の鼠のリボンを生温かい風が煽る。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お勢は黄八丈の一ツ小袖に藍鼠金入繻珍の丸帯、勿論下にはお定りの緋縮緬の等身襦袢、此奴も金糸で縫の入ッた水浅黄縮緬の半襟をかけた奴で、帯上はアレハ時色縮緬、統括めて云えばまず上品なこしらえ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず友染とか、繻珍とか、ぱっとした色気のものに包まっているから、横から見ても縦から見ても派出である立派である、春景色である。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その婦人は繻珍の吾妻袋を提げて、ぱッとした色気の羽二重の被布などを着け、手にも宝石のきらきらする指環を幾個も嵌めていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕様がないから、俄に私の繻珍の丸帯をほどいてズボンにしておきせしたよ、こんなこともある。",
              "citation": {
                "source": "繻珍のズボン",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に律義な祖父でも自分一人繻珍のズボンでは困ったろう。",
              "citation": {
                "source": "繻珍のズボン",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君の丸帯から出来た繻珍ズボンをはいて、謹厳な面持で錦絵によくある房附きの赤天鵞絨ばりの椅子にでもかけていただろう祖父の恰好を想像すると、明治とともに心から微笑まれるものがある。",
              "citation": {
                "source": "繻珍のズボン",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはお梅にとっては一大事で、南部表にしゅちんの鼻緒。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙入れ、軸、色鍋島の壺、しゅちんの帯、そうかと思うと金泥の仏像や嫁入り衣裳、またかなり値にもならないガラクタ物まで現れましたが、さて、どうしたのか、金吾と釘勘が目をすえて待つ、出目洞白の面箱という声はあがらない。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
