    "definitions": [
      {
        "index": 1,
        "gloss": "one's origin (e.g. city, country, parentage, school)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
