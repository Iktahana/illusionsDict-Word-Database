[
  {
    "uuid": "5a5a379a-e034-57b1-bf2b-8d9ea174a6d5",
    "entry": "史眼",
    "reading": {
      "primary": "しがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
