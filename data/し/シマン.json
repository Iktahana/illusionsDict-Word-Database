    "definitions": [
      {
        "index": 1,
        "gloss": "four types of mandala (in Shingon)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
