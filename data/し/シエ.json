[
  {
    "uuid": "5ec755d8-d5e1-5283-9b5f-c4a8b529c99a",
    "entry": "紫衣",
    "reading": {
      "primary": "しえ",
      "alternatives": [
        "しい"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "purple vestment (traditionally awarded by the imperial household)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで宋主（真宗）は日本の国体に嘆美｜措く能わず、又寂照の風神才能に傾倒の情を発して、大にこれを悦び、紫衣束帛を賜わり、上寺にとどめ置かせたまいて号を円通大師と賜わった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の日彼は紫衣に狐裘を重ね、牡馬二頭立の豪奢な車を駆って宴に赴いた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝今日、国君の服たる紫衣をまとう。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の日彼は紫衣に狐裘を重ね、牡馬二頭立の豪奢な車を驅つて宴に赴いた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝今日、國君の服たる紫衣をまとふ。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の貴人は静かに入ってきた。",
              "citation": {
                "source": "柳毅伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の若僧の一行あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の僧は落花の雪を袖に払いつつ行く。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣と云い、黄袍と云い、青衿と云う。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "金襴の袈裟、紫衣、旭川へ行く日蓮宗の人達で車室は一ぱいである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央に緑衣の男と、紫衣の女とが並んで坐つてゐる。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　（取り乱して）此の子が生れるのは来年の三月だから、それまでは、どうしたらいゝんです。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　（甘へるやうに）ねえ、お爺さん、お菓子なんかあたしはどうでもいゝから、来年こそ、なんとか一つ運が向くやうにして下さいな。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女┐　　　　├　　ぢや、どうか、わたしたちのことをよろしく頼んで置いて下さいますか。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　そんなこと云はずに、ねえ、ちよいと、小僧さん……。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　（しつつこく）そんなら、せめて、これから、どうなるものか、それだけでも教へて頂戴な。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　（諦めかねて）お爺さん、あんたのところにはもう仕合せが一つ二つ余つてゐませんか。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　（意地きたなく）通用しなくつてもよう御座んすから。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（去る）紫衣の女　　（その後を見送り）たうとう、行つちやつた。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（両手で何かを空中に撒き散らすやうにして舞台を歩きまわる）紫衣の女　　（身悶えながら泣く）緑衣の男　　（両腕に力を入れ）よし、元気を出してと……。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（起上らうとする）紫衣の女　　（男に取りすがり）もし、夜が明けるまで此処にゐて下さい。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　（含羞みながら）でも、それではあんまり……。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　（しなを作り）あんまり……緑衣の男　　（快活に）……早すぎますか。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　（摯ねて）あんな家へは帰りたくありません。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の女　　（感動して）それでは、あなたが……。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（体操をする）紫衣の女　　（男の膝に泣き伏し）こんなに親切にしていたゞいて自分がどんなに不幸な女だと云ふことさへ、もう忘れてしまひさうです。",
              "citation": {
                "source": "新年狂騒曲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紗帽を冠り、白紫衣を着け、飄々と李白が現われた。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、不意に紫衣のその司僧が、鳰鳥の方へ振り返った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣も珠玉も絵画も主は確に嘉し給はぬ。",
              "citation": {
                "source": "法王の祈祷",
                "author": "RECIT DU PAPE INNOCENT 3",
                "note": "青空文庫"
              }
            },
            {
              "text": "道化役者が疝気の発作におそわれればその派手な衣裳もその病苦をあらわすにちがいないし、兵士が砲弾に射ちあてられればぼろも紫衣のけだかさをもつであろう。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
