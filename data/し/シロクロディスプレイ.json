          "standard": [
            {
              "text": "古いパソコンには白黒ディスプレイが使われており、それがまた味がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "白黒ディスプレイは目に優しいと言われていて、長時間作業しても疲れにくい気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このレトロゲームは白黒ディスプレイで遊ぶと、より一層雰囲気が増して面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "九インチのブラウン管白黒ディスプレイを備えた８０８８マシンのポータブルＩは、飛行機の座席の下に収まる寸法で、約一二キログラムと確かに持ち歩けなくはない重量に収まっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンポーネント形式をとらず、すべての要素を一体化させたマルチ16の最低価格は、白黒ディスプレイ、メモリー一二八ＫＢ、五インチのフロッピーディスクの構成で七三万円とされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
