    "definitions": [
      {
        "index": 1,
        "gloss": "tax collection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「誰だ、きさん、収税だらう。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、云はなぃかこん畜生、貴さん収税だらう。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「収税でなくて何しに入るんだ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "収税吏に新宅の税を督促さる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "収税吏にその身を窶した大学生の田野流吉が何やら切りと指をあちこちに差しながら提灯持ちに向つて案内をいそがせてゐる様子であつた。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに高張提灯をつけて、五種類の酒の出来具合を収税吏と農林技士が吟味しようといふのである。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「執達吏と収税吏が、泥酔してしまつて、いつかな動かうともしませんが？",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓の上には戸籍台帳やら、収税帳やら、願届けを一まとめにした書類やらが秩序よく置かれて、頭を分けたやせぎすの二十四五の男と五十ぐらいの頭のはげた爺とが何かせっせと書いていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体租税とか女房から頼まれた手紙とかいふものはよく忘れ勝なもので、そんな物を忘れたり、怠つたりした所で、一向｜掛構ひの無ささうなものだが土地の収税吏は怖い顔をして催促に出掛けて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "収税吏は痩せた男だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると女将はいきなり大きな掌面でもつて収税吏の横つ腹を押へてぐつと締めつけた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "収税吏は女将の手許を潜りぬけて、空壜のやうに表へ転がり出したと思ふと、直ぐ巡査を連れて戻つて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "収税吏もあまりいいところじゃないらしいよ。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語を強制された朝鮮人民の生活の中で、日本語が話せ、日本字のかける朝鮮人が、総督府の官吏になり、巡査になり、収税吏になって、今日になってみれば、同胞の自由を抑え搾る仕事に協力していた。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレジエ氏の手に入る前迄はこの屋敷は王政時代の収税請負人の領地の一部分であつたのです。",
              "citation": {
                "source": "フランソア・コッペ訪問記",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「革命以前の収税請負人などは非常に、贅沢をしてゐたので、ここへ遊びに来て、田舎気分を味ふと言ふので、時々親戚や知人を此処へ招いたものです」と話しながら、先生は王政時代の財界の富豪の事を、こんな風に語つて聞かせた。",
              "citation": {
                "source": "フランソア・コッペ訪問記",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "収税が思ふやうにいかないからである。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、彼は、その両方面の財政に関しては、やむをえず収税請負人★と結託したのであった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "公の財政に関しては、モンセーニュールはそれを全くどうすることも出来なかったので、それゆえ誰かそれをどうにか出来る者に任さなければならなかったからであるし、私の財政に関しては、収税請負人は富裕であって、モンセーニュールは代々の非常な奢侈と浪費との結果として貧しくなりつつあったからである。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、モンセーニュールは、修道院にいる彼の妹を、彼女が身に著け得る最も廉価な衣装である面紗をかぶる★のが差迫っているのを断るにまだ時がある間に、そこから連れ戻して、家柄は賤しいがすこぶる富裕な一人の収税請負人に、褒美として彼女を与えたのであった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この収税請負人は、頭部に黄金の林檎のついた身分相応な杖を携えながら、今、外側の室の来客の中にいて、人々に大いに平身低頭されていた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その収税請負人は豪奢な男であった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "掠奪と徴発との出来る限りはひたすらそれをのみやるということを公言している人間として、この収税請負人は、――彼の婚姻関係がいかに社会道徳に貢献するところがあったにしても、――当日モンセーニュールの邸宅に伺候した貴顕縉紳の間にあっては、少くとも最も現実性に富んだ人物であった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣、国家の山師、収税請負人、医師、法律家、僧侶、大歌劇、喜劇、燦然たる間断なき流れをなした全仮装舞踏会は、馳せ過ぎて行った。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "村では、収税者も納税者もみんなぐっすりと眠っていた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "収税請負人　　フランスの王政時代に、一区域の租税を徴収する特権を政府から得て、その代償として政府に一定の額を支払い、その契約の定額以上に人民から搾取したものはことごとく自己の懐に収めることが出来た収税吏。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この収税請負人はこうして人民を誅求して、大革命の前には人民にはなはだしく怨まれていた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "税金「条文がちゃんとあります」――収税官吏はノワルミエに言った。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「条文がちゃんとあります」――また収税官吏は言った。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
