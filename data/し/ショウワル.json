    "definitions": [
      {
        "index": 1,
        "gloss": "ill-natured",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼等は、性悪で荒っぽくて使いにくい兵卒は、此際、帰してしまいたかった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「性悪るせずに、人さんの余った物でも貰うて食えエ……ここらにゃ魚も有るわいや。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「余程、性悪の女だね。",
              "citation": {
                "source": "シルクハット",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれ、お前さんも性悪をすると見えて、ひがむ事を覚えたね。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お客様、お前は性悪だよ、この子がそれがためにこの通りの苦労をしている、篠田と云う人と懇意なのじゃないか、それだのにさ、道中荷が重くなると思って、託も聞こうとはせず、知らん顔をして聞いていたろう。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこゝにもわたくしの中なる性悪な禍津日神を見出します。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分自身に対して根性悪く考えれば、人生に必要なスリルというもの、それをわたしは自分自身の為めに起す力を失ってしまっている。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して荀子は人間性悪説を執り法治論社の一派を形造った。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは東栄が所謂性悪をして、新造花川に負いたために、曲輪の法で眉を剃り落されそうになっているところである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるからに口説の際も常に予を戒めて、ここな性悪者め、他し女子に見替えて酷くも我を棄つることあらば呪殺してくれんずと、凄まじかりし顔色は今もなお眼に在り。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には書き手のあずかり知らぬところで改竄しようとする性悪もいないじゃない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに悪いのは、オレにとってみれば万死に値する大罪を犯した編集者が、全くもって根性悪に見えなかった点である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世では、その人となり性悪で無く、暗愚無知でも無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯性悪ければとて常に涅めたるが、かかるをや烏羽玉とも謂ふべく殆ど耀くばかりに麗し。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブの馬は、皆去勢せねど性悪しきもの少なく、また耳も尾も截らず、臨終｜際までも活溌猛勢だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かきねの外からすき見するほどの性悪だもの、あば敬なんぞといっしょに歩いていたひにゃ、じゃまされるに決まってるじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "性悪男８・26（夕）　ある婦人が市街を歩いてゐると、一人の男が横合から飛び出して来て、じつと婦人の顔を見てゐたが、暫くすると黙つて婦人の跡をつけた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女は見掛によらない性悪ですね。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「性悪……」と婦人は立ち止つて男の顔を見た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何方が性悪なんでせう、もしか仰有る通り、貴方が私にお惚れなすつたのだつたら、あの女の方を追駈けはなさらなかつた筈ぢやなくつて。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船では働いている仲間が、精神を痺らす奴隷的な労働と泥酔との暇に、仲間同士性悪な悪戯をしかけるばかりでなく、袋を背負い、背中を曲げ、十字を切りながら乗りこんで来る船客たちも、十二歳のゴーリキイの心に一種名状し難い侮蔑的な重苦しい感じで圧えつけ、夜眠っても忘れることの出来ない深い憂鬱をひろげた。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして世の人皆愚にして根性悪しき故、誰も小生の言葉に耳を借すことなく、申合せたる如く嘲笑致し居候。",
              "citation": {
                "source": "アンドレアス・タアマイエルが遺書",
                "author": "ANDREAS THAMEYERS LETZTER BRIEF",
                "note": "青空文庫"
              }
            },
            {
              "text": "只小生をして一命を捨てしむるに至りしは、世の人の愚にして、根性悪しきが為に候。",
              "citation": {
                "source": "アンドレアス・タアマイエルが遺書",
                "author": "ANDREAS THAMEYERS LETZTER BRIEF",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間も性悪しとてむやみに鞭撻を加へて教育すればますますその性を害ふて悪くするに相違なしと思ふ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもよほど快く候よし、病はすこしいゆるに加はると申こと、かの性悪先生之語也。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつがこっちのよりは全く性悪だそうだからね、注意するこったぞ。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と云ふ性悪の女だつたのだらう。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "性悪の女はそのやうに云つて、父親に月々五円の権利を与へたのだらう。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すつこんでやあがれ、この性悪女め！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の性質粗野にして根性悪しく、夫の父母に対して礼儀なく不人情ならば離縁も然る可し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
