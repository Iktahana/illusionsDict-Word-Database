    "definitions": [
      {
        "index": 1,
        "gloss": "civil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女の名前をシビル・ヴェンと云った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリアンはシビル・ヴェンを忘れかねて、それから毎晩、その怪しげな芝居小屋へ通った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "シビル・ヴェンは未だ初々しい内気な娘であった。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　シビルはメルボルーンへ向けて航海しようとしている弟のジェームスと共に明るい日ざしの中をユーストン通りの方へ歩いていた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　ヘンリイ卿とハルワアドは、ドリアン・グレイからシビル・ヴェンとの恋を打ち明けられて少からずおどろいた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "』十五分の後に遂にシビル・ヴェンはわれるばかりの喝采と共に舞台にその姿を現わした。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　ドリアンは、そう云い捨てると泣き沈んでいるシビルを残して立ち去った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はシビル・ヴェンに対して如何に無慈悲で残酷であったかを思い出して慚愧の念に心を噛まれた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあらためてシビルと結婚したいと思った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『シビルは死んだ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　10　ベエシル・ハルワアドもまたシビルの死を知ったのでドリアンを訪れた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ただ洗礼名だけだが、それだってシビルは誰にも話さなかったに違いない。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はまるでシビル・ヴェンの如くに優しく愛らしかった。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言うのは、その広間のドアーの上に、かのギリシャ神話の中のシビルの絵が額にして掛けてあったからで、別に何も怕いところはないのに彼女だけは、いわば虫の好かぬとでも言うのか、その絵を限りなく恐れたのである。",
              "citation": {
                "source": "怪談綺談",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の瞬間彼女は悲鳴をあげて、ドアーを開けるべく力任せにゆすぶっていたが、やがてガチャンという物の落ちる音がして、そのままばったり静寂に返ったので、人々は気味が悪くなってドアーを開いてみると、哀れにも彼女は上から落ちて来たシビルの絵の額に脳天を打ち砕かれ血溜りをつくって死んでいた。",
              "citation": {
                "source": "怪談綺談",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノウォシビルスク――満洲里から五日目。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノボオシビルスクにも、こんな賑やかな街はなかつた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノボオシビルスクの停車場で、二人連れの少年が、直吉の兵隊姿をじろじろ眺めてさゝやきあつてゐたものだ。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに恋ひこがれた東京へ戻つて来ると、妙な事には、時々ノボオシビルスクの夢を見て、涙を流してゐる時があつた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "直吉は兵隊の視線を受けて、突差に笑ひかけようとしたが、何と云ふ事もなく、ノボオシビルスクの、ソ連の少年の眼を思ひ出してゐたのだ。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――時には、夢で、ノボオシビルクスに引き戻されて怯える夜もあつたが、夢が覚めると、白いパンに向ふ時の厭な気持ちになるのは、心に重たいしこりがあるせゐであらうか。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノボオシビルスクにゐた頃も、時々、かうした虚しい思ひに耽つた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も、小舎の外の井戸端で、のびのびと顔を洗つてゐる直吉には、かうした狭い便所の匂ひには、ノボオシビルスクの収容所の匂ひを思ひ出させるのだ。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "５信　十六日の夕方、ノボォーシビルスクと云ふところへ着きました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノボォーシビルスクでは十五歳位の男の子が一人乗つて来ました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ神の光のみ本來眞なり、萬物の眞はこの光を頒つによりてはじめて存す五八―六〇天、二三・四九―五四參照〔他は〕夢その物は六一―六三〔消え〕記憶より六四―六六事物の記憶より冷えゆくさまをさらに二の譬にて示せり〔シビルラ〕キュマエ（ナポリの西の町）の巫女にてアエネアスを冥府に導ける者。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをシビル・マリッジという。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "合唱の群糸を繰るパルチェエの中の一番貴いあなた、一番賢い占女シビルレのあなた。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
