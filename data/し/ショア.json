        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "料理卓の上にはアンショア（ひしこの塩漬）の三枚におろしたのが昨日からオリーブ油に浸けられている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは料理家の間にアンショア・ア・ラ・ブレトンヌと名づけられる前菜なのだ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "基本のアンショア・ア・ラ・ブレトンヌに加減していた味の数学は漸く割り切れた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にオリーヴ油のアンショアを乗せ蝦の肉で彩るのだった。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰻も捨てられた、独活も捨てられた――そして「巴里人のアンショア」の名で一つの前菜が新しく生れた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「巴里のアンショア」の最初の一皿は、ほんの端だけ老翁に味われあとはゴミ桶へ捨てられた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くシーショア・ライブラリーという十銭本だった。",
              "citation": {
                "source": "黒岩涙香のこと",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」27甘くやさしい夏の夜星明かりに踊る影と影〈ディスタント・ショア〉チャド＆ジェレミー　教育委員会がどう考えようと、寮というのは、「異性交遊」には向いていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺碧の海に対し、渚にはまるで毒茸の園生のように、強烈な色彩をもったシーショアパラソル、そして、テントが処せまきまでにぶちまかれる。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に仏医ショアベーの名著『暖国の疾病』を操ってみれば判るとおりで、それにある奇形癩の標本を、いちいち稚市と対照してゆけば、やがて幾つか、符合したものが見出されるに相違ない。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」アベ・ショアズイはこの答を一生の冒険の中に数え、後のちまでも自慢にしていたそうである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス大使ショアシュール・グウフィエ伯と副領事フォヴェル（画家）が逸早くパルテノンの彫刻を運び去り、つづいてイギリス大使ロード・エルジンが運び出した。",
              "citation": {
                "source": "パルテノン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シモンは靴の底革を貼り合わせる締金付のマショアールという二枚板で先妻の子の頭をジワジワと締めつけ、のし餅のように平らにへし潰して殺したという評判があり、残忍のゆえに人に恐れられている男で、陰鬱な眼付をした、猫背の、顔色の悪い、いつも口元に冷笑を漂わせた、見るからに削げたような不快な人相をしていた。",
              "citation": {
                "source": "カストリ侯実録",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は英字新聞「エクセルショア」をもったまま、梨の木の下をあちらからこちらへ、こちらからあちらへ、と幾度も歩いた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルノール・ド・ヴィラノヴァ、アンリ・ド・モンドヴィル、ギ・ド・ショアリックである。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ国王ルイ十八世は、ほとんど毎日のようにショアジー・ル・ロアに行っていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショアズールとセランという二人の至って厳格な公爵夫人が、しばしばこの会を訪れてきた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅白｜碁盤縞の並より大きいシーショア・アンブレラの下で、私達は志摩子さんやそのお友達の娘さん達と、真黒な肩を並べてキャッキャッと笑い興じた。",
              "citation": {
                "source": "何者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフ・ショアの風に、怪物波の頂上は、白熱した飛沫のたてがみへと逆立った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し強いオフ・ショアの風を正面から受けて、波のスロープは鏡のように滑らかだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はオフ・ショアに変わっていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "強めのオフ・ショアの風を受けて、サーフの頂上からまっ白に水がはぎとられ、飛沫になって高く舞いあがる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の裾から吹きあげて来るオフ・ショアの風に叩かれ、赤いサーフボードはきりきり舞いをしながら、波のスロープを上へ飛んでいった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフ・ショアの風が強くなった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちあがっては突進し続ける波の壁が、そのオフ・ショアの風に叩かれ、でこぼこの少ない滑かな面になった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い壁になった波が、頂上の部分を水のアーチとして自分の前の空間に投げ出そうとするとき、強くなって来たオフ・ショアの風は、水の層を波頭からはぎとる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフ・ショアの風にその飛沫をうしろになびかせ、波は走る。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソーダ水を半分まで飲むあいだに、店のスピーカーから聞こえていたレコードによる英語の歌は、キティ・カレン、ゲイル・ストーム、ジョニー・レイ、そしてパイド・パイパーズをへてダイナ・ショアへと、五曲が経過した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
