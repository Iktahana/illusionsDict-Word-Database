          "literary": [
            {
              "text": "釦一つ押すと紫電一閃。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と宙にうなって、紫電一閃！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷の角を曲つて、筋違橋の方へ出ようといふ時、「え――ツ」　横合から紫電一閃、平次は眞つ二つ――と思ひきや、一髮の違ひで危ふく免れました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷の角を曲って、筋違橋の方へ出ようという時、「え――ッ」　横合から紫電一閃、平次は真っ二つ――と思いきや、一髪の違いで危うく免れました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「え――ッ」　まさに紫電一閃です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "毒酒薬酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫電一閃、お染は飛び散る血潮の中に、声もなく崩折れます。",
              "citation": {
                "source": "大江戸黄金狂",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬冠りを取ると見せて、右手は早くも懐の申の脇差の柄に――「え――ッ」　紫電一閃、「わッ」　羅紗陣羽織の肩から鮮血を吹き上げて、相手は倒れたのです。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫電一閃、満天の雲の峰を寸断する趣だ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
