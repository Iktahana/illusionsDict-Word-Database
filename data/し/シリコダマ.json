    "definitions": [
      {
        "index": 1,
        "gloss": "mythical ball inside the anus that is sought after by kappa",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔話に出てくる河童は、人間の尻子玉を抜くという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は、夜中に一人で歩くと尻子玉を抜かれるぞ、と冗談を言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は尻子玉を抜かれたように、ぐったりと座り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "馬鹿な面をしていやがって、尻子玉でもひっこぬかれるな」とでもいいそうな顔を妻の方に向けて置いて、歩きながら帯をしめ直した。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のころ、「あの川へ泳ぎに行くとカッパがいて、尻子玉を抜かれるぞ」　と、いわれた。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪隠の下の河童の覘ふものは、しりこだまであつた。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちはみづちの系統の語であり、ちごも、河童或は河童の好物しりこだまを意味する、福岡辺の方言である。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
