[
  {
    "uuid": "e82176de-12d5-57b2-a544-198abc0858ee",
    "entry": "神座",
    "reading": {
      "primary": "しんざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "place where there is a god or spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三山の冠を被り、淡黄袍を著けて、玉帯をした者が神座へ坐って、神案に拠りかかり、その従者であろう十人あまりの者が、手に手に戟を持って階下の左右に別れて立っていた。",
              "citation": {
                "source": "申陽洞記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "李生は起きて神座の辺に注意した。",
              "citation": {
                "source": "申陽洞記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、彼は神座をしつらえて、祭祀を怠らなかったが、その生活はすこぶる豊かで、ただ大いに富むというほどでないだけであった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "端的に言ふと、日本の神座に移動的なものがあつて、其が一つ、有力なものであつた事を見せてゐるのだと思ひます。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "音韻変化を持つて来る事は不自然になりますから控へますが、結局、かぐらは神座といふ熟語に過ぎません。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どの神座でもかぐらと言うたのではなく、或種類の神座を、専らかぐらと言うてゐたのです。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、旅をして、言ひ換へれば、移動して歩く神座に対して、世間の人が、其らの人の語を認めて、かぐらと言うた訣です。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、其なら何でも神座であつた様ですが、少くとも私どもの考へでは、単に神体が入れてあるだけではいけないので、其が祠であり、宮殿であると感じられなければ、神座ではなかつたのです。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、荷物と同じものではない――もつと詳しく言ふと、旅行中に荷物の中から神体をとり出して、其を臨時に据ゑて拝ませるといふ様なものではない――ので、持つて歩くもの其ものが神座でなければならぬのです。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が、前に申した神座にのせられて、西国から東へ上つて来る途中の行装をもつて名づける様になつた名称だ、と考へてゐるのです。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂はゞ、特殊な神座を曳き、或は舁いて鎮魂法を施して行く神人のする舞踊を意味したほど、それほど目立つた神座をたづさへてゐたのに相違ないと思ふのです。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、私どもには、其神座に乗つた神体が、果して獅子頭であつたやら、どうやらといふ決定が出来ないのです。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上座でも神座でもない様です。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い竿を地に掘り据ゑないで、人が支へるといふのは、神座の移動を便ならしめる為で、神が直ちに神社に降りない証拠である。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この倉は、地上に柱を立て、その脚の上に板を挙げて、それに、五穀及びその守護霊を据ゑて、仮り屋根をしておく、といふ程度のものであつたらしく、「神座なる棚」の略語、くらの義である。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年五月三十日相州三崎へ行つた時、同地祭礼で波打際に子供の拵へた天王様が置いてあつたが、やはりと言ふ物が、横臼を曳き出したり、綱を敷いたり、さては粟殻を撒いて早速の神座を作つたのと同様に、古代人の簡易生活を最鮮明に表示して居るので、漁師村などによく見掛ける地引網の綱を捲く台であつた様だ。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい物では、大阪で祭りの提灯を立てる四つ脚の※なども、地を掘つて柱を建てぬのは、即昔の神座の面影を遺すものではあるまいかと思ふ。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "百取りの机代物を置き足はす様になつたのは、遥かに国家組織の進んだ後の話で、元は移動神座なる髯籠が、一番古いものであつたと思はれる。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田原の団子の木が挽臼に立て掛けられるのも、依代と神座との関係を示してゐて面白い。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪の御舟祭りの屋台は恐らく、元三大師作と伝へる舟謡を残してゐるほど古い日吉山王の御舟祭りと同様、水上渡御の舟を移動神座なるの上に立てられ、其に車をつける様になつたといふ道筋を教へるものではないだらうか。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神に手芸の道具を献る事は、別に不思議でも無いが、線柱の一品だけは、後世臼が神座となり易い様に、ひよつとすれば、神のたゝりのよすがとなつた物かも知れぬ。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくは神座・机・発言者などの位置のとり方について言ふものらしいのである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして其｜神座に据ゑた神体が、異風なものであつたらしい事。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、其｜神座に居る神の実体は、後の神楽には、閑却せられて了ふ様になつたらしい。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから神楽も、古いものほど、神体を据ゑた神座なるものを中心とした群行だつたに違ひない。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡神を直に人形身で示した証拠がなくとも、其最側近なる神を偶像を以て表し、又其を緩慢にでも操る事によつて、一種の効果を齎したものとすれば、石清水系統に神座のあつた事が考へられる。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝言の乞食者が持ち廻つた神器が、又謂はゞ一種の神座でもある訣であり、同時に食器であり、更に運搬具でもあつたのだ。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とのさまの　そうしき　一休さんが、大ぶ　としとってからの　なかの　よい　ともだちに、にながわ　しんざえもん　と　いう人が　ありました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんざえもんは　一休さんの　えらさに　かんしんして、わざわざ　じしゃぶぎょう　と　いう　たかい　やくめを　やめ、一休さんの　しんじゃに　なった　ひとでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一休さんと　しんざえもんさんが　いろいろな　はなしを　していると、ひとりの　ぶしが　一休さんの　いおりを　たずねて　きて、「わたしは　うえむら　ないき　と　いうものの　けらいですが、このたび　とのさまが　しにました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
