[
  {
    "uuid": "50945295-06e7-5c89-9d30-9fa75a7e9b8f",
    "entry": "週報",
    "reading": {
      "primary": "しゅうほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
