      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "weekly report",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は日本屈指の大新聞、東都日報の外交部につとめる傍ら、本郷｜西片町の小さな活版屋で、家庭週報という四｜頁新聞を、毎日曜｜毎に発行していた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本新聞の附録週報に課題募集が毎號繼續した。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、僕個人として、二千六百年を記念する意味で、「新日本外史」といふ小著を執筆中であつたので、「週報」からの依頼も、喜んで引き受けたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治三十一年二月十四日〕三たび歌よみに与ふる書　前略。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治29・１・13　一〕海城丸船中　余は昨年四月十日近衛師団司令部と共に海城丸に乗り込み宇品を出発したり。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治29・１・27　三〕金州城内子規子　十五日柳樹屯に上陸し直ちに金州に入る。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治29・２・３　五〕　帰国するに一人の連はなきかと言へばわれも共に帰らん今二、三日がほど待てよといふは松枝某なり。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治29・２・10　六〕大連湾　一行八、九人大連湾の兵站部に到り宿舎を求む。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治32・３・13　一〕（二）◎文学者とならんか、画工とならんか、我は画工を択ばん。",
              "citation": {
                "source": "病牀譫語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治32・３・20　二〕（三）◎我に二｜頃の田あらば、麦青く風暖き処、退いて少年を教育するもまた面白からんと思ふ。",
              "citation": {
                "source": "病牀譫語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治32・３・27　三〕（四）◎子を愛せざるの親はあらず、しかも子を教ふるの親は少し。",
              "citation": {
                "source": "病牀譫語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治32・４・３　四〕（五）◎近時文字改良の論あり。",
              "citation": {
                "source": "病牀譫語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本附録週報』明治32・４・24　五〕",
              "citation": {
                "source": "病牀譫語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "この論文には予期以上の反響があって、ことに英吉利人が灰色兎・栗鼠・蜂鳥・馴鹿・かんがるう・野犬を襲撃するくだりには、それらの生物に対する氏の同情が切々と溢れ出ていて、ジェネヴァに本部のある万国動物愛護会が特にこの一節の抜粋を番外週報として一般に配布したくらいである。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはマークの札束を鞄に入れて歩いて、街の乞食の小僧が「小父ちゃん一万マークお呉れよパンを買うんだから……」と言ったという一つ話が伝わっているドイツの大恐慌の七、八ヵ月以前の状態とほぼひとしい（『同盟世界週報』一三一六号参照）形を示している。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで製作されるソヴェト・フォードは、小さい赤旗をヘッド・ライトの上にひるがえしつつソユーズキノ週報で先ず映画館の映写幕の上にころがり、つづいてモスクワの新造アスファルト道をもころがりはじめた。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（弘道会）日米週報社より、本田が広告を見て訪ねて来たことをしらす。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『週報』応募の牡丹の句の残りを検す。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔日本附録週報　明治31・2・14〕三たび歌よみに與ふる書　前略。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七月二十二日）七十二○先日『週報』募集の俳句の中に京極や夜店に出づる紙帳売といふが碧梧桐の選に入つて居つた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔日本附録週報　明治33・５・14　一〕　　　　　　（二）　　　天皇登香具山望國之時御製歌やまとにはむら山あれど、とりよろふ天の香具山、のぼりたち國見をすれば、國原は煙立ち立つ、海原はかまめ立ち立つ、うまし國ぞあきつ島やまとの國は　舒明天皇御製なり。",
              "citation": {
                "source": "萬葉集を讀む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔日本附録週報　明治33・６・11　三〕　　　　　　（四）　　　中皇命往于紀伊温泉之時御歌君が代もわが代も知らむ磐代の岡の草根をいざ結びてな　上二句は磐といふ字にかゝりていへるにて、磐は永久の者なれば君が代をもわが代をも知る筈なりといへるなり。",
              "citation": {
                "source": "萬葉集を讀む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔日本附録週報　明治32・２・27　一〕さし鍋に湯わかせ子供いちひ津の檜橋より來むきつにあむさむ　こは狐の鳴くを聞きてよめる歌にて狐に沸湯を浴びせてやらんと戲れしなり。",
              "citation": {
                "source": "萬葉集卷十六",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういうものよりも、もっと必要と感ずるのは、帝国館などで紹介している「ユニバーサル週報」の如く、外国の最近の出来事を撮影紹介するものである。",
              "citation": {
                "source": "活動写真",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『美術週報』に好い批評が出て居た。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが氏の論旨を知ったり、時々は氏に生意気な質問なぞも発したりしたのは、悉週報「上海」の主筆西本省三氏のおかげである。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（殊に当時は週報「上海」の締切り日が迫っていたのだから、私は愈氏の御苦労に感謝せざるを得ないのである。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日には大阪のＯ君から大阪朝日新聞の週報を受取り、廿一日には参謀本部附のＫ少佐から大阪朝日新聞を借りて読んだ。",
              "citation": {
                "source": "日本大地震",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十二日（水曜）〔発信〕池田小菊へ、書評『同盟世界週報』、お先に失礼したら面白い。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツの原文は一八五〇年以後、スヰス、イギリス、およびアメリカで幾度も飜刻され、一八七二年にはニューヨークで英文に譯されて、『ウードハル・エンド・クラフリン週報』に掲載され、そのイギリス譯からして同地の佛文雜誌『社會主義者』にフランス譯が現はれた。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
