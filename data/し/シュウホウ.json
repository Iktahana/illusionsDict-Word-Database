  {
    "uuid": "2fd026fa-2d39-52a6-a85d-1d8de9b9a3fe",
    "entry": "州法",
    "reading": {
      "primary": "しゅうほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "state law (e.g. in the US)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ミズーリ州の州法では、立ったまま淑女の顔をじろじろ見たりすると、ブラッシの背中でうんとお尻をひっぱたくことになっているそうじゃないですか。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが実は事の真相はあまりハッキリしていないということを忘れてはならぬのであって、関東州法曹団約七十名は、検事の召喚を拒んだり憲兵が憲兵司令官の命令に従って検事の命には従わなかったなどの、一種の司法上の分解作用を不安がって、司法権擁護のために真相調査に着手したそうである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
