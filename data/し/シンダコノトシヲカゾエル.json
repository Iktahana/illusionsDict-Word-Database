        "examples": {
          "standard": [
            {
              "text": "プレゼンは失敗に終わったが、今さら死んだ子の年を数えても仕方がない。次に向けて頑張ろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あー、あの株、買っておけばよかった！」と友人が悔やんでいたが、死んだ子の年を数えるようなものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "過去のミスをいつまでも引きずるのは、死んだ子の年を数えるのと同じだ。前向きに進むべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "雪の降り込む、風のひやびやと身にしみる丸木小屋に住ってふるえながら神様がお召になるまで泣きながら暮らさなければなりませんわね――　死んだ子の年を数えるよりもっと無駄とは知りながらもお城の中での楽しかった暮しを思い出さなければならないんでございますわ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ子の年を数える親心で、生きていたらあの子も今年三十二、いや一だったと、ゆうべも夜中に眼がさめて思い出していたくらいだ。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
