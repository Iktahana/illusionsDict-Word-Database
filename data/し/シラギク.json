        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白菊の咲く頃、大屋根へ出て、棟瓦をひらりと跨いで、高く、高く、雲の白きが、微に動いて、瑠璃色に澄渡つた空を仰ぐ時は、あの、夕立の夜を思出す……そして、美しく清らかな母の懷にある幼兒の身にあこがれた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　また前に言つた、もの凄い暗い夜も、年經て、なつかしい人を思へば、降積る霰も、白菊。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高嶺は遥に雪を被いで、連山の波の寂然と静まった中へ、島田髷に、薄か、白菊か、ひらひらと簪をさした振袖の女が丈立ちよくすらりと顕われた、と言うと、読者は直ちに化生のものと想わるるに相違ない。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、お鶴がその日の扮装には、頬に浪打つ黒髪を、頸に結んで肩にかけ、手織｜縞の筒袖は曠着も持たねば、不断のなり、襦袢の襟と帯だけは、桔梗の花、女郎花、黄菊白菊の派手模様。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄菊、白菊咲出でぬ。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "円髷、前垂がけ、床の間の花籠に、黄の小菊と白菊の大輪なるを莟まじり投入れにしたるを視め、手に三本ばかり常夏の花を持つ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "撫子　ああ、糸咲……の白菊……そうですか。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "撫子　その返り咲が嬉いから、どうせお流儀があるんじゃなし、綺麗でさえあれば可い、去嫌い構わずに、根〆にしましょうと思ったけれど、白菊が糸咲で、私、常夏と覚えた花が、撫子と云うのでしたら、あの……ちょっと、台所の隅へでも、瓶に挿しましょう。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "撫子、銚子、杯洗を盆にして出で、床なる白菊を偶と見て、空瓶の常夏に、膝をつき、ときの間にしぼみしを悲む状にて、ソと息を掛く。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七左　いや、この方が、床の間に活けた白菊かな。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが涙凝つて流れず塚の霜　その帰途、青山通りの造花屋にて白菊一枝を買い来りて仏前にささぐ。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩釜｜街道に白菊うえて何をきくきくありゃ便りきく　唄はどこも稚拙な洒落だが、言葉の訛や節の郷土色は、名歌手も及ばないところがあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀びとよ戀びとよ有明のつめたい障子のかげに私はかぐ　ほのかなる菊のにほひを病みたる心靈のにほひのやうにかすかにくされゆく白菊のはなのにほひを戀びとよ戀びとよ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　なににあこがれもとめてあなたはいづこへ行かうとするかいづこへ　いづこへ　行かうとするかあなたの感傷は夢魔に饐えて白菊の花のくさつたやうにほのかに神祕なにほひをたたふ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの感傷は夢魔に酢えて白菊の花のくさつたやうにほのかに神祕なにほひをたたふ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀びとよ戀びとよ有明のつめたい障子のかげに私はかぐ　ほのかなる菊のにほひを病みたる心靈のにほひのやうにかすかにくされゆく白菊のはなのにほひを。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い明るい庭に霜にいたんだ黄菊白菊が乱雑に咲いて居るのがかへつて趣ある風情だつたと覚えて居ます。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の気品といふものは、真黒いどつしりした大きい岩に白菊一輪だ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒海ながら、日和の穏かさに、渚の浪は白菊の花を敷流す……この友禅をうちかけて、雪国の町は薄霧を透して青白い。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "簪の白菊も冷いばかり、清く澄んだ頬が白い。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は白菊、ませの菊、にほひばかりの秋じややら。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂稲の黄ばむ田づらは、をりふしに雀むれ立ち、道ぞひの茅屋の庭に、白菊の盛り見せたる、胡麻と栗並べ干したる、暇ある心に見れば、なかなかに今日は安けし。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂稲の黄ばむ田づらはをりふしに雀むれ立ち、道ぞひの茅屋の庭に白菊の盛り見せたる、胡麻と栗並べ干したる暇ある心に見ればなかなかに今日は安けし。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより二年目、寛永三年九月｜六日主上二条の御城へ行幸遊ばされ妙解院殿へかの名香を御所望｜有之すなわちこれを献ぜらるる、主上｜叡感有りて「たぐひありと誰かはいはむ末※ふ秋より後のしら菊の花」と申す古歌の心にて、白菊と名附けさせ給由承り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより二年目、寛永三年九月六日｜主上二条の御城へ行幸遊ばされ、妙解院殿へかの名香を御所望有之、すなわちこれを献ぜらる、主上｜叡感有りて、「たぐひありと誰かはいはむ末※ふ秋より後のしら菊の花」と申す古歌の心にて、白菊と名づけさせ給う由承候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菊黄菊、大輪の中に、桔梗がまじって、女郎花のまだ枯れないのは、功徳の水の恵であろう、末葉も落ちず露がしたたる。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菊の咲く頃、大屋根へ出て、棟瓦をひらりと跨いで、高く、高く、雲の白きが、微に動いて、瑠璃色に澄渡った空を仰ぐ時は、あの、夕立の夜を思出す……そして、美しく清らかな母の懐にある幼児の身にあこがれた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　また前に言った、もの凄い暗い夜も、年経て、なつかしい人を思えば、降積る霰も、白菊。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斧と琴と菊模様の浴衣こそ菊枝をして身を殺さしめた怪しの衣、女が歌舞伎の舞台でしばしば姿を見て寐覚にも俤の忘られぬ、あこがるるばかり贔屓の俳優、尾上橘之助が、白菊の辞世を読んだ時まで、寝返りもままならぬ、病の床に肌につけた記念なのである。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様子を眺めて、沼田英吉は何かしらぎくりとしたが、さあらぬ風に嘯いて、相手の言葉を待受けた。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
