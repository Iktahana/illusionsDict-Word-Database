        "examples": {
          "standard": [
            {
              "text": "19世紀後半のフランス文学では、マラルメのようなシンボリストが活躍した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の描く絵画には、シンボリスト的な色彩感覚が強く表れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "シンボリストの詩は、言葉の持つ暗示的な力を最大限に引き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "桂華はシンボリストであり、またそれに未練がたつぷりある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからシンボリストでも、思想では霊肉一致だろうが自分の存在では未だ其処までは行って居らんよ。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａがまるで、シンボリストのような手紙をくれた。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
