        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "他人の失敗を嘲笑うような冗談を言うなんて、彼は本当に趣味が悪いと思う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "成金趣味を絵に描いたような金ピカの外装の建物は、周囲の景観から浮いていて趣味が悪い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんな派手すぎる服、どこに着ていくの？ 趣味が悪いよ」と姉に指摘されてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "僕は君に軍刀を手渡し、「どうもこの紐は趣味が悪いね。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊趣味が悪いと言われれば確かにそうなのではあるが、名人、上手の悪妻自慢はこれがなかなか楽しめる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "調度品は明らかに高級志向で、見事なものだが、派手すぎて趣味が悪い。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
