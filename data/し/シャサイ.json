    "definitions": [
      {
        "index": 1,
        "gloss": "corporate bond",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あすこも今社債問題で悩んで居るんだ。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その袋の中よりは、十万｜磅に近き価格のあるアメリカの鉄道の社債やその他巨額の、炭鉱あるいは諸会社の株券などが発見せられたり。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく大胆な強盗が行われたことが判明、一〇万ポンド相当の価値がある米国鉄道社債を初め、炭坑や諸会社の巨額証券が鞄のなかから見つかった。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ゴム園にしましても、例えば欧人園は資本を社債か株式か、とにかく低利で運用しておりますが、日本の方は原価も高く、それに流通資金まで高利です。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "社債の売買応募、金融の仲介、そんなことを主としてるこの商事会社では、微妙な而も単なる数字的な駈引折衝が社員の重な仕事だった。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
