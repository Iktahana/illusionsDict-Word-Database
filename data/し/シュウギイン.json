  {
    "uuid": "433801e9-3ac6-51ab-ab16-81e5606dac8a",
    "entry": "集議院",
    "reading": {
      "primary": "しゅうぎいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
