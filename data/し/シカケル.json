    "definitions": [
      {
        "index": 1,
        "gloss": "to start",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "段々と馴れて來るに從ツて、お房は周三に種々な話を仕掛けるやうになツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、中腹の岩に穴をうがち、爆薬を仕掛けるのだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら過激派でも、あの何も知らない、無力な、温順なツアールとその家族に対して、そんな非常識な事を仕掛ける筈はあり得ない……と心の中で冷笑していたのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この罠を仕掛けるのに協力なんてしてないよな？",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日は忙しくないと見えて爺さんは爐の側に居て種々な雜談を仕掛ける。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは今夜を手始めに、これからたびたびここへ押し掛けて来て、所詮この屋敷にはいたたまれないように仕掛けるのではあるまいかと、林之助はまた疑った。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから人工的に、水晶の糸だの、真空だの、雲母だのという装置をして、その圧力が物理学者の目に見えるように仕掛けるのだろう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「主人と言えば、親にもまさる大切なご恩人、然るにあの素浪人共の手先となって、毒蛇など仕掛けるとは何事じゃ。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの黒住の旦那様が、昔宇都宮藩で御同役だったとかいう市毛の旦那様と二人して、ゆうべこっそり手前を訪れ、あの毒蛇を鞍壺に仕掛けるよう、三十両の小判の山を積んで、手前を欲の地獄に陥し入れたのでござります。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、これは全く奇想天外の名案だと思うが、この一切の装置を、お葬式に使う花筒のなかに仕掛けるのだ。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで先づ江戸にある異人館を一度に燒き拂つて、それから水陸二手に分かれ、陸をゆく者は神奈川横濱へ押寄せて地雷火を仕掛ける。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "地雷火を仕掛ける、鐡砲をうち掛ける、火をつける。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが仕上ると次は車井戸を仕掛ける設備だ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "嚆矢アルテアアメリカに生まれる　一九七三年にテキサスインスツルメンツ社が電卓市場に参入して価格競争を仕掛けると、電卓キットで伸びたＭＩＴＳはたちまち窮地に追い込まれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という社内の強い懸念を、当時から田原氏と組んでいろいろな仕事を仕掛け、その後もいろいろと多方面で仕掛けに仕掛ける文藝春秋の花田紀凱氏が吹き飛ばして実現したという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらから談話を仕掛けると、哲學の話でも學術の話でもする。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらから談話を仕掛けると、哲学の話でも学術の話でもする。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、爆薬をそこに仕掛けるとか、或いは、めりめりと、敵の要塞のかべを破って、侵入する。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、あのようなくだらん磁力砲などを仕掛けるのはよせ」「余計な御忠告だ。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから人巧的に、水晶の糸だの、真空だの、雲母だのと云ふ装置をして、其圧力が物理学者の眼に見えるやうに仕掛けるのだらう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野さんは進んで仕掛けるような相撲をとらぬ、またとれぬ男である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その一本は表門へ、その一本は裏門へ、もう一本は予備として、拙者手もとに保存し置きます」「で、地雷を仕掛ける役は？",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩その悪魔が来て恥ずかしい事を仕掛けるのですもの。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより合一した以上は今度は何か仕掛けるであろうが、怯える心の故に、敵の仕掛は慌てているか、用心しすぎているか、どっちにしても迫力を欠くものにきまっている。",
              "citation": {
                "source": "決戦川中島　上杉謙信の巻",
                "author": "――越後守安吾将軍の奮戦記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "密室にするには、トリックを仕掛けるに、時間を要し、その室に通暁することを要し、犯人がその家の住人であることを、ほゞ確定させてしまう。",
              "citation": {
                "source": "「刺青殺人事件」を評す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人の頭の上へ逆さまに汗臭い油ぎった顔をさし出して、むつかしい挨拶をしむつかしい質問をしかける。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫の処を見ると定さんが旗竿へもたれて浜の方を見ながら口笛を吹いているからそこへいって話しかける。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも求婚の競争者が相当ございましてね」　という意味のようなことを話しかけると、妻は「まあまあ、そんなお話、どうでもいいじゃございませんか」「それよりかまだ山の中でおとうさまがお見残しのとこもございましょう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の氣まぐれの訪問者等は、始めから蒲原氏の事業と名聲を全く知らず、同輩の友人扱ひにして話しかけるさうである。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ人を目当てにしたものか、遺族ないしは会葬者に対して読まれるものだろうか、それとも死者に呼びかける形式で会葬者に話しかけるものだろうか。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
