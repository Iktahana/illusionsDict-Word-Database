    "definitions": [
      {
        "index": 1,
        "gloss": "Shirokiya (department store)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
