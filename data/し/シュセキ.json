    "definitions": [
      {
        "index": 1,
        "gloss": "head",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "埠頭に立てられてある赤い旗のあたりには、ロシアの主席達が二組も三組も手を組んで歩いて行くのが見えた。",
              "citation": {
                "source": "アンナ、パブロオナ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、ふたりのあとを追っかけるようにして、もう一組みの駕籠が同じ仁光寺の門前へ止まったと思われましたが、中から降り立った人の姿をみると、意外やそれはつい先の先まで木魚庵に居合わした同心主席の、あばたの敬四郎とその配下だったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "年初めそうそう大役を仰せつかったっていうなア、きっとあばたの野郎め、与力か、同心主席に出世しやがったにちげえござんせんぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――支那大陸紀元八十万一年重陽の佳日、中国軍政府最高主席委員長チャンスカヤ・カイモヴィッチ・シャノフ恐惶謹言頓首々々恭々しく曰す。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "船客も少く、而も私が一等船客の主席であつた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "急にあたりがまっ暗になって、今にもたおれるかと思いましたが、その時、先生が、この世ならぬ声で、主席助手の方に向って言われた御言葉ではっと我にかえりました。",
              "citation": {
                "source": "手術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "主席助手の方は、極めて落ついた性質でしたから、応急の手当を施されましたが、どうしても血が止まりませんので、私に、Ｔ先生を呼んでこいと仰しゃいました。",
              "citation": {
                "source": "手術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお繁さんの姉さんの方の田中は、中将になって今ワシントンの太平洋会議に陸軍代表の主席として出ている。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクソウルは、タイタニック号でこそ四等運転士だったが、主席舵手として最長年の海上生活の経験を有する実際家上りの腕っこきだった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテリングは長老へ、ロスリッジはその後任の主席補祭へ、夫れぞれの昇格式があるので、教会員の殆んど全部が出席していた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京に着いて宿舎に憩う暇もなく汪精衛主席に会う都合がついたからと公館に挨拶に出かけることになった。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "汪主席はかねて美術に理解のある方だと聞き知っていたが、眼にとまるところに砂子地に鶴を描いた六曲屏風が据えられていた。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "物静かな、大柄な、青年のような汪主席はいまは日本にとっては多く親しまれた風貌であろう。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "お話は通訳を通してのことであるが、汪主席は始終にこにこと微笑を浮べていられる。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまた汪主席にお会いしたときと、違った気持で、まことに感銘の深い思いであった。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり将軍の鼻づらを捉まえて、好きなように引っぱりまわす術を心得ている将軍の主席秘書が、例のホワンスキイ公爵の紹介状にそそのかされて、どんなに彼のために骨を折ってくれても、こればかりは絶対に如何ともすることが出来なかった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜子を主席にした卓へ帰って来たときの彼女は、実に生々して、はじめて見せる顔だった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日は、わが醤主席の密命を帯びてまいりましたもので、きっと博士のお気に入る珍味をもってまいりました」「羊の肉は、くさくて、嫌いじゃ。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、醤主席およびその麾下百万余名は、その重慶にも成都にも、はたまた昆明にも居なかったのである。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、主席はぜひ博士の御好意によって、最近御発明になったあの……」　といいながら、密使は一応四方八方へ気を配った上で、「……あのう、それ、人造人間戦車の設計図をお譲り願ってこいと申されました。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに、私の苦心の要ったことと申したら、主席によろしくお察し願いたい」「それはよろしく察して居る。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも金博士の発明になる人造人間戦車とは……」　油学士は、前後左右、それに頭の上を見渡し、砂漠の真中の一本のユーカリ樹の下には、主席と彼との二人の外、誰もいないことを確かめた上で、「……人造人間戦車とは、ソノ……」「早くいえ。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかお前は、金博士から妖術を教わってきたのではあるまい」　醤主席の言葉は、油学士の自尊心を十二分に傷つけた。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、すぐ腹を立てるから、立身出世が遅いのじゃ」　主席に、一本きめつけられ、油学士は、はっと吾れにかえったようである。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今申した極秘の電波を人造人間隊にかけますと、その人造人間隊は、たちまちソノー、主席はフットボールを御覧になったことがございますか」「余計なごま化しはゆるさん」「ごま化しではございません。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもお気に召しませんか」　　　　　３　醤主席は、今や極上々の大機嫌であった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも生産スピードが鈍いようじゃないか」　醤主席が到着すると、すぐいい出す言葉はこれであった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の中を見ないうちに、このおきまり文句をぶっぱなすところが、主席の得意な嚇かしの手だった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちと、こっちを巡覧していただきましょう」　油学士は、猿が飴玉を口に入れたように頬をふくらませ、主席を案内していくところは、毎朝多少ちがっていたが、結局、主席が最後ににこにこ顔で腰を据えるところは、外ならぬ人造人間戦車の主要部分品であるところの人造人間が、山と積まれている倉庫の前であった。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
