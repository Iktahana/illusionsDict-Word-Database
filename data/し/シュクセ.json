    "definitions": [
      {
        "index": 1,
        "gloss": "one's previous existence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宿世のくるみはんの毬、　　　　干割れて青き泥岩に、はかなきかなやわが影の、　　　卑しき鬼をうつすなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀相にお前は宿世によって情にもろい性質に生れついて来た。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その因と縁のもつれを仮りに宿世と名づけられてある。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして若し、それが宿世の因縁であるとしたら、わたしはあなたと結婚でも何でもします。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらにしても強くは言張り難いが、「然而将門尚与伯父為宿世之讐」といふ句によつて、何にせよ此事が深い怨恨になつた事と見て差支は無い。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙ない宿世か、前世の悪業か、あーあ今日もまた、極楽への行き損じか。",
              "citation": {
                "source": "或る秋の紫式部",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚕一つすら養い得ぬ宿世を哀しみ犬に向いて泣きいると、この犬鼻ひると二つの鼻孔より白糸二筋出る。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために、この世では身を傷り家をほろぼし、来世は地獄に堕つるとも、宿世の業じゃ、是非もござるまいよ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のはじめより泣き濡れし宿世は似たり花うばら。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ併し私はあの時も、いや寧ろ其れよりも前の彈正の君樣との事からしてが、何事も宿世の縁と云ふやうにしか考へられません。",
              "citation": {
                "source": "誠心院の一夜",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも逃れぬ宿世の業じゃ」　弟子たちももう彼のゆくえを探そうとはしなかった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇上州吾妻宿世の縁か魚の棲めない川もある　　　◇魚の棲めない吾妻川の水を眺めて暮らせとは山間特有の美人郷　東京では素顔の女は滅多に見ることは出来ないが、ここでは皆素顔の女ばかりである。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しさは墓のふかみに、あな聞きぬ、『宿世』の脚の忍びありき。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "日のはじめより泣き濡れし宿世は似たり、花うばら。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "五深山の鳥も、悲しびの酒甕に※むしたたりに、醉はざなるまい術なさか、いづれは若い身の性の、さても相似た宿世や。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "倫敦塔は宿世の夢の焼点のようだ。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月性本愛文性本愛文宿世因　　性もと文を愛す宿世の因、錯提長劍草爲茵　　錯つて長剣を提げ草を茵と為す。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿世をば敢て憎まず我涙いと快く涌き出づる日は　作者は仏教の因果観を信ずるものでないだらうから、現在が宿世の結果だなどとは思ふまい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで宿世といふのは従来の観念を借りただけで、ただ現状をといふほどの意味であらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "」翁は、やはり壺をいじりながら、「夜があけると、その男が、こうなるのも大方｜宿世の縁だろうから、とてもの事に夫婦になってくれと申したそうでございます。",
              "citation": {
                "source": "運",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれとうらなり君とはどう云ふ宿世の因縁かしらないが、此人の顔を見て以来どうしても忘れられない。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれとうらなり君とはどう云う宿世の因縁かしらないが、この人の顔を見て以来どうしても忘れられない。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "告朔の※羊は、何れは亡びて行くべき宿世を負うて居る。",
              "citation": {
                "source": "稲むらの蔭にて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風船男」「唇のない殺人鬼」「石膏像に包まれた娘達の死骸」　人目をひく、それらの大活字は、心ある読者を、極度にひんしゅくせしめたと同時に、物ずきな弥次馬共をやんやと喜ばせた。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
