    },
    "definitions": [
      {
        "index": 1,
        "gloss": "louse (esp. a sucking louse)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『虱や、ご生だからたからないでおくれ、私にしつつこくしないでおくれ、おまへはほんとに不愉快だ』そして痒いところへ手をやらうともしなかつた。",
              "citation": {
                "source": "諷詩",
                "author": "―人魚詩社の人たちに與ふ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒眼鏡をかけたスパイは、スパイとして使ひものにならないのと同樣に、所謂「詩人らしい」虚榮のヒステリズムは、文學の不潔な虱だとさへ思つてゐた。",
              "citation": {
                "source": "郷愁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "残っていた連中も、虱つぶしに引っ張られた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした例としては『諸国咄』中の水泳の達人の話、蚤虱の曲芸の話、また「力なしの大仏」の色々の条項を挙げることが出来る。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "虱がわいたとかで、つむりをくりくりとバリカンで刈ってしもうた頭つきが、いたずらそうに見えていっそう親の目にかわゆい。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじは、また、郭進才の場合のように呉の床箆子の附近をさがしまわって、破った、虱のいる肌着が一枚丸めて放ってあるのをつまみ上げ、舌打ちをした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、軍隊の到着以来、小山が、気に喰わない工人達に、虱つぶしに、リンチを加えるのを目撃していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虱は温か味が伝わるに従って、皮膚をごそ／＼とかけずりまわった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士達は、執拗な虱の繁殖になやまされだした。",
              "citation": {
                "source": "チチハルまで",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにこの眼前の生きた自然における現実の統計的物理現象の実証的研究によって、およそ自然界にいかに多様なる統計的現象がいかなる形において統計的に起こっているかを、できるならば片端から虱つぶしに調べて行って、そうしてそれらの現象の中に共通なる何物かを求めることが望ましく思われる。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの不潔な虱と、私の胸の奥の白絹に書かれてある蟻の足跡のような文字とは、本質に於いて全く異るものであるという事には、私も確信を持っているつもりであるが、しかし、その説明は出来ない。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、食った後の指を撮んで、けろりとした顔を上げて、気も無い様子で、「虱だと思ったかね、へへ、違うですが。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌、絲を以て虱を※に懸け、南面して之を臨む。",
              "citation": {
                "source": "術三則",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を入れたら虱を揉み潰すくらいが取柄だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓を學ぶものの、三年凝視の瞳には的の虱も其の大きさ車輪である。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目を避けて、蹲って、虱を捻るか、瘡を掻くか、弁当を使うとも、掃溜を探した干魚の骨を舐るに過ぎまい。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "虱なんぞ一匹も居ない筈だ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには、人々が恐れて近よらないこと、もう一つには毛の中に虱がわくことでありました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しみじみと虱を見てゐると、過去つた旅の十年間が憶はれるのであつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな虱なんかに、いつか親しむやうになつてしまつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士はこんな風に考へてゐても仕方がなかつたので、掌の虱を始末することにした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして中へ虱を入れると、削りとつた木屑で穴をふさいでおいたのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと武士は去年の虱を憶ひ出した。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの虱はもう死んでしまつたらうか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると去年、虱を閉ぢこめておいた箇所が見つかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士はふたをこじり出して見ると、中に去年の虱は、小さい体が一層小さくなつて死んでゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年間も何も喰べずにゐたのだから、虫が死ぬのは当りまへだと思つて、武士は虱の死骸を掌にのせた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "温い陽ざしにあてて、よく見てゐると、虱のこまかい足がかすかに動いた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "虱のしなびた小さい体の中に、まだ僅かに命が残つてゐたのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで武士は面白くなり、腕をまくつて、柔らかなところに虱をのせて見た。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
