        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スポーツ選手は、ドーピング検査のためにシャペロンの指示に従う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "試合会場には、厳格なドーピング検査を行うためのシャペロンが配置されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、ドーピング検査の際、常にシャペロンの監視下で行われることに不満を感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
