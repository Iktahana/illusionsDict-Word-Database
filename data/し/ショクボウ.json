[
  {
    "uuid": "3f5770a4-2e06-566c-bfcc-c402265b2e9a",
    "entry": "嘱望",
    "reading": {
      "primary": "しょくぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
