[
  {
    "uuid": "27796544-2e3e-5ccb-baca-1b51445737ee",
    "entry": "収納",
    "reading": {
      "primary": "しゅうのう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
