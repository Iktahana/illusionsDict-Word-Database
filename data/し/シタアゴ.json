        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下顎がべろべろしてるぢやないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　下顎骨の長い、獰猛に見える伍長が突っ立ったまゝ云った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尉は下顎骨の張った、獰猛な、癇癪持ちらしい顔をしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山は、下顎骨が燐の毒で腐り、その上、胸を侵され、胴で咳をしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、小山の下顎骨の落ちこんだ口元が、苦るしげに歪むのを見た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨壊疽で義歯を支えていた犬歯が抜け落ち、下顎の門歯がとれてしまったのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾人か、幾十人かが最も猛烈な黄燐の毒を受けて、下顎を腐らしてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下顎骨が腐蝕し、胴ぐるみの咳をする小山は、自分の背後に控えている強大な勢力を頼もしく意識した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母は下顎をはげしくふるわせ、二度も三度も真白い歯を打ち鳴らした。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下顎骨の左の方に暗紫色の痕が見える。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い浴衣でも着たような人の姿が見えたので、ふとその顔を見ると、小さな顔の下顎をかくすように大きな舌がだらりと垂れていた。",
              "citation": {
                "source": "餅を喫う",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸にまた高く札うち、蓮葉なる金切ごゑと老いたるが絶えず客よぶ、――と見る、ただ赤丹剥げたる閻魔王、青き牛頭馬頭、講釈のなかばいちどにがくがくと下顎鳴らす。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "下顎骨が形よく精巧に発達していて、唇が大きかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "下顎の出た猿のようなこの老人は、どこへでもしゃあしゃあと押しだして往って、何人とでも顔馴染になりました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬骨が秀でて、鉤鼻は大きく、頤はこけて、下顎は下り、白い大きな眼が突き出ている彼の顔の表情は、一般の事物に対する一種の頑固な無頓着さを示しているとはいえ、あらゆる模倣や叙述なども及ばないくらいに、実にしかつめらしいまじめくさったものだった。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "レッグズは自分の立っていたところの近くの壁にもたれかかって、あの下顎をいつもよりもっと低く下げ、眼をできるだけ大きく見開いた。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "下顎を後下方へ引っ張っているように、口を開いているので、その長い顔が殆ど二倍の長さに引き延ばされている。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜脱臼したのなら、直ぐに整復が出来る見込です」「遣って御覧」　花房は佐藤にガアゼを持って来させて、両手の拇指を厚く巻いて、それを口に挿し入れて、下顎を左右二箇所で押えたと思うと、後部を下へぐっと押し下げた。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下顎の脱臼は昔は落架風と云って、或る大家は整復の秘密を人に見られんように、大風炉敷を病人の頭から被せて置いて、術を施したものだよ。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介が動物を挟み困しめた記事は例の『戦国策』の鷸蚌の故事もっとも顕われ、其碩の『国姓爺明朝太平記』二の一章に、旅人が乗馬して海人に赤貝を買い取って見る拍子にその貝馬の下顎に咋い付き大いに困らす。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "木部はその性格ばかりでなく、容貌――骨細な、顔の造作の整った、天才｜風に蒼白いなめらかな皮膚の、よく見ると他の部分の繊麗な割合に下顎骨の発達した――までどこか葉子のそれに似ていたから、自意識の極度に強い葉子は、自分の姿を木部に見つけ出したように思って、一種の好奇心を挑発せられずにはいなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ葉子がどうしても弁護のできないのはますます目立って来た固い下顎の輪郭だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し振り仰いで顔を映すと頬のこけたのがさほどに目立たないけれども、顎を引いて下俯きになると、口と耳との間には縦に大きな溝のような凹みができて、下顎骨が目立っていかめしく現われ出ていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「左の手で頭のてっぺんを押えつけて、右の掌面でいきなり強く下顎をこづき上るんです。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に又、屍体の所々――両方の掌、肩、下顎部、肘等の露出個所には、無数の軽い擦過傷が痛々しく残り、タオル地の寝巻にも二、三の綻ろびが認められた。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に、肩、下顎部、肘等の露出個所に与えられた無数の軽い擦過傷。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ロープは彼の体の所々、例えば肩、下顎部、肘等の露出個所に無数の軽い擦過傷を与え、寝巻の一、二個所を引き裂いて、更に頸部と胸部に絡み附きます。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "種別を問はず口論、憶測、談笑等の彼等の所謂原始性が慕はれて、私は秘かにナルシサスを相手に、蔭では、この下顎を上下――時には左右に歪め、舌を巻き、喉を鳴らせる生れながらに慣れた発声法を用ひて猥らな言葉なども放たずには居られなかつた。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は火鉢の傍まで行くと少し下顎を膨らせた横顏を赧らめて故意に落ち着き出した。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりしたあごの線が意志の強さを現わしている。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
