  {
    "uuid": "7575a287-a4d0-5372-8603-6767568f1a1a",
    "entry": "新造",
    "reading": {
      "primary": "しんぞう",
      "alternatives": [
        "しんぞ"
      ],
      "is_heteronym": false
    },
    "grammar": {
