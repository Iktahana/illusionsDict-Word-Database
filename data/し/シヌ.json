      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to die",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死ぬ前の日に、彼は不思議な夢を見たと妻に話した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢見ることによって生きた詩人等は、また夢見ることの中で死ぬのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（芥川君は死ぬ少し前、白秋氏の「近代風景」といふ雜誌に私の評論を出してる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは、死ぬ気だ。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬ気でものを書きとばしている男。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿は、こんな大きさで、こんな色をして、しかも秋に実るものであるから、これこれの意味であろうなど、ああ死ぬるほどいやらしい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬと思っていたのは、私だけではなかった。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の苦しみを見かねて、私が、これから毎日、Ｍ・Ｔの筆蹟を真似て、妹の死ぬる日まで、手紙を書き、下手な和歌を、苦心してつくり、それから晩の六時には、こっそり塀の外へ出て、口笛吹こうと思っていたのです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、死ぬなんて、いやだ。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬなんて、いやだ。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあしたあたり死ぬかも知れないからね」　それからというもの、私たちはその甘酒屋で実にしばしば落ち合った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬことだけは、待って呉れないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうの愛情というものは死ぬまで黙っているものだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬほど好きなひとだもの。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は生れたときから死ぬるきわまで狂言をつづけ了せる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こうしてお互いに生きているというのは、なんだか、なつかしいことでもあるな」「人は誰でもみんな死ぬさ」",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生もう死ぬるものでございませうか」「駄目らしいね」医者は低声でそれを答へた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としたら、読みたい詩の百分の一も読まずに死ぬであらうと思へば、自分の子供にも詩をやつて貰ひたいくらゐのものなのだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「持つて生れた物は、俺の死ぬまで量は減じようとも続くであらう。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにわれら死ぬ時に心の杖となるものがあるなら、ありし日がわれらの何かを慄はすかの何か！",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、俺は何時死ぬるのか、明日か明後日か……――やい、豚、寝ろ！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは汝の妻死ぬるとも尚離れざるべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横顔は著しく痩せてはいたが、やがて死ぬ人とも見えなかったのである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は建築のアカデミーでシンケルが死ぬまでここに住まっていたそうである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬか、馬鹿になるか、と思われたそうであるが、幸いに死なずにすんでその代り少し馬鹿になったために、力に合わぬ物理学などに志して生涯恥をかくようになったのかもしれない。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎は必ずなおると定ったわけでもなし、一つ間違えば死ぬだろうに、あの時は不思議に死と云う事は少しも考えなかったようである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姪は死ぬる少し前まで、わたしが治ったら何処へ行くとか、何を買うとか、よくそんな事を云っていたので、死んでからはみんなでそのことを云ってよく泣いた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつまで経っても、死ぬと云うことは許されない。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ君は、持つてゐたステツキを振り上げて、悠然とその犬を撃退してくれたのですが、私は一時、死ぬばかりでありました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腫物で死ぬ奴も無いだらう、などと強がりを言つて、醫者に見せようともしませんでしたが、どうも、夜半ひとり眼覺めて、いろいろのことを考へると、なかなかに心細くなるのでした。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
