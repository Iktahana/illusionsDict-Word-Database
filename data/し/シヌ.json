[
  {
    "uuid": "6f43009d-afad-5566-9b61-55fce72300e5",
    "entry": "死ぬ",
    "reading": {
      "primary": "しぬ",
      "alternatives": [
        "ﾀﾋぬ"
      ],
      "is_heteronym": false
