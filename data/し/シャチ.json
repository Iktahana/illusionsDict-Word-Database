  {
    "uuid": "34e8320c-5191-5c2d-9d72-516a3138b017",
    "entry": "社地",
    "reading": {
      "primary": "しゃち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "land owned by a Shinto shrine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水神の社地を浮島といひて、洪水にも浸さるゝことなき由をもて名あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり神職もなく、財産、社地も定まらざる廃社同前のもの、また一時流行、運命不定の淫祠、小祠の類を除き、その他在来の神社を確立せしめんと力めたるもののごとし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "残れる十一万ばかりの神社もなお減ずべき見込み多ければ、本年度より地方官を督励して一層これを整理し、また一方には神社境内にある社地を整理せしむべし、とその筋の意嚮を載せたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に新宮には、ちょうど一昨年中村氏が議会へこのことを持ち出さぬ前にと、万事を打ち捨てて合祀を励行し、熊野の開祖｜高倉下命を祀れる神倉社とて、火災あるごとに国史に特書し廃朝仰せ出でられたる旧社を初め、新宮中の古社ことごとく合祀し、社地、社殿を公売せり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来地方の諸神社は、社殿と社地また多くはこれに伴う神林あり、あるいは神田あり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに何の心得なき姦民やエセ神職の私利のため神林は伐られ、社地は勝手に掘られ、古塚は発掘され、取る物さえ取れば跡は全く壊りおわるより、国宝ともなるべく、学者の研究を要する古物珍品不断失われ、たまたまその道の人の手に入るも出所が知れぬゆえ、学術上の研究にさしたる功なきこと多し。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ穿鑿せしに、西牟婁郡の鳥巣という浦の社地小丘林中におびただしく自生せり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "オガタマノキは、神道に古く因縁深き木なるが、九州に自生ありというが、その他に大木あるは紀州の社地のみなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷川士清の和訓栞「くぬぎ」の條に云く、神名式伊勢國度會郡に棒原神社見ゆ、こは棒字字書の義に違ひたれば欅原にて訓もぬをすに誤りたる也社地今田邊郷淺管村に在り萬葉集に　度會の大河のへの若歴木われ久ならば妹戀ひんかもとあり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "この神社も古雅な、なかなか結構な社地で、とても幽邃なところでして、この辺からすでに桜がちらほら見えます。",
              "citation": {
                "source": "女の話・花の話",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　この社地の隣りが花の寺です。",
              "citation": {
                "source": "女の話・花の話",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "社地は古の安楽寺の地なり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜の花に至っては、信玄公が好まれるだけに、躑躅ヶ崎のお館を巡り左右前後に延びているこの甲府のいたるところに爛漫と咲いているのであったが、わけてもお館の中庭と伝奏屋敷と山県邸と神明の社地とに多かった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此行事の最後に行はれるのは、田遊びと称へるもので、宣命と称するものを、社地の一部で唱へて居る間に、芸能がすべて結着する様になつて居るのです。",
              "citation": {
                "source": "信州新野の雪祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢をつがへて、一度は社殿の屋根に向けて射放ち、今一度は、社地の境に居る鬼に向けて射る行事があります。",
              "citation": {
                "source": "信州新野の雪祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、此を古い形にして見ると、主神に対して、大人神が附属して、其社地を護つて居るのと、一つでなければならない。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "社地の杉山の立ち木何本。",
              "citation": {
                "source": "神道の史的価値",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい潮流に乗って北洋から太平洋岸に沿って下ってきた鱒は、三月中旬には銚子、香取、取手、権現堂、妻沼、本庄裏へと、次第に上流へ上流へと遡ってきた鱒は、既に三月中旬にはわが上新田の雷電神社地先の利根の激流に姿を現わすのである。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕橋畔の料亭八百善、牛島神社の舊社地、弘福寺裏の富田木歩の家、淡島寒月の梵雲庵、饗庭篁村の家、幸田露伴の蝸牛庵、百花園の御成屋敷。",
              "citation": {
                "source": "桜もち",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜花は上野の山内のみならず其の隣接する谷中の諸寺院をはじめ、根津権現の社地にも古来都人の眺賞した名木が多くある。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹から来た門人らの説明によると、これは片桐春一が畢生の事業の一つとしたい考えで、社地の選定、松林の譲り受け、社殿の造営工事の監督等は一切山吹社中で引き受ける。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "予詣て社地を見るに式内の社には不相応の地にして尤も遺憾たり、古社地淀河組の内あり。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物々しい番兵の交代はベルリン名物の一つであったが、実際いかにも帝政下のドイツのシンボルのように花やかでしかもしゃちこばった感じのする日々行事であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花やかにしゃちこばった気分がドイツ大学生特にいわゆるコアー学生の常住坐臥を支配しているように思われるのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鼻の穴に指を突っ込んで、鉄筋コンクリートのように、鼻毛をしゃちこばらせている、コンクリートを除りたかったのだが一分間に十才ずつ吐き出す、コンクリートミキサーに、間に合わせるためには、とても指を鼻の穴に持って行く間はなかった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷い、しゃちこばった顔付が見えるようだ。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人によると妙にしゃちこばって土偶か木像のように硬直して動かないのがある。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩時間に廊下へ出て腰かけて煙草でも吹かしていると、自然にのどかなあくびを催して来る、すると今までなんとなしにしゃちこばってぎこちないものに見えた全世界が急になごやかに快いものに感ぜられて来て、眼前を歩いている見知らぬ青年男女にもなんとない親しみを感じるようになるのがわれながら不思議なくらいである。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいさんに見られた柱は、まるで木のように堅くなって、足をしゃちほこばらせて、わきめもふらず進んで行き、その変なじいさんは、もう恭一のすぐ前までやってきました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "垢染た煎餅布団でも夜は磯吉と二人で寝るから互の体温で寒気も凌げるが一人では板のようにしゃちっ張って身に着かないで起きているよりも一倍寒く感ずる。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
