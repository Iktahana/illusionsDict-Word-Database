[
  {
    "uuid": "84bc9a9f-0054-54a4-8098-dd05c25f3cb7",
    "entry": "白目",
    "reading": {
      "primary": "しろめ",
      "alternatives": [
        "はくがん"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
