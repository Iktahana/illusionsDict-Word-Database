[
  {
    "uuid": "aa79f75a-95c4-5ee7-8134-e8d213b8f185",
    "entry": "謝する",
    "reading": {
      "primary": "しゃする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊"
      ],
