      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to thank",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "素直に讀者の聲を聞き、自身のまづしい仕事を、そんなにも懇切に讀み、考へて呉れたことに就いては、どんなに感謝するかわからない。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは日々ここに居て罪を悔い王に謝する。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜誌「日本詩人」が自分のために評傳號を出してくれたことを感謝する。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は批評家の御注文に應ずべく神樣が僕及び人類を造つて呉れなかつたことを感謝する。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、今夜こそ、俺れゃ、お前に感謝するぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人翁に見送られて門を出て自動車に乗ると、さすがに主人翁の言い知れぬ平民的な好意ぶりに感謝する気になった。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にして思う、僕はハイカラの精神の我が桂正作を支配したことを皇天に感謝する。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それより彼は開墾の困難なことや、土地に由つて困難の非常に相違することや、交通不便の為めに折角の収穫も容易に市場に持出すことが出来ぬことや、小作人を使ふ方法などに就いて色々と話し出した、其等の事は余も札幌の諸友から聞いては居たが、彼の語るがまゝに受けて唯だ其好意を謝するのみであつた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と飽くまで親切に言つて呉れるので、余は実に謝する処を知らなかつた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ほとばしる嗚咽と共に男の胸に顔を埋めた女――男に謝する女の心、男を恨む女の心。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は随分、幸福に平和に満ち、神様に感謝することを一刻も忘れずに、世界のあらゆるものと仲よくし乍ら、せっせと働いて棲み合ったため、運命の種子はいつも二つの甕のなかに、みずみずしく育って居た」「お祖父さんその頃でも、綺麗な花が、汚ない土から、咲き出して居たのですか？",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆僧　――（一度に声を合せ）清浄法身本体の生命、円満報身導きの生命、相に在す現実の生命、今われらに食を与えて道に進む行者の歩みを健かならしめらるるを感謝する。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝なんざ崖に湧く雲の中にちらちら燃えるようなのが見えて、もみじに朝霧がかかったという工合でいて、何となく高峰の花という感じがしたのに、賢君の丹精で、机の上に活かったのは感謝する。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、神に謝するがごとくにいった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうか、」といったが、我ながら素気なく、その真心を謝するにも、怨をいうにも、喜ぶにも、激して容易くは語も出でず。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此驟雨があつたばかりに、其後深く天の恩惠を感謝する時が來た。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも手に／＼双眼鏡を携へ、白巾を振り、喜色を湛えて、諸君の好意を謝する事であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は愛子がさう云ふ技巧に浮身をやつして居るのを感謝するのが当然であると思つても、俺はかうして羽がひじめにされて行くんだと云ふ考へが先に立つ。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "といいつつ女房を見返りて、「おい、御女中をお連れ申して進ぜなさいと、命つけられて内儀は恐々手を曳いて導けば、怪しき婦人は逆らわず、素直に夫婦に従いて、さもその情を謝するがごとく秋波斜めに泰助を見返り見返り、蹌踉として出行きぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭の光輝に照らされたる、人形の瞳は玲瓏と人を射て、右眼、得三の死体を見て瞑するがごとく、左眼泰助を迎えて謝するがごとし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勞を謝するに酒もない。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘か、それとも因果何とか言ふ妾であらうか――何にしろ、私は、其の耳かくしであつたのを感謝する。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高綱　　子之介が高綱を恨まぬは、心からその罪を謝するといふ人のまことに感じたのではござるまいか。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『松』を毎号贈って下さる浜松の同人諸君に感謝する。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "近來、著るしく廢頽的傾向を帶びてきた私の思想に就いて、君が賢こい注意と叱責とを與へられたことを感謝する。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両君の好意を感謝する。",
              "citation": {
                "source": "『心』自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は、だんだん老紳士に対する好感が増して行き、慈しむような眼ざしで青年の姿を眺めていると、老紳士は、暗黙の中にそれを感謝するらしく、「だが、よく、むす子さんを一人で置いて来られましたな。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、真面目に規矩男の洞察に今更感謝する気にもなれなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きている事を神さまに感謝するだろう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹はむしゃくしゃすると同時に堪えぬなつかしさの痛み、悔いないでよいことへの悔い――そういったことでごちゃごちゃになっていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
