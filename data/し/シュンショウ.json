[
  {
    "uuid": "e9a69006-e658-5bf9-a34c-e7a91a921fc9",
    "entry": "春宵",
    "reading": {
      "primary": "しゅんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "spring evening",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女｜倶して内裏拝まん朧月　春宵の悩ましく、艶かしい朧月夜の情感が、主観の心象においてよく表現されてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春宵怨」とも言うべき、こうしたエロチカル・センチメントを歌うことで、芭蕉は全く無為であり、末流俳句は卑俗な厭味に低落している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折釘に烏帽子かけたり宵の春春の夜に尊き御所を守る身かな春雨や同車の君がさざめ言ほととぎす平安朝を筋かひにさしぬきを足で脱ぐ夜や朧月　引例を見ても解るように、特に春の句においてそれが多いのは、平安朝の優美でエロチックな文化や風俗やが、春宵の悩ましい主観において、特にイメージを強く与えるためなのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春宵一刻、價千金、か。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春宵一刻、――」などと、つまらぬ事を呟きながら木の虚から這ひ出ると、オヤ　ナンデセウ　サワグコヱミレバ　フシギダ　ユメデシヨカ　といふ事になるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は言わばたわいもない春宵の空想に過ぎないのであるが、しかし、ともかくもわれわれが金城鉄壁と頼みにしている頭蓋骨を日常不断に貫通する弾丸があって、しかもほんの近ごろまではだれ一人夢にもそれを知らずにいたというだけは確かな事実なのである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィッチを捻って昼の客をそのまま夜の客に更めて照し出した軒並みのキャフェのテラス――春宵のアンニュイに導かれて足はおのずと静なラシイヌ通りに踏み入る。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春宵一刻、価千金、か。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（とりとめもない夢の氣分とその抒情）春宵嫋めかしくも媚ある風情をしつとりとした襦袢につつむくびれたごむの　跳ねかへす若い肉體をこんなに近く抱いてるうれしさあなたの胸は鼓動にたかまりその手足は肌にふれほのかにつめたく　やさしい感觸の匂ひをつたふ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の詩人は悩ましげにも、「春宵一刻価千金」と歎息している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の夜の暖かい静かな室、春霞の軒に煙る浅春の宵――凝とたゞひとり机の前に坐つてゐると、大抵の方はこの法悦の気持に入ることが出来るだらうと思ひます――意味のない悲しさと悦ばしさとに感ずる淡い涙、支那の有名な詩人白楽天が「春宵の一刻価千金」と云つたのも、つまり「法悦」の喜びをうたつたのであります。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "松林桂月氏の『春宵花影』は題材的にも桜花を扱つて適当であつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂月の『春宵花影』や古径の『雪』のやうな写実的手段でなければ西洋人の悟性中心的な考への中に侵入することは不可能だと思ふ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "」純造は仕方がなくワザと応揚に駒下駄を引きずつて「春宵の一刻……と云ふ詩を知つてるかえ――僕はね昨べもこんな風に独りで随分遅く迄散歩したんだよ。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食後、春宵漫歩としやれる、伊万里も美しい町である、山も水も、しかし人はあまり美しくないやうである。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるまると肥つた紳士が一人、「詩韻含英」を拡げながら、未だに春宵の詩を考へてゐる。",
              "citation": {
                "source": "春の夜は",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "君乗せし黄の大馬とわが驢馬と並べて春の水見る夕　春宵一刻千金とまでは進まぬその一歩手前の夕暮の気持を象徴的に詠出したものであらうか。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "君帰り物語りすと見しは夢、ふとうたたねの春宵の夢君住むは西方百里｜飛鳥の、翼うらやみ大空を見ると、だらしがないほど彼女は恋しさを告白するようになった。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの好女の数の多い情人の一人として春宵のつれづれを慰めるために忍んで来た。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルタ切れどよき占も出ず春の宵　　　より江呪ふ人はすきな人なり紅芙蓉　　　かな女　春宵美しいびろど張の椅子に一人の女が、カルタの札を白い指で弄びつつ人待顔に、ひとり占をしている。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してあゝ、翠帳暖に春宵を度るの処、膏雨桃李花落つるの時、松殿の寵姫と共に、酔うて春に和せる往年の栄華、今はた、何処にかある。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに、一刻千金｜春宵のながめよりも儚なき青春よ！",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、なあに、これくらゐはね」　仏人オマアル氏著「球戯考」の序文に曰く　――春宵朗らかに球を撞けば、胸に愁ひあるを忘れ、秋夕粛やかに棒を滑らせば、頭痛忽ちにして去る――と。",
              "citation": {
                "source": "玉突の賦",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "２未婚婦人はそが暁近き薔薇色の感情に高揚されて浪漫主義的な、華やかな悩ましき春宵の恋を夢むおお恋！",
              "citation": {
                "source": "未婚婦人",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "行燈に描かれた芸人の名を見上げてゐるとき、場内から遠く花やかに太神楽や手品の囃子のながれて来るのも、じつに春宵である。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "色彩今野大力色彩なければ　我ら生はあらざらむ春宵の薄暮わが双眼の全き視神経は麻痺して宇宙は皆灰一色となり感ずべき何ものもなし心ただ焦燥して形なく踊れどもみたすべき何ものもなしああ春宵の薄暮奪われし色彩のかえらじ燃ゆるなき古城址の焔と消えんのみ",
              "citation": {
                "source": "色彩",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "春宵漸く漫歩によし。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り怪しむかの天台の二女、果して如何なる者なれば、途に迷える劉阮を誘惑し、単に邀えて、之を我家に容るるのみならず、之に羊脯を与え、之に牛肉を食わしめ、之を閨房に導き、之と春宵の戯を為し、以て神仙の名を汚さんとするか。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
