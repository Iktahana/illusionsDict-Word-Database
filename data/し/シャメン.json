    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pardon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "紙入れの中味を調べると、金と一緒に出て来たのが仇討赦免状（大写）。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎喜んで中の赦免状を役人に示す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衛門赦免状を書くとなりひらに渡す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても孤島に流されているアグリパイナと、ネロの身の上を恐ろしきものに思い、可哀そうでならぬから、と誰にとも無き言いわけを、頬あからめて呟きつつ、その二人への赦免の書状に署名を為した。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赦免状を手にした孤島のアグリパイナは狂喜した。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで元文四年三月二日に、「京都において大嘗会御執行相成り候てより日限も相立たざる儀につき、太郎兵衛事、死罪御赦免仰せいだされ、大阪北、南組、天満の三｜口御構の上追放」ということになった。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様の事に候はゞ、大将四郎にて御座候とも、罷り出でたる者これ在るに於ては、御赦免罷り成る可きの由に御座候事。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪冬の陣の媾和には、初め家康から、一、浪人赦免、二、秀頼｜転封の二条件を提議し、大阪方からは、一、淀君質として東下、二、諸浪人に俸禄を給するために、増封の二条件を回答した。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで元文四年三月二日に、「京都に於いて大嘗會御執行相成候てより日限も不相立儀に付、太郎兵衞事、死罪御赦免被仰出、大阪北、南組、天滿の三口｜御構の上追放」と云ふことになつた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に正氏が謫所へ、赦免状を持たせて、安否を問いに使いをやった。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時キリストを通して愛の神を知るに至れば、神観一転化を経て赦免の恩恵を実感し以て光明に入るのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝の御｜愛寵を裏切って情人を持った点をお憎みになったのであるが、赦免の宣旨が出て宮中へまたはいることになっても、尚侍の心は源氏の恋しさに満たされていた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒人｜遮二無二豕無数を殺した後、神の怒り最早安まっただろとて豕を赦免の令が出た。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方には親方の庄蔵から町名主にその事情を訴えて、六三郎の赦免をしきりに嘆願したので、結局六三郎はお構いなしということで免された。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府も特に評議の上これを許して、茂左衞門赦免の上使を遣はしたのであつたが、時僅かに遲れ、井戸上村まで來ると處刑濟の報に接したのであつたさうだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府も特に評議の上これを許して、茂左衛門赦免の上使を遣わしたのであったが、時僅かに遅れ、井戸上村まで来ると処刑済の報に接したのであったそうだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「不服か」「でも、てまえの密貿易の科は、すでに長崎お奉行さまからご赦免になっているではござりませぬか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "当分と云っても、もう二年以上になるが、彼はまだ本当の赦免に逢わない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父行綱が御赦免を……」　言いかけて、彼女は恐るおそる縁の上に平伏した。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩賞として父の赦免を願うか」　この願いは二様の意味で忠通のこころを動かした。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして自分の眼の前には、美しい乙女が泣いて父の赦免を訴えているではないか。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の赦免を願おうためか。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は昨夜、泰親の使いとして、弟子の一人がそれがしの許へ忍んでまいりました」「赦免の訴えか」「いや、今一度、降魔の祈祷を……」「むむ」と、頼長は烏帽子をかたむけた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むすめ」「らしゃめん」というような言葉さえそのはしたない言葉の中には交じっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春見た時はどこからしゃめん臭いところがあったが、今見ると縞お召の単衣を着て、髪もインテリ婦人のように後ろで束ねて、ずっと綺麗であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その異人館の大番頭が、らしゃめんの口を一つ欲しがっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつは耳よりだね」　慾に目のないお倉婆あが、耳をふくらませると、金公が続いて、一口にらしゃめんというけれど、いかに西洋人の相手になることが、へたな日本人の相手になることよりも、有利な事業であるかを説いて、お倉婆あの耳をいよいよふくらませる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがねえ、話の口は、そのらしゃめんにもなかなか先方に好みがあって、第一、芸妓や、女郎衆の、金で自由が利く奴ではいけず、そうかといって、伊豆の下田の唐人お吉なんていう潮風の染み過ぎたのでもいけず、お膝元の固いところでは、いくら困っても、娘をらしゃめんにでも仕立ててみようというほどに開けた奴はいねえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "らしゃめん、という語は子供仲間の会話にもよく使われたように覚えている。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどそれも南京らしゃめんと云うと何か違った意味をもって聞えた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
