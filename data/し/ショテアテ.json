        "examples": {
          "standard": [
            {
              "text": "給与明細には、基本給の他に諸手当が記載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社は社員の福利厚生として、通勤手当や住宅手当などの諸手当を支給している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "転職の際、基本給だけでなく諸手当の内容もしっかり確認した方が良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "勤労所得税がより高率にかけられることと二千四百円ベースには今日の諸手当が全部合算されてしまうからである。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずその保障の諸手当をいって見ますと、寄宿を出て一家を構えたものには固定給の三割を住宅手当として支給し、つづいてその家族の中に老人のあるものには老人手当（一人四円）、さらに子供のあるものには子供手当（四円）というのを出しています。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
