        "examples": {
          "standard": [
            {
              "text": "長時間、暗い場所でスマートフォンを使うと、視力障害の原因になることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "交通事故の後遺症で、彼女は重度の視力障害を負ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "早期発見と適切な治療が、視力障害の進行を遅らせる鍵となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、病気の筆頭は結核で、その次は脚気、視力障害がつづいている。",
              "citation": {
                "source": "若きいのちを",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四二年七月、巣鴨拘置所で熱射病のため危篤に陥ってからのち、一年ほど言語障害と視力障害に苦しみました。",
              "citation": {
                "source": "文学について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "視力障害はこんにちもつづいています。",
              "citation": {
                "source": "文学について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
