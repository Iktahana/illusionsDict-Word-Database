[
  {
    "uuid": "cd578935-5531-5ff6-8f5a-0cb8b5c7e66d",
    "entry": "職田",
    "reading": {
      "primary": "しょくでん",
      "alternatives": [
        "しきでん"
      ],
      "is_heteronym": false
    },
    "grammar": {
