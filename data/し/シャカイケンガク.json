        "examples": {
          "standard": [
            {
              "text": "明日は待ちに待った社会見学で、クラス全員で最新鋭の自動車工場を見に行く予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "社会見学の帰りに書いた作文がクラスの壁に張り出され、みんなから褒められて嬉しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "弁当を持って行く社会見学は、勉強というよりも遠足のような気分でワクワクする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "高松宮が大阪で社会見学をした――と云ってもキャバレーやバーめぐりであるが、どたばたキャーキャーの記事。",
              "citation": {
                "source": "ジャーナリズムの航路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は勇気のある社会見学の近代女性として、彼女の眼にうつったらしい。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会見学に働いてみるのも悪くはないが、当りまえの奥さんに落ちつく以外に手のなさそうな娘である。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚までの社会見学に働いてみる程度の軽い気持でなければいけないのよ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
