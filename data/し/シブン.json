[
  {
    "uuid": "a6fe3430-bf21-5c98-98fb-de6dfa71f752",
    "entry": "四分",
    "reading": {
      "primary": "しぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
