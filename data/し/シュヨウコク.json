        "examples": {
          "standard": [
            {
              "text": "地球規模の環境問題について、主要国が利害を超えて一致協力することが強く求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "中東の紛争解決に向けた和平案について、世界の主要国が秘密裏に協議を重ねている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "主要国の経済政策の変化は、為替市場や世界の株価に即座に大きな影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "第三　人間山の歩いてもいゝ場所は主要国道だけに限られている。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四　人間山が主要国道を歩く際には、朕の良民、馬、車などを踏みつけないよう、よく注意すること。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる社会においては、大きな国家の主要国内取引と称せられるもの、すなわち都市と地方との間に行われる取引は、必然的に外国貿易とならざるを得ず、そして外国穀物の輸入はその存在にとって絶対に必要である。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自らのエンジンを始動し、運転手なしにとある主要国道に乗り出した。",
              "citation": {
                "source": "西洋科学は素晴らしい",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
