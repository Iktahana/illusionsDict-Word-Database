    "definitions": [
      {
        "index": 1,
        "gloss": "success in life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから、いつまで経っても、出世できない様子です。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頻りに早く出世したい気持がして来て、その気持に引き摺られるやうに父のゐない部屋を歩き、歩いた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しまだ私には出世したい野心がある。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人はこれを、雀大臣と呼んで、この出世も、かれの徃年の雀に對する愛情の結實であるといふ工合ひに取沙汰したが、しかし、お爺さんは、そのやうなお世辭を聞く度毎に、幽かに苦笑して、「いや、女房のおかげです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころは既に広重の出世作、『東海道五十三次』（保永堂板）は完成され、葛飾北斎の『富嶽三十六景』が、絵草紙屋の店頭に人目を驚かしていたのであるが、その地図にある定火消屋敷で、広重が生れ、西の丸のお膝下で、名城と名山の感化を受けていたのだと思うと、晩年に富士三十六景の集作があったのも、偶然でない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別体」bettai「出世」shut-she→shusshe「悉皆」shit-kai→shikkaiハ行音の前では促音となり同時にハ行音はパ行音となる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩集「思ひ出」は、或る意味に於て、實に白秋氏の出世作であつた。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「芸は大根でも　家柄のある奴は、親の威光で　ドンドン出世する　皆んな家柄のお蔭だ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「可哀そうな兄さんの　出世の道　妨げたばかりか」　雪枝尚も叫ぶ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "話し振りから、低級な立身出世を夢みていることがすぐ分った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例を申せば、無塩君は醜婦でありましたが破格の出世を致しました。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人はたぶん出世のできない人であろうと思う。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもう、命が惜しくて、金が惜しくて、そうして、出世して妻子をよろこばせたくて、そのために徒党を組んで、やたらと仲間ぼめして、所謂一致団結して孤影の者をいじめます。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ私のすがたにどこやら似たところのある異國の一青年が、活動役者として出世しかけてゐたので、私も少しづつ女の眼をひきはじめた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ私のすがたにどこやら似たところのある異国の一青年が、活動役者として出世しかけていたので、私も少しずつ女の眼をひきはじめた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出世を競り合うて呪咀い合うものと聞いた、蔵元屋の前の御寮さんが、コッソリ里子に遣ったままにして置いた芋屋の娘……正しく蔵元屋の血統を引いた、お熊さん同様の一点の疵もない卵の剥き身、生さぬ仲の芋屋の老人夫婦を真実の親と思い込んでの孝行振りまで、お熊さんと瓜二つの生き写し。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬骨折って鷹に取らるるか……腕も知恵もないザマで立身出世ばっかりしたがる上役の下に付いとっちゃあ堪らんのう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は私の顔を天眼鏡で覗いて見たり、筮竹をがちゃがちゃいわして見たり、まるで人相見と八卦見と一しょにやっていましたが、やがてのことに、『イヤ御心配なさるな、この児さんは末はきっと出世なさるる、よほどよい人相だ。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸一人が都会に出て、手足にあかぎれ一つ切らさず、楽をしながら出世する。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけて、清逸はその瞬間ふと農学校の一人の先輩の出世談なるものを思いだした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸はそれを聞いた時、木下藤吉郎の出世談と甲乙のないほど卑劣不愉快なものだと思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、兄とか弟とかの立身出世のために自分を身売りまでする姉や妹があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親の因果で子の出世」とか「何の因果でこの幸福」などという文句を唄や浄瑠璃で聴いたことがありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ四十という年にもならんで、御存じの通り、私は、色気もなく、慾気もなく、見得もなく、およそ出世間的に超然として、何か、未来の霊光を認めておるような男であったのを御存じでしょう。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "村越の御子息が、目のあたり立身出世は格別じゃ、が、就中、豪いのはこの働きじゃ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とて、……及び腰に覗いて魂消ている若衆に目配せで頷せて、「かような大魚、しかも出世魚と申す鯉魚の、お船へ飛込みましたというは、類稀な不思議な祥瑞。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、なるほど、金沢の裁判所に……うむ、検事代理というのかい」　老いたる役員はわが子の出世を看るがごとく懽べり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははあ、重役の忰に奉って、手繰りつく出世の蔓、お大事なもんですからな。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、黙阿弥翁のことであるから、遅かれ早かれ世に出るには相違ないが、ここに「児雷也豪傑譚」という評判物の草双紙がなかったらば、或いはその出世が三年や五年はおくれたかも知れない。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房の尻に敷かれる人はかえって出世するものだって……。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
