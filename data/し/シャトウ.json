[
  {
    "uuid": "f575f338-9052-567a-a278-2a3b2e0c10ad",
    "entry": "社頭",
    "reading": {
      "primary": "しゃとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "front of (the main building of) a shrine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馳せ出でつつ、その落ちたる梭を取って押戴き、社頭に恭礼し、けいひつを掛く）しい、……しい……しい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう晩かつたから、材木の森に谺する鰐口の響きもなく、露地の奧から笛の音も聞えず、社頭にたゞ一つ紅の大提灯の霧に沈んで消殘つたのが、……強ひて擬へるのではない、さながら一抹の丹頂に似て、四邊皆水。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――事実でないのを確めたに就いて、我が最初の目的の達しられないのに失望したが、幸か、不幸か、浅間の社頭で逢った病者の名が、偶然貞造と云うのに便って、狂言して姉夫人を誘出し得たのであった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古え明星この社頭の大杉に降りしを祭る。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに書き洩らしたが加藤雀庵の『囀り草』の虫の夢の巻に、千住の飛鳥の社頭で毎年四月八日に疫癘を禳う符というを出すに、桃の木で作れり、支那に倣うたのだろうとある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『君が代の社頭の松に首くくり』さ。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "住吉の社頭で大矢数一昼夜に二万三千五百句を吐いた西鶴が、そのような早口俳諧をもってする風俗描写の練達から自然散文の世界に入って、浮世草子「好色一代男」（天和二年）などを書き始めた必然の過程は、人生と芸術への疑いにみたされていた桃青にどのような感想を与えたであろうか。",
              "citation": {
                "source": "芭蕉について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "觀月亭は、この社頭に立つ東屋風の一小亭である。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "注（３）「何事がそこに（起こった）あるかは、私には分からないけれど、〔社頭に立つといつも〕有り難くも涙がこぼれる。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めていると、きよらかな海際の社頭の松風のあいだに、どこやら微かに人声も聴えて来るという思いがする。",
              "citation": {
                "source": "あられ笹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶応義塾は社頭が福沢諭吉、副社頭が小幡篤次郎、校長が浜野定四郎で、教師中に門野幾之進、鎌田栄吉等があり、生徒中に池辺吉太郎、門野重九郎、和田豊治、日比翁助、伊吹雷太等があった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）土佐画の画工等、或は社頭の式を観をみる人あり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社の神は内地人の神であると誰も拝みに行かなかった頃、率先して内地人の群に投じ社頭にぬかずいた当初の彼は真に重大な人物で後光さえさしいろいろな役目もあった。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "社頭は静寂としていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて怪人支倉は逃走後一ヵ月有余、三月の空蒼く晴れ渡った朝、深川八幡社頭で哀れにも神楽坂署員に依って捕縛せられたのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "社頭の松の下に雪を避け、藁を焚いて暖を取りながら、吉田氏の内方に斡旋を乞うて百太夫社の開扉を待つたが、生憎責任者の組長が不在で遂に不可能となり、宿望の百太夫像は見られずに終つた。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中、三日目以後は、毎日一座、四日間、四座の太夫の薪猿楽奉納が、春日社頭に行はれる。",
              "citation": {
                "source": "薪能と呪師走の翁",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春日社頭の薪能の翁は、此、呪師走と謂はれるものである。",
              "citation": {
                "source": "薪能と呪師走の翁",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "社頭から坂の両側に続いて桜が今を盛りと咲き乱れている。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを自得の袈裟掛け一刀、伊那高遠の八幡社頭で、夜な夜な鍛えた生木割り！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春寒の社頭に鶴を夢みけり",
              "citation": {
                "source": "京に着ける夕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園の社頭ににう木に似た削り掛けを立てるのは、大晦日の夜から元朝へかけての神事ではないか。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがオーカミイナリはそれを証する古文書も古代の地図及び神域や社頭の絵図面も有ると言う。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿ならば、隠れておられる能登守殿も喜んで会われることと思う」「会ってみたい、そう聞いては今夜にも会ってみたい」五　権現社頭から帰って来たのは駒井能登守であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬られつ追われつしているのは、かつて三輪の社頭で見たその時のすべての人々であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "根津権現の社頭には慶応四年より明治二十一年まで凡二十一年間遊女屋の在ったことは今猶都人の話柄に上る所である。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "社頭で飴菓子を売っている人に逢った。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼でも暗い社頭の境内がある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉は手にした死骸の頭を大きな赤い口へ持って往ってむしゃむしゃとう容が瓜でも※うようであった。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃあね、女狂いはあの人の病ですから、あたしゃとうから諦めてはいますけれど、ただ一日も早くあたしという女房と、この深川の家を思い出して、帰って来ますようにお願いいたします。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
