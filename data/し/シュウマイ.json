        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちょうど三日目の朝、同郷人の赤土焼売が心配して訪ねて来た。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の中には世を渡る偽りの職業として、箕直し、天の橋立、風車売り、猿廻し、蒲焼売りなどを業とし、人里に立入って様子を見届けた上で、強盗に押入る者がある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、これも支那料理（敗戦後、中華料理と言わなくちゃいけないと言われて来たが、もういいんだろうな、支那料理って言っても）の一種だから、戦前にだって、神戸の本場支那料理屋でも食わせていたし、又、赤坂の、もみぢでは、焼売と言うと、これを食わせていたものである。",
              "citation": {
                "source": "ああ東京は食い倒れ",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "安くてうまい、といふのが来々軒、こゝは昔――震災前ほどではなくなったが、やっぱり分厚なものを食はせる、焼売など、又中華丼・雲呑がよろしかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食ひものに苦労した、一っそ毎日屋で豆と白あへでも食はうかと買ひにやったが休み、来々軒の焼売とゴモクワンタン食ったら、まづいの何のって。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "１番から焼売とやきそば取って食ひ終るともう五時すぎ、夜の「荒神山」眠くて弱った、「楽天」よく受ける、気持よし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上山と支那グリル一番へ行き支那食し、焼売二円がとこ土産にぶら下げて、橘のとこへ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼終ると、支那グリル一番から五目めしと焼売とって食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼終り、支那グリル一番のごもくめしと、焼売。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上森と長谷川へ行き、ウイ、もみぢの焼売沢山食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高陞へ歩き、焼売と叉焼雲呑を食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東興園の焼売と炒飯をとる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼売大きくて味気なし、炒飯は、まるで淡りしてゝ話にならない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬莱の焼売をふかさせ、炒り卵と野菜鍋。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の了り、亀井おばあちゃん又々蓬莱の焼売と肉まん持参。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが了り、折からの雨の中、慶楽へ行って、焼売と鶏糸湯麺を注文、ともに大にして食ひ切れず。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕われて来た百姓男は、よく、田舎から江戸へ出て来る黒焼売りのような泥くさい風態をしている。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒焼売りか、百姓か」「…………」　蟇然とした口は、相変らず、への字のままである。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もみぢのしゅうまいを大いに食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺篤に対する対策を練り、もみぢのしゅうまいでジョニ赤。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に来々軒のシュウマイ食ひたくなり、浅草へ廻り、しゅうまいとワンタン、中華丼食ひ、ミルクの川田と白十字で茶をのみ、日暮里へ女房と清を迎へに行き一緒に帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
