      {
        "index": 1,
        "gloss": "looking on with folded arms (with one's hands in one's sleeves)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
