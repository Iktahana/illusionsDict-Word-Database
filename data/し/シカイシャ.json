    "definitions": [
      {
        "index": 1,
        "gloss": "chairman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "バルセロナの市長夫妻が、古風なスペイン服で高い桟敷につくと、金と紅で美装した闘牛士の群が騎馬で出て来て、司会者の前で昔ながらの武士的な挨拶をするのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、司会者は黄金色と紅色で飾られた闘牛の魂とも云うべき鍵を、闘牛士に向って投げます。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな白いリボンを胸につけた司会者がはいって来ました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "両者の仲裁仲直りの席に、司会者の側の顔を大勢並べて両者を威圧するようにするのは卑怯で、かかる場合万々一間違が出来れば、左方からも右方からも甘んじて刀を受けて、一身を犠牲にして、そして飽迄も双方を取纏めるのを当然の覚悟とするから、助勢なんぞは却って要せぬのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私が、あの場に居合せたなら、そうして司会者から意見を求められたなら、きっとこう叫ぶ。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその夜も文学の会に出て、したたか酔つて夜更の路を帰つてきた、『司会者は、頭がいゝぞ――。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り沢山置き並べるので、演奏の邪魔になりそうなので、司会者が周章て取り降した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の大会は博士の報告演説だけで独占されることになっていたので、司会者の開会の辞がおわると、村木博士が割れるような拍手を浴びて登壇した。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り沢山置き並べるので、演奏の邪魔になりさうなので、司会者が周章て取り降した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫んで、そつと司会者に訊くと、弁士が弔演説をしてゐる男は、今は課長に昇進して、亡くなつた男がその後釜に据つてゐたのを雄弁家がつい早飲込みにその男だと穿違へて了つたのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その演説会の司会者といふのは、大のロイド・ジヨウジ崇拝者で、この政治家の試みた演説は、どんな詰らぬものでも、みんな新聞を切りぬいて手文庫へしまつて置くといふ風の男だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日の演説家を案内して、会場へ入つて来た背の高い司会者は、先づ起つて、この名高い政治家を聴衆に紹介はしたが、そのなかに次ぎのやうな言葉があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唯今承はりますと、今日の司会者は、私にお会ひになつて、甚く失望せられたやうな御｜容子で、誠にお気の毒に堪へません。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と首相は脊高の司会者の方へ皮肉な目つきを投げた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、司会者が現れた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "司会者はこの大男を皆にひき合はすのに、「歴代の大統領のなかで、一番人に愛されたタフト閣下です。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い布を掛け、青い十字架をつけ、牡丹の造花を載せた棺の側には、桜井先生が司会者として立っていた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ司会者が舞台の上から「集会は解散になりましたが、余興は別に許可されていますから、すぐそちらにうつります。",
              "citation": {
                "source": "日本プロレタリア文化連盟『働く婦人』を守れ！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「働く婦人の夕べ」準備委員会はすぐ抗議団として、弁護士布施辰治、司会者等を築地署へ抗議のために送った。",
              "citation": {
                "source": "日本プロレタリア文化連盟『働く婦人』を守れ！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロメルはそれを司会者のたぶん共産党の何とかいう男に通じた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "司会者は僕のそばへ来て、何を喋舌りたいのかと聞いた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロメルは僕を日本のサンジカリストだと紹介しただけなので、司会者は僕の名も何にも知らなかったのだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は司会者に言った通り、日本のメーデーについて話した。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとへまた、司会者の男が二、三名の連れと一緒にやって来た。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はちょっとのすきを窺って、ポケットの中の手帳を司会者の手に握らした。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一度警官の手に取りあげられたんだが、司会者等のはいって来たどさくさまぎれにまた取り返して置いたのだった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、もう一人の私服が、それじゃきっとさっきのムッシュ何とか（司会者の名だ）に渡したんだろうから、行って取って来ようと言いだした。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら、司会者が、いきなり、今度は日本の女の人が皆に挨拶をするからといってしまった。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＥＳＰＡＤＡのベルモントが、一同を代表して司会者――これはたいがい皇后さまか宰相夫人か、とにかく女性にきまってて、この日は赤十字マドリッド支部長としての市長夫人だった――へ、大芝居に騎士的な一礼をしている。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
