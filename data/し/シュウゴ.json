        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西洋諸国の上流紳士学者の集会に談笑自在なるも、果たして君らの如き醜語を放って憚らざるものあるか、我輩の未だ知らざる所なり。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な歌みたいなものまで書いて、恥ずかしゅうございました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、――年とって、もろもろの物慾が出て来て、お恥かしゅうございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしゅうございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしゅうございます、暁の祭までにはまだ間の時刻もございます。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐しゅうございました。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは致さない方が宜しゅうございますの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも宜しゅうございますから言って御覧なさいましよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、明りはまぶしゅうございますわ。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらは春の初には、なんでも物悲しゅうございますの。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、失礼でございますが、お店へあがりましてもよろしゅうございましょうか」と、女は忍びやかに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蚊帳のなかを見ても宜しゅうございますか」「どうぞお検めください」　半七の身分を知っている家主は異議なく承知した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、まことに勝手がましゅうございますが、あしたにもちょいとお出でを願いとうございます」　お亀はしきりに念を押して頼んで帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その女は跣足だったかえ」「はい、どうもそうらしゅうございました」と、お伊勢は思い出したように云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "（はい、よろしゅうございます、何事もおっしゃりつけは背きますまい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう云う処ですからあんなものまで人｜懐しゅうございます、厭じゃないかね、お前達と友達をみたようで愧しい、あれいけませんよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（いえ、誰でもそう申します、あの森から三里ばかり傍道へ入りました処に大滝があるのでございます、それはそれは日本一だそうですが、路が嶮しゅうござんすので、十人に一人参ったものはございません。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にお気遣はかえって心苦しゅうござります。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなにございませんければこうやってお話をなすって下さいまし、寂しくってなりません、本当にお愧しゅうございますが、こんな山の中に引籠っておりますと、ものをいうことも忘れましたようで、心細いのでございますよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひどく寂しゅうございますから、もう一時前でもございましょうか」「うん、そんなものかもしれない、ちっとも腕車が見えんからな」「ようございますわね、もう近いんですもの」　やや無言にて歩を運びぬ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると秀吉のその時の素ばらしい威勢だったから、宜しゅうござろう、いと易い事だというので、近衛竜山公がその取計いをしようとした。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "父様も母様も婆様のほんとうの御子ではございませぬから、婆様はあまり母様のほうへお遊びに参りませず四六時中、離座敷のお部屋にばかりいらっしゃいますので、私も婆様のお傍にくっついて三日も四日も母様のお顔を見ないことは珍らしゅうございませんでした。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしゅうござる。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな手あてをいたしたらよろしゅうございましょうか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘイ、お話ししてもよろしゅうございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "女難といえばその時もう女難に罹っていたといってもよろしゅうございましょう。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は叔母の家から私の学資を出さそうとしたらしゅうございました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にもそんな時が来るとしたら、私は死にはしないかと、今から悲しゅうございます。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にもそんな時が来るとしたら、私は死にはしないかと今から悲しゅうございます。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
