    "definitions": [
      {
        "index": 1,
        "gloss": "National Guard (esp. USA)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
