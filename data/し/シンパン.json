    "definitions": [
      {
        "index": 1,
        "gloss": "trial by ordeal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
