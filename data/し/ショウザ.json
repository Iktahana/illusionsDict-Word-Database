        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見ると、玄関の式台には紋服を着た小坂吉之助氏が、扇子を膝に立てて厳然と正座していた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑近な事を言へば、きちんと書齋の机に向つて正座しなければ書けぬ人もあるし、疊や寢床の上に腹這ひになつても書ける人もあるし、時には混み合つた動搖する汽車の中などで平然と筆を動かす事の出來る人もあるといふ風だ。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はいつも黒い羽織を着て端然として正座していたように思う。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自宅にいて黒い羽織を着て寒そうに正座している先生はなんとなく水戸浪士とでもいったようなクラシカルな感じのするところもあった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは未だ二十二歳の筈であるが、その、本郷の下宿屋の一室に於いて、端然と正座し、囲碁の独り稽古にふけっている有様を望見するに、どこやら雲中白鶴の趣さえ感ぜられる。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂へはいって鬚を剃り、それから私は、部屋の炉の前に端然と正座した。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門は正座に据つて自分のこの土地に於ける勢力を象徴するものゝやうに、本堂もひしめくばかり集つた大勢の会葬者の群を見廻した。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども男子は一度言ひ出したからには、のつぴきならず、翌る朝さつそく庭の隅に一坪ほどの掛小屋を作つて、そこに引きこもり、寒さに震へながら正座してゐた。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とたけの傍に坐らせ、たけはそれきり何も言はず、きちんと正座してそのモンペの丸い膝にちやんと両手を置き、子供たちの走るのを熱心に見てゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の坐っているのは母屋の中央、家長のいるべき正座である。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の用事か知らないが、法眼、円通といえば当時噂に高い清僧たち、失礼があってはいけないと言うので、女中たちに云い含め、いとも丁寧に座敷へ通して正座に据え、自分は袴羽織で挨拶に出ました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷の正面に荒家に不似合いの立派な仏壇が見え、正座に蓮如上人を据え、源右衛門と妻のおさきが少し離れて遜って相対して居る。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎晩、今か今かとその時機を待っているうちに或る朝の事、霜の真白い、月の白い営庭の向うの獄舎へ提灯が近付いてゴトゴト人声がし始めたので、素破こそと皆｜蹶起して正座し、その方向に向って両手を支えた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当出来た人ばかりであったが、その中の一人が正座した足趾の先で拍子を取っているのを敏感な翁が発見した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　翁は張盤の前に正座した時、必ず足の拇指を重ね合わせていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この声を出すには、先ずこんな風に正座して身心を整斉虚名ならしめ、気海｜丹田に力をこう籠めて全身に及ぼし、心広く体胖かに、即ち至誠神明に通ずる底の神気を以て朗々と吟誦するのです。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにその中央のお眼通り正座に控えた鼻ばかりはいつも無でいるようであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいに片付いた六畳ぐらいの居間の小さな火鉢の前に寒そうな顔色をして端然と正座しているのである。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は表座敷のいろりばたに正座して、たばこをくゆらしながら門のほうを見てる。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ机のまえに正座しなくとも、ベッドやトイレでも読める。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "只一人の巫女が彼等に特有の態度を保つて正座を張つて、其の何時でも放さない荷物を前へ置いてしやんと坐つて居るのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩には、この晩に限つて彼が正座に直つて、おそくまで慰労の盃を享けるのであつた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "きちょうめんに正座して、父は例の皮表紙の懐中手帳を取り出して、かねてからの不審の点を、からんだような言い振りで問いつめて行った。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはもうすっかりかたづけられていて、矢部を正座に、父と監督とが鼎座になって彼の来るのを待っていた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして古藤を正座に据えて小ざっぱりした座ぶとんにすわると、にっこりほほえみながら、「これなら半日ぐらい我慢ができましょう」　といった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "列座の人々はまだ殊勝らしく頭をうなだれている中に、正座近くすえられた古藤だけは昂然と目を見開いて、襖をあけて葉子がしとやかにはいって来るのを見まもっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十川女史が四角を思い出させるような頑丈な骨組みで、がっしりと正座に居直って、葉子を子供あしらいにしようとするのを見て取ると、葉子の心は逸り熱した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は年六十七八、墨染の十得の長い様なものを着て、まだ斯んなに船の揺れなかった前にはちゃんと正座しながら茶道捷径という本を手提の上に置き、歯の無い声で高らかに読んでいたのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "神妙に下座せいッ」　自らもまたその場に正座して、お濠端にのこった指揮者らしい姿にうやうやしく一礼すると、神色かわらぬその面にはればれとした笑みをただよわせながらいいました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
