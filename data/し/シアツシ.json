        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三日目、妻の美加子の勧めで、指圧師にかかった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高い、骨っぽい感じの指圧師がやって来た。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「医者なんかダメですよ」　背中を押しながら、指圧師はあざけるように言った。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし指圧師の指が腰に移ると、笑ってばかりいるわけには行かなくなった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "と叫ぶと、上から指圧師の叱声が落ちて来た。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでもまだ栄介は、急所に触れられるたびに、痛いと叫んで、指圧師から訂正を要求された。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "指圧師はそれから毎日通って来た。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて家政婦がやって来て、指圧師の来訪を告げた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "町　熊本の宿で、五郎は女指圧師に揉まれていた。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "指圧師は二十前後の体格のいい女で、黒いスラックスと白い清潔なブラウスを着けていた。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "女指圧師がまず口にしたのは、この部屋の悪口であった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「揺り返しが来もんでな、明晩もあんまか指圧師にかかりやった方がよろしゅござんそ」「揺り返し？",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんまか指圧師を呼んで呉れないか」「御食事前にですと？",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて指圧師がやって来た。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "女指圧師は入って来るなり言った。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたいのだが、女指圧師が駅で待っているかも知れない。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "女指圧師のことをしゃべるのは、面倒であり、重苦しくもあった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中は物のにほひや夏の月　芭蕉がそれにつづけて、あつしあつしと門々の声　これが既に、へんである。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつしあつしと門々の声。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸しあつし、また息ぐるし。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつし、あつしあつし、あつし、あつし狭い廬の中を蹈んで廻つた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入りて少々むしあつし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
