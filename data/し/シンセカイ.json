    "definitions": [
      {
        "index": 1,
        "gloss": "New World (esp. the Americas, but also Australasia)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
