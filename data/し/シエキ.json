[
  {
    "uuid": "b30a4c45-7dd7-5c83-b91a-9356eae60734",
    "entry": "使役",
    "reading": {
      "primary": "しえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "setting (someone) to work",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "船長は一箇の六分儀を以て星を使役する自信を持つてゐる。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツァイス會社製の、無駄な飾りのない、然しいかなる點にも綿密な親切と注意との行き亙つた、從つてたくらまないで美しい直線や弧線の綜合を成就した顯微鏡も、今は彼れの使役を拒むものゝやうに見えた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "磊落を装っているが、若い愛妻の詩的精神に使役されて、如何にこの噴水構造に苦心したかを暗に談話のうちにほのめかした。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢名主の声がかりというので、彼は普通の囚人とは全然別格の待遇をうけて、他の囚人どもを手下のように使役するばかりでなく、三日に一度ぐらいは鰻飯などを食って贅沢に生活していた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、重兵衛は狐や河童のたぐいを使役して、かれらに魚を捕らせるのではあるまいかと、近所の人たちに疑われていた。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちの子供の頃には、馬耕に限らず、荷車を挽かせるのでも何でも、全部、馬で、牛を使役するといふ事は、ほとんど無かつたんですがね。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は人に使役せらるべきものでないとするが故に首領を戴かない。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの長閑な例――奇妙な囚人服を着せられ道路工事に使役されている土人の囚人の所へ、日曜着の綺羅を飾った囚人等の一族が飲食物携帯で遊びに行き、工事最中の道路の真中に筵を敷いて、囚人達と一緒に一日中飲んだり歌ったりして楽しく過すのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西南の役始終を通じて、官薩両軍ともに、戦闘員の外に、非常に多くの人夫を使役した。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六、民を使役するには時を考へよ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天正十一年五月、秀吉は諸国から大木巨岩を集め、三十余国からの人夫を使役して、大坂に大規模な築城工事を起し、翌年の八月に殆んど竣工した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑木山からの薪運びに、伝平は、初めて馬を使役に曳き出した。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイス人青年は二度と見つからず、その人物がモリアーティの使役していた数多くの手先のひとりであることは疑いようもない。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狐は九尾で金色で、日月宮に使役されているのであるという。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次は疲れた身體を其の日も餘念なく使役した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や、彼らはボーイ長が雇い入れなしに使役されていたという事実について、彼らの意見を発表し合う必要が生じたのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどエジプトの昔の王様が己れの名が万世に伝わるようにと思うてピラミッドを作った、すなわち世の中の人に彼は国の王であったということを知らしむるために万民の労力を使役して大きなピラミッドを作ったというようなことは、実にキリスト信者としては持つべからざる考えだと思われます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "評論家の使役するところとなって、風の中の飄葉、空中の游塵のような、何の甲斐も無い境地を脱して、「雨｜淋げど、竹いよいよ翠に、天寒けれど鴨水に親しむ」的の面白い境地に至り得たのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ノ愚昧ナル善人ガ斯ル惡魔ノ喇叭卒ニ使役セラレテ其レヲ日本ニ向ツテ吹キシコトハ米國史上空前ノ恥辱ナリトス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこれから私が書き連ねる言葉は、恐らく私の使役に反抗するだろう。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無学な漁夫と税吏と娼婦とに囲繞された、人眼に遠いその三十三年の生涯にあって、彼は比類なく深く善い愛の所有者であり使役者であった。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　照子の機嫌は直ぐに癒つてしまつて、甘納豆が食べ度いから買つて来て呉れなどと言つて、彼を使役した。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういって、けなしている一方、医学生吹矢は、学歴においては数十歩先輩の熊本博士を百パーセントに利用し、すくなからぬその恩恵に浴しているくせに、熊本博士をつねに奴隷のごとく使役した。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹山は、「一日も早く新聞の仕事に慣れる様に、」と云つて、自分より二倍も身体の大きい長野を、手酷しく小言を云つては毎日々々｜使役ふ。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時のアテン人の間には奴隷使役が広く行われていた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アフリカにおいても、大中小の酋長はいずれもみな神権を持っていて、自由に地水風火の原素を使役する。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『朝日新聞』六月四日）飼主の命令のままに馴らされ、使役される犬猫から牛馬のたぐいは人道的なひとびとによって組織されている愛護デーをもつ。",
              "citation": {
                "source": "動物愛護デー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
