[
  {
    "uuid": "7a63f600-c187-564f-be93-55a26d957462",
    "entry": "縮刷",
    "reading": {
      "primary": "しゅくさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reduced-size printing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "のちに縮刷版も上梓せられた。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番売れたのは『吾輩は猫である』で、従来の菊判の本の外に此頃縮刷したのが出来て居る。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来絶版してゐたのを、今度縮刷したのである。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めこれを縮刷に付するに臨み、予は大いに字句を削正せむことを期せしに、會※歐洲大戰の起るありて、我國も亦其旋渦中に投ずるに至りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の縮刷版や雑誌のバックナンバーを閲覧するほか、ある分野に関してどんな本があるかは、先ず図書館に行って調べたいからです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村毅君で思い出すのは、同じく私のクラスメイトで、町田歌三君が、涙香の書物を出版していた扶桑堂の主人で、同君は、自分で縮刷本の表紙の図案なども書いていたのだった。",
              "citation": {
                "source": "黒岩涙香のこと",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頃日国書刊行会が『訪古志』を『解題叢書』中に収めて縮刷し、その伝を弘むるに至ったのを喜ぶのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六朝時代を通じて、僧尼は離俗出家といふので、その父母を拜せず、却つて父母の禮を受くるを例とした（唐の彦※「集沙門不應拜俗等事」【『縮刷藏經』露帙七册所收】）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の『鐔津文集』（『縮刷藏經』露帙一所收）卷三に收録されて居る。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十九版から縮刷六号になりました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は十三年前の順礼行には一冊の自著も携えなかったが今度は旅鞄に「新春」と縮刷「死の蔭に」と「順礼紀行」と而して縮刷『み※ずのたはこと』を入れて来た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前版は縮刷六号でしたが、復活版は最初に復えって四六型五号とし、插画を新にし、巻末に著者の最近消息を報ずる一長文を添えました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正五年四月籾山書店は旧版『すみだ川』を改刻しこれを縮刷本『荷風｜叢書』の第五巻となし装幀の意匠を橋口五葉氏に依頼した。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十七年出版の縮刷は相当に校合してありますが、私はどうかして古写本が校合する必要があるということを立証せんとして石山寺に参りまして、同寺の天平写本を調べました。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、念のため、明治四十五年五月博文館發行の「一葉全集」後篇及び大正十一年六月同所發行の縮刷本を以て誤植を正す參考とした。",
              "citation": {
                "source": "「樋口一葉全集第二卷」後記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもって行くための縮刷の詩集をこれからとり出して枕許において寝ます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "美佐子はそれらの顔の中にわざと夫と向い側にかけて鼻のあたまを毛皮の襟巻のふかふかとした中へ埋める程にして、縮刷本の水沫集を読んでいるのである。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "縮刷版の検索はそちらのこととして、取材・執筆者の氏名・現住所は末記のとおり。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は資料といえばまず分厚くふくらんだ大きなスクラップ・ブックでしたが、いまでは縮刷版はマイクロ・フィルムですし、切り抜きは光ディスクへと完全に換わっています。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も手近な一例を示せば、先月号「新青年」の縮刷図書館の冒頭に訳されているゼルールド女史という人の探偵小説論にもこれがある。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
