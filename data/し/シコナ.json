    "definitions": [
      {
        "index": 1,
        "gloss": "wrestler's stage name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
