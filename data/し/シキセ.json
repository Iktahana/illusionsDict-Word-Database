[
  {
    "uuid": "994c2956-e55e-5173-a003-e8b8d3084dcd",
    "entry": "仕着せ",
    "reading": {
      "primary": "しきせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
