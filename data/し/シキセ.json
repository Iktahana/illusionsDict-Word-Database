    },
    "definitions": [
      {
        "index": 1,
        "gloss": "servant's clothes provided by an employer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "敢て流行を趁う考も無いし、もう年を取ったからしゃれても仕方が無いと思って居るので、妻の御仕着せを黙って着て居るが、女などがいい着物を着たのを見ると、成程いいと思う。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論囚人服を着たままですから、夜しか人里に出られなかった訳でしたが、私は盗みというものを絶対にしない方針でしたので、どこまでも青いお仕着せ姿で、鳥獣と同じ生活をして行かなければなりませんでした。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＵＮＩＸは使う側の都合に合わせて仕掛けを変えていく柔軟性が高かったことで、技術屋や学生の中でもとりわけわがままな連中は、メーカーのお仕着せでないこのＯＳを好んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どなり、しかり、当たり散らしながら死骸を見調べると、小娘は年のころ十三、四、手甲、脚絆、仕着せはんてんにお定まりの身ごしらえをして、手口は一目｜瞭然、絞殺にまちがいなく、かぶっている菅笠のひもがいまだになおきりきりと堅く首を巻いたままでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、女物の、同じような仕着せはんてんの片そでなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "片そでをもぎとられた仕着せはんてんはここにござる。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまがらは合いませぬかな」　にこやかに笑って、帳場のわきから取り出したのは、だんだらじまの右筒そでをちぎられた仕着せはんてんでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これなる仕着せの主がおくにとすれば、片そでがふびんなおなつの口なり手なりに残っておった以上、まず十中八、九までおくにが下手人とにらまねばなりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も何事も自分を相談相手にしてゐた夫は、さぞ歳暮の忙しさに手廻りかねてゐるであらう、店の者達の仕着せもまだ整へてなかつた。",
              "citation": {
                "source": "四十餘日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに夏冬の仕着せはこっちで為てやって、年に三両の給金をやる」「ふむう」と、半七は眉をよせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "老僕が無言でわたしに背を向けた途端に、お仕着せのひどくすり切れた背中が丸見えになって、そこに赤さびの出た定紋入りのボタンが、ぽつんと一つ残っているのが目についたが、彼はそのまま皿を床へ置くと、奥へ引っ込んでしまった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆暮の仕着せ、折々の心づけ――あの店のさかんな時分には、小竹の印絆纏や手拭まで染めさせて、どれ程多勢の人を悦ばせたことか。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れる頃に、お島は物置の始末をして、漸と夕飯に入って来たが、父親は難しい顔をして、いつか長火鉢の傍で膳に向って、お仕着せの晩酌をはじめているところであった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはそう毎日々々親の機嫌を取っているほど、気楽な身分じゃないんですからね」　晩方になると、きっとお仕着せを飲ませることに決っている父親への、酒の支度を疎かにしたといって、小野田がその時も大病人のように二階に寝ていたお島に小言をいった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学生、小さい女学生、印バンテンの労働者、お仕着せを着たどっかの小僧さんの一団までをまぜて、見物人は犇々太い丈の手摺りぎわへつめよせ、ギッシギッシと動いている。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うだろう、其の服は英国の監獄署で女の囚人が着ける仕着せである。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲役に行ったとて牢屋の着物を外まで被て出る者はない、牢屋の着物は監獄のお仕着せだ、縦しや着て居たいと思ったとてそうは行かぬ、之を着て出るのは牢破りの逃走者ばかりだ、若しアノ服を秀子の着たものとすれば秀子は牢破りの罪人か知らん、アノ服を着けたまま監獄から忍び出て来たのか知らん、思えば思うほど恐ろしい。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "執事と門衛と売子監督はいぎりす産に限ると言われてるほど、いかさま堂々とした「｜能なし」がお仕着せのモウニングを一着におよび、微笑の本家みたいな顔をして直立している。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍客――私達――の出現にすっかりよろこんで、お客のほうは女店員に任せっきり、いろいろ江戸時代の絵を出して来たり、自分の著した“Netsuke”と題する研究的な一書を見せたり、そのあいだも、何にするのか女中のお仕着せみたいな染め絣が一尺二尺とよく売れて行く。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色の仕着せを着た音楽隊はフィガロの婚礼を奏し、飾棚にロココの女の入黒子で流眄する。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白茶の西洋仕立の洋服にビイツの多く下れるを着し」前髪をちぢらせた夜会巻にしているやや年かさの娘は、成上り華族で、家の召使たちにまで西洋風の仕着せをきせている極端な欧化主義者の娘篠原浜子。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃ってお仕着せの薄灰色のガウンをかき合わせ、それだけは病わぬ舌によって空気を震わす盛な声が廊下に充満する。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女たちはなかなか凝った服装をして、市内を軽馬車で乗りまわしていたが、その馬車の後部には、ちゃんと流行にしたがって、金モールつきのお仕着せを著た従僕がゆらゆら揺れながら立っていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分の顏のよしあしも、一つは、細君の子分操縱法――つまり臺所まかなひ、小遣ひ錢、仕着せの心附けなどの附け屆けの氣の利きかたで、だいぶ違ふのだらうと思ふ。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕着せ、まきもの、配りもの、飾りもの、ありきたりな凝ようではなかった。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに大暖炉の上の電気時計の針が、カチリと音を立てて三時三分を指しますと、大学のお仕着せを着た四十恰好の頭を分けた小使が、一葉の名刺を持って這入って来て、恭しく正木博士の前に捧げました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし不検束な主人はその正規の時間に帰って、正規のおしきせの晩酌で満足して寝ることは稀であった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　鴾の細君の弱ったのは、爺さんが、おしきせ何本かで、へべったあと、だるいだるい、うつむけに畳に伸びた蹠を踏ませられる。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、なにがまだだい、姐さん、ばかにしちゃいかんよ、俺はお前さんのおしきせを飲んでるのじゃないよ、が、まあ、宜い、黙って酒を持って来た」　女は洋服の男の権幕に驚いたのかそのままむこうへ往った。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩あたり来ようものなら、ひと打ちだ」と、台所の隅で鼻の端を赤くして、おしきせの酒をちびりちびりとやる僕もあった。",
              "citation": {
                "source": "女賊記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
