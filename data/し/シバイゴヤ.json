        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "＝（Ｆ・Ｉ）芝居小屋の内部　蛇の目の傘を半開き、ダダッと駈けて、花道の七三で大見得切った仲蔵の定九郎。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）大入満員三日目の中村座　＝（Ｆ・Ｉ）芝居小屋　幕閉って居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（たらいに番附入れたのを肩に乗せ売って歩いている等芝居小屋の情景よろしく）　平土間で「幕開けろ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ツ巴の大波瀾を予期した江戸ッ児連が中村座に雪崩れ込んで……　＝（Ｆ・Ｉ）芝居小屋　大人気大入の平土間。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、太刀逆手にグサッと横腹を……（急速なるＦ・Ｏ）　＝（Ｆ・Ｉ）芝居小屋　花道をダダッと駈け出た仲蔵の定九郎。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、モナコの華美な海浜の妾達の芝居小屋は、世界各国の観衆で一杯でした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶屋のボンボリの仄白い光の中から、芝居小屋にかかげられた幟の列を俯瞰する。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居小屋へ活動写真がかゝると、その電燈は息をした。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふいに、強力な電燈を芝居小屋へ奪われて、家々の電燈は、スッと消えそうに暗くなった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうした町も今は屋根瓦の間へ挾まれてしまって、そのあたりに幟をたくさん立てて芝居小屋がそれと察しられるばかりである。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居小屋のなかは思ったように蒸し暑かった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより芝居小屋の建物は俄作りの仮普請で、その騒動を持ち堪え切れる筈はなく、二階から先にずり落ちた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "話している内に道頓堀の芝居小屋のハネになり、丁度そこは朝日座の楽屋裏の前だったもの故、七八人一時に客が寄って来たのを機会に、暫く客の絶間がなかった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリアンは当もなく東の方向を択んで進む中に、忽ち陰気な薄暗い街の中へ迷い込んで、やがて小さな立ちくされた芝居小屋の前に出た。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリアンはシビル・ヴェンを忘れかねて、それから毎晩、その怪しげな芝居小屋へ通った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬小屋が芝居小屋になっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居小屋はしまってしまうし、菓子屋のおかみさんたちは、砂糖菓子の子ブタに、黒い喪章をまきつけました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居小屋もすばらしいし、お客さんもすばらしい人たちでした。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の芝居小屋の舞臺開きに東京の雀三郎一座といふのがかかつたとき、私はその興業中いちにちも缺かさず見物に行つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校から歸るとすぐ、私は柔い着物と着換へ、端に小さい鉛筆をむすびつけた細い銀鎖を帶に吊りさげて芝居小屋へ走つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ休暇中のことだつたが、まちに浪花節の興行物が來たとき、私のうちでは、使つてゐる人たち全部を芝居小屋へ聞きにやつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして街道の兩側には川、芝居小屋、料理屋、果物屋がある。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（同日夜）　夜、一種の好奇心からちよつと芝居小屋を覗いて見た。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、むかし大川の河口の三角洲があったのを埋立てた土地で、母の若い時分は芝居小屋があったり、楊弓店があったり、かなりな盛り場だったそうですが、今は全く普通の住家町になって、船つきに便利な為めか倉庫が多いようです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その芝居小屋のかげをゆく馬車の喇叭のなつかしさよ。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒を倦ませないやうにといふので、ここかしこに芝居小屋を掛けて、兵卒に芝居をさせる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　で、鍍金の奴が飛びつくと、（べらぼうめ、いくら山手だってこう、赤城に芝居小屋のあった時分じゃねえ、見物の居る前で生命の取遣りが出来るかい、向う崖の原ッ場までついて来い、殺してやる、来い！",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にこの芝居小屋も寺内にある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、男と女と入りまじりの芝居をするのは不都合だというので、浅川の方から鳳閣寺の芝居小屋へ掛け合いを持ち込んだが、四の五の云って埓が明かない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやつり芝居が夏休みのあいだに、二人が一座を組んで信州路へ旅興行に出て、中仙道の諏訪から松本の城下へまわって、その土地の或る芝居小屋の初日をあけたのは、盂蘭盆の二日前であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
