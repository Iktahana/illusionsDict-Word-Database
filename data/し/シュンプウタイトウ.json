      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "warm and genial spring weather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あいあい、」と女房は春風駘蕩たる面持で、「一年でも二年でも、ゆっくり御養生しておいでなさい。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風駘蕩たるところが無いんで、僕なんか、いつでも南国の芸術家には押され気味だ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風駘蕩の美徳もうらやましいものには違ひないが、私はやはり祖先のかなしい血に、出来るだけ見事な花を咲かせるやうに努力するより他には仕方がないやうだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたも間違えんようしっかり考えなはれや」と相手をいたわるような春風駘蕩の口を利いたりした。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桜の間」は、越後獅子の人徳のおかげか、まあ、春風駘蕩の部屋である。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻の咲く頃は、春風駘蕩、猫も杓子も浮れ出す。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの春風駘蕩たる彼の貴重な顔を眺めながら神経質な彼の作品を思い出したことは一度もない。",
              "citation": {
                "source": "人間山中貞雄",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "行程三里弱、午前中に谷津の松木一郎君を訪ねる、一郎居は春風駘蕩だ、桜の花片が坐敷へ散り込む。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "にも拘らず一向に方法というような心棒のシステムを感じさせないのが、彼の謂う処の「春風駘蕩」派たる所以だろう。",
              "citation": {
                "source": "文芸評論の方法について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くの景色は春風駘蕩といったのどかな趣があり、見晴らしは霞が薄青くたなびいてこの上なかった。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "布袋というものに人格化された福々しさが、厭味なく、春風駘蕩と表現されて居る。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "師とお話して居ますと自ら春風駘蕩たるものがあります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕は婦人に対してだけは、むかしから春風駘蕩派だからな。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから浜尾君をよく知らないものは、彼から春風駘蕩たるものを感ずるよりは、秋霜烈々たるものを感ずる事が多かったらしい。",
              "citation": {
                "source": "徹底的な浜尾君",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "演者はただひたすらに芝居を楽しむといふ風で、寒気厳烈の雪原とはいへさながらに春風駘蕩、「三年さきに勘平の男前の若い衆はどうなすつたね。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風駘蕩、芳花繽紛トシテ紅靄崖ヲ擁シ、観音ノ台ハ正ニ雲外ニ懸ル。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの時私は、成蹊学園長中村｜春二先生の知遇を得ることとなり、同誌はその結果枯草の雨に逢い、轍鮒の水を得たる幸運に際会することを得、秋風蕭殺の境から、急に春風駘蕩の場に転じた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつを無造作に掴んで、そこらをふいている可愛い男の顔を、お絃は、食べてしまいたそうに、うっとり見惚れていようという、まことに春風駘蕩たるシインだ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この、一見、地味で目立たない存在が、家庭でも、学校でも、決して周囲からうとんぜられる存在ではなく、それどころか、彼の在るところ、常に春風駘蕩といひたいほどの、一種の温か味と爽やかさとを身につけてゐることが、それを感じるものにはみな感じられてゐた。",
              "citation": {
                "source": "計算は計算",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮川は水が深く流れがゆるやかなので、じつと堤に腰を落着けて、ゆつくり浮子のチヨン、チヨン、スウと沈むのを楽しむ事が出来て、春風駘蕩の季節に溶け込める。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "演者はただひたすらに芝居を楽しむという風で、寒気厳烈の雪原とはいえさながらに春風駘蕩、「三年さきに勘平の男前の若い衆はどうなすったね。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、時が春風駘蕩の時ではないが、ところはたしかに桜の馬場。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し書斎の仕事からすっかり解放された時のヘルンは実に春風駘蕩たる幸福感に満ちみちてゐました。",
              "citation": {
                "source": "父八雲を語る",
                "author": "稲垣巖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、逢えば、機嫌は悪くなく、能面と評された例の無表情な顔で、春風駘蕩たるものだった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら、これでやつとこさ、春風駘蕩たる気分が出てきたのではないでしようか。",
              "citation": {
                "source": "擬似新年",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に、浜尾先生の顔はいつ見ても春風駘蕩で、その慈眼には子弟を愛する温情があふれるほど湛へられてゐたのに、銅像の顔には、かすかな笑ひの裡に、専制的な意志と皮肉な冷やかさが潜んでゐる。",
              "citation": {
                "source": "浜尾新先生",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令朱鞘の浪人者が徘徊するにしても、空気は一変して春風駘蕩の図とならざるを得ぬであろう。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春風」を配合しないでも、慥に春風駘蕩たるところがある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚子の奴、僕の手を取って喜ぶでしょう」「君のところはいつも春風駘蕩のようだが、子供のないのが玉に疵だな」「仲が好過ぎるからでしょう」「こら！",
              "citation": {
                "source": "人生正会員",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつにしゅんぷうたいとうたるものだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
