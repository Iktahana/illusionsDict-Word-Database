[
  {
    "uuid": "524428a9-3a15-599d-a9b6-66cecec444c5",
    "entry": "春風駘蕩",
    "reading": {
      "primary": "しゅんぷうたいとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
