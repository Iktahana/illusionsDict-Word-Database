          "literary": [
            {
              "text": "白鱚は藤色の白銀、青鱚は緑光の白銀色をもつてゐる。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初が小さい白鱚、後に青鱚になり、尺近くのを釣ると、ちよつと鮎に彷彿としてゐるから、あまり遠出せず、半日の愉しみにも出られる訳である。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "牟呂の海では鮎と鰡と白鱚と沙魚を釣った。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "海鱚は白鱚ともうし、青鱚は川の鱚なんでございます。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            }
          ]
        }
