[
  {
    "uuid": "f3e6bdf4-d71a-544e-a277-1fdfa5ad8306",
    "entry": "支配下",
    "reading": {
      "primary": "しはいか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
