    "definitions": [
      {
        "index": 1,
        "gloss": "to death (bored, scared, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死ぬほど好きなひとだもの。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○「一生のうち一度だけ、巴里は死ぬほど行って見度いわ。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファオンと呼ぶ美しい青年に死ぬほど惚れた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がりがり後頭部を掻きながら、なんたることだ、日頃の重苦しさを、一挙に雲散霧消させたくて、何か悪事を、死ぬほど強烈なロマンチシズムを、と喘えぎつつ、あこがれ求めて旅に出た。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬほど酒を呑んでみたいんだ。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をさまし、笠井さんは、ゆうべの自身の不甲斐なさ、無気力を、死ぬほど恥ずかしく思ったのである。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭が面白くないから、此所で死ぬほど飲むんだ。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその翌年に女学校を卒業して、つまり、今は、その叔父さんの悪魔のような予言を、死ぬほど強く憎んでいながら、或いはそうかも知れぬと心の隅で、こっそり肯定しているところもあるのです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬほど酔っぱらうの。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見て死ぬほど惚れて、二度目には顔を見るさえいやになる、そんな情熱こそはほんとうに高雅な情熱だって書かれていたわねえ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、言いつけられたとおりにそこへ置いたとたん、さっと夕風が吹いて来て、その紙幣が庭へ飛び散りまして、一円札でも何でも、私にとっては死ぬほどの苦労をして集めて来た大金です、思わず、あっと声を挙げて庭に降りてその紙幣の後を追った時の、みじめな気持ったら比類の無いものでございました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田島は、キヌ子を憎むあまりに、ほとんど人間ばなれのしたケチな卑しい計画を立て、果して、死ぬほどの大難に逢うに到った。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の酷たらしい抱擁の下に、死ぬほどに苦しみ悶えながら彼女の純潔が奪われていく瞬間を想像すると、渡瀬はふたたび眩惑するような欲望の衝動を感じないではいられなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思うと死ぬほどの口惜しさをじっと堪らえる形のように。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬほどの熱情を男も女も失っていた。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし内心では夫を死ぬほど愛していたのですから、脳も疲れ果てて嫉妬することや、疑ぐることが出来なくなると、呆然として、ただただ馬鹿のように夫に寄りすがるのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足を方々切って見ましたが、それで直ちに死ぬほどの大切なところがありませんでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょう事なしに、笑って云うにゃ云いましたが、死ぬほど辛うござんしたわ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬほどの思いで、辛抱はしたんだが、遣切れなくなって煩いついた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち彼の生に対する脅かしさへなくなれば、彼は死ぬほどのことはないとも思つた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自分で死ぬほど、要らぬ生命を持っているなら、おなじ苦労をした女の、寿命のさきへ、鼻毛をよって、継足をしてやるが可い。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも棄て、身も棄てて、死ぬほどの思いをして、あなたのお言葉を貫きました。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家の、足のわるい十七の女中に、死ぬほど好かれている。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子も、ラプンツェルも、死ぬほど疲れていましたが、ゆっくり休んでいるひまもありませんでした。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、とりわけ、病身の次男を、死ぬほど好いている。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬほど淋しいところだと聞いている。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬほど淋しいところ。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂わば、「死ぬほど淋しいところ」の酷烈な孤独感をやっと捕えた。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中の女どころか、お隣りの娘さんひとりを持てあまして死ぬほど苦しい思いをしている。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「己はそれほどの勇気もなければ、　あの女をつかまえて殺して自分もしぬほどむごくもない。",
              "citation": {
                "source": "死に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
