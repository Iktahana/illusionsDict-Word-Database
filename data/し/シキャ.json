          "literary": [
            {
              "text": "）わたしでは手と足しきゃお役に立たないのですもの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "少ししきゃあ寐ませんでしたの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、唐黍だ、三尺ぐらいしきゃないね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は依田さんに何か言おうかと思ったが、どうもやはりしらじらしい事しきゃ思い附かないので、言い出さずにしまった。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "差当り燭台に立ててあるのしきゃないのだから」と云うような事を言っている。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この真夜中に木まくらとかやり粉をもってのそのそしていたひにゃ、だれが見たってつじ君あさりとしきゃ思いませんぜ」　しかし、右門はもうそのとき完全に、われわれのむっつり右門でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぶかしい名まえじゃが、親がつけたか」「いいえ、親のつけた名まえは辰九郎というんですが、あんまりあっしが小粒なんで、善光寺さまのご尊体が一寸八分しきゃないとかいうあれをもじって、みんながいつのまにかそんなあだ名をつけたんでございますよ」「いかさまな、物は考えようじゃな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "数の少ねえそのなかで、山住流含み針に心得のある達人は、第一にまず四ツ谷｜永住町の太田五斗兵衛、つづいては牛込の小林｜玄竜、それから下谷竹町の三ノ瀬熊右衛門と、たった三人しきゃいねえんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには三ところしきゃけえてねえが、きょうのふた口を入れると、しめて八人、きゅうっと抱きしめられて、つるりとなでられて、するするとしごきを抜きとられているんですよ」「そんなことをきいているんじゃねえんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、二十四人しきゃいねえから、ひとり足りねえといってるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、てめえたちの仲間はたった七人しきゃねえんだからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえに、土のちっともつかねえ真新しいわらじが、はくのを待つばっかりでこちらむきにそろえてあるとすりゃ、野郎が逐電の覚悟をつくりゃがって、大急ぎに道楽仲間を呼び寄せたとしきゃ読めねえじゃねえか」「いかさまね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつあ、六、七年まえに、いっぺんあそこで食ったことがあってね、そのときやっぱり三つしきゃ刺してなかったんで、ちくしょうめ、なんてけちなだんごだろうと、いまだに忘れずにいるんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの可哀想な子は走る事の出来ないナマコのような畸形児で、両手の指が三本丈しきゃないんですもの。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな人は、誰にだって一人しきゃないことはきまってるじゃないの」　やっぱり、みさをの愛している男は私だけだったのです。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日あの人の室へ出入りした人ですか、それは、神村さんと、村井さんとしきゃ知りません。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどいくら考えたってしかたがないですもの、成るようにしきゃならないんですもの」荻生さんは清三のつねに沈みがちなのを見て、こんなことを言った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だってまだ一題しきゃ出来てないんだもの。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの若い時は羽織の紋が一つしきゃないのを着て通人とか何とかいって喜んでいた。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は自分の力だけのことしきゃ出来ないのだから。",
              "citation": {
                "source": "自分だけの世界",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "などとそんなことを真剣に考えて読んだものだが――どんな本を読んでみても自分の頭がわるいせいか結局、なんにもわからないということだけしきゃわからなかった。",
              "citation": {
                "source": "自分だけの世界",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "短篇集なんぞの中には、西洋の事を書いて、西洋人が書いたとしきゃ思われないようなのがあると云う。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあに、たった五露里しきゃないんだから、一息で駈けつけられるよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ骨折り損の銭うしないってことにしきゃなりませんから。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲しきゃお母さんが貰いにくればやるって、そうお言い」　終業式の前頃に、子供達の家からは何かと教師に贈られるのが常だった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは親切な人でもそうした時はいやがりますからね」「そうね、人は冷たいですからねえ、それにあなたは少しきゃしゃ過ぎるようだけど、今までにひどい病気したことがありますか、東京へ来てから……」「あります。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウイスキー入りの珈琲は一つしきゃ通っていないのに、そんな事を云うんです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十何人居た受験者が、タッタ二人しきゃ居ないんだ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
