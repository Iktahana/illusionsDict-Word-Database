[
  {
    "uuid": "ce4193c4-318e-57d1-a4da-7044069d06b0",
    "entry": "勝負",
    "reading": {
      "primary": "しょうぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "victory or defeat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勝負事でも始めるか酒でも飲むしか仕方はない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二分も経つか経たぬに勝負は私の負けとなつて、忽ち立て続けの負け十回目が終つてしまつた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としてはまだも少し突きたい欲望が残つてゐたわけなので、猶も勝負を続けたが彼等の勝手決めな観念がみす／＼自分に向つて放たれ、そして私以外の三人の間では立派に通用しつゝあるのをみると、イヤな気がして来たので、恰度十三回目が終ると、其処を出てしまつた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝負に勝つても、いまのままでは、横綱になれません。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家と国家と戦争して勝負をつけるように、プロレタリアートとブルジョアジーも、戦って片をつける。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "にっこりと笑った三要は払子を打って法戦終結を告げ、勝負は強いて言わずに、次の言葉を発しました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道では、今でもまだ人間と動植物が生存競争をやっていて、勝負がまだ付いていないという事は札幌市内の外郭を廻っても分る。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝負事には一切見向かない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争でなくても、これだけの心尽くしの布片を着込んで出で立って行けば、勝負事なら勝味が付くだろうし、例えば入学試験でもきっと成績が一割方よくなるであろう。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝負事を否定する（第百十一段）かと思うと、双六の上手の言葉を引いて（第百十段）修身治国の道を説いたり、ばくち打の秘訣（第百二十六段）を引いて物事には機会と汐時を見るべきを教えている。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この他にも賭事や勝負に関する記事のあるところを見ると著者自身かなりの体験があったことが想像されて面白い。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にデンプシーの審判で勝負が決まった時｜介添に助けられて場の中央に出て片手を高く差上げ見物の喝采に答えた時、何だか介添人の力でやっと体と腕を支えているような気がした。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤知らずに尚も、Ｔ「尋常の勝負ならば　断じて大吉如きに」　大吉が後を続けた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五左が、Ｔ「白倉源五左衛門が　勝負しよう　道場へ来いッ」　と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うものが運命なら運命のぎりぎりの根元のところへ、向うものが事情なら、これ以上割り切れない種子のところに詰め寄って、掛値なしの一騎打の勝負をしよう。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この勝負を試すには、決して目的を立ててはいけない。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に寫眞、音樂、園藝などと各種の趣味をあさつたが、勝負事にも相當に感興を持つた方で、撞球は二十四五歳の頃百五十點突いた。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな勝負事も背後に生｜活問題が裏附けるとなれば一そう尖鋭化してくる事は明かだが、それにしても將棋がああまでも戰はなければならぬものになつて來た事は正しく時代の推移の然らしむる所であらう。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も勝負だ、戰ひだ。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴落されて憐憫を待つ如き心｜掛なら、初めから如何なる勝負にも戰ひにも出る資格はない譯だ。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論技を爭ひ、機を捉へ、相手を覘ふ勝負事だ。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然、そこが麻雀の長所でもあり短所でもあつて、どつちかと言へば玄人筋のガンブラアには輕蔑される勝負事のやうに思はれる。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　日本の麻雀も近頃は少々猫も杓子もの感じになつてしまつたが、僅か四五｜年ほどの間にこれほど隆盛を見た勝負事はあるまいし、またこれほど組織立つて麻雀を社會化したのも日本だけではあるまいか？",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、讀書人夏目漱石は勝負事には感興を持つてゐなかつたのであらうが、それは麻雀競技の甚だ漠然とした、斷片的な印象を數行綴つたのに過ぎない。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いふまでもなく先生は私の三田｜文科生時｜代からの先生であるが、球突では始終喧嘩相手で、銀座裏の日｜勝亭で勝負を爭つて、その成績で風月｜堂の洋食のおごりつこをしたなどもしばしばである。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、負けても實はおごつて頂く方が多かつたがどういふのかこの師弟の勝負はとかくだれ勝ちで、仕舞ひには兩方｜共憂鬱になつて、むつつりしたこはい顏つきで變に意地にかかつた仕合になつてしまふ。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十三年から十四年への晩を除夜の鐘を聞きながら、先生と勝負を爭つた事もある。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、勝負をしながら畫談を聞かせて頂いたりするのも、私には一つの樂みだつた。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心よき誘惑　とにかく球突といふものは少し味が分つてくると、實にデリケエトな興味のある勝負事だ。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば秋の温泉塲の靜かな夜更けなどに、好もしい相手と勝負に熱中しながら、相當腕が出來なければ冴た。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
