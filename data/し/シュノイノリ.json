        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『主の祈り』をとなえたように思われます。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子はやっと四つになったばかりでしたが、それでもほかの子供たちと同じように、『主の祈り』をとなえることができました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため母親は、毎晩その子の寝床のそばにすわって、その子が『主の祈り』をとなえるのを聞いてやるのでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親はいちばん小さい子の寝床のそばにすわって、いまこの小さい子が『主の祈り』をとなえるから、みんな静かになさい、と言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "いましも『主の祈り』を声高にとなえているところだったのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "カイは、こわくてたまらなくなって、「主の祈り」をとなえようとしました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、小さなゲルダは、「主の祈り」をとなえました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲルダが「主の祈り」をとなえおわったときには、ゲルダのまわりを、天使の軍隊がとりまいていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間がお願いしなければならない、あらゆることが、この『主の祈り』のなかに、わずかの言葉で、言いあらわされているんだよ！",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、出かけるまえに、まず、おとうさんのお墓におまいりして、「主の祈り」をとなえました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は教会で集まりの終わり頃に、みな立って「主の祈り」を一緒にいのる時、「われらに罪を犯すものをわれ赦すごとく、我らの罪をも赦し給え」というところになるといつでも涙が滲みます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は教会で皆と一緒にあの「主の祈り」を合唱して「われらに罪を犯すものをわが赦すごとくわれらをも赦したまえ……」というところに来ると涙がこぼれる。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕五時、禮拜堂のお祈りにも參列させて頂いた、一同が和して唱へる『主の祈り』こそ、神の嘉し給ふところであらう。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に栄一は心より主の祈りの中にある――『我等に日用の糧を今日も与へ給へ』と、祈る意味が初めてわかるやうに思つた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏同心の決意を固めた衆徒にとっては、山王大師の憐れみも、天台座主の祈りも、無駄であったのだ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃公は目を瞑って、主の祈りをした。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃公は主の祈りを五六度した。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はなんとかそれらを追い出そうと主の祈りを繰り返し、そのうちＴ.Ｓ.エリオット氏の現代主義的な『荒地』のような記憶のごた混ぜの中に消えていった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆は耳が聞えず、眼は閉じているため、ヴィンセントが祈りを続けていると思いこみ、口の中でボソボソと主の祈りを繰返して余念がない。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで――で、主の祈りというのは、どういうのかね？",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人見　しゅ、主の祈りでございますか？",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――主の祈りをとなえながら、その拍子に合せてキカン銃を打っていたヘイタイが居た――こないだ本で読んだんですよ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に歯のない老婆が数人いたが、そういう人たちでもラテン語の主の祈りを暗記していて、まるで子供の時から知っているかのようであった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう調子で、その村の信者には主の祈りを知らない者はなく、その発音もポルトガル人に劣らなかった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "会堂を出る前に主の祈りを三唱し、信者らも合唱する。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はラテン語で主の祈り、アベ・マリア、使徒信経、サルヴェ・レギーナ（処女マリアへの祈祷歌）などを教え、日本語で神の十誡、教会の制令、重大な罪、これに対する徳、慈善の事業などを教えた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」五　気晴らし　食堂の扉の上の方に、人をまっすぐに天国に導くためのものであって純白なる主の祈りと称せらるる次の祈祷が、黒い大字で書かれていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いみじき純白なる主の祈り、神自ら作りたまい、神自ら唱えたまい、神自ら天国に置きたまいしもの。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奴を捕まえられるように、『主の祈り』を十回と、『アヴェ・マリア』を十回唱えよう。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "『主の祈り』より『アヴェ・マリア』のほうが唱えやすいようだ。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
