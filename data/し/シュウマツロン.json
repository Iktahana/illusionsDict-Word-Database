        "examples": {
          "standard": [
            {
              "text": "終末論は、宗教や哲学において古くから議論されてきたテーマである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、人類の未来に対する悲観的な終末論に共感していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "終末論的な予言は、人々に恐怖や希望の両方を与えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "靈魂不死性の思想はこの歸結を要求するであらうが、プラトンは、オルフィク教の影響の下にかれが説いた終末論の示す如く、一定の期間にこの練習を限局した。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにイエスの預言は概念的な終末論ではなく、おのれの名を信ずる者に対する愛の発露として、実際的な注意を与えられたものでありました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
