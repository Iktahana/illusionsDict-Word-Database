    "definitions": [
      {
        "index": 1,
        "gloss": "there's no (other) way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのようなこと、決してないのです』と夫人が言うに対しても、『心からの話、真面目のことです』と言い、『仕方ない！",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠にパンセは言葉にたよる他、仕方ないものなのか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも仕方ないのだ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながらカムパネルラが出て来るか或ひはカムパネルラがどこかの人の知らない洲にでも着いて立ってゐて誰かの来るのを待ってゐるかといふやうな気がして仕方ないらしいのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕まだ来ないものは仕方ない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝はすぐそこだし、ここを下りるより仕方ない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つじゃ仕方ない、お一人十ずつとしても六十なくちゃだめだ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうも仕方ないことは、私たちのイギリス海岸では、川の水からよほどはなれた処に、半分｜石炭に変った大きな木の根株が、その根を泥岩の中に張り、そのみきと枝を軽石の火山礫層に圧し潰されて、ぞろっとならんでいました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方ない夜明け迄に一ぺん宿へ引っ返し日が出てから改めて出掛けよう。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは乱視だから仕方ないさ。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもどうも仕方ない。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもやっぱり仕方ない。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは火の性質だから仕方ない。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云う、熱いもの、乾かそうとするもの、光るもの、照らそうとするもの軽いもの騰ろうとするものそれを焔と呼ぶのだから仕方ない。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてそうかと云うならばそれはそう云う性質のものを水と呼ぶのだから仕方ない。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもぼくのはほんとうだから仕方ない。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ仕方ない、わしは外に持っていないからな。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやだけれども仕方ない。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながらカムパネルラが出て来るか或いはカムパネルラがどこかの人の知らない洲にでも着いて立っていて誰かの来るのを待っているかというような気がして仕方ないらしいのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「仕方ない、とろう。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでぼくは早く何か喰べたいんだが、どうも斯うどこまでも廊下じゃ仕方ないね。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうか、じゃ仕方ない。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えい、仕方ない。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清作はどうも仕方ないというような気がしてだまって画かきについて行きました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がどうと吹いてぶなの葉がチラチラ光るときなどは虔十はもううれしくてうれしくてひとりでに笑へて仕方ないのを、無理やり大きく口をあき、はあはあ息だけついてごまかしながらいつまでもいつまでもそのぶなの木を見上げて立ってゐるのでした。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝はすぐそこだし、こゝを下りるより仕方ない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうも仕方ないことは、私たちのイギリス海岸では、川の水からよほどはなれた処に、半分石炭に変った大きな木の根株が、その根を泥岩の中に張り、そのみきと枝を軽石の火山礫層に圧し潰されて、ぞろっとならんでゐました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうに、かしはばやしの青い夕方を、ひとりで通りかかつたり、十一月の山の風のなかに、ふるへながら立つたりしますと、もうどうしてもこんな気がしてしかたないのです。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうにもう、どうしてもこんなことがあるやうでしかたないといふことを、わたくしはそのとほり書いたまでです。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、かしわばやしの青い夕方を、ひとりで通りかかったり、十一月の山の風のなかに、ふるえながら立ったりしますと、もうどうしてもこんな気がしてしかたないのです。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
