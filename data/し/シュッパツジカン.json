        "examples": {
          "standard": [
            {
              "text": "ツアーのしおりを確認すると、明日の朝の出発時間は厳守と書かれており、遅刻は許されない雰囲気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ねえ、出発時間までまだ1時間もあるし、駅のカフェでゆっくり朝ごはんを食べない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "道路の渋滞を予想して、予定していた出発時間を30分早めることにし、家族全員にグループチャットで連絡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "出発時間の迫った旅人の様な気持に追立てられて、彼はひたすらに書いた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発時間はと聞けば、午前十一時十分だという。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の人や記者団からは、明日の御出発時間を問合せて来る。",
              "citation": {
                "source": "秩父宮殿下に侍して槍ヶ岳へ",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど午前八時が出発時間になっていた。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "メアリの出発時間が近づくと、別れが心配になった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、出発時間がさし迫り、このグラントリーを去らねばなりません」　エレンはそれ以上言わず、背を向けて、客間へ戻って行った。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
