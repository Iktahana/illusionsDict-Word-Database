    "definitions": [
      {
        "index": 1,
        "gloss": "House of Representatives (lower house of the National Diet of Japan)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四月八日の衆院本会議を通ったとき、全く私達は手を握り合ったのであった。",
              "citation": {
                "source": "図書館法楽屋話",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この東京市会議員の選挙からは芽が出て、昭和十一年の衆院議員選挙に当選し、トントン拍子に運ぶようになった。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときの特別国会では、衆院議長も第一党たる社会党がとることに話合いがつき、松岡駒吉氏が議長に選ばれ、ついで首班指名では松岡議長から『片山哲君が内閣総理大臣に指名されました』と宣告した。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
