        "examples": {
          "standard": [
            {
              "text": "脊髄の上部にある神経管は、やがて脳と脊髄に分化する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "胎児の神経管閉鎖障害を防ぐため、葉酸の摂取が推奨されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神経管の形成は、発生の非常に早い段階で行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "葉酸への興味の他の方向は神経管欠損（脊椎披裂）の赤ん坊を産む母親の多くは収入が少ないグループに属するというイギリス連合王国における観察から出発した。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性がふつう妊娠したと自覚する受胎の最初の21日以内に神経管の欠損が起きるからである。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "表１　神経管欠陥（NTD）の再発。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前に新生児または胎児に神経管欠陥があった女性において次の妊娠時にマルチビタミン・サプリメントの有無による再発の比較1。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "3 イギリス連合王国内で神経管欠陥が前者で最も少なく後者で最も多いので選ばれた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
