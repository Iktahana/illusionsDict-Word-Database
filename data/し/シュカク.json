[
  {
    "uuid": "9cad5b29-1ae5-5112-aa25-3bfc762ed6ef",
    "entry": "主格",
    "reading": {
      "primary": "しゅかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
