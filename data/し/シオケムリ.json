        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一色の海岸にうち寄せる夕浪がやや耳に音高く響いて来て、潮煙のうちに、鎌倉の海岸線から江の島が黛のように霞んでいる。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞻むれば一｜隻の海賊船は轟然たる響諸共に、船底微塵に碎け、潮煙飛んで千尋の波底に沈み去つた、つゞいて起る大紛擾、一艘は船尾逆立ち船頭沈んで、惡魔印の海賊旗は、二度、三度、浪を叩くよと見る間に影も形も。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一色の海岸にうち寄せる夕浪がやや耳に音高く響いて来て、潮煙のうちに、鎌倉の海岸線から江の島が黛のやうに霞んでゐる。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔或る僧侶が幕府に獻言し、枝一本腕一本とかいふ嚴しい法度を作り、この松原を育てゝその蔭の田畑の潮煙から蒙むる損害を防いだものであるさうだ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "駿河灣一帶の風光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにヤット波の絶頂まで登り詰めてホットしたと思う束の間に、又もスクリュウを一シキリ空転さして、潮煙を捲立てながら、文字通り千仭の谷底へ真逆落しだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の磯恋しき人の網洩れし小鯛かくれて潮煙しぬ　春の磯を歩いてゐると静かに寄せる波が岩の間にもまれてぱつと小さい潮煙が上がる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "全帆、はり裂けんばかりに帆桁を鳴らし、躍りあがる潮煙は迷濛な海霧ばかり。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "一刻一刻と風は高まり、海は白い泡をかぶって、たてがみのような潮煙を立てた。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、高い潮煙が障壁から躍り上がって、人も巌も、その真白な飛沫をかぶるのだった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて潮煙の彼方に、陸地が現われる。",
              "citation": {
                "source": "風景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、潮煙の立つ荒寥たるこの磯に、亡くなった妻の形見と思って来た、というのだが、句々緊張して然かも情景ともに哀感の切なるものがある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつに浪が打ちつけ、しぶき、吹き、まるで霧のやうな潮煙りが崖を驅けのぼつて、その廣い傾斜地を濛々と匍ひ上る。",
              "citation": {
                "source": "南方",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕地の秣、榛の木の新芽などは潮煙りをしつきりなく浴びるので、葉末が赤茶けて、鏝をあてたやうに縮み、捲き上つてゐる。",
              "citation": {
                "source": "南方",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲のあなた、日本海の上に、潮煙りに巻かれて点在している、孤島の姿が映って見えた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、ヒユツ、ヒユツといふ音を立てて、潮煙を立てた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初潮煙が船の艫を衝いた、と思ふと、海水の束は何物をも破壞するやうな勢で、どつと打つかつて來た。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひ――ッ……という傷手をふくんだ声が千鳥ヶ浜をかすれて行きましたが、一瞬の剣風をかわして、お粂の影がまたドドドドと砂地の浜をこけつまろびつ、死に身になって逃げ廻るのが、黒く明るく、潮煙と月光のなかに見える。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
