        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正札を見ると百二十円とあった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば、月並みな陳套な正札付きの真実よりも、うそから出た誠にかえってより多くのより深き真実を見いだすこともありうるという意味で、こうした言葉を使っているのではないかと想像される。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴屋の安売――運動靴に、平常靴に、雪靴に、金と赤のイヴニングシューズまで寄せて一円五十銭也と括りの紐の結び目に正札で下って居ます。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか三越の六階で薔薇を見ていたら、それにもちゃんとこの虫がついたままに正札をつけてあるのを発見して驚いた事がある。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく拭き込んだ板敷の床は凸凹だらけの土間に変り、鏡の前に洋酒の並んだラック塗りの飾り棚の代りには縁台のようなものが並んで、そこには正札のついた果物の箱や籠や缶詰の類が雑然と並んでいた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころには書物の値段は正札でなく一種の符徴でしるしてあった。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男もので手さえ通せばそこから着て行かれるまでにして、正札が品により、二分から三両｜内外まで、膝の周囲にばらりと捌いて、主人はと見れば、上下縞に折目あり。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と眼を※りしが、天なるかなと断念て、「以後は正札附になすってはどうです、その方がお手数が懸りますまい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　Ｈ――氏は正札と見比べるように、私の財布の中味を覗き込んだ。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店の女房が、東京ものは清潔ずきだからと、気を利かして、正札のついた真新しい湯沸を達引いてくれた心意気に対しても、言われた義理ではないのだけれど。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、註文通り、火鉢に湯沸が天上して来た、火も赫と――この火鉢と湯沸が、前に言った正札つきなる真新しいのである。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白山下の花屋の店に、二銭の正札附でサフランの花が二三十、干からびた球根から咲き出たのが列べてあった。",
              "citation": {
                "source": "サフラン",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「未だ、ありますよ――あんなのが……」　主が棚を指差したので、見ると、其処には僕等の大きな手風琴が、「金三円也」といふ正札を貼られて、載せてあつた。",
              "citation": {
                "source": "馬車の歌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正札を貼りつけるなんて、何といふ皮肉な親爺だらう。",
              "citation": {
                "source": "馬車の歌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "無装飾のスッキリした、少しも体裁を飾らない、微塵も忌味ッ気がない江戸前の雑誌であって、正札附金三銅が貧乏書生に取っては殊に嬉しかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それは左も右くもとしてこの額面の正札が、驚く勿れ、金六十八円｜也とある。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "イクラの前借を申込んだか知らぬが、多分この正札の額よりも少なかったろう。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉服屋の飾窓に自分の年と恰好した品物が目につくと、なんとなく寄つて見て正札を覘き込んだ。",
              "citation": {
                "source": "神樂阪の半襟",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時ちらと夫がいゝと云ふ柄の正札を睨んだ。",
              "citation": {
                "source": "神樂阪の半襟",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売の巻最新式「無言の正札」　或る哲学者がこんな事を云った。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその品物のどれにもこれにも、一つ残らず大きな正札が付いているから、一層現実的である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか浅草のカフェーの菓子、握りすし、盛すし、天プラ、印形、青物なぞ、何でもカンでも正札付きで、中には支那料理の折詰なぞいう珍品もある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無正札は「女」だけ　浅草辺の店ではショーウインドに凝った趣向なぞを用いない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗や看板なぞを極端に派手にする代り、店の中は窓も棚もテーブルも一面に商品を並べて、悉く大文字の正札をつけておく。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石に丼屋や何かいう喰物店は実物を並べて正札をつけてはないが、それでも中に這入ると壁一パイの正札である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "喰べる処は大抵椅子｜卓子式で、腰をかけるとすぐに、「何に致しましょう……畏まりました……エエ、五十銭に八十銭に一円……一円二十銭と四通りで……」　とあたりに響く大きな声で正札を云う。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリギリ決着のところ、浅草で正札の付いていないものは、「女」だけと云ってもいい位である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした大文字の正札式は浅草ばかりではない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を云うとその道の人に笑われるかも知れないが、論より証拠、こうした正札一点張りの店で買ったり喰ったりしたあと、正札の付いていない店へ行くと、何となく不安心な上に、一々店の人に出してもらったり、価格を聴いたりしなければならぬので、恐ろしく面倒な気持がする。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
