        "examples": {
          "standard": [
            {
              "text": "風が吹くと、木の葉が**しゅるしゅる**と音を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいスカートのシルク生地が**しゅるしゅる**と心地よい音を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あ！見て、このヘビ、**しゅるしゅる**って地面を這ってったよ！」と子供が指さした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "附近では爆弾破裂の音を聞いた人が殆んどなく、しゅるしゅるという音だけは聞いたそうな。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、ぼくのたてた音に気づいて、ヘビはすなのなかへ、ふんすいがやむみたいに、しゅるしゅるとひっこんでしまった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、酔眼をみはって見廻したとたんに、廂の上を、しゅるしゅるッと、力のない外れ矢の這う音がした。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
