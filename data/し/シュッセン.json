    "definitions": [
      {
        "index": 1,
        "gloss": "departure of a ship (from a port)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "巡査と駅員に守られて一旦乗船したが出船間際に連れ下ろされて行った。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンナイ河に翩々と帆かけた米穀輸出船は彼の指揮によって饑饉と、戦禍の彼の本国に積出された。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーウ、ボーウとサイレンが　出船みたいになつてゐる。",
              "citation": {
                "source": "島",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸に繋いであるモーターボートを見ると、急に思い立ったものと見え、運転手に町のスタンドからガソリンを買わして来てまでして、ボートを借りて出船して行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この高浜は、盆前から夏一杯、入船出船で繁昌し、一浦が富貴する。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　絶縁の書　ここにて朝鮮行の出船を待つほどに、ある日無名氏より「荷物｜濡れた東に帰れ」との電報あり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを書いてゐるうちに、吹き降りの夜があけると、磯の方から出船の貝笛の音が聞えて来る。",
              "citation": {
                "source": "痩身記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は、今は、前航海の、夜中におけるサンパンの中の船長でも、出船前の室蘭における彼でもなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "出船も入船も、それらの乗員たちは一勢にカルラの舞ひを見あげてゐるのだらうとおもはれるやうな鈍い滑らかな船あしであつた。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "出船が、夫々の人数を乗せて次々に渚を越えると、陸では殆んど感じなかつたが沖に出るに従つては順風が立つてゐると見えて、赤や黄や白など、三角や四角のとりどりの帆を挙げてゐた。",
              "citation": {
                "source": "海路",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかには恥を忍んで、のぼり下だりの旅人や、出船入船の商人を相手に、色をあきなうもあると聞く。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ女体よりの下り路に、北斗石、紫雲石、高天原、側面大黒石、背面大黒石、出船入船などの奇巌、峯上に突起す。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中にて、出船入船と名付けたるは、稍くの心地す。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕の出船入船、落ち込む客の全盛は、花の晨雪の夕、十六島はいふも更なり、香取、鹿島、息栖、銚子の浦々まで一望に浮び、富士、筑波の兩峯は西南に連なり、眺望世にすぐれたる好境也』と。",
              "citation": {
                "source": "北總の十六島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "この出船の時の人々の気組み働きは、だれにでも激烈なアレッグロで終わる音楽の一片を思い起こさすだろう。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今日は一切此処より出船しないという。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "出船入り船帆影も繁き石の巻からそのお城下までへは、陸前浜街道を一本道に原ノ町口へ抜けて丁度十三里――まさかと思ったのに、およそ退屈男程気まぐれな風来坊も稀でした。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてこの家の舊い習慣として、その前後に催さるる入船出船の酒宴には長崎の紅い三尺手拭を鉢卷にして、琉球節を唄ふ放恣にして素朴な船頭衆のなかに、柳河のしをらしい藝妓や舞子が頑くななな主人の心まで浮々するやうに三味線を彈き、太皷を敲いた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩竈の町は遠い昔から色の港で、出船入り船を迎うる女郎山の古い名が今も残っている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、出船の合図に、法螺を吹く掛りがあるね、あれにならなれる自信があるんだ。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい一くちにばいろあるとといえば、それは直ちに「坂の上の娼家横町」を語意していた――そして、そこの白っ茶けた建物の窓から、朝夕の出船入船の景色が、まるで大型活字の書物の一頁を読むように詳細に一眼だった。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "波止場（出船の船、波音、人声、老弱男女）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜四時過乗船、夜半出船。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫より六月四日より桜島と言、蒸気船ニて長州へ使を頼まれ、出船ス。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十二月四日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "又承り候得バ、早明日御出船と、定而此頃御多用ニ候べしと奉存候得バ、事ニより近日山口までも御尋申べきかと奉存候間、何卒御面遠ながら御足お止められ候所を一筆｜御印置可被遣よふ｜奉希候。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十二月十五日　木戸孝允あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに用向がすめバ一日も止り候ハ、甚よろしからぬ事故、早※出船御セ話可被遣候。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十二月二十日　伊藤助太夫あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は、照国丸といふ船が、朝九時に出船しますと、夜明け頃、火鉢の火を運びに来た時に知らせてくれた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから天保山あたりに泊って、翌日出船した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
