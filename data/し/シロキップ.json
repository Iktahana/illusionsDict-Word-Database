        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は豪華なクルーズ旅行のために、奮発して白切符を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "一度でいいから、白切符で新幹線に乗ってみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_text": "白切符の乗客は、専用ラウンジで出発までの時間を過ごせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "翌日出帆の上海行汽船の白切符を買って来いと命じて、私はその上海行きの長崎丸という汽船に乗って盛広の短刀と一緒に一切の事実を告白した遺書を残して、海中へ飛込む計劃である。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って一等の白切符を上等と称し、三等の赤切符を下等と呼んだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車なら無論白切符か特等車で、自動車なら紋章入り、一台以上の格である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう云ふおれでさへ上等を奮発して白切符を握つてるんでもわかる。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうおれでさえ上等を奮発して白切符を握ってるんでもわかる。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
