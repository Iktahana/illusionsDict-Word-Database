    "definitions": [
      {
        "index": 1,
        "gloss": "scene",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雷の音が次第に急になって最後にドシーンと落雷したときに運｜拙くその廻送中の品を手に持っていた人が「罰」を受けて何かさせられるのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝苦しい、麹室のようなムンムンする、プロレタリアの群居街でも、すっかりシーンと眠っていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その試験問題の討究のために試験官仲間をターリングに招待したが、そのためにソリスベリー卿とディスレリーとの和解の饗宴という歴史的のシーンに出席する機会を逸した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い旅路と季節の推移を示す短いシーンの系列など、まさに挿画を順々にめくって行く気持である。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この過程と、映画の一つ一つのカットの連続を見てその一つのシーンの内容を理解する過程とは大体において同じようなものである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日お前を訪ねて此処へ来るそうだ」　「だから今夜の中にたってしまえば、まさか吉兵衛の奴も、気がつくめえと思うンだ」（ＷＩＰＥ）Ｓ＝奥座敷（前のシーンと同じ）　石松、大分飲んだ後の感じです。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ「翌る朝」Ｓ＝ファーストシーンの町角　てっきり鉄と三次が今日も亦ばったり出会った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにラストシーンがダレると困りますから、三四郎の立廻りをなるべく簡単にやって頂きたい）Ｔ「空晴れて風そよぐ――」Ｓ＝垂れ下った柳　静かな川の流れ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝村の小川の水車の辺りで　六助とお絹のラヴシーン。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳がシーンと鳴っている。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあまりたいした成効とは思われなかったが、しかしともかくも人間のドラマのシーンの中間に天然のドラマの短いシーンをはさんで効果を添えるということは、従来よりももっともっと自由に使用してよいわけである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "連句における天然と人事との複雑に入り乱れたシーンからシーンへの推移の間に、われわれはそれらのシーンの底に流れるある力強い運動を感じる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのシーンの推移のテンポは緩急自在で、実に目にも止まらぬような機微なものがある。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々が見ているものは実は筋でなくしてシーンであり、あるいはむしろシーンからシーンへの推移の呼吸である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「忠弥」の貧民窟のシーンでもがそうである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいよいよ次の画面が現われて観者の頭脳の中の連続的なシーンと「コインシデンス」をする。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相合傘の下に、　いきち、おるい　その戯書の大写からＯ・Ｌして、７＝元のお類の待っていた処　お類と伊吉のラブシーンです。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）２８＝（Ｆ・Ｉ）例の生島屋附近　伊吉とお類のラブシーン。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）28＝（Ｆ・Ｉ）例の生島屋附近　伊吉とお類のラブシーン。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまあ一般に言えば人の秘密を盗み見るという魅力なんですが、僕のはもう一つ進んで人のベッドシーンが見たい、結局はそういったことに帰着するんじゃないかと思われるような特殊な執着があるらしいんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕は今はもう実際に人のベッドシーンを見るということよりも、そんな自分の状態の方がずっと魅惑的になって来ているんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると次は秘密のなかでもベッドシーンの秘密に興味を持ち出した。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから秘密のなかでもベッドシーンの秘密が捜したくなって来る。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥は大分深いかして何の音も聞えて来ぬ、シーンとしている。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
