    "definitions": [
      {
        "index": 1,
        "gloss": "twelfth month (esp. of the lunar calendar)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
