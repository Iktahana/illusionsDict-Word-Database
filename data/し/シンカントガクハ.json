    "definitions": [
      {
        "index": 1,
        "gloss": "neo-Kantian school",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
