    "definitions": [
      {
        "index": 1,
        "gloss": "to endure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "就中高山植物の美麗は熱帯の壮大華麗なる花を凌ぐのであるが、高山植物の美観は他日題を改めて説くつもりである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨露を凌ぐ菰の小屋さえ建てて呉れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉が落ちかけて居るけれど、十月の熱を凌ぐには十分だ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "千万たびの死を凌ぐのでございます。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、苦労に立ち向って、これを凌ぐ力を養わねばなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "凌ぐ力が養えたら、苦労があってもないのと同様であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小間物店の若い娘が、毛糸の手袋｜嵌めたのも、寒さを凌ぐとは見えないで、広告めくのが可憐らしい。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨露｜凌ぐ軒はまだしも、堂｜社の縁の下、石材や、材木と一所にのたっている宿なし同然な身の上だで、御挨拶も手続も何も出来ねえですで、そこでもって直訴だでね、生命がけで願えてえだな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十の佐十さんは壮者を凌ぐ程の元気。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "乘組の人員は、五人が定員で、車内には機械室の外に、二個の區劃が設けられ、一方は雨露を凌ぐが爲めに厚さ玻璃板を以て奇麗に蔽はれ、床上には絨壇を敷くもよし、毛布位いで濟ますもよし、其處は乘組人の御勝手次第、他の區劃は彈藥や飮料や鑵詰や乾肉や其他旅行中の必要品を貯へて置く處で、固定旅櫃の形をなして居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、適当な場所をと見廻したが、ここらは一面の禿山と原で更に露を凌ぐに足るほどな処もない。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "金子で買って凌ぐような優長な次第ではないから、餓えてるものは何でも食いな。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "淺草でも、銀座でも、上野でも――人の往來、店の構へ、千状萬態、一卷に道中の繪に織込んで――また内證だが――大福か、金鍔を、豫て袂に忍ばせたのを、ひよいと食る、其の早業、太神樂の鞠を凌ぐ……誰も知るまい。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞食の徒といえども、なおかつ雨露を凌ぐべき蔭に眠らずや。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといっても、かたき討は大石内蔵助と荒木又右衛門に株を取られてしまったので、今更どんな掘出し物をしても彼らを凌ぐことはむずかしい。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、地図によれば此処らは未だ越中の領分で、足腰の疼痛に泣く旅人も無し、山霧に酔う女もあるまいが、更に進んで雲を凌ぐ庵峠を越え、川を抱いたる片掛村を過ぎて、越中飛騨の国境という加賀澤に着くと、天地の形が愈よ変って来て、「これが飛騨へ入る第一の関門だな。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天を凌ぐ山毛欅の梢の間から、僅に洩るる空の色を仰いで、「もう日が暮れるのに間もあるまい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉は折柄の雨を凌ぐ為に、有合う獣の皮を頭から引被って、口には日頃信ずる御祖師様の題目を唱えながら、跫音を偸んで忍び出た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒気を凌ぐ為に落葉を焚く者もあった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角も一時を凌ぐ為に、彼女は此の空屋の戸を明けようとすると、半朽ちたる雨戸は折柄の風に煽られて礑と倒れた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "況て鎖されたる家の内は殆ど真の闇であったが、彼は危くも吹き倒されんとする雪風を凌ぐ為に、兎も角も一歩踏み込もうとする途端に、内には怪しい唸声が断続に聞えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "名は小使だが、一平には特殊の技能と一種の特權があツて、其の解剖室で威張ることは憖ツかの助手を凌ぐ位だ……といふのは、解剖する屍體を解剖臺に載せるまでの一切の世話はいふまでも無い。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内者は味噌の入った握飯を、行く先々で用意し、餓えを凌ぐのだったが、そこまで来るともう安心で、前橋へ入って来たところで、彼は各自の希望を訊き、ここに留まるものは、この町の桂庵に引き渡し、東京を希望のものは、また上野まで連れて行くことになっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌う鳥が囀るんだ、雲雀は星を凌ぐ。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吶々として、しかも沈着に、純真に、縷々この意味の数千言を語ったのが、轟々たる汽車の中に、あたかも雷鳴を凌ぐ、深刻なる独白のごとく私たちの耳に響いた。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっぽりと被るのが、寒さを凌ぐより、半分は見得で、帽子の有無では約二割方、仕立上りの値が違う。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨露を凌ぐなら、私等が小屋がけをして進ぜる。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は天保の饑饉のときにこの尾根一ぱいに野老芋が蔓延って、村民はこれを掘って餓えを凌ぐことが出来たという。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六国の相印を一人の身に帯び車駕の数は王者を凌ぐと称せられて居た合従の策士蘇秦は日に日に落魄の運命に陥り新に秦の宰相であり連衡の謀主である張儀の勢力が目ざましく根を張って来た。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "方角をかえて河岸通へ、しかものそのそと着流しのぐなりとした、角帯のずれた結目をしゃくって行く。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
