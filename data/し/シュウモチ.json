    "definitions": [
      {
        "index": 1,
        "gloss": "serving a master",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ここの女郎は、皆亭主持ちなんだぜ！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人はまだ亭主持ちじゃありませんわ」「亭主でも情夫でも兄弟でも構わねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は亭主持ちだから、そこをよく決めて置かないと、事が面倒ですからね」と、半七は宗助に訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも隠してゐたことですが、実をいふとＯさんは亭主持ちの体でした。",
              "citation": {
                "source": "恋妻であり敵であつた",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、立ち去らむとすれば、文の舍、使に兎一匹もたせて贈り來り、手紙一つ添へ、手荷物に煩はしかるべけれど、例の坊主持ちとやらも、亦一興なるべしとて、狂歌までよみ加へたり。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、こうなって見るとちと面目ねえ、亭主持ちとは知らずに小厭らしいことを聞かせて。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "生娘の癖に、亭主持ちの真似をして、一年近くも物凄い廃屋に納まっているなんてナカナカ義理や物好きでは出来るものじゃないよ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩愛、人情、義理をすてて、ここは、京まで、万難を忍んで、牧を討つべき時じゃ」「はい」「それに討手は、主持ち、わしらは浪人者じゃ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世間にいくらだつてゐる、あの亭主持ちの女と、一体どう違ふんだい……亭主を持ちながら、それが不足でいろんなことをする女とさ、……」それから、最後の一ヶ所は、プウレットが、「見ておやりよ、この色気狂ひをさ……」と云ふと、エリザが「あらさうぢやないんだよ……。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間にいくらだつてゐる、あの亭主持ちの女と、一体どう違ふんだい……」（議場騒然）　かう騒がしくては本文を読み上げることができません。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから兄貴、ここいらで見切りをつけて、二人が馴れ合って、こいつを坊主持ちということにして、江戸へのしてしまおうじゃねえか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、この名刀を坊主持ちにして、例の甲州街道を、都合よく縫って通ります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだい、兄貴、こうして坊主持ちも根っから新しくねえ、これから江戸へ着くまで、二人で腕っくらべをやろうじゃねえか、おたがいに出し抜いて、せしめた方が、この刀を物にするということにしようじゃねえか、売り飛ばして山分けにするよりは、その方が柄に合って面白かろうぜ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のいう、甚内様、永護様という変態な神様の縁起は、大よそこういったようなもので、二人は例の伯耆の安綱を坊主持ちにして、高尾の山の飯綱の社から、浅草鳥越まで行く間に、その名刀の処分をきめようとするのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、亭主持ちが二人、あとの三人は、二十を越したばかりといふ娘つこでございませう。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私はこうして旅から旅を渡り歩いて日を暮す女ですが、これでも亭主持ちなんです。",
              "citation": {
                "source": "鉄の処女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主持ちじゃあねえ。",
              "citation": {
                "source": "口笛を吹く武士",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "このふっくらしたやつを一人で抱いてくなんて理窟はねえ」「じゃあ、恨みっこねえように坊主持ちだ、坊主もちだ！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "この往復電車賃もすべて店主持ちである。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "使用人としては、原紙などの運び役に櫛原万造という大酒飲みのじいさんと、私が日給二十銭で雇った亭主持ちの女子作業員、おげんさんの二人。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豊どの、お前は亭主持ちのはずじゃ」「ええ……」　お豊は竜之助の前へその事情を自白しようとするところでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "竜神の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやで添わされた亭主持ち、金で辱しめられた女の仕返し、そんな事も有り得ることなんですが、あの舟のは、そんなんでもないようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞと思ふ女がみんな亭主持ちなんだから、世の中が嫌になるぢやありませんか」　八五郎は飛んでもないことを言ひ出して、大して悲觀する樣子もなく、ニヤリニヤリとするのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "艶妻傳",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣をつけろ、相手は亭主持ちだ」「その父親ほども年の違ふ亭主に、癪にさはるほどよくしてゐるんで、腹が立つぢやありませんか」「何んだ、褒めたり腹を立てたり」「二十七八でせうかね。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "艶妻傳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうなると主持ちは哀れだ」と七十郎は盃を取って、くすっと笑いながら云った、「おれは斬っても斬られても、迷惑する者も泣く者もない、ところが扶持を貰い、家族縁類があると、そうはいかないからな、――おい佐平、二人を送ってってやれ」「万右衛門、刀をおさめろ」と渡辺七兵衛が云った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主持ちと、出先には知られているので、媾曳はきかないし、河合は、来るのは嫌だというし――それにも焦々していた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっ腰のない主持ちのおさむらいなんぞにゃあ、どうせ喧嘩はできまい」　そこらの角丸太、金づち、切れ物などを、手当り次第に持つと、あわや一かたまりの旋風になって、あとを追いかけようとした。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ましたかえ」「ありゃあ、さだめし亭主持ちだろうな」「ええ、それがまあなんと、可哀そうに、あんな縹緻を持ちながら」「とはまた、どうしてさ、可哀そうたあ？",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……けれどさ旦那、なんたって亭主持ちでしょ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間の見ている手前もあるが、平常でも、主持ちの士とか、少し身分のある武士に対すと、下風にはつかぬぞ、諂いはせぬぞ――と殊さらに態度を持して示す――野武士たちの通有性でもあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
