[
  {
    "uuid": "552aeab5-7020-5f31-a0f0-bb0f46b8e2f1",
    "entry": "師恩",
    "reading": {
      "primary": "しおん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
