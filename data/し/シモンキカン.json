        "examples": {
          "standard": [
            {
              "text": "その諮問機関が出した勧告には法的拘束力はないが、行政に大きな影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "諮問機関のメンバーは、中立的な立場を保つために様々な分野から選ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "内閣が重要事項を決定する際には、関連する諮問機関の意見を聴くことが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "保護期間七〇年延長への道　保護期間延長については、文化庁の諮問機関である文化審議会著作権分科会で、過去、何度か論議されてきた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか半官半民の堂々たる研究諮問機関のやうに聞いてゐる。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなればこれは当時の現政府用の諮問機関の程度を出ないことになるから、この点から尋常な意味における内閣補強工作と見られたとしても仕方あるまい。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘調所は老職総務部に属し、政治の監査と、藩主の諮問機関を兼ねている。",
              "citation": {
                "source": "百足ちがい",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
