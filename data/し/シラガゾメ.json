        "index": 1,
        "gloss": "hair dye (for graying hair)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近代的｜懐疑とか、近代的盗賊とか、近代的｜白髪染めとか――そう云うものは確かに存在するでしょう。",
              "citation": {
                "source": "或恋愛小説",
                "author": "――或は「恋愛は至上なり」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、あのお齢になってさえも、相変らず白髪染めだけは止めようとはなさいません。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "由美子のは、腋臭めいた臭気がするし、八重子のは白髪染めの臭気がする。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪染めの八重子の髪の臭いが、気のせいか鼻についてきた。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪染めをやめたせいか、頭髪に白いのが目立ち、腰が曲ってきたせいか、背丈が縮んだようでした。",
              "citation": {
                "source": "落雷のあと",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワタクシは元来理髪師でございまして、なかんずく、得意といたしますところは白髪染めでございます。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の発明した白髪染めも同じことです。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画壇の斎藤別当尾形月耕翁白髪染めの証人　風俗画で一流を成した尾形月耕画伯、諸事｜恬淡の江戸ッ子気性ながら、その作品に対しては老いてますます熱を加えた。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
