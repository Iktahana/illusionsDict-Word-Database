[
  {
    "uuid": "d8af3f37-8175-5a8c-98c5-46cb494bc082",
    "entry": "詳述",
    "reading": {
      "primary": "しょうじゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
