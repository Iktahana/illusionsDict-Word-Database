        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "されば帝政論派は議院尚早論を紹述して当時に起こり、その父祖の系統において親戚たるにもかかわらず、痛く自由論派に反対し、並せてこの点についての付和論派たる改進論派に反対したり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "其紹述の功勤めたりと謂ふ可し。",
              "citation": {
                "source": "杉田玄白",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「皇宗の後裔に胎し給える統治の洪範を紹述するに外ならず」という一句がある。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
