[
  {
    "uuid": "c3c9de0f-fb20-515d-89e9-cc70e23524bc",
    "entry": "自然",
    "reading": {
      "primary": "しぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
