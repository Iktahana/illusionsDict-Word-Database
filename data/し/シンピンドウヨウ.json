          "literary": [
            {
              "text": "四、五回しか履いてないから、まだ新品同様だぜ」　高志はもう、一六二、三になっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その書付には、品行方正なる馭者、雇われたしというのもあれば、一八一四年パリより購入、まだ新品同様の軽馬車、売りたしというのもある。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "売物は売主と同一のもの、但し、新品同様、履行は、昭和二十九年。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だけどまだ新品同様なんだぜ。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板にある船長の席はきれいに整頓され、木工部や舵輪は飴色に拭きこまれており、機関部へ命令を伝える鐘や、それに付いている打金紐までが、新品同様に保持されている、というぐあいであった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新品同様な蒲団がたった十九円六十銭！",
              "citation": {
                "source": "蒲団",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
