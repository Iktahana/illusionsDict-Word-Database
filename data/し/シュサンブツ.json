        "examples": {
          "standard": [
            {
              "text": "その小国の経済は、天然ガスという唯一無二の主産物によって辛うじて支えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "農業に従事する村人たちにとって、米は単なる食料ではなく最も神聖な主産物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工場の主産物である半導体の出荷が遅れ、自動車業界全体に大きな影響が出ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "周囲は米の産地として有名な地味｜肥沃の庄内平野に包まれているので主産物は米であった。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋久島では、砂糖が主産物だが、そのほかにも、ポンカン、飛魚、牛馬、海藻類、木炭、松脂、木材、樟腦、皮革といつたものが移出される。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はこの副産物と主産物と全く融合して居ることがある。",
              "citation": {
                "source": "和歌批判の範疇",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆ど一致することはあるが、）それより、漸く副産物の量を減じて、部分的に副産物と主産物との交渉あるもの、或は殆ど副産物の加はつて居ないと見ゆるものもある。",
              "citation": {
                "source": "和歌批判の範疇",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても副産物が伴はるゝものとすれば、主産物との融合に努めて見ることも必要であり、又、その融合の程度によつて価値の増減も自から生ずる訳である。",
              "citation": {
                "source": "和歌批判の範疇",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
