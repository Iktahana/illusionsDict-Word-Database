    "definitions": [
      {
        "index": 1,
        "gloss": "eloquence or flattery designed to deceive",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
