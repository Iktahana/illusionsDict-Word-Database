    "definitions": [
      {
        "index": 1,
        "gloss": "social phenomenon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実に十年前には見られなかった新しい顕著な社会現象の一つである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此根本的精神の相違は、日清戦後に比較して日露戦後に於ける醜劣なる社会現象の万端を解決す。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会現象は往々にして作家活動を粗雑なものにしてしまふ場合がある。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "又それを単なる心理現象とも社会現象ともことなつたものであると認めることにも異存はない。",
              "citation": {
                "source": "文学の本質について（二）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会現象はそれ程簡単ではない。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして社会現象を統一的に理解せしめる最もすぐれた方法を与へたものは、少くも現在に於いてはマルクス主義の社会観であることを私は信じてゐる。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、芸術は社会現象のすべてゞはない。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし社会現象が他の部門には進化があるが、文学にはただ流行があるだけだというなら、氏の認識が正しくないか氏の論理が迷走しているかだ。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、昭和四年の文壇に起こった現象の過程も、他の社会現象との連関において、また、少なくも最近数年間の過程との連関においてのみ、はじめて理解することを許されるであろう。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然力、すなわち物理を人々は社会現象という。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての社会現象はこの疑問の中を彷徨してはてしない運命をたどっている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって教育でもないし、文壇は始終触れているし、まあ、社会現象が一番面白そうだ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会現象の中でも就中男女の関係が最も面白そうだが、其面白味を十分に味わおうとするには、自分で実験しなければならん。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろロシアの文学者が取扱う問題、即ち社会現象――これに対しては、東洋豪傑流の肌ではまるで頭に無かったことなんだが――を文学上から観察し、解剖し、予見したりするのが非常に趣味のあることとなったのである。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかくの如き総合的社会現象を完全に科学をもって証明することは不可能のことである。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "また戦争は多くの社会現象の中で最も科学的に検討し易いものではなかろうか。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この自然主義の試みは健康な一面の功績を残したが、今日では常識のうちの理性が成長しているから、自然現象と人間の社会現象の質のちがい、そこに関係して行く人間の意味の相異もはっきり区別されて理解されている。",
              "citation": {
                "source": "人生の共感",
                "author": "――求められる文学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "興味のあることは、こういう種類の読者の層と文学がすきでずっといろいろの文学書も読んで来たというような一部の読者とが、いつの間にやら購買力としてひき出される社会現象のなかで混淆してしまって、これまでの判断や好みをぼんやりさせられてしまっていることである。",
              "citation": {
                "source": "今日の読者の性格",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の論敵たる勢力が「民衆を隷従、蒙昧、無智の状態に引止めて置こうとしている」現代の「非真実」な社会現象との闘いが、今日すべての人間らしき人間の関心事である。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロンタイズムは、全く一九一七年から二三年間の混乱期にふるいブルジョア社会の性的放縦の最後の反映、火花として現れた変則な社会現象であった。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人作家「不振」の原因は、他のすべての社会現象同様、社会組織の如何にあります。",
              "citation": {
                "source": "婦人作家の「不振」とその社会的原因",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風雲」の作者が、その真率でたゆみない天質によって、社会現象に対しては常にまともから相応ずる生き方で、今日までを打ち貫いて来ていることは、作品を一読して、その基調を明かに感じるのである。",
              "citation": {
                "source": "文学における古いもの・新しいもの",
                "author": "――「風雲」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "往々社会科学には実験は不可能だと云われているが、併し社会現象の典型的な出来事はすべて、実験としての意味を後から或いは外部から、持ち得るもので、それを別にしても、色々の実験が、実験としての自覚の下に、行なわれていることを忘れてはならぬ。",
              "citation": {
                "source": "技術へ行く問題",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時は一つの社会現象を又或る時は自覚をすら意味することが出来る。",
              "citation": {
                "source": "空間概念の分析",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学・哲学・宗教・意識・其の他一切の文化現象、社会現象――経済・政治・風俗・道徳――が総て表現でなくてはならぬ。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、一切の社会現象（又間接に自然現象もだ）は批評の対象となる時、文化の問題にまで高められる。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のモラルという、目立つのが一倍損というような社会現象をとりあげて語るならば、私たちは、その頽廃を導き出し、放置し、更に救いがたくしてゆくような、今日の社会の諸矛盾にこそ触れたい。",
              "citation": {
                "source": "人間の道義",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際生産用具はそのように欠乏に欠乏を重ねて来るのに、増産の必要は昂まるし、一方には正規の増産とその配給とを攪乱するような農業会、統制会、闇売買が横行して、農村では近年の一つの病的な社会現象として、物がないのに金はあるという状態になって来た。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の人気の動きというものこそ時代の甘くて辛い裏表を瞬間のうちに表現するのだから、女を人前でいためつけるという一つのあらわれも、決してかるがるしく見すごさせる社会現象ではない。",
              "citation": {
                "source": "私の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身がいわばすでに功成り名をとげた人々であるそれら大多数の婦人たちは、政治的に、すなわち客観的に現実的に社会現象を判断し対処してゆく能力は欠いていて、事大的な追随を政治的な態度と思いあやまって、結果としてはかえって、時局を漫画化する登場人物の役割をもった傾さえあった。",
              "citation": {
                "source": "女性の歴史の七十四年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
