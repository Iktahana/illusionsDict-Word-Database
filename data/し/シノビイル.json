    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to steal or sneak or slip into",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その頃のかやの稚い胸には得態の知れぬ憂鬱がひそかに忍び入ることもしばしばあった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍び入ることなどは叶わぬようにしてもあるし、又物騒の世なれば、二人三人の押入り者などが来るとも、むざとは物など奪られぬよう、用心の男も飼うてある家じゃ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやこれやで、私は、私自身、湖畔の或る古城に忍び入る戦慄の悪徳物語を、断念せざるを得なくなった。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪の音、恋えば聞ゆる、聞こゆればその音の忍び入るお菓子の花の形に。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物｜病ましさのかぎりなる室のといきに、をりをりは忍び入るらむ戯けたる街衢の囃子、あはれ、また、嬰児笑ふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の中、をりをりに雲を透かしてさ緑に投げかくる金の光はまた雨に忍び入る。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに恋愛なる一物のみは能く彼の厭世家の呻吟する胸奥に忍び入る秘訣を有し、奇しくも彼をして多少の希望を起さしむる者なり。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち低い低い、忍び入るような音が、私の耳の底にかすかに響く、――しかもそれは、ベーカー街の方からではなく、自分達が隠れ忍んでいるこの家の後の方から来る音である。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、二時間、あるいは三時間もたってから深谷は、すき間から忍び入る風のように、ドアを開けて帰ってきた。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お留は枝折戸の外に出で、あたりを見まはしながら生垣を押破つて墓場に忍び入るを、お妙は縁に立ちて不安らしく眺めてゐる。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――過去のうちへ忍び入る追憶、それの魅惑的な月光に、ひとは心を傾け尽した。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤次郎にとっては同じ屋根の下にいて、而ももう一人の女給と同じ部屋にねている美代子の所へ、要之助が忍び入るという事は一寸考えられなかったのだ。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてやそれが、祖父とか曾祖父といつた自分の身内の者の登場してくる話ででもあらうものなら、それこそ――自分が曾祖父の魂のなかへ潜りこむか、それとも曾祖父の霊が自分の中へ忍び入るかして、まるで自分自身に経験したことのやうな思ひがされるものぢやて。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "大木の倒さるゝ事幾度ぞ胸をば深き森と頼めど　千古斧鉞を入れぬ処女林のやうに思つて頼みにして来た我が胸にもいつの間にやら忍び入るものがあつてその度に大木が地響打つて伐り倒された。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、忍び入るべき機会は少しも彼に与えられなかった。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷え冷えとした川風がせせらぎの音に連れて忍び入る。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日通る道も眞白く清められて新らしく人の目を惹き何ものか心に忍び入る如く暫らく會は無い空のあなたの遠い人々も思ひ出して心は嬉しく、世界は賑ふ。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "執念の蛇の血は、心地よき流れとなりて、俺が弾ずる琴の糸からあふれ出て、お前の心へ忍び入る。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてこの室へ忍び入るのだろう。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな大芝居でもうたなければ、まるで中世紀の城塞のような辻川博士邸内に忍び入ることはまず不可能だと思われた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少の身分のありそうな武士が、こんな挙動をして人の家に忍び入るのは似合わしからぬことであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分、あの境内に忍び入るには、どの口から向ったのが有利か、それを研究しているのでしょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、別館に忍び入る意外な人物を見出しました。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その九　覆面屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の私は、かの田園の逍遥なぞと、洒落ることこそなかつたけれど小さな我が心臓は、いと気高き渇望に膨らむでゐた如何なる聖霊が我が昂ぶれる五感にまで翼を与へたか私は知らぬが、押黙つた歎賞を以て我が眼は諸々の光景を打眺め、我が胸の裡にやさしき田園への愛惜は忍び入るのであつた。",
              "citation": {
                "source": "ランボオ詩集≪学校時代の詩≫",
                "author": "VERS DE COLLEGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの窃盗が、忍び入る前に盥の中に放糞するも、マジナイであるそうだ。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "朦朧たるものの影は、鶴子の家の扉の前でやや暫くたゆたっていたが、廊下に人のけはいのないのを見定めると、そっと扉を押し開けてその内部へ忍び入る。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルミドネスが王のため巨木の幹を切り倒し、築きて上に、沼澤に刈りて集めし柔き　450蘆荻を以て屋を葺ける其陣營に忍び入る。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、かよわい女が、この夜中に、知ってか、知らずにか、こういう物凄い気分のひそむ室内へ、独り忍び入るということも、愛すればこそで、その怖る怖るの一足一足が、どうしたものか、竜之助の寝ている方へ近寄って来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん扈従の者は遠ざけた二人きりで、燭台の光りが、いかにも秋の静夜らしく、書院窓から忍び入る微風に、ときおりはたはたと揺れていた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――引窓から忍び入るつもりなのだ。",
              "citation": {
                "source": "柿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
