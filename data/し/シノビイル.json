[
  {
    "uuid": "90680bb7-0faf-51c8-8272-2addf5f2bf6e",
    "entry": "忍び入る",
    "reading": {
      "primary": "しのびいる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
