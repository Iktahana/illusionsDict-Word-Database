          "literary": [
            {
              "text": "（やっぱり、あんな不当な謝礼は、頂くのではなかったかしら）金銭の収受は、男女の間をたちまち接近させるものではないかしら、と思ったりした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十歳未満は、窃盗十五人、詐欺一人、殺人六人、嬰児殺し三人、堕胎一人、放火九人、贓物収受一人、文書偽造一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二日参事会収受。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に私は、私の商業手形を収受するのみでなく、これを銀行に譲渡して、期限前の割引を求める。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはまた公力をもって耕作し、収穫全体を収受するのであるか。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
