    "definitions": [
      {
        "index": 1,
        "gloss": "rope used to cordon off consecrated areas or as a talisman against evil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そつちには、そつちで、また改めて、しめ縄を巻かれた神々しい賽銭箱が控へてゐた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに年末の松竹梅と三宝荒神様のための玉の灯明台、しめ縄餅箱を買うことは、われわれの心へいとなつかしき正月の情趣を準備させることだった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "みしめ縄、門の松竹、見る物に春の色あり。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みごとな伊勢海老じゃぞ」　忠相の声が藪から棒に大きかったので、となりにしめ縄をひねくっていたおかみさんの背なかで、おびえた赤ん坊がやにわにワアッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "張りめぐらされたしめ縄に、御幣がたくさん垂らしてある――その山笠が、ゆさゆさ、はげしく揺れながら、恐しい勢で、こちらの山笠に近づいて来た。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "それといっしょに、一人の神さまは、女神のおうしろへまわって、「どうぞ、もうこれからうちへはおはいりくださいませんように」と申しあげて、そこへしめなわを張りわたしてしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "七艘ともにしめなわを張って、どの舟の船頭もまた一様に同じしめなわを腰へ巻きつけ、人目にたたぬように船龕燈をそででおおいながら、いまかいまかと舟宿から出てくる客を持ちうけている様子でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、舟にはしめなわが張ってあるのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭の腰にもまた奇怪なことにしめなわが見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "内庭にはまた水門から堀がつづいて、船頭たちはどこへ姿を消したか、ぬしのないしめなわ舟がなぞのごとくに見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な小娘は、しめなわをものものしげに張りめぐらしたそこの右側の扶桑教祈祷所と見える一軒へ、主従ふたりを誘うかのごとくにおどおどとはいりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "べらぼうめ、もったいらしくしめなわなんぞ張りめぐらしゃがって、きっと子ぬすっとのにせ行者にちげえねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍の樹木にしめなわを張り、その上に豚や牛の骨をかけておくことがあるが、これは疫病よけのマジナイである。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "万作夫婦は朝夕涙に暮れて、茶断塩断して、いつもお光が腰かけた柳の根株にしめなわかけて筑波さまあらぶる神さまに願をかけても、一向に帰って来ぬ。",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も玉島川には、「神功皇后魚釣りの岩」と、しめなわが張ってある。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "野呂栄太郎は、その治安維持法によって殺され、その直接の売りわたし手の査問を担当した事件の裁判に当って、自身もまた同じ悪虐な法律のしめなわにかけられ民衆に対する責任と義務と信頼とを裏切る仕儀に陥った。",
              "citation": {
                "source": "信義について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
