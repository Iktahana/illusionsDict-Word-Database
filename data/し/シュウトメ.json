    "definitions": [
      {
        "index": 1,
        "gloss": "mother-in-law",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "オババサマとは彼の妻の母であって、名義上、小泉家の養子たる彼にとっては、姑の義母に当る老婦人である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンはその妻と共に、姑の老婦人と一家に同居し、純日本風の仕方でよく孝養の道を尽した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姑の婦人もまた、旧武士の家庭に育った士族の娘で、純日本風の礼儀正しき教育を受け、かつ極めて善良に優しい心根の人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの文学に出る日本婦人のモデルは、多くその妻に非ずば姑の老婦人だといわれてるが、すくなくともヘルンは、この点での好運にめぐまれていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら日本においても、それほど貞淑な妻や善良な姑は、一般に沢山は居ないからである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故ある人々は、ヘルンがもし悪妻をめとり、意地悪の姑等と同居したら、彼の神国日本観は、おそらく顛倒した結果になったろうと言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が蛇を追ったといって叱られ、植木屋が筍を抜いたといって怒られ、はては『おババさま』の姑でさえが、枯れた朝顔をぬいたというので『おババさま好き人です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "西大久保の家に移った時は、ヘルン夫妻と姑の外に、子供が三人。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "餓えて憩っている老翁のために魚鳥の獲ものの剰ったのを持って来て呉れたり、菱の実や、黒慈姑を持って来て呉れたりした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姑にいびられた嫁が後日自分で姑の地位に立った場合には綺麗に昔の行届かなかった自分を忘れてしまうように、自分が審査員になる頃にはたちまち全能の神のような心持になる、ということも全然この世にないとは限らない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから水に漬けてある豆だとか慈姑だとか。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば昔あったような姑と嫁の争いである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姑は「姑」を宣伝し、嫁は「嫁」を宣伝するために、一家に風波が立つ。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「煙のビスケット」が生物のように緩やかに揺曳していると思うと真中の処が慈姑の芽のような形に持上がってやがてきりきりと竜巻のように巻き上がる。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舅小姑の面倒があるでは無し、主人の小幡は正直で物柔かな人物。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらから見ると顔がまだむくんでいる」「でも……」「でもじゃないよ」「お母さん……」「お姑さんには行ってもらうさ」「だから……」「だから切符は出すさ」「はじめからそのつもりで言ってるんですわ」信子は窶れの見える顔を、意味のある表情で微笑ませた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道で、彼はやはり帰りの姑に偶然追いついた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "声をかける前に、少時行一は姑を客観しながら歩いた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お帰り」姑はなにか呆けているような貌だった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの方は……」　まあ帰ってからゆっくりと思って、今日見つけた家の少し混み入った条件を行一が話し躊っていると、姑はおっ被せるように「今日は珍しいものを見ましたよ」　それは街の上で牛が仔を産んだ話だった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、姑がそれを見た頃には、蓆を敷き、その上に仔牛を載せた荷車に、もう親牛はついていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、どいてくれよと言って、前の人をどかせて牛を歩かせたんです――みんな見てました……」　姑の貌は強い感動を抑えていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいじゃ、先へ帰ります」　買物があるという姑を八百屋の店に残して、彼は暗い星の冴えた小路へ急ぎ足で入った。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして科学者として立とうとしている以上、今後は文学などに未練を繋ぐ姑息を自分に許すまいと決心したのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを一時の愛着に牽かされて姑息にして置く法はない。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その野菜というのが蓮根だの、慈姑だの普通煮て食べる種類のものを、ただ皮を剥いただけで、ざくざく輪切りにしたものでありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚当時からのことをいろいろ回想してみると、妻に対しての気のどくな心持ち、しゅうとしゅうとめに対して面目ない心持ち、いちいち自分をくるしめるのである。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそのまえからお遊さんが妹夫婦とあまりいききをしすぎるということが小曾部の方はなんともいうものはござりませなんだが粥川家の方でしゅうとめや親類のあいだにぽつぽつうわさのたねになっておりましてお静さんの気が知れないというようなことを申す者が出てまいりました。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
