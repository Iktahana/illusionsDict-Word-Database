        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "殺気に満ちた静けさが長くつゞいた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらくは水の静けさ！",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "園の静けさは前に変わらぬ。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長なす黒髪を項の中から分けて豊かに垂れ下げ、輪廓の正しい横顔は、無限なるものを想うのみ、邪なる想いなしといい放った皎潔な表情を保ちながら、しら雲の岫を出づる徐なる静けさで横に移って行く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの静けさに少し気持ちがよかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と獣との闘いもやがて終ったらしく、寺町の闇は元の静けさにかえった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲は、なお遠くで、静けさを破って轟いていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子もなく夫にも死に別れたその女にはどことなく諦らめた静けさがあって、そんな関係が生じたあとでも別に前と変わらない冷淡さもしくは親切さで彼を遇していた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きている窓はなく、深夜の静けさは暈となって街燈のぐるりに集まっていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を打ったような静けさがいまこの谿を領していた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その静けさはひょっと夢かと思うような谿の眺めになおさら夢のような感じを与えていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この径を知ってから間もなくの頃、ある期待のために心を緊張させながら、私はこの静けさのなかをことにしばしば歩いた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにざわめいていた人びとが今のこの静けさ――私にはそれが不思議な不思議なことに思えた。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとはまたもとの静けさのなかで音楽が鳴り響いていった。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも都会に住み慣れ、ことに最近は心の休む隙もなかった後で、彼はなおさらこの静けさの中でうやうやしくなった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした心の静けさとかすかな秋の先駆は、彼を部屋の中の書物や妄想にひきとめてはおかなかった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "星は冴えに冴え、風は死し、秋の夜の静けさ、虫は鳴きしきっている。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はいつしか小山を忘れ、読む書にもあまり身が入らず、ただ林の静けさに身をまかしていると、何だか三、四年｜前まで、自分の胸に響いたわが心の調べに再び触れたような心持ちがする。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の半ばに時雨しめやかに降り来たりて間もなく過ぎ去りし後は左右の林の静けさをひとしおに覚え、かれが踏みゆく落ち葉の音のみことごとしく鳴れり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉半ば落ちて大空の透かし見らるる林を秋霧立ちこむる朝｜訪わばいかに心騒がしき人もわれ知らず四辺の静けさに耳そばたつるなるべし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、冬は手入れかたがた閉場しているので、まるで山中の静けさだった。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、青年の艇は大ような微笑そのものの静けさで、ぴたりぴたりついて来て離れない。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは静けさの中に黎明が育まって行く。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに、千日前｜界隈の見晴らしの利く建物の上から、はるか東の方を、北より順に高津の高台、生玉の高台、夕陽丘の高台と見て行けば、何百年の昔からの静けさをしんと底にたたへた鬱蒼たる緑の色が、煙と埃に濁つた大気の中になほ失はれずにそこにあることがうなづかれよう。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙の雲が夜の静けさの中に照らしだされて、笠松のこずえのように、血のように赤くひろがっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の間には更に緊張した深い静けさが流れた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くに電車の音が辷って行くきりで、人通りも何もなく、真夏の日盛りの静けさが耳の底に泌み入るほどシンカンとしていた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真黒く煤けた工場の全体に、地下千｜尺の静けさが感じられる一｜刹那である。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "円山公園を抜けて一休庵へ行く途中、古びた低い門をくぐると左手に高台寺の見える細長いさびた道がいかにも京都らしいしずけさの中に伸びていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョロチョロと、小川の水の流れる音だけが、この深いしずけさの中から聞こえてくる、ただ一つのものでありました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
