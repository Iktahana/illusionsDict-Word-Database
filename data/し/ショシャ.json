[
  {
    "uuid": "9d1ebe0b-032d-52a1-8b49-6fab580cfe52",
    "entry": "書写",
    "reading": {
      "primary": "しょしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
