    "definitions": [
      {
        "index": 1,
        "gloss": "company employee",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると三十格恰の会社員でもしてゐさうな、蝶ネクタイが出て来た。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかしねえ」と、その傍にゐた会社員風の男が睡さうに云つた、「音羽屋のを見てからは見られませんよ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ向うの腰掛には会社員らしい中年の夫婦が十歳くらいの可愛い男の子を連れておおかた団子坂へでも行くのだろう。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平一はこの会社員らしい男を何処かで見たように思ったがつい思い出せない、向うでも時々こちらの顔を見る。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社員は組員へ注意した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "このなつかしさに対しては、去年の夏から互に許し合っている水泳場近くの薄給会社員の息子薫少年との小鳥のような肉体の戯れはおかしくて、想い出すさえ恥じを感ずる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、某私立大学生、某会社員、某教師等々と関係したことを告白せり――。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "會社員の奧さんで肋膜がお惡い上に盲膓炎なんですつて。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになく元｜たＭ会社員の青木さんは、山の手のある靜かな裏通りにある我家の門口をはひると、今まで胸に包んでゐたうれしさを一｜時に吐き出すやうにはしやいだ声で奧さんの名を呼んだ。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで立っていた若い会社員風の二人連れが話しているのを、聞くともなく聞いていると、毎朝同じ時刻に乗る人がみんなそれぞれ乗り込む車の位置に自ずからきまりがあると見えて、同じ顔が同じところにいつでも寄り合うようだと云っていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のポケットには、福隆火柴公司の社員の名刺がはいっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計係の岩井と、社員の小山は「何だい！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "于立嶺は、平生から社員に睨まれていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでも社員のリンチが行われた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の社員が、軍隊を笠に着て、工人を虐待する心理を読むと、その中隊の兵士達は承知しなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は、軸列機を動かす手を休めて、そッと、社員に発見されないように、窓のかげから、小山が、于のもう一方の拇指に針を突き刺すのを見つめていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "製氷公司の社員からビールや、菓子や、お茶を御馳走されて、牛のよだれのような長話をつゞけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社員、おッ母アと、王とあわせない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い、小さい子供の身体、皮と骨だけになって、脚かたかたになっていた……社員、職長笑う。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配人も、職長も、古参の社員も、嫌悪した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社員に、おべっかを使うように、ペコペコ頭を下げた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌てふためいた支配人、社員、中隊長、重藤中尉、特務曹長が、そこら中をかけずりまわった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社員は、朝からそわそわした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "感謝状はまずそのしるしといっていいようなもので、これを国への土産にすると、全国の社員は皆満足に思うです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内を縦断する通路の自分とは反対側の食卓に若い会社員らしいのが三人、注文したうなぎどんぶりのできるのを待つ間の談笑をしている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡の九州日報社という民政系の新聞社にいる頃、社員で酒を飲まないのは私一人であった。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その周囲を重役以下男女社員が犇々と取り囲んで、敵選手の練習を見ている処へ乗り込んだ時には、何かなしに全身を冷汗が流れた。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれらの社員は単に寄書家という格で外様大名のような待遇を受けるのでなくて、その社の仕事の全体に参与しかつ責任を負うものでなくてはならない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸の上で会う松浦は、単にＳ会社の平凡で勤勉な妻子持ちの社員だけである。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私に取ってこういう奇蹟的な存在の人が、世間では私の母の廉い仕立もののお得意さまであって、現在、製菓会社の下級社員で、毎日ビスケットを市中に届けて歩き、月給金○○円の方であるとは、どうにも合点がゆきませんです。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
