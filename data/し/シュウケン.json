    "definitions": [
      {
        "index": 1,
        "gloss": "cocoon crop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あんこくじの　ひなそうに　なった　一休さんは、しゅうけんと　いう　なまえを　もらって、まいあさ　おしょうさまから　おきょうを　ならいましたが、りこうなので　すぐおぼえます。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しゅうけん、おまえ　いってこいよ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅうけん　いってこいよ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一休さんが　あめだらけの　あたまを　かかえると、これを　みた　おしょうさまは、「しゅうけん、なに　しとるのじゃ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しゅうけん、わしが　わるかった。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいや、しゅうけん。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一休さんに、「しゅうけん、おまえの　とんちには　おどろいた。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しゅうけん、今日は　おまえが　るすばんだ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一休さんが　目を　しろくろ　させて　いると、さきに　きた　あにでしが、「しゅうけん、また　いたずらを　したな。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから　はいってきた　おしょうさまは　この　ようすを　みて　くすくす　わらいながら、一休さんの　まえに、かけた　かがみもちを　だして、「しゅうけん、しゅうけん、十五やの　月は　まんまるなのに　これは　どうしたことだ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしょうさんは、この　一休さんの　とんちに　すっかり　かんしんして　しまって、「しゅうけん、でかした　でかした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しゅうけん、うまく　やったな。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははあ、これは　しゅうけんぼうずかい。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うまい、うまい、しゅうけん――ああ、むねが　すーッと　した。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひらいて　みると、「ゆうがた、ごちそう　したいから、しゅうけんさんを　つれて　あそびに　きてください。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしょうさまは、にこにこ　わらいながら、一休さんを　よんで、「しゅうけん、じくさいさんが、こんな　てがみを　よこしたよ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この　はし　わたるな「おやおや、やっぱりだね、しゅうけん。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると　一休さんと　おしょうさまが、へいきな　かおで　はしを　わたって　きたので、「しゅうけんさん、おまえさんは　あの　たてふだが　みえなかったのかね。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、おもわず　ひたいを　たたいて、おしょうさまに、「しゅうけんさんの　とんちには、おとなの　わたしも　とても　かないません。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と　いって、したを　まいてしまいましたが、すぐ　おもいかえして、「でも、しゅうけんさん、こんどは　まけませんよ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅうけんさんとの　とんちきょうそうは　これからですよ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると　じくさいさんは、ゆうゆうと　おちつきはらって、「さて、しゅうけんさん、わたしが　これから　なんもんを　だしますから、りっぱに　こたえてください。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、しゅうけんさんが　わたしの　なんもんに　こたえられなかったら、今日の　ごちそうは　おあずけにします。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに、こんどこそ　しゅうけんさんを　ぎゅう　というめに　あわしますよ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　じくさいさんは、そう　いって　おいて、「しゅうけんさん、したから　うえに　さがるものは　なあに……。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いって、「さあ、しゅうけんさん、ごちそうばかり　ながめて　いないで　はやく　こたえて　ください。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり　わたしは　しゅうけんさんに　かないません。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、一休さんの　とんちは　たちまち　大ひょうばんに　なって、「あんこくじの　しゅうけん　という　小ぼうずは　大へんに　とんちが　すぐれて　いるそうだ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "では　一つ　その　しゅうけんと　いう　小ぞうを　よんで、ごちそう　して　やろうでは　ないか。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
