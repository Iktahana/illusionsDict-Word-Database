    "definitions": [
      {
        "index": 1,
        "gloss": "dance (in kabuki)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）媛神　花の都の花の舞台、咲いて乱れた花の中に、花の白拍子を舞っている……巫女　座頭俳優が所作事で、道成寺とか、……申すのでござります。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした出演者の表現能力のみをもって舞台面を一パイにして行く行き方に、日本では所作事式のものが色々ある。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女どもはそれは何の所作事かと尋ぬると、われは人間のゴリラであると飛んでもない言を吐いたから、下女ども大いに驚き用心して爾来｜碌に近寄らず。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女のことは江戸時代に芝居の所作事などにも出ているし、絵草子にも描かれている。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙ってついてきな」　どんどんはいっていくと、ちょうど幕のあいていたのをさいわい、土間の片すみからその鋭いまなこを送って、おりから水芸所作事に踊り舞っている江戸五郎の両手の先をじっと見調べました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の潔白はそれで証明されるでしょう」　すると後から女大臣アサリ女史が憎々しげな赭ら顔を出して、「博士、それはまことにお気の毒ですがネ、テレビ放送にはお二人の所作事が見えただけで、声の方はラジオが停ったきりで高声器はウンともスンとも鳴りませんでしたよ。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫のだんまり、虫の濡場、虫の荒事、虫の所作事、虫の敵討のおもしろさ。",
              "citation": {
                "source": "草の親しみ",
                "author": "刈草の匂ひ　１",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次は自分の手から全く安次が離れていったのだと思うと、今迄の安次に向っていた自分の態度は、尽く秋三に動かされていた自分の頭の所作事であったと気が附いた。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻くや繃帯白妙の　衣の袖は紅に染み真白に細き手をのべて……　あの調べも、歌詞も実にいい「ほづつの響遠ざかり」の歌をうたいつつ、「日の本の、仁と愛とに富む婦人」の所作事が演じられた時、私は感激に涙ぐむばかりになっていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四世｜彦三郎を贔屓にして、所作事を書いて遣ったと、自分でいっている。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「去夏狂言評好く拙作の所作事勤候處、先づ勤めてのき候故、去顏見せには三座より抱へに參候｜仕合故、まづ役者にはなりすまし申候。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇通で芝居の所作事をしくんだ壽阿彌に斯の如き滑稽のあつたことは怪むことを須ゐない。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかる勘平の道行といつたやうな、芝居の所作事と、それに伴ふ輕く細く美しい音樂とが、頻りに思ひ出されて來た。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "後は賑かに、村の娘や後家の噂さになつて、猥らなテクニツクを用ゐた話が、大切の所作事のやうにはずんだ。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅黄の石持で柿色の袖なしに裁布をはいて、腰に七輪のアミを提げて、それを叩いたり三味線を引いたりして、種々な音色を聞かせたが、これは芝居や所作事にまで取り入れられたほど名高いものである。",
              "citation": {
                "source": "梵雲庵漫録",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十になる彼女は、中幕の所作事「浅妻船」の若い女に扮そうとしているところだった。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば、吉野山の所作事には、静と忠信との道行き――道行きは恋愛の男女のに限られない。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に、能や歌舞妓の所作事などゝも、交渉はないと見てよいと思ふ。",
              "citation": {
                "source": "沖縄舞踊に見る三要素",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代の歌舞妓所作事の獅子舞で、石橋うつしでありながら、扇に牡丹をつけ、赤頭で舞つたものゝ多かつたのは、見当違ひである。",
              "citation": {
                "source": "獅子舞と石橋",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから其から出発しての議論でなくては、と言ふ論法で、歌舞妓所作事を踊りの正道なものとするのなら、話は別である。",
              "citation": {
                "source": "歌舞伎とをどり",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが芝居の方の所作事とか言ふのにも出る相ですが、雌の白蔵司が、実朝の前に坐つて居る様な、不気味な心持ちであつたことは、よく覚えて居ます。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其外に尚、所作事系統の形容芝居や芸事風の物などは早く、歌舞妓の埒外に専門を持たしめてよいではないか。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鯉つかみ」のやうな水芸に近い狂言、「山帰り」のやうな身軽な季節の所作事の一団があるのだから、「四谷怪談」だの「累物語」だの「小幡小平次」「皿屋敷」だの、「笠森おせん」なり、新しい所では「敷島譚」なり「乳房榎」なり「牡丹燈籠」なり、皆身軽で、経費が尠くて、水のふんだんに使はれる場面もあるのだもの。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "所作事は源之助の得意とするところではないので、先代菊五郎が、「茨木」「戻橋」「土蜘蛛」など沢山の所作事をしてゐるのはうつさなかつた。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に、能や、歌舞妓の所作事などゝの交渉も、予断せられてゐるほどにはない、と見てよからう。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、能と所作事・景事との間にある程の違ひはない、と言うてよい。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "所作事は源之助の得意とするところではないので、先代菊五郎が、「茨木」「戻橋」「土蜘蛛」など沢山の所作事をしているのはうつさなかった。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "所作事と云ふのは踊を主としたもので、地狂言と云ふのは台詞と仕草に依つて物語りを運んで行く普通のドラマを云ふのであります。",
              "citation": {
                "source": "日本演劇の特質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
