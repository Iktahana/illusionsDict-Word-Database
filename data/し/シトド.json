    "definitions": [
      {
        "index": 1,
        "gloss": "dripping wet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馬は背、腹の皮を弛めて汗もしとどに流れんばかり、突張った脚もなよなよとして身震をしたが、鼻面を地につけて一掴の白泡を吹出したと思うと前足を折ろうとする。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授は不似合な山高帽子を丁寧に取って、煤けきったような鈍重な眼を強度の近眼鏡の後ろから覗かせながら、含羞むように、「ライプチッヒから本が少しとどきましたから何んなら見にいらっしゃい」　と挨拶して、指の股を思い存分はだけた両手で外套をこすり続けながら忙しそうに行ってしまった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕紙に手をやってみるとはたしてしとどに濡れていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が母らしく立ち上がって無作法を責めながら髪をけずり衣物を整えに二階にやろうとするのを、貴女は椅子から立ち上がりさえして押しとどめた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――（手を挙げて青年の言葉を押しとどめ）理屈でもって実行を妨げないこと。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてもその夜は暑かりしや、夢の恐怖に悶えしや、紅裏の絹の掻巻、鳩尾を辷り退いて、寝衣の衣紋崩れたる、雪の膚に蚊帳の色、残燈の灯に青く染まって、枕に乱れた鬢の毛も、寝汗にしとど濡れたれば、襟白粉も水の薫、身はただ、今しも藻屑の中を浮び出でたかの思がする。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしとどのつまり出刃打ちが殺したになって、予審は終結した。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "極度の緊張に脳貧血を起していったん意識を喪い、再び恢復して来たときの復一の心身は、ただ一｜箇の透明な観照体となって、何も思い出さず、何も考えず、ただ自然の美魅そのままを映像として映しとどめ、恍惚そのものに化していた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はた、あかあかと蒸気鑵音なく叫び、そこここに咲きこぼれたる芹の花、あなや、しとどにおしなべて日ぞ照りそそぐ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗滴るしとどの熱に薄曇り、暈みて歎く吊橋のにほひ目当にたぎち来る小蒸汽船の灰ばめる鈍き唸や、日は光り、煙うづまく。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時ごろ一人はいって来た客が、自分らが起き上がろうとするのを、ビッテビッテと言って押しとどめて腰掛けのすみのほうへ小さくなって腰かけていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが階段の下のところで、先ほど話題にも出たやくざな船乗りに出くわし、押しとどめられて、さらにそこで手伝いをやっているデンマーク人も加わって、ついには表へ追い出されてしまった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご婦人は寝台の上で身体を起こしていたが、手を突き出して相手を押しとどめた。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が深く切り込んでも、こちらが途中で押しとどめる。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　渠は、今更ながら、しとど冷汗になったのを知った。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月待草に朝露しとど湿った、浜の芝原を無邪気な子どもを相手に遊んでおれば、人生のことも思う機会がない。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリイはおしとどめて、「しばししばし、かく口を揃へて問はるる、巨勢君とやらむの迷惑、人々おもはずや。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女打ちまじりたる中に、先の夜「ミネルワ」にて見し人ありしかば、巨勢は往きてものいはむとせしに、少女おしとどめて。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところは寂びたり、人里は遠し、雨の小止をまたんよすがもなければ、しとど降る中をひた走りに走らす。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しからぬ命に代へて目の前の別れをしばしとどめてしがな　と夫人は言う。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "草も木もしとどに濡れてゐる。",
              "citation": {
                "source": "水源を思ふ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはどなたですか」　大きな男はちょっときまりが悪そうに汗でしとどになったまっかな額をなでた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡の手は火鉢にかざしてあったせいか、珍しくほてって臆病らしい油汗が手のひらにしとどににじみ出ていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いきり鋭利なメスで手ぎわよく切り取ってしまったらさぞさっぱりするだろうと思っていた腰部の鈍痛も、急に痛みが止まってしまって、からだ全体がしびれるようにしゃちこばって冷や汗が額にも手にもしとどに流れた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シーツを思いきりつかんでいた手を放して、弱々と額の所をなでると、たびたび看護婦がぬぐってくれたのにも係わらず、ぬるぬるするほど手も額も油汗でしとどになっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私がＭ―老人を呼ぼうというのをも押しとどめて、ただ二人だけでこの飲料をたのしもうとしていたのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがねむる家のそちこち音に澄みてこほろぎの鳴く夜となりにけりこほろぎのしとどに鳴ける真夜中に喰ふ梨の実のつゆは垂りつつ使ひ終へていまたてかけしまな板の雫垂りつつこほろぎの鳴く　こほろぎと同じく、飼つておくわけでもないに部屋のうちに来て鳴く虫に茶たて虫といふがゐる。",
              "citation": {
                "source": "秋草と虫の音",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "青水無月の小林に、漆樹は、さこそ木膚の目より美脂をしとど滴つれ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人はそのいじらしさ、可憐さにしとどほおをぬらしながら、ことばを改めていいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくは滝口」　部屋番号をいおうとすると、浅井が押しとどめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
