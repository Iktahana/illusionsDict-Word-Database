        "examples": {
          "standard": [
            {
              "text": "海外旅行の出発日が近づくにつれて、パッキングをしながら現地の気候や美味しいレストランを調べるのが楽しくて仕方ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出発日の朝になって急に熱が出てしまい、楽しみにしていた家族旅行をキャンセルせざるを得なくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "留学の出発日、友人たちが空港まで見送りに来てくれて、寄せ書きの色紙を手渡された時は涙が止まらなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "出発日までの一週間を、博士は出発の用意に専念した。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度に何週間もちょくちょく留守にして、出発日も行き先も教えないと言わざるを得ません。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
