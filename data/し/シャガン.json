[
  {
    "uuid": "ffbeb4c2-cd30-5aff-9b6b-66ad18c0160a",
    "entry": "赭顔",
    "reading": {
      "primary": "しゃがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ruddy face",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）　と赭顔なのが白い歯を剥き出していうようです。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髯赭顔のデビス長老が、質素な黒のガウンを着て、祭壇に立ったのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め、赭顔・鬚面のその容貌を醜いと感じた俺も、次の瞬間には、彼の内から溢れ出るものに圧倒されて、容貌のことなど、すっかり忘れてしまった。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "赭顔は、でっぷりとした頬を張って、「いやさ、用とはこっちから云う事じゃろうが、うう御老人。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡から行く二人は皆赤い襟章で、一人は赭顔の図抜けて背の高い男、一人は締まつた体で、苦味走つた顔をした男である。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人も客も湯帷子に着更へて、縁側近く据わつて、主人と背の高い赭顔とが棋を打つのを、小男の客が見てゐる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　石を一つ持つて考へ込んでゐた赭顔は奥さんにかう云つた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "赭顔は大きな体をゆつたり構へて、にこにこしてゐる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は小男が赭顔の相手に出て来た。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　赭顔はゆつたり構へて、にこにこして主人の顔を見る。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "赭顔と小男との勝負はなかなか附かない。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は小男が勝つたと見えて、赭顔が笑つて五分苅頭をさすつてゐる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "赭顔は直に自分のを取り上げて、少し口に入れて舌打をした。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くすると、傍で見てゐた赭顔が、忽ち「あはあは」と笑つて、「さうなつては、もう挽回の望もない」と云つた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人のと赭顔の男のと、別々に聞えるやうである。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵来て泊つてゐる赭顔の安中大佐も、小男の宇都宮中佐も、主人の流義が好いと云ふので、内でも人の処に泊つても、服装一切は傍を離さないのである。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、筆を借りてそこの壁に詩を題し、終ると傍にいる二人の小供を抱き締めるようにしてさめざめと泣いていたが、やがて孫恪の方を向いて、「これから永のお別れをします」　と言って、着ていた着物を引裂いて投げ出したのを見ると、赭顔円目の一大老猿であった。",
              "citation": {
                "source": "碧玉の環飾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪にも髭にも白いのがかなり混った割には極めて元気な矮躯赭顔の翁は折柄処用で外出しかけて居たにも係らず、懇ろに我等がために古文書を展き、絵図を示し、流されてこの島に三年の月日を送られた上皇の故跡をいろいろと説明せられた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひどいことをやったもんですね」　もうどこからか聞込んだと見えて、赭顔の人の好さそうな松永博士はそう云って主任へ椅子をすすめた。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十二歳になるというのに、腰一つ曲らず、流石に頭髪だけは霜のように真白になっては居るが、肉付は年増女房を思わせるほど豊満で、いつも赭顔をテラテラさせているという、怖るべき精力老人であった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は白髪赭顔の静かな人物だった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪｜赭顔のワーナー博士は、愛用のパイプから紫煙をゆるやかにくゆらせていた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪｜赭顔の、飛行島建設団長リット少将と、もう一人、涼しそうなヘルメット帽をかぶって白麻の背広のふとった紳士とが、同じように双眼鏡を眼にあててはるか北の方の水平線を眺めている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "象の刺繍、象の置物、色琺瑯製の象の吊垂灯――そして、ちょん髷の人力車夫と、ヘルメット帽の赭顔いぎりす紳士と。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内にレコードを掛けて、柿丘と雪子とが相抱いて踊りはじめると、赭顔の博士は、柿丘夫人呉子さんを援けておこして、鮮かなステップを踏むのだった。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを赭顔にすると、先生そつくりであつたのだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ返辞をしないうちに、例の赭顔の女中が大きい盆に一人前ずつに包んだ餅菓子を山盛にして持って来て銘々に配り始めた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚がそよそよと伸びるのが肉眼でも判るほどだから、と真顔で教えたら、だまってしゃがんで僕の顎を皿のようなおおきい眼でじっと見つめるじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端に乞食が一人しゃがんで頻りに叩頭いていたが誰れも慈善家でないと見えて鐚一文も奉捨にならなかったのは気の毒であった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "端艇へ飛びのってしゃがんで唾をすると波の上で開く。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
