    "definitions": [
      {
        "index": 1,
        "gloss": "consideration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西洋文化の構成契機を商量するときに、この問は否定的の答を期待するよりほかはない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "觀照と實行の問題も商量された。",
              "citation": {
                "source": "硝子窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――然し其の商量は、遂に何の滿足すべき結論をも我等の前に齎さなかつた。",
              "citation": {
                "source": "硝子窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堂々たる男子が、何故生を軽んじる、事情があるなら商量にあずかろうじゃないか」　そこには法海禅師が背に衣鉢を負い手に禅杖を提げて立っていた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし末造はこの席で幻のように浮かんだ幸福の影を、無意識に直覚しつつも、なぜ自分の家庭生活にこう云う味が出ないかと反省したり、こう云う余所行の感情を不断に維持するには、どれだけの要約がいるか、その要約が自分や妻に充たされるものか、充たされないものかと商量したりする程の、緻密な思慮は持っていなかった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堂々たる男子が、何故生を軽んじる、事情があるなら商量にあずかろうじゃないか」　法海禅師が背に衣鉢を負い手に禅杖を提げて立っていた。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は我齡を算へ、我がために作さでかなはぬ事を商量したり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる返事は、斯う云ふ具合に、相手と自分を商量して、臨機に湧いて来るのが本当だと思つてゐた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ可なりの大部分の者は自由なる立場に立つことを建前として、この二つの世界観を対比・比較し、その間の複雑な交互作用に於ける夫々の意義を歴史的に科学的に商量する為に、身を以て、いま世に容れられざる「唯物論の研究」に従っているというのが事実である。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほよそ造語はその既往の歴史を以て人の寛恕を得べき權利なきものなれば、そのこれを造るに當りて鄭重なる商量をなさゞるべからず。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また／＼御商量可被下候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "否るものは英独名を取ること鉱物字彙の如くすべしや否や、此には商量の余地がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は気分だけで京都行に決定したことが後には帰郷と実際的の利害得失を比較商量する様になつた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女問題を論ずる多数の識者が、この男女の性欲の不平等を重要な一つの資料として商量しないのは迂濶の甚しいものである。",
              "citation": {
                "source": "私娼の撲滅について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりもその候補者の政見に思想及び知識の背景があるか、どの点まで世界及び日本の現状に照して実用主義的であるか、その政見は景気の好い一時的の口約束でなくて、あくまでも実行の責任を持った発言であるかを商量することが太切だと思います。",
              "citation": {
                "source": "選挙に対する婦人の希望",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぬるい夢や憧憬や、しちめんどうな瞑想や、小賢しい商量や、虚偽や、馬鹿らしい後悔や追憶を必要とせずに生きて行く。",
              "citation": {
                "source": "南洋館",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳言すれば彼は理論と事実との間に、幾多の商量すべく、打算すべく、加減すべき摩擦あるを知らざりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる返事は、こう云う具合に、相手と自分を商量して、臨機に湧いて来るのが本当だと思っていた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして始から取捨も商量も容れない愚なものゝ一徹一圖を羨んだ。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事を商量するものは一本調子の人を羨ましがる。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が壓制から脱れると云ふ意味は假にも放縱無秩序の生活を送らうとするのでなく、私達の實際生活に必要である限り、聰明な批判商量を經た上で、あらゆる自制律――新道徳、新制度の類――を建設しようとするのです。",
              "citation": {
                "source": "貞操は道徳以上に尊貴である",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそ美の源泉そのものの相異を認識する力無き者の商量であるといわねばならない。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の町会議員は其金質を、一人は其｜重量と直径とを、一人は其見積りの代価を、いづれも心に商量したり感嘆したりして眺めた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "余｜児輩ト商量シマサニ起程ヲ緩クセントス。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はお延に事情を打ち明ける苦痛と、お秀から補助を受ける不愉快とを商量した。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "悩乱のうちにまだ一分の商量を余した利巧な彼女は、夫のかけた鎌を外さずに、すぐ向うへかけ返した。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども雨を凌いでここまで来た彼には、まだ商量の隙間があった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして始から取捨も商量も容れない愚なものの一徹一図を羨んだ。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうりょうという褐色の蜻※あり、群をなして飛べり。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
