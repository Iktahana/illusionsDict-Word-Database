    "entry": "蕭寥",
    "reading": {
      "primary": "しょうりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "desolate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "花曇りの空が、刻一刻に天から、ずり落ちて、今や降ると待たれたる夕暮の欄干に、しとやかに行き、しとやかに帰る振袖の影は、余が座敷から六｜間の中庭を隔てて、重き空気のなかに蕭寥と見えつ、隠れつする。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "室外の天下は蕭寥たる秋である。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうりょうという褐色の蜻※あり、群をなして飛べり。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
