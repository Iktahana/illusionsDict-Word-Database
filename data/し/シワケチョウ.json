        "examples": {
          "standard": [
            {
              "text": "毎日の取引は、仕訳帳に日付順に記録される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経理担当者は、仕訳帳の記入ミスがないか丹念に確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この仕訳帳を見れば、過去の財務状況を把握できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「わたしも一つ馬籠へ手紙を出して、仕訳帳を至急取り寄せなけりゃならない。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、庄屋方から差し出してあった人馬立辻帳、宿勘定仕訳帳等の返却を受けて、そんなことで屋敷から引き取った。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿勘定の仕訳帳は伊之助さんに頼みますよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、伊之助は宿勘定仕訳帳を取り出して、それを半蔵の前にひろげて見せた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
