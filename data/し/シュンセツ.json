    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dredging",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今度出来て来た詩集をみると「浚渫船」とある。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運河には浚渫船が腰を据えていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "浚渫船のデッキには、石油缶の七輪から石炭の煙が、いきなり風に吹き飛ばされて、下の方の穴からペロペロ、赤い焔が舌なめずりをして、飯の炊かれるのを待っていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "団扇のような胴船が、浚渫船の横っ腹へ、眠りこけていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "浚渫船の胴っ腹にくっついていた胴船の、船頭夫婦が、デッキの上で、朝飯を食っているのが見えた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして橋の手すりに肘をついて浚渫船をボンヤリ眺めた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には、浚渫船で蒸汽を上げるのに、ウント放り込んだ石炭が、そのまま熔けたような濃い烟になって、私の鼻っ面を掠めた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペイドオフ（馘首）の食いたてなんだ」　浚渫船のデッキから、八つの目が私に向いた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "浚渫船は蒸汽を上げた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角この浚渫機械の小屋と土手は恐らくこの美しい上高地の絵の上にとまつた蠅か蜘蛛のやうな気のするものである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこの浚渫機械の小屋と土手はおそらくこの美しい上高地の絵の上にとまった蠅か蜘蛛のような気のするものである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざと毛色の変わったところを調べていくと、東亜港湾工業という浚渫と埋め立ての会社に目が止まりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョセフ・スタンバーグが自主制作で撮り、チャップリンに高く評価されて公開の運びとなった『救ひを求むる人々』は、浚渫船を舞台とした映画です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "浚渫船のクレインの響きが港一杯に鳴り渡り、目醒ましい水煙をあげてゐた。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関士君の心の中の浚渫船、古い泥の掻ひ出しの仕事を停めた、瞬間、君には寂寥がきた、時代は青年のものだ――とレーニンは言つた。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりしているときには、それを東京時代に経験した自動車の警笛のように聞いたり、或いは又、お濠の外に重いチェーンを降ろす浚渫船の響きのようにも聞いた。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒水浸入に因れる共有井水浚渫費の増加。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、私は慰められてゐた……　このとき、私は、下の方に、浚渫船の機関の騒音のやうな、また、幾分、夏の午後の遠雷に以た響を聞いた――私のために涙を流した女らの追憶が、私の魂の最低音部を乱打した。",
              "citation": {
                "source": "鳥獣剥製所",
                "author": "一報告書",
                "note": "青空文庫"
              }
            },
            {
              "text": "下水の口で休息してゐる浚渫船。",
              "citation": {
                "source": "七階の運動",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱い煙突を持つた浚渫船が起重機から泥を吐きながら、まるで大雨のやうな音をたてゝ動いてゐた。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "古我判事は中一日を置いて四月二日には疾風迅雷的に古井戸を浚渫した人夫、請負った親方、検視をした医師、静子の母親の四人を喚問して調べ、同日被告支倉の第二回訊問を行っている。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリンスの方は一向存じませんです」　井戸浚渫を請負った山谷某は古我判事に次のように答えた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河口を切り開き河底を浚渫するのは治水の要諦で、格別不思議とするに足らぬが、但その論據を、二千年以前の事實を記した經書に求めた點が、支那人的で面白いでないか。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、鉱業人は、上野国待矢場両堰水利土切会と契約し、自費を以て両堰水門内に沈澱場を設け、時々之を浚渫すべき準備中なり。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大きい浚渫船が一艘｜起重機を擡げた向う河岸も勿論「首尾の松」や土蔵の多い昔の「一番堀」や「二番堀」ではない。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年七月にはその第一期工事が完成され、築堤、浚渫、貯水池、水門など、各種の難工事が克服され、このために移動された土壌の量は、高さ一メートル幅一メートルの土堤に直してみると、長さ二十万キロ、地球赤道を五周するほどだという。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大阪港の築港工事に使うしゅんせつ船「大浚丸」一号から十三号までの十三隻に使う石炭二千五百万斤の大入札のときである。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
