[
  {
    "uuid": "9684892f-7516-52c1-8bbe-c525a0788917",
    "entry": "浚渫",
    "reading": {
      "primary": "しゅんせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
