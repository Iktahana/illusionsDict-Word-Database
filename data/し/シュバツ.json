    "definitions": [
      {
        "index": 1,
        "gloss": "purification rite (esp. one held prior to a Shinto event)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "地鎮祭の冒頭で、神職による修祓が行われ、参列者がお祓いを受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "修祓の儀式を経て、身も心も清められた状態で神前に進む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祭典の準備が整い、厳かな雰囲気の中で修祓が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大分おくれて修祓式を済ませ、先づ文芸部の芝居「かなりや軒」川島の女形、上山の老け等傑作あり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
