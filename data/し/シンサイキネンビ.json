        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陰暦七月十五日、そして二百十日、そして関東震災記念日で酒なしデー。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百十日、関東大震災記念日。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "興亜奉公日、関東震災記念日、二百十日、――等には極めて意義ふかい日であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百十日、興亜奉公日一周年記念日、関東震災記念日。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百十日、大震災記念日、昨日の今日だ、つゝましく生活しよう。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は敵機の空襲に備へて、震災記念日を忘れたれど、大地は忘れずして我等を驚かしつるならん。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に考へますと同日は彼の關東大震災記念日でもあり國民一般が嚴肅な氣分に浸る日でもあるのでこの機に於て我國最初の經濟大衆車を大市場に送る事も何等かの意味ある事と思つてゐます。",
              "citation": {
                "source": "乘用車發表に際して",
                "author": "――豐田常務のメツセージ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月一日（金）　震災記念日、鶴見に詣でる。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
