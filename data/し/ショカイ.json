[
  {
    "uuid": "dcd3ec08-39b5-5ba4-a4b7-ab2bb908c7e5",
    "entry": "初回",
    "reading": {
      "primary": "しょかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "first time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「初回はそうです。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "初回の印刷分は、平均して五千部程度。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初回に作っておいた印刷用のフィルムを使い回せるため、再版では一冊あたりの製造コストを抑えられます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間はありませんが、是非初回に間に合わせたいと思いました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那や後インドで※蛇肉を賞翫し、その胆を薬用する事は本篇の初回に述べた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "初回は冬のことだつたから、季節にはあまり注意も払はなかつたやうだつた。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "停船中禁足を命ぜられしは、この地を初回とす。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "この講座の初回に挙げた例のように、詩とは叫びであるとか、詩とは怒りであるとか等々の答えにしても、結局は教えられたり押しつけられたりしてそのようにおもったのではなくて、詩人自身が探り当てたり発見した結果に違いないのである。",
              "citation": {
                "source": "詩とはなにか",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間の名高い一人の批評家が、ある通俗劇場の初回興行ごとにその提灯持ちをして、幾何の金をもらってるかを――（もちろんまったくの中傷ではあろうが）――話し合った。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその大なる手腕は――（彼らの言うところによれば）――幾度も初回興行があるように、上演作をできるだけ早くやめさせるような讃め方をすることであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "初回のときは、別になんとも思わんじゃったけんど、あんまり、毎回じゃけ、鈍なわたしも、変に思うて見るようになりました。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "初回訪問でこんな残念なことになって。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば、小学校の時から、どうも、おかしいな、と思うことがありましたよ」「小学校が一しょかい」「ええ、そうですとも。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ湯に這入っています」「直といっしょかい。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "追分節の歌の文句の一つにも、送りましょかい送られましょかせめて桝形の茶屋までもとあるのがそれです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
