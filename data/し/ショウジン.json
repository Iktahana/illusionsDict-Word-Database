  {
    "uuid": "c749d9bc-d1af-5923-a143-d89b3887eb86",
    "entry": "匠人",
    "reading": {
      "primary": "しょうじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "craftsman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その拡がり方といい勾配の曲線の具合といい、並々の匠人の手で鋳られたものでないことをその鐘は語っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（余童子のとき匠人金次といふもの長府侯江戸の邸第補修のとき長府二の宮舞台のはふのごとくなれと好のよし語れり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に金を取る匠人でなくても匠気というものが生じるのです。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが乾山の値打ちのあるところで、洗練された光琳に見ることの出来ない持ち味を見せるのも、実はこの匠人気質に堕さなかった個性にある。",
              "citation": {
                "source": "乾山の陶器",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな塊を、かくまで薄く、かくまで規則正しく、刳りぬいた匠人の手際は驚ろくべきものと思う。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの硯について人の眼を峙つべき特異の点があるとすれば、その表面にあらわれたる匠人の刻である。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋲の輪の内側は四寸ばかりの円を画して匠人の巧を尽したる唐草が彫り付けてある。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "指物師が百円に負けて置くから買わないかといった立派な紫檀の書棚をじろじろ見ながら、彼はその二十分の一にも足らない代価を大事そうに懐中から出して匠人の手に渡した。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑なな匠人気質の一徹によって、その生活を釣り換えにして得たところの抒情であった。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "精進日覚、×日　　朝×日　　昼まで×日　　終日しょうじん　そんなふうに書いて張ってあるが、三十日間に、幾日もあきのない家もあった。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
