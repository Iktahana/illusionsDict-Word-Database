[
  {
    "uuid": "c9fa8fd9-cc19-5ff6-adf6-fa8d3bd12966",
    "entry": "精進",
    "reading": {
      "primary": "しょうじん",
      "alternatives": [
        "そうじん",
        "しょうじ",
        "そうじ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "concentration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鏤心の秋、琴も文も同じ事なり、まづしい精進をつづけて行かうと思ひます。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく富士山麓の宿屋としては、北の精進ホテル以外において、もっとも景勝の地を占めたものであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまた驚くべく長大なる、最新の熔岩流をひろげて、下吉田の町まで肉薄する剣丸尾、青木ヶ原の樹海から精進村まで、末広がりに扉開きになる青木ヶ原丸尾を、眼下に展開する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから精進口の登山新道、三合目へ下りることが出来て、途中に中庭、奥庭などを通過するそうだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ分相応にその道に精進すべきは人間の職分として当然のことであるとだけは言った。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして常に青年らしい野心を深く包んで黙々として芸道に精進している。",
              "citation": {
                "source": "雑録",
                "author": "――前進座に就いて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "食楽は、精進料理がお好き。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず録糸にてつくる魚翅、湯葉でつくれる火腿、たまに彼女はかつて母とともに杭州の西湖にある功徳林｜蔬食処へ精進料理を味わいに行った。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、私はその動揺の内にも窺はれる氏の人としての壮心と、芸術に対する精進的態度に敬意を払つてゐる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、現在までの処では私も可成りな不満を氏の芸術に抱いてゐるものであるが、恐らく氏はその壮心と精進的態度の下に自己を鞭打ちながら、やがては私の所期する処に自己の芸術を展開させて行くに違ひないと信じてゐる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、それが好い意味に氏を支配する時、芸術に対するあの厳正な精進的態度となつて現れる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、ともあれ現在の芥川氏は自ら鞭打ちながら、精進しながら、内に苦しみを抱きながら、その芸術的展開の一つの道程にある。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて時分｜時だといふので、念の入つた精進料理が出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて時分時だといふので、念の入つた精進料理が出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「精進のホツキ貝ですよ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして婆に言いつけて、私の連れの職工とその相手のおいらんをも私たちの部屋へ呼んで来させ、落ちついてお茶をいれ、また部屋の隅の茶箪笥から、お皿に一ぱい盛った精進揚げを取り出し私たちにすすめました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎょっとして、あわてて精進揚げを呑みくだし、うむ、と首肯くと、その女は、連れの職工のおいらんのほうを向いて小声で、育ちの悪い男は、ものを食べさせてみるとよくわかるんだよ、ちょっちょっと舌打ちをしながら食べるんだよ、と全くなんの表情も無く、お天気の事でも言っているみたいに澄まして言うのでございます。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手管というのは、たとえばこんな工合いの術のことであって、ひとりの作家の真摯な精進の対象である。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足りないながらせめては家に居て、仏壇の掃除なり、精進物の煮付けなりして、母を手伝つたら、母も喜んだらうに、不人情にも程がある。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴吉はすぐ又喧嘩があつたのだなと思つて、あたりさはりのない世間話に口を切つて見たが、母は碌々返事もしないで布巾をかけた精進の膳を出してすゝめた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ふと又真面目になつて、「よんべ、お末は精進も食はず哲を抱いて泣いたゞが……はゝゝ、何そんな事あるもんで、はゝゝゝ」　と云ひながら又不自然に笑つた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕二度の精進の食事と昼にはパンと牛乳とで働きました。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度に大小の災害はあって、ひどいのは須走口一合目に在る小富士を噴出させたり、精進湖と西湖は、もと一つの湖であったのを山から溶岩を流して今のように二つの湖に中断したり、富士にも富士山麓の形態にさえ多少の影響を及ぼしている。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いずれ精進には縁があります。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻苦勉励、学問をも仕り、新しき神道を相学び、精進潔斎、朝夕の供物に、魂の切火打って、御前にかしずき奉る……媛神　私は些とも頼みはしません。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦は出離の道を求めんが為に檀特山と名くる林中に於て六年｜精進苦行した。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私で精進しますから。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はお精進の女で、殺生には向かないんですって。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "精進日覚、×日　　朝×日　　昼まで×日　　終日しょうじん　そんなふうに書いて張ってあるが、三十日間に、幾日もあきのない家もあった。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
