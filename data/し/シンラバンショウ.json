[
  {
    "uuid": "88df2328-b04e-5d86-ba5d-3d62abb4a1e0",
    "entry": "森羅万象",
    "reading": {
      "primary": "しんらばんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
