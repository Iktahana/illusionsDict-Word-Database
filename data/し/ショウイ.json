  {
    "uuid": "0c1c1f59-11c5-571b-9d34-f7d2c1a57faa",
    "entry": "焼夷",
    "reading": {
      "primary": "しょうい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
