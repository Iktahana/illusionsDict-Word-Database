[
  {
    "uuid": "18e35665-3013-56bf-a802-55b2d5b54eb3",
    "entry": "尻餅",
    "reading": {
      "primary": "しりもち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
