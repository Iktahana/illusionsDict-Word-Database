[
  {
    "uuid": "49e291b6-9b31-5346-b5a7-8d63ad758f2b",
    "entry": "塩気",
    "reading": {
      "primary": "しおけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
