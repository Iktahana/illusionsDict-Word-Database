[
  {
    "uuid": "98d107d7-9927-5ec3-8171-5a36f51d4675",
    "entry": "掌中",
    "reading": {
      "primary": "しょうちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
