          "standard": [
            {
              "text": "昔は近所に必ず新聞販売店があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は新聞販売店で、休刊日以外の全ての新聞を購読している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新聞販売店は、地域の情報拠点としての役割も果たしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "新聞販売店のオヤジは自分が日に十五時間働くと云っても雇ってくれない。",
              "citation": {
                "source": "人生案内",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はともにある新聞販売店に勤めていて、そこの主任が出征し、その家族が疎開したあとの留守宅を守っていたのである。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
