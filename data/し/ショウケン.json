    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commercial supremacy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はサイゴンとプノンペンを往来する商権の保持と、為替ブローカーをやり、かたわらカンボジヤとシャムの国境に巨大なゴム園を経営していた。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "商権は、ノラの父は華僑のもつ把握しがたい観念をもっていた。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは汗の民衆が商権の支配者になった生活のうえの産物であったかもしれなかった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はベグノニアの花園を踏んで商業的騒音に生きる、商権の雑音を愛した。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき彼女の父は為替相場の変動のために、彼の商権に致命傷をうけた。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は商権殆ど唐津に移れるより、昔時の繁盛を見るなしといふ。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "奪われた商権　何故に富を奪われたかと申しますと、一面において印度が政治上、英国の支配を受けなければならない様になったがためでありますが、私の見る所では、経済上英国人に負けたことが重大なる原因になって居ると思います。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その相場が不当であっても、商権を持っていない印度人は如何ともする事が出来ず、仕方なく売ってしまう。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう事情を見ても商権を奪われるということくらい、浅ましい無惨なことはないと感じました。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがもし日本の手に商権があって、外国からぜひ日本に「生糸を売ってくれ」と云って来れば、日本では「桑の原価が二円かかっているから、少しは利益を見て二円五十銭くらいで売ろう」というようになる。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も旅行より帰ったら自らも奮発し、また他の方々にもおすすめして、今までに奪われて居る商権は取り止めて、印度の轍を踏まないように心掛けねばならないと考え、今度の旅行にその方面の研究も加える事にして、幾分気を付けてまいったのであります。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国は商をもって立つ国で、その大海軍も商権保護のために造られ、またかの世界大戦も商権をおびやかさんとする独逸を圧するがためでありました。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ統制経済と自由経済との撞着は増々著しくなって行くので、小商人層の商権擁護や反組運動やデパート襲撃、等々というような運動となって現われている（世間では又統制経済に対する自由経済反対を、敢えてファシズム反対という処にまで結びつける。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那に商権を拡張せんとする欧米諸強は、日本の勢力の支那の市場に伸ぶる事を甚だ喜ばない。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "京商人の油屋小金は、まさか兵家常習の策略とは思わず、もしこれが成功すれば、北陸の商権は、両家の縁によって、自分の一手に占められる――と、かれはかれの野心のもとに、両家のあいだを、奔走した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹は口から泡をふいていっしょうけんめいはさみをつかいました。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかり合っては大へんだから、どいつもみな、いっしょうけんめい、じぶんの稲を扱いていた。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日からは何を食べて、どこに寝るのだろうと思いながら、早くみんなの顔が見たさにいっしょうけんめいに走った。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブドリはいっしょうけんめい、その本のまねをして字を書いたり、図をうつしたりしてその冬を暮らしました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、さぎ師はいっしょうけんめい布を織っていました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人のさぎ師はからのはた織り機でいっしょうけんめい働くふりをしています。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぎ師の仕事場につくと、二人はいっしょうけんめいに働いているふりをしていました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、さあ、これからは、いっしょうけんめいに、卵を生むとか、のどをゴロゴロ鳴らして、火花でも散らすようにするといいわ！",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここには、バラの花がないわ」　こう言うと、花園の中へとびだしていって、いっしょうけんめい、バラの花をさがしました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、いっしょうけんめい走って、この女の子を雪の女王のお城へ連れていくんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲルダは、前へ前へと、いっしょうけんめい、かけていきました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、コウノトリの子供たちは言って、それからは、ほんとうにいっしょうけんめい、おけいこをしました。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子は、一日じゅう、そこにすわって、いっしょうけんめい、なにかを作っていました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろぼくは、よく考え、よく仕事をする審判官として、賞をもらうもののために、いっしょうけんめい考えたんだからね。",
              "citation": {
                "source": "かけっこ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかでも、お人形のベッドに寝ていたお花たちが、いっしょうけんめいたのんでやったのです。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
