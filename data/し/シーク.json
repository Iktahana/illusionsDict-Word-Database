    "definitions": [
      {
        "index": 1,
        "gloss": "seek",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シークな部屋であった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人の頭の中のものをスーッと泄って行く……不思議な……なつかしい青年……近頃流行のシークとかスマートとかいう言葉は、こんな青年を形容する言葉ではあるまいか」　そう思いながら私は提灯の火を吹き消した。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲の容器が柄の付いた縦に細長いシークなコップで、それに吸管をつけて来ます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Down with the British Empire（大英国を倒せ）とシークな事よ。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても生き生きしてシークよ。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はブーテーに籠城、こちらは我ら連隊と砲兵半個中隊、シーク教徒の歩兵中隊に多数の文民やご婦人方で、そして周囲には一万人からの逆徒がいて、しかもねずみ取りを囲んだテリアの一団ほどに凶暴だった。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、此頃洋酒は苦手で具合が悪いのだが――其処は、シーク・ドランカーの井伏鱒二君や中村正常君達に依つて知らされたところなので、彼等がゐれば好いが――と念じながら走つた。",
              "citation": {
                "source": "川蒸気は昔のまゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィルムなら「中抜き」で撮れるのに、このようにシークェンスどおりに撮影しているのは、編集ができないためだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "部室から聴こえてくる、〈シークレット・エイジェント・マン〉のイントロのリフに、その声はかき消されそうになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜のお化粧とか朝のお化粧とかそう云う化粧読本の箇条としての一般論みたいなものは行き渡っているようだけれども、もっと自分に即して、自分の気持をとらえているという風のおしゃれは、まれに思えます、それは一応通ななり、凝ったなり、或はシークななりというのとは自ら違ってね。",
              "citation": {
                "source": "女性の生活態度",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖いぷかぷかな場席へ、所謂シークなパリの中流男女、金をつかいに来たアメリカ女が並んで、ソヴェトから買って来て骨をぬいた「アジアの嵐」を観ている。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "府中のコンピュータ技術本部の一角にはシークレットルームと名付けられた一室が設けられ、すべての作業は部外者の立ち入りを厳しく排除したこの部屋で進められた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこのシークボーイ……アンポンタン・ポカン君は、その遺伝発作を起して人事不省に陥ったあとで、ヤット正気を取返すと間もなく、自分の生れ故郷や、両親の名前は勿論のこと、自分自身の名前までもキレイに忘れてしまっている事を、自分自身に気が付いた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭脳明晰……シーク……ホガラカという事になって行くのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼がハイド氏なら、己はシーク氏になってやろう＊」と彼は考えていた。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "二一頁　彼がハイド氏なら……　ハイドという名は「｜隠れる」という語と発音が同じであり、シークは「探す」という意味である。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイド・アンド・シーク」は隠れんぼを意味するので、その洒落である。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすべての印度教徒、囘教徒、シーク教徒、※教徒、基督教徒、及び猶太人にして、印度國民たる信念をもつ人々が、スワデシの誓ひをなし、又他人にも同じ誓ひを立てるよう勸説せんことを懇願するものである。",
              "citation": {
                "source": "スワデシの誓",
                "author": "エム・ケー・ガンヂー",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、昔の岡場所のような隣との間の境界が決してお寒いものでなく、薄桃色の照明、黒白の壁、その壁へシークに貼られた洋画女優のブロマイド、同じく壁にかけられている目の醒めるような派手なドレス――朱塗りの鳥籠に青い鸚鵡が一羽いても、決して不調和ではない、幻想的なルームである。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "シークな彼が、この時位物哀れに見えたことはなかった。",
              "citation": {
                "source": "黒猫十三",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの所謂「アンシークロペディー」と并んで、之を改版した模造百科辞典が少なからず造られた時代であったのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがアカデミシャニズムとジャーナリズムと更に又ディレッタンティズムとの云いたい処をよせ集めると、丁度アンシークロペディストという概念になると思うが、寧ろこの方が適当ではないかと思う。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼はアンシークロペディストとしての享受家だ。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い享受家としてのアンシークロペディストである彼から結果する事は、判断の公平という外見上の特色である。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この魔術あるが故に、一切のテーゼに対しては、いつでもアンティ・テーゼを対抗させることが出来るのだし、常にアラ・モードでモダーン乃至シークな学術を紡ぎ出すことも出来るのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのシークエンスで彼が着ていたシャツが、現物のなかではもっとも高値なのですって」「素晴らしいアロハ・シャツでしたね」「ニューヨークにあった、シスコという名の会社が作ったの。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず実際のシークエンスどおりにつなぎ、さらに、おなじフィルムをいろんな順番でつないだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "波乗りのシーンに合成技術やトリックを使わせないよう気を配るばかりではなく、主演の男たちを短期間で立派なサーファーに仕立てあげ、波乗りのシークエンスを完璧なものにすると同時に、画面の細かなところまで出来るだけ「本物」が映るよう、注意しなくてはいけない。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＶ局のヴィデオ班ですら、すさまじいシークエンスをものにしている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "素晴らしいシークエンスが、ワン・ショットで撮れた」　僕はファインダーをのぞいていただけだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
