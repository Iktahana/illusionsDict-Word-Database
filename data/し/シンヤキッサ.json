        "examples": {
          "standard": [
            {
              "text": "友人との深い話は、いつも深夜喫茶で交わされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はアイデアを練るために、深夜喫茶で過ごすことが多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねえ、今から深夜喫茶行かない？話したいことあるんだけど。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いまの洞窟喫茶、深夜喫茶もまたドイツ系である。",
              "citation": {
                "source": "カフェー",
                "author": "勝本清一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三曲ほど聞いてから、深夜喫茶へと脚を向けた。",
              "citation": {
                "source": "赤い手帖",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、深夜喫茶ではじめて見たときのあの二人づれと同じように、それは、なんの変哲もない他人たちの一人一人にすぎない。",
              "citation": {
                "source": "赤い手帖",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
