        "examples": {
          "standard": [
            {
              "text": "戦後の経済復興期には、各国で新資本主義的な政策が導入された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一部の経済学者は、現代社会の課題を解決するためには新資本主義の考え方が必要だと主張する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境問題への取り組みを重視する新資本主義の動きが世界的に広がりつつある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
