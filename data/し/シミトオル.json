    "definitions": [
      {
        "index": 1,
        "gloss": "to soak through",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは寒々とさせ、鼻には湿っぽく、服の中にまで染みとおる。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、人の心の奥底まで、しみとおるほどでした。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歌が、心の中までしみとおるようにひびきましたので、ヨハンネスの目には、涙がうかんできました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "風は氷のようにつめたくて、まるで、骨のずいまでしみとおるようでした。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は外套の上にまた大外套を重ね着していながら、風に向いた皮膚にしみとおる風の寒さを感じました。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つを取り上げてみると、この菌特有の高い香気がひえびえと手のひらにしみとおるようだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月四日の新聞は世界の人の目に何ともいえない皮肉さで腹の底までしみとおるような写真をのせた。",
              "citation": {
                "source": "動物愛護デー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫛田さんの母としての心、娘さんの心もち、どちらも、その期待、その不安によってわたしの実感にしみとおるものだった。",
              "citation": {
                "source": "その人の四年間",
                "author": "――婦人民主クラブの生い立ちと櫛田ふきさん――",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々ゴーリキイが大人の醜い争いに義憤を感じて、例えばよその上さんが穴蔵へ下りたところを上から揚げぶたを卸して封じこめたりすると、祖母はゴーリキイの肚にしみとおるような言葉を優しく云った。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯にしみとおるように冷いうで玉子を、池を向いて食べる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に寝間着一枚の肩にしみとおる寒気に心づくと一緒に、サヨには、自分のところをのぞいてあらゆる附近の屋根屋根の下で、この瞬間夫婦がぱっと床の上におきかえっていて、灯をつけていて、何なんでしょう！",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日ばかりは鳴かなかったが、そのうちまたしみとおるような、細い、高い、ヒュウ、ヒュウという口笛を吹きはじめた。",
              "citation": {
                "source": "木彫ウソを作った時",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎さんも千代子さんも、あつい毛の襟巻きをまき、足には足袋を二つ重ねてその上に毛布と外套をかけて、お父さんお母さんの背なかにしっかり負われているのですが、それほどにしても、山の寒さは身にしみとおるほどきついのであります。",
              "citation": {
                "source": "峠",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく万ずの物がしみとおるような力で彼の内部までもはいって来るのに、彼は五十余年の生涯をかけても、何一つ本当につかむこともできないそのおのれの愚かさ拙なさを思って、明るい月の前にしばらくしょんぼりと立ち尽くした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢の中にはまた、七寸丸太の長さ三十尺近くもある奴が総立ちで一個連隊ほども旗鼓堂々と材木置場へ押し寄せてくる光景、丸太や桁材や背板が互いにぶつかり合って、腹の底までしみとおるような乾いた木の音を鳴り響かせながら、どっと倒れては起き起きては倒れ、互いに相手を足場に踏まえて積み重なってゆく有様も出てきた。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、伸子はその薬屋のほこりっぽい店つきとともにフランスの庶民生活にある伝統の古さを、身にしみとおるばかり感じた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は魂にしみとおるような痛さで、自分が初めて受けた祝詞ともいうべき、これらの言葉の性質を感じた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜に向いた薄い膝や、細そりした鼻つきを一目見ると、とっさにおくめは、しみとおるような淋しさを感じた。",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　次郎は、しみじみとした父の愛情が全身にしみとおるのを感じた。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼうっとあのときの人びとの顔までも見えるようで――何と申しますか、わたくしも四年前に家内に先立たれ、こういうさびしいひとりぐらしをしておりますと雨のしみとおる壁までもすぎ去った日のかげのように、もうしっかり自分と結びついてしまうものでございます。",
              "citation": {
                "source": "蜜柑の皮",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か明るいかんじが胸の底までしみとおるようで急にあのひとと自分とが位置をとりちがえたような気がいたしたのでございます。",
              "citation": {
                "source": "蜜柑の皮",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしみとおるような喜びとともに、年上の男は、関心と注意がまるでむくいられぬままではないのを、たしかに認めることができた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく準備して冷えないよう理想的にいたしましたが、しんしんとした土のしめりと靴底の紙まがいのゴムからしみとおる冷えで、変になって、中途ですっかり着物を直して盲腸のときの腹帯をしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分で玄関へ出る扉をあけると、一足さがってうやうやしく腰をかがめて、相手の胸にしみとおるような会釈をしたものだ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、八｜畳を二つぶっとおした部屋に、さわやかな風はみちわたり、肌にこころよくしみとおるようだった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しみとおるように、すがすがしい山の空気と、高い流れの音を聞きながら、川にまだそんなに魚のいる、という感動にひたっていた。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇った午後で、四時まえだというのにあたりは暗く、弱い北風が肌へしみとおるほど寒かった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "おくめ殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああもう、と叫ぶように云った声には彼の胸にしみとおるような響きがあった。",
              "citation": {
                "source": "扇野",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは川の上の繋ぎ船で焚く火明りの、ちらちらと頼り無げな焔の色と共に、初冬の宵のしみとおるような寒さを際だたせるものだったが、そのときの又三郎にはなにやら懐かしく、できたらその仲間へはいってゆきたいような、誘惑をさえ感じた。",
              "citation": {
                "source": "野分",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっ母さんは騙した」おしのは歯と歯のあいだで呟いた、「おっ母さんはあたしを騙したのよ、あのときもう江ノ島へゆくことはきまっていたんだわ」　二十七日の夜から、火のけを入れなかったその部屋は、壁までしみとおるほど冷えていた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
