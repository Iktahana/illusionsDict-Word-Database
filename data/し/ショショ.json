    },
    "definitions": [
      {
        "index": 1,
        "gloss": "here and there",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このような類似な詩形が諸所にあるのは偶然の一致かも知れない。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼前に銀座まで出掛けたら諸所の店前の立看板などが吹き飛ばされ、傘を折られて困っている人も少なくなかった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは諸所の同じ名を負へるところの地形を考へて悟るべく、なほまた明かに曲り金と称ふる地名の川沿の地に多く存するをも併せ考ふべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲飛は所謂る掌中の珠を奪はれ殆ど死なうとまでした、諸所に人を出して搜さしたが踪跡が全で知ない、其中二三年｜經ち或日｜途中でふと盆石を賣て居る者に出遇た。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近医学の進歩につれて、この性欲なるものは、人体内の諸所より血液中へ分泌される内分泌物、すなわちホルモンの司る作用であって、そのホルモンが血液に混じて体内をめぐり、一方性欲を惹起させ、他方また精神、肉体を強靱ならしめていることが実証されて来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どこと申して行く処に当は無いので、法衣を着て草鞋を穿くと、直ぐに両国から江戸を離れて、安房上総を諸所｜経歴りました。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は少しも険阻ではないが、ただ連日の大雨のため諸所山崩れがあって、時々頭上の断崖からは、土石がバラバラと一行の前後に落ちてくるには閉口閉口。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一〇）登山競争　町付村から、山道は漸く深くなり、初めは諸所に風流な水車小屋なども見えたが、八溝川の草茂き岸に沿うて遡り、急流に懸けたる独木橋を渡ること五、六回、だんだん山深く入込めば、最早どこにも人家は見えず、午後四時頃、常州第一の高山八溝山の登り口に達した。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年、私は家を追われ、一夜のうちに窮迫し、巷をさまよい、諸所に泣きつき、その日その日のいのち繋ぎ、やや文筆でもって、自活できるあてがつきはじめたと思ったとたん、病を得た。",
              "citation": {
                "source": "黄金風景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は有力の佛者が諸所の山々を開いた時代で、小角が芳野を開き、泰澄が白山を開いたのなどは先蹤をなしてゐる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時から、諸所を漂泊った果に、その頃、やっと落着いて、川の裏小路に二階｜借した小僧の叔母にあたる年寄がある。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天王山は諸所方々に移転した。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隨つて鹿島踊、鹿島の事つげ、船唄の類もまだ全國の諸所に殘つて居るかも知れないが、然し盆踊はつい近頃まではあんなに盛であつたのが、今は殆ど全廢してしまつた。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島民は新王に不服だったが、諸所の暴動も独逸軍艦の砲火の前に沈黙しなければならなかった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一益は長島に在って予め兵を諸所に分ち、塁を堅くして守って居た。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その深い木立の下草に諸所｜木苺の實がまつ黄に熟れてゐた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし水戸義公は日本諸寺社の古文書を写させ、水災を虞れて一所に置かず、諸所に分かち置かれしという。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルコポロ紀行に元｜世祖将官に位勲の牌を賜い佩用せしむるに、金また銀を鍍した牌に獅の頭を鐫り付けたとあるが、ユールの註に拠るとマルコの書諸所に虎を獅と訛称しあるそうだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "少時足藝師の子分と成り、外遊中病で置去られ、阿弗利加沿岸の地諸所多く流寓、十七年の間、或は金剛石坑に働き、又ペンキ塗などを業とせし由、ズールーの戰爭に英軍に從ひ出で、賞牌三つ計り受用す。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの「死体盗人」というものがおびただしくできて、諸所の墓をあばいて死体を盗み、それを解剖者に売ることを業としたのである。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルマニヤの俗伝にいわく昔犬頭痛甚だしくほとんど狂せんとし、諸所駈け廻るうち蛇に邂逅せ療法を尋ねた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "本邦諸所にドーレの木といふ物あり、妙な木ゆゑ、名をとふとドーレ（何れ）の木と問返したのを、その木の名としてしまつたといふ類だ。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛鳥山、向島、その他、諸所の櫻、多くはこれ也。",
              "citation": {
                "source": "東京の近郊",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處をどう掻き破つて出たのだか兎に角に三人とも素裸體で、諸所に擦傷を負ひながらもつぶれた屋根の下から這ひ出す事が出來た。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋酒屋の息子とかで、家はかなり大きな店らしく、その手紙と共に大勢の追手が出て、その一隊が高野からあと／＼と辿つて今日一度この山へ登つて來、諸所を調べた末一度下りて行つたが、驛前の宿屋で今朝の話を聞いて夕方また登つて來たのだ相である。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよ／＼家族を連れて東京から移つて来て見ると家が古いだけにあちこちと諸所造作を直さねばならぬところがあつた。",
              "citation": {
                "source": "村住居の秋",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦は半ば黄色に熟れて、諸所、刈っているのにも出会った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通に歩けばその日のうちに充分松崎まで行けたのであるが、また行くつもりでもあったが、この附近の余りに景色のよさに諸所道草を食っていて斯うなったのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
