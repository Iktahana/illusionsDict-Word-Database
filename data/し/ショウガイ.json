  {
    "uuid": "9d0f4539-1561-545a-ae29-2a2d6170b0f3",
    "entry": "勝概",
    "reading": {
      "primary": "しょうがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beautiful scenery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こたび尋ねし勝概こそは、始めて我心を滿ち足らしめ、我をして平生夢寐する所の仙郷に居る念をなさしめしものなれ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "説き得て、勝概をつくせるものと云ふべし。",
              "citation": {
                "source": "北總の十六島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗山の勝概こゝに至つて盡く。",
              "citation": {
                "source": "日光山の奧",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "登千山、宿大安寺千山在奉天省、南部諸山中、有勝概奇絶之称。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "佳話の初にまず公園の勝概が述べてある。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅町の岸は本郷向ヶ岡の丘阜を背にし東に面して不忍池と上野の全景とを見渡す勝概の地である。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖のこっち側と向う側と昔は続いていたのでしょうがいつかの時代に裂けるか罅れるかしたのでしょう。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれからしょうがい、夜昼おまえのうちの番をして、おまえに奉公するから」と、かたくお誓いになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ出すのでしょうがいかがしましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは、おれのしょうがいの、かたきだからね。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの美しさのまま、しょうがい年をとらないようにしてあげる。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
