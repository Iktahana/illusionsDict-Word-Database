        "examples": {
          "standard": [
            {
              "text": "高校では、年に数回、専門家による進路指導が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私は進路指導室で、大学の選択について先生と話し合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "進路指導のおかげで、将来の目標が明確になったと彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "進学一本やりの高校では、大学受験のための進路指導は手厚く行われても、就職希望者への指導には経験も力もない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
