    "definitions": [
      {
        "index": 1,
        "gloss": "entering the priesthood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
