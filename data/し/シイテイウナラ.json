        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "強いて言うならば、その時ぼくには明日子が轡川の言う様に浮気な女であるかどうか、ということをその行為で試してみようという気持が心の奥底にあった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は如何でもよろしおま」表情一つ動かさず、強いて言うならば、綺麗な眼の玉をくるりくるり廻していた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ての責任は――若しそれを強いて言うならば――私の中にある。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて言うならば、この物語は児童教育の貴重な参考書であり、その逆の意味では年少の読者にとってたぐい稀な少年文学の一つの見本である。",
              "citation": {
                "source": "「にんじん」とルナアルについて",
                "author": "岸田国士",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって男と女のことであり、強いて言うなら恋愛小説だ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しいていうなら凄艶無比な一個の生きているものだった。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しいていうならば主人公は“時の流れ”である」と、起稿のさい書いた作者のことばを、もいちど思い出していただきたい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
