[
  {
    "uuid": "cef87f2e-fd22-5fc5-bcc9-6f6525bc33ce",
    "entry": "軍鶏",
    "reading": {
      "primary": "しゃも",
      "alternatives": [
        "ぐんけい",
        "シャモ"
      ],
      "is_heteronym": false
    },
