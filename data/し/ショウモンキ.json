    "definitions": [
      {
        "index": 1,
        "gloss": "Shōmonki (chronicle of the Taira-no-Masakado Rebellion, ca 940CE)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
