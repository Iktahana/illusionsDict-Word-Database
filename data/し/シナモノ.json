    "definitions": [
      {
        "index": 1,
        "gloss": "article",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此では到底喧嘩に成らない品物。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主と息子は時々店の品物に溜まる街道の塵をはたいている。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にテーブルを囲んだ人々の環を伝わって卓の下でこそこそと品物が廻される。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にも断えず皆が卓の下で次々に品物を渡しているような真似をしている、その人の環のどこかを実際に品物が移動しているのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、乙姫のお情で、浦島をいつまでも青年にして置くつもりだつたのならば、そんな危險な「あけてはならぬ」品物を、わざわざ浦島に持たせてよこす必要は無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、依田に顛末を知らす事が出来る、その上で行こう、六時にはピケッチングの交替になる時間なんだから、どうしてもそれまでは待たなければならない）　中村は「困るなあ、困るなあ」と呟きながら、品物でも値切るように、クドクドと吉田を口説いた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ているうちに私はこの雑多な品物のほとんど大部分が皆貰いものや借り物である事に気が付いた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の旅嚢から取り出される品物にはほとんど限りがない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれのエキスパートが品物の産地を云ひ當てるやうに、此の男には矢張り特別な眼識が具はつて居るかと思はれた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角も自分の子供の時にはみんな貴重な舶來物であつた品物が、ちやんと此處等のこんな見窄らしい工場で出來て綺麗なラベルなどを貼られて市場に出てくるのであらう。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっと目星い品が視野から彼女を呼び覚すと、彼女の青みがかった横長の眼がゆったりと開いて、対象の品物を夢のなかの牡丹のように眺める。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある一つの大きな台に積上げた品物を何かとよく見るとそれがことごとく石鹸の箱入りであった。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその品物の製作者やその時代に関する歴史的聯想も加わる。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また少し種類が違っているが、品物を集めるのではなくて、古い書物や論文を愛読してその中からその価値の如何によらず人のあまり知らぬ研究や事実を掘出して自ら楽しみまた人に示すを喜ぶ趣味もある。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく「自然」は無尽蔵だと言いますがこれはあながち品物がたくさんにあるというだけの意味ではない。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高射砲など常識で考えても到底頼みになりそうもない品物である。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に日本で出来た品物には誤魔化しが多いから猶更である。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう品物がどういう種類の需要者によって、どういう目的のために要求されているかという事を聞きただしてみたいような気がした。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にぎっしり色々の品物をつめ込んであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に我が親愛なる税関吏は止みなくチューインガムをニチャニチャ噛みながら品物を丹念に引出し引っくら返しては帳面に記入するのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は直に箪笥を拭き始め、その上の品物を一々拭きて工合好く据直す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから忙しげに、なんの必要もない抽斗なぞを開け放して、品物を取り出しては、又元の位置に戻したり何かした。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼女も、私と同じやうに、其處に竝べてある品物を見入つてゐるのだと思つてゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "百円がところ品物を持ち逃げしやがった！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生国を紀州なりと童のいうがままに「紀州」と呼びなされて、はては佐伯町附属の品物のように取扱われつ、街に遊ぶ子はこの童とともに育ちぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し言葉を変えて言ってみれば、西洋人は自然というものを道具か品物かのように心えているのに対して、日本人は自然を自分に親しい兄弟かあるいはむしろ自分のからだの一部のように思っているとも言われる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういうあらゆる杖に比べると、いわゆるステッキほどわけのわからない品物はないと思われる。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の真中にある分析台の上に置いた品物がどこかへ片付けられた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせいでもないが自分は今日まで煙管に限らず時計でもボタンでも金や白金の品物をもつ気がしなかった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "博識の人が、おのれの知識を機会ある毎に、のこりなく開陳するというのは、極めて自然の事で、少しも怪しむに及ばぬ筈であるが、世の中は、おかしなもので、自己の知っている事の十分の一以上を発表すると、その発表者を物知りぶるといって非難する。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
