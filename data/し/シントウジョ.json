  {
    "uuid": "4d9575b3-70bd-5b20-b812-35aa2db908c2",
    "entry": "新唐書",
    "reading": {
      "primary": "しんとうじょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
