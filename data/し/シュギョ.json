        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この地域では、古くから狩漁を生活の糧としている人々がいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国立公園内での狩漁は、厳しく制限されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現代では、狩漁よりも農業や漁業が主な収入源となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "狩猟時代から農耕時代に入った頃の男子は、なお依然として山野に河海に、狩漁の仕事をつづけていた。",
              "citation": {
                "source": "穀神としての牛に関する民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ、さかな屋のむすこや、ひゃくしょうの子であっても、いっしんふらんに勉強し、しゅぎょうをすれば、えらいおぼうさんになる道がひらけていました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、したしくしているかかりの人が、「蘭学しゅぎょうというのは、さきにれいがないし、ぐあいがわるい。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲術しゅぎょうにいきたいというねがいにしたほうがよい。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "その医者のところへ砲術しゅぎょうにいくというのは、おかしいではありませんか。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、おしぬぐって　じっと　だまり、おこらない　しゅぎょうを　したいと　おもいます。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "できる　ように　しゅぎょう　いたします。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "上とうの　ぼうず――もうれつに　しゅぎょうして、ほんとうの　ぼうずの　みちに　たっした　ぼうず。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "中とうの　ぼうず――しゅぎょうが　ふつうで、ものわかりの　いい　ぼうず。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "みっちり　しゅぎょう　しました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もっと　もっと　べんきょうしたい　一休さんは、「わたしは　まだまだ　しゅぎょうが　たりません。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さま、わたしは　びわこの　ほとりに　しゅぎょうに　いきます。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「京で　しゅぎょう　したと　いうが、だれの　もとで　まなんだ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "からすの　こえ　一休さんは　五ねんあまり、この　かそうさんの　もとで　しゅぎょうして　いました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
