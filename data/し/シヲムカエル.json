    "definitions": [
      {
        "index": 1,
        "gloss": "to approach (one's) death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
