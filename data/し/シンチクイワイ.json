        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末、友人の新築祝いに呼ばれたので、お洒落な花を持っていこうと思う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新築祝いには、新しい生活を始める人に喜ばれる実用的な贈り物が良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「新しい家、素敵だね！今度、新築祝いするから来てね」と彼女が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さかんな新築祝いの宴が、時計屋敷で三日三晩にわたって行われたのち、百五十人の建築師たちは、村人にあいさつもせず、風のようにこの土地を去った。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豊　そうさなあ――壮六　それに、今すぐ立つと言うが、今日という今日はああやって喜助頭梁をはじめ、新築祝いでみんな集って来てくれているだからなあ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新築祝いだの転任の餞別だのと、何か因縁をつけて持ち込むのがこの先生の癖である。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、翌年の花盛りに新築祝いが催されたとき、彼は紬の紋附を着、お下りを貰った山沢さんの仙台平をはいて、皆の前で彼の言葉でいう「感状」と幾何かの賞金を貰った。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然う／＼、道場新築祝いだった。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シジムの新築祝い――前に出たイチノベノオシハの王の物語の續きで山部氏によつて傳承したと考えられる。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　ここに山部の連｜小楯が播磨の國の長官に任命されました時に、この國の人民のシジムの家の新築祝いに參りました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
