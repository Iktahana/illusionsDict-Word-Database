        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雨上がりの葉の上には、いくつもの勺水が輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コップの底に残った勺水を飲み干し、彼は席を立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "砂漠で喉が渇き、一滴の勺水でもあればと願った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
