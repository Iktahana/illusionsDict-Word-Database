        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "小さな茶碗に注がれた勺水は、喉を潤すのに十分だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "渇ききった砂漠で、一滴の勺水が命を繋いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はまるで勺水をすするように、ゆっくりと薬を飲んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「雲厨宝鼎」の額の左右に金字の聯をぶら下げて曰、「勺水共飲蓬莱客、粒米同餐羽士家」と。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "先二百五十目位な雛鶏を骨付のまま五分位にブツブツに切ってお米五｜勺水五合とともに塩胡椒を加えて弱い火で気長に二時間ほど煮ます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
