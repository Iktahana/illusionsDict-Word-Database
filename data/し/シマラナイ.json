        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「脚がよく締まらないのは、そりゃあ胴が太いからだろう？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川向うの上木屋町あたりで若い妓たちが、この門の締まるのを見ると、有卦に入るといって、欄干にもたれてじっとそれを待っているが、見ているときには締まらないで、ちょっと眼を外っ方に逸らした時に、ちゃんと閉じられているということだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木戸の締まらないうちに早く行こう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも、晝間は氣が締まらないで駄目だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なぜ政府は雌の河童が雄の河童を追いかけるのをもっと厳重に取り締まらないのです？",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "その締のない口元と目尻の下った目付とは、この女の心の片意地でない証拠と見え、また幅狭い帯の下から隆起した大きなお尻の円味と、下締がよく締まらないのかと思われるような下腹のふくらみ塩梅は、浴衣なぞ着た折は殊に誘惑的に見られるのであった。",
              "citation": {
                "source": "夏すがた",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が、その両親や、祖父母を訴うることを許さずと法律で定めながら、なぜ、子供をも大事にしない親達を厳重に取り締まらないのだ。",
              "citation": {
                "source": "子供は虐待に黙従す",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばね仕掛けであるはずの戸が自然にしまらないのを不思議に思ってふと気がつくと、彼女が静かにハンドルを握りながら、ほほえんで立っていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって見ると、おばあさん二人は竹やぶににげ、英男が土蔵にものを運び込んで、目ぬりまでし、曲って大扉のしまらないのに困って居た。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最大の欠点は、口元にあるらしく、そのために一寸しまらない感じを与へます。",
              "citation": {
                "source": "実悪役者を望む",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "口のしまらない、と言ふ欠点を諒解して、その矯正につとめ、一日も早く実悪らしい実悪、大きな立役に誕生することを望んでやみません。",
              "citation": {
                "source": "実悪役者を望む",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "防水｜扉がしまらないって？",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、運わるく防水｜扉はしまらないで、浸入した海水は、洪水のように機関部へ流れこんでいくという。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工上がりの萬朝はおよそしまらない男で、朝は師匠の圓朝より遅く起きた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「戸がしまらないのさ。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとてそのままでは、バクバクして、いくら土を押えても、根がしまらない。",
              "citation": {
                "source": "雪割草の花",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "口のあたりに方々小さな穴をあけておいてくれ、そしてまた上の板も、あまりきっかりしまらないように釘を打ってもらおう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし酔っぱらっていなかったら、言ってやりましょう、ボン・コアンの家がしまらないうちに一杯引っかけてこようや。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、ボン・コアンの戸がしまらないうちにさ！",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして門がしまらないうちに出るだけの時間はない。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日目ダレで、しまらない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、針金がじゃまになって、ふたは、ピッタリしまらないで、ほそいすきまがあいているのです。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアがピッタリしまらないで、そのすきまから、部屋の中のあかりが、もれているのです。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
