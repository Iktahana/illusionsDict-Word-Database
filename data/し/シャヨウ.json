[
  {
    "uuid": "d0e2dc12-df03-5412-bde6-c15d65020780",
    "entry": "斜陽",
    "reading": {
      "primary": "しゃよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
