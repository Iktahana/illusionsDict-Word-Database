          "literary": [
            {
              "text": "若ければ諦めをつけているが、もう中年へ差しかゝっているのに先が全く閊えていると思うから痺れを切らす。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろそろ旦那が痺れを切らすんじゃないかと心配ですな。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫が好かんやつはきらいさ」「それはそうだろうが、もっとはっきりと区別できないかな」　ケンは伯爵の返答にしびれをきらす。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
