    "definitions": [
      {
        "index": 1,
        "gloss": "junior high school (operated under post-war guidelines)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
