        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「〈ギミ・サム・ラヴィン〉がいい」　ワラがニューヨークで買ってきた、ＫＷＴＳが誇る超最新盤だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧盤の物々しくも劇的な盛上りに対して、新盤の方は素気なくて冷徹だ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、ビクターにはハイフェッツの新盤もある（ＶＤ八〇五六―八）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しくショパンを研究する人には『バラード』の新盤と『ワルツ集』がある。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『トリスタンとイソルデ』の「前奏曲と愛の死」の新盤がコロムビアに入り、世界音楽名盤集の第三輯に入れられることになっている。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時のファンはカルーソーのレコードを一枚か二枚所有するのが、恐ろしい見得で、少々大袈裟に言えば、千里を遠しとせずして、カルーソーの新盤を聴きに行ったものだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
