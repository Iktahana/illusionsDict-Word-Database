        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "築山だけは周りに遠慮したものでしょうか、型ばかりに設えてあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その植え添え方は、豊後梅の幹の洞の中へもって来て野梅を据え、遠くの客座敷の方からは、それが一本の木の花にも見えるよう設えたと言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは床から五｜呎許りの壁に設えた龕の中に納められてあった。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄瑞露と柳麗玉は一隅の薪の積んである前に寝床を設えている。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の上に木を渡して設えたる相当広き物乾し。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板ゴルフ、麻雀、ブリッジ、碁、輪投げ、散歩、デッキに設えたプウルの水泳。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもなお宿泊施設が足りないので、特別列車を設えて兵隊たちを出来るだけ速やかに九州北部に輸送していた。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖壇の前には半円形の演奏台が設えてあって、そこに、ドミニク僧団の黒と白の服装をした、四人の楽人が無我恍惚の境に入っていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その結果、理智の秤量が反対になってしまって、かえってこっちの方が、犯人の設えた秤皿の上に載せられてしまったのだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、さらにあの室の状況を仔細に観察してゆくと、伸子が花瓶を倒すまでの真相が明らかになって、そこに、貴方の顔が現われ出たからですよ」と、まず彼が設えた、狂言の世界を語り終ってから、問題を伸子の動作に移した。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでお伽噺みたいに、そんなことって……」　とお光は結綿を動かして、せかせかと息を喘ませていたが、杉江はその黒襟の汚れを爪で弾き取って、「いいえ、それと云うのは、私の設えた幻燈なので御座います。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四郎兄弟は、陥穽を秘かに設えて置いて、猟人も及ばぬ豊猟を常に占めていたのである。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、外に出たと思って中に入ろうとし、紙帳の垂れをまくって一足｜膝行ると、今度は反対に外へ出てしまうのですが、その眼の前に、一つの穽が設えてあるのです。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、外に出たと思って中に入ろうとし、紙帳の垂れをまくって一足膝行ると、今度は反対に外へ出てしまうのですが、その眼の前に、一つの穽が設えてあるのです。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に設えられた高度計の目盛は、グングン廻って行った。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野は、そこに設えつけの、望遠鏡の接眼部を拭うと、静かに眼に当てた。",
              "citation": {
                "source": "地図にない島",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内されるままについて行くと、その藁葺の農家は、なかはすっかり洋風に造りかえられてあって、椅子やテーブルが設えてある。",
              "citation": {
                "source": "火星の魔術師",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾の尋ねるはらからというのは、その頃寮の中に設えられた座敷牢のような太い格子の内側で、毎日毎日｜温和しく寝ていた幼童――といっても生きていれば今では妾と同じように成人している筈だ――のことだった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口に受付の帳場を設え、来会者を次から次へ住所、氏名年齢、職業を記入する。",
              "citation": {
                "source": "食指談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目を避け他聞をはばかって、奥まった片隅に会議の席を設え、コン吉とタヌが待ち構えていると、ガイヤアルを先登にして三人の山案内が、威風堂々｜舳艫を啣んで乗り込んで来た。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お、冷たい、冷たい、硬直な、怖ろしい死よ、ここに汝の祭壇を設えよ。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は水母の化石を百万年の後に残し、人間の夢は今この雪の結晶を十年博物館の一隅に設えて、暖国に育った子供達に顕微鏡を覗かせたいと願う。",
              "citation": {
                "source": "雪の化石１",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが驚いたことには、こういう建物には、皆冷凍機が設えてあって、年中冷たい風を、床下に通しているのだそうである。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スチームのない客車のこととて、ストーブが設えつけてあったが、それにはまだ火がはいっていなかった。",
              "citation": {
                "source": "ツンドラへの旅",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの頃行ってみると、その町の小学校にもピアノが設えつけられていて、唱歌の時間には子供達が二部合唱をしていた。",
              "citation": {
                "source": "長崎留学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "官邸の玄関に設えられた桟敷の上に、モナコやモロッロの王様と並んで、何時の年の巴里祭に見ても、常に悒然たる面持で佇んでいる、日本名を宗方竜太郎というあの黒髭の美紳士がつまり宗皇帝なのだ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵を取り付ける木枠は本物そっくりの電気仕掛けの薪の上に設えられていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの間をつづってオリーブのつくり葉が、金銀のモール線を綾なして居るのは、どこでも同じしつらえではあるが、独逸はやっぱり独逸らしい。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺骸を郊外山腹にある先祖代々の墓地に葬った後、なまなましい土饅頭の前に仮の祭壇をしつらえ神官が簡単なのりとをあげた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計台のちょうど下にあたる処にしつらえられた玄関を出た。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
