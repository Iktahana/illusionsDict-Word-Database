        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こはよき朝のめざめなり、をとめらのさんたまりやの祈祷なり、みな少女、素足あしなみそろへ行く手に、ちよこれいと銀紙に卷かれ、くだものは竝木の柵に飾られぬ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "校庭宮沢賢治さ霧する白き木柵幹彫れる桐のいくもと剥げそめし白きペンキの木柵に人人は倚りそのペンキあるいは剥げあるものは庭をのぞめり一鐘のラッパが鳴りて急ぎ行く港先生白堊城秋のガラスはひらごとにうつろなりけり",
              "citation": {
                "source": "校庭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限に遠き空の彼方續ける鐵路の柵の背後に一つの寂しき影は漂ふ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠に隣った牧牛舎の柵の中には親牛と小牛が四、五頭、愉快そうにからだを横にゆすってはねている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "流しの板のすべりそうなのを踏んで向側へ越すと柵があってその上は鉄道線路、その向うは山の裾である。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側の柵の中で子供が四、五人石炭車に乗ったり押したりしている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柵の外より頻りに汽車の方を覗く美髯公のいずれ御前らしきが顔色の著しく白き西洋人めくなど土地柄なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "構外のＷＣへ行つて其處の低い柵越しに見ると、丁度其の向側に一臺の荷物車があつて人夫が二人其の上にあがつて材木などを積み込んで居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方のバックには構内の倉庫の屋根が黒く聳えて、近景に積んだ米俵には西日が黄金のやうに輝いて居り、左の方の澄み通つた秋空に赤や紫や色々の煙が渦卷き昇つて居るのが餘りに美しかつたから、いきなり繪具箱を柵の上に置いてＷＣの壁にもたせかけ大急ぎのスケッチをしようとした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで勘定場近くの便所の口へ出て低い木柵越しに外を見ると、そこに一団、かしこに一団という風に人間が寄集まって茫然として空を眺めている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この便所口から柵を越えて逃げ出した人々らしい。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "処々どっしりした旧独逸の高級品屋が在り、柵を引しめる棒柱のように見えるので、下品には決して墜さないで、あとは軒並みの戦後独逸の安物屋、街のかみさんや、あんちゃん、ねえちゃんといった処へ、時々素晴らしい毛皮の令嬢奥様も交った調和が、かえって淋しく品の好い高級品屋の店頭より綺麗なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんどん黒い松の林の中を通ってそれからほの白い牧場の〔柵〕をまはってさっきの入口から暗い牛舎の前へまた来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は〔ひ〕るすぎうっかりしてこうしの柵をあけて置いたもんですから大将早速親牛のところへ行って半分ばかり呑んでしまひましてね……」その人はわらひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニはまだ熱い乳の瓶を両方のてのひらで〔〕包むやうにもって牧場の柵を出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大長柵へは一里に遠いッて云いましたねイ」「そうです、一里半には近いそうだが、もう半分の余来ましたろうよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時少し過ぎと思う時分に大長柵の畑へ着いた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺一体に高台は皆山林でその間の柵が畑になって居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝七五郎家の外（昼）　厩の中で馬に飼料をやりながら七五郎、傍の柵に凭れている石松と話している。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の顏を何度もリュクサンブウル公園の柵に押しつけました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日、ゲエテ街の安宿に、ロダンさんのお迎えの車がやって来て、妾はオテル・ド・ロンの歴史的建築物の薔薇の花の絡んだ鉄柵の小門を潜って、右手の階下のロダンさんのアトリエに妾は案内されました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田は院庭の柵をとび越して二三十歩行くなり、立止まって引金を引いた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "健二はじっと柵にもたれてそれを見ながら、こういうやつを野に追い放っても大丈夫かな、とそんなことを考えていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柵をはずして、二人が糞に汚れた敷藁を出して新らしいのに換えていると、にや／＼しながらいつも他人の顔いろばかり伺っている宇一がやって来た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いざという場合に柵がはずれなんだりすると大変だぜ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して、百姓達は押えに来た際、豚を柵から出して野に放とう、そうして持主を分らなくしよう。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は豚小屋に封印をつけて、豚を柵から出して、百姓が勝手に売買することを許さなくするためにやって来たのである。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "健二は、慌てゝ柵を外して、十頭ばかりを小屋の外へ追い出した。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、外に出るのを恐れて、柵の隅にうずくまっているやつがあった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校の廊下には、べたべた推薦のビラが張られて、選擧事務所なども、ものものしく、或るものは校門の下に立つて、登校の生徒ひとりひとりに名刺を手交し、よろしくたのみます、といつて低くお辭儀をして、或るものは、中學校の先輩といふ義理のしがらみに依つて、後輩を威嚇し、饗應、金錢、などといふばかな噂さへ立つた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
