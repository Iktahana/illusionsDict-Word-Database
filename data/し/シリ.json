[
  {
    "uuid": "d54855c7-a026-5fbb-b52d-7a6bf5d0e289",
    "entry": "尻",
    "reading": {
      "primary": "しり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
