    "definitions": [
      {
        "index": 1,
        "gloss": "Siri (virtual assistant developed by Apple)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
