[
  {
    "uuid": "4efedb38-da1d-5fa9-b565-ff30bb764ab8",
    "entry": "秋霜",
    "reading": {
      "primary": "しゅうそう",
      "alternatives": [
        "あきしも"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "autumn frost",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実に秋霜烈日の如き威光であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し仏法臭を帯びては居るが、秋霜烈日の如き遺言である。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには秋霜のごとく犯しがたき威厳が伴った。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "行けい」　秋霜烈日とした声だった。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は却つて一段の秋霜烈日の嚴を増したのではないかと思つた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は却つて一段秋霜烈日の厳を増したのではないかと思つた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句｜季寄の書には秋霜の題を設くといへども、その作例は殆んど見るなし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから浜尾君をよく知らないものは、彼から春風駘蕩たるものを感ずるよりは、秋霜烈々たるものを感ずる事が多かったらしい。",
              "citation": {
                "source": "徹底的な浜尾君",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴君の一令、秋霜烈日の如し。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを一読するに、温乎として春風のごとく、これを再読するに、凜乎として秋霜のごとし。",
              "citation": {
                "source": "将来の日本",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "順序から言へば、おなじ頃のものと思はれるが、人の刀くれけるとき抜からに、身をさむくする秋霜。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに斯うして武装した軍隊を見ると秋霜凜冽、矢も楯もたまらぬ、戦わざるにすでに一触即発の肉弾になりきっている。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋霜にひしがれ枯れた、名もない草は、早くも、来年の夏を希望する。",
              "citation": {
                "source": "名もなき草",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "独在異郷為異客、毎逢佳節倍思親、遙知兄弟登高処、※挿茱萸少一人、手種茱萸旧井傍、幾回春露又秋霜、今来独向秦中見、攀折無時不断腸、　昔中国から来た呉茱萸が今日本諸州の農家の庭先きなどに往々植えてあるのを見かけるのは敢て珍らしいことではない。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろその秋霜烈日の命令が立ちどころに履行されてゆく爽快味を満喫してゐると言つた方が、当つてゐるかもしれない。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "血迷ったか丹波、突然その釣瓶落しを振りかぶるが早いか、それこそ、秋の日ならぬ秋の霜、秋霜烈日のいきおいで、大上段に斬りつけたのです。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　レエヌさんが、息を切らして打つのをやめると、キャラコさんは、しずかに立ちあがって、秋霜のような威厳で命令した。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家の勢の持つ弓すでに半月に引かれ、太刀は三尺の秋霜となって何時でも敵の骨を断とうと光を放っていた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにその厳として秋霜烈日的なる人格は深く畏敬せられ、自ずと衆人に襟を正さしむるものがあった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "卜宅麻渓七値秋霜餘老樹擁西楼笑吾十日間中課掃葉曝書還※裘荷風ノ書ト漢詩ハサシテ巧ミデハナイケレドモ、彼ノ小説ハ予ノ愛読書ノ一ツデアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その父は、秋霜のように、厳格一方な人物だった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常は秋霜のようにきびしいが、実は、世の親の誰よりも子には甘い煩悩をも一面に持っていることをみなよく知っているからだった。",
              "citation": {
                "source": "剣の四君子",
                "author": "柳生石舟斎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうふうに、剣の烈しい一面のみを以て、秋霜身を持し、また将軍にもそのまま、刃びきの刀をもって、遠慮なしに稽古をつけたりした小野一刀流は、自然、忌まれ避けられ、次郎右衛門その者の人間まで、知らず知らず遠ざけられて、独り柳生流のみが、将軍お手直しの剣道として、世人にまで称美される風を作った。",
              "citation": {
                "source": "剣の四君子",
                "author": "小野忠明",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝は今、ここ生涯の門立ち、死にもの狂いの気と、秋霜の軍律をもって臨んでおり申せば、自然｜厳かに過ぐるとも、微塵、日頃の私情や妥協は持ち合わさぬが――ようその軍律にお伏しあったぞ。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに見れば、川向こうから三方ヶ｜原のおちこちには、いつか、秋霜のごとき槍と刀と人影をもって、完全な人縄を張り、遠巻きに二｜重のにげ道をふさいでいる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋霜の下りた山国のあさは、都の冬よりはまだ寒い。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "にも関わらず、いかに彼が努めて――春風人ニ接シ、秋霜己レヲ持ス――の態を心がけても、その大きな黒瞳をもった瞼は、涙というものに濡れた例しを知らないかのように見える。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが自分への叱責であった事は温かい慈愛の相の中に秋霜のようなきびしい素振りを時々見せたのでも考えられた。",
              "citation": {
                "source": "梅※の杖",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
