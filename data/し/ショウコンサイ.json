    "definitions": [
      {
        "index": 1,
        "gloss": "memorial service (esp. for war dead)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翌年の初夏金沢の招魂祭を当て込みて、白糸の水芸は興行せられたりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……秋の招魂祭の、それも真昼間。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アメリカにも、招魂祭があるのかしら。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそここへ泊まるほうが楽だろうと思って、じゃあいたへやへ案内してくれと言うと、番頭はまたおじぎを一つして、まことにお気の毒さまでございますが、招魂祭でどのへやもふさがっておりますのでとていねいに断わった。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕に出た女が、招魂祭でどこの宿屋でもこみ合っているとか、町ではいろいろの催しがあるとか、佐野さんも今晩はきっとどこかへお呼ばれなすったんでしょうとか言うのを聞きながら、ビールを一、二はいのんだ。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊の行列も招魂祭の賑はいも、すべては古風な絵巻か何かのやうにおもへる。",
              "citation": {
                "source": "広島の牧歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "常設館ができるまでは巡業隊の持つてくる写真を芝居小屋か招魂祭の掛小屋で見ていた。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "招魂祭の掛小屋で乃木大将の一代記というのを見た覚えがある。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはむしろ招魂祭の見せ物に近きものである。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小郡の招魂祭、ポン／＼花火が鳴る、彼等に平和あれ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯屋でゆつくり、そして酒屋でいつぱい、それから栄山公園の招魂祭へいつた、そこは小郡町唯一の遊覧地である、まづ可もなし不可もなしだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　陣中の芝居　明治三十八年五月四日の午後、阿吉牛堡に駐っていた、第×軍司令部では、午前に招魂祭を行った後、余興の演芸会を催す事になった。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方は招魂祭の余興相撲であつたらう。",
              "citation": {
                "source": "「追憶」による追憶",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今春、招魂祭の夜の放送を聞いて、しみじみと思ったのである。",
              "citation": {
                "source": "人生における離合について",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京には招魂祭、府中には大国魂神社の祭礼があるので、甲州街道も東へ往ったり西へ来たり人通りが賑やかだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦争｜凱旋当時、此｜丘上に盛大な師団｜招魂祭があって、芝居、相撲、割れる様な賑合の中に、前夜｜恋人の父から絶縁の一書を送られて血を吐く思の胸を抱いて師団の中尉｜寄生木の篠原良平が見物に立まじったも此春光台であった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで招魂祭にはよく、時間の間を見ては、行き／＼したものだ。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（按）右は明治八年頃戊辰戰死者の爲に招魂祭典を擧げたる時、翁自ら靈前に供へたる祭文なり。",
              "citation": {
                "source": "遺篇",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊野先生　大正十一年秋、松江の招魂祭の日はしぐれていた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒は招魂祭がすむと城山のからめ手石垣のかげに集まり、先生の弁明を要求し、やむを得ねばストライキにまで行こうと決議した。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそんなことは気にかけてもゐないやうに、今日は招魂祭だのに、国旗を出し忘れたといふやうなことを喋つたと思ひます。",
              "citation": {
                "source": "クロニック・モノロゲ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戰爭凱旋當時、此｜丘上に盛大な師團招魂祭があつて、芝居、相撲、割れる樣な賑合の中に、前夜戀人の父から絶縁の一書を送られて血を吐く思の胸を抱いて師團の中尉｜寄生木の篠原良平が見物に立まじつたも此春光臺であつた。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋、招魂祭で九段の靖国神社が、テント張りの見世物で充満している、ある昼過ぎのことであった。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうそう、此間中招魂祭だったね。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "招魂祭の特別余興場、今日は東宝の日で、一席やる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、十時起き、招魂祭の奉納余興で軍人会館へ、堀井・石田の漫才、次に一人で漫談、田舎客、おまけに子供ビービー泣き、大くさり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
