        "examples": {
          "standard": [
            {
              "text": "プログラムの実行速度を上げるには、主記憶へのアクセス回数を減らす工夫が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "CPUが直接データを読み書きするのは、ハードディスクではなく主記憶である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "主記憶の容量が不足すると、OSはスワップ処理を行い、動作が極端に重くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それでも一一枚のプリント基板を駆使し、主記憶は一Ｋバイトの手作り一号機を完成させることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーボードの上に指を置き、ジャズピアノを奏でるような流暢な手つきでセーブしてある“ＫＡＩＺＯＫＵ＄９”を主記憶上に呼び出した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
