    "definitions": [
      {
        "index": 1,
        "gloss": "first edition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その理由の一つは、兩者の詩共、昔の初版の原本でなく、後に改造社や新潮社で出したところの、自選詩集によつて讀んだ爲であるか知れない。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "初版は、五百部ぐらいだったでしょうか。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初版は、五百部ぐらゐだつたでせうか。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七七年に彼の Theory of Sound の初版がマクミラン（Macmillan）から出版された。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再版の序　この詩集の初版は大正六年に出版された。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この詩集の初版が初めて世に出た時の詩壇と今日の詩壇とは、何といふ著しい相違であらう。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「晩年」の初版は昭和十一年に砂子屋書房といふところから出版せられた。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このころ第一創作集の「晩年」というのが出版せられて、その創作集の初版本に、この写真をいれました。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一つ家に一人寝て観る草に月（「愚を守る」初版本）",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩ちればコスモス咲いてそして茶の花も（「愚を守る」初版本）",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「愚を守る」初版本　昭和十六年八月刊）",
              "citation": {
                "source": "遍路の正月",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "初版から三版までに多くの歳月が流れているのは、この本がデンマークにおいてはあまり問題にされなかったためであろう。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ツァラトストラ」の初版が、僅かにただ三部しか売れなかつたといふ歴史は、この書物の出版当時に於て、これを理解し得る人が、全独逸に三人しか居なかつたことを証左して居る。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元來、詩集といふものは、初版限りで絶本にするところに價値があるので、版を重ねて増册しては、詩集の人に貴重される稀本の價値が無くなつて來る。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の理由は、初版「青猫」の内容と編輯とが、私にとつて甚だ不滿足であり、意にみたないところが多かつた爲である。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも「青猫」を完全な定本詩集とする爲には、是非とも此等の詩を補遺しなければならないので、初版出版後今日まで、長く私はその再版の機會を待つて居た。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた私は、その再版の機會をまつて、初版本の編輯上に於ける不統一を正さうとした。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「青猫」の初版本が、この點でまた不備であつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の第二の理由は、初版本の裝幀、特に繪とするつもりであつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初版「青猫」は多くの世評に登つたけれども、著者としての私が滿足し、よく詩集のエスプリを言ひ當てたと思つた批評は、當時讀んだ限りに於て、藏原伸二郎君の文だけだつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藏原伸二郎卷尾に　この書の中にある詩篇は、初版「青猫」を始め、新潮社版の「蝶を夢む」第一書房版の「萩原朔太郎詩集」その他既刊の詩集中にも散在し、夫夫少し宛詩句や組方を異にしてゐるが、この「定本」のものが本當であり、流布本に於ける誤植一切を訂正し、併せてその未熟個所を定則に改定した。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの書の初版が出てから、既に約十年の時日が経ってる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の両方合せて三十五版、部数は初版が二千部で二版以下は大抵千部である。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "定本：「岡本かの子作品集」沖積舎　　　1990（平成2）年7月20日初版発行　　　1993（平成5）年6月30日新装版発行※底本は、物を数える際や地名などに用いる「ヶ」（区点番号5-86）を、大振りにつくっています。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「晩年」は初版が五百部くらいで、それからまた千部くらい刷った筈である。",
              "citation": {
                "source": "「晩年」と「女生徒」",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女生徒」は初版が二千で、それが二箇年経って、やっと売切れて、ことしの初夏には更に千部、増刷される事になった。",
              "citation": {
                "source": "「晩年」と「女生徒」",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は知るまいが、初版は千五百部で以後五百部ずつ版を重ねたのだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "海豹と雲　　　　初版　　昭和四年八月　　アルス版（絶版）白秋全集第四卷　詩集※　昭和六年一月　　アルス阪（絶版）",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、初版に一二訂正を加へたのがある。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初版通りで済ませば済むものを、旅先まで昔の幽霊を背負ってあるく自分も自分だなと深い心の底から溜息も出る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
