    "definitions": [
      {
        "index": 1,
        "gloss": "first word (of an infant)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今ごろから寄り道をしていたりすると、全體が無際限に長くなつてしまう上に、自分が最初語ろうと思つた事がらを指の間からすべり落してしまうかもわからない。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園精舎の初語りもよし、小督、忠度都落ち、宇治川、敦盛、扇ノ与一。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ないしょごとはすぐ暴露れまさあね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ないしょごとってえものがあるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間にはだれだって他人に聞かせてならねえないしょごとってえものがあるんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでお妃は、王さまのけらいの者にたくさんお金をやると、こやつらはさっそく、王さまのないしょごとをあかして、おまけにふしぎなおだまきだけが道しるべをしてくれることまで、べらべらしゃべりました。",
              "citation": {
                "source": "六羽の白鳥",
                "author": "グリム兄弟　Bruder Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしも、ちょっと買物をしますから、たいてい、ごいっしょごろになりますわ。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの些細のないしょごとに過ぎないでしょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人はおとなしくうなずき、水を汲むのも、顔を洗うのも、まるでないしょごとのように気をくばりました。",
              "citation": {
                "source": "柿の木のある家",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "コソコソとないしょごとをやるのは、いわばしろうとでございますからね」「えらい。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
