[
  {
    "uuid": "f7a20cea-bb90-51a5-bf42-92c3a4ad654d",
    "entry": "硝石",
    "reading": {
      "primary": "しょうせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
