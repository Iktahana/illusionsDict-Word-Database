    "definitions": [
      {
        "index": 1,
        "gloss": "ceremony held before going into battle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "出陣式では、戦国時代の習わしに従って勝ち栗や打鮑が振る舞われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勇壮な太鼓の音が響く中、出陣式が執り行われ、一族の結束を確認し合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "神社で必勝祈願を行った後、広場に集まって盛大に出陣式を開催した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "熱田の町口には加藤｜図書助順盛が迎えに出て来て居て、出陣式法の菓子をそなえた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時は出陣式とか鎧の着初式とかいうのを古式に依って行い、門人の中の或る子供が殿様や若殿様となり、その他も種々なる役人となって、各々小具足を着けて真似事などをした。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "ceremony to kick off an election campaign",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "事務所前で行われた出陣式には多くの報道陣が詰めかけ、熱気にあふれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「勝つぞ！」という掛け声とともに出陣式が締めくくられ、支持者たちのボルテージは最高潮に達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出陣式で候補者の妻が涙ながらに支援を訴えると、会場から大きな拍手が沸き起こった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
