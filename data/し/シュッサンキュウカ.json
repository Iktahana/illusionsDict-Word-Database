          "standard": [
            {
              "text": "来月から出産休暇に入るため、現在の業務を引き継ぎ資料にまとめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出産休暇中に会社の制度が変わり、復職後の時短勤務がより柔軟になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ゆっくり休んでね」と送り出され、心置きなく出産休暇に入ることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "身重になった看護婦が、一つ病院の中でそういう体で大して無理のない部署へまわり、出産休暇まで勤務をつづけるのは、思ってみればあたりまえのことだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
