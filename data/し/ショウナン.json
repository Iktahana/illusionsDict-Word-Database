[
  {
    "uuid": "c668d780-2ad2-5f74-8fd4-bdc6f957b4a1",
    "entry": "小難",
    "reading": {
      "primary": "しょうなん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
