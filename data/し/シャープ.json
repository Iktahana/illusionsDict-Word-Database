    "definitions": [
      {
        "index": 1,
        "gloss": "sharp (blade, image, mind, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジョッキとアフガンに従軍し、キャラシァブ、シャープール及びカブールに駐屯したる事あり。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの仲間から、シャープの出していたＭＺ―80Ｋというマシンを中古で譲ってもらい、しばらくはプログラミングに熱中したそうです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも家電への参入宣言があり、この戦略に沿ってアップルはカラーの液晶ディスプレイに高い技術を持つシャープとの提携に踏み切った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九二年三月二十七日付けのシャープの発表によれば、両社は「次世代のパーソナル情報機器の開発から生産および販売について、長期的な事業提携を結ぶことに合意し、契約を締結」した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャープの電子手帳はアメリカではウイザード（魔法使いね）という名前で出張っているが、こいつにマッキントッシュの爪の垢を飲ませて洗練させようということだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに明かとなっているパートナーは、シャープとソニーだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "次世代のコンピューター開発をめぐるアップルと日本企業の協力という線で追えば、先に触れた一九九二年三月二十七日発表のシャープとの提携は、この次にくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハミルトン氏は実にシャープなビジネスマンライキな人です。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一はギター・ケースのところにいき、外側の大きなポケットをあけ、スパイラル・ノートとシャープペンシルをひっぱりだし、令子のそばにもどる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄然太陽の光は白くなり、影はシャープになる。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音をきいて居ると、急に、自分のピアノのFaのシャープの出ないのが気になり出す。",
              "citation": {
                "source": "一日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ポケットからエ※・シャープを出し、「よく御覧なさい、ここにほら一枚大きい石がはまってるでしょう、ここがとりはずし自由で、内が龕になっているというわけさ。",
              "citation": {
                "source": "墓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日立のベーシックマスターやシャープから出ていたＭＺ―80Ｋなどいくつかの先行するマシンはあったものの、おそらくほとんどの人が日本における初の本格的パーソナルコンピューターとして指摘されるだろう日電のＰＣ―８００１の発売からは、わずかまだ五年です。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、日本国内ではカシオ計算機とシャープを中心に激しい電卓の低価格化競争が繰り広げられており、その様は電卓戦争とも形容されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アタリ社の創設者、ブッシュネルのシャープなビジネス感覚と、マイクロコンピュータの可能性だ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新し物好きで、毛色の変わった電気製品には目のなかった父は、それまで真空管式だった電卓を一九六四（昭和三十九）年にシャープが初めてトランジスター化したコンペットを買ってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついては日本に来ないか」と電話でまくしたてた東洋人が、同世代のシャープな人間であることを、ゲイツはすぐに理解した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のソフトハウス、ハドソンの開発したベーシックを載せたシャープのＭＺ―80Ｂといった一部の例外を除いて、マイクロソフトのベーシックは日本の標準となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "早水は計画部の平賀正豊と二人で年末商戦で賑わう秋葉原を歩き、ＰＣ―８００１やシャープのＭＺ―80、日立のベーシックマスターなど八ビットの人気機種用のアプリケーションを片っ端から買い集めはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六〇年代のはじめに真空管を使って初めて作られた電子卓上計算機は、一九六四（昭和三十九）年にシャープのコンペットで初めてトランジスター化され、小型化、低価格化に向かって進みはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターで初めてＡＳＩＣを使いはじめたのはシャープのＭＺ―80Ｂだったが、松本もＳＭＣ―70でほぼ同じ時期に、専用のＬＳＩを起こすことを体験していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子辞書に音声の合成装置を組み合わせ、母国語で入力した言葉を外国語に変換して発音させるというこの装置を、孫はシャープに売り込んで事業化させることに成功する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ』とシャープの『Ｏｈ！",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　万年筆だのエヴァシャープだのを胸ポケットにさしている年配のが、落着いたような声で云った。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の相手役、米国海軍士官ピンカートンになるテナーはパリのグランドオペラのラフィット、米国領事シャープレスになるのはジュリアン・キムベル、女中お鈴になるアルトはイダ・サガールが主役で幕があきました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国領事のシャープレスが、ピンカートンの手紙を持って訪ねて来ます。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあとで判ったことだけれど、彼女はあの銀鍼をシャープペンシルの軸の中に隠して持っていたのだった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、本物からのスカシ画を利用して、先のシャープな鉛筆で着実にトレースをはじめるのだ。",
              "citation": {
                "source": "“能筆ジム”",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままでにも、だめといったのが、無理に頼めば、しまいにはきいてもらえたので、シャープ＝ペンシルにしても、いつか自分のものになると思ったからです。",
              "citation": {
                "source": "小さな弟、良ちゃん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
