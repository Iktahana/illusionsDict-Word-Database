        "examples": {
          "standard": [
            {
              "text": "天体観測において、シーイングの良し悪しは非常に重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日のシーイングは素晴らしく、遠くの銀河もクリアに見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大気の状態によってシーイングが変わり、望遠鏡の性能に影響する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "シーイング、岩遊びの場合でもそうであるが、ことに登山の場合には一度目指された頂きはあくまでも追求されねばならず、いい加減でやめてしまうわけにはいかない。",
              "citation": {
                "source": "山想う心",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、気さえあれば、相当に賢いサイト・シーイングが出来ない訳ではなかったのだ。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機体の美しさに合わせた造形の階段が引き離され、四つのプロペラが回転を始め、機体はおもむろにタクシーイングを始めた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
