        "examples": {
          "standard": [
            {
              "text": "このプロジェクトは途中でモチベーションが下がり、尻すぼみになってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のスピーチは序盤は盛り上がったが、最後は尻すぼみで終わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のストーリーが尻すぼみで、期待外れだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「恐かねえさ、あんま、面白そうでもないしよ……」　という山崎のことばは、尻すぼみに小さくなる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥へいくにしたがって尻すぼみにせまくなる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一本ボトルをあけろ」　つぶやきがしりすぼみになり、再び深い眠りに落ちた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
