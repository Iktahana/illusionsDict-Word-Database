[
  {
    "uuid": "7c45d889-f1be-57ec-a796-7c7f1c72cbae",
    "entry": "鐘楼",
    "reading": {
      "primary": "しょうろう",
      "alternatives": [
        "しゅろう"
      ],
      "is_heteronym": false
    },
    "grammar": {
