      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "belfry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三　山の麓のさびれた高い鐘楼と教会堂の下に麓から谷間へかけて、五六十戸ばかりの家が所々群がり、また時には、二三戸だけとびはなれて散在していた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手に鐘楼があって、小高い基礎の周囲には風が吹寄せた木の葉が黄色くまたは赭く湿れ色を見せており、中ぐらいな大さの鐘が、漸く逼る暮色の中に、裾は緑青の吹いた明るさと、竜頭の方は薄暗さの中に入っている一種の物※しさを示して寂寞と懸っていた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの名高い伽藍にくらべて別に立派なとも思いませんが両側に相対してそびえた鐘楼がちょっと変わった感じを与えます。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘楼の下の扉が開いて女が顔を出した。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「セバストポールの鐘をごらんなさい」と先に立って、反対の側の鐘楼へ導く。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また鐘楼へもどってはいる。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩原晃この時｜白髪のつくり、鐘楼の上に立ちて夕陽を望みつつあり。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘楼は柱に蔦からまり、高き石段に苔蒸し、棟には草生ゆ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷包を斜に背い、脚絆草鞋穿、杖づくりの洋傘をついて、鐘楼の下に出づ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘楼へ上ってみても差支えはありませんか。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、丑満の鐘を撞いて、鐘楼の高い段から下りると、爺は、この縁前で打倒れた――急病だ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――虫より細い声だけれども、五十年の明暮を、一生懸命、そうした信仰で鐘楼を守り通した、骨と皮ばかりの爺が云うのだ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩原晃はいざ知らん、越前国三国ヶ岳の麓、鹿見村｜琴弾谷の鐘楼守、百合の夫の二代の弥太兵衛は確に信じる。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥方の人を離れた美しさを見るにつけても、天がこの村のために、お百合さんを造り置いて、鐘楼守を、ここに据えられたものかも知れん。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雪　む、（と眦をあげて、鐘楼を屹と見る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦｜仲睦じく、一生｜埋木となるまでも、鐘楼を守るにおいては、自分も心を傷けず、何等世間に害がない。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とお百合を抱くようにして三人｜鐘楼に駈上る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び凄じき電に、鐘楼に来り、すっくと立ち、鉄杖を丁と振って、下より空さまに、鐘に手を掛く。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "学円、高く一人｜鐘楼に佇み、水に臨んで、一揖し、合掌す。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と鐘楼を見ていひました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして鐘楼に眼をつけると、「そんなら、鐘撞いて見ろ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　栄蔵は鐘楼にのぼつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達はかういふことには馴れてゐるので、兎のやうに鐘楼からとび下りると、下にゐた子供達と一緒に一目散に山門をとび出していつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘楼の下にあじさいが咲きさかっている真昼どきだった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、尼寺の庭の鐘楼の下は、村のこどものたまりばだからだ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなつきたいものばかりなので、吉彦さんはみんなを鐘楼の下に一｜列励行させた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんごろ鐘はひとまず鐘楼の下に新筵をしいて、そこにおろされた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは、ごんごろ鐘の出征の日を、一｜日まちがえてしまって、ついにごんごろ鐘にお別れが出来なかったことを、たいそう残念がり、口を大きくあけたまま、鐘のなくなった鐘楼の方を見ていた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手に鐘楼が有つて、小高い基礎の周囲には風が吹寄せた木の葉が黄色く又は赭く湿れ色を見せて居り、中ぐらゐな大さの鐘が、漸く逼る暮色の中に、裾は緑青の吹いた明るさと、竜頭の方は薄暗さの中に入つて居る一種の物※しさを示して寂寞と懸つてゐた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とへんじがきこえて、正観が、ごそごそ鐘楼からおりてきました。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
