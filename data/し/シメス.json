[
  {
    "uuid": "44aae192-8d3e-582e-8779-94ed5253fcb6",
    "entry": "示す",
    "reading": {
      "primary": "しめす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
