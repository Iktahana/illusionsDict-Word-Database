    "definitions": [
      {
        "index": 1,
        "gloss": "to show one's true colors (colours)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "信吉の意に適っているのは、野放図、破天荒、横紙破り、常規を逸したもの、破目を外したもの、尻尾を出すこと――いわゆる反俗精神の裏づけあるものに限られていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家と世間で認められてゐる人の中でも、ときどき思はぬ尻尾を出すことがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼女が少しでも伊達と妥協しているとすれば、ああいう問題の際に、ちよつとでも顔色をかえて尻尾を出すものだが、そのようすはすこしもなかつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに秘密に事を運ぼうとしても、すぐに尻尾を出すからね。",
              "citation": {
                "source": "化生のもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "速水さんの調べが済んでるのよ」「いまに尻尾を出すから見ていてごらんなさい。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあに訴えた所で、彼奴が尻尾を出すもんですか。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こだわった揚句には、とんだ尻尾を出す危険がある。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが天井裏は思ひの外綺麗で、あんなに着物が汚れる筈はなかつたんだ」「――」「國松は利巧者で、つまらない細工の好きな方だつたが、それでも惡い奴は器用な細工をすればするほど尻尾を出すことになるんだね。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "酒屋忠僕",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ていろ、いまに尻尾を出す」　そういいながら、行子のほうへ振返った。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "容易のことでは尻尾を出すまいよ」　平次はそういううちにも死骸の調べを続けております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時どんなことで、下手人が尻尾を出すかもわからないから――」　そんな暢氣なことを言ふのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お吉お雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕が出來ても、腹の出來ない人間といふものは、何處かで尻尾を出すんだね。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕が出来ても、腹の出来ない人間というものは、どこかで尻尾を出すんだね。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつどんなことで、下手人が尻尾を出すかもわからないから――」　そんな暢気なことを言うのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お吉お雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界はこんなに大きく歴史が轟いて推移して居り、その波は日夜この生活にさしているのに、意識した関心事といったら、けちなけちな一身の欲望、どんなにして尻尾を出すまいとか、口実をみつけようとかいうのだというのは、何と不思議でしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きさまは嘘ばかりついてるんだ、おれに尻尾を出させようと思って、人をからかってるんだ……」「いや、もうそのうえ尻尾を出すわけにはゆきませんよ、ロジオン・ロマーヌイチ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十三次はドライブしたが、京都や大阪は、そんなにくわしく知らないから、尻尾を出すのがこわい。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間なんか大騒ぎだったぜ」「謹厳の君子チョク／＼尻尾を出すと見えるね？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういういやがらせをして、僕たちが尻尾を出すのを待ちかまえているんだ。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆に出たらあわてて尻尾を出す奴だろう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
