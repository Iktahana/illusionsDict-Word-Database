    "definitions": [
      {
        "index": 1,
        "gloss": "Das Kapital (by Karl Marx)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "経済学史を講じているんだが『富国論』と『資本論』との比較なんかさせるとなかなか足角が現われる。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスの資本論でもそうだ。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働者と資本論との間に何のかかわりがあろうか。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体まだ資本論さえ読んで居ないんですもの何とも云えません。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが友は、今日も我が友は、今日もまた、マルクスの「資本論」の難解になやみつつあるならむ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に何かの拍子で共産主義のことが出た時、伯父は、『資本論』の原本をその中に誰かに借りて来てくれ、と言い出した。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "航海学かい」「ナアニ、友人から借りて来たんだが、とてもむずかしくて、わからねえんだ」「ちょっと見せたまえ、ヘヘー、マルクス全集、第一巻※か、資本論か、それや君、社会主義の本じゃないかい」　藤原は、自分もその本を非常に読みたく思っていたが、あまり高価なので今まで買うことができなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八〇年代というときは、又ロシアに最初のマルクス主義団体が生れ、マルクスの「資本論」が翻訳されていた。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "情勢は移って「資本論」などが読まれだしていた。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の労働者の中に、『資本論』を読んだものは幾人も居ない。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼のとりかかっている「資本論」は大英博物館の図書館なしには完成しない。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六七年、遂に世界的な名著『資本論』第一巻が出版された。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マルクスがイエニーを失った悲しみにうちかって資本論を完成しようとした努力は、寧ろ悲痛な姿であった。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「資本論」をよみとおすことはできなかったけれども、他の部分では、作家として、女として、多くのことを学ぶことができた。",
              "citation": {
                "source": "生きている古典",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢えたる人間にとってはバイブルがなんの役にも立たない如く、マルクスの資本論も同様に役には立たないのである。",
              "citation": {
                "source": "錯覚自我説",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに小さくても、私どもはその「資本論」を読んで自分たちの生活を改善して行くことができる、そういう条件下におかれている小さい一人一人です。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、マルクスの『資本論』をひもとくに及んで、始めて、長年の蒙を開かれ、そして自分の進むべき道はただ一つ――資本主義社会の転覆以外にはない、ということを知ったのです。",
              "citation": {
                "source": "進むべき道",
                "author": "野呂栄太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "講座及び「資本論」の方何卒よろしく御願いします。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三三年三月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケットに資本論を突っ込んで銀座をブラついて歩いたって咎めるわけにはいかない。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マルクスの資本論も疎開させておくといいよ、今に値うちが出る」修造がこう云うと、周一は大きく頷く。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ本をかりて読み、或るとき、何と思いちがいしたかマルクスの「資本論」をかしてくれと云った。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊＊＊　岩波文庫版、『資本論』第一巻第一分冊、三二頁。",
              "citation": {
                "source": "科学批判の課題",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダーウインの進化論以後に於て、更にマルクスの資本論乃至唯物史観以後に於て、彼奴等支配階級に対して同情を感ずると云ふことは、コペルニクス以後に太陽が地球の周囲を廻ると考へるよりももつとひどい誤謬でありこつけいであると僕は思ふのだ。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本論、交換カチのところ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから資本論やって貰い、その二人を片山さん divan の上から写生した。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方資本論で頭よくしようとしつつセンチになっては何もならぬ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　このイギリス譯は、マルクスの『資本論』の大部分を譯したサミュエル・ムーア氏の手になり、氏と私と一緒に校訂をなし、私は更に、歴史的用語を説明する二三の註釋をつけ加へた。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づイリー教授の書とカーカップの歴史を讀み、マルクスの『資本論』に喰ひつきました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論讀了どころか半分も讀めませんでした、そして、ジョン・レーの『現代社會主義』中のマルクス紹介で資本論をも卒業しました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、私の社からの出版物としては第一に円本の先駆をなした『現代日本文学全集』を挙げ、それから『アインシュタイン全集』、『経済学全集』、『マルクス・エンゲルス全集』、『資本論』、『日本地理大系』その他数十の全集を発行して来た。",
              "citation": {
                "source": "十五年",
                "author": "山本実彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
