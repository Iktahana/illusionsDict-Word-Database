    "definitions": [
      {
        "index": 1,
        "gloss": "to put an end (to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
