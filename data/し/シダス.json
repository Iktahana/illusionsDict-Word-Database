    "definitions": [
      {
        "index": 1,
        "gloss": "to begin to do",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "タンポポの花一輪の贈りものでも、決して恥じずに差し出すのが、最も勇気ある、男らしい態度であると信じます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、も少し出すかと思つた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は、龍宮の階段まで見送りに出て、默つて小さい貝殼を差し出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中から、舌を拔かれた小雀を搜し出すのは、至難の事のやうに思はれるが、しかし、お爺さんは異樣な熱心さを以て、毎日毎日探索する。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "管壁の摩擦に打勝って卵を押し出すために卵の後方の環状筋を断えず収縮して卵殻を圧しつける。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "深山榛の木の根方にうち倒れた、醜い空骸は、土に還ると共に、根方に寄生して、そこから穂のような花をさし出すおにくという植物になった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "良さん今朝の指輪はめて下さいましたかと云ふ声の細さよ答へは胸にせまりて口にのぼらず無言にさし出す左の手を引き寄せてじつとばかり眺めしが。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去のある瞬間に世界のうちのある場所で起った出来事を映写器械のレンズで見た、その影像の写しをそのままに吾々の眼を通して直接に吾々の頭の中へ写し出すのである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳が、Ｔ「娘をこの雲霧主膳に呉れぬその時は」　と云って、Ｔ「此の連判状を奉行所へ差し出すぞ」　エッと源兵衛顔色蒼白となる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳が、Ｔ「連判状を老中へ差し出すなぞ、野暮は申さぬ」　と言って、Ｔ「その代り」　と詰め寄る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍が、Ｔ「先生　只今御病気中に　御座れば」　ナニッ病気、と団九郎、　取次の侍、紙包を取り出して、Ｔ「誠に軽少に　御座るが　ホンの草鞋銭」　と団九郎の前に差し出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで次に皿を差し出す檀那は誰様だらうと思案したが、これはカロリイネ様の御亭主でペエテル様だと極めた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘商人が自転車で忙がしく商取引所方面に疾走し出すころ、マダム・レムブルグが瀝青の浮いた黒襦子の着物をつけて朝のミルクのなかで接吻をすると、海峡を船脚｜迅く航行する汽艇、陳独秀が汕頭に行く姿を指さすのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘商人が自転車で忙がしく商取引所方面に疾走し出すころ、マダム・レムブルグが瀝青の浮いた黒襦子の着物をつけて朝のミルクのなかで接吻をすると、海峡を船脚迅く航行する汽艇、陳独秀が汕頭に行く姿を指さすのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、その性質｜如何に拘らず、一｜體人の犯罪｜乃至は祕密を探し尋ねて、それを白日にさらし出すと云ふ事はあんまり好い氣持のするものぢやありません。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前には兩眉の間の眉間のへんが妙にむづむづしてくるのが極りだつたが、何しろ自分の體がいきなり涯知らずくうつと延び出すやうな感じがし出す。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつたい誰でも運勢が傾いてくると、自然とじたばたし出すのは人情の然らしむる所だが、五｜段里見※は紙入からお守札を並べ出す、四｜段古川緑波はシガアレツト・ライタアで切り火をする。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見て来た人の説明を聞いても、自分の目で見るまでは、色彩のある絵画を映し出す影絵の存在を信ずる事ができなかった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どうもこの管弦楽というものは、客観的分析的あるいは批評的に聴くべきものではなくて、ただこの音の醸し出す雰囲気の中に無意識に没入すべきもののような気がする。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に彼は音楽の醸し出す天上界の雰囲気に包まれて、それで始めて心の集中を得たのではあるまいか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にはただ弔詞を包紙に包んだままで柩の前に差し出すのも沢山にあった。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　タエは、鉱車を押し出す手ごをした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松公慌てて手を差し出す。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時に」Ｔ「御身たち江戸へ行くのか」　「いかにも」　「そうか、それなら実はな」Ｔ「頼み度い事があるんだ」　と話し出す。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨模樣の空の間から射し出す太陽がいやに蒸暑くてあの單調な路が殊更長く思へた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く丈の詰った影で、街燈が間遠になると鮮かさを増し、片方が幅を利かし出すとひそまってしまう。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを、露草の花が青空や海と共通の色を持っているところから起る一種の錯覚だと快く信じているのであるが、見えない水音の醸し出す魅惑はそれにどこか似通っていた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのづと「書いてゐる奴等」のアラを探しだす。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてＢは、其の場の空気を批判しだす。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しも此の時突然知人の誰かが声を掛けたとしたら、私はニコニコしだすかも知れないし又、愚鈍な瞳で力なく返事するかもしれない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
