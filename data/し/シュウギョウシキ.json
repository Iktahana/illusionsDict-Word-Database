    "definitions": [
      {
        "index": 1,
        "gloss": "ceremony held at the end of a school term",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうせ、あすは終業式だけだから、大目に見てやろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年目の終業式がすんだ日、お家に帰ると政子さんは袴をはいたまま、芳子さんのお部屋に来ました。",
              "citation": {
                "source": "いとこ同志",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、母の知合いの家の男の子の絣の筒袖に鬱金縮みの兵子帯を結んでもらって終業式に出た。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は、例の終業式以来ずっと御無沙汰していた学校へ再び通えるようになった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の終りになって私はまた終業式に出ることになった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもいつも辱しめられる終業式に。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲しきゃお母さんが貰いにくればやるって、そうお言い」　終業式の前頃に、子供達の家からは何かと教師に贈られるのが常だった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二学期の試験が済んで、暮れの二十五日の朝、みゑ子は学校の終業式へ出て行った。",
              "citation": {
                "source": "盗難",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も、ついそれに誘われて、急いで近づいてみると、そこには黒塗の掲示板が二枚かかっており、まだ十分に乾ききれない白堊の毛筆書きで、その一方には、「教諭心得宝鏡方俊、願ニ依リ本職ヲ免ズ」とあり、もう一方には、「明○○日第一学期終業式後宝鏡先生ノ送別式ヲ行ウ」とあった。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　翌日の第一学期終業式の校長の訓辞はごく簡単ですみ、引きつづき宝鏡先生の送別式が行われた。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
