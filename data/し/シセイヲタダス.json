          "literary": [
            {
              "text": "姿勢を正すと、苦痛が一層こたえる。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "御者台から、この有様を眺めていたと見えて、自分が帽子から手を離して、姿勢を正すや否や、人指指を竪に立てた。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一同、姿勢を正す）赤鬼　　（黒鬼に）上等兵は先頭。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると天皇がツカツカ進んでいってその兵の姿勢を正す。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
