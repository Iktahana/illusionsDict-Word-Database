[
  {
    "uuid": "a842343b-b2f3-5427-80b8-2616cb648ff0",
    "entry": "侵入",
    "reading": {
      "primary": "しんにゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "invasion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いくら小人島の蚊でもこんな細かい目を潜って侵入する奴はあるまい。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると鉄の浮いていた小管内の水銀面が下がって弁の細い孔が露出し、ここから瓦斯が侵入して稀薄の度を減じ、管が光り始める。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外来語は山紫水明の古都までも無遠慮に侵入している。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語を欧米の侵入に対して防禦することを私は現代の日本人の課題の一つと考えたい。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "震源の所在を知りたがる世人は、おそらく自分の宅に侵入した盗人を捕えたがると同様な心理状態にあるものと想像される。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがだんだん研究してみると、驚くべし、これは生殖作用を遂げるため、雄の足の一部が子種を運ぶために脱離し、雌の体内に侵入したものだという事がわかった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「無有入於無間」を「個体性のないものは連続的物質中に侵入する」と訳しているが、これは、何となく古典物理学のエーテルを云っているようで面白い。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤丸平家に帰ってからもいたずらに空中に聳える時計台の白い針のみが部屋の窓に侵入して私をいらいらさせた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内に行われていた全ての過去から続く催し物に喪が発せられ、結婚式の美しい半裸体の夜半の女の背中に機関銃の弾で穴だらけになったソビエットの赤い旗が迫って、宣伝隊の装甲自動車が租界内に侵入して宣伝ビラを配付した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は白色人の侵入を徒らに眺めいる帝国なり。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気の流通がよくてしかも雨やあらしの侵入を防ぐという点では、バーベリーのレーンコートよりもずっとすぐれているのではないかという気がする。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが地下電線の被覆鉛管をかじって穴を明けるので、そこから湿気が侵入して絶縁が悪くなり送電の故障を起こすのだそうである。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モナリザの失踪」という映画に、ヒーローの寝ころんで「ナポレオンのイタリア侵入」を読んでいる横顔へ、女がいたずらの光束を送るところがあったようである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの演芸の声だけでなくて演芸者自身がその声にくっついて忽然として自分の家庭に侵入して来るように感じる。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかすると鶺鴒の群がこの辺の縄張を守っていて雀の侵入者を迫害するのではないか。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "塵埃と共に黄燐を含んだ有毒瓦斯は、少年達へと同様に、彼の肺臓へも、どん／＼侵入して来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街は、南軍の侵入と、掠奪、破壊ばかりでない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　彼の友達の中津が、まッさきに、侵入して掠奪した家は、十王殿に、バラバラの空骸となって残っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "命取りの強敵はもう深く体内に侵入しているがそんなことは熊にはわからない。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中六番町の家を引き払おうという二三日ぐらい前の夜半に盗賊がはいって、玄関わきの書生部屋の格子窓を切り破って侵入した。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが雨のあとなどだと、店内の片すみへ川が侵入して来ていて、清冽な鏡川の水がさざ波を立てて流れていた。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "命の親のだいじな消化器の中へ侵入しようとするものを一々戸口で点検し、そうして少しでもうさん臭いものは、即座にかぎつけて拒絶するのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　侵入者　郊外の田舎にわずかな地面を求めて、休日ごとにいい空気を吸って頭を養うための隠れ家を作った。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれとも知れぬ侵入者は驚くべき鋭敏な感覚で、宝捜しでもするような気で捜し出すと見えて、ほとんど残りなしに抜き取ってしまうのである。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがおもしろい事にはこれらの侵入者が手をつけないで見のがす幾種類かの草花がある事を発見した。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはこの三つの植物の繁殖力の旺盛な事に関する侵入者の知識がこの現象の原因になるかと思ってみたが、それもあまりに付会に過ぎた説明としか思われない。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かまわず打っちゃっておくとおしまいには家の内までも侵入しそうな勢いを示して来る。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は賞をもらったが、後者は家宅侵入罪その他で告発されるという話である。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓の道を横に辿ってその幅によりこれは只事でないと感じ取った翁の胸には、福慈岳の高さに就ても、その心積もりに相当しんにゅうをかけたものを用意していた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男は癩病患者ででもあったのでしょうか」「いやそれにしんにゅうをかけたようなものさ」とフランボーが云った。",
              "citation": {
                "source": "作男・ゴーの名誉",
                "author": "THE HONOUR OF ISRAEL GOW",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
