          "literary": [
            {
              "text": "シ※ークスピヤか、然らずんば際物かといつた調子である。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば……　などと、いや何うも氣恥かしいが、其處で倒れまいと、一生懸命に推敲した。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば――苦しいから、繰返して、汝炎威と戰へ。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王、斉泰と黄子澄との斥けらるゝを聞き、書を上りて、呉傑、盛庸、平安の衆を召還せられんことを乞い、然らずんば兵を釈く能わざるを言う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣営は厳密、まさに周亜父細柳の如くなるべし、然らずんば敵の猛將の奇襲突破するところとならん。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くして彼等の齎し来る所謂新学説とは何ぞ、曰く無意義、然らずんば無用、たゞこれのみ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば吾人民友子に対する誤解の生ぜんことを危ぶむなり。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば不謹慎な冷笑であつた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば生育せず』とて、杖にせる櫻の枝を植ゑ立てしに、盛んに生育したりとの事也。",
              "citation": {
                "source": "白河の關",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "死か然らずんば前進、唯この二つの外に路が無い。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "行先は死、然らずんば戰鬪。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "行先は死、然らずんば戦闘。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺の如きは、神経｜未熟の野人か、然らずんば己れを偽はる愚者としか代助には受け取れないのである。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば拙訳の致す処であらう。",
              "citation": {
                "source": "翻訳製造株式会社",
                "author": "戸川秋骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば奸臣｜朝に満ち、乾綱紐を解き、内憂外患｜交至り、彼衰亡の幕府と択ぶなきに至らむ。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば、東坡の詩、既に紅と曰へり、又た翠と曰ふ可ならんや」。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地語か然らずんば筆を折るべしという一派の言説の如きは余りにも言語道断である」そこで急に卓を叩いて立ち上った。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば、人間の腹より出でたる犬豕を生ずること必定なり。",
              "citation": {
                "source": "家庭習慣の教えを論ず",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "速に汝の得たる金を差出せ、然らずんば我等は暴力を以って汝に臨まん。",
              "citation": {
                "source": "急行十三時間",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば何の尊ぶ可きことか之れ有らん。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草は何よりも病気にさわるというので、医者は禁煙か然らずんば節煙を命じ、家人たちもそれを懇望し、本人もその決心をした。",
              "citation": {
                "source": "条件反射",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "全てか、然らずんば無か、私のこうした極端な気持が一度、共産党と喧嘩すると、今度は淫売婦のふところに飛びこませた。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば言論の自由を与えよ。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ロボットは、御意のままか、然らずんば、破壊か、だ。",
              "citation": {
                "source": "ロボットとベッドの重量",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば我等に死を与えよ』と云うのですからね。",
              "citation": {
                "source": "不思議な島",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡はただ前後左右に、木馬が跳ねたり、馬車が躍ったり、然らずんば喇叭がぶかぶかいったり、太鼓がどんどん鳴っているだけなんだ。",
              "citation": {
                "source": "一夕話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば、予が一生の汚辱を披瀝せんとする此遺書の如きも、結局無用の故紙たると何の選ぶ所か是あらん。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺の如きは、神経未熟の野人か、然らずんば己れを偽わる愚者としか代助には受け取れないのである。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいわゆるずっとというのは軍鶏なんじゃろ、しからずんば鰻か。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百合、晃の手に取縋ると、縋られた手を震わしながら、し、しからずんば決闘せい。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
