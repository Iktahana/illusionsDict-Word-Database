[
  {
    "uuid": "0bf854c0-855f-52ae-9f27-48f2e5ec9939",
    "entry": "消失",
    "reading": {
      "primary": "しょうしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
