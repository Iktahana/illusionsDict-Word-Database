        "examples": {
          "standard": [
            {
              "text": "信越本線は、群馬県から長野県を経て新潟県までを結ぶ重要な路線だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏休みには、信越本線に乗って実家のある長野まで帰省する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かつて信越本線は、日本海側と内陸部を結ぶ大動脈として栄えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "更埴から上田まで、信越本線ぞいに、国道18号。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
