[
  {
    "uuid": "8810ec7c-deab-596c-98d7-b4d15349ef0e",
    "entry": "周回",
    "reading": {
      "primary": "しゅうかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going around",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "午前八時岡山練兵場出発――Ｆ飛行士は、彼は昔、自転車周回競争の選手だった。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッキントッシュは淀み、ＭＳ―ＤＯＳは周回遅れでたらたらとマックを追いかけ、ＵＮＩＸの土俵ではＯＰＥＮ　ＬＯＯＫとＭｏｔｉｆ（共にＵＮＩＸをマックに化けさせる厚化粧の流儀）が水入りの勝負を続けている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中最大の木の随一でその幹至って低いが周回七十｜乃至九十フィートのものなり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "周回三里ばかりの噴火口を控えたり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより東に奉天城があり、城は辺城と内城とに分れて、辺城は高さ七尺、周回一万六千米突の土壁を以て内城を囲み、内城と辺城との間にある四方の広大な支那市街は東西南北の各大街に沢山の胡同（横町）が属してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "時たま彼らの周回曲線が、猛烈な勢ひで、彼女たちの円陣の外周をこすつて過ぎることもある。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "室を一周回取巻いても未だ余ってる。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、周回七十何里という琵琶湖の水はたとい五月雨が何日降り続こうとも、どれだけ増したということは、そう的確に目に見えるものではない。",
              "citation": {
                "source": "俳句の作りよう",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "【櫻島の各部落】　島は略々圓形を爲し、周回九里三十一町、東西櫻島の兩村あり、西櫻島村には赤水、横山、小池、赤生原、武、藤野、松浦、西道、二俣、白濱の十大字あり、東櫻島村には野尻、湯之、古里、有、脇、瀬戸、黒神、高免の八大字あり、大正二年度に於て戸數三千百三十五戸、人口二萬一千九百六十六人を有せり。",
              "citation": {
                "source": "櫻島噴火の概況",
                "author": "石川成章",
                "note": "青空文庫"
              }
            },
            {
              "text": "じきに周回し始めるだろう。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "周回を始めるがいい。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロープの傾きからは、周回しているとは思えなかった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると、魚は鉤素を叩くのをやめ、再びゆっくりと周回を始めた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚には勝手に周回させておき、ロープを引くこともなしに、舳先で休んでいたい。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回の周回で、老人は初めて魚の目を見た。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の周回で、魚は水面から背を出した。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次の周回でもまだ遠かったが、魚の位置はより高くなっていた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしすぐ持ち直し、また周回を始める。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうえ何度も周回されたら耐えられない。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しっかりしろ」　さらに二度、周回のたびに同じことが起きた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
