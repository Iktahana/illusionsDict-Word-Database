    "definitions": [
      {
        "index": 1,
        "gloss": "historical drama",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "団十郎の重盛は毀誉相半ばしたるが、いわゆる「活歴」なる史劇の新形式は、この頃よりおいおいに芽を噴きたるなり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七月十六日、東京府民有志の発企にて、来朝中の米国前大統領グラント氏を新富座に招待し、新作の史劇「後三年奥州軍記」と芸妓の手踊を演ず。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十月、明治座にて松居松葉の史劇「悪源太」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会の懸賞募集脚本に、長谷川時雨女史の史劇「花王丸」当選して、一番目に上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この伏見の地震は、河竹黙阿弥の地震加藤の史劇で有名な地震で、石田三成等の纔者のために斥けられて蟄居していた加藤清正は、地震と見るや足軽を伴れて伏見城にかけつけ、城の内外の警衛に当ったので、秀吉の勘気も解けたのであった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早稲田文学」の史劇論其の第一なり。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「読売」の高田半峰氏発起して歴史脚本を募れるは、「早稲田」の史劇論に続て、劇詩界の高潮を報ずる者なれ。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二番目の、「史劇北山風雲録」といふのになると、今度は言葉がさつぱり分らない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二番目の、「史劇北山風雲録」というのになると、今度は言葉がさっぱり分らない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "史劇――新しい史劇といふ以外には、さほど重きを置くに足りる作ではないと私は思つてゐる。",
              "citation": {
                "source": "社会と自己",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲劇、喜劇、史劇、抒情詩、叙事詩、牧歌、悲歌……その他その他が、それぞれ形式的にきちんと区分されていたのである。",
              "citation": {
                "source": "『心理試験』を読む",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが脚本というものに筆を染めた処女作は「紫宸殿」という一幕物で、頼政の鵺退治を主題にした史劇であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして明治三十二年の秋に、明治座で史劇「悪源太」を上場することになった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回は歌舞伎座で開かれて、わたしが第一の史劇「天目山」二幕を書いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが好評で、紫紅君は明くる三十九年の秋に『七つ桔梗』という史劇集を公けにした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若葉会は更に東京毎日新聞社演劇会と変って、同じ年の十二月、明治座で第一回を開演することになったので、私は史劇「新羅三郎」二幕を書いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、これらはいずれも一種の素人芝居に過ぎないので、普通の劇場とは没交渉のものであったが、それでもたび重なるに連れて、いわゆる素人の書いた演劇というものが玄人の眼にも、だんだんに泌みて来たと見えて、その年の十二月、紫紅君は新派の河合武雄君に頼まれて史劇「みだれ笹」一幕（市村座）を書いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岸荷葉君もこの年、小団次君らのために「ハムレット」の翻訳史劇（明治座）を書いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌四十一年の正月、左団次君が洋行帰りの第一回興行を明治座で開演して、松葉君が史劇「袈裟と盛遠」二幕を書いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の七月、かの川上音二郎君が私をたずねて来て、新たに革新興行の旗揚げをするに就いて、維新当時の史劇を書いてくれと云った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果として先ず現われたのは河竹黙阿弥作の史劇「二代源氏誉身換」で、仲光の身がわりを脚色したら好かろうという原案は、求古会員から提出されたらしかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "学海居士は川尻宝岑と合作で、そのほかにも「吉野拾遺名歌誉」「豊臣太閤裂封冊」「拾遺後日連枝楠」などの史劇を公けにして、その時代においては議論の方面にも、実行の方面にも、演劇改良の急先鋒であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この史劇はもとよりこの一座のために特に書き卸されたものではなく、やはり在来の歌舞伎俳優に当てはめて書かれたものを採用したのであるから、竹本浄瑠璃を使っている場面が幾カ所もある。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「千本桜」については別に言うこともないが、第一に据えられた「泉三郎」三幕は宮崎三昧の新作史劇で、河竹新七校と記されてあった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "史劇は鎧や太刀に金が掛かるから、なるべくは維新当時あたりの世界を択んで貰いたいと、かれは三十分あまりもひと息に弁じた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが一幕物の史劇をかいて『文芸倶楽部』の編集者に見せると、その編集者はそれまで私の小説や小品のたぐいを幾たびか掲載してくれたにもかかわらず、脚本ではどうも困るからこれを小説体に書き直してくれないかと言った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薄ぼんやりした眼をこすらせたのは、松居松葉君の史劇「悪源太」が明治座で上演されたことである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この成績がよかったので、越えて三十四年の十月、明治座では再び松居君の史劇「源三位」を上場した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちエリザベス（エドワード四世の妃）が幽閉中の二王子に逢いに来る場と、二王子を殺した刺客の述懐の場は沙翁の歴史劇リチャード三世のうちにもある。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
