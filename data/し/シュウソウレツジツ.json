        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実に秋霜烈日の如き威光であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し仏法臭を帯びては居るが、秋霜烈日の如き遺言である。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "行けい」　秋霜烈日とした声だった。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は却つて一段の秋霜烈日の嚴を増したのではないかと思つた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は却つて一段秋霜烈日の厳を増したのではないかと思つた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴君の一令、秋霜烈日の如し。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろその秋霜烈日の命令が立ちどころに履行されてゆく爽快味を満喫してゐると言つた方が、当つてゐるかもしれない。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "血迷ったか丹波、突然その釣瓶落しを振りかぶるが早いか、それこそ、秋の日ならぬ秋の霜、秋霜烈日のいきおいで、大上段に斬りつけたのです。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにその厳として秋霜烈日的なる人格は深く畏敬せられ、自ずと衆人に襟を正さしむるものがあった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、その大塔ノ宮が一山の僧兵を指揮する秋霜烈日ぶりや、ご自身も朝夕に、太刀｜薙刀の猛訓練に一心不乱なお姿には、皆こういって舌をまいた。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
