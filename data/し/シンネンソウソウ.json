        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新年早々から人間と牛との闘いだ。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに新年早々はどこの店でも門松を立て、国旗をかかげ、回礼者の往来もしげく、鉄道馬車は満員の客を乗せて走る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年早々であるから、碌々に会葬者もあるまいと予期していたが、それでも近所の人々その他を合わせて五、六十人が送ってくれた。",
              "citation": {
                "source": "正月の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「葬式に好い時節というのはないが、新年早々は何ともいいようがない。",
              "citation": {
                "source": "正月の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごめん下さい『先生――ごめん下さい、新年早々から。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらを歩いてＨさんの店に寄る、不在、新年早々借金しないでかへつてよかつた、やれ／＼。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年早々数十件の損害要償の訴訟が起つて、水でいたんだ晴着の代を出させられたからである。",
              "citation": {
                "source": "防火栓",
                "author": "DAS GROBE VERGNUGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年早々東京では旧幕府の諸学校を再興されて、漢学専門の昌平塾を昌平学校と称してそれに国学を併せて教授する校舎が出来た。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年早々、ろくでもない言葉を吐いた。",
              "citation": {
                "source": "井の中の正月の感想",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅君は新年早々入営することになつてをり、その晩は、立命館の先生福本君、山本君、四人集り、三宅君の壮行を祝して越年の酒宴をひらく筈であつた。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年早々屠牛を見に行くとは、随分｜物数寄な話だとは思ったが、しかし私の遊意は勃々として制え難いものがあった。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、新年早々、殺生するのはいやだといったら、勇ちゃんもゆくのをよして、二人で、ボールを投げて遊んだ。",
              "citation": {
                "source": "ある少年の正月の日記",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年早々黄金饅頭を撒き込んでくれるなんざ、ふだん女郎の尻を撫でてるだけのことアある。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年早々筆を手にする余裕もなかったのである。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど」「それよりも新年早々お始めの方がよろしいではなかろうかと存じられます」「なるほど」「矢島君のおっしゃるとおり、さしあたりはご自由におまかせ申しあげて、新年からおたがいに努力する方が策の得たものかと私も存じます」　と有本さんが賛成した。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "註文が千差万別だから、新年早々一仕事のようだ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお新年早々お殿様のお目にかかったとき、特別にありがたいお言葉を頂戴した。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年早々の不勉強で、まるでセリフが入ってゐないのだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年早々、お詫びするわけ。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
