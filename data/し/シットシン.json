[
  {
    "uuid": "dbc7c03e-6d53-5ba9-aaf4-515fe6d390e4",
    "entry": "嫉妬心",
    "reading": {
      "primary": "しっとしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
