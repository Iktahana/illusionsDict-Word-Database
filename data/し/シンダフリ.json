        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "笠井さんは、このまま死んだふりをしていたかった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより私は、東京を離れた瞬間から、死んだふりをしているのである。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時は、あわてて死んだふりなどしてみたが、すべていけないのである。",
              "citation": {
                "source": "一日の労苦",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、兵太郎君はいぜんから、死んだふりや、腹のいたむまねが、ひじょうにうまかったからである。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは仕様がないので、舞台の上に身を横え、死んだふりなどして見せた。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八になって、向島の待合の下女をつとめ、そこの常客である新派の爺さん役者をだまそうとして、かえってだまされ、恥ずかしさのあまり、ナフタリンを食べて、死んだふりをして見せた。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフトウエアによる日本語が現実的でなかったこれまでを、ＭＳ―ＤＯＳマシンは独自の努力で、マッキントッシュは死んだふりでそれぞれ乗り切った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなとこで死んだふりしてないで、どんどん続きをやりなさい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語化という、どう考えてみても死んだふりをするのが賢明そうな難物にも、手が付かないままだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合に、死んだふりをするということはだれでも知っている。",
              "citation": {
                "source": "くまと車掌",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に狸が死んだふりをして落ちてくるから、そうしたら、縄で縛り上げるがよい」　しばらくして老人は、南天の杖をふり上げて、非常に大きな声で叫びました。",
              "citation": {
                "source": "狸のお祭り",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十日の浅草｜本所深川などのやられたやうなことが戦争の始めにあれば、しめた、といふので、死んだふりをしたり、無籍者になつたり、年齢をごまかしたり、余は丁種でござる、といふやうなことを申立てゝ、なんと云つたつて区役所から何から何まで焼けたり死んだりしてゐるのだからビク／＼することはない。",
              "citation": {
                "source": "わが戦争に対処せる工夫の数々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "野村が生きてゐれば抱き起しにきてくれると思つたので死んだふりをしてゐたら、案の定、抱き起して、接吻して、くすぐりはじめたので、私達は抱き合つて笑ひながら転げまはつた。",
              "citation": {
                "source": "続戦争と一人の女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから、袋のひもを長くのばして、そのはしをつかんだままじぶんはこちらに長ながとねころんで、死んだふりをしていました。",
              "citation": {
                "source": "猫吉親方",
                "author": "またの名　長ぐつをはいた猫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあの怪物は、死んだふりをしていたのだろうか」「そこがわからないのだ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱山の底で死んだふりをしていた。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては、死んだふりをしていたな。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは自分をこの城内に連れ出して、恋を打ち明ける目的のために、わざと死んだふりをしているのではないかとも思いました。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんないたずらをする子供らが木の葉や草を集めて運んでくる間でも、上人は死んだふりをして、静かに道ばたに横になりながら、子供らのすることを楽しんでいたというからおどろきますね。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうして、死んだふりをしていよう。",
              "citation": {
                "source": "僕がかわいがるから",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして少しも動かないで死んだふりをしてゐる。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるぎつねは、腰かけ台の下へ大の字なりになって、ぴくりとも動かず、まるでぶち殺された鼠のように、死んだふりをしていたのです。",
              "citation": {
                "source": "おくさま狐の御婚礼",
                "author": "ヤーコップ、ウィルヘルム・グリム　Jacob u. Wilhelm Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで清正が脇差をぬいて皺くちやな頸をごしごし斬るまねをするのを四王天が顔をしかめてこらへながら目をつぶつてぐにやりと死んだふりをすればひと先づ勝負がつくことにきめてあつたが、雨の日などには七八遍もおんなじことをくりかへして、しまひに四王天がひよろひよろになるまでやらせた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は死んだふりをしてるんだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
