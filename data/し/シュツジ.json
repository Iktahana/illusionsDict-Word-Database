        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "立派な出自と教育のある男だが、競馬で一財産すってしまい、今ではロンドンのあちこちにある遊興倶楽部で、うちうち上流相手の賭け事の胴元をやって暮らしている。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おタマはお芳の高貴さを武家出の母親の出自に由来するものと見たが、その出自こそが不運であると思っている。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に挙げた京水出自の事の如きは其一である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その主なるものは錦橋の年齢、其廃嫡子京水の出自等である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出自、その入門等は既に記した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターでは、技術情報を徹底的に公開する文化的な流儀がその後大きな役割を演じることになるが、その出自をたどるうえで、初めてのＭＩＴＳの紹介記事は着目すべき指標の一つであると思われる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷めかけた心は、完成品のパーソナルコンピューターを支える技術の出自をたどることで、いっそう熱を失っていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那から殖民したものゝ子孫だといふ風に、沖縄びとの出自を空想してゐたことが久しかつた。",
              "citation": {
                "source": "沖縄を憶ふ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを「呪師走の翁」と呼び馴れたのは、出自の呪師芸能なることを示すもので、四座其他の猿楽側で言ひのこした語なのであらう。",
              "citation": {
                "source": "薪能と呪師走の翁",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、此を直に、花祭りの出自を延年舞だと引き出す企てだと思はれては困ります。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、謡曲の弱法師といふ表題は、此物語の出自を暗示してゐるもので、同時に日本の歌舞演劇史の上に、高安長者伝説が投げてくれる薄明りの尊さを見せてゐると考へます。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中の神に丹生神の多いのは、必しも、其出自が一処の丹生といふ地に在つた為と言はれぬとすれば、此を逆に、山中の丹生なる地が神降臨の場所であつた、とも言ひ得られる。",
              "citation": {
                "source": "稲むらの蔭にて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊野念仏譚は、出雲出自のものもある。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "小枝・小萩・中将・少将・桂姫・初花・安寿・きく丸などの出自。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は古代皇妃の出自が水界に在って、水神の女であることならびに、その聖職が、天子即位｜甦生を意味する禊ぎの奉仕にあったことを中心として、この長論を完了しようとしているのである。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷に用ゐられた外居が、行器とおなじ出自を持つて居るものとすれば、何時の頃どう言ふ手順で入り込んだか、すべては未詳である。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中臣女と汎称した下級巫女の上に、発達して来たものと推定の出来る中臣志斐連の職業は茲に出自があるものと思ふ。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした大歌も、必しもすべて宮廷出自の物に限つて居なかつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵冒頭の語句を以て名としたふりと称するものは、他氏・他領出自の歌であつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　天語と卜部祭文との繋り名は神語・天語歌と区別してゐるが、此二つは、出自は一つで、様式も相通じたものである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても「曲舞」の寺出自なるに対して、多くは社及び神宮寺を仰いだ一流である様である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "此外、種々の芸人皆、寺奴・社奴出自でないものはない。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "其等ほかひ人と童子との外に、今一つ声聞身出自の一流派に属する団体がある。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏の両大派の開祖の種姓は伝説化してゐるが、高貴の出自を信じることは出来ない。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "此とおなじことが、もつと有力に、さかいの出自なる上方にも起つて居たことは、考へておいてよい。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "語部古く見れば、宣詞その物が、主神自身の「出自｜明し」であり、対象たる精霊の種姓を暴露すると謂つた、内容を持つてゐたものなのだ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は古代皇妃の出自が水界に在つて、水神の女である事並びに、其聖職が、天子即位甦生を意味する禊ぎの奉仕にあつた事を中心として、此長論を完了しようとしてゐるのである。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぢまもりの場合は、其出自が漢種であり、現實性が多い書き方の爲に、如何にも橘を齎した國が南方支那の樣に見える。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ後世の人々が、一般に彼らの俘囚たることを信ずるを難んずるゆえんなれども、つらつら思うに、ひとり則清と継信と忠信とのみならず、堂々たる武士の中にも、これと出自を同じうするもの少からず存し、しかして当時においては、もはや彼らを夷族としては認めざりしものにてもあるべし。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはやほっこくもさくらのはながちり春のなごりのおしまれる季せつでござりまして、おこしいれのゝちはじめての御しゅつじんでござりましたから、うちあわび、かちぐり、こんぶなど、おくがたはことにこゝろをこめておさかなの御用意をあそばし、御｜主殿においてかどでをおいわいなされました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
