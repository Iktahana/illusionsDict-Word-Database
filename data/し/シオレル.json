    "definitions": [
      {
        "index": 1,
        "gloss": "to wither",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上方一と言われた女も、手活の花として眺めると、三日｜経てば萎れる。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど入院したてには燃えるように枝を飾っていたその葉が一枚も残らず散りつくして、花壇の菊も霜に傷められて、萎れる時でもないのに萎れていた。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の姓名を非常に嫌ふといふ奇癖の持主で、うつかりその名を呼ばれると時と場所の差別もなく真赤になつて、あはや泣き出しさうに萎れるのであつた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな喧嘩をしては帰るわけにもゆくまいね……」　俺が久良の上を案ずると、太吉も久良も俺が町から戻るまでは、到底二人で夜を共にすることは適はぬと萎れるだけだつた。",
              "citation": {
                "source": "木枯の吹くころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の姓名を非常に嫌うという奇癖の持主で、うっかりその名を呼ばれると時と場所の差別もなく真赤になって、あわや泣き出しそうに萎れるのであった。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからと云うものは、塞ぐのでもなく萎れるのでもなく、唯何となく沈んでしまッて、母親が再び談話の墜緒を紹うと試みても相手にもならず、どうも乙な塩梅であったが、シカシ上野公園に来着いた頃にはまた口をきき出して、また旧のお勢に立戻ッた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "持って生れて来ただけの生命の芽は内部から外部へ押出そうとはしても、まだまだ世間見ずの捨吉の胸はあたかも強烈な日光に萎れる若葉のように、現実のはげしさに打ち震えた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "草木のことを言へば、福寿草を小鉢に植ゑて床の間に置いたところが、蕾の黄ばんで来る頃から寒さが強くなつて、暖い日は起き、寒い日は倒れ萎れる有様である。",
              "citation": {
                "source": "路傍の雑草",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなしらを切るな」　男は文吉の顔を見て、草葉が霜に萎れるように、がくりと首を低れた。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしは生きようと思います」と云う、猛烈な叫声を、今日の大向うを占めている、数多の学生連に喝采せられながら、萎れる前に、吸い取られる限の日光を吸い取ろうとしている花のようなヴィルトン夫人に連れられて、南国をさして雪中を立とうとする、銀の鈴の附いた橇に乗りに行く。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼は萎れる花のようにうなだれる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見には植物に限らず、一国の文化を推進せしめるものは外国文化の影響刺戟に因るものであるという信念がいつからか萌していてさして発育もしなかったが、根は抜けずに、そのままになっていて、萎れるということもなく持ちこたえている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬は刀をとってその前に坐り、「まだお寝みにはなりませんでしたか」「お前様のお帰りを待っておりました」「それほどに御執心ゆえ、よいお返事を聞かせてお上げ申したいが……」　兵馬の言葉が濁って、その様子が萎れるのを見たお君の面色に不安があります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "草木のことを言えば、福寿草を小鉢に植えて床の間に置いたところが、蕾の黄ばんで来る頃から寒さが強くなって、暖い日は起き、寒い日は倒れ萎れる有様である。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、この「ふるえ草」は、萎れることがない。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物は春、樹木の若芽が出ると好んで食べ、また汁の多い草も食べますが、夏になつて草木が生長すると穀物やそば等を食べ、寒くなつて木の葉や草が萎れると森林内でぶな、かし、くりの木の實を食べたりします。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            },
            {
              "text": "……温室の草花は外の寒い風に當てると、直きに萎れるんですかね。",
              "citation": {
                "source": "見學",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "悄然として萎れる雨中の梨花には、ただ憐れな感じがする。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、お榮はその唐突さに氣のついた樣子もなく、「良い方でした、――氣の毒なことに――」　と萎れるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凉み船",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに困つたことで」　と打ち萎れるだけのことです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美女罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には義理の妹、詩人でピアニストで、夕顔の花のように淋しく美しかった幽香子は、昨日の午後、私と愛子が丁度淡路島で楽譜の暗号を解いて居た頃、その夕顔の花が日に当って萎れるように果敢なく目を瞑ってしまったのだそうです。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人のお米さんはそれが気に入らなくて、お咲さんをただコキ使った上、番頭さんの給金まで減らした、食い扶持を差引くつもりだったのだね」「…………」「返事がなければ、そう思って差支えはあるまい」　和助の萎れる姿を見て、平次は立上がります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二本の脇差",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お前は助けてやる、逃げ隱れしちやならねえよ、宜いか」「ハイ」　品吉の打ち萎れるのを見て、平次は斯う言ひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花嫁の幻想",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私はもう途方に暮れてしまひましたよ、親分」　お春はさう言つて、痛々しいほど萎れるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "晒し場は招く",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにこの世の人の仕業に習つてか、その物を償わない」と言つて、その兄の子を恨んで、イヅシ河の河島の節のある竹を取つて、大きな目の荒い籠を作り、その河の石を取つて、鹽にまぜて竹の葉に包んで、詛言を言つて、「この竹の葉の青いように、この竹の葉の萎れるように、青くなつて萎れよ。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぞほかに新しい花を召しますのなら、どうか名を仰有つて下さいまし、女の胸の上、戀人の床の上に萎れる花の名はみんな存じてをりますから。",
              "citation": {
                "source": "わるい花",
                "author": "レミ・ドゥ・グルモン　Remy de Gourmont",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（医師しおれる）農民四、五、六　登場農民四「じゃ、この野郎、山師たがりだじゃぃ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待（いよいよしおれる）農民一（気の毒になる）「じゃ、あんまりそう言うなじゃ、人の医者だて治るごともあれば、療治｜後れれば死ぬごともあるだ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "八蔵は泰助に恨あれば、その頭蓋骨は砕かれけん髪の毛に黒血｜凝りつきて、頬より胸に鮮血迸り眼を塞ぎ歯を切り、二目とは見られぬ様にて、死しおれるにもかかわらず。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、そこいらの川の中の島にはえているたけを伐って来て、それで目の荒いあらかごを作り、その中へ、川の石に塩をふりかけて、それをたけの葉につつんだのを入れて、「この兄の神のようなうそつきは、このたけの葉がしおれるようにしおれてしまえ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
