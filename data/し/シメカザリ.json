    "definitions": [
      {
        "index": 1,
        "gloss": "decorating shrines and gates with shimenawa ropes for the New Year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "普通は、正月のしめ飾りのとれた時分から十四日まで鳥小屋にいて、「とんど」「どんど」などというてしめ飾りを焼く式をする。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "門松しめ飾り、松の内の八百屋町をぱったり人通りが杜絶えて、牡丹雪が音も立てずに降っている。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「梅と松とや若竹の手に手引かれてしめ飾り」という端歌の文句もあります。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幸、益※お正月号のしめ飾りではない存在だから今月は、これまでのものに手を入れたりする暇もあり、そういう暇をもつ意義を十分にあらしめたい心持です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "山へ行つて、松と裏白とを採つてきて、松飾をこしらえる、うらじろ、しめかざりといふものはよろしいかな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて正月十三日十四日のうちに門松しめかざりを取り払ひ、我国長岡あたりにては正月七日にかざりをとり、けづりかけを十四日までかくる餅花を作り、大神宮歳徳の神｜夷おの／＼餅花一｜枝づゝ神棚へさゝぐ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
