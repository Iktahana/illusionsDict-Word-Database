[
  {
    "uuid": "643f6ad5-fe4a-58ab-a799-dc094da52471",
    "entry": "宿舎",
    "reading": {
      "primary": "しゅくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lodging (house)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今は雑使婦か何かの宿舎になっているらしい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこのみちばたの青いいろの寄宿舎はゆっくりして爽かでよかったが。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、物理学教科書にある方則と寄宿舎の規則との区別を自覚している生徒がどれだけあるか疑わしい。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の話しぶりはきわめて卒直であるものの今宵初めてこの宿舎で出合って、何かの口緒から、二口三口｜襖越しの話があって、あまりのさびしさに六番の客から押しかけて来て、名刺の交換が済むや、酒を命じ、談話に実が入って来るや、いつしか丁寧な言葉とぞんざいな言葉とを半混ぜに使うようになったものに違いない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この某町から我村落まで七里、もし車道をゆけば十三里の大迂廻になるので我々は中学校の寄宿舎から村落に帰る時、決して車に乗らず、夏と冬の定期休業ごとに必ず、この七里の途を草鞋がけで歩いたものである。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "七里の途はただ山ばかり、坂あり、谷あり、渓流あり、淵あり、滝あり、村落あり、児童あり、林あり、森あり、寄宿舎の門を朝早く出て日の暮に家に着くまでの間、自分はこれらの形、色、光、趣きを如何いう風に画いたら、自分の心を夢のように鎖ざしている謎を解くことが出来るかと、それのみに心を奪られて歩いた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが、二棟の寄宿舎に閉じこめられてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は宿舎の方へ進んだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄宿舎の方で涙ぐんで淋しげに黙っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二棟の寄宿舎は、険悪なけしきに満ちた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿舎からは、工人の金属的な、激昂した声が、やかましく事務所の方へもれて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マッチ工場の寄宿舎から、工人を他の一棟へ追いやって、そこの高粱稈のアンペラに毛布を拡げ、背嚢か、携帯天幕の巻いたやつを枕にして、横たわった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、マッチを箱に詰めるところや、職工の寄宿舎には、婦人もいるんだから、用事のないのに、そこへむやみに出入りしてはいけない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七　軍隊は、工場の寄宿舎の一と棟に泊まっただけだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士たちは、くた／＼になって宿舎へかえった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄宿舎は狭くなった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁のざらざらした、屋根がひくい、息づまる寄宿舎で、彼等は思い／＼の考えにふけった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓のない、支那風の暗い寄宿舎には、男ばかりのくさい息がこもった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿舎はいつも暗かった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは、一度兵士達が見つけて以来、勤務について、寄宿舎にいなくなった留守を見はからって敢行された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、大根ナマスのように、白楊の素地が軸刻機にきざまれて軸木の山が出来て行く、刻作業部を通りぬけて、用材置場から、薄暗い兵士のいない宿舎をちょっとのぞいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工人の大蒜や葱の匂いと、兵士の汗と革具の匂いが交錯して、寄宿舎の厚い重たい壁についているようだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い寄宿舎で、彼等は、それを読んだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まもなく、寄宿舎と工場内に大騒動が起った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、子供らしい笑いが洞窟のような宿舎に響き渡る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、人々は、Ｓ銀行の宿舎へ、移れという命令をうけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿舎の二百人ばかりのつわものが、同時に、息の根をとめられ、うーッと唸って、現で立ちあがった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "交代した歩哨は、寝不足と夜露で蒼くなって、宿舎へ這入ってきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫びながら、寄宿舎から逃げるように駆け出してしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……実際居留民の保護だけなら、何故、こんな不便な、きたないマッチ工場の南京虫がうようよしている寄宿舎に入れて置くかね？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
