    "definitions": [
      {
        "index": 1,
        "gloss": "number of births (including stillbirths)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
