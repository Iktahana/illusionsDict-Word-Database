    "definitions": [
      {
        "index": 1,
        "gloss": "something painted white",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "客車の中は白塗りのがらんどうで、ただ片側の壁に幅の狭い棚のような腰掛があるだけである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "温室の白塗りがキラキラするようでその前に二三人ふところ手をして窓から中をのぞく人影が見えるばかり、噴水も出ていぬ。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」警部を先頭に我々は進み、閂付きの扉を開けて、曲がりくねった階段を下り、白塗りの廊下へ出てきた。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "その堀と堀の間には、たくましいクレーンの群が黒々と聳え立って、その下に押し潰されそうな白塗りの船員宿泊所が立っている。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "花見の場で酔っ払っているような奴は、大抵お腰元なんぞに嫌われる敵役で、白塗りの色男はみんな素面ですよ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "最新式のマルコニー・スループ型で、全長約二十｜呎、檣柱も船体も全部白塗りのスマートな三人乗りだ。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査だって何もぼんやり立ってるんじゃなくて、白塗りの棍棒を振り廻しながら盛んに無辜の歩行者を白眼みつけたり、その余暇に、前を走る自動車にとても忙しそうにやたらに挨拶してる。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院は松林に囲まれて小高い丘の上の清楚な白塗りの建物です。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白塗りの大きな西洋造りである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡の中には、二階へ上る楷子段の側面を始として、向うの壁、白塗りの扉、壁にかけた音楽会の広告なぞが、舞台面の一部でも見るように、はっきりと寒く映っている。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央の平地に上図通りの配列で並んでいるのが、失楽園の全部であって、四棟ともいずれも白塗りの木造平屋で、外観はありきたりの、病棟と少しも異なっていなかった。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引替え、三万円の貯金と、バラックながら二軒の家持ちの桂子、私は子供の頃、ひとから（おまんこ倉）と綽名される、美貌の未亡人の白塗りの倉を持った家が近くにあったのを思いだす。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくの乗せて頂いたのも、華奢な白塗りのリンカン・ジェフアで、車内に、ラジオも、シガレット・ライタアも装備してある豪勢さでした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "大門を這入ると、半丁ばかりは樹木は繁茂致して、昼さえ暗く、突当りに中門がございまするが、白塗りにて竜宮の様な妙な形の中門で、右の方はお台所から庫裏に繋っており、正面は本堂で、曹洞派の禅林で、安国山総寧寺と云っては名高い禅寺でございます。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "左端のニンフの顔も白塗りにより、右手も白く消された。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼女は、非常な手練と速さを持って、さっき白塗りにした上に、別の画を描いていった。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁は白塗りであつたが、割れ目や、激しく拳固で撲りつけたらしい跡があつた。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この看板屋が又、絵心があるといふのか、袋小路のどん底の傾いて化け物の現れさうな碁席であつたが、白塗りに赤字でぬき、華車な書体で、美術倶楽部と間違へさうな看板だつた。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでまず第一に訊きたいのは、今から丁度一年ほど前に、この沖に着いた白塗りの外国船があった筈ですが、そのときこの村の衆のうちで、雇われて沖の本船まで行った人は誰と誰とだろうね」「まあ、そんなことをよくご存じなのですねえ」とお美代は目をパチクリしながら、「それは三人でしたわ。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白塗りの救急車で、押しかけて搬びこんだのが外ならぬヒルミ夫人の外科病院だった。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、纏屋次郎左衛門から、六十四組の町火消しに供給した的と謂はゞ言はるべき、形の上の要素を多く具へた、馬簾つき、白塗り多面体の印をつけた、新しい物を考へに置いてかゝる事だけは、控へねばならぬ。",
              "citation": {
                "source": "まといの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして銀箔地へ家々の定紋を書いてばれんをつけたまといが、今の白塗りの物となつたのは、寛政三年から後の事で、享保四年大岡越前守等の立案で、町火消六十四組を定めて、一本宛のまといを用ゐる事を許したのが、此迄武士の手を離れなかつた此軍器が駈付け人足の手に移つた始めである。",
              "citation": {
                "source": "まといの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関へ出てみると、門から車寄せにうねりあがっている砂利道を、白塗りのジープが、ためらうようにそろそろとのぼってくるのが見えた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関番の小舎は、内部も外部も白塗りの、異国風な建物で、床が磨き込まれて鏡のように光っていた。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "御殿の玄関は黒塗りの大きな式台造り、そして上方の庇、柱、長押などは皆眼のさめるような丹塗り、又壁は白塗りでございますから、すべての配合がいかにも華美で、明朗で、眼がさめるように感じられました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絵のまんなかに、一つの白塗りのバーク型の帆船が、ゆるやかな波のうねりに浮きつ沈みつしながら進んでいる。",
              "citation": {
                "source": "歌う白骨",
                "author": "THE ECHO OF A MUTINY",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
