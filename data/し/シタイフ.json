    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese scholar-bureaucrat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
