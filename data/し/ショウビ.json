[
  {
    "uuid": "e3fbd838-f206-5828-a7f2-009d7f8af058",
    "entry": "賞美",
    "reading": {
      "primary": "しょうび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
