      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "admiration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五葉の松でもあればこそ、落葉松の実生など、余り佳いものでもないが、それを釣瓶なんどに植えて、しかもその小さな実生のどうなるのを何時賞美しようというのであろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仮説を敷衍すれば、熱い酒に冷たい豆腐のひややっこ、アイスクリームの直後のホットカフェーの賞美されるのもやはり一種の涼味の享楽だという事になる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼君これを御覽じて、嬉しげに見えたまへば、彼勸めたる何某面目を施して、件の籠を左瞻右瞻、「よくこそしたれ」と賞美して、御喜悦を申上ぐる。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ったよりは高名で、現に、この頃も藤屋に泊った、何某侯の御隠居の御召に因って、上下で座敷を勤た時、（さてもな、鼓ヶ嶽が近いせいか、これほどの松風は、東京でも聞けぬ、）と御賞美。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "利休が心窃かに自ら可なりとして居た茶入を氏郷も目が高いので切りに賞美して之を懇望し、遂に利休をして其を与うるを余儀無くせしめたという談も伝えられている。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の山科の丿貫という大の侘茶人が糊を入れた竹器に朝顔の花を生けて紹鴎の賞美を受け、「糊つぼ」という一器の形を遺したと共に、作略｜無礙の境界に入っている風雅の骨髄を語っているものである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の油筒を掘り出して賞美するかと思えば、ケチでは無い人だ、家重代の者をも惜気無く親友の所望には任せる。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それはまたそれで丁度そういう調子合のことの好きな磊落な人が、ボラ釣は豪爽で好いなどと賞美する釣であります。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "功名手柄をあらわして賞美を得た話は折々あるが、失敗した談はかつて無い。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一青年が力を假し車を推したのは、所謂惻隱の心とでも云はうか、仁恕の心とでも云はうか、何にせよ或心の發動現象で有つて、儒家者流に之を賞美するには値せずとするも、其の行爲たるや決して不良でも無く、兇惡でも無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "歐米の人はすべて古代を侮り、未來を夢想的に賞美して居つて、時間さへ經過すれば世は必らず文明光耀の黄金期に入るもののやうに感じて居る傾が多いが、大空間の地球も掌上の獨樂も同じ事であつて、其の能く自ら保ち支へて廻轉して立つて居る間は幾干も無いのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（空の具合を見廻して）どうだ、この黄昏の冬木立を賞美しながら、雑司ヶ谷あたりまで行かんか。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊太閤が賞美してこの名を与えたそうである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "某が買い求め候香木、畏くも至尊の御賞美を被り、御当家の誉と相成り候事、存じ寄らざる儀と存じ、落涙候事に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "某が買求め候香木、畏くも至尊の御賞美を被り、御当家の誉と相成り候事、存じ寄らざる仕合せと存じ、落涙候事に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉王　あつぱれとの御賞美は憚りながらおめがね違ひ、それは夜叉王が一生の不出來。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の大試合に拝領した藩公の賞美刀、波の平行安の斬味見たさもあった。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "武芸学問、出精抜群の段御賞美あり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の暮れに軍功のあった侍に加増があって、甚五郎もその数に漏れなんだが、藤十郎と甚五郎との二人には賞美のことばがなかった。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、今こそかれの操る舟に便乗して不安もなく、次々に展開される風景を賞美することの幸ひを悦びました。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米の人はすべて古代を侮り、未来を夢想的に賞美していて、時間さえ経過すれば世は必ず文明光耀の黄金期に入るもののように感じている傾向が多いが、大空間の地球も掌の上で回る独楽と同じ事であって、その能く自ら保ち支えて回転して立っている間はいくらもないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "シリア人は、ラファン体に歩く馬を賞美し、右の前足と右の後足と、而して左の前足と左の後足を相繋いで、稽古せしむ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさこそは貞世がきっと賞美しながら食事を取るだろうと葉子はいそいそとたけの高い食卓を寝台の所に持って行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、うなぎは名人にとって恋人にもまさるほどの、賞美賞玩おかざる大の好物。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいや、なになに、お奉行さまからは表だってのご賞美はなくとも、こういうやさしいところが、夜ごと日ごとにぽうっとなって念じてくれりゃ、ね、だんな、いっそありがてえくらいじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉王　あっぱれとの御賞美ははばかりながらおめがね違い、それは夜叉王が一生の不出来。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同いたずらに手に汗を握っているうちに、御徒士の一人坂入半七というのが野懸けの装束のままで飛び込んで、やがてその鷹と鴨とを臂にして泳ぎ戻って来たので、将軍はことのほかに賞美された。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
