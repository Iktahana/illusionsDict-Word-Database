    "definitions": [
      {
        "index": 1,
        "gloss": "rifle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小銃弾の速度は毎秒九百メートルほどである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顛覆した列車の窓からとび出た時の、石のような雪の感触や、パルチザンの小銃とこんがらがった、メリケン兵のピストルの轟然たる音響が、まだ彼の鼓膜にひゞいていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、待ちかまえていたパルチザンの小銃と機関銃が谷の上からはげしく鳴りだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い錆のついた小銃弾を、ほかの屑物と一緒に買い取った屑屋が、何気なくそれをいじっていて、そこを巡警に見咎められ、ついに死刑にされたことさえあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処からともなく、小銃の音が五六発聞えた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆をはぜらすような、小銃の発射は、方々ではげしくなった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くで、豆をはぜらすような小銃の音がひびいた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "噸數一千｜噸位、二本烟筒に二本檣、其下甲板には大砲小銃等を積めるにやあらん。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、鐵車に紀念塔を積入れ、小銃、彈藥、飮料水、糧食等の用意に日を暮して、さて其翌日となると、吾等撰任されたる五名は未明に起床でゝ鐵車へ乘組んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私が叫ぶ瞬間、日出雄少年は隙さず三發まで小銃を發射したが、猛狒は平氣だ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何、左樣でない、此獸は泥土と、松脂とで、毛皮を鐵のやうに固めて居るのだから、小銃の彈丸位では容易に貫く事が出來ないのさ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "此種の海鳥は、元來左迄に性質の猛惡なもので無いから、此方さへ落付いて居れば、或は無難に免れる事が出來たかも知れぬが、不意の事とて、心から顛倒して居つたので、其樣な事を考へ出す暇もない、急ぎ追ひ拂ふ積りで、一發小銃を發射したのが※失であつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸山が原で夜間演習のときは、小銃を乱射するにも驚かされた。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震に乗じて朝鮮人が陰謀を企て、今晩は竹早町の小学校を中心にして放火を企てているから警戒せよというような貼紙をする者があったので、各戸から一人ずつ、小銃、刀、手鎗など思い思いの得物を持ちだして付近を警戒することになった。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『砲弾か小銃弾か？",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "進んだ時も夢中であったんやが、さがる時も一生懸命――敵に見付かったらという怖さに、たッた独りぽッちの背中に各種の大砲小銃が四方八方からねらいを向けとる様な気がして、ひどう神経過敏になった耳元で、僕の手足が這うとる音がした。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何等罪状の指摘できないマターファ（彼は、いわば喧嘩を売られたに過ぎぬのだから）が千｜浬離れた孤島に流謫され、一方、島内白人の殲滅を標榜して立った小タマセセは小銃五十｜梃の没収で済んだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして今は全く人間が居ないので、今まで来る間に死骸らしいものには一つも行き当らず、小銃のケースや帽子なぞいう戦闘の遺留品にも触れなかったことから推測すると、味方の者は無事にこの森を出たかも知れない……ということなぞ。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人数も、わずかに数人で、籠手臑当して、手槍を持ち、小銃を持っているものは、わずかに数人で、大砲は一門もなかった。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "両軍銃火を交えて戦ったが、幕軍は行軍のままの隊形だったし、小銃が少いものだから、薩長のために、打ちすくめられて、死傷｜頗る多かった。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲は、右は淀川で、左は水沢の地で頗る要害の隘路で京軍を支えんとしたが、薩長の兵は小銃隊を以て、進撃して手もなく、新選組を打ち破った。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小銃をつかむ手はほとんど肉がなく骨のようだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐る前にまず、役立たずの小銃を地面に置き、鼠色の襟巻きに包んだ大きな荷物を下ろす。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とジェファースン・ホープは言って、鞍に下げている小銃へ手を掛ける。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつぶせになり、小銃を岩に構え、しっかりと狙いを定めて引き金を引く。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりのことで取り乱し、心ここにあらず、ジェファースン・ホープは目もくらみ、倒れないよう小銃を杖にして凭りかかるほかない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "身も心もぼろぼろの彼は、小銃を支えにして目下静かに広がる街めがけ荒っぽくその痩せこけた手を振る。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "クー・クラックス・クラン　名は小銃の掛金をかける響きに似通わせて作れる言葉に由来する。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
