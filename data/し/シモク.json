[
  {
    "uuid": "1575f03d-8d33-5937-aa53-3b1140d8cec1",
    "entry": "下句",
    "reading": {
      "primary": "しもく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
