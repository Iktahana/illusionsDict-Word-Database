        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体の地面よりは一段高い芝生の上に小さな猪口の底を抜いて俯伏せにしたような円錐形の台を置いて、その上にあの白い綺麗なボールを載せておいて、それをあのクラブの頭でひっぱたくと一種独特の愉快な音がする。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗に刈りならした芝生の中に立って正に打出されようとする白い球を凝視していると芝生全体が自分をのせて空中に泛んでいるような気がしてくる。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の緑が柔らかで鮮やかで摘めば汁の実になりそうである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂のガラス窓越しに見える水辺の芝生に大名行列の一団が弁当をつかっているのが見える。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海ホテルの海に面した芝生は美しい。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り出せるは、皺になれる敷島の袋、残れる一本を、くわえて、火を点ず、残れる火を、さて敷島の袋にうつす、秋の日の下、物思いのひるさがり、芝生の上、めらめらと、袋は燃ゆらし　灰となりゆく、あわれ、我が肺もこの袋の如、日に夜に蝕まれゆくか、秋の日の下、くゆらす煙草のいとからし。",
              "citation": {
                "source": "詩二つ",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペエテルは腮をずらせ戻して正面を向いて、汁の垂る目を芝生の緑に注いだ。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "青桐の木の向うには平たい芝生の庭があつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の庭の處處には櫻や檜葉や楓などが立つてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の庭を挾んだ向うには、水色のペンキで塗つたこつちと同じやうな二階建の病室の棟が立つてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねり絲のやうなしめやかな雨が青桐の葉や、芝生や、樹木の若葉をしつとりと濡らして、朝から夜がくるまで降り續けてゐる事があつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、女も私に氣附いたやうにちらりと視線を向けて、直ぐ芝生の方へ俯向いてしまつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに奧さんがお氣の毒ですわね……」と、武井さんは五六日前に庭の芝生の上に出てゐた、まだ若若しいその奧さんを私に教へながら、彼の身の上の事を話し聞かせてくれた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに窓から見える病院の芝生の庭には一昨日のやうに、昨日のやうに、ぎらぎらした午後の太陽が照りつけ、處々に咲く松葉牡丹の花が陽炎の中に燃えるやうな紅を映してゐる、動く物一つない靜けさだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして庭はなるたけ広くとつて芝生にする。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくびが終るか終らないうちに、彼は、ぱたりと丸太を倒すように芝生の上に倒れてしまった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵舎の樋から落ちた水は、枯れた芝生の間をくぐって、谷間へ小さな急流をなして流れていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生を隔てて二十｜間ばかり先だから判然しない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中の芝生に鶴が一羽歩いているのを小さな黒犬が一｜疋吠えついていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃かの地でボーアに会って帰って来た友人の話によると、このまだ若い学者は、どこか近い田舎に小さな別荘のようなものを有っていて、暇のあるごとにそこへ行く、そうして平和な周囲と新鮮な空気の中に想を練りペンを使う、どうかすると芝生の上に寝転がって他所目にはぼんやり雲を眺めているそうである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう型の学者があるとすれば、それを世間が本当に尊重するつもりなら、やはりはたから構わないで自由に芝生に寝転がって雲を眺めさせておく方がいちばんいいだろうと思う。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のノーベル・プライズのために不意打ちをくらった世間が例のように無遠慮に無作法にあのボーアの静かな別墅を襲撃して、カメラを向けたり、書斎の敷物をマグネシウムの灰で汚したり、美しい芝生を踏み暴したりして、たとえ一時なりともこの有為な頭の安静をかき乱すような事がありはしないかというような気がする。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年十月『週刊朝日』）　　　　　　　　　十　芝生に水をやるのに、十分に、たっぷり、土の底深く浸み込むまでやることにしなければいけない。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "園内の芝生は割合に気持のいいところである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の真中で三、四人弁当をひろげて罎詰めの酒を酌んでいる一団がある。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳と山崎は、暗い夜露のおりた芝生の上に立ってそれを見ていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三人は、芝生の土手を越して、塹壕のある草ッ原に出た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻尾を焼かれた馬が芝生のある傾斜面を、ほえるように嘶き、倒れている人間のあいだを縫って狂的に馳せまわった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔のオランダ植民地付近が、しばしばふしぎなできごとや現象におびやかされていたのを知っているからである。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
