        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "バーミューダ・ショーツにＴシャツ姿のワラもいっしょだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーツをはいて、銃もって、真面目な姿で、うしろに二本の長い編み下げをたらしている。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮮やかなグリーンのラグビー・ショーツに、花柄の半袖シャツを、今日の彼女は着ていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日系の女性はゴムぞうりにバミューダ・ショーツ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショート・パンツの下には、彼は競泳用の黒いショーツをはいていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーツは汗で濡れていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "部室で裸になり、薄いナイロンのスイミング・ショーツを身につけた祐一は、半地下のようなコンクリートの通路を歩いて、プールへ出た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "外見は良くても、気持ちは冷たいから」「勝手にそう思うだけだろう」「みんなに聞いてみろよ」　口をとがらせてそう言い、中沢はスイミング・ショーツ一枚で部室を出ていった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーパー・マーケットの二階にスポーツ用品の店をみつけ、そこで競泳用のショーツを買った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "撮影のあいだ、私は裸かハイレグのショーツ一枚でした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸とショーツ一枚を、一定の間隔で交互に繰り返して。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、庭のあちこちや家の周囲では、ヒールのあるサンダルを履いて、ショーツも履き替えて、たくさん撮影しました」　そこまで語って、中野玲子は組んでいた脚を降ろした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が身につけているショート・パンツはラグビーのためのショーツだった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロアに腹ばいになってさらに撮り、立ち上がってショーツを脱ぐ彼女の一連の動作も、低い位置から彼はフィルムに収めた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーツの浮き出た腰は完全に無防備だった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョギング・ショーツに、肩ひもの細い、紫色のタンクトップ、片手で髪をかきあげ、もういっぽうの手を、フェリーにむかって振っている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンクトップの胸のふくらみがいいし、ジョギング・ショーツからのびている脚が、すんなりと、しかも、力を秘めている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗せて」「その格好では、無理だ」　タンクトップにペラペラのジョギング・ショーツのミーヨを、ぼくは指さした。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
