        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶どきと見え青い茶が乾してあったり、茶師の赤銅色の裸体が燻んだ色の町に目立っていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人用の烟管の吸口と雁首に附けた金具に、銀と赤銅とを用いて、銀白色の帯青灰色との横縞を見せているのがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの美しい緑色は見えなくなって、※びたひわ茶色の金属光沢を見せたが、腹の美しい赤銅色はそのままに見られた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は、通りと同様に、赤銅色に塵埃をあびていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半信半疑で警戒を怠らなかった赤銅色の売手は、店をたゝむひまもなしに、忽ち、中山服に取りまかれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "連日炎天の行軍で顔は赤銅のごとく、光っているのは眼ばかり。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、お化けかしら」　自分は本棚から、モジリアニの画集を出し、焼けた赤銅のような肌の、れいの裸婦の像を竹一に見せました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際＝如輪木の胴に赤銅の箍を嵌めた酒筒から、大小二本の蔓の根が窓框を捲いて延び上り、緊密な濃緑色の葉立ちの陰に、練絹へルビーを包んだやうな小花を綴るびなんかつら。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頭には乗っかる、突き飛ばす、赤銅色の漁師の腕はすり抜ける、嚊衆の洗濯物はばたつかす。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが犬帰でなも」と後から赤銅の声がする。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "老爺は六尺に近い大男で、此｜年齡になつても腰も屈らず、無病息災、頭顱が美事に禿げてゐて、赤銅色の顏に、左の眼が盲れてゐた。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅色の、逞ましい、逞ましい老爺の顏！",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の白髯を集めて作った兜の飾り毛を風に靡かせ、獣歯の頸掛をつけた・身長六｜呎五｜吋の筋骨隆々たる赤銅色の戦士達の正装姿は、全く圧倒的である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅色の戦士を満載して風上から入港して来るボートの群。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………　老酋長の一人が、赤銅色の皺だらけの顔に涙の筋を見せながら、――生の歓びに酔いしれる南国人の・それ故にこそ、死に対して抱く絶望的な哀傷を以て――低く眩いた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅色に近い・紅く濁った月である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時かの夜夢に起されて公宮の露台から見たのとまるでそっくりの赤銅色に濁った月である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事に赤銅色をした逞しい男が、眞赤な褌一つで漕いで來る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の顏色は例によつて生々と、或ひはテラ／＼と茶褐色に飽く迄光り輝き、短い袖からは鬼をもひしぎさうな赤銅色の太い腕が逞しく出てをり、圓柱の如き脚の下で、靴の細く高い踵が折れさうに見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅色に近い・紅く濁つた月である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時かの夜夢に起されて公宮の露臺から見たのとまるでそつくりの赤銅色に濁つた月である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事に赤銅色をした逞しい男が、真赤な褌一つで漕いで来る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の顔色は例によって生々と、あるいはテラテラと茶褐色にあくまで光り輝き、短い袖からは鬼をもひしぎそうな赤銅色の太い腕が逞しく出ており、円柱の如き脚の下で、靴の細く高い踵が折れそうに見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にカーンストック鉄工場引込線は、六月三日は十六台の赤銅鉄運搬車が軌道を遮りて留め置かれありし事実あり。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらの方にも荒野がゆるやかな起伏をなしており、枯れシダの赤銅色が地平線の果てまで続き、目を遮るものとてはただタヴィストックの尖塔群と、ケイプルトンの調馬場と知れる家々がはるか西方に連なっているのみである。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは跡へ引き返す相談をしようと思つて、ふいと背後を振り返つて見ますと、背後の方の空が、一面に赤銅のやうな色の雲で包まれてゐるのに気が付きました。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅のやうな顏で目玉がぐり／＼して居る。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "脇差は一尺八寸、直焼無銘、横鑢、銀の九曜の三並びの目貫、赤銅縁、金拵えである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
