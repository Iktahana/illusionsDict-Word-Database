          "literary": [
            {
              "text": "小さい角きりの魚をてり焼らしく見せたもの（味は洋風）一口茄子の油煮、ずゐきの白ごま酢（サラダ代り）クツキースとコーヒ。",
              "citation": {
                "source": "季節の変るごとに",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋のずいきは白ごま。",
              "citation": {
                "source": "ともしい日の記念",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お延の平生から推して、津田はむしろごまかされるに違ないと思った。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
