        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "厳しい克己は、春雷の轟きのように、快く、情慾の末を痺らせる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔かさ、かがやかさ、尾は立てぬ、斑雪矢羽根、鳩なり、よき紫、閑かさや、そのかたち、水の輪の紋織や、嘴を、嘴を、嘴をふれ、聴くともなし、春雷。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初雷、春をうたふ空のしらべだ、春雷。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け方、雷鳴そして雨声、春雷でもあるまい、冬雷か、ぬくい、ぬくい、ぬくすぎる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雷、身心ぐた／＼になつて、それでも戻つて来た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日ぶりの酒はまたかくべつの味だつた、春雷、それも酒中の一興だつた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷電は夏季のものとされてゐるが、春雷冬雷の語はまた特殊の気味を持つてゐる。",
              "citation": {
                "source": "雷談義",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雷やたどりつきたる京の宿",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の松尾いはほ、平尾春雷、田中八重、田畑三千女、其他京阪神の諸君五、六十名の出迎を受く。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雷や傘を借りたる野路の家四月二十七日　村上村上平、杜子美居の祭に招かる。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、春雷、雪解、別れ霜。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ夜半に春雷があって、雹やら風が雨戸を打った。",
              "citation": {
                "source": "紅梅の客",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべの夜半の春雷と雹の音も、彼は机で聞いていたであろうか。",
              "citation": {
                "source": "紅梅の客",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八二七年三月二十六日、春雷の猛り荒ぶ日、「喜劇はおわった、諸君、喝采し給え」、そう言って死んだ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雷とはいうものの、すさまじく鳴りはためいて、今にも落ちそうになる。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雷と木瓜との配合も、自然に或調和を得ている。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雷一　――いつまでこの春はこう寒いのだろうか。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雷一　年毎の梅はことしも恙なく咲きみちている。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに春雷一震のような畏怖をおぼえたのは大奥の女人国だったにちがいない。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一　ときならぬ春雷は、一瞬、地を震わせ、人々の胆をおどろかせたが、落花微塵な威も見ぬまに、花の道中を、次の日はもううららかに、水戸へさして帰っていた。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、春雷の鳴ったような轟が、大地を揺りあげた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、土佐境の空には春雷が鳴っていた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀雲後宮をつつみ、春雷殿楼をゆるがして、その日なお董承と日ごろ親しい宮官何十人が、みな逆党の与類と号されて、あなたこなたで殺刃をこうむった。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
