[
  {
    "uuid": "35ad2345-5e8e-5bdf-969d-9775ad073f2a",
    "entry": "萎む",
    "reading": {
      "primary": "しぼむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
