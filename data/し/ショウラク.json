        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "天平勝宝三年に僧勝楽が死んだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘仁と其の弟子の聖雲とが遺骨を納めて勝楽寺をたてた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝楽という師の僧が共に土着したことは系図によって知りうるのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝楽寺の若光墓は供養塔か、他のコマ王か、又はほかの何かであろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "主客、席につくと、喨々、得勝楽という軍楽が奏された。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――目的は甲良村の勝楽寺。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、私たちは勝楽寺の帰途、ひょんな目に遭った。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "期待していた佐々木道誉の画像（近江彦根の勝楽寺蔵）はまだ出ていなかったが、夢窓国師像では、案外な気がした。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
