  {
    "uuid": "f53c07fe-21b0-5f9c-84fd-d0f94599cd18",
    "entry": "師傅",
    "reading": {
      "primary": "しふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "guardian and tutor of a nobleman's child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人中の語は師傅篇に見え、明堂の語も靈樞中の何處かに見えたと記憶する。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王の幼時からの師傅たるナブ・アヘ・エリバでなかったら、恐らく、生きながらの皮剥に処せられたであろう。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "師傅の礼をとって、その言を貴ぶべきです。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "張昭と周瑜のふたりは、どうか師傅の心をもって、孫権を教えてください。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世なるえにしふかくして母よ子と和みくらさんみじかきこの世を。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "前方から目明しふんぞり七兵衛がふんぞり返って急ぎ足に来る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別にどうも……」と、お徳はあいまいに答えたが、その声は少しふるえていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの声も少しふるえていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "化物丁場すなどりびとのかたちして、　　つるはしふるふ山かげの、化物丁場しみじみと、　　水湧きいでて春寒き。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現象については先年わが国のある学術雑誌で気象学上から論じた人があって、その所説によると旋風の中では気圧がはなはだしく低下するために皮膚が裂けるのであろうと説明してあったように記憶するが、この説は物理学者には少しふに落ちない。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しふざけ過ぎたようであまり愉快なものではないが、しかし、これなども映画で見ればこそ、それほどの悪趣味には感ぜられないで、一種のファンタスティックな気分をよび起こされることもできなくはない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども戻るわけにも行かず少しふるへながら樺の木の前に進んで来ました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども戻るわけにも行かず少しふるえながら樺の木の前に進んで来ました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "由なき戯れとは思いつつも、少女がかれに気づかぬを興あることに思いしか、はた真白の皿に紅の木の葉拾いのせしふるまいのみやびて見えつるか、青年はまた楓の葉を一つ摘みて水に投げたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の日など泥まみれの足を手ぬぐいでごしごしふいて上がるのはいいが絹の座ぶとんにすわらされるのに気が引けた記憶がある。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたままで清逸は首だけを腰高窓の方に少しふり向けてみた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと驚いたでせう、といふ氣持ちを、すこしふら／＼する手つきに出して西原氏はわれわれにこの話へのより多くの注意を促した。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「必要だ」　きっぱりといったが、しかしふと赧くなった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことないよ」　と、鶴雄の声はしかしふと弱かった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ自首をすすめるのでも、おれの方は悪い役まわりや」　しょんぼりした声だが、しかしふとえくぼが泛び、したたるような微笑をたたえながら豹吉は言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがあればいいけれど、ただ何となしふらふらしてんのね。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいしょきみの下に使われていたときも、わたしはきみに、おまえといわれると、やはりおなじ感じがして、いわば地面におしふせられるようにおもったものだ。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光と海月月光の中を泳ぎいでむらがるくらげを捉へんとす手はからだをはなれてのびゆきしきりに遠きにさしのべらるもぐさにまつはり月光の水にひたりてわが身は玻璃のたぐひとなりはてしかつめたくして透きとほるもの流れてやまざるにたましひは凍えんとしふかみにしづみ溺るるごとくなりて祈りあぐ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたで無いと涼しふならん。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは色んな冗談を言つて、書物を投げつけ合つたり足踏して床を鳴らしてゐたが、そのうちに私は少しふざけ過ぎて了つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しふとってかえって若くなった、とみんなが言った。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その児、その孫、二代三代に到って、次第おくり、追続ぎに、おなじ血筋ながら、いつか、黄色な花、白い花、雪などに対する、親雀の申しふくめが消えるのであろうと思う。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十になつて、少しふとつた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しふとって、愛想のよい口元をしていて、私にも、感じがよかった。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしろ、信濃なる千曲の川のさゞれ石も　　　　君しふみなば玉とひろはん　と言う場所なんですもの。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
