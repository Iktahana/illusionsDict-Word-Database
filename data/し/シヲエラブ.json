    "definitions": [
      {
        "index": 1,
        "gloss": "to commit suicide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "決して、決して、自分は死を選ぶべきでなかつた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遺書で彼の死んだ事情が最もハッキリして居るのですが、「皆私を引止めて呉れたけれども、自分は科学者として死を選ぶのが一番善いと思ったんで死ぬ。",
              "citation": {
                "source": "あの世から便りをする話",
                "author": "――座談会から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーガスタス大帝も、「ユータネシア、ユータネシア」と叫んだそうですが、もしお互に自分が不治の病にかかって、臨終にはげしい苦痛が来たとしたら、恐らくその苦痛を逃れるために死を選ぶにちがいないだろうと思います。",
              "citation": {
                "source": "安死術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして恋の敗北者が底知れぬ苦悩の淵につき落され、そのために死を選ぶに至ることも、同じく無数に繰返された喜劇である。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、僕は毒薬死を選ぶことに決したのである。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、そんなあさましいことをするよりわしは餓死を選ぶ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　死への道　　そしてまた彼女達は、何と容易に死を選ぶことだろう、刃物で、劇薬で、鉄道線路で……。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　死への道　そしてまた彼女達は、何と容易に死を選ぶことだろう、刃物で、劇薬で、鉄道線路で……。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしで、おそらくそのときには、自分ならむしろ死を選ぶかもしれない信仰上の破滅だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、もし、万一、死を選ぶとして、どんな方法をとるかね？",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その極まつた分岐点で死を選ぶなら、それはそれで仕方がない。",
              "citation": {
                "source": "悲願に就て",
                "author": "――「文芸」の作品批評に関聯して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "降伏を選ぶか、それとも死を選ぶか？",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その極まった分岐点で死を選ぶなら、それはそれで仕方がない。",
              "citation": {
                "source": "悲願に就て",
                "author": "――「文芸」の作品批評に関聯して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま黙つて寝ろと言はれれば、僕は、潔く死を選ぶ。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、記代子に、死を選ぶような素振りがあったわけではない。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の恋が成功しないとすれば、我らはただ死を選ぶまでだ！",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵は、なんといふか、君を完全に愛するために、死を選ぶよりしかたがなかつた、といふことは云へんかね？",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも不名誉な生よりもむしろ死を選ぶことは、もってのほかのことだと思われている。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ひとりで死ねなければ、自分のいちばん好きな相手と一緒に死を選ぶのが、いちばん賢い生き方ではないか、生きているということは、そんなに幸福なことでも、価値のあることでもない、と思ったりすることもありますのよ……」「お雪ちゃんとしては、珍しい心の持ち方ですね。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして膝へ膝をつき進めて、「小寺の家中が、危害を加えんとする惧れも充分ある上に、その方自身が、死を選ぶ惧れもわしは多分に抱くのじゃ。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドゥーニャは悟った――彼は自分を手放すくらいなら、むしろ死を選ぶに相違ない。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶望したる者は身を投げ出し、疲弊したるものは死を選ぶ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、死を選ぶほかに彼の道はないのではないかと考えた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この苦しい忠興の意も汲まず、後に遺る子も思わず、この場合、何よりやさしい死を選ぶ所存か。",
              "citation": {
                "source": "日本名婦伝",
                "author": "細川ガラシヤ夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく小右京は死を選ぶかもしれない。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
