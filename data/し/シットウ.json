    },
    "definitions": [
      {
        "index": 1,
        "gloss": "devitrification",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じ磁土がないために、錫を用いた失透釉で陶土を被い、藍絵磁器に類似する特殊な手法へと進んだ。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが一度古く出来た大鉢やいわゆる呉須茶碗等の失透釉のものに来ると、すばらしい美しさである、骨もある腰も強く、すべてが豊である。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いものは主として緑青か白の失透釉を用いたが、後には宝珠の玉の模様を入れ、色も黄色のが多い。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失透の海鼠窯を見ると出来たものは朝鮮あたりのものと似通う。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
