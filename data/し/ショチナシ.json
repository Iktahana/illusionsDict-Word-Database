          "literary": [
            {
              "text": "わが脳細胞の老衰は全然処置なしではなかったのだ。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがわからないうちは処置なしだ）　博士は、その異常現象が、九台の救援ロケットの破壊をすくったことさえ知らなかった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "むにゃむにゃ……」「それを使えば、敵側は全く処置なしという凄いものを御提供願いたい。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃから処置なしじゃ。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう処置なしだ」　山ノ井は、そういった。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（もう処置なしだ）　と、中尉は心の中で叫んだ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、『魔の空間』、ほんとうだったな」　　　処置なし　山岸中尉は、ついに操縦桿から手を放した。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、桜木町事件は処置なしですよ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "新十郎も処置なしと諦め顔、「もうこれ以上は仕方がありません。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢山、むずかしい」　そう言って、両手を拡げて、処置なしという表情。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
