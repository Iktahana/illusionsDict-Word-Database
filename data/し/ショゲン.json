  {
    "uuid": "38d175bb-55af-5cd8-895c-7f87f594f9c7",
    "entry": "諸彦",
    "reading": {
      "primary": "しょげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "many accomplished persons",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "運命をともにする同車の日本人｜諸彦――車室順。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "多年日本紳士｜諸彦ノ御引立ヲ蒙リ廉価ニ御調製｜仕候。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "「壬午九月十有二日、為亡友高君子融小祥期矣、同社諸彦賦感秋詩、述思旧之情、余亦賦一律以奠。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「七夕小集」の七絶に「茅亭亦有諸彦会」の句がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸彦祝以亀寿鶴齢之章。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども読者諸彦のしばしば書を寄せて過当の奨励をなすもの往々これあるにより厚顔にもここにふたたび印刷職工を煩わせり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、右思ひつきたる事を筆にまかせ記せしに過ぎず遣漏誤聞もとより多かるべし、大方諸彦の御示教をまつものなり。",
              "citation": {
                "source": "古本評判記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "五山が絶筆の韻を次いで枕山は「五門諸彦散。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔五門ノ諸彦散ズ／頼ニ我ガ徒ノ同マル有リ／蓮寺詩ヲ以テ会ス／氷社ノ中ニ参ズルガ如シ〕と言っている。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私においてはもとよりであるが、併せて読者｜諸彦に対しても同じくこの尊影に向って合掌せられんことを御願いする。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら諸彦の助力を跋文中に銘記するに先だって、特に今記すべき一事は、畏友大野晋氏が、語法と基本語詞につき、更にその同窓板坂元・同美智子両氏の協力をも得て、応急適切な援助を寄せられたことである。",
              "citation": {
                "source": "『広辞苑』自序",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをもって、読者諸彦へのお詫びともさせていただきたい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
