  {
    "uuid": "fe8786ac-152f-5481-9864-cc88dc1af220",
    "entry": "生薬",
    "reading": {
      "primary": "しょうやく",
      "alternatives": [
        "きぐすり",
        "せいやく"
      ],
      "is_heteronym": false
    },
    "grammar": {
