    },
    "definitions": [
      {
        "index": 1,
        "gloss": "crude drug",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「一、山男紫紺を売りて酒を買い候事、山男、西根山にて紫紺の根を掘り取り、夕景に至りて、ひそかに御城下（盛岡）へ立ち出で候上、材木町生薬商人近江屋源八に一俵二十五｜文にて売り候。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生薬屋のおやじも死んだと。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手先の一人は取りあへず四谷伝馬町の生薬屋を取調べたが、その当日又はその前日に赤膏薬を買ひに来た侍はないと云ふのであつた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "生薬屋の店で何か買っていました」「金造はどんな奴だ」「なに、けちな野郎ですよ」　半七は立ちどまって考えていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "御苦労だが、品川へ引っ返して、その生薬屋で金造が何を買ったか調べて来てくれ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ近所に甲州屋という生薬屋があって、そこのお直という娘がお粂のところへ稽古に通っているのを、半七も知っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十年ほど前予が本草学を修めた頃は、京阪から和歌山田辺（想うに全国到る処）の生薬屋に、馬、牛、猴、獺、狐、狸、狗、鹿、鯨、また殊に膃肭獣のタケリ、すなわち牡具を明礬で煮固めて防腐し乾したのを売るを別段不思議と思わず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このお丸というのはどんな女だ」「芝口の下駄屋の娘で、兄貴は家の職をしていて、弟は両国の生薬屋に奉公しているそうです」と、源次は説明した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうなると、その生薬屋に奉公している弟というのも調べなければなりませんね」と、源次は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軒｜隔いて隣りの備前屋という生薬屋の娘さんでございます」と、勘蔵は答えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの代りに采配を振って、若けえ奴らを追い廻してくれめえか」「そこで、その御用というのはどんな筋だね」「田町の備前屋という生薬屋の娘が殺されたのだ」「備前屋の娘が殺された……」と、半七もすこし驚かされた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七もすこし風邪をひいたようで、重い顳※をおさえながら長火鉢のまえに欝陶しそうに坐っていると、町内の生薬屋の亭主の平兵衛がたずねて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰ってはいるが、きょうは雨やみになっているので、半七はあさ飯の箸を措くとすぐに町内の生薬屋へ行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都度樹木に特有な冷えびえとした黴臭い生薬のやうな匂が、私の心のうちにまでもそつと忍び寄つて来る。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と卜新氏は長い間｜生薬と女の唇とを嘗めて来たらしい口を開けて笑つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを心から感心して見るのは、どうしたって、本町の生薬屋の御神さんと同程度の頭脳である。",
              "citation": {
                "source": "明治座の所感を虚子君に問れて",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は凧の絵の赤い色は皆な蘇枋というもので描いたので、これはやはり日本橋の伊勢佐という生薬屋で専売していたのだが、これを火で温めながら、凧へ塗ったものである。",
              "citation": {
                "source": "凧の話",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十七　病気と称して、引籠ってしまった右源太は、生薬屋から買ってきたいい加減の煎じ薬を、枕元に置いて（さあ、困った）　と、布団の中で、眼を閉じていた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は、木薬店（生薬が正しいか）で、西洋流の売薬と、漢薬との混沌期であったらしく、店先に、蜜柑の皮が、一杯干してあったのを憶えている。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も亦僕の小学時代には鉄面皮にも生薬屋へ行つて「半紙を下さい」などと言つたものだつた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もまた僕の小学時代には鉄面皮にも生薬屋へ行って「半紙を下さい」などといったものだった。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行くかね」と、兄は微笑して、「――行くんならね、普通の生薬屋へ行つても駄目なんださうだ。",
              "citation": {
                "source": "イボタの虫",
                "author": "中戸川吉二",
                "note": "青空文庫"
              }
            },
            {
              "text": "近「生薬屋の看板だよ。",
              "citation": {
                "source": "心眼",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北山先生薬くだされ！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生薬屋であつた私の家の店先へ、いつからか来て、来れば一時間では腰をあげる気づかひのない若い山陽道辺の女、亭主と言ふのは、東京から来た巡査で、此二人が世話になつて居たのが、一山と言つたか、一山の弟子であつたか、うろ覚えになつてしまつたが、此も東上りの講釈師であつた。",
              "citation": {
                "source": "寄席の夕立",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は久しぶりに下谷の車坂へ出て、あれから東へ真直に、寺の門だの、仏師屋だの、古臭い生薬屋だの、徳川時代のがらくたを埃といっしょに並べた道具屋だのを左右に見ながら、わざと門跡の中を抜けて、奴鰻の角へ出た。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七　よく見るとこれは一軒の生薬屋の店を仕切って、その狭い方へこざっぱりした差掛様のものを作ったので、中に七色唐辛子の袋を並べてあるから、看板の通りそれを売る傍ら、占ないを見る趣向に違ない。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い室一つの住居としか思われないのに、肝心の易者の影も形も見えないから、主人は他行中で、細君が留守番をしているところかとも思ったが、店先の構造から推すと、奥は生薬屋の方と続いているかも知れないので、一概に留守と見切をつける訳にも行かなかった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ふくろう先生は二匹に毛生薬を沢山ぬりつけて、風邪をひかないやうに、暖い毛布で、二匹を包んで下さいました。",
              "citation": {
                "source": "お猫さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士も黒田警官も、殆んど死人のように見えましたが、博士の用意してあった回生薬のお蔭で、極く僅かの時間に、メキメキと元気を恢復することが出来たのだそうです。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
