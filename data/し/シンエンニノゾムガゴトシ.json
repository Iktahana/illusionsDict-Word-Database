          "standard": [
            {
              "text": "重要なプロジェクトの責任者に任命され、まさに深淵に臨むが如しという心境だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "未知の領域に挑む彼の姿は、深淵に臨むが如し、勇気に満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人生の岐路に立ち、深淵に臨むが如し、慎重な選択が求められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "伝書には「手に虎の児を握るが如く、薄氷を踏むが如く、深淵に臨むが如し」などと教えて居ります。",
              "citation": {
                "source": "禁断の死針",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
