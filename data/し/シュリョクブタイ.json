          "standard": [
            {
              "text": "偵察隊が敵の状況を確認した後、主力部隊が満を持して総攻撃を開始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山岳地帯での戦闘を想定し、主力部隊には精鋭の歩兵が選ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前線の主力部隊に食料と弾薬を届けるため、輸送トラックが急ぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一、「アツツ」島守備部隊は五月十二日以来極めて困難なる状況下に寡兵よく優勢なる敵に対し血戦継続中の処、五月二十九日夜敵主力部隊に対し最後の鉄槌を下し皇軍の神髄を発揮せんと決意し全力を挙げて壮烈なる攻撃を敢行せり。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
