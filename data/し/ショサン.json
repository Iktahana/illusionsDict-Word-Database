      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "result",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは下らねい感傷の所産に過ぎない。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう方面から考えて行くと、同時代に生れて同様な趣味や目的をもって、同じ学校生活を果した後に、また同じような雰囲気の中に働いて来たものが多少生理的にも共通な点を具えていて、そしてある同じ時期に死病に襲われるという事は、全く偶然の所産としてしまうほどに偶然とも思われない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人間精神の所産物と比較して広義の芸術的科学的ないし功利的の価値を考えてみたときに、特に漫画を低級なものと考えるべき必然な根拠を見出す事は困難である。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし室生自身に言はせれば、かうした幸福や家庭生活やは、決して偶然の所産でなく、彼自身の努力によつて、意志的に構成したものなのである。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界が神の所産でないことは世界の欠点だらけなことからもわかると論じている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後私の生活がいかように変わろうとも、私は結局在来の支配階級者の所産であるに相違ないことは、黒人種がいくら石鹸で洗い立てられても、黒人種たるを失わないのと同様であるだろう。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局彼は人間の精神的要求が完全し満足される環境を、物質価値の内容、配当、および使用の更正によって準備しうると固く信じていた人であって、精神的生活は唯物的変化の所産であるにすぎないから、価値的に見てあまり重きをおくべき性質のものではないと観じていたとは考えることができない。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三階級にのみおもに役立っていた教養の所産を、第四階級が採用しようとも破棄しおわろうともそれは第四階級の任意である。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの詩程理智的でなく見えて、その實かれの詩程理智の所産なるものはない。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "接觸の所産は詩である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとあの役人の身の上も、全く私の病中の空想の所産で、実際の見聞で無いのは勿論であるが、次の短篇小説の主人公もまた、私の幻想の中の人物に過ぎない。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その所産、「春日の鹿」「正倉院御物抄」。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち『白南風』が、大正十五年暮春、小田原より東京谷中天王寺墓畔に転住して以来、馬込緑ヶ丘、世田ヶ谷若林、砧村大蔵、等に亘る東京生活の所産であるに対し、本集は、殆同時代の覊旅の旅を主として採録した。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代頽唐の所産たる「邪宗門」が既に是を証する。",
              "citation": {
                "source": "「白秋詩集」序",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "本集は大正二年五月より三年二月に至る、相州三浦三崎に於ける私のささやかな生活の所産である。",
              "citation": {
                "source": "雲母集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旗奪の夜の怪異は、今から考えてみると実在の怪異であったか、それとも怪異の恐怖の中から創作したものであったか、それはどうもはっきりしないが、その後にあった一つの怪異は実在のもので、老媼茶話の中にでもありそうな話であるが、それは後になって人間の巧智の所産であることが判った。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り体に云うと前述の錦絵は日本所産の芸術作品の中でもかなりに俗受け専門の低級浅薄なものであるが、それでもその中に含まれている画家と、彫刻師と、印刷者の苦心は、外国一流の芸術家たちを刺戟して、新生面を打開させるだけの偉大深刻な尖鋭さをもっている。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして作品に在る温味も力強さも、この人格の所産であると言った方が一番よく判るかも知れないと思う。",
              "citation": {
                "source": "志賀直哉氏の作品",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは言うものの、「佯りのうそ」でも結局それがほんとうに活きていた人間の所産である限り、やはりそれはそれとしての標本として役立つかもしれない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場その場の同居人の気持ちを如実に表すものとだけはわかるが、この音楽が思索の助けとなるのか、ただ単たる気まぐれや思いつきの所産なのか、私には判断しかねた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこの辺で、我々の長い分析の、貧弱ではあるが確実な所産を、しめくくってみるとしようじゃないか。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一条　この法律は、著作物並びに実演、レコード、放送及び有線放送に関し著作者の権利及びこれに隣接する権利を定め、これらの文化的所産の公正な利用に留意しつつ、著作者等の権利の保護を図り、もつて文化の発展に寄与することを目的とする。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、その際、著作権法は「これらの文化的所産の公正な利用に留意」するともいう。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし県庁で他所産の知事さんが、僕の国のものに逆うのは好くないというので、黙許するという事になった。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば天を仰いで可見の星の姿を写さうならば、それは直に空想の所産であつて、ひつきよう絶対の存在ではないか。",
              "citation": {
                "source": "水車小屋の日誌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は、「赫耶姫の上った天上の世界というものは空想の所産にすぎません。",
              "citation": {
                "source": "源氏物語",
                "author": "絵合",
                "note": "青空文庫"
              }
            },
            {
              "text": "心理学は西洋の所産だけあつて、多くは自の方面から見てゐる。",
              "citation": {
                "source": "自からを信ぜよ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "短篇小説といふものも、何方かと言へば、近代文芸の所産である。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、フランス文学の所産と言つても好い位である。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとな、雷師匠といわれた手習のおしょさんの近所に国年という絵かきがいてな、絵を教えてくれて、これも大変可愛がった。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
