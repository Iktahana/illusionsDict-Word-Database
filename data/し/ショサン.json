[
  {
    "uuid": "3d9a8793-822d-55ed-adb8-edd6bbec6384",
    "entry": "所産",
    "reading": {
      "primary": "しょさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
