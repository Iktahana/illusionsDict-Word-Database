  {
    "uuid": "8c8dc90c-0505-5895-b2e1-5a6c50c12c89",
    "entry": "死球",
    "reading": {
      "primary": "しきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pitch that hits the batter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "野球のような近代スポーツでも、死球をくらったのにそれがバットをこすったりするとアウトになる。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か話し掛けたいと思いましたが、どうもあんまり向うが寂かなので、私は少しきゅうくつにも思いました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それで、おまえが、なんとかなれば七円ほど、くめんをして、しきゅう、たのむ、おとっさんも、いたか、いたか、きってくれ、いいよんなはる。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし見えたら、マルタンはすぐ信号を送って、彼らをしきゅうひきかえらせるつもりだった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くねたまえ」　そこで春夫少年は、すこしきゅうくつですが、防毒面をかぶったまま、きかいときかいの間に毛布をしいて、その中にもぐりこみました。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さま、そんな顔をなさいますと、わたしきゅうに恐くなってまいりますの、おねがいですからそんな顔をしないでくださいな。",
              "citation": {
                "source": "みずうみ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しきゅう、お話ししたいことがありますので、わたしのじむ所まで、おいでねがえませんか。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしきゅうくつですが、からだの小さい小林君なら、乗れないこともないでしょう。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しきゅうくつだけれど、うしろの席に四人がこしかけたのです。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
