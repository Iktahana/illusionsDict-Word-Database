    "definitions": [
      {
        "index": 1,
        "gloss": "male Buddhist novice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
