[
  {
    "uuid": "2f9ab0eb-bab9-5441-a14f-634dc81eb763",
    "entry": "しもた屋",
    "reading": {
      "primary": "しもたや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
