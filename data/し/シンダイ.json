    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "借りた室の寝台にはこの真冬に白い紗の蚊帳がかかっていた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆色のセーターを着た助手が、水道のホーズから村山貯水池の水を惜気もなく注いで、寝台自動車に冷たい行水を使わせている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景な病室の粗末な寝台の上で最期の息を引いた人の面影を忘れたのでもない、秋雨のふる日に焼場へ行った時の佗しい光景を思い起さぬでもないが、今の平一の心持にはそれが丁度覚めたばかりの宵の悪夢のように思われるのである。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ色の青い恐ろしく痩せた束髪の三十くらいの女をつれた例の生白いハイカラが来て機関長と挨拶をしていたが、女はとうとうこの室の寝台を占領した。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めての他郷の空で、某病院の二階のゴワゴワする寝台に寝ながら窓の桜の朧月を見た時はさすがに心細いと思った。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤石山の、てっぺんへ、寝台へ寝たまま持ち上げられた、胃袋の形をしたフェットがあった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森から乗った寝台車の明け方近い夢に、地下室のような処でひどい地震を感じた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中過ぎに寝台の縁に腰を掛けた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そこには栗鼠の毛皮の外套をつけた、僕にたいする敵愾心を青ざめた顔面に浮べた女性が寝台の柱に凭掛っていた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がホテルの寝台でしおれかかったビリダリアの夜の花。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はマルセーユから催眠酒をのまされたような意識を失って近東行の急行列車に乗ると昏々とマホガニイの寝台でフロレンス辺まで吊されていたらしいのだ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人のボオイが部屋を去ると、私はふと同室の寝台に乱雑に投げ出された女物の革手袋と粋な持物の下の花模様の部屋靴が私の目にとまるのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が自分の部屋にかえると隣の寝台にカーテンも引かないでペチ・コートのまま仰向けになったアダが、夢うつつにも寝床で寝るトア・ズン・ドルの女を再び見出した。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良が電流に乗ってリー・シー・ツワンの部屋に這入ると、彼は寝台のなかで外出着をつけて胸には瀝青を鍍金した勲章をぶらさげていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は黙々として寝台の枕もとに立っていましたが、しばらくすると寒さのために震えながら私の××に這入ってきました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　街に展いた窓の出張に置かれた洋紅色の花鉢を寝台の枕もとに持ってくると、夜の女は眸の快楽のために、「――その女房と云うのはどんな役目なの？",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなときスマ子女史は、彼女の「彼氏浮気もの」を待つあいだを英語の勉強をしたり寝台のうえで体操をしたり日本の作家の有名な小説を読んだりしているが「彼氏浮気もの」が、にこ／＼わらいながらかえってくれば、悦しくなって、なにしろ彼は可愛いいので、だがすこしばかり眼に涙をためて、――おかえり！",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台から跳ねあがる音がして、黒いスカートのもとから素足のままで、フランのワイシャツに汚れたネクタイを締めながらスマ子女史は英介氏の部屋にやってきて、ストーブのまえでうずくまりながら、――お仕事できたらしいわねえ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊濁点付きの二倍の踊り字は「／″＼」-------------------------------------------------------　　　　　　一　内地へ帰還する同年兵達を見送って、停車場から帰って来ると、二人は兵舎の寝台に横たわって、久しくものを言わずに溜息をついていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ばかり椅子でボンヤリしているうちに、伍長と、も一人の上等兵とは、兵舎で私の私物箱から背嚢、寝台、藁布団などを悉く引っくりかえして、くまなく調べていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、ほかの看護卒の、私物箱や、財布をも寝台の上に出させ、中に這入っている紙幣を偽物かどうか、透かしてたしかめた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の帳尻とが合っているかどうか、寝台の前に立たせられて、班の上等兵から調べられた経験を持っていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼の寝台の上には、手帳や、本や、絵葉書など、私物箱から放り出したまゝ散らかっていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛布をかむって寝台からペンキの剥げたきたない天井を見た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大西は無遠慮に寝台を見まわした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知っている青年達は中隊の班内で寝台を並べてねる同年兵たちに、そのことを噛みくだいて分るように語らねばならぬ、武器の使用方法を習って、その武器を誰れに対して用いるか、そのことについてほかの分かっていない同年兵たちに語らねばならぬ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、鉄の寝台が並んでいた。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがお前の寝台だ。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある寝台の前につれて来た二年兵が云った。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども陛下は、まだおかくれになったというわけではなく、やせほそり、色は青ざめながら、ながいびろうどのとばりをたれて、どっしりとおもい金のふさのさがった、きらびやかなしんだいの上にやすんでおいでになりました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
