[
  {
    "uuid": "76e6c380-61d1-5bbc-aee2-d6e978e7cfa9",
    "entry": "寝台",
    "reading": {
      "primary": "しんだい",
      "alternatives": [
        "ねだい"
      ],
      "is_heteronym": false
    },
    "grammar": {
