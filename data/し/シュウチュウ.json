[
  {
    "uuid": "1df6a3eb-ba92-531f-9cd7-309b0640ea5b",
    "entry": "集中",
    "reading": {
      "primary": "しゅうちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
