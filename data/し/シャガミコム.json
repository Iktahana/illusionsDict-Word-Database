        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向ふの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらゐの活字を次から次と拾ひはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向うの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらいの活字を次から次と拾いはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向こうの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと、小さなピンセットでまるで粟粒ぐらいの活字を次から次へと拾いはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く捜してから諦めると、そこで一夜を明す事に決め、小さな岩陰に三人身体をつけてしゃがみ込む。",
              "citation": {
                "source": "一ノ倉沢正面の登攀",
                "author": "小川登喜男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カテリーナ・リヴォーヴナはしゃがみ込むと、良人の喉にかかっているセルゲイの両手を、じぶんのもろ手でぐいと押しつけ、耳をその胸に当てがった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何ということもなく、そこへしゃがみ込む。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、なりもふりもかまっていられなくなって、人通りのはげしい、そこの石段の上にしゃがみ込むと、腕で顔を隠して、大声で泣いた。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙は抜いて持っている刀で塀外の方を指し示すような身振りをして、身体を支え切れず前へしゃがみ込むような具合に植込みの方へ倒れてしまう。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いわれて滝三もしゃがみ込む。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言われて瀧三もしゃがみ込む。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はッと驚いて、男女がそこへしゃがみ込むと同時に、向うの提灯もふッと消えましたが、それと共に明らかに分るのは、タ、タ、タ、タッ……暗い大地をうって、ここへ目がけてくるその人間の跫音。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちが自分の本望だか、こいつあ、考えてみるまでもねえじゃねえか」　と、九兵衛が彼女のそばにしゃがみ込むと、それにも返辞はなくて、ただ草のなかに顔を埋めたお粂の白い手足が、わなわなと指先にまで痙攣を起こしてきています。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一人が、「おい、｜小父さん、ちょっとの違いで、すごい御馳走を棒にふったぜ」と声をかけたので、何かと思って僕もしゃがみこむと、非番の兵隊が集まって「戦争の終ったのを祝って」一杯やった所だという。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うがしゃがんだままなので、僕もしゃがみこむと「あの子にバナナをやりたいとおもって持って来たんだが、呼んでくれないか」という。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泳ぐというよりは、前の方へうつむきがちに、しゃがみこむように見えましたな」　と一人が答えた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "使用した毒物はわからないが、刀傷によって死んだものでないことは確かのようです」「すると、加納さんが前へとんとんと泳がれて、胸をかきむしるようにしてしゃがみこむようになすったのは、刀傷によるのじゃなくて、毒物の作用によるのですね」「まア、そうでしょう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "やろうと思ったら、人殺しだってなんだって、やれるんだぞ」　愛一郎は、下草のなかにしゃがみこむと、夜目にもそれとわかる飛びだしナイフで、萱のしげみをめちゃめちゃに切りまくった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（再びしゃがみこむ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙は抜いて持っている刀で塀外の方を指し示すような身振りをして、身体を支え切れず前へしゃがみこむような具合に植込みの方へ倒れてしまう。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（再びしゃがみこむ）仙太　アハハハ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして便器にまたがって、ゆっくり、ズボンをずるずるとおろして、「オッパイの、もろにでっかい女だな」と呟きながら、しゃがみこむと、その俺のつい鼻のさきに、黒いゴムの管がぶらさがっていて、ゆらゆらとゆれていて、俺の顔にぶつかりそうだった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "一息抜いたところで万吉は後ろからこっそり、「ご免よ」と主の和平に目じらせして、梯子下の道具部屋にしゃがみこむ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
