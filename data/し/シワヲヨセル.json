        "index": 1,
        "gloss": "to wrinkle up (one's eyebrows, one's nose)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
