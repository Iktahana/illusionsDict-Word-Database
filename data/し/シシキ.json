[
  {
    "uuid": "0474b09a-520a-5f99-b4a1-9716945d20f3",
    "entry": "士師記",
    "reading": {
      "primary": "ししき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Judges (book of the Bible)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヘブライ語聖書で「預言者」と呼ばるる部分は、預言者のほかに、古い時代にできた歴史書（ヨシュア記、士師記、サムエル書、列王紀略）を含む。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日過ぐる所は、すべて旧約の士師記、列王紀略上下、サムエル書上下等に関する名所旧蹟に満ちたる地なり。",
              "citation": {
                "source": "馬上三日の記",
                "author": "エルサレムよりナザレへ",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よやわが十指は晶結し背にくりいむは瀧とながるるごとししきりに掌をもつて金屬の女を研ぎ胴體をもつてちひさなる十字を追へば樹木はいつさいに※轉し都は左にはげしく傾倒す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少ししきゃあ寐ませんでしたの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私達は仙台の方からやつて来たのである）『なアに、どんなに遠く見積つたつて地図によると、一里と少ししきやありやしない。",
              "citation": {
                "source": "旅から帰つて",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "○庭に立つ麻手刈り干ししき慕ぶ東女を忘れたまふな　〔巻四・五二一〕　常陸娘子　藤原｜宇合（藤原不比等第三子）が常陸守になって任地に数年いたが、任果てて京に帰る時、（養老七年頃か）常陸娘子が贈った歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "名にし負うたにはささやまささやまに得てしいのししきょうくいにけり　先日黒豆は少々、士郎兄の奥さんに割愛した。",
              "citation": {
                "source": "丹波篠山",
                "author": "平野零児",
                "note": "青空文庫"
              }
            },
            {
              "text": "川島、「ガラマサ」の自分創作の個所に対ししきりにくどく言って来るので、今日一寸きめつけ、僕に任せて置けと言ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
