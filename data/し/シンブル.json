        "examples": {
          "standard": [
            {
              "text": "裁縫をする際、針が指に刺さらないようにシンブルをはめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "おばあちゃんは、使い込んだシンブルを大切にしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "革製のシンブルは、指によくフィットして作業しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "バオバブ樹の実を指す、またピーター・シンブルの話に猴吸い（サッキング・ゼ・モンキー）といえるは、椰子を割って汁を去りその跡へラム酒を入れて呑むをもいえば、樽に藁を挿し込んで酒を引き垂らすをもいう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "トカイワインは贅沢な高級品で、シンブルグラスで飲む代物だ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
