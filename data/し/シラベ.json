  {
    "uuid": "4aa9e6a5-09bc-5ce5-96ef-ee909fb953f5",
    "entry": "白檜",
    "reading": {
      "primary": "しらべ",
      "alternatives": [
        "シラベ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Veitch's silver fir (Abies veitchii)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "数町行くと、白檜森が左右に一かたまり茂って、その側に潺々たる小川が流れている。",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな岳樺や白檜などが折れたり、根ぐるみ引抜かれたりして、雪に埋まっている。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから昼も暗い程に茂った白檜の林を分けつつ、仙丈岳に続く長い尾根を北に辿った。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上は烟も抜き切れない程に枝と枝とが組み合った白檜の密林である。",
              "citation": {
                "source": "大井川奥山の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の流れていそうな溝を探している中に大降りとなったので、側にあった矮い白檜の下に逃げ込んで雨を避けた。",
              "citation": {
                "source": "大井川奥山の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥が偃松や白檜の間でチュイーチュイーと鳴いているのが聞える、岳雀であるという。",
              "citation": {
                "source": "大井川奥山の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫を通り越して偃松の斜面を下った所は白檜の森林で、足ざわりの柔らかい苔の上を歩くのがよい気持である。",
              "citation": {
                "source": "大井川奥山の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野営地に着く早々、天幕を張れというのを聞き入れず、大鉈を揮って頃合いの木を伐り、四本の柱と四本の横木を用いて骨組を済すと、枝を籠目に編んで四方を囲い、白檜の皮を巧に剥ぎ取って屋根を葺き、羽目を当て、床を張り、ものの四十分と経たぬ中に一坪余りの小屋が出来上る。",
              "citation": {
                "source": "鹿の印象",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒檜、白檜、唐檜などの針葉樹が岩の斜面にしっかりと根を下ろして、薄暗い蔭を翳している木の間伝いに、どこからともなく大嵐の吹きすさぶに似た音が響いて来る。",
              "citation": {
                "source": "渓三題",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "針葉樹の大深林が見られるのも、主として沼の北岸で、大白檜、黒檜、米栂、姫小松、唐松などが、或は混生し、或は純林をなして鬱蒼と繁茂している。",
              "citation": {
                "source": "那須、尾瀬、赤城、志賀高原",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐檜や白檜の密生した梭葉草の多い小山を二つ踰えて、三つ目の山に懸った。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲武信の頂上から望見した所では、距離も近く登り降りも少ないので、容易に達せられそうに想えるが、さて木立の中に這入ると、白檜の若木が透間もなく生えているので、通過に困難だ。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "栂や白檜の大木が茂っているが、思いの外登り易い。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小繋川　琴牛岳ノ南ヨリ出、白檜渓（大烏帽子ノ山脚刃物ヶ崎ノ岩峡ニ発ス）ヲ合セ、東流奈良沢ニ入ル。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白檜渓というのが刃物ヶ崎の岩峡から発源しているが、これは其東側の岩巣から発して北流して小繋に合する沢のことであろう。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千九百米を超えた山腹であると、土地の人がブサと呼んでいる大白檜の純林が見られることもあるが、これは寧ろ稀であった。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小繋沢が東方に発源すとあることや、又小繋川の条に白檜渓が大烏帽子の山脚刃物ヶ崎の岩峡より発すとある事などから推せば、朝日岳の北にある千七百四十四米の峰が大烏帽子らしく考えられる。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又二つ程瘤を上下して白檜の疎林に切明けの通じている高まりを踰えると池がある。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾根通りは白檜、万作、偃松、石楠の藪であるから、絶えず左側の草地から草地へと縫うように辿って行く。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三角点の東から北へかけては主として二十尺前後の白檜の森林であって、西から南へかけては岩銀杏を主とした草原である。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾根は白檜の森林が時折東からも西からも延び上って、中央の部分で結び付いていることもあれど、概して東側に草地が続いて、尾根上の平な所には多くは小池が存在する。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此附近は大白檜の大木が少くない。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予定ではこれから大白沢山を経て景鶴山に登り、然る後尾瀬ヶ原に下る計画であったが、山頂まで白檜の森林に掩れた藪の深い様子を眺めては、到底縦走を続ける勇気もなく、近い大白沢山もススケ峰も一瞥を与えたのみで、鞍部から猫又川へ下ってしまった。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫を踰えると右側から次第に白檜の疎林が押寄せて来る。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時折両側の白檜の林に蹈み込んで見るが、まだしも陣竹の方が相手にし易い。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は此処から西に白檜の林中を下ること十五、六分で水のある所に野営し、翌日は其日の中に柳淀へ帰ろうとして、一向距離の点にのみ拘泥したので、終に大高へ登る機会を逸してしまったのである。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小高大高間の山稜も陣竹と白檜の林とが入り交っているようであるが、大高の円錐状をなした斜面は、至仏山のと同じ色の岩の堆積で、所々に一団の偃松か真柏らしいものが生えている。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上の北側には白檜の若木に雑って偃松が生えていた。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白檜の若木が邪魔になって困った。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ一つ入念にしらべてみたか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
