[
  {
    "uuid": "a0bdbf8e-9b70-57aa-99e9-0d5b7cad87a1",
    "entry": "調べ",
    "reading": {
      "primary": "しらべ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-接尾辞"
      ],
