    },
    "definitions": [
      {
        "index": 1,
        "gloss": "investigation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一枚書くのに、二、三度は、辞林を調べている。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、文章をゆっくり調べて読む癖があるので、とても読み切れない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前日、新宿の百貨店へ行って結納のおきまりの品々一式を買い求め、帰りに本屋へ立寄って礼法全書を覗いて、結納の礼式、口上などを調べて、さて、当日は袴をはき、紋附羽織と白｜足袋は風呂敷に包んで持って家を出た。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暦を調べて仏滅だの大安だのと騒ぐ必要は無かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵へはいって、いろいろ書きものを調べてみた事があった。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へたな見透しなどをつけて、右にすべきか左にすべきか、秤にかけて慎重に調べていたんでは、かえって悲惨な躓きをするでしょう。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉の俳句においては、言葉がそれ自身「咏嘆の調べ」を持ち、「歌うための俳句」として作られている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雲に鳥」という言葉の軽く果敢ない音律によって構成され、そしてこの「調べ」の構成が、それ自ら句の詩情するリリシズムを構成しているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に芭蕉も弟子に教えて、常に「俳句は調べを旨とすべし」と言っていたという。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「調べ」とは西洋の詩学で言う「韻律」のことであり、言葉の抑揚節奏する音楽のことである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉が常に「調べ」を俳句の第一義とし、「声のしおり」と「心のしおり」を不離の関係に説いたのも当然である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日はポツオリに行って腹立たしくうるさい案内者に悩まされながらセラピスの寺の柱に残る地盤昇降の跡を見、ソルファタラ旧火口の噴煙を調べ、汚い家でスパゲッティの昼食を食って、帰りの電車で、贋銀貨をつかまされた外にはあまり人間味のある記憶が保存されていない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか調べてみたいと思うけれどもこれからでは到底駄目であろう。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばある庭のある桜の開花する日を調べてみると、もちろん特別な年もあるが大概はある四五日ぐらいの範囲内にあるのが通例である。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "開花当時の気温を調べてみても必ずしも一定していない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは毎日一日役所の殺風景な薄暗い部屋にのみ籠っているし、日曜と云っても余計な調べ物や内職の飜訳などに追われて、こんな事を考えた事も少ないが、病んで寝てみると、急に戸外のうららかな光が恋しくて胸をくすぐられるようである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藏へはひつて、いろいろ書きものを調べてみた事があつた。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へたな見透しなどをつけて、右すべきか左すべきか、秤にかけて愼重に調べてゐたんでは、かへつて悲慘な躓きをするでせう。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、本題に立ち帰つて、「どうすれば、真実な意味の、強いプロレタリア文学が生れるか」　私は、調べた芸術とか、プロレタリアリアリズムとか、難かしいもつともらしい文句から、全つ切り、傍道へ外れ込んだ。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "本田家の邸内を護衛していた、小作人組合に入っていない、青年団の青年たちや、消防組員までも、一応は取調べを受けた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "消防組、青年団は、何のために護衛し、非常線を張り且つ（調べられる）か？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族の者とても、取調べを受けない訳には行かなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前の話であるが、『藪柑子集』中の「嵐」という小品の中に、港内に碇泊している船の帆柱に青い火が灯っているという意味のことを書いてあるのに対して、船舶の燈火に関する取締規則を詳しく調べた結果、本文のごとき場合は有り得ないという結論に達したから訂正したらいいだろうと云ってよこした人があった。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ある僕の全く知らない人の年々に受取る年賀はがきの束を僕に貸してよこせば、それを詳しく調べた上で、その人の年恰好、顔形、歩き振り、衣服、食物の好みなどを当てて見せる」という。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで思い出したのは、関東大震災のすぐあとで小田原の被害を見て歩いたとき、とある海岸の小祠で、珍しく倒れないでちゃんとして直立している一対の石燈籠を発見して、どうも不思議だと思ってよく調べてみたら、台石から火袋を貫いて笠石まで達する鉄の大きな心棒がはいっていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にこういう空間曲線を作る事は厄介であるから、その代りにこの曲線をＸＺ面とＹＺ面に投射したものと二つを画いて調べる外はないのである。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近な歌集の中から口調のいいと思うのと、悪いと思うのとを選り分けて、おのおのに相当する曲線を画いてみて両者の間に何か著しい特徴が線の上から見えるかと思って調べてみた。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の調べた中で口調のいいと思ったのには、初めに長い波がつづいて終りに短いのがあるか、あるいはその反対のが多いようであった。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと沢山の材料について調べてみたいと思ったきりでそのままになっている。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし出来るならば、多数の歌人が銘々に口調のいいと思う歌を百首くらいずつも選んで、それらの材料を一纏めにして統計的に前述の波数や波長の分配を調べてみたら何かしら多少ものになるような結果が得られはしないかと考えるのである。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
