[
  {
    "uuid": "a997e39b-3a4c-5c06-b8ed-2057abd4669d",
    "entry": "収益",
    "reading": {
      "primary": "しゅうえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
