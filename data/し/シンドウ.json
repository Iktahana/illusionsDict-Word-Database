[
  {
    "uuid": "7ef30d71-5900-56b7-a718-aa1f272315e5",
    "entry": "振動",
    "reading": {
      "primary": "しんどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
