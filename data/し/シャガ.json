    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cargo unloading",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "沖のほうをふりかえると、ノアの一族を運んできた第二神路丸は、浅瀬の海から立ちあがるドロンとした真昼の霧に包まれて船体を霞ませ、島の主計科の兵隊が裾から火がついたような騒ぎをしながら貨物を卸下していた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚がそよそよと伸びるのが肉眼でも判るほどだから、と真顔で教えたら、だまってしゃがんで僕の顎を皿のようなおおきい眼でじっと見つめるじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端に乞食が一人しゃがんで頻りに叩頭いていたが誰れも慈善家でないと見えて鐚一文も奉捨にならなかったのは気の毒であった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "端艇へ飛びのってしゃがんで唾をすると波の上で開く。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻はそこへしゃがんで熱心に拾いはじめる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は関わずに、すぼめて逆さに立てた蝙蝠傘を支えにして、しゃがんで休む。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向ふの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらゐの活字を次から次と拾ひはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは、しばらくきまり悪そうに、しゃがんで水を見ていたけれど、とうとう立って、「鬼っこしないか。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はしゃがんで籠を倒にして数を数えてから小さいのはみんなまた籠に戻しました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二は汗を拭いて、しゃがんで何べんも水を掬ってのみました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしゃがれた声で早口に罵りはじめ、同室の婦人を指しては激烈に挑戦した。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぶつぶ絣の単物に桃色のへこ帯を後ろにたれ、小さな膝を折ってその両膝に罪のない手を乗せてしゃがんでいる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻も台所から顔を出して、「三人がよくならんでしゃがんでること、奈々ちゃんや、鶏がおもしろいかい、奈々ちゃんや」　三児はいちように振り返って母と笑いあうのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三歩あるいてはしゃがみ、そして何か拾っている。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんま上下二百文」という呼び声も古い昔になくなったらしいが、あのキリギリスの声のようにしゃがれた笛の音だけは今でもおりおりは聞かれる。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しく鷹揚な猫で、ある日犬に追われて近所の家の塀と塀との間に遁げ込んだまま、一日そこにしゃがんでいたのを、やっと捜し出して連れて来たこともあった。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花火船の艫にしゃがんでいた印半纏の老人は、そこに立ててあった、赤地に白く鍵屋と染め出した旗を抜いて、頭の上でぐるぐると大きく振り廻した。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに一人物腰などからかなりの老人らしく思われるのがやって来て、私の右にしゃがんでしばらく黙って見ていたが、やがてこんな問答がはじまった。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所へ入ってしゃがんでいると直ると云われてそれを実行したことはたしかであるが、それがどれだけ利いたかは覚えていない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、ここへ来ておくんなさい」　半七は彼を師匠の墓の前へ連れ戻して、二人は草の上にしゃがんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧民窟の掘立小屋の高粱稈の風よけのかげでは、用便をする子供が、孟子も幼年時代には、かくしたであろうと思われるようなしゃがみ方をして、出た糞を細い棒切でいじくっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸がへしゃがれるようで、息をすることも、出来なかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "針金の鳥籠が踏みへしゃがれていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "墜落した飛行機に棟を折られた民屋は、甲羅をへしゃがれた蟹のようにしゃがんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには、落盤にへしゃがれるか、蝕ばまれた樹が倒れるように坑夫病で倒れるか、でなければ、親爺のように、ダイナマイトで粉みじんにくだかれてしまうかだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へしゃがれた蟹のように、骨がボロ／＼に砕けていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬鹿々々しい上ッつらの体裁ばかり作りやがって、支柱をやらんからへしゃがれちゃったんじゃないか！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八番坑のへしゃがれた奴が、岩の下に見えている。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガドルフはしゃがんでくらやみの背嚢をつかみ、手探りで開いて、小さな器械の類にさわってみました。",
