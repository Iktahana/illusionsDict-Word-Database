    "definitions": [
      {
        "index": 1,
        "gloss": "fringed iris (Iris japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "林や竹藪の中に屈まる射干、春蘭のような花すら美しき遠つ世を夢みている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "射干にも似、菖蒲にも似たる葉のさま、燕子花に似たる花のかたち、取り出でゝ云ふべきものにもあらねど、さて捨てがたき風情あり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "脇へ出て見ると射干が一株ある。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "射干があつたとて不思議ではないが爺さんの説明が可笑しいのだ。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "射干のすぐ上である。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "射干が急に延び出して赤い花が目前に開くのを見る樣な心持である。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑中休暇の後であつたといふのは庭に射干の草叢があつたので記憶して居る。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分垣根に簇生して居た射干の花を母が切つて佛壇へ供へるので射干の花が僕の腦髓に深く印象され且つ之を好むやうに成つたのであつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其射干の花が皆莢になつて居た頃に其百姓家へ移つたのであつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも射干らしいので何だときくと「あゝ左樣でございました、一寸ランプを拜借致します」　と障子の内側の机に載せてあつた僕のランプを點けて立つた儘引つ込ませてあつた心を出してそこへ差しつけた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしますと母が其では國府田さんにして見ましたのでございますがお氣に召しますかどうかお尋ねしてからと思ひまして此所へ出して置きましたのでございます」　といつてランプを机へもどして蚊帳の釣手を一隅外してその射干の花を掛物の側へ置いた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は射干の花を見ながら正服をとる。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例を挙ぐれば彼が自筆の新花摘に射干して※く近江やわたかなとあり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "射干は「ひおうぎ」「からすおうぎ」などいえる花草にして、ここは「照射して」の誤なるべし。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村が照射と射干との区別を知らざるはずはなけれど、かかることに無頓着の性とて気のつかざりしものならん。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭前に咲ける射干を根ながら掘りて左千夫の家土産とす。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅瓶に射干一もとを挿む。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "九谷焼の花瓶に射干と白い夏菊の花を投込に差した。",
              "citation": {
                "source": "住吉祭",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例を挙ぐれば彼が自筆の『新花摘』に射干して※く近江やわたかなとあり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "射干は「ひあふぎ」「からすあふぎ」などいへる花草にして、ここは「照射して」の誤なるべし。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村が照射と射干との区別を知らざるはずはなけれど、かかる事に無頓著の性とて気のつかざりしものならん。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後に続いたのは反射干渉の結果の圧力だったろうけれども」「日本ではこんなことを知らなかったのかい？",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりを罩める射干玉の夜陰に、なんのことはない、まこと悪夢の一場面であった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚がそよそよと伸びるのが肉眼でも判るほどだから、と真顔で教えたら、だまってしゃがんで僕の顎を皿のようなおおきい眼でじっと見つめるじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端に乞食が一人しゃがんで頻りに叩頭いていたが誰れも慈善家でないと見えて鐚一文も奉捨にならなかったのは気の毒であった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "端艇へ飛びのってしゃがんで唾をすると波の上で開く。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻はそこへしゃがんで熱心に拾いはじめる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は関わずに、すぼめて逆さに立てた蝙蝠傘を支えにして、しゃがんで休む。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはその人の卓子の足もとから一つの小さな平たい函をとりだして向ふの電燈のたくさんついた、たてかけてある壁の隅の所へしゃがみ込むと小さなピンセットでまるで粟粒ぐらゐの活字を次から次と拾ひはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこは、しばらくきまり悪そうに、しゃがんで水を見ていたけれど、とうとう立って、「鬼っこしないか。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
