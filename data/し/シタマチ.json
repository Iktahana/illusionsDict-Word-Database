    "definitions": [
      {
        "index": 1,
        "gloss": "low-lying part of a city (usu. containing shops, factories, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若い丸髷の下町式マダムが弁慶縞の上っぱりで、和装令嬢式近代娘を相手に、あでやかにつややかに活躍している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下町は昨日の祭礼の名残で賑やかな追手筋を小さい花台をかいた子供連がねって行く。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の下町の若旦那らしい一團が銘々にカメラを持つてゐて、思ひ思ひに三脚を立てゝ御誂向の瀧を撮影する。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は東北のＳという城下町の表通りから二側目の町並を歩いていた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいぶ以前から四郎は、最初出現したＳ――の城下町にも飽いて、五六里｜距った新興の市へ遊びに行った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この物語を書き記す作者のもとへは、下町のある知人の紹介で和歌を学びに来たのであるが、そのとき彼女はこういう意味のことを云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妓はそれまでの指導の礼だといって、出入りの職人を作者の家へ寄越して、中庭に下町風の小さな池と噴水を作ってくれた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立っていた中年の下町女が何気なしにバスの間を覗いていたがふと自分の前の少女を見付けてびっくりしたような顔をして穴の明くほど見詰めていたようである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその時刻にはもうあの恐ろしい前代未聞の火事の渦巻が下町一帯に拡がりつつあった。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　ある城下町Ｓ＝街角　立札。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は、どこか下町のビルヂングに支店を出すことに熱意を持ちながら、小鳥を飼うのを道楽にしていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所はまだ下町の中央に未練があって、毎日、その方面へ探しに行くらしかった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅夜に瀟洒な鉄線を組み立てている清洲橋を渡って、人形町の可愛らしい灯の中で青苦い香気のある冷し白玉を喰べ、東京でも東寄りの下町の小さい踊り場を一つ二つ廻って、貝原はあっさり小初の相手をして踊る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが都会人の気の弱いものが、一たん飜ると思い切った偽悪者になることも、小初はよく下町で見受けている例である。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　下町の袋小路にあるホテルの一室ヘ、僕は僕の恋心を監禁してしまった。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "山下町の支那語韻の街まで彼女を追跡すると支那劇場の喧噪な音楽の前でマリは東洋族を驚かすような音を立てて倒れると、地上を寝床にして唇から泡を吹きながらタヌキ寝人を始めた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみよの兄という人が下町のある大店に勤めていて、その兄の方から月々の仕送りを受けているのだと母のおちかは吹聴していたが、その兄らしい人が曾て出入りをしたこともないので、近所ではそれを信用しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを教えてやろうと思って、わざわざ下町からのぼって来たんだぜ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でいちばん年とった純下町型のＹどんは時々露骨に性的な話題を持ち出して若い文学少年たちから憤慨排斥された。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう点では、下町の素人の芝居好きの劇評のほうがかえって前述のごとき著名なインテリゲンチアの映画批評家の主観的概念的評論よりもはるかに啓発的なことがありうるようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼人だってどんな具合でここへ漂って来まいものでもない、』など思いつづけて坂の上まで来て下町の方を見下ろすと、夜は暗く霧は重く、ちょうどはてのない沼のようでところどころに光る燈火が燐の燃えるように怪しい光を放ちて明滅していた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し大庭真蔵は慣れたもので、長靴を穿いて厚い外套を着て平気で通勤していたが、最初の日曜日は空青々と晴れ、日が煌々と輝やいて、そよ吹く風もなく、小春日和が又｜立返ったようなので、真蔵とお清は留守居番、老母と細君は礼ちゃんとお徳を連て下町に買物に出掛けた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外から下町へ出るのは東京へ行くと称して出慣れぬ女連は外出の仕度に一騒するのである。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時過ぎて下町行の一行はぞろぞろ帰宅って来た。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "礼ちゃんが新橋の勧工場で大きな人形を強請って困らしたの、電車の中に泥酔者が居て衆人を苦しめたの、真蔵に向て細君が、所天は寒むがり坊だから大徳で上等｜飛切の舶来のシャツを買って来たの、下町へ出るとどうしても思ったよりか余計にお金を使うだの、それからそれと留度がない。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "住居は愛宕下町の狭い路次で、両側に長屋が立っています中のその一軒でした。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝の新聞で見ると実際下町ではひさしの瓦が落ちた家もあったくらいでまず明治二十八年来の地震だという事であった。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い曇天無風の夜｜九段坂上から下町を見るといわゆるロンドンフォッグを思わせるものがある。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが歌舞伎芝居が好きで、わけて田之助びいきの処から、其の楽屋に出入りしているうち同じ贔負の国太郎と知り合い、官吏の家庭とはまるで世界の違う下町生活の話を聴いて異常な好奇心と憧憬から自分から進んで黒繻子の襟のおかみさんになったのであった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くの山の手のお嬢さん気質と、全くの下町の坊っちゃん気質と共通するところがあって彼女は国太郎にナイーブなところを見付けていた。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
