        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「叔母ソフィが小ロシアの曲をピアノで弾いているので、それが私に田舎の家を思わせる。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第一の敵は、行先が小ロシアの諸県に接近していることで、あちらでは周知の如く、酒の販売が自由に許されていますからね。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "小ロシアの晴々とした皮肉。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーゴリの小ロシアの小品のようなロシア的神秘あり。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙの部屋、自分が先見たときとは違って壁に地図があったり、小ロシア風の壁かけの小さいのがあったりして、大変居心地よくなって居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小ロシア風の刺繍壁かけ、この下には、壁をぬり直して大きいしみがかくされて居るのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は典型的な小ロシア人で、そろそろ怠け癖がつきだしたから、この際性根を叩き直す必要がある。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェーホフは自分を小ロシア人と手紙の中で呼んでいる。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリコフの賑かな小ロシア風な町の様子も。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
