    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese white birch (Betula platyphylla var. japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕がドストイェフスキイを讀んだ頃は、丁度｢白樺」の一派が活躍して、人道主義が一世を風靡した時代であつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白樺派の人たちは、トルストイとドストイェフスキイとを竝立させて、文學の二大神樣のやうに崇拜して居た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がド氏の名を初めて知り、その作品を讀む機縁になつたのも、實は白樺派の人に教はつた爲であつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれを讀んだ後に、僕は白樺派の文學論を輕蔑した。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "單に人道主義といふ如き感傷觀で、二者を無差別に崇拜する白樺派のヒロイズムは、僕にとつてあまり子供らしく淺薄に思はれた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも書いた通り、この時代は白樺派の活躍した全盛時代だつたので、自然その影響を受けたらしく、山村君や室生君等やの詩にも、多少人道主義的傾向が現れ、トルストイズムの臭氣が濃厚だつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに僕はトルストイが嫌ひであり、且つ白樺派のジャーナリズムに輕侮の反感を抱いて居たので、此等の友人等に向つて、僕は大いにドストイェフスキイの惡靈的神祕文學を推薦した。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の讀み方によるドストイェフスキイは、心理上でポオと共通し、思想上でニイチェ、ショーペンハウエルと類縁するところの作家であつたが、友人たちの見たドストイェフスキイは、やはり白樺派の人と同じく、人道主義的に見たそれであつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "單にドストイェフスキイばかりでなく、白樺派の偶像としてあれほど流行したトルストイさへ、少しも本質的には理解されて居なかつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡兎はポンと跳んで、すれずれに立つてゐる二本の白樺の間を摺り抜けた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牝狐は今にも彼を捕へさうだつたのだが、白樺の間に挟まつてしまつて、進むことも退くことも叶はなくなつた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢車草、車百合、ドウダンなどが、栂や白樺の、疎らな木立の下に、もやもやと茂っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺や五葉松は、制裁もなければ、保護もなく、永えに静粛に、そして厳格に、造化の大法を、寸分容赦なく行ってゆくように、この自然の王国から、定まれる寿命を召されて、根こそぎに、谷の中にたわいなく倒れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "栂、樅、唐檜、白樺などは、山の崕に多く、水辺には、川楊や、土俗、水ドロの木などが、疎に、翠の髪を梳っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺の痩せた稚い樹が出て来て、その中から山桜の花が、雪のように咲いている、四月の色は北岳の北の尾根から、信濃金梅の傾斜を伝わって、この森林にまで、流れ込んでいる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱樺の火は燃え出した、その明るくなることは、花が発くのと同じで、万象の色が真の瞬間に改まる、槍と穂高と、兀々した巉岩が、先ず浄い天火に洗われて容を改めた、自分の踏んでいる脚の下の石楠花や偃松や、白樺の稚いのが、今眠から醒めたというように朝風に身振いしてソヨソヨと顫った、天地皆新しい。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺の薄皮が、隣りの牧夫によって戯むれに剥がれた時、君はその緑色の冷たい靱皮の上に、繃帯をしてやるだらう。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　谷間の白樺のかげに、穴が掘られてあった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の将校が軍刀の柄に手をかけて、白樺の下をぐる／＼歩いていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校は、穴や白樺や、兵卒の幾分輝かしい顔色を意識しつゝ、なお、それ等から離れて、ほかの形而上的な考えを追おうとしている様子が見えた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、本能的に白樺の下へ行くのを忌避していた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老人は、白樺の下までつれて行かれると、穴の方に向いて立たせられた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の病院からは、谷間の白樺と、小山になった穴のあとが眺められた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗島は、時々、院庭へ出て、白樺のあたりを見おろした。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足あとは血を引いて、一町ばかり行って、そこで樹々の間を右に折れ、左に曲り、うねりうねってある白樺の下で全く途絶えていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペーチカへ、白樺の薪を放りこんだワーシカは、窓の傍によって聴き耳を立てた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武石は、ペーチカに白樺の薪を放りこんでいた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペーチカの中で、白樺の皮が、火にパチパチはぜった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さきから、雪を投げていた男が、うしろの白樺のかげから靴をならしてとび出て来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『徒然草』の「あやめふく頃」で思い出すのはベルリンに住んではじめての聖霊降臨祭の日に近所の家々の入口の軒に白樺の折枝を挿すのを見て、不思議なことだと思って二、三の人に聞いてみたが、どうした由来によるものか分らなかった。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
