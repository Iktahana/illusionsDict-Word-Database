    "definitions": [
      {
        "index": 1,
        "gloss": "chatting without a break",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友達と久しぶりに会って、止まらない喋くりが続いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の止まらない喋くりは、聞いていると楽しくて時間を忘れてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夜遅くまで、私たちは近況報告の喋くりに花を咲かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かげでぶつ／＼云っていず、自分からさきに出て、喋くりもし、みえを切ったり、華々しく腕を振りまわしたりやってみればいゝのだ。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の村ばかりでなく、隣村まで出かけて喋くりに行く。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことしたら、あの奥さんとこへ行って、何もかも喋くりちらしてやるから。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男、四人も殺してるンだつて凄いわねえ……」　喋くりながら、二人とも小桶を鷲づかみにして、ざアざアと湯をつかつた。",
              "citation": {
                "source": "暗い花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母　ハツハハ、あても、喋くりはしませんさけ、大丈夫どす。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの黄いろな、口喧しい口でもつて、ぱちくり喋くりながら。",
              "citation": {
                "source": "独楽",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になると、シャベルを持った女や、空のモッコをぶらさげた女の群が、三々五々しゃべくりながら長屋へ帰って行った。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日もなんだか訳の分らねえことしゃべくりながら人に行き逢っても挨拶もしねえで、そこら歩いていたっけから。",
              "citation": {
                "source": "一老人",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしな雀しゃべくりやがる、こないだミラがその窓をたたいて俺の名を呼んだばっかりに。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の男女がしゃべくり陽気に笑いながら周りに集まってきて、ほとんどの連中をすぐ見分けられたのはオデロン劇場で見ていたからだ。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "amusing two-person dialogue (form of stand-up comedy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
