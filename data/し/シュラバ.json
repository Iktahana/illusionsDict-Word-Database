[
  {
    "uuid": "4ce0d28b-53ff-5e09-8107-a7025d0b3387",
    "entry": "修羅場",
    "reading": {
      "primary": "しゅらば",
      "alternatives": [
        "しゅらじょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
