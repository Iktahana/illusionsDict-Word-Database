      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fighting scene",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕等は卑怯でみすぼらしく　生き甲斐もない無頼漢であるが僕等の親分を信ずるとき僕等の生活は充血する仲間のみさげはてた奴らまでがいつぽんぶつこみ　拔きつれまつすぐ喧嘩の、繩ばりの、讐敵の修羅場へたたき込む。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無殘な修羅場だつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "サア開戰だから江戸が大修羅場になるかと思へば、勝と西郷とで此危機をソツとコハして仕まつた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "累々とした被服廠の死屍、まるであの惨憺たる写真のとおりだが、これはまさしく現実に活動し、匍匐し、生殖し、吼哮する海獣の、修羅場の、歓楽境の、本能次第の、無智の、また自然法爾の大群集である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　砂上、黒雲の影、いよいよ盛んなる乱闘、　幾千の成牡（ブル）入り乱れてまさに修羅場の壮観となる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、とにかく、三万頭の膃肭獣により成る数千百のハーレムにおける割拠、争奪、保護、飛血、生殖、哺乳の大歓楽境｜大修羅場を現出する。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人をしかった上官にも見せてやりたかったんやが、『その場にのぞんで見て貰いましょ』と僕の心を威嚇して急に戦争の修羅場が浮んできた。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の追撃をふり切って夜目にもぼっと白い平沙の上を、のがれ去った部下の数を数えて、確かに百に余ることを確かめうると、李陵はまた峡谷の入口の修羅場にとって返した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その煙がすっかりぬぐわれると、そこはまさに恐ろしい修羅場と化していた。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "主よ、この船のごとき修羅場が、かつてあったでしょうか。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしは妙な人間で、江戸時代の若いときから寄席の落語や人情話よりも講釈の修羅場の方がおもしろいという質で、商売柄にも似合わないとみんなに笑われたもんですよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては往来の遑き目も皆｜牽れて、この節季の修羅場を独天下に吃ひ酔へるは、何者の暢気か、自棄か、豪傑か、悟か、酔生児か、と異き姿を見て過る有れば、面を識らんと窺ふ有り、又はその身の上など思ひつつ行くも有り。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根を越え、御殿場を越えて逃げて來た所謂罹災民の悲慘な姿で沼津驛前あたりが一種の修羅場化してゐる話をば人づてに聞いてゐたが、私が直接にさうした人を見たのはその六日の夕方、自宅の庭に於てゞあつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘタな修羅場読と同様ただ道具立を列べるのみである。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "過日のしけの時などは、下水を溢れて滝のように流るる汚水の中に、押し合いヘシ合って電車に乗る人々、自動車のタイヤの両側に破れむしろを袴のように垂らして、その中を押しわけて行く自動車の笛、雨の音、叫び声なぞいう修羅場が東京市中到る処に展開された。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、とてもわたくしが修羅場をうまく読むわけには行かないから、張扇をたゝき立てるのは先ずこのくらいにして、さて本文に這入りますと、なにを云うにも敵の大軍が野にも山にも満ち／＼ているので、さすがの日本勢もそれを望んで少しく気｜怯れがしたらしい。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮は生命さえも危ないという恐ろしい修羅場になっておりますから「これでは、どうも仕方がない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猛火の中の私たち",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、もう人々もさすがにゆっくり眠っていることは出来なくなったと見えて、中には眠りながら手だけは殴る形をして動かしている者もあり、踏んだり蹴ったり殴ったり修羅場みたいに傍若無人になぐり合っているうちに、また一同は眠り出した。",
              "citation": {
                "source": "時間",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおらかな感銘の漾っているのも束の間で、やがて四辺は修羅場と化す。",
              "citation": {
                "source": "冬日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、自らが解きえない問いを集団に「放」し、その場で調べなおしていくという方法を知った二人が、互いの愛を研鑽の俎上に載せることは、ともに修羅場に立ちそこで向かい合うことを意味しよう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "……けれどもそれは、まだ十分と経たない中に見る見る悽惨を極めた修羅場と化する……。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の甲板は、むろん一瞬間に修羅場と化していた。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家が千日前に近い関係上、ひまさえあると誰れかに連れられて私はこの修羅場を歩きまわった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんでの事に修羅場となりさうだつた座敷の眞中に、田原はどつかりと胡坐を組んだ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の通「真書太閤記」も一二節に芝居の衣をかけしまでにて、かたりに記せる修羅場の読切といへるには適すれども、むづかしき戯曲論など担ぎ出すべきものに非ず。",
              "citation": {
                "source": "明治座評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その越ガ谷で、見世物師同士がぶっつかって、思いがけなく飛んだ修羅場が始まったのさ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人獣争闘の大修羅場がこうして、邸内に展開された。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに次回が血腥く、いかに素晴らしい大修羅場が次々に行われ演ぜられるか？",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
