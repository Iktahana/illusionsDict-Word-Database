[
  {
    "uuid": "eaa5f2e8-1b32-5cd5-8389-6c0de427a90e",
    "entry": "沼沢",
    "reading": {
      "primary": "しょうたく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
