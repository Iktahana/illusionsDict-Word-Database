[
  {
    "uuid": "d36ddedf-c718-560c-8548-d0e92c8868e9",
    "entry": "昭和維新",
    "reading": {
      "primary": "しょうわいしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
