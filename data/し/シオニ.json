[
  {
    "uuid": "e7152fa2-e001-5f05-8808-5630af149f8b",
    "entry": "塩煮",
    "reading": {
      "primary": "しおに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
