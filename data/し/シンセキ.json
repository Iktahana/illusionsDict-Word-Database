[
  {
    "uuid": "ffdfde22-b309-5c8d-bca9-8ff174db0cd6",
    "entry": "親戚",
    "reading": {
      "primary": "しんせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "relative",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空想的な人物であつた彼女のお母さんは、アメリカで金持になつてゐる親戚に会ひに行つて、家を建てて貰はうなぞと考へた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚はネグロ達から家を逐ひ立てられてゐるといふ始末であつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "加ふるに黄熱病が猖獗を極めてゐて、ルモオルは船から船に移されて漸くのことで例の親戚の手に渡されたのだが、その親戚は貧乏になりはてちまつてゐたといふわけだ。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいトランクを二つ持つて、お土産物も沢山棚に積んでゐる此の男は、神経が太くて、まづまづ彼の親戚間では成巧者であるのに相違ない。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを電報打つたその親戚も知らないわけでもないのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、名ばかりの親戚で僕とは血のつながりなんか絶対にない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚の豊田様のお家に、ずつと世話になつてゐました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚の豊田様のお家に、ずっと世話になっていました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は此の頃、道を歩いてゐて秋津が自分の近くに飛んで来ると、それが親戚の人か何かのやうに思はれるのだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者の私も子供の時、大阪の親戚（旧家の商店）で見たのを記憶している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行て船室へ場を取りませねばと立上がれば婢僕親戚｜上り框に集いて荷物を車夫に渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへの之までの業蹟に就いては親戚の者共、いづれも心配してゐた樣である。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも親戚の老人などの中にはこの災難と厄年の転業との間にある因果関係を思い浮べるものも少なくないだろう。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の親戚を見舞うことは断念して松住町から御茶の水の方へ上がって行くと、女子高等師範の庭は杏雲堂病院の避難所になっていると立札が読まれる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰宅してみたら焼け出された浅草の親戚のものが十三人避難して来ていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前に父親も親戚も婿をとるようかなりお蘭を責めたものだが、こればかりはお蘭は諾わなかった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも燈明を上げたらという親戚の助言は聞かなかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚の妻女だれかれも通夜に来てくれた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚の妻女が二つになる子どもをつれてきて、そこに寝せてあればその子の呼吸の音がどうかするとわが子のそれのように聞こえる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年許り前に親父が未だ達者な時分、隣村の親戚から頼まれて余儀なく買ったのだそうで、畑が八反と山林が二町ほどここにあるのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七二年正月ケント州の Bedgebury の親戚の宅で泊っているうちに劇烈な熱病（rheumatic fever）に罹り、一事は心許ない容態であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七六―七七年の冬には、やはりフルードの弟子で、また親戚であった前記のマロックを助手として液体力学の実験をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "使い慣れた古道具や、襤褸や、貯えてあった薪などを、親戚や近所の者達に思い切りよくやってしまった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな物を東京へ持って行けるんじゃなし、イッケシ（親戚のこと）へ預けとく云うたって預る方に邪魔にならア！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　じいさんはそんなことを云うおしかにかまわず、篩いや、中古の鍬まで世話になった隣近所や、親戚にやってしまった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこにもまた、いろいろな手段がとられていて、先日東京から来たある友達の話によると、外米の入っていない県にいる親戚に頼んだり、女中さんの田舎へ云ってやったりして、送ってもらっている者がだいぶあるとか。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしはこのお亀の親戚の者でございますが、うけたまわりますれば、こちらの娘を御所望とか申すことで。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸には近しい親戚も無し、自分もだんだんに年をとって来るもんですから、お亀も娘のそばに行った方が好いという料簡になって、世帯をたたんで一緒に遠いお国へ行きましたよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "村では、殆んど親戚のうちに這入らないような親戚だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんは、こうしてしごとをしながら、自分のわかいじぶんのことや、また、遠方のしんせきのことや、はなれてくらしている孫娘のことなどを、空想していたのであります。",
              "citation": {
                "source": "月夜とめがね",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
