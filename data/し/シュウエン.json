[
  {
    "uuid": "01c197d2-c78f-5361-83fe-27e205906279",
    "entry": "周縁",
    "reading": {
      "primary": "しゅうえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fringe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのおもな原因は日本が大陸の周縁であると同時にまた環海の島嶼であるという事実に帰することができるようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱や手すりを白樺の丸太で作り、天井の周縁の軒ばからは、海水浴場のテントなどにあるようなびらびらした波形の布切れをたれただけで、車上の客席は高原の野天の涼風が自由に吹き抜けられるようにできている。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にして空氣は漸くその隅角と周縁とを冷却して黒變せしめ、そのさま黒き絲もて編める網に黄金を裹める如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄首里の人末吉安恭君二月号に載せた予の不毛婦女に関する説を読んで来示に、かの辺りで不毛をナンドルー（滑らか）と俗称し、少し洒落ては那覇墓と唱う、琉球の墓は女根に象る、普通その上と周縁に松やうず樹｜芒等を栽え茂らす、しかるに那覇近所の墓に限り多くは樹芒少なく不毛故の名らしい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大金字塔の当初の高さは一四五メートル、またその四辺の周縁の全長が九三一メートルであった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽雰囲気のこの部分には凝縮によって生じた微粒が恐らく多量に存するであろうということは、太陽板面の周縁に近づくほど光輝が弱くなることから推定される。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "周縁は、海水が土堤のように盛りあがっている。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渦は、毎時周縁のあたりが三十カイリの速さ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もう一段眺望を高めると、その沈んだ色彩の周縁が、コロナのような輝きを帯びていて、そこから視野のあらんかぎりを、明るい緑が涯もなく押し拡がってゆく。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その太湖石の重畳の間に、深さ三四尺の空地が延びていて、熊笹や雑草が周縁に生えていました。",
              "citation": {
                "source": "碑文",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその頭状花の周縁に射出する多数の舌状弁花をその光線に見立ったものだ。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福となるための現実的な入口は、却ってもっと部分的な、もっと一面的な、云わば充分に周縁しない一種不完全な幸福観念にあるのである。",
              "citation": {
                "source": "娯楽論",
                "author": "――民衆と娯楽・その積極性と社会性・――",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪廓は遮光器の周縁にして、横線は透かしなるのみ。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "製法は自然の扁平石の小さきものを採り、又は石を打ち缺き摩り※らして斯かる形と爲し、其上に燧石抔の尖りたる角にて切り目を付けしものならん●錘り石圖中｜精製石棒中央の下に畫きたるは自然の扁平石にして、周縁相對する部に人爲の缺損有り。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
