    "definitions": [
      {
        "index": 1,
        "gloss": "spring day (which seems long and quiet)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "春昼太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）工合い-------------------------------------------------------　四月十一日。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜の花や鯨も寄らず海｜暮ぬ　菜種畠の遠く続いてる傾斜の向うに、春昼の光に霞んだ海が見え、沖では遠く、鯨が潮を噴いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例として桜狩美人の腹や減却す人間に鶯鳴くや山桜　人里離れた深山の奥、春昼の光を浴びて、山桜が咲いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楚歌一身に聚りて集合せる腕力の次第に迫るにも関わらず眉宇一点の懸念なく、いと晴々しき面色にて、渠は春昼｜寂たる時、無聊に堪えざるもののごとく、片膝を片膝にその片膝を、また片膝に、交る交る投懸けては、その都度靴音を立つるのみ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく轆轤台の軋る音だけが春昼の閑けさの中に耳につく。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上下をすべて切って廻せば、水仕のお松は部屋に引込み、無事に倦飽みて、欠伸を噛むと雑巾を刺すとが一日仕事、春昼｜寂たりという状なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "楚歌一身に聚りて集合せる腕力の次第に迫るにもかかはらず眉宇一点の懸念なく、いと晴々しき面色にて、渠は春昼寂たる時、無聊に堪えざるものの如く、片膝を片膝にその片膝を、また片膝に、交る交る投懸けては、その都度靴音を立つるのみ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方一帯、春昼の埃臭さのなかに、季節に後れた沈丁花がどんよりと槙の樹の根に咲き匂っている。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りの思いがけなさに、渠は寂然たる春昼をただ一人、花に吸われて消えそうに立った。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "春昼の陽は暖かかった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春昼三月の昼のひかり、わが書斎に匍ふ藤むらさき。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「花魁から乞食、乞食から泥棒、その辺がオチでございましょう」「武士から乞食、乞食から泥棒、まずこの辺が恰好さ」　春昼である。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒い格子には春昼の陽が、鮮に黄色くあたっていた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、治部めを討ち取りましょう」「娘月姫は其方のものだ」「忝けのう存じます」　春昼の陽は暖かく光善寺の樓門を照らしていた。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "去歳、浅草大空襲後約一ヶ月春昼の一日を、私は七軒町新堀端辺の焦土に北斎、春章、清親らの掃墓をしてのち、御厩河岸なる梅若能楽堂跡に佇んだ。",
              "citation": {
                "source": "浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "春昼・二つの人出　木遣の音頭だ。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岳樺は寒い土地の木で、こんな処では根づくまいといわれたのだが、植えたときからみると倍以上にもそだち、今も若枝にみずみずと、柔らかそうな双葉が出そろって、春昼の日光をきらきらと映していた。",
              "citation": {
                "source": "つばくろ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ手伝ってあげよう、着替えをしてお稽古にいっておいで」春昼一　万三郎は井戸端で汗をながしていた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虻のかすかな羽うなりも鼓膜にひびくような春昼である。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、殺すといい、殺してくれと叫んでいた男と女が、気だるい春昼の納屋倉に、蒸れ合うばかりな情炎の餓鬼となって苦悶した。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "春昼、酒はよくまわる。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
