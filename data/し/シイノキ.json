    "definitions": [
      {
        "index": 1,
        "gloss": "any beech tree of genus Castanopsis",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ向う側の割竹を並べた垣の上に鬱蒼と茂って路地の上に蔽いかぶさっている椎の木らしいものだけが昔のままのように見える。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家なども随分と古い、柱が残らず椎の木だ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（雜誌・椎の木所載・室生犀星君の心境的推移について・參照）それは最近出版された彼の詩集『故郷圖繪集』を見た時、最も明白に直感された。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪ぎわの大きな椎の木の下に立って遠い街道の孤独の電燈を眺めた。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪沿いに大きな椎の木がある。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは喬い欅や樫や椎の木にまじつて椋の木や櫻の木などが鬱蒼と溪から山腹を覆つてゐた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が吹くと椎の木から去年の葉が留度なく散り飛んでいます。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……だって、椎の木婆さんが、糸車を廻す処ですもの、小豆洗ともいうんですわ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうか、椎の木の大狢、経立ち狢、化婆々。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾さんの家は西方町の椎の木界隈の汚い長屋に引込むで、一二年は恩給で喰ツてゐたが、それでは追付かなくなツて、阿母さんの智慧で駄菓子屋を始めた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　三月のある日、藤本の庭では、十畳の廊下外の廂の下の、井戸の処にある豊後梅も、黄色く煤けて散り、離れの袖垣の臘梅の黄色い絹糸をくくったような花も、いつとはなし腐ってしまい、椎の木に銀鼠色の嫩葉が、一面に簇生して来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "山果庭ニ落チテ、朝三ノ食｜秋風ニ※クとは申せども、この椎の実とやがて栗は、その椎の木も、栗の木も、背戸の奥深く真暗な大藪の多数の蛇と、南瓜畑の夥多しい蝦蟇と、相戦う衝に当る、地境の悪所にあって、お滝の夜叉さえ辟易する。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁椎の木のかげにゐられるあの白面の翁はどなたさまかの、ああ、なにか笑まれるやうな、月の光がさすわの。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人がつづいて横町へはいると、路ばたの大きい椎の木のこずえから、鴉らしい一羽の鳥がおどろかされたように飛び起った。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段｜地所が高くなって処どころ椎の木を植えた処があった。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊江はすぐ駈けあがった地所を右に切れて、そこの椎の木の下へ往って揮返った。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊江は椎の木の前からまた赭土の傾斜をすべりおりるようにおりて、ちょっとはしって揮返った。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子が気にしていた便所の屋根の前には、庭のすみにあった椎の木が移してあったりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "椎の木の古葉もすっかり散り尽くして、松も新しい緑にかわって、草も木も青い焔のようになった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上には大きな椎の木が、日の目のもらないほど厚い葉を茂らして、丸い形に、水ぎわまで張り出していた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薔薇が椎の木陰の下の、黒い髪のなかできわだって光っていた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊笹の中を水ぎわへおりて、例の椎の木の所まで来て、またしゃがんだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の椎の木に蜜蜂が二、三百匹ぶら下がっていたのを見つけてすぐ籾漏斗に酒を吹きかけて、ことごとく生捕にした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら、あなた、椎の木の下にしゃがんでいらしったじゃありませんか」「あなたは団扇をかざして、高い所に立っていた」「あの絵のとおりでしょう」「ええ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面の全体が焦茶色の調子でひきしめられていたが、枯れ朽ちた椎の木の上皮に養いを取って、かりそめの生を心ゆくばかり娯しんでいる菌の気持が、心にくいまでよく出ていたことを覚えている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、うちの庭からは菩提樹や椎の木立に遮られて、坊やの瞳には映らない。",
              "citation": {
                "source": "書斎と星",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処には竜見長庵と云う医者の邸があって大きな椎の木があった。",
              "citation": {
                "source": "義人の姿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉平の姿はその椎の木の下で見えなくなってしまった。",
              "citation": {
                "source": "義人の姿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽気な人っていうのは、私は土台淋しいのきらいさ、と口やかましく賑やかに暮して、それは小説なんか書かない人だわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
