[
  {
    "uuid": "7feb2952-333e-5246-b27f-c7d73b8e774c",
    "entry": "仕付け",
    "reading": {
      "primary": "しつけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
