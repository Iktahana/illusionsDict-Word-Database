        "examples": {
          "standard": [
            {
              "text": "彼はプロジェクトの失敗の責任を取り、進退伺いを提出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "進退伺いが出された後、会社は彼の処遇について検討を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "報道によると、彼は近いうちに進退伺いを出すらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "那美子夫人は」「改めて私から因果を含めましたが、これは未だに辞表どころか、進退伺いも出しません。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市教育部ではすでに、不可抗力によるもので、校長及び職員には責任はないと決定していた処なので、市当局も文相の言葉を遺憾とするし、西陣小学校の校長以下全職員は憤慨して、進退伺いをつきつけた。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "西陣学区会は職員側を支持しているので、結局進退伺いは却下されるだろう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲ではそう云ったが、孝之助はともかく進退伺いを出した。",
              "citation": {
                "source": "竹柏記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
