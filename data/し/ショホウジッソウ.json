    "definitions": [
      {
        "index": 1,
        "gloss": "concept that all things and phenomena reflect the truth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
