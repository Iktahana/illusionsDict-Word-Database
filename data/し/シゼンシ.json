[
  {
    "uuid": "5ae7b35b-bffd-5e46-a78d-3b9d13efeb18",
    "entry": "自然死",
    "reading": {
      "primary": "しぜんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
