    "definitions": [
      {
        "index": 1,
        "gloss": "photograph",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔雪とひのきの坂上に〕宮沢賢治雪とひのきの坂上に粗き板もてゴシックを辛く畳みて写真師の聖のねぐらを営みぬぼたと名づくる雪ふりていましめさけぶ橇のこらよきデュイエットうちふるひひかりて暮るゝガラス屋根",
              "citation": {
                "source": "〔雪とひのきの坂上に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つに繻絆一枚で腰掛けて老人の読んでゐた新聞に、三十何年とか撒水車を挽いてゐるといふ男の笑つて汗を拭いてゐる写真が通りがかりに見えた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝私は寝床の中で、夏らしく黒く撮れたその写真をみたのだつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「写真を、北京へ送ってやったのです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうこれから先方へ、申込みに行こうと思っているのですが、あなたのところに大隅さんの最近の写真がありませんか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「最近は、大隅君からあまり便りがないのですが、三年ほど前に北京から送って寄こした写真なら、一、二枚あったと思います。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はるかに紫禁城を眺めている横顔の写真。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "碧雲寺を背景にして支那服を着て立っている写真。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのお写真は、」部屋の長押に、四十歳くらいの背広を着た紳士の写真がかけられていたのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小坂氏は、ふり向いてその写真をちらと見て、「長女の婿でございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京から送られて来た写真を見ましたが、あれ以上進捗していないようです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いの家系と写真と、それから中に立った山田勇吉君の証言だけにたよって、取りきめられた縁である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすめられるままに、ただ阿呆のように、しっかりビイルを飲んで、そうして長押の写真を見て、無礼極まる質問を発して、そうして意気揚々と引上げて来た私の日本一の間抜けた姿を思い、頬が赤くなり、耳が赤くなり、胃腑まで赤くなるような気持であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、或る外国の新刊本をひらいてみたら、僕の友人の写真が出ているのを見て、おどろいた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アラ、来週はメーベルノーマンドの写真なのね、あたし今度は一人で来るわ」　予告のビラが横手の壁にあつたのをみて、Ｓ子はさういつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真店の看板を見る兵隊さん。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日私は活動写真で、菊の生長の状況を見せられた事がある。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし記憶の衰退率がどうにかなって、時の尺度が狂ったために植物の生長や運動が私の見た活動写真のように見えだしたらどうであろう。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃活動写真で色々な空中戦の壮烈な光景を見せられる。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族一同の写真を送ってくれたが、四十年前の亀さんの面影が今日でもそっくりそのままに残っているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例のボーイが cabin からいかがわしい写真を出して来て見せびらかしながら会食室へはいったと思うと、盛んに笑う声が洩れて来た。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絵の写真は『文章世界』に載せられた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで自然損害の一番ひどい局部だけを捜し歩いて、その写真を大きく紙面一杯に並べ立てるから、読者の受ける印象ではあたかも静岡全市並びに附近一帯が全部丸潰れになったような風に漠然と感ぜられるのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の隧道を抜けていよ／＼上高地の関門をくゞつたとき一番に自分の眼に映じた美しい見ものは、昔から写真でお馴染の大正池の眺めではなくて、丁度その時雲の霽間にその全貌を現はした焼岳の姿と色彩とであつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十九日　曇、午後雷雨　午前気象台で藤原君の渦や雲の写真を見る。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは普通の積雲とは全くちがって、先年桜島大噴火の際の噴雲を写真で見るのと同じように典型的のいわゆるコーリフラワー状のものであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとまた反対に向うへ行く人々の中には写真機を下げて遠足にでも行くような呑気そうな様子の人もあった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の隧道を抜けていよいよ上高地の関門をくぐったとき一番に自分の眼に映じた美しい見ものは、昔から写真でお馴染の大正池の眺めではなくて、恰度その時雲の霽間にその全貌を現わした焼岳の姿と色彩とであった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがために用いた天体図や写真に含まれていた星の数は百万を少し越えている。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "１　マルガリイダに内証でいつ写したものか、リンピイは、品物の一つ一つに、例の白熊テレサの裸体写真や、それから、テレサと黒輝石のような印度人の火夫との春画しゃしんやなんかを上手にひそめていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
