        "examples": {
          "standard": [
            {
              "text": "神経科学の進歩は、脳機能の解明に新たな光を当てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は神経科学の研究者として、認知症の治療法開発に貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近、神経科学に関する興味深いドキュメンタリーを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ワシントン大学でコンピューター科学と神経科学を専攻したアトキンソンは、卒業後、いったんは医学研究用のシステムを作る仕事についたが、ラスキンに誘われて一九七八年にアップルに入った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
