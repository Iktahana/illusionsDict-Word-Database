        "examples": {
          "standard": [
            {
              "text": "この統計モデルの信頼度は非常に高く、予測精度に優れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい部品の信頼度試験を行い、長期的な耐久性を評価した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アンケート結果の信頼度を高めるため、調査対象を拡大する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これが人間同士なら北の涯の者と南の涯の者の間にも、言葉は通じなくとも何とか意志を通ずる方法もあるし、相手の気持も能力も信頼度も、まず大体察知し得られる。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻への信頼度の強さにも因ろうが、私の性欲が受動的、女性的であることにも、大きな原因があるのではないか。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対の信頼度はあなたと同じですから。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならメッセンジャー新聞の信頼度は絶対だからだ。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
