    "definitions": [
      {
        "index": 1,
        "gloss": "commercial (on radio, TV, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腰を落ちつけたのは、東京にある特殊効果専門のＣＭ制作会社、アニメーションスタッフルームです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮沢りえが若さを謳うテレビＣＭをなんべん見せられるより、オレには関澤専務のパフォーマンスを一度見るほうが、表現の道具としてのＦＭ　ＴＯＷＮＳの可能性がよく分かる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりＣＭＬＱＴＰＡＩＮＳの十種である。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六八年十二月、ＡＣＭとＩＥＥＥがサンフランシスコで共催した、秋のジョイントコンピューター会議で、増大研究センターはＮＬＳのデモンストレーションを行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカのテレビＣＭ向けに目もくらむようなコンピューターグラフィックス（ＣＧ）を作っていたボブ・エイブルの作品に、藤井はこの時期目を奪われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のビールのＣＭが、そのあとに続いた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ばらの花の専門店のＣＭがあった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "次のＣＭがはじまり、声は中年の男性に変わった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新車展示会のＣＭが終わると、ＴＶの画面には、天井でゆっくりとまわっている扇風機が映った。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井で回転する、クラシックなスタイルの扇風機を専門に扱っている店のＣＭが、はじまった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
