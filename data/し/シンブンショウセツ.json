    "definitions": [
      {
        "index": 1,
        "gloss": "novel serialized in a newspaper",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
