    "definitions": [
      {
        "index": 1,
        "gloss": "ancient Chinese vehicle with a compass whose needle always pointed south",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
