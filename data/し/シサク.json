    "definitions": [
      {
        "index": 1,
        "gloss": "speculation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは抽象的でも具体的でもない、又あらゆる習慣、あらゆる思索の便宜に作られた言葉、あらゆる名辞以前にあるものだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "思索や学究や情熱なぞをどこに置き忘れて来たのか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ色々でこそ此の世が成立つのだらう……」――そんな客観的な考へで、私は自分が何かに付けて思索する癖のあることを、不幸かも知れないといふ半面の気持に強ひられて、好い加減でうまく胡魔化して置きたかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きるという事実の上に根を置いて、冷酷なほどに思索の歩みを進めて下さい。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、すべての思索の必然的制約として、概念的分析によるのほかはなかった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "往々考えが形而上的に走り、罷り違えば誇大妄想狂となんら選む所のないような夢幻的の思索に陥って、いつの間にか科学の領域を逸する虞がある。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず自身に取っては芸術上の問題を思索する事によって自分の専門の事柄に対して新しい見解や暗示を得る事も少なくないのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを何と形容したら適当であるか、例えばここに饒舌な空談者と訥弁な思索者とを並べた時に後者から受ける印象が多少これに類しているかもしれない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　ロダンさんは中年時代、シャトウ・チェリイから出て来た女弟子のカミイユ・クロオデル嬢との恋愛の破綻によって、思索上にもロダンさんの生理学にも余程の変化があったのだそうです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然障子があいたやうな氣がしたかと思ふと紋着羽織に袴をつけた抱月さんが、例の朝鮮髭をはやした頬のこけた、思索家的な奧深い光を持つ細い眼をした顏を靜かにその間から現して、どう云ふ譯だか何の詞もなく、蒲團の袖に鼾つくやうにして丁寧に頭をさげた。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の学者などの中にはほとんど年中、あるいは生涯貧しい薄暗い家の中に引き籠ったきりで深い思索や瞑想に耽っていたような人もあったらしい。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ簑虫とちがうのは、幾年かの後に思索研究の結果を発表して、急にあるいは徐々に世間を驚かした事である。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学芸術の研究は個人の努力と、それから独創的思索にたよるものだ。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　いわゆる頭脳のいい人はどうも研究家や思索家にはなれないらしい。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事が哲学やその他文科方面の研究思索について真実である事はむしろよく知られた事であると思うが、理化学の方面でもやはりそうだという事はあまりよく知られていないようである。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼の思索や行為はいつの間にか佯りの響をたてはじめ、やがてその滑らかさを失って凝固した。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くそのころの自分にとっては科学の研究は一つの創作の仕事であったと同時に、どんなつまらぬ小品文や写生文でも、それを書く事は観察分析発見という点で科学とよく似た研究的思索の一つの道であるように思われるのであった。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思索の形式が一元的であること。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはしばらく思索にふけつたふりをして眼を輕くつぶつたり短い頭髮のふけを拂ひ落したり、爪の色あひを眺めたりするのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはしばらく思索にふけったふりをして眼を軽くつぶったり短い頭髪のふけを払い落したり、爪の色あいを眺めたりするのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つだけでも充分な深い思索に値するだけの内容をもった事がらが、数限りもなくただ万華鏡裏の影像のように瞬間的の印象しかとどめない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のような、みずから求めて世間に義理を欠いて孤独な生活を送りながら、それでいて悟りきれずに苦しんでいるあわれな人間にとっては、ケーベルさんのような人が、どこかの領事館の一室にこもったきりで読書と思索にふけっているという考えだけでもどんなに大きな慰藉であったかしれないと思う。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして孤独にも孤独の痛快味がわれとわが空虚のうちを慰め潤おし、それが弾みとなって思索から思索へと累進するときに、層々の闇の中にときどき神秘なうす明りが待受けていて何か異香らしいものさえ鼻に薫じた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう歩行中でも彼の思索に探り入る習慣は立派な鍛錬となって、決してわきの刺戟によって思索の軌道を踏み外すようなことはなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は思索に思い入りながらすぐ寝てしまった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし慧鶴は、すべてに関らず、眼が覚めると同時に眠中の無意識へ織り入れた思索の糸を再び覚めた意識の軌道上に取出して、また糸口を繋いだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くれがたくれがたのおそろしさくりやのすみの玉葱ほのぐらきかをりに浸りて青き芽をあげものなべての罪はひき窓の針金をつたはる。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄命な花世の身のすえに同情するあまり、いくぶんの誇張もあるのだろうが、光実の肖像画で見る美しさくらいのことはたしかにあったのにちがいない。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて取り柄をいえば、縹渺たる響灘を望む景色のよさと、魚の新しさくらいのものであろう。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちのお手伝いをさせられる悔しさくらいは我慢するさ」「おやおや！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
