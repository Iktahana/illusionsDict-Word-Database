    },
    "definitions": [
      {
        "index": 1,
        "gloss": "employer's house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」――母の疳高い声が主家の方から聞えて来た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は主家の方へ出て行つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、従来のいわゆる統計物理学は物理学の一方の庇を借りた寄生物であったのであるが、今ではこの店子に主家を明け渡す時節が到来しつつあるのではないか。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅びた主家の家臣らが思い思いに離散して行く感傷的な終末に「荒城の月」の伴奏を入れたのは大衆向きで結構であるが、城郭や帆船のカットバックが少しくど過ぎてかえって効果をそぐ恐れがありはしないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主家の大きな門の前に来た。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂きことのなほこの上に積れかし　　限りある身の力試めさん　これは尼子十勇士の一人の山中鹿之助が主家の再興を図りましたけれども、ほとんど絶望であることが発見されてのち詠み出でた歌であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に何もかも話してくれたようであるが、用人とても主家の迷惑になるようなことは口外しなかったに相違ない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪野は小さい時分から、米の大問屋へ奉公にやられ、機敏に立ち働き、主人の信用を得ていたが、主人が亡くなり妻の代になってから、店を一手に切りまわしていたところから、今までの信用を逆に利用し、盛んに空取引の手を拡めて、幾年かの間に大きな穴をあけ、さしも大身代の主家を破産の悲運に陥れたものであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の主家に居る時、ほんの小僧の時、一度、若者になつてから二三度、無理やりに朋輩や先輩に誘はれて遊女屋へ足を入れたことはあつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから主家の小間使ひであつた大工の娘のお静といふ可愛い少女に暫らく人知れず懸想して居たことはあつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻のお辻も、主家の娘といふ点が、いくらか彼のプライドを緩和しただけで、たゞの町家の平凡な娘を、便宜上、妻にしたに過ぎないといふ気持ちばかりで終始してゐた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊丹の城主、荒木村重につかえて横目役を勤め、年久しく主家を泰山の安きに置いた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると文化年間、吉原の橋本楼に小式部太夫と云う妓がいて、それに三人の武士が深い執着をもって、主家を浪浪するもかまわず、通いつめて自分の有にしようとした。",
              "citation": {
                "source": "偶人物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎は大谷吉隆に就いて主家を悪く秀吉に思取られぬよう行届いた処置をした。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其実は主家の為に忠に死するに至つた者は終に何程も有りはし無かつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "主家に対する忠義の心の、よもや薄い筈の木沢殿ではござるまいが。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニ此の木沢左京が主家を思い敵を悪む心、貴殿に分寸もおくれ居ろうか、無念骨髄に徹して遺恨｜已み難ければこそ、此の企も人先きに起したれ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナ、御返答は……」「…………」「主家のためなり、一味のためなり、飽まで御返辞無きに於ては、事すでに逼ったる今」と、決然として身を少く開く時、主人の背後の古襖左右へ急に引除けられて、「慮外御免。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、これを土産に勇んで御主家へ戻ります。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、今度はわしがそなたを御主家まで送ってやりましょう』おくみ『送って貰うはうれしいけれど。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明方までにそなたも御主家へ戻らずば首尾が悪るかろう。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこをよう聴き分けて御念仏一筋を便りにおとなしく御主家へ帰って呉れ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしゃもう、御主家へは帰りますまい』源兵衛『こりゃまた乱暴な。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御主家へ戻って呉れ』おくみ『わたしゃ、どうあっても嫌じゃわいなあ』源兵衛『すりゃこれほどに頼んでも』おくみ『死んでもお傍を離れませぬ』源兵衛『帰れ』おくみ『いやじゃ、いやじゃ』（二人、また揉み合うところに、源右衛門の家の垣の中に声あって）×××『二人とも争うには及ばぬ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主家つづきに牛舎があり、中庭を隔てて、一層古びて頽れかけた茅舎の穀物納屋もあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、主家の外に牛舎か何かの建増しをしている露人の一戸があった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずかずかとその主家にはいり込み、納屋をのぞき、牛舎へ廻り、ほとんど傍若無人の限りを尽していた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利氏は終始事多くして、制度としては何の見るべきところもなし、北条氏は実権は之を保有せしにせよ、其状態は恰も番頭の主家を摂理するが如くなりしなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "源家に至りては極めて規模なく、極めて経綸なきものにして、藤原氏の如きは暫らく主家を横領したる手代のみ。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「知ってる奴でしゅか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
