    "definitions": [
      {
        "index": 1,
        "gloss": "defense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」五　吉永の中隊は、大隊から分れて、イイシへ守備に行くことになった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イイシへ守備中隊を出すのは、そこの連絡を十分にするがためであった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――吉永は、危険なイイシ守備に行ってしまうのだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この点呼に、もしもおくれる者があったら、その中隊を、第一中隊の代りに、イイシ守備に行かせること、そうしてくれ、罰としてここには置かない。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中隊がイイシ守備に行かなけりゃならんのは誰れのためだと思うんだ！",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等は、満洲や朝鮮をゴロツク間に、不逞なヨボや、苦力が、守備隊の示威演習や、その狂暴な武力によって取っちめられてしまうのを、痛快に思いつつ目撃して来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、ここに、そういう、日本帝国の守備隊が、来て呉れていないことを残念がった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、おとなの居留民達は、出兵請求の決議にかけずりまわり、一ツ一ツ印を集め、懇願書を出して、折角やってきて貰ったなつかしい兵士が、自分達のちっぽけな家とはかけ離れた、工場や銀行の守備に赴くのを、はたして、ペテンにひっかゝったように、憤ろしく、意外に感じなかっただろうか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次は、周囲の範囲を拡大した区域の守備工事だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士は守備区域の作業をつゞけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そういう私刑をやるのなら、工場の守備は御免を蒙る、と云い出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗みどろになって守備作業をつゞけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外の場所には、守備工事は施されなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居留民は、この守備区域内へやって来いというのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチ工場で、蒋介石の抗議による守備区域の障害物の撤退、南軍と、日本軍との衝突の危険、などについて、軍隊自身よりも、支配人が気をもんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間を三台の自動車に分けて乗らす、日本軍の守備区域を走る時には、山崎に云って、誰何されない交渉をした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二時間たって、現場から四十八｜粁距ったここで守備隊の出発防備隊の召集ときているんだ。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論まるきり、その人たちに留めさせる事の出来ない事は、解って、あきらめなければならないまでも、手筈を違えるなり、故障を入れるなり、せめて時間でも遅れさして、鷭が明らかに夢からさめて、水鳥相当に、自衛の守備の整うようにして、一羽でも、獲ものの方が少く、鳥の助かる方が余計にしてもらいたい。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先頭に進んで行き、敵の守備兵が固めている、玄武門に近づいて行った。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸に獅子、虎の狙うと同一に、入道鰐、坊主鮫の一類が、美女と見れば、途中に襲撃って、黒髪を吸い、白き乳を裂き、美しい血を呑もうとするから、守備のために旅行さきで、手にあり合せただけ、少数の黒潮騎士を附添わせた。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "公子　ところが、敵に備うるここの守備を出払わしたから不用心じゃ、危険であろう、と僧都が言われる。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』骸骨のいひも竭きざるに、死屍は脣なほ青褪め、『さらばわれ守備の兵にはやく告げて去らしめむ。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら寡婦のうち衣食に窮するままに、辺境守備兵の妻となり、あるいは彼らを華客とする娼婦となり果てた者が少なくない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡崎城守備　庵原元景等千余人緒川、刈屋監視　堀越義久千余人　十八日には今村を経て沓掛に来り陣し、ここで全軍の部署を定めた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸根砦攻撃　　　松平元康　二千五百人鷲津砦攻撃　　　朝比奈｜泰能　二千人援軍　　　　　　三浦備後守　三千人清須方面前進　　葛山信貞　五千人本軍　　　　　　今川義元　五千人鳴海城守備　　　岡部三信　七八百人沓掛城守備　　　浅井政敏　千五百人　更に大高城の鵜殿長照をして丸根鷲津攻撃の応援をさせる。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他占領した各処には、部将それぞれ守備を厳重にして居たのである。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶喜が二条城を去った後、永井｜玄蕃頭が、之を預り大場一心斎麾下の水戸兵二百人と、新選組百五十人が守備に任じていたが、大場は元来勤王思想があるので薩長と気脈を通じている容子があるので、近藤勇は憤慨して、十七日に二条を去って伏見に来て、其地の奉行所衛兵と合同して、警備の任に就いた。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから乗り込んだ青島守備隊の軍楽隊が艫の甲板で奏楽をやる。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、しゅびよく油を一｜合かいました。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、このむすめさんに、十二人りきがついて、しゅびよく雪の女王にかてますよう、のみものをひとつ、つくってやっていただけませんか。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
