    "definitions": [
      {
        "index": 1,
        "gloss": "fire department (in Japan, composed of on call civilian firefighters)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
