        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "裏白やゆずり葉を輪の表に縛り付けるか裏につけるかを議論していた。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、送音管を外して、それを倒さまに中央の回転軸に縛り付ける。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯の分も炊いて飯盒に入れたまま背嚢に押し込もうとしたが、到底余地がないので南日君が腰の周りに縛り付ける。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "囚人はあわてて兵士に合図を出して、将校を縛り付けるために駆けていった。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ自分の位置を知ることも、世事に縛り付ける愛着の力を超えて高みに昇ることもできぬまま、地縛霊となってしまったはずだ。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜寝るときは自分のつま先をベッドの柱に縛り付けるという昔の手を使ってみることに決めた。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰓から口にロープを通して、頭を舳先に縛り付けるのだ。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、わしをしばりつけるものは、なにもない。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分をぶん殴り、しばりつける人、ことごとくに、「いや、有難うございました。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、ねむっているあいだに、車からころげ落ちないように、荷をしばりつける綱を輪にして、じぶんのあごにひっかけておくことを忘れてはいけないのです。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この男の髪へ縄をつけて、はたもの（罪人を笞打つためにしばりつける刑具である）に男を後向きにしばりつけた。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日ほどで、笞のあとが、いえると、また同じ室につれて行って、はたものにしばりつけると、今度は、前よりもしたたかに八十打った。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、彼の半生を支配してパリにしばりつけるほどの魅力の根源となった婦人、彼によって描かれるばかりでなく、彼をして書かしめる力となった活溌な、美貌の歌手ヴィアルドオ夫人との微妙な関係を知らねばならない。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの社会こそ人間らしい立体的人間性の発展のためにつくしているのに、なぜ作家は、陳雲が諷刺しているような畸型的「家」に自分をしばりつける必要があるだろう。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "解放したい「自我」を詭弁の足かせでしばりつけることは、あまり悲しいことと思う。",
              "citation": {
                "source": "自我の足かせ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてうしろへ身を引き、合図の手をあげると、綱をもった幹部と会員とが女史のそばへより、女史の身体や手足を、むごいほどきつく椅子にしばりつける。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手などはうしろに組合わしてしばった上、さらにそれを椅子の背にしばりつける。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらにしっかりした岩を見つけてロープの端をしばりつけるのだ」「見物はあとにして、こっちへ集って下さい」　と、玉太郎がさけぶ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その椅子は重力に異常のあったときに、からだを椅子にしばりつけるための丈夫なバンドがひじかけのところについているものだった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはまたこの来助老人が筆持つ腕に重い石をしばりつけるほどにして書道のほうにも工夫を積んだ人と聞いていましたから、何か記念に書いてほしいと頼みました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいか、さきに、怪我人を梁へしばりつけるんだ。",
              "citation": {
                "source": "秋空晴れて",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの鉄柱にしばりつけるまえに、口に鉄管をふくませて舌を噛むことを拒いだという。",
              "citation": {
                "source": "せいばい",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは木の皮や壁の裂目に隠れるので、自分の体を巻いた糸で其処に自分の体をしばりつけるのだ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが両手の、ここが両足の、ここが首の、それぞれ身体をしばりつけるための革ひもです。",
              "citation": {
                "source": "流刑地で",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "受刑者は熱心に兵士に合図し、二人は将校をしばりつけるためにかけつけていった。",
              "citation": {
                "source": "流刑地で",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以上、めんどうなことを考えて自分をしばりつけること自体が既にもう一種の堕落だよ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の造園師は、植木の小枝に永久的の形がつく迄、それを竹の枠にしばりつけるという、一方法を持っている。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "烈風が画架を吹き飛ばそうとする勢いに、杭を打ち込んでしばりつける。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで二人は酒を呑んで話していたが、ＢはＡの油断を見すまして、突然襲いかかり猿ぐつわをはめ、手足を長椅子にしばりつける。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして黒眼鏡の四肢を、ぎりぎりと隅へしばりつけるとボートは、オールの唄のどかに、鉄の橋の下を辷るように潜って行く――　びっくりして、色を失った豆菊や若い妓はその橋の上を、今にもわっと泣き出しそうな顔をして、関内の街へ、走っていた。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
