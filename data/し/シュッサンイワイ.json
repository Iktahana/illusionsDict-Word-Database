      {
        "index": 1,
        "gloss": "celebration of a birth (usu. approx. one month after birth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
