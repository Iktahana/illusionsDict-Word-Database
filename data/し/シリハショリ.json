[
  {
    "uuid": "cbad1274-b5e8-5e9e-bc2e-2af06641191f",
    "entry": "尻端折り",
    "reading": {
      "primary": "しりはしょり",
      "alternatives": [
        "しりばしょり",
        "しりはしおり"
      ],
      "is_heteronym": false
    },
    "grammar": {
