    "definitions": [
      {
        "index": 1,
        "gloss": "newspaper company",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その後一時新聞社へもはいっていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体、戦前から戦後にかけて彼の筆役勤務の現役を終えた文人であって、この付近に雑誌社、新聞社の巣窟があった時代の習慣で足はおのずとここへ向く。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ新聞社の電気告知の綴文字が事件をたえまなく運搬した。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　伝書鳩がまた新しい事件をもって新聞社の楼上にまい下りた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今国民新聞社に勤む。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去んぬる十三日、相携へて京橋なる新聞社に出勤せり。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、すぐ近所の新聞社の二の面の（三の面の人は概して、飲みそうで飲まない）豪傑兼｜愛嬌者である。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の朝日新聞社の大展覧会でみた雅邦でもコケオドシとしか見えなかった。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "某新聞社からだという。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は別の新聞社から同じ事の問合わせであった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの硬派、軟派は、新聞社内の二つの区別じゃ勿論なかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間も或新聞社の人に話したが、言文一致體の語尾の「だ」と「である」との事で、予は「だ」といふと強く當り過ぎると思ふ。",
              "citation": {
                "source": "文章の音律",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ事がらが自然科学の事実に関する限り、それを新聞社会欄の記事として錯覚的興味をそそることだけは遠慮なくやめたほうがいいであろうと思う。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこかに人殺しがあった」という事実だけが正確でうそでなければ、それ以外の間違いについて新聞社に苦情を持ち込むほど物ずきな読者はまれであろうと思われる。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう実に不思議な現象の原因の一つは新聞社間の種取り競争に関連して発生するものらしく思われる。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞社のニュースの種取り競争が生み出す喜悲劇はこれにはとどまらない。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういういろいろの不思議な現象は、新聞社間の命がけの生存競争の結果として必然に生起するものであって、ジャーナリズムが営利機関の手にある間はどうにもいたし方のないことであろうと思われる。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の東京朝日新聞社の建物がなんだかさびしそうな顔をして立っているように思われるのであった。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞社にちょっと用事があったもので、……」　何の用事だろう。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞社に用事とは、大きく出たね。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたら、あの一団は、雑誌社か新聞社の人たちかも知れない。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い事、有楽町の新聞社に勤めていたという。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那さまは、三田の義塾を出た綺麗なおかたでして、いま朝鮮の京城で、なんとかいう可成り大きな新聞社を経営して居られるとかいう話でございます。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に新聞社へ宛てて神経衰弱がヒドクなったようだから一箇月ばかり静養して来る……という意味の届けを出して、警視庁の手の届かない遠い処へ飛ぶつもりでいるのだから万に一つも捕まる心配はない。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡の九州日報社という民政系の新聞社にいる頃、社員で酒を飲まないのは私一人であった。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦酒会社でも抜け目はない、新聞社と試合をすれば新聞に記事が出る……広告になると思ったものらしいが、それにしてもこっちの実力がわからないので作戦を立てるのに困ったと言う。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずだれよりもいちばん迷惑を感じたのは新聞社自身であったろうが、ここではそれは問題に入れるわけには行かない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の理想を実現させるためには新聞社はあらゆる実務や学術技芸はもちろん一般思想上の各方面について第一流の人たちを記者として網羅しなければならない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう大新聞社の経営を少数な資本家の手にゆだねるのは穏当ではあるまい、これはむしろ全国民自身か、少なくもその大部分の共同経営によるものとしなければなるまい。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこのような新聞社ができたとすれば、それは従来の意味の新聞社とはだいぶちがったものになる。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
