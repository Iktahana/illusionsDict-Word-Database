        "examples": {
          "standard": [
            {
              "text": "この地域は古くからリンゴの主産地として知られ、秋になると村全体が甘い香りに包まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "原料の主産地が記録的な干ばつに見舞われたため、今後の価格高騰が非常に懸念されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高級な畳表の主産地として名高いこの場所では、今でも職人が手作業でイ草を育てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども、それが地理的に接近しているのは、ちょうどその中心に、主産地であるエルツ山塊があるためにほかならないのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その農場は、北海道でも馬鈴薯の主産地といわれる地方の中心にある。",
              "citation": {
                "source": "農業物理学夜話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちがこの數年來冬毎に立てこもっていたニセコの山の山麓地帶は、北海道でも馬鈴薯の主産地の一つである。",
              "citation": {
                "source": "雪を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
