          "literary": [
            {
              "text": "自分の知ったことではない。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤の他人であって親の様に思われ子の様に愛するということは、無情な人の夢にも知ったことではない、先生と長塚との間柄は親子としてはあまりに理想的で、師弟としてはあまりに情的である、ゆえに予はこれを理想的愛子と名附けた。",
              "citation": {
                "source": "正岡子規君",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉虫　お前の知ったことではない。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「………」「人の喧嘩じゃ、身共の知ったことではない、嫌じゃ勝手にせいと申したら何とする？",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなた衆の知ったことではない。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女大臣、何をなさるのですの」「お前の知ったことではない。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "袴氏の知ったことではない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々の知ったことではないわ」　ことの済んだ後で、云い訳をしているのは、酔も何も醒めはてた権四郎の同輩たちだった。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛の色がきたないという偶然が彼の運命を支配したので、そんなことは彼の知ったことではない。",
              "citation": {
                "source": "黒猫",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "対自性によって論理的となるもの、それは恐らく構成的概念――それは論理的であった――であろう、把握的概念の与り知ったことではない。",
              "citation": {
                "source": "空間概念の分析",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今も明白にその反対の理由を話したばかりだが――第一、そういう内面的な経過は、僕の知ったことではない。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの知ったことではないのだから」と云った。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴れようと投げようと、人の知ったことではない。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ――それがどうなるかは、俺の知ったことではない。",
              "citation": {
                "source": "病室の幻影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことは俺の知ったことではない。",
              "citation": {
                "source": "病室の幻影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「合法、非合法の境は、そっちの勝手でどうにでもずらすんだから、私が知ったことではない」　マルクス主義作家として、飽くまでも合理的な文化建設のために働くことを任務とすると、自分は口述した。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが偶然間違ったからって、俺の知ったことではないじゃないか。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黙れ、そちの知ったことではない」「然し」「黙らぬか」「はい」　小太郎は立上った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前の知ったことではないわ。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "君なんか、君なんかの知ったことではない」　伯爵はいつもの伯爵とは別人のように、ごうまんな態度でいいはなった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "方福山にどういう意図があろうと無かろうと、吾々の知ったことではない。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのことは、彼女等や彼等の知ったことではない。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何も自分の知ったことではない、と私は思った。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気が短くていらっしゃろうと、お気が長くていらっしゃろうと、こっちの知ったことではないのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守を預かろうが、預かるまいが、間が抜けていようと、間が塞がっていようと、お前たちの知ったことではない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "空襲警報もどこ吹く風、バクゲキなどはわが身の知ったことではない。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼女が驚こうが驚くまいが、私の知ったことではない。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の知ったことではない。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小門が開いていたからよ」「だが、指定した、こんな時刻に……」「俺の知ったことではない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
