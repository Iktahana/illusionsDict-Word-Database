[
  {
    "uuid": "7f000637-6bfc-56b7-a6db-6a956d0a8470",
    "entry": "嫉妬",
    "reading": {
      "primary": "しっと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
