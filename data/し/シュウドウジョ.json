    "definitions": [
      {
        "index": 1,
        "gloss": "(Catholic) nun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
