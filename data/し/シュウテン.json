    "definitions": [
      {
        "index": 1,
        "gloss": "terminus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "２　私は下高井戸駅――玉川電車の終点で車を棄てた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校は下宿にばかりゐては胃が悪くなるから散歩の終点だと思つて通つてゐる。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ学校のことも勉強なさいよ」「えゝ……ハヽ……」「文学のことばかりせずに……」　汽車が支線の終点駅に着いた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がようやく冴えて来た、足許の岩では、偃松が近くは緑に、遠くは黯くなって、蜿ねっている、天外絶域の、荒れはてた瘠土にまで、漂って来た、緑の垂直的終点を、私は今踏んでいるのだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり各部門においては現在既知の知識の終点を究め、同時に未来の進路に対して適当の指針を与え得るものが先ず理想的の権威と称すべきものではあるまいか。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし特殊の題目について重なる学術国の重なる研究者の研究の結果を up to date に調べ上げて、その題目に対する既得知識の終点を究める事は可能である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは新しい研究という事はいくらも出来るが、しかしそれをするには現在の知識の終点を究めた後でなければ、手が出せないという事をよく呑み込まさないと、従来の知識を無視して無闇に突飛な事を考えるような傾向を生ずる恐れがある。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばタレースは始めて金字塔の高さを測るために、塔の影の終点の辺へ小さな棒を一本立てた。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍも終点であったがこのＥも終点であった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその辺りの地勢や人家の工合では、その近くに電車の終点があろうなどとはちょっと思えなくもあった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "満員の電車から終点へ下された人びとは皆働人の装いで、労働者が多かった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、ある終点からある一定時間ごとに発車する電車が、皆一様な速度で進行し、また途中の停留所でも一定時間だけ停車するように規定されたとする。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここだ、この音だ――と云ったその紳士の言を聞いた、松崎は、やっぱり渠等も囃子の音に誘われて、男女のどちらが言出したか、それは知らぬが、連立って、先刻の電車の終点から、ともに引寄せられて来たものだと思った。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの男は……」　どこに住んでいるのかなどと、根掘りそこのお内儀にきくと、なんでもここから一里半、市内電車の終点から未だ五町もある遠方の人で、ゆで玉子屋の二階に奥さんと二人で住んでいるらしい。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと電車の終点まで来た。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三厩はバスの終点である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番の八時の汽車で五所川原を立つて、津軽鉄道を北上し、金木を素通りして、津軽鉄道の終点の中里に九時に着いて、それから小泊行きのバスに乗つて約二時間。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "難波の終点についたのは正午頃だったが、大阪の町ははじめてのこと故、小一里もない生国魂神社前の丸亀の料理場に姿を現わしたのは、もう黄昏どきであった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "車掌に揺り動かされて眼を覚すと、難波ア、難波終点でございまアーす。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺り動かされて、眼がさめると、梅田の終点だった。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "難波へ出るには、岸ノ里で高野線を本線に乗りかえるのだが、乗りかえが面倒なので、汐見橋の終点まで乗り、市電で戎橋まで行った。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがまた、真岡、アイヌ語のモウカ「美しい波の上」という美しい語義を持った樺太西海岸での第一の市街から、南へ南へ、終点本斗を指して出た、や、それは今出たばかりの煙の、むくり、むくり、むくり、ぽっ、ぽっぽっである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "土田は名鉄の犬山口から分岐する今渡線の終点に近い。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この航路の終点でもあり、ナポレオン少年の新しい配流地でもある。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車に乗せるたんびに終点まで行ってしまうような健康な精神病者や痴呆患者が出来上る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
