[
  {
    "uuid": "16a94b70-9dfc-5d44-8d2a-3241011d389f",
    "entry": "赤熊",
    "reading": {
      "primary": "しゃぐま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
