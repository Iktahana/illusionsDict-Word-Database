[
  {
    "uuid": "5a4e3024-07f4-5127-83f2-c33934097c2c",
    "entry": "凌ぎ",
    "reading": {
      "primary": "しのぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(means of) enduring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "晃平が、先刻、未だ日の暮れないうち、朝飯の菜にとて、山款冬数十茎を折って来たのを、みんなして、退屈｜凌ぎに、繊維を抜いては、鍋へ投げ入れる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈凌ぎに飲食することは、前祝いのようで都合が悪かった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが私をお嫁に貰うには、もっと立派な賢い人にならないじゃ――ねえ、判って」　お蘭に取って、この言葉は一時凌ぎの気休めであり、また四郎への励ましに使ったものに過ぎないけれども、四郎は永く忘れなかった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈｜凌ぎに何か事あれかしと待構へてゐる徒であつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈凌ぎに何か事あれかしと待構へてゐる徒であつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄工所の人は小さなランチへ波の凌ぎに長い竹竿を用意して荒天のなかを救助に向かった。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ山霊感応あったか、蛇は見えなくなり暑さも凌ぎよくなったので、気も勇み足も捗取ったが、ほどなく急に風が冷たくなった理由を会得することが出来た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ体が凌ぎよくなったために足の弱も忘れたので、道も大きに捗取って、まずこれで七分は森の中を越したろうと思う処で五六尺｜天窓の上らしかった樹の枝から、ぼたりと笠の上へ落ち留まったものがある。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それに、洋画家の梶原さんが、雨を凌ぎ、波を浴びて、船でも、巌でも、名勝の実写をなすつたのも、御双方、御会心の事と存じます。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴はそれで饑を凌ぎながら胆太く自分と富士の運命を見届けにかかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人間の心には、人世のあらゆることを凌ぎかつ無限に向上せしめて行く力があることを信じます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが私をお嫁に貰うには、もっと立派な賢い人にならないじゃ――ねえ、判って」　お蘭に取って、この言葉は一時｜凌ぎの気休めであり、また四郎への励ましに使ったものに過ぎないけれども、四郎は永く忘れなかった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただただ永年夜食として食べ慣れたどぜう汁と飯一椀、わしはこれを摂らんと冬のひと夜を凌ぎ兼ねます。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）どうです、寒さ凌ぎに……。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平も退屈｜凌ぎに一緒に日比谷や邦楽座、また大勝館あたりで封切りを見るのが、月々の行事になってしまったが、見る後から後から筋や俳優を忘れてしまうのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さ凌ぎに昨夜出先で風呂を貰い、お神がもう冷めているかも知れないから、瓦斯をつけようというのを、酔っていた彼女はちょっと手を入れてみて、まだ熱そうだったので、そのまま飛びこみ、すっかり生温になっていることが解ったが、温まろうと思い、しばらくじっとしているうちに、身内がぞくぞくして来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で寒さ凌ぎに一パイ飲んで、夕方になって、やっと自宅へ帰りついた文作は着のみ着のまま、物も云わずに、蒲団を冠って寝てしまった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速、ホテルと君の事務所へ電話をかけてみたが、出ているというので、退屈凌ぎにここへ昼寝する積りで来てたんだが……」ひょっとするとここへ廻るかも知れないとも思った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の紺の筒袖に、尻からすぽんと巻いた前垂で、雪の凌ぎに鳥打帽を被ったのは、いやしくも料理番が水中の鯉を覗くとは見えない。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻も耳も吹切られそうで、何とも凌ぎ切れませんではござりますまいか。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "てれかくしと、寒さ凌ぎに夜なしおでんで引掛けて来たけれど、おお寒い。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いえね、いよいよとなれば、私は借着の寸法だけれど、花柳の手拭の切立てのを持っていますから、ずッぷり平右衛門で、一時｜凌ぎと思いましたが、いい塩梅にころがっていましたよ。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛の圍の幻は、却て鄙下る蚊帳を凌ぎ、青簾の裡なる黒猫も、兒女が掌中のものならず、髯に蚊柱を號令して、夕立の雲を呼ばむとす。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ山霊感応あつたか、蛇は見えなくなり暑さも凌ぎよくなつたので気も勇み足も捗取つたが程なく急に風が冷たくなつた理由を会得することが出来た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ体が凌ぎよくなつたゝめに足の弱も忘れたので、道も大きに捗取つて、先づこれで七｜分は森の中を越したらうと思ふ処で、五六｜尺天窓の上らしかつた樹の枝から、ぼたりと笠の上へ落ち留まつたものがある。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家の窮乏を凌ぎ、幾多の犠牲を忍んでの結実であつただけに、刊行者としての弟鉄雄の張りきり方も非常であつた。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔日暴風雨を凌ぎ、疾雷閃電の猛威を以て、中原を席捲し去りたる夢は今｜何処にかある。",
              "citation": {
                "source": "想断々（２）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "運よくして思ふこと図に当りなば傲然として人を凌ぎ、運あしくして躬蹙りなば憂悶して天を恨む。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「停車場などで売っている俗書だが、退屈しのぎに……」と断ってよこしてくれたのである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、棄てられた一軒の小屋に這入って、寒さをしのぎつゝ、そこから、敵の有様を偵察することにきめた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
