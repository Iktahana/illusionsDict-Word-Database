[
  {
    "uuid": "9deee809-1b3f-5cce-9a76-6ade55a89901",
    "entry": "召致",
    "reading": {
      "primary": "しょうち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
