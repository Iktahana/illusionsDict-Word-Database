        "examples": {
          "standard": [
            {
              "text": "大学で初めてＣ言語を学び、プログラミングの基礎を習得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "Ｃ言語は組み込みシステムやOSの開発によく用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はＣ言語で複雑なアルゴリズムを実装することに長けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日電の個人用マイコンであるパーソナルコンピューター『ＰＣ―８００１』が一人に一台あてがわれ、マイコンの使い方、ＢＡＳＩＣ言語によるプロクラム作成やゴルフゲーム、英文ワードプロセッサ実習など盛り沢山な一日入門コースをこなす。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題を解決するために、手順を組み合わせていくアルゴリズムの視点を持つことを教えられ、アセンブラーやＣ言語を初子から学んだ福良は、やがて教える側が驚くほどの構想力と繊細さ、緻密さをプログラミングに感じさせるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
