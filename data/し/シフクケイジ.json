    "definitions": [
      {
        "index": 1,
        "gloss": "plainclothes police officer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
