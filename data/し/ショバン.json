        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近年有名になつたのは趙汝※の諸蕃志である。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "高宗の崩御の際、諸蕃酋の親しく來弔する者六十一人もあつた。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "千二百餘年後の今日に至つても、乾陵の諸蕃酋の石像は依然として存在して居る。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大師の入唐より約百年前に、則天武后の延載元年（西暦六九四）に、諸蕃長は醵金して、武后の徳を頌する爲に、洛陽の宮城の正門前に、銅鐵製の天樞を建てた。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "南宋の趙汝※の『諸蕃志』に、この國のことを記して、國人多姓蒲とあるのは、當時この國に假寓したアラブ商人のことを指した樣に想はれる。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "又水戸藩で編纂した『大日本史』には、支那を諸蕃傳に列してある。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那を諸蕃扱にしたものは、尚更見當らぬ。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の歴史に日本を東夷傳に入るる以上、日本の歴史に支那を諸蕃傳に列して、不思議はないのである。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "宋の趙汝※の『諸蕃志』には麻霞勿とあるが、この勿は末と等しくメッドの音を表はすので、末と勿との通用の例は可なりに多い。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "降つて宋時代に至つても亦同樣で、『宋史』を始め『諸蕃志』『嶺外代答』等いづれも大食と稱して居る。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "依羅氏は、新撰姓氏録摂津国皇別に、依羅宿禰の条に、日下部宿禰同祖、彦坐命之後也とあり、又、河内国諸蕃、依羅連の条に、百済国人素弥志夜麻美乃君之後也とある。",
              "citation": {
                "source": "人麿の妻",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余輩はまた「日本民族」構成の事蹟を調査するに当って、漢韓その他、諸蕃帰化の諸民族をも、閑却してはならぬ。",
              "citation": {
                "source": "「日本民族」とは何ぞや",
                "author": "日本民族の概念を論ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただに国津神の後裔のみならず、秦・漢・百済等海外諸蕃の裔を承けたもので、入って皇妃・夫人の列に加わったものさえも、史上その例に乏しくはない。",
              "citation": {
                "source": "「日本民族」とは何ぞや",
                "author": "日本民族の概念を論ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる天神・地祇はもとより、我が国土に祭らるる秦・漢・百済等の諸蕃神も、ことごとく我ら「日本民族」共同の祖神として尊崇すべく、我が国史上に現われたる偉人傑士は、ことごとく我ら「日本民族」共同の尊親属として、相ともにその誇りとなすべく、相ともにこれを尊敬すべきものである。",
              "citation": {
                "source": "「日本民族」とは何ぞや",
                "author": "日本民族の概念を論ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋は勿論、東洋も支那からいうと諸蕃の地であるから、支那みずからが東洋とせられなかったことは勿論である。",
              "citation": {
                "source": "東洋文化、東洋思想、東洋史",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            }
          ]
        }
