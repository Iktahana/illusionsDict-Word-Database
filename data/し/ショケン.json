[
  {
    "uuid": "651739a7-3cea-595f-815f-f7fa920833b6",
    "entry": "所見",
    "reading": {
      "primary": "しょけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
