    "definitions": [
      {
        "index": 1,
        "gloss": "capital stock",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「でも、女のする商売って、どんなものがございましょうかしら、それに……」（資本金も要りますし）と、いう言葉を、差し控えた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土地だって資本金が掛かってんですぜ。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本金は一億円、予定従業員数は四十名。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「資本金でもあれば店も結構だが、われわれ、どうして商売など始められんべ？",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ田畑を売り払へば、相当の資本金は調達出来るからね。",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、場所のせいばかりでなく、前にもいう通りの事情で、どこの座主にも十分の資本金がないので、たとい少しぐらいの利益を収めても、とかく金利に追い倒されるという苦しい立場にも置かれていたらしい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父は幾つとなく事業をやつて皆失敗したぢやありませんか、僕だつて僕だつて……」「そんな資本金はもう家にはない。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに資本金が出来ようとも、人間、下宿屋だけは始めなさんな、と。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三四年間に取り盡されるといふ蟹の鑵詰製造の爲めに、如何に奮發して資本金を出しても知れたものゆゑ、松田家の事業としては、餘りちひさ過ぎるといふ理由で、あの問題はお斷わりすることに決定致しました」と。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本金三十萬圓、一ヶ年の釀造高六千石、賣上高ほぼ八十萬圓。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本金一〇〇三億三〇〇〇万円、一九八四（昭和五十九）年三月期決算の売上高一兆四六〇〇億円。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七七（昭和五十二）年五月、西、郡司、塚本の三人は、資本金三〇〇万円でアスキー出版を設立した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八二年四月、ケイパーは資本金一〇〇万ドルでロータスディベロップメント社を設立し、１―２―３と名付けられることになる統合表計算ソフトの開発に着手した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んでもやたらに、資本金七万円、五万円という会社が出始めたりしているよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "教員金の多少を争う右の通り三田の新塾は万事都合｜能く行われて、塾の資本金こそ皆無なれ、生徒から毎月の授業料を取集めて之を教師に分配して、如何やら斯うやら立行くその中にも、教師は皆本塾の先進生であるから、この塾に居て余計な金を取ろうと云う考はない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本金二百円のテンプラの出し店が、ある場末の町角で始まったのでした。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、人身ヲ売買スルハ古来ノ制禁ノ処年期奉公等種々ノ名目ヲ以テ其実売買同様ノ所業ニ至ルニ付娼妓芸妓等雇入ノ資本金ハ贓金ト看做ス故ニ右ヨリ苦情ヲ唱フル者ハ取糺ノ上其金ノ全額ヲ可取揚事。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の力で工夫して食べて行きなさい」　と、なにがしかの資本金を与えた。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中仙道の板橋方面、甲州街道の柏木方面、奥州浜街道の千住あたりを極力捜したのであるがいかに場末と雖も、資本金三百円をもって開店し得るような、街道に沿うところに、そんなささやかな貸家はない。",
              "citation": {
                "source": "烏惠壽毛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本金三十万円ほどの小さな国立銀行であるが、はからずも彼は、そこに実父左近の預金が一万七千余円あることを知った。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に翻訳してみたら、新制大学の新卒から、資本金一億円級の会社の重役くらいまでが、この階級に含まれているとみてよい。",
              "citation": {
                "source": "知られざるアメリカ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要する処彼は、仕事がなくて困つて居るから、伝道師になれるか、さも無ければ、餅売の資本金でも貸してくれと云ふのであつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、その資本金を直に与へることが出来なかつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一寸出て来てくれと云ふので、店の外へ行くと、餅屋をするから資本金を二十円貸してくれと云ふ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに三好が三千円の資本金を出すと云ふのですから恁那甘い話はありませんよ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本金百万足らずの会社に有給の重役が五人もいるなんて、およそ意味ないじやありませんか」「それがどうにもならんのさ。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一四三、非国教宗の歳入　スコットランド非国教宗中、フリー・チャーチ宗の一年の収入、悉皆総計（一八八七年中）五十九万二千八百五十五ポンド（三百八十万円）、この四十年間に徴募せる宗教資本金一千八百五十万ポンド（一億二千万円）なりという。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて株式会社中村屋は資本金十五万円とし、全株の半分を妻良の名義にし、残りの半分をば私と婿のボース、伜や娘、功労ある店員十名の間に分配した。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私がそうした自惚れの心を起こし、森永や明治の向こうを張って一つ資本金一千万円の大会社にしてやろうなどという野心を起こしていたならば、あるいは今日の中村屋はなかったかも知れない、結局私は不器用でいわゆる、馬鹿の一つ覚えで、与えられた日々の仕事につとめて来たことが今日あるを得たものと思っている。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
