        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大きな丸太を針金で縛り合せた仮橋が生ま／＼しく新しいのを見ると、前の橋が出水に流されてそのあとへ新造したばかりであらうかと思はれた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな丸太を針金で縛り合せた仮橋が生ま生ましく新しいのを見ると、前の橋が出水に流されてそのあとへ新造したばかりであろうかと思われた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそれは間もなく日光にあたってぼろぼろに裂け、度々の出水に次から次と削られて行きましたが、新らしいものもまた出て来ました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や廃れたる一切の情緒が出水のやうに溢れてきた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出水だ危い、と人々此方の岸から呼ばゝつたが、強情にものともしないで、下駄を脱ぐと杖を通し、帯を解いて素裸で、ざぶ／＼と渉りかける。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知でしょうが奥山の出水は馬鹿に疾いものでして、もう境内にさえ水が見え出して参りました。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそれは間もなく日光にあたってぼろぼろに裂け、度々の出水に次から次と削られては行きましたが、新らしいものも又出て来ました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホイホイ背後から追い追い立て、約二里ばかり進めば、八溝川の上流、過般の出水の為に橋が落ちている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物をとりて棚におけあふれる情調の出水にうかばう。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知でせうが奥山の出水は馬鹿に疾いものでして、もう境内にさへ水が見え出して参りました。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僥倖に、白昼の出水だったから、男女に死人はない。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしから堤が低く、地面と水との距離がいたって近いので、ややもすると堤を越えて出水する。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の子供のときには四年もつづいて出水したことがあった。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所、深川には出水して、押流された家もあった。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋のところでは、此間まで川ぷちを崩してせツせと新らしい鑛泉を掘り拔いてゐたのが出水の爲めにさん／″＼になつた跡を、立ちどまつて、暫らく見てゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥は、毎日のことが單調なのと出水があるかも知れないと云ふおそろしい評判との爲めに、東京ばかりを戀しがつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば用水が畔へ開き、田が一面の湖となる、雨上りの広田圃を見るような、鮒と鰌の洪水めいたが、そのじめじめとして、陰気な、湿っぽい、ぬるぬるした、不気味さは、大河の出水の凄いに増る。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また厄介なのは、縦横に幾ヶ処ともなく、畦の切目があって、ちょいと薪を倒したほどの足掛が架っているが、たださえ落す時分が、今日の出水で、ざあざあ瀬になり、どっと溢れる、根を洗って稲の下から湧立つ勢、飛べる事は飛べるから、先へ飛越えては、おもしろ半分、（お手をお取り申しましょうかね。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過からがらりと晴上って、蛇の目の傘を乾かすような月夜になったが、昨夜から今朝へかけて暴風雨があったので、大川は八｜分の出水、当深川の川筋は、縦横曲折至る処、潮、満々と湛えている、そして早船乗の頬冠をした船頭は、かかる夜のひっそりした水に声を立てて艪をぎいーぎい。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この出水をよい事にして近所の若者どもが、毎日いたずら半分に往来で筏を漕ぐ。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "深刻に出水の苦痛を恐れて居る予は、八月という月の此天候に恐怖を感ぜずには居られなかったのである。",
              "citation": {
                "source": "大雨の前日",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ雨も降らないのに、出水を心配するなどは猶更無駄な話だ。",
              "citation": {
                "source": "大雨の前日",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近在にも出水がみなぎって溺死人がたくさん出来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐は天候をうらない、出水や旱のことを予言すると、みな適中した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "出水の時は、恐ろしく大きな音をたてて、玉石などを本流に転がし込むのだつたが、ふだんは子供たちのいい遊び場であつた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "出水のためにいくらかは濁つてはゐるけれども、それでも谷川らしい感じを失はない水は、大きな岩に当つては砕け、当つては砕けた。",
              "citation": {
                "source": "山間の旅舎",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなおりに、思いがけなく川に出水があって、徒渉りがしにくいと、この仙人は手にさげた折畳み式の馬に水を吹きかけます。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきごろの出水に頽された広瀬川の堤を越えて、昼もくらい杉並木の奥深くはいると、高い不規則な石段の上に、小規模の日光廟が厳然とそびえている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月の末に霖雨が降りつづいたので、利根川は出水して沿岸の村々はみな浸された。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その塚は明治の後までも河原に残っていたが、二度の出水のために今では跡方もなくなったように聞いている。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
