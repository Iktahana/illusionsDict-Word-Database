    "definitions": [
      {
        "index": 1,
        "gloss": "refusing flatly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "イデオロギストは、趣味を峻拒すか。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭は斷じて此の結婚を峻拒する。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論周三は、此の要求を峻拒した。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで氏郷は之を援けて一揆を鎮圧する為に軍を率いて出張したが、途中の宿々の農民共は、宿も借さなければ薪炭など与うる便宜をも峻拒した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、詩及詩人に対する理由なき優待を自ら峻拒すべきである。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっさいの空想を峻拒して、そこに残るただ一つの真実――「必要」！",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に詩および詩人に対する理由なき優待をおのずから峻拒すべきである。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ふところはドン・ホアンを欺く蕩子なる如くにして、まことは聖アントニウスの誘惑を峻拒する氣概あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "由って虎を霊視するの極、本来動物崇拝を峻拒する回教徒中にあっても、かつて上帝が虎と現じて回祖と談じたと信ずる輩すらある（『太平広記』二九二。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや手配済みでござるから、このうえのご配慮は迷惑でござる――そういう理由のもとに、半ばお直参の威嚇を示しながら、ぴたりと面会を峻拒いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、小田切久之進は顔さえも見せないで、いよいよ奇怪なことに、いっそうろこつなお直参の威嚇を示しながら、重ねて右門の申し入れを峻拒いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのたびに校長がそれを峻拒したということも聞いていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、僕は最初からそれを峻拒していた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この月夜の果樹園のような空気を呑んで陶酔を覚えたものにとって、「緑色の羅紗」の手ざわりは一生｜峻拒出来ない魅惑なのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの愛する国家は、他の国家と他の国民を峻拒しもしくは敵視するような排他的の目的を少しも持たず、歴史的、地理的、生産的、政治的の特殊な差別関係によって集団生活を持続している日本国民のために専らその自治改造の確実な機関たる外に何の目的もないものでありたいと思います。",
              "citation": {
                "source": "三面一体の生活へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主主義の徹底する時代には偶像崇拝の思想の幻滅すべきは勿論のこと、法外な英雄崇拝の思想もまた自我の退嬰萎縮として峻拒されねばならないことだと思います。",
              "citation": {
                "source": "激動の中を行く",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "促がされたるも、本部の依頼は一切峻拒して之に応ぜざりき。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の策士犬養木堂は、星を入れゝば必ず内部から破裂があるので、これを峻拒した。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのものについて、惨めなもの、醜いものは、容赦なく峻拒しよう。",
              "citation": {
                "source": "白藤",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままの状態で十時間経ったが、一片の麺麭すら与えられないので、多少の飲食物を乞うたところ、国王によって峻拒された。",
              "citation": {
                "source": "泡沫の記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目の僞手紙でお關をおびき出し、目黒の下屋敷につれ込んだ高力左近は、恩人にして臣下、今はしかも自分の身代りにならうと言ふ志賀内匠の妻お關に、無體の戀慕を仕掛け、貞烈なお關の峻拒に逢つて、首を三太刀まで切つた上、茣蓙に包んで目黒川に流した始末を、平次は手に取る如く語り聞かせたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十手の道",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目の偽手紙でお関をおびき出し、目黒の下屋敷につれ込んだ高力左近は、恩人にして臣下、今はしかも自分の身代りになろうという志賀内匠の妻お関に、無体の恋慕を仕掛け、貞烈なお関の峻拒にあって、首を三太刀まで切った上、茣蓙に包んで目黒川に流した始末を、平次は手に取るごとく語り聞かせたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十手の道",
                "note": "青空文庫"
              }
            },
            {
              "text": "サあ、帰って下さい、私は貴方の奸策を皆んな父に話して笠森さんを呼戻さなければなりません」「これ程まで云っても」「帰って下さい」　美奈子は毅然として丹波丹六を峻拒したのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれが解決されなければ、他のいかなる解決をも峻拒する。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見てどうするわけじゃないが、どんな形で、どんな具合にかくれているか、参考までにさ」　私は彼が峻拒するだろうと予想していた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その演奏会に、喃々私語する貴婦人達を叱※して、「こんな豚共に聴かせるピアノではない」とピアノの蓋を閉してサッサと帰ったこともあり、普仏戦争当時、戦塵を避けたリヒノフスキー邸で、フランス軍の将校のためにピアノの演奏を迫られ、敢然峻拒して二百キロを歩んでウィーンに帰ったことなどもあった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラームスが俗流に媚びず、新奇なもの浮薄なものを峻拒して、一生地味で冴えない――が最も芸術的な音楽を作り通した非妥協的な態度はブラームス本来の性格によることではあるが一部は理想家シューマンと聡明なクララ夫人の感化によるものと言っても決して間違いではないと思う。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれを峻拒されると、機先を制して二十九日に、旧自由党だけの大会を開いて解党を議決した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊たちに峻拒されて、やむなく後へ帰ってしまった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうちの男の峻拒などは上べだけのものでしかない、ときめこんでいる大胆さなのである。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
