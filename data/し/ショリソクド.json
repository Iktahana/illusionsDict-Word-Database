[
  {
    "uuid": "272d8c6b-095d-5d9e-b429-968e697b8511",
    "entry": "処理速度",
    "reading": {
      "primary": "しょりそくど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
