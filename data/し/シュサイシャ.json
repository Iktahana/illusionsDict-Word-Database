[
  {
    "uuid": "e36e2238-3e5f-561a-9bd3-5134fb6bf0f0",
    "entry": "主催者",
    "reading": {
      "primary": "しゅさいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
