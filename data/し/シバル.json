        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分で、自分の頸を縛ることだ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや縛る前に早く承諾書をとらなくちゃ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難がもし答えられなかったら即座に縛るが宜しい。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私等は口惜くて口惜くて仕様が無いの、ああいう乱暴な貧民は何人あろうと、一人々々ふん縛るわけには参りませんか。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、もっとも神妙に覚悟して乗って行けば縛るには及ばんてさ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁がここにあるで、縛るがええ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "客人はあと二、三日、石の唐櫃に籠ったように、我と我を、手足も縛るばかり、謹んで引籠ってござったし、私もまた油断なく見張っていたでございますが、貴下、聊か目を離しました僅の隙に、何処か姿が見えなくなって、木樵が来て、点燈頃、（私、今、来がけに、彼処さ、蛇の矢倉で見かけたよ、）　と知らせました。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「構わねえたって、これ、縛るとなると。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこをふん縛るんだ」「しかし、親分、猿飛という奴は、親分にも大火傷、いやお灸を据える位の忍術使いですから、下手すると、こっちがやられてしまいますぜ」「莫迦をいえ！",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼の道人は者があって彼を縄で縛るように見えたが、やがて足が地を離れて空にあがった。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めるとなると、なんだか自分で自分を縛るやうな心持がして不愉快である。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「縛るのですか」　婢が云った。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥様のお室へ縛るのですよ」　年増はそう云い云いひどい力で讓を後へ引ぱった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「縛るんですか、」　女中が云つた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥様のお室へ縛るんですよ、」　年増はかう云ひ云ひひどい力で譲を後へ引張つた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お披露目をするといってもまさか天婦羅を配って歩くわけには行かず、祝儀、衣裳、心付けなど大変な物入りで、のみこんで抱主が出してくれるのはいいが、それは前借になるから、いわば蝶子を縛る勘定になると、反対した。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、かの道人は者があって彼を縄で縛るように見えたが、やがて足が地を離れて空にあがった。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「指を縛るのか」「そうだ、これで三度まわして、きちんと縛ってくれたまえ」「禁厭か」　彼はばかばかしいので叱りつけるように云った。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「禁厭と云うわけでもないが、それでいい、縛ってもらえば」「そうか」　ばかばかしくても指を縛るくらいはなんでもないので、すぐ手をやって神中の手にしたものをとった。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは布の様子と油染みた所とから見ると、水夫が辮髪を縛る紐らしい。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版社の意向や物理的な制限など、紙の本作りを縛るさまざまな制約を逃れ、より自分の思いに近い姿で作れるのなら面白い。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、どうしましょう」「まさか、いきなりにふん縛るわけにも行くめえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "「縛られ地蔵を詠んだ句でしょうが、俳諧だから風流に藤の花と云ったので、藤蔓で縛るなぞはめったに無い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうで縛るならば、繁昌の地蔵さまを縛った方が御利益があるだろうと云うわけでしょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おめえはふだんから親孝行だそうだが、正直に云わねえとお父さんを縛るぞ」　お住は泣きそうになったが、それでも口をあかなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃は草というては悉皆薙倒して麁朶でも縛るやうに中央を束ねて馬に積むのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "山椒大夫のやうな伝説は、書いて行く途中で、想像が道草を食つて迷子にならぬ位の程度に筋が立つてゐると云ふだけで、わたくしの辿つて行く糸には人を縛る強さはない。",
              "citation": {
                "source": "歴史其儘と歴史離れ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雲のあわやから鬼が穴う突ん出して縄で縛るよな屁をたれた」　甚句を歌うものがある。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦を縛る縄を綯って売る者もあった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで荷物を縛る紐みたいに薄べったくなってね、変化は徐々にだが、根強く行われているんだね」「絶えず変ってるんだろうが、こんな風に山が来るってな風でないと、俺達にゃ分らないんだろうか。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            }
          ]
        }
