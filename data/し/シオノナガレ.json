    "definitions": [
      {
        "index": 1,
        "gloss": "sweep of the tide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
