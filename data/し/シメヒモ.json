        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一人は砂時計の形をした太鼓を二つ持ち、その一つを左の腋にはさみ、他は左手で締め紐を持って、右肩にのせた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろかわったしめひもがあります。",
              "citation": {
                "source": "白雪姫",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と思いまして、戸をあけて、きれいなしめひもを買いとりました。",
              "citation": {
                "source": "白雪姫",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そのばあさんは、すばやく、そのしめひもを白雪姫の首をまきつけて、強くしめましたので、息ができなくなって、死んだようにたおれてしまいました。",
              "citation": {
                "source": "白雪姫",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、のどのところが、かたくしめつけられているのを見て、小人たちは、しめひもを二つに切ってしまいました。",
              "citation": {
                "source": "白雪姫",
                "author": "グリム",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
