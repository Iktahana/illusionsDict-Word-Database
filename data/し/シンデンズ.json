        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "心電図モ暫ク取リマセンカラ、取ッテ見ル必要ガゴザイマスネ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉田氏ハ心臓ヲ何度モ打診シテ見、背中ヲ調ベ、深呼吸ヲサセ、携帯用ノ心電計デ心電図ヲ取リ、「格別御心配ナコトハナイト思イマスガ、帰リマシテカラ後程結果ヲ御報告申シマス」ト云ッテ帰ッテ行ッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心電図ノ結果ハ矢張格別ノコトハアリマセン。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "約一年前から既に心電図上ＳＴの降下、Ｔ波の平低化等、心筋傷害を疑わせる所見が見られたが、最近まで特に心臓についての訴えはなかった。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の心電図には一年前に比べ著変が見られない。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月二日夜、排便時に力んだところ、心臓部に五十分以上に亙って激しい締めつけるような疼痛がおこり、最寄りの医師の往診を受けたが翌日の心電図検査に依り、胸部誘導に前壁中隔梗塞を疑わせる所見が見られた。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血圧は一四二―――七八、心電図には三日とほゞ同様、ＳＴ・Ｔの異常と、前壁中隔梗塞を疑わせる所見が見られ、胸部レントゲン写真では心臓肥大はあまりなく、動脈硬化像が見られる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心電図は前回と特に変っていない。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベクトル心電図でも前壁中隔梗塞の疑いがある。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心電図に軽度の改善が見られる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心電図には新しい病変の所見は見られない。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中略二月三日　快晴心電図も大部よくなり、最近は小さい発作も殆んどおこらない。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒドクナレバ失心スルハナカッタノダガ、今日始メテ測ラセラレ、心電図ヲ取リ、腎臓ノ検査モサセラレル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
