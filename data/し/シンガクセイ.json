        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはおなじ階でおとなり同士の若い神学生で、はいって来てこういいました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもさしあたり神学生も、おなじウェッツラ（四輪馬車）にのりあわせた旅の道づれも、それをくちびるにのせたものはありませんでした。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで神学生がまずその役にあたりました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、神学生はいいました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう実業家が今日わが国に起らんことは、神学生徒の起らんことよりも私の望むところでございます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は神学生徒がキリスト信者のなかに十人あるかと思うと、実業家は一人もないです。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は神学生でもなければ、貴族でもない。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂につづいた一棟の建物の中に別に寄宿する神学生なども思い思いの方角をさして出掛けて行く。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮勝ちに普通学部の生徒の側を通って郊外の空気を吸いに出る神学生も見える。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "補祭はいつも小卓の足もとに転がしてあるギターを取り上げて、調子を合わせてから細い声で、居酒屋のほとり、神学生の群たたずむ、　と静かに歌いはじめた。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ上の二階には今村小六という勉強ずきの神学生がいて、今も灯がもれているから、この水音をききのがす筈はない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十一　稲妻は見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかえって見るといつも陣地から水をもらいにくる、黄色くしなびた、貧乏な神学生のような若い兵隊さんが立っていた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のためにしっかりやってください」　神学生は煤けた頬をオールド・ローズ色に染め、足を踏みかえながらもじもじしている。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにかご用なの」　神学生は眼を伏せながらしどろもどろにいった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、あの蔭へでも行きましょうか」「はあ」　といったきり神学生は動かない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしのできることでしたら」　神学生が眼を伏せたままぶつぶついった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、こっちへいらっしゃい」「すみません」　神学生の兵隊さんは玄関で藁草履をぬぐと、篏木の床に大きな足跡をベタベタつけながらあたしのうしろからついてきた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "家主の説明によると、私の他の四組の間借り人のうち二組は共稼ぎの若夫婦で、あとは美容院に勤めている姉妹と、家主の遠縁の神学生が一人で部屋に入っていた。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神学生とアリョーシャと、もう一人の道心とは立ったままであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリョーシャはラキーチン（神学生）の顔さえ、眺めることができなかった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "』七　野心家の神学生　アリョーシャは長老を寝室へ助け導いて寝台の上へ坐らせた。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人どもとあらゆる種類の神学生の街ですからなあ！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂によると、なかなか分別のある人だということですね（それは姓の示すとおり（ラーズムは叡知の意）ですよ、きっと神学生なんでしょう）。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一人の将校あがりと二人の神学生であった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏な田舎医師の息子でまず神学生になったが哲学の研究に移り感覚論者の学説に近い考えを持ってコンディヤクの信奉者であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "神学生が一番左向けをします」「これは驚いた」「アメリカあたりじゃ皆｜然うですって」「然う言えば、君も少し左へ曲っていますよ」「ハッハヽヽヽ。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男のくせに、いつも薄化粧をしているバプテスト神学生の三浦、紺がすりの羽織紐を首のうしろへ引っ掛けている今村、西洋乞食の樫井、新聞配達の西村といった順に、ぼつぼつ不良色が濃くなって、そのうちにトム公も交じっていた。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それが、どうしたというのか、早く、説明に移ってもらいたいな」　と、神学生の今村が言った。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
