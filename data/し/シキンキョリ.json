    "definitions": [
      {
        "index": 1,
        "gloss": "point-blank range",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし至近距離から発砲されたことは確かだった。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごくごく至近距離で、すぐさままた別のホーホーが応じる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は、パラフィン紙にコンビーフをのせ、それをランプの台におき、ランプの先を折り曲げて至近距離に近づけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしとちがって、いまはご近所サマが、至近距離でひしめきあっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその直後に爆弾は至近距離に落ちて爆裂したが、伏せたおかげで身に微傷も負わなかった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所はアフンルパ※から旧道を横切り二百歩余東南に行った至近距離で、其処は丘上で沢形になった地形で、下るとごく小さな泉が湧いており、水は細流になって流れ出している。",
              "citation": {
                "source": "あの世の入口",
                "author": "――いわゆる地獄穴について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦は急遽左回頭して、針路を転換、必死に遁走を試みたが、敵艦から撃ち出されてきたる砲弾は、右舷左舷の至近距離に丈余の水柱を挙げ、飛沫は、全艦滝のごとくに降り濺いでくる。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転席のドライヴァーが聞いているはずのラジオの番組が、ほんの一瞬僕たちの耳にも届いた、と錯覚しても許されるほどの至近距離だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車のトランクを開くジェフリーを、撮影機は至近距離からとらえた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "地を這いながら至近距離で敵兵と射ち合う白兵戦を、彼もウクレレも、傷ひとつ負うことなく、切り抜けた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "至近距離から彼女の目をのぞきこむように見るのが、ぼくは好きだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、ハワイに集結している軍事施設から、至近距離にある。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの向こう側という至近距離にいるこの美しい女性は、いったいなになのだろうか、と川島は思った。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女とこうして肩をならべて歩くのは初めてだし、微笑している顔を至近距離から見るのも初めてだ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで住んできたこれまでの自宅は、いつでも自由に立ち寄ることの出来る、至近距離にある第二の自宅ではないか。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "至近距離にあるいくつかのボタンを見て、しばらくのあいだ彼女は無言でいた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして反対側に千鶴子がストゥールを背にして至近距離に立った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彼女を至近距離に見て、たいそう美しい、と彼は思った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆるものがどうでもいいほどに遠くなったあとに、愛子だけが至近距離にあった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "最終的な目標としては、出来事のぜんたい像を知った上で、美代子さんの至近距離までいければそれでいい」「美代子さんをひと目は見たいと思うのではないですか」「思うだろうね」「どうします？",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、全貌をほぼ知った上で、美代子さんにはまったくなにひとつ知られることなく、ごく短い時間でいいから、美代子さんの至近距離までいってみたい。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に濡れた彼女の顔を、彼は至近距離に見た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが向こうの坂道へ出ていかないように、私があそこに立っててあげたの」　振り返ってその場所を示す夏子を、冬彦は至近距離から見た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身を開いて彼を受けとめ、彼の腕に両手を添え、夏子は至近距離の彼の顔を見た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここよ」　ヨシオと至近距離に立って、彼女はそのスペースを示した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシオから至近距離に立ちどまり、「かたづけは終わったの？",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　暗い寝室の布団のなかで、おたがいに体と顔を触れ合わせている至近距離から、直子が聞いた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "至近距離から、彼女はぼくの目を見ていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく敵のとりでに接し、またなるべく小高い岩頭などをえらんで組んであるので、矢を射こむには、至近距離をなしている。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然、矢は用をなさないので、長柄、なぎなた、太刀、槍の白兵戦となろうが、いつまでも、或る至近距離から内へは敵もすすまず、こっちも出てゆく風はなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
