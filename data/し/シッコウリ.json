          "literary": [
            {
              "text": "「ええ、ル・バングよ……あの死刑執行吏のサ」",
              "citation": {
                "source": "碧眼",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "テュイルリーの宮殿★から、モンセーニュールと全宮廷とを経て、議院や、法廷や、すべての社会（あの案山子たちだけを除いて）を経て、その仮装舞踏会は下賤な死刑執行吏にまで及んだ。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死刑執行吏でさえ、かの呪文に遵って、「頭髪を縮らし、髪粉をつけ、金モールの上衣、扁底靴★、白絹の靴下を著用して」職務を執行せよと命ぜられていたのだ。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムシュー・パリー　　パリー市の死刑執行吏をこう言った。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
