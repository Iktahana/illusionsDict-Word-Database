        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな田舍臭い百姓歌の主人公が、灯ともし頃に羽織をきて、新宿の宿場を漂泊して居るやうな氣がした。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、妙な美談の主人公になろうとして、こんな事を言っているのではありません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公ラスコリニコフの心理と言行とが、小説の最初から大尾まで、魔法のやうに僕の心を引き捉へて居た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕はニイチェを讀んで居たので、あの主人公の大學生が、ナポレオン的超人にならうとイデアした思想の哲學的心境がよく解り、一層意味深く讀み味へた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白痴」を讀んだ時は、主人公の精神病的な異常氣質が、たまたま僕とよく酷似してゐる點があるので怖くなつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、その小説の主人公である白痴の貴族が、丁度その僕と同じ精神変質者であったからだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白痴の主人公は、愛情の昂奮に駆られた時、不意に対手の頭を擲ろうとする衝動が起り、抑えることが出来ないで苦しむのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張、不如帰の女主人公を思はせるやうな、少しく旧式な温順さをもつた、どこか病身らしい細顔の女たち――である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この舌切雀の主人公は、日本一どころか、逆に、日本で一ばん駄目な男と言つてよいかも知れぬ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹斎というのは小説の主人公の藪医者の名さ。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この挿話の主人公夫婦として現われる二人の俳優の演技が老巧なためにこれが相当な効果をあげているようである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の主人公なるが如く心得、家庭の事は、男子の片手間の事業かの如く考えて居るのが、今日家庭を説くものの理想らしいが、これが大間違の考と云わねばならぬ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの主人公の復讐はクリスチャンとしてはあまりひど過ぎると云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に彼の『イディオット』の主人公の無技巧な人格の美に対して感じるような快感を津田君の画から味わい得られる。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもあの生活を背景にした主人公があゝいふ風な感興を持つたロシアの女のイメイジである。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」はその瞬間の主人公の緊張した氣持が、表面へ出して來るよりも餘計效果的に讀者に觸れて來る。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風に作者は主人公の女に對する氣持の起伏の消息や、陰影に富んだ然も純な性格を、語るより以上に感ぜしめてある。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物足りなく思ふもう一つは主人公の氣持が純眞ではあるが、その力み方に少し誇張したところが感じられることである。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして拳鬪試合に飛び入りをすることが、書いてあるのだが、鬪志といふものがさうした亂暴な荒療治を必要とするものかどうか、それが主人公の稱してゐる如く唯物論的なものであるかどうかはしばらくおくとして、作品の重心がまるで劍劇のやうな立廻りに置かれてゐるといふことは馬鹿々々しい氣を起させる。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公の画家の姉えさんとおっ母さんとの間の関係です。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公ヂックが牧師の内に往って、牧師夫婦と話をしているうちに、牧師が余所へ出てしまう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの虚無主義者と看做されている主人公の医学生に賛同しているというので、貴族｜等は作者を攻撃する。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう少し先のところで、マルテとあるのは、あの有名な「手記」の主人公マルテ・ラウリッヅ・ブリッゲを指してゐることは言ふまでもない。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私は傷ましい悲劇の女主人公を眼の前にしながら、ただ索漠たる氣持の中に陷るばかりだつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち或｜作品では、例へば、「石にひしがれたる雜草」と云つたやうな作品では、主人公の心持の限界を越えて、作者の理智がお芝居をし過ぎて居る爲めに、その心持がどうしても頷けなくなつて來る。",
              "citation": {
                "source": "三作家に就ての感想",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、又一方から見ると作者の愛が實際にその衷心から滲み出てゐる例へば「小さき者へ」の中に於ける、子供に對する主人公の愛といつたやうな場合には、そこに釀されてゐる實感の強さから、可成り感動して作品を讀む事が出來ます。",
              "citation": {
                "source": "三作家に就ての感想",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一兵卒の死の原因にしても、長途の行軍から持病の脚気が昂進したという程度で、それ以上、その原因を深く追求しないで、主人公の恐ろしい苦しみをかきながら、作者は、ある諦めとか運命とかいうものを見つけ出そうとしている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョン・バリモアー役の主人公が「おれもそんなに忠実なコンパニオンがほしい」とはなはだ深刻な皮肉を言う場面がある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこで、その怪談の主人公の女というのは、以前は西川｜伊登次という看板をかけていた踊りの師匠で、今では高山という銀座役人の囲いものになって、牛込の赤城下にしゃれた家を持って贅沢に暮らしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にして、山東の主人公たる優越的地位を失うならば、日本は将来、鉄と石炭との独立を全うすることが出来ない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
