      {
        "index": 1,
        "gloss": "elegant classical Chinese prose employing antitheses using four and six-character compound words",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
