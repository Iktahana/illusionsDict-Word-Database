    "definitions": [
      {
        "index": 1,
        "gloss": "having no choice but to ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の友人は、ほんの数えるくらいしか無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の底では、あなたのからだだつて紙一枚の重さくらゐしか無いのですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＮは、もう三十を越してゐるのであるが、体が小さくて細くて、けいれんの発作があつて、その上、視力が、常人の三分の一しか無いのである。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "買ひおきし薬つきたる朝に来し友のなさけの為替のかなしさ　これだけ抜いたのは、面白いと思ふ歌がこれだけしか無いといふのではない。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の宗教的神聖の意味を知つてるのは、世界で支那人と日本人としか無いであらう。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆に振ったが五両しか無い。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の表情には、怒りと笑いと、二つしか無いようです。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯の仕度にとりかかっていたら、お隣りの奥さんがおいでになって、十二月の清酒の配給券が来ましたけど、隣組九軒で一升券六枚しか無い、どうしましょうという御相談であった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち二人はフカの餌食になる価打しか無い、狂妄だったのですから……。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五円と言って来たのだよ」「でも只今これだけしか無いのですから……」「だって先刻用意してあると言ったじゃないか」「ですから三円だけ漸々作らえましたから……」「そうお。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、お前に命ずる処のものは、お前に取って堪え得られる分際のものでしか無い。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三十戸しか無い村中にこのことが忽ちのうちに響き渡つた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで蛍のやうな火種しか無いのだからな。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市治郎は、自分には娘が一人しか無い、権右衛門には四人の娘があり、三亀雄には良家の出の嫁があると毎夜留置場で呟いていた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ若しこれが大金持ちか王様の娘であつたならば美事な着物を何枚も着せて大勢の人々に見せびらかさうものを、折角｜此様に天人の様な美しい娘を授かり乍ら着せるものは汚い黒い襤褸しか無い、嗚呼何と云ふ情ない事であらうと娘の顔を見る度に涙を流して居りました。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時三十分まで、もう三時間くらいしか無い。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは、私のほんの一部分でしか無いのだ。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやなひと、にやにや笑いなんかしてさ、知っていますよ、節ちゃんさ、兄ちゃんにはね、あたしと節ちゃんと二人の女性しか無いのさ、なにせ丙種だから、どこへ行ったって、もてやしませんよ、そうでしょう？",
              "citation": {
                "source": "律子と貞子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという悲しい顔をしているひとだろう、切株、接穂、淘汰、手入れ、その株を切って、また接穂、淘汰、手入れ、しかも、それは、サロンへの奉仕でしか無い。",
              "citation": {
                "source": "豊島與志雄著『高尾ざんげ』解説",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら実際には、真に「観照のための観照」を考えている芸術は、殆ど稀れにしか無いであろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その易者の言によると、僕の手相は極めて珍らしい手相であつて、何十万に一人しか無いといふ、不出世の天下筋といふのがあるさうである。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、やはり、「文化」というものを全然知らない、頭の悪い津軽の百姓でしか無いのかも知れない。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者の力量が、これだけしか無いのだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民学校の先生になるという事はもう、世の中の廃残者、失敗者、落伍者、変人、無能力者、そんなものでしか無い証拠だという事になっているんだ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄村先生には、この掛軸一本しか無いようである。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の念願は一つしか無い。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その人に五円しか無いことを言って、なるべくお酒をゆっくり持って来てくれるように、まじめにたのんだ。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが仮りに私の気温のせゐだとしても、何のせゐだとしても、この好い気持はこの好い気持であつて、これを努力して造型してお目に懸けることくらゐは出来るとしても極めて可及的可能なことでしかない。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、根本的には唯一つの態度しかない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父も、私も漫然とそんなことを言ひ合つてる時、ヒツとした瞬間、私は一生に一度しかない此の夏休みを、旅行しないといふことがとても尊い物でも取り逃がす様な気持が矢鱈に湧き上つて来た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
