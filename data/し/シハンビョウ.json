          "literary": [
            {
              "text": "紫斑病という言葉を聞きかじっていたので、斑点を仔細に調べ、それから腕や腿をめくって眺め、風呂にはいる時にも体のあちこちを眺めた。",
              "citation": {
                "source": "春盲",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビタミンＣの欠乏に原因する風土病の一種で、和名は紫斑病といふものらしかつた。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "関節の疼痛も紫斑病の特異な徴候である。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
