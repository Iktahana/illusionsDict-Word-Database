        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三　別れの曲　ショパンがパリのサロンに集まった名流の前で初演奏をしようとする直前に、祖国革命戦突発の飛報を受取る。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇場での初演の歌の歌い方と顔の表情とに序破急があってちゃんとまとまっている。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新富座の初演以来、二回目の上演である。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊五郎の嶋蔵、左団次の千太は初演の通りで、団十郎欠勤のために、望月輝の役は菊五郎が兼ねていた。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただひとり初演と違っているのは源之助の「弁天おてる」であった。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狂言の初演は明治十四年で、その当時は半四郎の「弁天おてる」に対して、源之助はその女中のおせいという役を勤めていたのであるが、今度は自分がおてるを勤めることになった。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも再演で、団十郎の河内山、菊五郎の直次郎、左団次の市之丞、すべて初演同様の顔触れである中で、源之助は三千歳を勤めた。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも初演は半四郎の役であった。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○八月、市村座において「桃山譚」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年（庚午）　一八七〇○三月、守田座において市川左団次の丸橋忠弥初演、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は前名を九蔵といい、天保十一年河原崎座において「勧進帳」初演の当時、富樫左衛門を勤めたり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月、中村座の二番目「梅雨小袖昔八丈」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "九年（丙子）　一八七六○三月、中村座の二番目に新作「偽織大和錦」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十二月、新富座にて「黄門記童幼講釈」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、新富座の二番目に「木間星箱根鹿笛」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十二月、新富座の二番目に「島鵆月白浪」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、市村座にて「新皿屋敷」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七年（甲申）　一八八四○四月、新富座の一番目に「二代源氏誉身換」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台開きの狂言に、団十郎は北条高時の天狗舞を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目に左団次の「碁盤忠信」、二番目に菊五郎の「筆売幸兵衛」、いずれも初演にて好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、千歳座にて「四千両小判梅葉」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、新富座にて「夢物語盧生容画」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、中村座にて「月梅薫朧夜」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、千歳座にて「籠釣瓶」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、市村座にて「蔦模様血染御書」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、桐座の二番目に「め組の喧嘩」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、歌舞伎座にて「相馬平氏二代譚」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座の中幕に「戻り橋」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四年（辛卯）　一八九一○六月、歌舞伎座にて福地桜痴居士作「春日局」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、歌舞伎座にて「侠客春雨傘」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
