          "literary": [
            {
              "text": "代議士でも大臣でも縣の出世頭でも、腰繩がついちまつちやおしまひだものな。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆笑同人には死んだ燕路、蝠丸（伸治の父）もいたが、出世頭は志ん生、今輔、圓歌、可楽、三木助の五君であろう。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "中橋英太郎といえば、今は時めく出世頭の一人。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩書からいうと海軍少佐、某呉服店営業課長、某銀行支店長、地方裁判所判事、私立医大教授なぞが出世頭で、自家営業では料理屋の亭主、小間物問屋、地主、運送屋、何といっても会社員が一番多い。",
              "citation": {
                "source": "母校復興",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後余り振わないようだが、矢張り全同窓中の出世頭だ。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豪いものです」「まあ／＼、同窓中の出世頭でしょうな」「先生、立身出世はしたいものですね」「君も大にやるさ。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会ったことはないが、郷党の出世頭だ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
