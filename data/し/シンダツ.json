        "examples": {
          "standard": [
            {
              "text": "隣国による領土の侵奪は、国際社会から非難された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "権力の侵奪を企てる者は、いずれ失脚するだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この土地は、過去に他民族によって侵奪された歴史を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "延喜十四年三善清行の上った「意見封事」十二個条のうちに、一　諸国の僧徒の濫悪、及び宿衛舎人の凶暴を禁ぜんと請ふ事右、臣伏して見れば、去にし延喜元年の官符、已に権貴の山川を規錮し、勢家の田地を侵奪することを禁じ、州郡の枳棘を芟り、兆庶のを除く。",
              "citation": {
                "source": "濫僧考",
                "author": "河原者・坂の者・宿の者・非人法師",
                "note": "青空文庫"
              }
            },
            {
              "text": "自衛のために他国と戦うは、今日の勢い万やむをえずとするも、自国の膨張を図らんために、ほかの国を侵奪せんとするは、絶対的に反対なり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人つきりでゐれば、どんなに苦しんだつて苦しみ甲斐があるわ。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが悲しんだつてどうにもなりはしない。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
