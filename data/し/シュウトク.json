[
  {
    "uuid": "5d1f74ff-0bf4-510d-ae9f-ab44f6c30346",
    "entry": "収得",
    "reading": {
      "primary": "しゅうとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
