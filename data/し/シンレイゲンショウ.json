    "definitions": [
      {
        "index": 1,
        "gloss": "psychic phenomenon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
