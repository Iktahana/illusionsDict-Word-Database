          "literary": [
            {
              "text": "煙草をふかしたり撮影したりしている間に、ガイドはリュックザックからシュタイクアイゼン Steigeisen を取り出して、輪カンジキと取りかえてくれる、それからロープですっかり縛られてしまった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は雪車とシーと輪カンジキを、此のヨッホの岩角に残して、シュタイクアイゼンをつけて立ち上った。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日がかりでシュタイクアイゼンに鑪をかけたり、靴の曲った釘を打ちかえたりするような、はたから見るとたわいもない労力までが、もう岩角へとっついたように緊張させる。",
              "citation": {
                "source": "続スウィス日記（千九百二十三年稿）",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
