        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何という題であったか忘れたが、自分が九歳の頃東海道を人力車で西下したときに、自分の乗っていた車の車夫が檜笠を冠っていて、その影が地上に印しながら走って行くのを椎茸のようだと感じたと見えてその車夫を椎茸と命名したという話を書いた。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規がその後時々自分に「あの椎茸のようなのはもっとないかね」と云ったことを思い出す。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの車夫に椎茸と云う名をつけた。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道に沿うた松並木の影の中をこの椎茸がニョキ／＼と飛んで行くのがドンナに可笑しかったろう。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝はこの椎茸が恐ろしく長くて、露にしめった道傍の草の上を大蛇のようにうねって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお面白いのは日が高くなるにつれて椎茸が次第に縮んで、おしまいにはもう椎茸とも何とも分らぬものになって石ころ道の上を飛び飛び転がって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体が西を向いて行くのであるから、椎茸は車の右脇へ頭を出したり左へ出したり。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな坊チャマを膝へ乗せた父上も大概な事ではなかったらしいが、椎茸もトンダ目に会ったものだ。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椎茸少々｜宜しからぬ事があって途中から免職になったのはよかったが、その後任の爺さんがドーモ椎茸でなかったので坊チャン一通りの不平でない。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢や櫟を切り仆して椎茸のぼた木を作る。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山葵や椎茸にはどんな水や空気や光線が必要か彼らよりよく知っているものはないのだ。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁もどきッて、ほら、種々なものが入った油揚があらあ、銀杏だの、椎茸だの、あれだ、あの中へ、え、肴を入れて交ぜッこにするてえことあ不可ねえのかなあ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昼と晩の順は忘れたが、鱒と葱の玉子綴、鳥のスチウ、鱒のすりみと椎茸と茗荷の椀。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、いつかどこかでごちそうになったときに出された吸い物の椎茸をかみ切った拍子にその前歯の一本が椎茸の茎の抵抗に負けてまん中からぽっきり折れてしまった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が書いて新聞に出しますから」　皆がパチパチと手をたたくと、お次に椎茸が立ち上りました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆さん、私は椎茸というものです。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ椎茸さんのような畠も作ってくれません。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶にこぼれて出て来るのは、小姓梅之助に手を曳かるる腰元の青柳か、密と外して酔ざましの椎茸髱。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁もどきツて、ほら、種々なものが入つた油揚があらあ、銀杏だの、椎茸だの、あれだ、あの中へ、え、肴を入れて交ぜツこにするてえことあ不可ねえのかなあ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が言ふまでもなく、それどころか、椎茸も湯皮もない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松茸、椎茸、とび茸、おぼろ編笠、名の知れぬ、菌ども。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかなは、鑵詰の蟹と、干椎茸であった。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕗、椎茸つけあはせ、蒲鉾、鉢。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の入口に請願巡査の小屋があってそれから道の両側に欅の並木があり、その先は折れ曲っているので玄関はどのくらい先にあるか判らない金持の邸の並木の欅五六本目のところでカーキ色の古ズボンを穿いた老人が乾した椎茸を裏返している。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな町中で椎茸が栽培出来るのか。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人は多く材木とか椎茸とか木炭とかいふ山の産物で生活してゐるのです。",
              "citation": {
                "source": "樹木とその葉",
                "author": "故郷の正月",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節は春に止めを刺すので、材料はたい、にんじん、たけのこ、ふき、さやえんどう、しいたけ、玉子焼、紅しようが、木の芽などである。",
              "citation": {
                "source": "わが妻の記",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐は急におなかがへってきましたし、頭のこぶは、しいたけみたいに大きくもりあがっていてとても熱をもっていました。",
              "citation": {
                "source": "狐物語",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、駕の垂れを上げて「何うぞ、旦那様」「いや、乗るのは、女じゃ」　駕屋は、御殿風のしいたけ髱の深雪と、小藤次とを見較べて「じゃあ、お腰元様」　と、御辞儀をした時「小藤次、御苦労」　と、小藤次の後方で、声がした。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それに、いかに方便だってあの晩の話で見りゃあ、三斎屋敷のわがままむすめ、大奥のこってり化粧にも、何かたらし込みをしている容子――あれほどの男を、しいたけ髱なんぞだけに、せしめさせて置くってわけはねえよ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
