          "literary": [
            {
              "text": "儀注は現在行はれてゐる儀式の次第書き。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安朝の文献に、宮廷の御神楽に、人長の舞ひの後、酒一巡して、才の男の態がある、と次第書きがある。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "江家次第・西宮記などにも「人長の舞」の後、酒一｜巡して「才の男の態」があると次第書きしてゐる。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――というのが、時の「護国寺供養記」に誌された“行幸次第書き”だった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
