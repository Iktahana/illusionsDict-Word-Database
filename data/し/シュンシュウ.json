[
  {
    "uuid": "0c06b0e5-375c-5e70-9a81-24ed7bcd42bf",
    "entry": "俊秀",
    "reading": {
      "primary": "しゅんしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
