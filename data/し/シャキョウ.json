[
  {
    "uuid": "e2794512-f533-5aaf-ac3c-1bf689e8fe6f",
    "entry": "写経",
    "reading": {
      "primary": "しゃきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
