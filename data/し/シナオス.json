[
  {
    "uuid": "5980e778-ba8c-5d48-89e4-5d7289e37f59",
    "entry": "し直す",
    "reading": {
      "primary": "しなおす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行"
      ],
