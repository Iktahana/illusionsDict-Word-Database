[
  {
    "uuid": "8a57d759-a8f3-5753-af1e-2bec7a952bf5",
    "entry": "収斂",
    "reading": {
      "primary": "しゅうれん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
