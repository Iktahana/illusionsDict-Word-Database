    "definitions": [
      {
        "index": 1,
        "gloss": "light used for brightly lighting up a plaza, building, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは諸々の観測器具を始めとし食糧、飲料、工具、通信器、照明灯などの外にダイナマイトと水中鏡も加えられ、これらがずらりと並べられたところは、仲々ものものしかった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "天じょうの上の古風なシャンデリアと、四方の壁間にとりつけられた、間接照明灯が、影のない明かるい照明をしている。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に金博士の深海歩行器というのは、直径三メートルばかりの丈夫なる金属球でありまして、中に一人の人間が入り、局所照明灯により、前方の機雷や防潜網を避けながら歩行機械により海底を歩行出来る仕掛けになって居りますが、十分ドーバー海峡下の水圧には耐えるようになって居ります。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓は上の方に小さく、天井には水銀灯をつかった照明灯が、気味の悪い青白光を投げかけていた。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "側に立つルネサンス風の高い照明灯は、いよいよ明るさを増していった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、室内に大きな電灯が消され、壁の一方から円錐形に投光される照明灯だけがのこった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂葉が、あたり五メートル四方が満月の下ほどの明るさになる照明灯を点じた。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾部には強力なる照明灯が点いていて、昼間のように明るい。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い鉄塔の上から照らしつける照明灯は、地上を昼間のように明かるくして、どこにも影がない。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、刻々と明かるさがひろがっていって、高い鉄塔の上から照らしつけている照明灯の光が、だんだん明かるさを失っていった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにく要塞の側面から発する数十条のつよい照明灯がまぶしく目を射て、こまかいところはわからないが、はるか上の方に、あやしげなりんかくが、はけでかいたようにぼーっとうかびでている。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいわい艇についている照明灯一つが、消えのこっているので、あたりは見える。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ太平洋魔城　外は、海水が、海底要塞の照明灯にてらしだされてうつくしくかがやいていた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "低温室の内部の壁が白木で張ってあるので、照明灯の光が映えて、室全体が煌々と輝いて、如何にも暖かそうに見える。",
              "citation": {
                "source": "映画を作る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題だけについて見ても、初めからこういう室内で特殊の効果を出すような照明灯から、工夫してかかるべきであったということが、後になって分った。",
              "citation": {
                "source": "映画を作る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを書きこれを起し題は何とつけたらよいか、私は起きて蛍光灯の一般照明灯を点け、さらに等身くらいある電気スタンドをともし、病室の白昼を呼び戻して見た。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "照明灯が一本だけ、立っていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "広っぱには、高いはしらの上に照明灯がつけられ、その光のなかに、十数名の制服のおまわりさんが、大きな円をえがいて立ちならんでいました。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
