  {
    "uuid": "7af37434-489f-5b83-a9d2-ba147410f980",
    "entry": "社歌",
    "reading": {
      "primary": "しゃか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "company song",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "玄文社歌舞伎座にて観劇。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄文社歌舞伎座見物。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で国民の歌とか校歌社歌等が作られる場合、通例まず歌詞が決められ、その曲は一人の専門家に委嘱するか、公募して審査員が選ぶ。",
              "citation": {
                "source": "歌詞とその曲",
                "author": "信時潔",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古来風体抄』に、必ずしも錦、繍のごとくならねども、歌は、ただ読みあげもし、詠じもしたるに、何となく艶にも哀れにも聞ゆることのあるなるべし、といっており、『日吉社歌合（日吉七社歌合・慈鎮和尚自歌合）』の判詞にも、同じような説明をしている。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水が凍らないように、長い棒でしょっちゅう水面をばしゃばしゃかきまぜ、叩いていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも裏の事実は一人の例外なしに、堂々、不正の天才、おしゃかさんでさえ、これら大人物に対しては旗色わるく、縁なき衆生と陰口きいた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝は、まるで、緑色のしゃか、旗のように、波うって、ひろがりました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストも、おしゃかさんも、ごちゃまぜになった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、また、机の引き出しを、くしゃくしゃかきまわす。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃから、色が黒くても南洋じゃ美人というあの歌がきらいやねん」と言い、顎をなでて、「今日一ぺん化粧してこましたろ思て、髭剃ったんやけど、あとからなんぞつけるのん忘れたよって、ひりひりして痛いわ」と言うのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "地雷でも踏んだように突然トラブルが発生し、せっかくそこまで作ってきたものが何度かおしゃかになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "できあがった個体の遺伝子を種が変わるほどひん曲げようと、放射線を浴びせたりレトロウイルスを束にしてぶち込んだりすれば、個体がおしゃかになるだけだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、ええ、どうせあっしゃかわいい子分じゃねえんでしょうからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が鳥打帽をぬいで、頭をもしゃもしゃかきながら、その日は曇った六月の空を仰ぎ、何かいって、三人はやがて面白そうに笑い出した。",
              "citation": {
                "source": "坂",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナムアミダブツのおしゃか様。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ又後便で…………皆たっしゃか、気をつけて、僕は大変健在。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰ちゃんも、皆たっしゃか。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰ちゃんはどうしている、僕のことを忘れてへんやろか、たっしゃか。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰ちゃん、たっしゃか。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちは皆、たっしゃか、重子もたっしゃか、泰弘も。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかアさんも、三休橋も、丼池も、安堂寺町も、皆たっしゃかね。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お千代、たっしゃかえ！",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾、あなた様から、お隠匿していただきました晩、あなた様、眠りながら、お千代、たっしゃかえ、たっしゃでいておくれと仰有いましたが、お千代様とおっしゃるお方は？",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とわたしはギョッとしましたが、「へい……何んでございますか」「あのお方たっしゃかい」「え？",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　しゃかどん大阪府三島郡｜佐位寺に「つの」とも「かど」とも訓む字と、其第三の訓とを用ゐて、家の名とした一家がある。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、脂のぎらぎら浮いてる味噌汁を、音を立ててすすったり、佃煮で茶漬にした御飯を、くしゃくしゃかんだりしますのを、そばで見ていますと、その匂いがむかむかと胸にきて、私はもう何にも食べる気がなくなります。",
              "citation": {
                "source": "食慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（つづけてよむ）いかなるちしき上人、そのかみ、しゃか仏ほどのにょらいも、五体に身を受けたまえば、やまいのくるしみ、しょうろうびょうしとて、なくてかなわぬ物にて候。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆかないと、さむい日に、てめいのいのちは、おしゃかになるぞ。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしゃかになるというのは『毀す』という隠語だがこれは工場なんかで使われる言葉だ。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は柱時計、第二は水甕、第三は花瓶、第四は寝台というわけで、今までのところで、この租界の中に於て、この四つの品に限り全部おしゃかになってしまったではないか。",
              "citation": {
