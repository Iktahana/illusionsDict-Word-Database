[
  {
    "uuid": "d6dae45f-2cce-53e6-b191-5cec1ea34ce9",
    "entry": "釈迦",
    "reading": {
      "primary": "しゃか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
