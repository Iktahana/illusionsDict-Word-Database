      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Gautama Buddha",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（釈迦は諦観したであらうが、諦観した人として歩いたかどうか私は知らぬ。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦はその同じ虚無の寂しさから、森林に入って出家し、遂に人類救済の悟道に入った。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに社会的自個の行動は、毫も戒飭するところなく検束する趣なく、極めて随意に、心の動くままに振舞いたり、親鸞のいわゆる自然法爾なるものと、すこぶる相似たるの跡ありといえども、しかも子規子の態度は、釈迦如来の知らざるところ、親鸞上人の知らざるところなり、嗚呼あに偉ならずや、予はなお終に臨で一言せん。",
              "citation": {
                "source": "絶対的人格",
                "author": "正岡先生論",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦が譬喩に云った事を出家が真に受けているのが可笑しいというのである。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "※４　舎利＝本来は釈迦の骨。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでこの竜は天上にうまれ、後には世界でいちばんえらい人、お釈迦様になってみんなに一番のしあわせを与えました。",
              "citation": {
                "source": "手紙　一",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときの虫もみなさきに竜の考えたように後にお釈迦さまから教を受けてまことの道に入りました。",
              "citation": {
                "source": "手紙　一",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにしてお釈迦さまがまことのために身をすてた場所はいまは世界中のあらゆるところをみたしました。",
              "citation": {
                "source": "手紙　一",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聖人になりたい、君子になりたい、慈悲の本尊になりたい、基督や釈迦や孔子のような人になりたい、真実にそうなりたい。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子や釈迦や耶蘇もいろいろなちがった言葉で手首を柔らかく保つことを説いているような気がする。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "法華経見宝塔品という経文の中に、多宝塔（この宝塔の中には如来全身有す）という塔が地中より涌き上って空中に止まり、その中に多宝如来と釈迦仏とが並んで座せられる場面が書いてあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場面で、多宝如来は真理を現し、釈迦仏は智慧を現している。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを、多宝塔中、釈迦多宝の二仏の並座で表現したのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦如来を本尊とする仏像の脇士は、左に文殊菩薩、右に普賢菩薩であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本尊の釈迦如来は、その平衡の取れた円満な真理を現しております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平等の文殊と、差別の普賢を脇士に控えた中道真理の釈迦如来の仏像。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、今から二千五百年の昔、中印度、迦毘羅城に、釈迦族の王子として生れ、現実の悲哀を観じ、二十九歳にして出家せられ、六年苦行、三十五歳にして道を得られ、四十五年間説法の後、八十にして入滅せられた釈尊も、仏陀と称するのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私達二人は生きながら悪鬼となって、人情を軽蔑したあなたを始め、釈迦仏教団の人々に向って生々世々怨みをなすが、これは如何だ？",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園精舎に在す釈迦牟尼仏よ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無祇園精舎に在すわが師釈迦牟尼世尊よ！",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神将のＣ　――われ等の教主釈迦牟尼世尊は美しくまします。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神将のＢ　――して見ると阿難の美しさは感情を攪きまわす器械でお釈迦さまの美しさは感情の水｜漉し器械だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様はそれでも釈迦教団の幹部か。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にまた仏教の創設者｜釈迦牟尼を見よ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦は出離の道を求めんが為に檀特山と名くる林中に於て六年｜精進苦行した。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に釈迦は集り来れる多数の信者に対して決して肉食を禁じなかった。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどこれ畢竟不具である畸形である、食物のみ厳格なるも釈迦の制定したる他の律法に一も従っていない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦はその晩年、その思想いよいよ円熟するに従て全く菜食主義者ではなかったようである。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水が凍らないように、長い棒でしょっちゅう水面をばしゃばしゃかきまぜ、叩いていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも裏の事実は一人の例外なしに、堂々、不正の天才、おしゃかさんでさえ、これら大人物に対しては旗色わるく、縁なき衆生と陰口きいた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
