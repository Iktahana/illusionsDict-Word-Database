        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近江商人の店などでは、新潟あたりから小僧をやとひ番頭にしてやるといふ條件でながい間の奉公を勸めさせ、やがてそれが相當の年配になると、酒や女で店をしくじるやうに仕向けて、結局店から追つ放つてしまふといふことが、常套的に行はれてゐるさうである。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それはそれとして、今度の計画はうまく行くかな、やりしくじると困るんだ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸席をしくじることは、ヤトナとしては自殺にひとしい。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "このポイントさへはづさないやうにして書いたなら、しくじることはあるまい。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このポイントさえはずさないようにして書いたなら、しくじることはあるまい。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざとしくじる楽しさを知れ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の仏像は御首をしくじるなんと予感して大にショゲていても、何のあやまちも無く仕上って、かえって褒められたことなんぞもありました。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……嫁御はなるほど、わけしりの弟分の膝に縋って泣きたいこともありましたろうし、芸妓でしくじるほどの画師さんでございます、背中を擦るぐらいはしかねますまい、……でございますな。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも、自分の手にしている事件に対してあまり深謀すぎたり浅慮すぎたりしてしくじるのだ。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対にドラフツでは、動きが一様で変化が少なく、しくじる率も少ないし、わりあいに注意力も働かされずにすむので、利益はすべて、どちらかの優れて明敏なほうが得ることになる。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらがこんな事をしゃべったなんていうことが津の国屋へ知れると、出入り場を一軒しくじるような事が出来るかも知れねえから。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一それが本当ならば、お定ばかりのことではなく、兄もお店をしくじるのは知れていますから、母はすぐに支度をして、京橋の店へその実否をただしに行くことになりまして、慌てて着物を着かえているうちに、俄かに持病が起りました。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷をしくじるように、あたしはふだんから祈っているんだから」「冗談じゃあねえ」と、林之助は仕方なしに笑った。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談ではあろうが、屋敷をしくじるように祈っていると言ったこともある。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつてなまじつかなところへ奉公なんかすると、身をしくじる元だから、それこそよく何した上でないと。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はしくじるまいと、藤一郎は自転車に燈をつけた。",
              "citation": {
                "source": "少年",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや敵もまたしくじるから同点になるよ、見ていたまえ」　とイルコックがいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "教場で折々しくじるとその時だけはやな心持ちだが三十分ばかり立つと奇麗に消えてしまう。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "事が表立てば、彼は学校をも世間体をもしくじるだろう。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "各の本ごとに、暗号を書きしくじる、それも妙だが、それを又、本の中に必ず置き忘れるということが奇妙である。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さん方みんながたびたびしくじるのは、そこなんだ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "しくじる時はどう石橋を叩いてみてもしくじるものでござらうて。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「万一｜見咎められるようなことがありましょうとも、一命に懸けて御一同の難儀になるようなことはいたしませぬ」「その覚悟で行けば、しくじることもあるまい。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄だけではありません、若いものでも時々しくじることがあるのです。",
              "citation": {
                "source": "雪",
                "author": "津村信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪くするとしくじるよ」　「いや陸軍にも、わかった人もあるが、実に話のできン男もいるね。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪くするとしくじるよ」「いや陸軍にも、わかった人もあるが、実に話のできン男もいるね。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸子の位置が殺して戻るに最も有利で、一同の後へ戻ればよいのだから、そしてその間に人の介在が皆無なのだから、彼女の場合戻り道でしくじる危険は全くなしと断じてよい。",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
