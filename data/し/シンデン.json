[
  {
    "uuid": "898d3902-c0d3-52f4-bfeb-267df3c1408d",
    "entry": "神殿",
    "reading": {
      "primary": "しんでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "temple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして多分そのためであろう、神殿の屋根がだいぶ風にいたんでいるように見受けられた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘルメスのために私が建てた小さい神殿、直ぐそこの、あの神殿が私にとって何であるかを知ってはいまい。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も知る人はないが、このきゃしゃな神殿は、私が嬉しくも愛した一人のコリントの乙女の数学的形像だ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この神殿は彼女独自の釣合を忠実に現わしているのだ｛５｝」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この個人的な経験はおそらく一般的には応用が利かないであろうし、ましてや、科学の神殿を守る祭祀の司になろうと志す人、また科学の階段を登って栄達と権勢の花の山に遊ぼうと望む人達にはあまり参考になりそうに思われないのである。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野口氏の本質的心境たる熱情を、世間の人は殆んど知らず、皮相なる氏の表皮からして、いたづらに氏をクラシツクの詩匠として所謂「世界的詩人」の無意味な神殿に祭りあげてる。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の詩壇一般、及び淺薄なる世間の俗見が見る野口米次郎氏は、正に世界的詩人の無意味な空語で「神殿に奉られてゐる道化者」の觀がある。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれだけにかえって祖父に対するなつかしみは浄化され純化されて子供等の頭の中の神殿に収められるだろうと思ったりする。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔すゝきすがるゝ丘なみを〕すゝきすがるゝ丘なみを、　　にはかにわたる南かぜ、窪てふ窪はたちまちに、　　つめたき渦を噴きあげて、古きミネルヴァ神殿の、　　廃址のさまをなしたれば、ゲートルきりと頬かむりの、　　闘士嘉吉もしばらくは、萱のつぼけを負ひやめて、　　面あやしく立ちにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちはビーナスの神殿に行きました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂地の灼けつくような陽の直射や、木蔭の微風のそよぎや、氾濫のあとの泥のにおいや、繁華な大通を行交う白衣の人々の姿や、沐浴のあとの香油の匂や、薄暗い神殿の奥に跪いた時の冷やかな石の感触や、そうした生々しい感覚の記憶の群が忘却の淵から一時に蘇って、殺到して来た。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、彼はプターの神殿の祭司ででもあったのだろうか。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち新しき筵を敷いた神殿の床の上には、黄ろい綸子や藍の玉蟲の綾などの直衣を着た禰宜が色斑らに並ぶ。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神殿の廊下の外には女子供が立集って、きゃきゃと騒いだ。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神殿は野茨なり、風、そを祝ふ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "神殿の前に立つと、私たちは皆濡れしずくの麦稈帽を脱った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "神殿はもう薄紫の暮色がたちこめて、奥殿に何か幽かに光るものが神々しく拝まれた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖経はエルサレムの神殿を以て神の座すところとせり、其神殿に聖所あり、至聖所あり、至聖所には祭司の長の外之に入ることを得るもの甚だ稀なりと伝ふ。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士のうわ矢のかぶら一すぢに　　　思ひ切るとは神は知らずや」　と吟ずるや否や神殿の扉に発矢とばかり二本の矢を射かけた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "罰を当てるなら当ててみよ』　と破れた醤油樽を御神殿に投込んで人参畑へ帰って来たが、帰ってからこの話をすると、それは賞められたものじゃったぞ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしんがあゝして苦しんでんのに、駄目だの死んだのと縁喜くそ惡いことばかりぬかしやがつて、惡病神だ、サツサと出て行つてくろ！",
              "citation": {
                "source": "旱天實景",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
