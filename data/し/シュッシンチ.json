[
  {
    "uuid": "dc4d0d8c-2438-5b09-9d58-9b5293391249",
    "entry": "出身地",
    "reading": {
      "primary": "しゅっしんち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
