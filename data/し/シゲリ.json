    "definitions": [
      {
        "index": 1,
        "gloss": "growing thick",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山吹や井手を流るる鉋屑　崖下の岸に沿うて、山吹が茂り咲いている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭の日には、家々の軒に、あやめや、菖蒲や、百合などの草花を挿して置くので、それが雨に濡れて茂り、町中が忽ち青々たる草原のようになってしまう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三径の十歩に尽きて蓼の花　十歩に足らぬ庭先の小園ながら、小径には秋草が生え茂り、籬に近く隅々には、白い蓼の花が侘しく咲いてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年夏始めに、程近い植物園からこのわたりへかけ、一体の若葉の梢が茂り黒み、情ない空風が遠い街の塵を揚げて森の香の清い此処らまでも吹き込んで来る頃になると、定まったように脳の工合が悪くなる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の大名邸の高い土堤の上に茂り重なる萩青芒の上から、芭蕉の広葉が大わらわに道へ差し出て、街燈の下まで垂れ下がり、風の夜は大きな黒い影が道一杯にゆれる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなりに長いこの阪の凸凹道にただ一つの燈火とそのまわりの茂りのさまは、たださえ一種の強い印象を与えるのであるが、一層自分の心を引いたのはその街燈に止った一疋の小さいやもりであった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間もない茂りの緑は霜にややさびて得も云われぬ色彩が梢から梢へと柔らかに移り変っている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉の大木の下に床几を積み上げたるに落葉やゝ積りて鳥の糞の白き下には小笹生い茂りて土すべりがちなるなど雑鬧の中に幽趣なるはこの公園の特徴なるべし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これのみは樹木黒く茂りたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこの樹の茂りを見てはじめて三十年前の鶯横町を取返したような気がした。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯横町の椎の茂りを見ただけで満足してそのまま帰って来てよかったような気がする。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと共に、もし富士山に北米レイニーア火山のような氷河が放射していたならば、今の白石楠花の茂りは押し流されて見るべくもないから、私は現在の万年雪で満足し、花と雪を併せ有することを悦びとしたい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲店の軒には花樹が茂り、町に日蔭のある情趣を添えていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は天主閣の建っていた所が平地になって、いつしか姫小松まばらにおいたち、夏草すきまなく茂り、見るからに昔をしのばす哀れなさまとなっています。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この盛んな勢いで生長している植物の葉の茂りの中に、枯れかかったような薔薇の小枝から煤けた色をした妙なものが一つぶら下がっている。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ路傍の草いきれが恐しい、大鳥の卵見たようなものなんぞ足許にごろごろしている茂り塩梅。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや枕をもたげて見る、竹縁の障子あけ放して、庭つづきに向いなる山懐に、緑の草の、ぬれ色青く生茂りつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは茂りあった枝のかげで、まっくらでしたが、二疋はどっちもあらんかぎりりんと眼を開いてゐましたので、ぎろぎろ燐を燃したやうに青く光りました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは茂りあった枝のかげで、まっくらでしたが、二疋はどっちもあらんかぎりりんと眼を開いていましたので、ぎろぎろ燐を燃したように青く光りました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さな、緑色に繁茂り栄えた島の中には、稀に居る大きな蟻のほかに、私たちを憂患す禽、獣、昆虫は一匹も居ませんでした。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから炭坑のトロ道が作る黒い投影の中を一散に走って、直方駅構内の貨物車の間を影のようにスリ抜けて、ほど近い日吉町の日吉旅館の裏手に来た青年は、素早く前後を見まわして、警戒のないのを見定めてから蔦蔓の一パイに茂り絡んだ煉瓦塀をヒラリと飛越えた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど空気は重く湿り、茂り合う葉桜の陰を忍びにかよう風の音は秋に異ならず、木立ちの夕闇は頭うなだれて影のごとく歩む人の類を心まつさまなり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面の上にはトマトの茂りがあつて、採り殘された實の熟したのが、こゝに一つかしこに一つ、赤々と小さな色を殘してゐる。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其方の……貴女のお庭に、ちよろ／＼流れます遣水のふちが、此の頃は大分茂りました、露草の青いんだの、蓼の花の眞赤なんだの、美しくよく咲きます……其の中で鳴いて居るらしいんですがね。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又あとより枝一枝、桂の葉の茂りたるが、藍に緑を飜し、渦を捲いてぞ流れ來る。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼方では、一團の水兵がワイ／＼と騷いで居るので、何事ぞと眺めると、其處は小高い丘の麓で、椰子や橄欖の葉が青々と茂り、四邊の風景も一際美はしいので、今夜は此處に陣屋を構へて、大祝賀會を催すとの事、其仕度に帆木綿や、檣の古いのや、倚子や、テーブルを擔ぎ出して、大騷ぎの最中。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」七　籠の囮　倉瀬泰助は旅店を出でて、雪の下への道すがら、一叢樹立の茂りたる林の中へ行懸りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目も及ばざる広庭の荒たきままに荒果てて、老松古杉蔭暗く、花無き草ども生茂りて踏むべき路も分難し、崩れたる築山あり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――閨、いや、寢床の友の、――源語でも、勢語でもない、道中膝栗毛を枕に伏せて、どたりとなつて、もう鳴きさうなものだと思ふのに、どこかの樹の茂りへ顯はれない時は、出來るものなら、内懷に隻手の印を結んで、屋の棟に呼びたい、と思ふくらゐである。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の根について三所ばかり、寺院の棟と、ともにそびえた茂りは、いづれも銀杏のこずゑらしい。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
