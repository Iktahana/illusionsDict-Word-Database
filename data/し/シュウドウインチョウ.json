[
  {
    "uuid": "199fe3e5-5a29-571f-aaef-f17546e919e0",
    "entry": "修道院長",
    "reading": {
      "primary": "しゅうどういんちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
