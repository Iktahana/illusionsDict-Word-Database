    "definitions": [
      {
        "index": 1,
        "gloss": "Shōwa era (1926.12.25-1989.1.7)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「西部劇通信」だの「ゼーロン」だのを書いた昭和五年の頃は、彼の返り咲きの観があつたし、評判がよかつたのであるが、あの頃のものよりも、それから暫く後に書いた、水車小屋の壁に凭れて月の明りで手紙を読む短篇なぞの方が、遙かに牧野さんらしいものであると思はれる。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十六年九、十月）",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「芸術新聞」昭和十七年八月――",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十一年に、砂子屋書房から出ました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和五六年の頃より、つまり小林秀雄が文壇に現れて間もなくの頃より、文芸評論は頓に盛んになつて、現今猶益々盛んである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年春、河上に紹介さる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和四年同人雑誌「白痴群」を出す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和五年八号が出た後廃刊となる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和七年季刊誌「四季」第二輯夏号に詩三篇を掲載。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和八年五月、偶然のことより文芸雑誌「紀元」同人となる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和八年十二月、結婚。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年四月、「紀元」脱退。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年十二月、「ランボオ学校時代の詩」を三笠書房より刊行。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十年六月、ジイド全集に「暦」を訳す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十一年六月「ランボオ詩抄」（山本文庫）刊行。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十二年より昭和八年十月迄、毎日々々歩き通す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和七年の夏金沢を訪れた時、その松が見たかつたが、今は見知らぬ人が借りてゐる家の庭に這入つてゆくわけにも行かなかつたが、家は前面から見た限り、昔のまゝであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和七年に行つた時、幼稚園は早速に見に行つた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年九月十五日中原中也高橋新吉様",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十一年一月著者郷愁の詩人｜与謝蕪村蕪村の俳句について君あしたに去りぬゆうべの心｜千々に何ぞ遥かなる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年二月著者我が心また新しく泣かんとす冬日暮れぬ思ひ起せや岩に牡蠣漂泊者の歌日は斷崖の上に登り憂ひは陸橋の下を低く歩めり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸郷昭和四年の冬、妻と離別し二兒を抱へて故郷に歸るわが故郷に歸れる日汽車は烈風の中を突き行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川沖觀艦式　　昭和四年一月、品川沖に觀艦式を見る。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "國定忠治の墓　　昭和五年の冬、父の病を看護して故郷にあり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「地下鐵道にて」「昨日にまさる戀しさの」等凡て昭和五――七年の作。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和三年頃の或る雜誌に、近頃トルストイやドストイェフスキイを言ふのは時代遲れだと書いた人がある。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも昭和十年頃の最近になつて、それらのもつと古臭いゲーテやハイネが、漸く少しばかり本體を知られて來たのである。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、大正昭和と俳句隆盛時代の経過するうちに、栄養に富んだ食物も増し料理法も進歩したことはたしかであるが同時にビタミンの含有比率が減って来て、缶詰料理やいかもの喰いの趣味も発達し、その結果｜敗血症の流行を来したと云ったような傾向がないとも限らない。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年九月『俳句研究』）",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年五月『輻射』）",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
