    "definitions": [
      {
        "index": 1,
        "gloss": "to bend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このごうごうと撓う大地、誰が無生物と思えようぞ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、遠慮したか、葭戸の開いた敷居越に、撓うような膝を支いて、框の隅の柱を楯に、少し前屈みに身を寄せる、と繻子の帯がキクと鳴る、心の通う音である。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜いて持った釵、鬢摺れに髪に返そうとすると、や、するごとに、手の撓うにさえ、得も言われない、異な、変な、悪臭い、堪らない、臭気がしたのであるから。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって布袋竹の釣竿のよく撓う奴でもってピューッと一ツやられたのだもの。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖の撓うを胸へ取った、前抱きにぬっと立ち、腰を張って土手を下りた。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ただ引伏せた練絹に似た、死んだようなお冬の姿が、撓うばかりに揺れたのであります。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつい雨で、見ていると大事な空地の花壇の青紫蘇がぴしぴし雨脚に打たれて撓う。",
              "citation": {
                "source": "雨と子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃子の心と体とはそういう順助の声の優しい重さに撓うばかりである。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そのように瑞々しく撓えば撓うほど、桃子の肉体の内に一つの叫びが高まるのをどう説明したらいいだろう。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、父の体はどっしりして重く、手が撓うようになる。",
              "citation": {
                "source": "種紙の青む頃",
                "author": "前田夕暮",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩の枝が撓うばかりに露の置いた趣で、そう具体的に眼前のことを云って置いて、そして、「寒くも時はなりにけるかも」と主観を云っているが、感の深い云い方であるのは、「も」、「は」などの助詞を持っているからである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく撓う大阪格子の戸をあけると、口髯ばかりいかめしい貧相な男が、袴のうしろをひきずりながら出てきた。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳の枝のようによく撓う小さな手だった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊の枝のようなよく撓うあの小さな手。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪割りから水汲みと、越後から来た飯炊男のように実を運んでも、笹の雪、撓うと見せて肝腎なところへくるとポンと撥ねかえす。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人分を感じて、私の心は撓うようです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからみそこしね、あのわくはよく撓う木ですが、それもなくなって来ていますって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "風にさえ、すぐブランブラン揺れる足場だし、歩くと、上下にも撓うので、自然、その上での動作は曲芸師の身ごなしが身につく程なものだった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろくほどしなやかで柔らかく、こっちの思うままに撓ううぶな躯の芯で、そんなに強く反応するものがある、ということがおれを夢中にしてしまったらしい。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の感じでは、平生でもミシミシ撓うヘギのような梯子段が、両側から帆のように膨らむ壁と壁に挟まってメリメリ壊れかけて来たと思えた。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその撓う竿を持ったまま、頭を垂れた、低く頭を垂れて、そして口の中で囁いた。",
              "citation": {
                "source": "鵜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意して渡っても危ないほど撓う。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足下の地面が撓うのを感ずる下水夫らは、いつもまず第一に、その道具袋や負い籠や泥桶を投げ捨てるのであった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十｜哩、六十哩、彼の車は車体が撓う程の速力で、車輪も宙に疾駆した。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵は樫の黒い柄が撓うほど、それを振っていた、また突いてはねとばした、また上から撲りつけた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、本文通り、黒革縅の大鎧、樹蔭に沈んだ色ながら鎧の袖は颯爽として、長刀を軽くついて、少し屈みかかった広い胸に、兵の柄のしなうような、智と勇とが満ちて見える。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と白い手と一所に、銚子がしなうように見えて、水色の手絡の円髷が重そうに俯向いた。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵のものは五枚以上積めば気をうしなうのである。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家をやしなうぐらい、今ではなんでもないのですから。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "へいぜいは頭のよい人でも、しょうばいを失うかどうかというようなせとぎわでは、正しい判断をうしなうものである。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
