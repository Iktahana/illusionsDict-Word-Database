        "examples": {
          "standard": [
            {
              "text": "一度決めた目標は、信じきることで必ず達成できると彼は言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は自分の直感を信じきり、誰もが反対する道を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このチームなら絶対に優勝できると、監督は選手たちを信じきっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「僕はあなたを信じきる事ができればどれほど幸いだか知れないと思うんです。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合、たとへ冷静な判断といふものが得られたにしても、甲のそれは乙を服せしめることはまづ不可能であり、乙は自分の意見が正しいために、却つて冷静に甲を説得できぬものと信じきるやうな場合もある。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの娘の言葉も信じきるわけにはゆかない」　と金吾は迷いました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
