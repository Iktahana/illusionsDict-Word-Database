    "definitions": [
      {
        "index": 1,
        "gloss": "nervous disorder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もちろん肺病ばかりでなく、精神病や、神経病も随分多いことと思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのふるえようがあんまりひどいので私は少し神経病の疑さえももちました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家系を調べて見ると神経病で伯父が死んだ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経病の怪談にて、菊五郎の娼妓おさよ、好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "剰へ日が血のやうに西からのぼり、月が痺れて東へ落ちかかる怪しい神経病者の幻想さへ時折発作のやうに霊自身を慴やかす。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あゝ、堪らない／＼、神経病になりさうだツ、煩さい／＼、どこかへ行つてしまへツ！",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経病のはじめなんだア！",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の神経病にも困つたものだ。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、神経病の分野なんですが、あたり前の神経衰弱とは違つて、或る時機が来れば、必ず治る――明日にでも、いや、次の瞬間に於いてゞも……」　加藤は、苦笑を浮べた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のは何も神経病といふわけではないんだから、灸など真つ平だ。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤグラ峠の唐松の下で私の祖父は頻りと狐に化されて幾多の滑稽や悲惨なる挿話を今も尚ほ人々の口に残してゐたが、恰度私達の行手には例の唐松が踊りあがつたやうな枝を空へ張り、飄々と風を呼んでゐる風情は、まさしく神経病患者の独り路であるならば容易く山霊の催眠術を吹き込むにふさはしかつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　彼女の父親の名前は僕も兼々聞き知つてゐた神経病科の有名な医学博士である。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの神経病みの雨蛙みたいに。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の墓を掘ると神経病になって死ぬと云う云い伝えがこの地には昔から流れているのだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の中のある部分は神経病的に整然と物が並び、だれかが彼女のるすにホンの一ミリほど品物を動かしてもすぐに気づいてしまう。",
              "citation": {
                "source": "わが妻の記",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九〇年代のフランス文学の潮流は、一方に象徴派が隠遁超脱の城に立てこもり、一方には自然主義者たちが、象徴派の人々の神経病を嗤っているという時代であった。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法医学的な分野で接近があり、心理学、神経病理学とのつながりがあるからなのだろうか。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ年は若いのだが、彼女の姉が死んでまだ間もなく先の夫と結婚したのだが、神経病で死にそうだと云う。",
              "citation": {
                "source": "樹蔭雑記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨人間は右の如く慾あるものなるに若しそを少しにても押へて発せざらしめば、即ち百斤のものを九十五斤となさば其人は神経病を起すなり。",
              "citation": {
                "source": "読書弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "憐れむべきにあらずや〔医師の話を聞くに、近来は神経病および発狂の病人多しという〕。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "性慾は制限すれば健康を増すが、画家から筆を奪うとじきに彼は神経病になる。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソリエはその現象を、神経病の一種のオートスコピー・エクステルヌと云っている。",
              "citation": {
                "source": "奇怪な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰国後の算哲博士は、日本の大学からも神経病学と薬理学とで二つの学位をうけたのだが、教授生活には入らず、黙々として隠遁的な独身生活を始めたものだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒死館の人々は、恐らくその程度こそ違うだろうが、厳密な意味で心理的神経病者たらざるはない――と」　誰しも人間精神のどこかの隅々には、必ず軽重こそあれ、神経病的なものが潜んでいるに相違ない。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、モッソウの『疲労』を引き出さなくても、神経病発作や催眠誘示には、すこぶるつきの好条件になってしまう。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人の神経病的天性を探ることと、その狂言の世界を一つの心像鏡として観察する――その二点に尽きる。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ロダンの『接吻』の中から、僕がいま発見した内容にも記されているとおりで、ダンネベルグ夫人もやはり砒食人――常日頃神経病の治療剤として、夫人は微量の砒石を常用していたのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マヌエラにはマレー女の血がある“Latah”は、マレー女特有の遺伝病、発作的神経病だ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
