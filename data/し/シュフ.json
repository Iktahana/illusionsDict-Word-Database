[
  {
    "uuid": "a6859161-e17f-5f3c-a57f-a8cbb57c2beb",
    "entry": "主婦",
    "reading": {
      "primary": "しゅふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
