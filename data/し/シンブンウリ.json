        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三　○○町の停留場に新聞売りの子供が立っていた。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして思いついたのは新聞売りと砂書き。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日清の間が切迫してくるや、彼はすぐと新聞売りになり、号外で意外の金を儲けた。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞売りや夜店商売なんかで学問の出来るはずはない。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "直吉は手近な所に店を出してゐる、新聞売りの女から、新聞を買つた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木の下には花売り、新聞売り、くだもの売りの御婆さん達娘達が嬉々として生を楽しんでゐる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の争いの仲裁者となったり、病める青年を慰めたり、新聞売りの老婆や、飯焚きの小娘や、犬やをも労わり愛した。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と鈴の音のけたたましゅう呼びあるく新聞売り子のあとより、一｜挺の車がらがらと番町なる川島家の門に入りたり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「船にも乗ったろうし、汽車にも乗ったろうし、新聞売りの手にも渡ったろうし、バッチンの穴の中へも入ったろうし、紙芝居のおじさんの手にも、そのほか考えたら、まだいろいろあるだろう。",
              "citation": {
                "source": "一銭銅貨",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の新聞売りの小僧が嘲弄的ではあるが悪意はない気持で、彼の仕業を不思議そうにながめていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞売り子が大勢繰り出し、辺りを大声でつんざいた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポプュレール新聞売り子ティイー。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞売りの少年がひとり、歩道の縁に立っていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ったんだけど、おまわりが大銀杏を探しに行ったときには、もうなんにもいやあしなかったよ」　ルンペンも、新聞売りの小僧も、中学生も、青年団員も、商店の御隠居も、通りがかりの会社員も一つになって、恐ろしいポスターの主人公について論じ合った。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さん、新聞売り子少年が叫んでいるチャールズ・マクスウェルと言う人が誰かは知らないでしょう。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの作戦の実行中、ほとんど知らなかったのですが、新聞売り子があの恐ろしい悲劇を叫ぶのを聞きました。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞売り子たちがメリヘイブン閣下の前を走りながら、見出しを叫んでいた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "外で、新聞売り子たちが忙しく動き、いつもより新聞をたくさん抱えている。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "くそったれの新聞売り子め。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新聞売り子の声は聞きました。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側の小さな新聞売り場です」「どうもありがとう。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜も遅かったが、新聞売り子達が声をからし舗道をうろつき、野暮な通行人に新聞を売りつけていた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の新聞売り子が道路のそこいら中におり、ラ・シガール新聞の宣伝看板を背負っている。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りには大勢の新聞売り子が行き交い、口々に叫んでいた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "どぶ板通りから新聞売り子がテムズ河畔の大火災を叫んでいる。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
