    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rice flour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「堅雪かんこ、しみ雪しんこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堅雪かんこ、凍み雪しんこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四郎はしんこ、かん子はかんこ、おらはお嫁はいらないよ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四郎はしんこ、かん子はかんこ、黍の団子をおれやろか。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凍み雪しんこ、堅雪かんこ、　　　野原のまんじゅうはポッポッポ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍み雪しんこ、堅雪かんこ、　　　野原のおそばはホッホッホ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堅雪かんこ、凍み雪しんこ、鹿の子ぁ嫁ぃほしいほしい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堅雪かんこ、凍み雪しんこ、しかの子ぁ嫁ほしい、ほしい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで四郎とかん子とは「堅雪かんこ、凍み雪しんこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅雪かんこ、凍み雪しんこ、狐の子ぁ嫁ぃほしいほしい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堅雪かんこ、凍み雪しんこ、硬いお餅はかったらこ、白いお餅はべったらこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キックキックトントンキックキックトントン　凍み雪しんこ、堅雪かんこ、　　　　　野原のまんじゅうはぽっぽっぽ　酔ってひょろひょろ太右衛門が　　　　　去年、三十八たべた。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キックキックトントン、キックキック、トントン、　凍み雪しんこ、堅雪かんこ、　　　　　野原のおそばはぽっぽっぽ、　酔ってひょろひょろ清作が　　　　　去年十三ばい喰べた。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さしみと、オムレツと、牛鍋とおしんこを下さい。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際ある浅薄な理想主義の芸術はまさにしんこ細工の花のようなものである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理には五分もすきはなく、数学の運算に一点の誤謬はなくても、そこに取り扱われている「天然」はしんこ細工の「天然」である。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「凍み雪しんこ、堅雪かんこ、　　　　野原のまんぢゅうはポッポッポ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍み雪しんこ、堅雪かんこ、　　　　野原のおそばはホッホッホ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
