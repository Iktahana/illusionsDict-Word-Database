        "examples": {
          "standard": [
            {
              "text": "昔は、親族結婚が珍しくなかった地域もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遺伝的な観点から、親族結婚にはいくつかのリスクが指摘されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は親族結婚を避けるため、遠い親戚とは距離を置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "陸軍の古い朋党組織や、統制官庁の指導トラストや、Inbreeding（親族結婚）で繁栄した〈五十一家族〉などを自らの手で解散する作業を、汗をながしながらやらなくてはならない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
