[
  {
    "uuid": "2c69819b-e717-5b76-9748-5ab6ea89ac88",
    "entry": "正直",
    "reading": {
      "primary": "しょうじき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
