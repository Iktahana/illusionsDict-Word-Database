        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「すっかり濡れてしまいましたけれど、どうやら開きました」　母親は四つに折った書簡箋をそっと抜き出して拡げた。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、最も簡単な書簡文を書かうと、あせりながら、一行書いては駄目にし、三行書いては破棄して、午までに、書簡箋を一冊費した。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の引出から、万年筆と書簡箋を出した。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "書簡箋、小形の封筒、そんなものを順々にお蔦が私の枕許に並べたてた。",
              "citation": {
                "source": "響",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な店頭の封筒　東京市中到る処の縁日や露天には、封筒や書簡箋の店が多い。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が留守だと、その机の抽出をあけて書簡箋にいたづら書きをしたり、悪意ではないんだが、他人から借りた物は返し忘れて紛失させたりして平気だつた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小判の白い平凡な書簡箋に見馴れた父の万年筆の筆蹟で、ところどころ消したり、不規則に書体を変えたり、文句を訂正したりしながら二十行の詩が書かれているのであった。",
              "citation": {
                "source": "わが父",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古文を用いますと、空っぽで内容はなくとも、八行の書簡箋はいっぱいに埋められるわけであります」ははあと、感服した。",
              "citation": {
                "source": "書簡箋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は居間に来て榛原の書簡箋を繰りひろげ、芳しい墨をすり流した。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも長いことかかってひどい万年筆で書いたと見え、桃色の、やはり四つ葉のクローヴァのついた書簡箋が、ところどころ皺になってさえいる。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄と弟」「書簡箋」「ベリンスキーの眼力」などは太平洋戦争中、作品の発表できなかった時分のノートから。",
              "citation": {
                "source": "はしがき（『女靴の跡』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙は桃色の書簡箋に覚束ないペンの字を並べたものだった。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度は手当り次第に一つの手紙の封を切り、黄いろい書簡箋に目を通した。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月初旬の日曜で、表側の朝子の部屋は人通りがうるさく、素子の室で、朝子は読み終った分から一枚ずつ書簡箋を素子にまわした。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書簡箋は、既に一年もまえ、現在のものに変えられたというのだからね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信子はさう云ふ寂しい午後、時々理由もなく気が沈むと、きつと針箱の引出しを開けては、その底に畳んでしまつてある桃色の書簡箋をひろげて見た、書簡箋の上にはこんな事が、細々とペンで書いてあつた。",
              "citation": {
                "source": "秋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、あのしわいＡが、書簡箋は、上にゴッホの絵のついた今まで買ったこともないようなものを買って来て居る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達は書簡箋一枚に、久々で手紙を貰つてうれしかつたこと、返事の遅れてすまなかつたこと、あなたも無事でうれしいこと、自分もどうにか平和でゐることなどが、達筆に走り書されてある。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大机に向かい、書簡箋の入っている引出しを明けた。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなたは、ケリヤムグインを書簡箋に吸収させました。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその書簡箋は、缶詰の中に厳封して、旗田鶴彌氏へ送ったのです。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんその書簡箋には、或る文句が書いてありましたがね。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その書簡箋を鶴彌氏が取出すと、文面を読んで確かめた上で、火をつけて焼き捨てたのです。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの懸賞小説に投稿なさるといいですなあ」「その書簡箋に書いてあった文面が、また興味あるものなんです。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれだけを有り合はせの書簡箋に心覺えに譯して置いたのであつた。",
              "citation": {
                "source": "色褪せた書簡箋に",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして中から四つ折の書簡箋を取出すと、開いてみた。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ書簡箋に、この方は楷書で丁寧に、こんな文句が認めてある。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや」と思ひながらその場で封を切つて、書簡箋五六枚に例の悪筆で乱暴に書きとばした文句を、ざつと読み通しました。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと見ると枕もとに書簡箋が一枚二ツ折にしてある。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
