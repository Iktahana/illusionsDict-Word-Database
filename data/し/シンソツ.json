[
  {
    "uuid": "7736d119-eab2-59e1-b065-26e9824b969b",
    "entry": "真率",
    "reading": {
      "primary": "しんそつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
