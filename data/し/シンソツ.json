      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "honesty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "されば、僭越乍ら、詩人諸氏が、何卒真率になられんことを希望してやまない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して、真率とは、――詩を書かう書かうと思ふことではなく、自分の現在に忠実であるといふことである。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が、真率にして齢を重ねる時、「習慣」の存在に対して次第に寛容になることは、自然なことである。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "真率にして富永は齢を重ねていつた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして真率｜朴訥という事から出て来る無限の大勢力の前に虚飾や権謀が意気地なく敗亡する事を痛快に感じないではいられない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめてこの時少年の面貌｜風采の全幅を目にして見ると、先刻からこの少年に対して自分の抱いていた感想は全く誤っていて、この少年もまた他の同じ位の年齢の児童と同様に真率で温和で少年らしい愛らしい無邪気な感情の所有者であり、そしてその上に聡明さのあることが感受された。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "真率であるべき人生の行為を、戯論で手遊にするというものです。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんという間違いをしたものだろう」　むす子に対する憧れが突然思いもかけぬ胸の中の別の個所から厳粛というほどの真率さでもって突き上げて来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しなやかさと真率なることに於て人生の一節を表現し巌の如き丈夫心をも即々と動かす。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞんざいというと非難するように聞えるが、そうではない、シネクネと身体にシナを付けて、語音に礼儀の潤いを持たせて、奥様らしく気取って挨拶するようなことはこの細君の大の不得手で、褒めて云えば真率なのである。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浄瑠璃の行われる西の人だったから、主人は偶然に用いた語り物の言葉を用いたのだが、同じく西の人で、これを知っていたところの真率で善良で忠誠な細君はカッとなって瞋った。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しく、しかも真率なる。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱烈の舌一世を罵り、勇猛の気英雄を呑み、豪快天地を嘲るが如き挙動を為しながら、別に一片の真率無慾なるところ、専念｜回向するところ、瞑目静思する処ろ、殆数個の人あるが如き観あるもの、何ぞや。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も我が真率ならざるを笑ふに似たり。",
              "citation": {
                "source": "一夕観",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は驚きてわが黄なる面をうち守りしが、わが真率なる心や色にあらわれたりけん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、趙の、この、平生に似ない真率な慟哭が私を動かした。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと真率であります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ彼の実験談か、あるいはヨブを諭さんための技巧なるか、いずれにせよかかる演劇的態度を以て悩める友を諭さんとするは、真率において欠くる所ありといわねばならぬ。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その平凡な事でも真率な心を以てマジメに考察し研究して見ればそれが動かすべからざる実際の現実である。",
              "citation": {
                "source": "文壇一夕話",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく君はかかる内部の葛藤の激しさに堪えかねて、去年の十月にあのスケッチ帳と真率な手紙とを僕に送ってよこしたのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "という事が、少し甘い、しかし真率な熱情をこめた文体で長々と書いてあったのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村の訪問したというのを聞いて、ひどくなつかしそうな様子で出迎えて、兄でも敬うようにもてなして、やや落ち付いてから隠し立てなく真率に葉子に対する自分の憧憬のほどを打ち明けたので、木村は自分のいおうとする告白を、他人の口からまざまざと聞くような切な情にほだされて、もらい泣きまでしてしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、沼南の応対は普通の社交家の上ッ滑りのした如才なさと違って如何にも真率に打解けて対手を育服さした。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、二葉亭のいうのは恐らくこの意味ではないので、二葉亭は能く西欧文人の生涯、殊に露国の真率かつ痛烈なる文人生涯に熟していたが、それ以上に東洋の軽浮な、空虚な、ヴォラプチュアスな、廃頽した文学を能く知りかつその気分に襯染していた。",
              "citation": {
                "source": "二葉亭四迷",
                "author": "――遺稿を整理して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "真率な文句、単調な身振り、節は誰も知っている「ナカノリさん」である。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吾も其頃は、感情の荒んだ今とは別人の様で、血の熱かい真率な、二十二の若々しい青年であつたのだ。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学が科学に向った想像力においては殆ど常にあわれな架空性に陥り、科学がその文学的な想像力においては、やはりとかく憫然たる架空性に陥らざるを得ないという今日の文化のありようについて、私たちは真率なかなしみと、それからの成長の熱い願いとを抱いてよいのだろうと思う。",
              "citation": {
                "source": "文学のひろがり",
                "author": "――そこにある科学と文学とのいきさつ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は忠直卿とともに、人間関係の真率、偽りなさ、まことの現実を求める人間の情熱を辿ってはいるが、虚偽を生む社会関係を主体的に忠直卿から判断させてはいない。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初三句は極めて拙き句なれどもその一直線に言い下して拙きところかえってその真率偽りなきを示して祈晴の歌などには最も適当｜致居候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁語に巧を弄せんよりは真率に言いながしたるがよほど上品に相見え申候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
