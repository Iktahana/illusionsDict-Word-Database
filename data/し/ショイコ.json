    "definitions": [
      {
        "index": 1,
        "gloss": "wooden rack with shoulder straps for carrying loads on one's back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お秋さんが背負子といふもので榾を背負つて涸れた谷の窪みを降りて來た。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "積み重ねた榾の上へ仰向になつて復た起きたら背負子だけが仰向の儘榾の上に殘つた。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秋さんは荷をおろすと輕げに背負子を左の肩に引つかけて登る。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が暇を告げて出たらお秋さんは背負子を負うて坂の中途まで行つて居た。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "背負子を負ふために殊更小さな綿入のちやんちやんを引つ掛けたので體が何時もより小柄に見えた。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秋さんは右の手を拔いて左の肩で背負子を支へて左の膝を曲げてそつと地上へ卸した。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "持つてゐて呉れといふので自分は背負子を支へてゐる。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秋さんは背負子を岩の上に乘せてくるりと背中を向けて背負つた。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は一足さきに出拔けて振り返つて見たらお秋さんは背負子を負うた儘婆さん達に取り卷かれて話をして居る。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鶏声堂に、中年の女の人が、冬はいつも真綿の背負子を著ていました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは自分でも人足の姿に身を変え、下男の佐吉に言い付けて裏の木小屋から「せいた」（木曾風な背負子）を持って来させた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピシピシと荷をまとめ、繩でしばって背負子にくゝりつけ、しっかりした足取りで急な雪渓を下りて行く。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "存在しない荷物をまとめて、それを背負子にくゝりつけるのである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで土地によっては連尺を背負子の手ともいい（三宅島）、あるいはまた荷繩のことだというものもある（佐渡）のである。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は、たった橋一つのちがいで、この厄介者をしょいこむのを拒絶する口実を見つけたらしい。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "めいめい大きな荷物をしょいこんで、押合いへし合いなんです。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "与吉もこれにはすっかり往生したが、振り返りでもしようものなら、そのとたんにぽかんと拳固がとんできそうな気がするし、一度などは与吉が道路にしゃがんでわらじを結びなおすと、泰軒は平然とそばに立って待っている始末で、駒形名うてのつづみの与吉、まるで大きな荷物をしょいこんだ形でほとほと閉口してしまった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那さまが、その掛川の借財をすっかりおしょいこみになったのでございますか」「さよう。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは同類なんだから、棺をしょいこんで来たやつに手を貸し、棺へ入ってきた替玉とお米をすりかえ、その中のひとりは中ノ玄関で待っていて、平野屋の隠居がかついできた棺の断りを言う。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "金鳳釵",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は、その事実だけをしょいこんで生きてるんです」「なにをいいたいんだ？",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つねに自分がしょいこみ、対面せざるを得なくなっている現在の処理にしか（処理が不可能だとわかることも含めて）、信じられる自分も、その相手も存在してはいない、と考えていたのだった。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、腕が一本しかないものもありますし、せなかと胸に、こぶをしょいこんでいるものもあります。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客様の荷物を受取り、しょいこにくくりつけている間、お客様は対山館の食堂でお茶位のんでいる。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしば、さあこれで重荷をおろしたと考えているが、なに、また別の重荷をしょいこんでいる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らがそのように沢山の材料を一度にしょいこむのはなぜかというと、彼らには自分みずからの風趣だけで持ちこたえてゆくだけの自信がないからである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（c）近頃わたしは時代の思潮・他人の勧告・に従って、わたしの素志・わたしの最初の流儀・には反するけれども、毎日ますます他人のものをしょいこんでいる＊。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "花やは天理教の信者で、神仏を尊崇する念が厚く、自分の衣類などはそのままにして、神棚や仏壇のものを大風呂敷にして背中にしょいこんで逃げた。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
