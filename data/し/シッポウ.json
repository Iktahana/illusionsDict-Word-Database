    "definitions": [
      {
        "index": 1,
        "gloss": "the seven treasures (gold, silver, pearls, agate, crystal, coral, lapis lazuli)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そら、大粒の赤玉、白玉のメノーを七宝の青い葉茎がくっきりうけとめている、チューリップ！",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀の地に青や赤の七宝がおいてあり、美しい枯れた音がした。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雲を透して、四方に、七宝荘厳の巻柱に対するのである。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪らず袖を巻いて唇を蔽いながら、勢い釵とともに、やや白やかな手の伸びるのが、雪白なる鵞鳥の七宝の瓔珞を掛けた風情なのを、無性髯で、チュッパと啜込むように、坊主は犬蹲になって、頤でうけて、どろりと嘗め込む。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づきてとくと視れば、浅葱地に白く七宝｜繋ぎの洗い晒したる浴衣の片袖にぞありける。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすぐ傍にどしりと投げ皺められて七宝配りの箔が盛り上っている帯を掬い上げながら、なお、お納戸色の千羽鶴の着物や、源氏あし手の着物にも気を散らされながら、着物と帯をつき合せて、「どう、いいじゃないの……」と、まるで呉服屋の店先で品選りするように、何もかも忘れて眺めていた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それへプラチナ鎖に七宝が菊を刻んだメタルのかかった首飾りをして紫水晶の小粒の耳飾りを京子はして居た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銀の瓔珞、七宝の胸かい、けしの花のような軽い輿。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の右手の隅に七宝細工かと思われる贅沢な寝台が在る。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そが中に突立ちたる奈美女は七宝の大香炉に白檀の一塊を投じ、香雲｜縷々として立迷ふ中より吾をかへりみて、かや／＼と笑ひつゝ、此の部屋の楽しみ、わかり給ひしかと云ふ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ眼前に広がって居るのは、七宝池の一つに違なかった。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "古めかしい油絵の額や、カメオや七宝の装飾品などが目についた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ」とついに彼は、見事な七宝細工を施したどっしりした銀製のテーブルの方へと振向きながら、言った。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪らず袖を巻いて唇を蔽ひながら、勢ひ釵とともに、やゝ白やかな手の伸びるのが、雪白なる鵞鳥の七宝の瓔珞を掛けた風情なのを、無性髯で、チユツパと啜込むやうに、坊主は犬蹲に成つて、頤でうけて、どろりと嘗め込む。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも良心の苛責ゆえでありましょうのに、あたりの七宝荘厳なのは、どうも変だ、といよいよ魔法にかかって、とろとろとしたと思う。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七宝の粧も螺鈿の衣桁もたちまち消えて、紗綾、縮緬も、藁、枯枝、古綿や桃色の褪せた襤褸の巣となったんです。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宗は又かつて長孫無忌に七宝帯を賜わった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "「動くと、命がありませんぞ」　彼は白刃を突き付けて、その枕の函の中から七宝帯を取り出した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "七宝を描いてみてそれから肌を描いて見ようと思つてゐるんだ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも七宝的な絢爛とした美しさは、洋画の材料としての油絵具を完全に生かしきつたといふ美しさである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでは彼の企てた『硝子のやうな透明感』また、東洋の七宝のやうな光りのけんらんたるアラベスクを現出してゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "予て用意したれば、海老茶の紋縮緬の※の傍に七宝焼の小判形の大手炉を置きて、蒔絵の吸物膳をさへ据ゑたるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "違棚には箱入の人形を大小二つ並べて、その下は七宝焼擬の一輪挿、蝋石の飾玉を水色縮緬の三重の褥に載せて、床柱なる水牛の角の懸花入は松に隼の勧工場｜蒔絵金々として、花を見ず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋羽二重の小豆鹿子の手絡したる円髷に、鼈甲脚の金七宝の玉の後簪を斜に、高蒔絵の政子櫛を翳して、粧は実に塵をも怯れぬべき人の謂ひ知らず思惑へるを、可痛しの嵐に堪へぬ花の顔や、と群集は自ら声を歛めて肝に徹ふるなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "七宝とはまず女宝とて、膚艶に辞潔く妙相｜奇挺黒白短なく、肥痩所を得、才色双絶で志性金剛石ほど堅い上に、何でも夫の意の向うままになり、多く男子を産み、種姓劣らず、好んで善人を愛し、夫が余女と娯しむ時も妬まぬ、この五つの徳あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿猴ら竜宮に責め入って后を取り返し七宝を奪い取って本の深山に帰る。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が覚えてるだけでも真珠を七箇箝めた領留針、無線｜七宝の宝玉匣、仏蘭西製の象牙骨の扇子、何とかといふ名高い絵工の書いた十二ヶ月美人とかの帖、何れも其辺の勧工場で買へない高料い品を月に一遍位は必と持つて来た子。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは七宝に山鵲の飛んでいる図であった（山鵲という鳥はちょっと鵲に似て、羽毛に文系があり、白冠で、赤い嘴、尾が白くて長い。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもよく例の小豆色の矢絣のお召の着物に、濃い藍鼠に薄く茶のしっぽうつなぎを織り出したお召の羽織を着てやって来たのだが、今日は藍色の地に細く白い雨絣の銘仙の羽織に、やっぱり銘仙か何かの荒い紫紺がかった綿入れを着ているのが、良い家の小間使か、ちょっとした家の生娘のようで格別あどけなく美しく見えた。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
