[
  {
    "uuid": "c14b3086-3fed-5c00-9772-9f802b7b4130",
    "entry": "神経",
    "reading": {
      "primary": "しんけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
