    "definitions": [
      {
        "index": 1,
        "gloss": "privately operated",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "官営また私営の純粋な科学研究を目的とする研究所も少数にはある。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私営脳病院のトリック。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次は私営の乗り合い自動車で、型のズッと大きいのが幅を利かしている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り賃金はずっと安くて、速力は私営のとあまり変らない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何百というこの独立の私営賭馬人が、思い思いのところにずらりと陣取って、サム・ワウだのアウサウ・フウリガンだのという名乗りの大看板をあげ、酒場の主人らしいのや東部のごろつき然たるのが、汗と泡を飛ばしながら、白墨と財布を両手に握って、台の上から我鳴り立てる。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道会社――亜米利加は水道も私営である――のほうは何うなっているだろうというのだ。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに会社は私営と来ているので、官線の駅夫らが嘗めるような規則攻めの苦しさは、私たちにないので、どっちかといえばマアのんきというほどであった。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛が錫と結合しえいたらこのような結果は起きない。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
