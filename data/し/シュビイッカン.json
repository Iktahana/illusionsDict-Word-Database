        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "批評主義者のカントが天才を一種の芸術的官能に制限したのは、甚だ首尾一貫している。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して名誉をとり返せるだろうかという心配、先生への不面目、裏を知られたという羞恥、キズ物になったような心持ち、九つや十の子供の心にハッキリと暗い、そしていくらか世俗的な恢復慾を起こさせたことは、どうしても父としては首尾一貫していない気がする。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが首尾一貫して字体から行の配りまでキチンとしている。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説に首尾一貫を期さうとし、あくまで組織づけやうとすると、その聯絡毎に概して無理がともなひがちで、あくまで真実らしくしやうとすると、ここでも進行不能の渋滞を惹起しがちのものであり、その反対には不当な曲芸を犯してしまふことが多い。",
              "citation": {
                "source": "文章の一形式",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は始めてあの人のこと、あのころのことを思いだしてみようとしたが、その時はもう、みんな忘れて、とりとめのない断片だけがあるばかり、今もなお、首尾一貫したものがない。",
              "citation": {
                "source": "三十歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾一貫した終戦の合図、笑い納めて、飲み直す。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説書きという奴は、かくの如くトンチンカンで、妙チキリンに古風で、首尾一貫していない。",
              "citation": {
                "source": "私は誰？",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは筋の立たない妄想であつたが、人の企みは首尾一貫筋を要するものではなく、偶発し、事態の変に応じて育つものである。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、子供のしわざと思へぬほど首尾一貫し、バレたときの用心がちやんと仕掛けてあり、大概の人は私を信用するのであつた。",
              "citation": {
                "source": "石の思ひ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十八日（晴）　ひどく合理的で、始めから、何かハッキリ割当てられた筋書のやうに首尾一貫したものができた。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある種の愛情に対しては心中を不可とせぬ人間で、理論的には首尾一貫せず、矛盾の上に今までも生きてきた。",
              "citation": {
                "source": "ぐうたら戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "義智の妻は小西行長の妹で義の兄弟、この両名は朝鮮のことに就ては首尾一貫連絡をとつてゐる。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで事もなく宴会が終れば、それはむしろ甚だ人をバカにし人を軽く見たようなものであるが、幸いにも誰もバカにされずに、首尾一貫してゲリラの精神に添うことができた。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如くに日向の里人の神様信仰というものは首尾一貫を欠いている。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、子供のしわざと思えぬほど首尾一貫し、バレたときの用心がちゃんと仕掛けてあり、大概の人は私を信用するのであった。",
              "citation": {
                "source": "石の思い",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十八日（晴）　ひどく合理的で、始めから、何かハッキリ割当てられた筋書のように首尾一貫したものができた。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ最後の仕上げに総勢出動のあわただしい音も、ガイセンの音も、祝盃の音も、みんなきこえて、最後に殊勲の女を情夫が愛撫する音まできこえ、首尾一貫、居ながらにして、現代劇を味っているようであった。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾一貫した理窟によつて現象を結び合せる労力は愚かであるが、これを生活に就て言へば、その労力は生活を殺す時間にほかならない。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天国で添いとげます、そんな風に首尾一貫、恋愛によって死ぬ方が、私には、珍だ。",
              "citation": {
                "source": "太宰治情死考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に彼と会ったときは、大そう高齢になっていたが、ほかのどんなことにも、まことに筋道が通って首尾一貫していたので、心ある人ならこの話を信じないわけにはゆかないだろうと思う。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し苟くも何等かの主義といふ樣なことを標榜して出でる以上は、例へば懷疑主義であらうとも、其れは純粹の中性的態度では無い、從つてピュローン流の論法で行けば首尾一貫したる懷疑論では無いのである。",
              "citation": {
                "source": "懷疑思潮に付て",
                "author": "朝永三十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがさしずめ本朝宝石怪談の元祖に当るかも知れねえや」　　　　　　　　　　★　昇龍丸の冒険談から殺人事件に至るまで首尾一貫して語るのにヒマがかかって、虎之介が海舟邸を辞去する時はすでに午になろうとしている。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂兄弟妻争説話の一個にして、此説話も亦た首尾一貫するが如しと雖も、詳かに之を観察するときは、其中に二個の挿説の混入するを発見す可し。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合においてすら、この推理は首尾一貫しない。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "セイ氏は、私が彼れの好著より引用した明白な原則を首尾一貫して固執しているとは、私には思われない。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、首尾一貫せんがためには、農業及び製造業におけるすべての改良及びすべての機械発明を阻止すべく努むべきである。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "海難から救助までの事変の梗概は、いかにも首尾一貫していて、誰でも容易に納得するのだが、いざ調べる気になって精読しだすと、随所にモヤモヤした不分明なところが出てくる。",
              "citation": {
                "source": "海難記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアメリカでの近年の研究と、私たちの実験とを併せると、雪の結晶の人工製作の問題が、初めて首尾一貫して解けたことになる。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "首尾一貫前後相待って渾然と出来上がっている。",
              "citation": {
                "source": "コンラッドの描きたる自然について",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、啓示全部が首尾一貫したものではないからである。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
