        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしヘルンのように神経質で気むずかしく、感情の変化が烈しい男に仕えるのは、普通のありふれた日本の女性では、容易に為し得ないことであったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしヘルンが仕事をしている時は、家人が皆神経質に注意しているので、家中がひッそりとして閑寂に静まり返っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上僕は神経質であった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに僕は神経質で、非常に早く疲れ易い。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた友の肉体に潜んだいろいろな苦悶と疾患とが、友を非常な神経質な針のさきのやうなちくちくした痛みを絶えず経験させた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の繊細な恐ろしい過敏な神経質なものの見かたは、いつもサイコロジカルに滲透してゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（神経質なる態度にて、あちこち歩き始む。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経質のくせに表面は大ように見せている父親はときどき「ぼうずはどうして生きているのかい」　と子供の食事を覗きに来た。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達の列車が巴里盆地にさしかかると、佐野は何の理由もなしに、巴里を極度に嫌がって、バルセロナを懐しがったりして、女のように神経質になっていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくしかしそれにしてもと、あんまりお帽子の菱がたが神経質にまあ一寸詩人のやうに鋭く尖っていささかご人体にかゝはりますが、）（えい、畜生まだ何か云ってやがる。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田はまた猫のことには「こんなことがあるかもしれないと思ってあんなにも神経質に言ってあるのに」と思って自分が神経質になることによって払った苦痛の犠牲が手応えもなくすっぽかされてしまったことに憤懣を感じないではいられなかった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈍重なスコッチとスマートなロンドン子と神経質なお坊っちゃんとの対照が三人の俳優で適当に代表されている。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三番目「仇討輪廻」では、多血質、胆汁質、神経質とでも言うか、とにかく性格のちがう三人兄弟の対仇討観らしいものが見られる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれからもきれいとほめられる容貌と毛皮をもって、敏捷で典雅な挙止を示すと同時に、神経質な気むずかしさをもっていた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかして鏡に向うようなことのあるたびごとに、園は自分の顔にそれが現われではしないかと神経質に注意した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "密閉主義の日比野の家でも、衛生には殊に神経質のおふみが、何かとこの青年に健康の相談をかけ、出入を許している只一人の親戚ということが出来る。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの拍子にうつむき加減に、にっと笑うと、真白な歯並が、神経質らしく少し乱れて見える。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに、お帳場も先と違って今はお嬢さんが取締っているんですから」　すると老人は両手を神経質に擦り合せて「はあ、そういうことになりましてすかな」　と小首を傾けていたが「とにかく、ひどく寒い。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその拍手のまだ鳴りやまないうちにもう異教徒席の中から瘠せぎすの神経質らしい人が祭壇にかけ上りました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしもし、小田ですが……」　神経質な疳高い声でいうと、「あ、小田さんですか」　と、聴き覚えのある司法主任の声だったが、何かいつもより晴々として、明るかった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十前後の、ヒョロヒョロと痩せて背の高い、放心したような表情の男だったが、眉には神経質らしい翳があり、こういう男はえてして皮肉なのだろうか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "須賀信吉という男は、女たちのいわゆる神経質な表情と、放心したようなキョトンとした虚ろな眼や笑った時の眼尻の皺から感じられる子供っぽい表情と、二つの表情の交錯する顔を持っていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉はこんな場合、神経質に気を使って愛想よくするか、むっとしているかの、どちらかだったが、薄井の自信たっぷりの容貌は、信吉に、後者の方を選ばせてしまった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "下地は好きなり空腹でもあったので、ほろほろ気分になって宿のある方へ歩いていると、ぴこりと前に立ってお辞儀をした男があった、中年の、痩せて蒼白い、見るから神経質らしい顔の持主だった。",
              "citation": {
                "source": "道〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに神経質じゃだめだよ！",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "草川巡査の小さな茶色の瞳は、モウ神経質にギロギロと輝き出していた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……けれども亦、一方に伊奈子には案外神経質な、用心深いところも、あるにはあった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの知識婦人に見る範疇として、彼女の容姿は瘠形で背が高く、少し黄色味のある皮膚をもった神経質の女であった。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に夫人の方は益※神経質に興奮して来た。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふうん、面白いんだねえ‥‥植物って、なかなかしんけいしつなんだね」「そりやそうさ、生物ってものは、ちゃんとよくみてやらなくちゃ何にもならないよ。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
