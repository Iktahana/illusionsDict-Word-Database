[
  {
    "uuid": "8c1bf247-ac2b-5547-818d-0e482131090b",
    "entry": "震災",
    "reading": {
      "primary": "しんさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
