[
  {
    "uuid": "83285d66-bdc5-5cc7-92e2-226ac5387b27",
    "entry": "市域",
    "reading": {
      "primary": "しいき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
