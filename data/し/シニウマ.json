        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人も必死に馬を止めたらしく、ちょっと口が利けないほど、驚いているし、新子はあわてて馬を避けた拍子に、背後へ倒れかかったらしく、そこにある白樺の太い幹へ、十字架にかかったような姿勢でよりかかって、痛そうに顔をしかめ、鷺のように片足で立っているのだった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳を取ったどすぐろい汚水、死に馬の眼のような水溜まりだった。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "必死に馬を走らせ、また馬を踏み止めて、順慶長光の太刀ふりかぶり、「信玄、覚悟！",
              "citation": {
                "source": "決戦川中島　上杉謙信の巻",
                "author": "――越後守安吾将軍の奮戦記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉光次郎は遥かに落ちる瀬尾主従三騎を認めるや、必死に馬を走らせてその距離をおよそ一町にちぢめた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "若菜は必死に馬をあおった。",
              "citation": {
                "source": "伝四郎兄妹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにスパセニアの姿も、見る見る遠ざかって、それでもまだ必死に馬を飛ばせながら、鞭を持った手を狂気のようにふっています。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "駆け抜けて迎え討たんと雪蹴り立てて、必死に馬追って敵陣に割り入ったが、そこは硝煙｜叢雲のごとく立ち昇り、馬撃たれて為す術失ってしまった。",
              "citation": {
                "source": "戦争",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうこんなことで、なにもかも、とんとんびょうしにうまくはこんで、すえの妹のほうがまず、このやしきの主人のひげを、もうそんなに青くは思わないようになり、おまけに、りっぱな、礼儀ただしい紳士だとまでおもうようになりました。",
              "citation": {
                "source": "青ひげ",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時がくりゃ、ちゃあんと、あたしにうまい考えがあるのさ。",
              "citation": {
                "source": "にいさんと妹",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "塾長といふのは、たいへんむつかしい職務ださうで、わたくしにうまくつとまるかどうか、あんまり自信はありませんけれども、一所懸命やつてみるつもりです。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶこちゃんだって家具なんか買えないって云ってたんじゃないか」「わたしにうまく云えるかしら――言葉の点で……」「平気じゃないか。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
