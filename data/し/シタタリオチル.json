    "definitions": [
      {
        "index": 1,
        "gloss": "to trickle down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "葉末から滴り落ちる露がこの死んだような自然に一脈生動の気を通わせるのである。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、飲めないもの」　酌をしながら、美しい眼が下向きに、滴り落ちる酒にそそがれて、上瞼の長い睫毛のやや上反りになったのが、黒い瞳のほほ笑みを隠した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにこの娘から滴り落ちる……滴り落ちる何んだな……滴り落ちるＸ、そのＸの量ときたらどうだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに砂糖楓の幹にナイフで傷をつけると、見る／＼血液のやうに樹液が滴り落ちる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、しとしとと心の上より下へ向って滴り落ちる雫は、思いやりと、慈しみと、親しさと、恩愛の情です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに装束を着けて舞うのだから大変で、「名乗れ名乗れと責めかけられ」　と畠山が景清を橋がかりへ追込む時の如き、二人とも満面夕立のような汗が烏帽子際から滴り落ちるのであった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その高い梢からは一滴一滴と絶え間なく露が滴り落ちる。",
              "citation": {
                "source": "沈黙",
                "author": "――神話",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤坊はいんちこの中で章魚のような頭を襤褸から出して、軒から滴り落ちる雨垂れを見やっていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷々から滴り落ちる水が、或は潺々とした小さい瀬を成し、或は人に知られない無名の瀑布を懸け、時には激し時には淀んで、段々世間に流れ落ちて行く形が面白い。",
              "citation": {
                "source": "日光",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見てゐると、生きることの悦びは、そこらの枝に来合はせてゐる鳥のさへづりや、蜜をもとめて花のなかを飛び交してゐる蜜蜂の鼻唄めいた唸りと一緒に交り合ひ、融け合つて、私の心のうちに滴り落ちるので、ともすれば陰気に曇らうとする私の感情のくまぐままでもが、覚えずぱつと明るくならうとする。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見てゐると、生きることの悦びは、そこらの枝に来合せてゐる鳥のさへづりや、蜜をもとめて花のなかを飛び交してゐる蜜蜂の鼻唄めいた唸りと一緒に交り合ひ、融け合つて、私の心のうちに滴り落ちるので、ともすれば陰気に曇らうとする私の感情のくまぐままでもが、覚えずぱつと明るくならうとする。",
              "citation": {
                "source": "春の賦",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "露に濡れた芭蕉の葉からすゞしい朝の雫の滴り落ちるやうな時もやつて來た。",
              "citation": {
                "source": "短夜の頃",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、その浅黒い顔から玉をなして流れ、あまつさへ長い泥鰌髭のさきからぽたぽた滴り落ちる汗を、ものうげな手つきで拭き拭き歩をはこんでゐるが、その髭は、幾千年このかた美醜の別ちなくあらゆる人の子をば招かれもせぬのに訪づれる、あの容赦なき調髪師の手で髪白粉をふりかけられてゐた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しくそれは聞いたこともなかったものだというよりも、もう二度とそんな気持を覚えそうもない、夕ごころに似た優しい情感で、温まっては滴り落ちる雫くのような音である。",
              "citation": {
                "source": "洋灯",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈はここでの先ず何よりの自分の勉強は、この完璧な伝統の美を持つ都会に働きかける左翼の思想が、どれほど日本と違う作用と結果を齎すものか、フラスコの中へ滴り落ちる酸液を舐めるように見詰めることだと思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月――日　南瓜の尻から滴り落ちる雨の雫。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……魂から滴り落ちる血と汗の臭気がわかるような……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞼から滴り落ちる新しい涙の一粒一粒が、光弾の銀色の光りを宿して、黒い土に消え込んだ。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "腋の下から冷汗がポタポタと滴り落ちるのがわかった。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……では皆様……さようなら……御機嫌よう御過し下さいませ」　低く低く頭を下げた天川呉羽の、大きな水々しい前髪の蔭から玉のような涙がハラハラと滴り落ちるのが、フットライトに閃めいて見えた。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その反動で、繊毛が順次に位置を変えてゆくのだから、何度か滴り落ちるうちには、終いに櫨木から大理石の方へ移ってしまうだろう。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何度となく水中を透し見たり、浮んでいる作り藻を絞ったりしていたが、そうして滴り落ちる蒼黒い水に、明らかな失望の色を泛べるのだった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼が懸命の力を尽している事だけは、その手足から滴り落ちる汗の絶えないのにも明かであった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仁作は畦につくと、まだ泥水の滴り落ちる除草器を肩にかついで、跣のまま歩き出した。",
              "citation": {
                "source": "無題※",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのままぐったりと雪の上にたおれて、フィルンから滴り落ちる、水溜りに口をつっ込んで、犬のように冷たい水を吸ったのを、今だによく記憶しておる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この辺は水源に近く雪橋から滴り落ちる水も、長い時間太陽の恵みを得ていないから、温度が低いのである。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、旅なかまは、れいの三本のむちで、びしびしと、それこそ地びたにぽたりぽたり、血のしずくがしたたりおちるほどぶちましたから、もうあぶなく途中でとべなくなるところでした。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶ける雪のしたたりおちる音はすべての谷あいに聞かれ、氷は池で解けいそいでいる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さし交した樹々の枝は愈※深くかげを絡ませながら、揺れ、そよぎ、根から梢まで震動をつたえつつ、葉と葉とからしたたりおちる雨粒が、下の泉の面にころがり、珠と結び、その珠のつながりは忽ち泉のふきあげるしぶきにまじって、紅の罌粟の花弁をひたしながら溢れる様子。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
