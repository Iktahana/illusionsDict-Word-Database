  {
    "uuid": "312e3c45-fe73-5e6e-96c9-ccaebead1554",
    "entry": "少丁",
    "reading": {
      "primary": "しょうちょう",
      "alternatives": [
        "しょうてい"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "men 17-20 years, subject to a quarter of the obligations of older men (ritsuryō system)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（少丁、口分田をうけ田租を納めるほかに、四分の一人前の庸調を負担す）長女、十六歳。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（少丁、戸主長男に同じ）次男、十六歳。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
