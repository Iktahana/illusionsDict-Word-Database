[
  {
    "uuid": "04d3075d-6e31-5ce2-b2db-5d114018fa01",
    "entry": "彰徳",
    "reading": {
      "primary": "しょうとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "public praise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フツフ王の彰徳記念碑は五千年の風雨に曝されても、今尚厳としてエヂプトの空にそびへてゐるのを知らないか、酒樽奴！",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復をいれてわづか三週間といふ短い旅であつたが、当時、京漢線方面では、彰徳の攻撃がはじまる前であり、娘子関がまだ落ちず、保定、定県附近には敗残兵が頻々と出没して油断のならぬ頃であつた。",
              "citation": {
                "source": "後日譚",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「彰徳府の楊林と申す者で、あだ名は錦豹子。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "序戦に二度も失策をかさね、あげくに、おそろしい傑物がいた」「傑物が」「もと彰徳府にいた虎騎隊の指揮官で、あだ名を没羽箭といい、苗字が張、名は清」「ああそれは有名な軍人です」「しかも、部下には中箭虎の丁得孫。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の御みおつけの実は何に致しましょうとくると、最初から即答は出来ない男なんだから……」「何だい御みおつけと云うのは」「味噌汁の事さ。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちが結婚しましょうと云えば、こうして時々遊びましょうとくる。",
              "citation": {
                "source": "出家物語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
