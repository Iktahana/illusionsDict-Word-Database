[
  {
    "uuid": "0dbee0ce-98ef-5135-bbc9-4e42b9b3757f",
    "entry": "初段",
    "reading": {
      "primary": "しょだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "first rank in the senior class (in martial arts, go, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "初段、黒帯をしめ、もう殺される心配のない夜の道をガニ股で歩き、誰か手ごめにしてくれないかしら。",
              "citation": {
                "source": "好奇心",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの間に持って生れた器用さから、趣味の技芸なら大概のものを田舎初段程度にこなす腕を自然に習い覚えた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓は初段をとっていたが、これは趣味と言えるかどうか。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　矢藤老人――ああ、年を取った伊作翁は、小浜屋が流転の前後――もともと世功を積んだ苦労人で、万事じょさいのない処で、将棊は素人の二段の腕を持ち、碁は実際初段うてた。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬吉は田舎初段であったが、おたかに言いふくめられて、三度に一度儀助に負けてやった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂田の棋力は初段ぐらいだろうなどと乱暴な悪口も囁かれた。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の舞の初段の左右の型のところで気が掛からないと云って十遍ばかり遣り直させられてスッカリ涙ぐんだあとで、利彦氏が同じ稽古（男舞）で又やり直し十数回の後、とうとう突飛ばされてしまったのを見て、「出来ないのは自分ばかりじゃないな」と窃に得意になった事もある。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は二十五六のときには、初段に二十段位だつた。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、初段に大駒二枚位だつたと思ふ。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人は将棋家元大橋家の最後の人たる大橋｜宗金から、初段の免状を貰つてゐると云ふ珍らしい人だつた。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に初段近きまたはそれ以上の上手と指す場合、定跡を知つてゐると云ふことは、第一の条件である。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "初段に二枚以上の連中の人達では、一枚位違つてゐても、平手で相当指せるものである。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人の初段は、玄人の初段とは二三段違ふと云ふのである。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮坂氏は、自分の棋力を初段に十一目だと鑑定してくれた。",
              "citation": {
                "source": "碁の手直り表",
                "author": "菊地寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもわたしは現在、それらの技の何ひとつ初段の程度に達してゐるものとてもなく、まるで無稽至極で、全く何も習はなかつたと同然である。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく初段近くの力がある人だらうと思ふ。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして柔道初段という刑事と、撃剣が三級という腕節の強い刑事とが、選ばれてその大鳥居の陰に身を隠しました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらだんなが碁は初段にちけえお腕めえだって、音を聞いただけで眼の狂いがわかってたまりますかい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕は職業初段に先というところ――したがって、石の音は真に戞然と高い！",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方は遇然にも並つた初段級の腕達者ぞろひであつたから、彼等に負をとつた験はなかつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人初段位の腕前があつたが、本職の碁を打つと同様に、よく考へて決して一手も苟しくもしないといふ態度なんだ、あの位の程度ならまア一時間もかゝればせいぜいなのに、本因坊のは考へ込むので二時間も三時間もかゝつた。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ではこれでも加納流の初段である。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "又同じ理由に依つて、上京後は労働と勉学の傍ら熱心に柔道を学んだ、今ではこれでも加納流の初段である。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻も申上げた通り、これでも柔術は加納流の初段であるので、一秒の後には其非文明な男は雪の堅く氷つた路へ※と許り倒れた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（云ひ忘れたが、あいつは十一貫足らずの目方しかない痩ツぽちで、身は軽いが腕力と来たら何もないのに引きかへて自分は、柔道初段で、目方は十七貫より減つたことはない。",
              "citation": {
                "source": "夏ちかきころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、勝負事が嫌ひだつたが、彼は好きで（碁も将棋も初段で平常は多くの仲間があつたが、斯うなると彼等に尋ねられることを怖れて不在を装ふてゐた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は彼自身が云っているように、本当に柔道初段以上のために広過ぎる程の肩が凹み込んでいるのかは知らないが、がに股はあの妙な電信柱を知るようになって以来のことだった。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "招ばれもしない会に現われては口を開けば、フランス語やドイツ語ラテン語のうろ覚えているだけの単語を出鱈目に喋りちらし、人の前では自分は柔道初段以上だからと胸を張ってみせる。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
