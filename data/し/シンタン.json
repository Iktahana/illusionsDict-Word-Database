[
  {
    "uuid": "89fdc0bf-c1ea-5646-95bb-594a1707eb5e",
    "entry": "薪炭",
    "reading": {
      "primary": "しんたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wood and charcoal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえば雷電の火の元子は薪炭の火の元子よりも微小であるから、よく物を透す力がある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで氏郷は之を援けて一揆を鎮圧する為に軍を率いて出張したが、途中の宿々の農民共は、宿も借さなければ薪炭など与うる便宜をも峻拒した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちこち、気長に金子にして、やがて船一｜艘、古物を買い込んで、海から薪炭の荷を廻し、追々材木へ手を出しかけ、船の数も七艘までに仕上げた時、すっぱりと売物に出して、さて、地面を買う、店を拡げる、普請にかかる。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国に行く四年前まではこの家は地震で曲ったままの古家で薪炭を商なっていた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪炭商から瓦斯の道具を売る店へ、文化進展の当然の過程だ。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼津あたりから見るのでは、中腹以上が一帶にうす黒く見渡されて其處が森をなしてゐることだけはよく解るが、たゞ普通の灌木林か乃至は薪炭を作る雜木林位ゐにしか考へられなかつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "四邊の山より富士を仰ぐ記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一谷、もとのまゝならば、紅葉の美觀あるべけれど、惜しや、拂ひ下げられて、木はみな薪炭とならむとす。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも他日薪炭に伐らるゝかと思へば、心細し。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜木とは、櫟、榛木など、木材とならずして、おもに薪炭に用ゐらるゝもの也。",
              "citation": {
                "source": "東京の近郊",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるか向こうを見ると山から木材や薪炭を積みおろして来た馬橇がちらほらと動いていて、馬の首につけられた鈴の音がさえた響きをたててかすかに聞こえて来る。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "建網に損じの有る無し、網をおろす場所の海底の模様、大釜を据えるべき位置、桟橋の改造、薪炭の買い入れ、米塩の運搬、仲買い人との契約、肥料会社との交渉‥‥そのほか鰊漁の始まる前に漁場の持ち主がしておかなければならない事は有り余るほどあるのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地味に適しているのか、薪炭に伐られぬのか、兎に角此処の渓間にはこの花が多い。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子　北山薪炭様　北山薪炭は、花子の手紙を受取りました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんのところへそろそろ行かずばなるまい」　北山薪炭はそう言って、山の炭焼小屋の中で、背のびをしました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれ、ちょっくらいって、汽缶車の都合をきいて来ようか」　北山薪炭は、停車場へ出かけました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汽缶車さん、ひとつおいらをのっけて、花子さんの町までいってくれないか」　北山薪炭が、そう言いました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山薪炭はそばへよっていって、「こんちは、君ひとつ花子さんの町までいって貰えないかね。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、北山薪炭の前へ、ちいさいちいさい、玩具の汽缶車が出て来ました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「薪炭さん、さっきからお話をきいていると、お気の毒ですね。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかしてはやく花子さんのところへ薪炭をおくりたいという一心です。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんださか、こんなさか」　それでもやっとこさ、峠のうえまで、ちいさな汽缶車が大きな薪炭を引きあげました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "右へ移ると薪炭問屋の丁子屋、その背面が材木町の出はずれになっていて、この通りに前川という鰻屋がある。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもならば京橋あたりへ、薪炭を積んで来る船頭の女房が最初に罹るのであるのに、今度の流行の魁となったのは、浅草六区のＫ館に居るＴという活動弁士であった。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく小学校を出た時分から男とと関係して、田舎の医師のところへ縁づく前には、ある薪炭商の隠居の世話になっていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラヂオとか新聞とか、電燈｜瓦斯、薪炭などの小払ひは何うにかすましたのだつたが、明日は年始に来る客もあるので、その用意も必要であつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "村人が一年中の薪炭も、此林から出れば、稻田の肥料にする青葉も馬を飼ふ秣も、此草山が供給して呉れる。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪炭浸毒に因る焚火の烟害。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅山薪炭の増加に因れる水源山林の濫伐。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "加野君が、薪炭林の中間作業に就いての詳細をよこしてゐましたが、御覧になりましたか。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
