        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、ヒット曲を連発する人気アーティストの最新シングルを予約した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "独身の友人が、シングル向けの婚活イベントに参加してみると言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この部屋はシングル向けですが、広々としていて快適です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "シングル（一人用）の寝台より少し幅があるように見えるだけで、ただ枕が二つ並んでいるのでダブル寝台といえるわけだ――その上に煽情的といっていいくらい派手な赤い模様の掛蒲団が、掛っている。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に阿弥陀にした鳥打帽がパサリと背後に辷り落ちてシングルカットの頭が露われた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浴室附のシングルベッドの部屋を二晩借りることにきめた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浴室附のシングルベツドの部屋を二晩借りることにきめた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉川機関手は腰を上げて、リバース・シングルバース・ハンドルを引き倒した。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉川機関手はもう一度汽笛を鳴らしてから、リバーース・シングルバース・ハンドルを戻してレギレーターを入れねばならなかった。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一、シングル・スティック、ボクシング、フェンシングの達人。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小心者根性は今もオレの血潮の中に脈々と流れていて、普段のオレには全体の構成を決めずにドシドシと原稿を書き始めてしまうといった、六万四千人の大観衆の前でシングル・マッチでデビュー戦に臨む北尾光司のような真似は、とてもできない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階にはシングル、ダブル取交ぜて素朴なベツドを具へつけた幾つかの寝室があつた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコード屋のシングルの紙袋だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビートルズの新作『ラバー・ソウル』、そして、ラディックのドラム・スティックをもちながら、慶一は、さらにシングルの棚で三〇分ほど逡巡した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、で見た、マコーイズ（うっかり、マッコイズなどと発音すると、ワラに死ぬほど馬鹿にされる）の〈ハング・オン・スルーピー／フィーヴァー〉というシングル、そして、『ポップ・ギア』と同時上映になっていた、『五人の週末』という映画に出ていた、デイヴ・クラーク・ファイヴのＥＰを、友人の長兄にさしだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "シングルのイントロではないにしても、アルバムのイントロとしてはいい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＬＰが一八〇〇円として五〇枚、残りの金で、コンパクトなら二〇枚、シングルなら、えーと、会社によってちがうけど、三七〇円として、二六枚か二七枚も買える！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一が電話を終わり、二階まで吹抜けになった、天井の高いレコード屋に入っていくと、高志はすでに、二枚のシングルを手にしていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは金をのこしたいから、それでガマンしろ」「なんで、お金とっとくの」「いいことがあるんだ」　慶一はシングルの棚を素早く見ていき、結局、ホリーズの〈アイム・アライヴ〉を選んだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚を見つづけている慶一のところにもどると、高志はシングルの袋を手わたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このシングルはヘヴィーだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみのデビュー・シングルのジャケットは、おれにまかせなさい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーマ・スートラ・レコードは、やっと日本の配給会社が決まったばかりで、まだシングルしか発売になっていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくのＬＰを、シングルみたいにあつかうことはないのに……。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュー・ヴォードヴィル・バンド〈ウィンチェスター・カテドラル〉、ナンシー・シナトラ〈シュガー・タウン〉、彼女の父親の〈ザッツ・ライフ〉、ロニー・ダヴ〈クライ〉、ボビー・ヴィントン〈カミン・ホーム・ソルジャー〉、サンディー・ポウジー〈シングル・ガール〉。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、例によって高志は、サンディーちゃんはかわいい声してる、〈シングル・ガール〉はいい曲だ、などといっているし、鼻歌のレパートリーに〈シュガー・タウン〉を加えているが。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな頭のおかしい奴、いなくなって助かりましたよ」　ワラはさっきから、ダブルにしたり、シングルにしたり、タイを締めなおしてばかりで、落ちつかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、シングル・ノットに決めたらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これの頭のほうが、ソフトだもんね」　と、シングル盤の山をひっくりかえす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "シングルのほうに予算をとられるので、なかなかＬＰは買えない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このまえもかけたじゃない」　ワラは、かまえていた鉛筆の尻で、目のまえのシングル盤を指す。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ここには十数枚のシングルと、六枚のＥＰ、それに三枚のＬＰしかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、シングルしかないけどな」「放送でかけたことないだろ？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
