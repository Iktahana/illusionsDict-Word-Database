    "definitions": [
      {
        "index": 1,
        "gloss": "(prefectural) school inspector",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は文部局の巡回視学官ですから、どうしても始終出張ばかりしてゐます。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学校は、やっぱり大学校で、教授たちも、巡回視学官の私などが行ったからと云って、あんまり緊張をするでもなし、少し失敬ではありましたが、まあ私はがまんをしました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文部局の巡回視学官です。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後、ちょっと来られた視学官の方も、すぐに私の名前を記憶して行かれたようですが、それは私の成績が作文と、習字と、図画と、体操を除いては、級の中で一番｜末席だったせいばかりではなかったように思います。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからその次に、父兄代表として視学官の殿宮さんが壇上にお立ちになった時の演説のお立派でしたこと。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その謝恩会がすみますと直ぐに私は、帰り道の途中に在る殿宮視学官様のお宅をお訪ねしました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男二人女二人４・27（夕）　文部視学官の丸山｜環氏は九人の子福者で、お湯に入る時には自分が湯槽に浸りながら、順ぐりに飛び込んで来る子供達を芋の子でも洗ふやうに垢を擦つてやる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝記を読んだ方々には御承知の通りに、マリヤは、ポーランドの首府ワルソーで中学校の物理の先生をする傍副視学官をつとめていたスクロドフスキーの四人娘の末っ子として生れました。",
              "citation": {
                "source": "キュリー夫人の命の焔",
                "author": "――彼女を不死にするものは何か、",
                "note": "青空文庫"
              }
            },
            {
              "text": "教員再教育のために、文部省は四六年十月から四七年三月まで全国視学官、市視学およそ一、〇〇〇名を行政区別に分けて教員の再教育を実施した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又余計な事をする」と云って視学官連中が膨れ面をするにきまっていたから……。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……視学官ぐらいに何がわかるものか。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに間もなく文部省の視学官が視察に来る事になった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "因て直ちに出京したが、野村視学官はまだ帰京していなかった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また県の教育課長、視学官になる必要もない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし詩人などというものは、雲の上にうろついているもので、その思想は、日常の生活のためにも、また視学官のつぎの巡回の時にも、何の役にも立たぬものだと。",
              "citation": {
                "source": "青年に訴う",
                "author": "AUX JEUNES GENS",
                "note": "青空文庫"
              }
            },
            {
              "text": "八｜月にアンドレイ、エヒミチは市役所から、少し相談があるに由って、出頭を願うと云う招状があった、で、定刻に市役所に行って見ると、もう地方軍令部長を初め、郡立学校視学官市役所員、それにドクトル、ハバトフ、またも一人の見知らぬブロンジンの男、ずらりと並んで控えている。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後は視学官として、Nancy, Caen, Douai, Pau 等に転任している。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、アンナが聞いたところでは、父親のピョートル・レオンチイッチを首にしないようにと、校長やさもなければ視学官に宛てた手紙を、閣下に一筆書いて貰うことも造作はないという話であった。",
              "citation": {
                "source": "頸の上のアンナ",
                "author": "АННА　НА　ШЕЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、大塚氏とともに、普通教育を管理する学務局に至り局長に面会を得て、市内の学校参観を請いたるに、即時に快諾せられ、視学官長に命じて案内せしめらる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前、視学官長の案内にて、師範学校に至る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前、また視学官の案内にて男子の中学校を参観す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛筆が弟の方を向いていると訳しているところへ教頭が視学官を連れて参観に行ったから耐まらない。",
              "citation": {
                "source": "首席と末席",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
