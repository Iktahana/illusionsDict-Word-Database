    "definitions": [
      {
        "index": 1,
        "gloss": "(anti-aircraft) searchlight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東京ビルの横腹を染めていた大火光は、その盛りあがった土塊のなかから、照空灯のようにパッとさし出ているのであった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に、照空灯のように燿いていた赤光も、どこかに見えなくなった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最中に、突然、飛行島上から、数条の照空灯が、暗い大空に向け、ぱぱーっと竜のようにのぼっていった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "照空灯は、幾条も幾条も一つところへ集ってきた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千メートル以上の上空をとんでいる日本機の翼に、照空灯が二重三重四重に釘づけになっている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一所に釘づけされたようになっていた照空灯が、右に左に活溌に首をふりうごかしはじめた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵機をうち落す高射砲、プロペラの音によって、敵機の位置をさがす聴音機、空を昼間のようにあかるくパッと照らす照空灯などが、この中隊に附属していた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにぶっちがいに、また地上から別の照空灯の光がサーッと閃いた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし照空灯の強い光の帯だけが、いつまでもアリアリと眼の中に残っていた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが敵機は、照空灯を全身に浴びたまま、ゆうゆうと砲弾の間を飛んでいる。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲弾は、照空灯の光の柱をおいつづける。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中に乱舞する照空灯、その間に交って破裂する投下爆弾、メラメラと燃えあがる火の手、遠くからながめても恐ろしい焼夷弾の力！",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かに高田市あたりと思われる遠空に、たった一本の照空灯がピカリピカリと揺れているばかりだった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に照空灯、聴音機等若干の損害を受けましたが、爾後の戦闘には、支障なき程度でございます」「軍隊以外の死傷は」「死者約七十名、重傷者約二百名、生死不明者約千名であります。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが出来るなら、空襲警報も間に合わないほどの急襲をやることが出来、殊に雨夜の空襲をかけると、敵の防空隊の照空灯も届かず、聴音機も間に合わず、従って高射砲で狙い撃つ方法もなく、大いに戦果をあげることが出来ようと思う。",
              "citation": {
                "source": "成層圏飛行と私のメモ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこから出したのか、幅の広い照空灯が、ぶっちがいに、大空の真中で、交叉した。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "照空灯は、いつの間にか、消えていた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆弾の音を聞かされ、照空灯のひらめきを見せられた弦三は、自分の使命のことも何処へか忘れてしまい、「畜生！",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウ、なんだネ」　こっちは、頤髯がある――向う側のビルディングの窓硝子が照空灯の反射で、ピカリと閃いたので、その頤髯が見えた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "照空灯が、水色の暈光をサッと上空に抛げると、そこには、必ず敵機の機翼が光っていた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "照空灯は、サッと、光を収めた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真暗な空には、今も尚、照空灯が、青白い光芒を、縦横無尽に、うちふっていた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上からは、噴水のように、青白い光芒を持った照空灯が、飛び上ってきた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "離室への廊下から東南の方を見ると、わが照空灯が十数条、大井町の上空と思われるところへ集まっており、それよりやや左にぱらぱらと火の粉のようなものが落下して行く。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵機が照空灯につきさされながらも、わが砲弾と六百万都民を尻目に悠々と帰って行くので、さらに寒さを感ずる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "照空灯の光の中にしっかり捉えられている。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "九台の僚艇は、全部が六号艇の遭難現場のまわりに集まってきて、四方八方から六号艇のほうへ強力なる照空灯で照らした。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "照空灯と照明弾とが、空中で噛み合っていた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで照空灯に照らし出されたように見える。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「要注意」の信号「火の玉」少尉が、空中の異変に気がついたのは、それからしばらくして、風の中に××陣地のサイレンの響を聞き、それに続いて××陣地にありったけの照空灯が、彼の乗った気球の方に向けられたときだった。",
              "citation": {
                "source": "空中漂流一週間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
