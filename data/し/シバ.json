[
  {
    "uuid": "9c8ba378-9c8c-596a-9586-fdafdfa606b2",
    "entry": "芝",
    "reading": {
      "primary": "しば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
