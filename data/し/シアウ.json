    "definitions": [
      {
        "index": 1,
        "gloss": "to do together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また、ことさらに独自性をわめき散らし、排除し合うのも、どうかしている。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥のＲが死んでからもう二十余年になるので当時の想い出を話し合う相手もなくなってしまった訳である。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を伸し合う針葉樹は、格子縞を、虚空に組み合せている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺屋の白袴、医者の不養生ということもあるが、物理の学徒等が日常お互いに自由に話し合う場合の用語には存外合理的でないものが多数にあって、問題の「速度のはやい」などもその一例である。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへははやり唄の作者や唄本の発行者も集って来て本の取引かたがた町のはやり唄に対する気受の具合を話し合う。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは気を付けて行って見るが確かにそうだ」「それは変だな」「変だ」「変だ」と噂し合うようになりました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お通夜の人々は自分の仕振りに困じ果ててか、慰めの言葉もいわず、いささか離れた話を話し合うてる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の心持が今少しませて居ったならば、この二日の間にも将来の事など随分話し合うことが出来たのであろうけれど、しぶとい心持などは毛ほどもなかった二人には、その場合になかなかそんな事は出来なかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その群集の一番最後の遊び人風の男が二人、歩き乍ら話し合う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "六畳ばかりの玄関には十四五人の男や女が押し合うように詰めかけていて、坐り切れない人達は式台の上までこぼれ出していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで窓の話などを持ち出して話し合う気になったのだ。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そんな言葉で話し合うのが堯にはなぜか快かった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいの押し合う力の合力の自然変異のために神輿が不規則な運動をなしている状態は、顕微鏡下でたとえばアルコホルに浮かぶアルミニウムの微細な薄片のブラウン運動と非常によく似た状態を示している。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それが生きるために互いにけんかをして互いに殺し合う。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また押し合いへし合うことのきらいな人間は遠慮なく昇降機を割愛して階段を昇降すればよい。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、先を争うて押し合う心理も昇降機の場合にはたいした恐ろしい結果は生じない。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われには机のしたで調べるノオトもなければ、互いに小声で相談し合うひとりの友人もないのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの二人が恋し合うのは見ていても美しいだろう。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服の着代えをしようとしてがんじょう一方な木製の寝台の側に立っていると、戸外でカロラインと気軽く話し合うファニーの弾むような声が聞こえた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな気心を知り合った人間同志の間柄でも、互いの性質が違い、年齢が違い、教養が違い、その時々の気分や頭の調子に変化のある以上、そう一つことを二人の人が全く同じように了解し合うということは不可能であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが散り散りばらばらであっては、お互いを信ずることが出来ませんから、親身になって慈悲の心を出し合うことも出来ません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は照し合う心の曇りなき様子を語らうのに、人の世の言葉の不束かなのに焦立ちさえするので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は誠を証し合ううちにも、変らぬ誓を立て合ううちにも、望月の光のたるみ、満潮の浪のけだるさ、明日の寂しさを背筋に予感して、やがて溜息となりすすり泣きともなるので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』僕たちは話し合うんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って菜食はみんなの心を平和にし互に正しく愛し合うことができるのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は出版会社のタイピストをしており、ある夜、その出版会社から出ている雑誌を鶴雄に貸してくれたことが切っかけで、講習会場で顔を合わすと、時どき話し合うようになった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い飴売鮮人と話し合うた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も母も、この長男について、深く話し合うことを避ける。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白痴、唖、……それを一言でも口に出して言って、二人で肯定し合うのは、あまりに悲惨だからである。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女を連れ出して、この喫茶店のアカデミックな空気の中に游がせて置けば、かの女は、立派に愉快を取り戻せるものと信じ切っているらしく、かの女に茶を与え、つまみ物を取って与えた後は、ぽかんとして、勝手な考えに耽ったり、洋食を喰べたり、元気で愛想よくテーブル越しに知人と話し合う。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
