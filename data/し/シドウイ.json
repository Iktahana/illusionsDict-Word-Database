        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしどういうものかそれ以来その某国のスパイらしいものがＢ教授の身辺に付きまつわるようになった、少なくもＢ教授にはそういうふうに感ぜられたそうである。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りに心掛けたが、しかしどういうものか足が早くて水蜜桃など瞬く間に腐敗した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しどういふわけか、物音が非常に強くなつてゐまして、一しよう懸命兄きの耳に口を寄せてどなつて見ても、一言も向うへは聞えないのでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどういふものか車中では其女に對して自分は毫も惡感を催さなかつた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しどういふ訳でか、奥さんは、どうかすると、一人で人のゐないところに彳んで、少らくしく／＼泣き入つてゐられるやうな事を、よく婆やは見たさうであつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどういうものか、ケノフスキーからの返電は一度も来なかった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう認識論と哲学（併しどういう立場に立つ認識論や哲学かは重大な点だが）を想定することが、批評を科学的であるとする感想の動機をば事実上なしているものではないだろうか。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどういう処へ自分は連れられて来たのか見当が付かなかった。",
              "citation": {
                "source": "耳無芳一の話",
                "author": "THE STORY OF MIMI-NASHI-HOICHI",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどういうものか二人は僕の頼みにすぐには賛成してくれなかった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどういう径路をとり、どういう有様に流行したかは、知る人きわめて少いだろう。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しどういふものか子鶉は、ちつとも嬉しさうなそぶりも見せなければ、物も喰べず、又一つも謡ひもせず、夜も昼も悲しさうに首を垂れて何やら考へてをりました。",
              "citation": {
                "source": "孝行鶉の話",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しどういふ訣か、若宮の祭礼の日は動揺が激しいのです。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどういう気持か、ひきつけられるようにＨ公園の傍にあるパーク旅館の前へ出て了った。",
              "citation": {
                "source": "Ｐ丘の殺人事件",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどういうわけで、そんなに態度が一変したのでしょうか」「それはわたしにはとけない謎だ」「あなたはあの部屋へはいると、きゅうにはげしい頭痛におそわれたのでしたね」「部屋へはいってすぐではなかった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどういふ種類の間違ひをやらかしたかといふことになると、暫く娘の顔を眺めてゐたり、家の具合を観察したり、前後の事情を思ひ出したりしないうちは見当がつかなかつたね。",
              "citation": {
                "source": "西東",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどういうものですか貴嬢がお拵えなすったカステラほど美味く出来ません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、あの紳士の方のことでございますか」　とキヨは俄かに狼狽の色を示しながら、「まあ奥さま、あたくしどういたしましょう。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどういうものか、吉岡君から借りたのだけは、妙に頭にひっかかっていた。",
              "citation": {
                "source": "好意",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に対しどういうことをしようと思っているのか、それはまだはっきり分らないけれど、この際、それを知って置かねば日本国民は枕を高くして安心して寝てはいられない。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどういふ風に実行すべきものか、其手段がわからない。",
              "citation": {
                "source": "人妻",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といいながら、しかしどういう訳か一同の如く心の底から陶然と酔を催す様子は更に見えなかった。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い僕が気がついてすぐ警視庁へ電話をかけ、警官をひそかに呼び寄せておいて、園丁達に云いふくめ、あらかじめ猛獣を檻の中から出しておいたからよかったものの、そうでなかったら市民達の円かな眠りは醒まされたろう」「しかしどういう方便で回鶻人のあの男が園長と知るようになったのでしょう？",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどういふ譯か三番通詞も「得十郎」となつてをり、日本側の記録をさがしても、ペルリ側の記録にみても、昌造はほとんど表だつて出て來ない。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　萩乃は団扇で顔を隠して、「そんなことになったら、あたくしどういたしましょう。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどういう意味で？",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ、そんな町つて、あなたのお父様、あたくしどういふ方かぞんじあげませんもの」「区役所の書記です。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどういう激烈な状態ではじまるものかそれだけは察してくれるだろう。",
              "citation": {
                "source": "黒い手帳",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史として知ろうとすることは、一つの社会を形成している人々が、どういう心理でどういう行動をなしどういう事件を起し、それが互にどうはたらきあって社会全体がどう動き、その動きがまた人々の上にどんなはたらきをすることによって、社会全体の生活が変ってゆくか、の過程である。",
              "citation": {
                "source": "歴史の学に於ける「人」の回復",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しどういうことが自分が存在しているということであるか、又なぜ自分が存在していると云うことが出来るか、という問題になると、解答は極度に厄介なのである。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
