          "standard": [],
          "literary": [
            {
              "text": "ニュー・ヴォードヴィル・バンド〈ウィンチェスター・カテドラル〉、ナンシー・シナトラ〈シュガー・タウン〉、彼女の父親の〈ザッツ・ライフ〉、ロニー・ダヴ〈クライ〉、ボビー・ヴィントン〈カミン・ホーム・ソルジャー〉、サンディー・ポウジー〈シングル・ガール〉。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、例によって高志は、サンディーちゃんはかわいい声してる、〈シングル・ガール〉はいい曲だ、などといっているし、鼻歌のレパートリーに〈シュガー・タウン〉を加えているが。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルから数マイル離れたところに生まれたシュガートアソシエーツという小さな会社では、当時、フロッピーディスクのドライブの開発を始めていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "シガーとシュガーを間違えて烟草を買いに遣て砂糖を持て来るもあり、医者は人参と思て買て来て生姜の粉であったこともある。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブランディとラムもまたしばしば焦がした砂糖で色づけられ、ブリティッシュ・モラセズ、シュガー・スピリットで混ぜ物処理がなされている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリティシュ・モラセスまたはシュガー・スピリットを混ぜたブランディは、両手の掌のあいだで擦ることにより明らかになる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュガー・ピースと呼ばれている白い果物入り飴は主として砂糖、デンプン、コーニッシュ・クレイコーンウォール産の白いパイプ粘土）からなり、赤いドロップはふつう下級の朱で色付けられている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "シガー（たばこ）とシュガー（さとう）をまちがえて、たばこを買いにやったら、さとうを買ってきたというような、わらい話のようなしくじりもありましたが、もっとけっさくもうまれました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケインとはシュガー・ケインのことだ、と思うまもなく、セスナは砂糖きび畑に林立するケインに機体の腹をこすり始めた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二枚の写真を、ぼくはシュガー・ポットに立てかけた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュガー・トレイン１　横長の小さな四角いフレームの中央に、飛行艇が一機、真正面から鮮明にとらえられていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちのおじいさんなんか、これは祝福に値するとか言って、医者に止められているお酒を、また飲み始めたから」「昔は誰もが、この汽車のことをシュガー・トレインと呼んでいたのよ」「そう。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュガー・トレイン。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『アロハ・オエ』『アイランド・スタイル』『シュガー・トレイン』『ベイル・アウト』の四篇は、『野生時代』の創刊から三、四年あと、同誌に書いた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "待つ間、サーロインステーキとポタアジュ、シュガーコーン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポット入のスープと、マトンの料理、シュガーコーンと、プディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭を連れて外出、不二アイスの二階で、チキンコロッケとトマトクリームスープ、シュガーコーン、ストロベリーショートケーキ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
