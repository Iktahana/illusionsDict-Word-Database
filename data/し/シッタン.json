          "standard": [],
          "literary": [
            {
              "text": "日本で古代梵語學の大家たる安然の悉曇藏などでも、いづれも梵語學の説明として支那の反切即ち九弄音紐といふやうなことを借用して居る。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた帰っていらしったんですか……ひどくなりそうですね」　そうしたら、その乞食らしい人が、「子どもさんたちがけんのんだから連れて来たよ。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはわざわざ僕に逢いに入らっしったんですか。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんです、何を買っていらしったんです。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方は泳いで在らしったんです。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私「星を見乍らそんなことを考えていらっしったんですか。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私「そして、こんなに早くお宅を出ていらしったんですか。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私「そして、直ぐ引返していらしったんですか。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと年少らしい芸妓が、部屋の上下周囲を見廻しながら「このお部屋、大旦那が母屋へお越しになってから、暫らく木ノさんがいらしったんでしょう……」と云った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご夕飯がすむと、急にお熱が出て、今お医者さまがいらしったんですの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　優しい準之助氏の眼は、たちまち親しく怒りつけるような眼つきに変って、新子を見ながら、抜足して病床に近づいて来て、「あれから、ずーっとここにいらしったんですか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上お母さままでいらしったんでしょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間｜中から、姉さんと三人で、話をしたいって云ってらしったんだから、ちょうどいいわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどあなたのほうがお約束の時間より少し早くいらっしったんです。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、幹事の方から宿も指して寄越したし、……これでも、こんな土地……違った……」　と胡坐を整然と直して、ここで十万軒が崖にごつごつをぶち開けたが、「そうでござんすとも、東京からいらしったんでは。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那さまもお里さんのところへいらしったんですか」と、お此は子細らしく訊いた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒にこの船でいらしったんですもの。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まででも時々いらしったんだけれどもついにお目にかかるおりがなかったわね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ野々宮宗八さんをかいていらしったんですね」「なぜ」「野々宮さんは外国じゃ光ってるが、日本じゃまっ暗だから。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなたはまたなんであんな所にしゃがんでいらしったんです」「熱いからです。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃どちらへいらしったんです」と、女房は煙草の火を出しながら聞いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "いついらしったんです？",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらしったんでございますよ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちだわ」「何故貴女一人放って行らしったんでしょう、……私あの方は……此は貴女だけに云うのよ政子さん……余り親切じゃあないと思うことよ、私嫌だわ」　政子さんは、少し驚いて友子さんの顔を眺めました。",
              "citation": {
                "source": "いとこ同志",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉が郷里から出て来てくれることに成っていますからね」「姉さんは最早出ていらしったんですか」「いえ、まだ……来月でなきゃ」「あなたは今月のうちに神戸へお立ちに成るというじゃ有りませんか。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、毎日々々あんなに黙って、こわい顔ばかりしていらしったんですもの。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「×さんもそういう仕事をしていらしったんでしょう？",
              "citation": {
                "source": "沈丁花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう絶望のどん底で私のところへ今朝いらっしったんですの、一緒に泣いてしまいましたわ。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お薬とりにいらしったんだって？",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先日塩野さんが、ノートル・ダムの写真を撮りにいらしったんですのよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
