    "definitions": [
      {
        "index": 1,
        "gloss": "traditional style of Japanese residential architecture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
