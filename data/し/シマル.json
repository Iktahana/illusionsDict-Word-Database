[
  {
    "uuid": "c9d4eb78-a532-57f3-aced-cccd090125f3",
    "entry": "絞まる",
    "reading": {
      "primary": "しまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be strangled",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "貴様こそ、――ああ、喉が絞まる。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "松虫も同じことなれど、名と実と伴はねばあやしまるゝぞかし。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入りて波ますます狂い波止場の崩れしかと怪しまるる音せり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の異様に引きしまるのを覚える。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに相模湾を隔てて、一点二点の火、鬼火かと怪しまるるばかり、明滅し、動揺せり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "バクテリヤは次から次と分裂し死滅しまるで速かに速かに変化してるのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒布はゆれるしまるで十月の風だ。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜に鼠の気勢もさせず、帽とともに小脇にかかえた杖よりも身を細く、小さな口から、するりと抜けると、硝子窓は向うから、音もなく、するりとおのずからしまるのが、姿見にありありと映って、夢の覚際かと見えたのである。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは已に殻ばかりとなりけるよと思うにつけて、英一の死のまた今更に悲しまる。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊五郎の実弟にて和事を得意としていたるが、晩年は団十郎張りとなりて評判よく、その死は楽屋の内外に惜しまる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗に十代目団十郎の候補者と呼ばれたる有望の俳優にて、菊之助と共にその死を惜しまる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女に会いに行くんだ」　と、鶴雄が君勇に言ったのは、君勇をまくための咄嗟の言い逃れだったが、しかしまるっきり嘘でもなかった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎚をふり下さうとする瞬間瞬間に、赤くやけたくびの筋肉がぐつとしまるのを、新次はうれしく思つて見つめてゐた。",
              "citation": {
                "source": "鍛冶屋の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふ※、しかしまるで子供だな。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つき合って僕は気がひきしまる。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとあきかけても、またぴしゃりとしまる。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その口許の左へ軽くしまるのを見るがいい。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は見られていると意識するときに、ちょっとてれた気持もしないではないが、然しまるで草木のような感じしかない少女が一人、傍にいたとて別に気分の障りにはならなかった。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、旅だ、時には心もひきしまるが、また、笑に代へ、親しみに代へたりして。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとなくその由るところ悲しまる、元日の午後の眠たき心。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "賤が伏せ屋の見すぼらしい母子が只の人でないと眼をつけられ、綾羅錦繍の裡に侍ずかるる貴婦人がお里を怪しまるるそもそもの理由も、亦ここにあるのではありますまいか。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　今や主人の眼光は消え去つたが、永遠に生けるが如く、彼の珠光は益々光の翼をのべて、不断にいつまでも輝き、多くの訪者になつかしまるゝであらう。",
              "citation": {
                "source": "珠玉の如き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすると、窓にはひとりでしまる力がなければならんことになる。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、避雷針をはなし、足をしっかり壁にかけて踏んばり、思いきってそれを蹴ると、鎧戸はあおりをくってばっとしまるだろう。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一度この鐘楼に上ったのであったが、攀じるに急だし、汗には且つなる、地内はいずれ仏神の垂跡に面して身がしまる。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「助けてくれ――」　川の方へ、引こう引こうとしていた、そのうつくしい女の、優い眉が屹としまると、蓑を入れちがいに砂堤に乗って、海の方から御坊の背中を力一杯どんと圧した。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　勝手の戸がかたりとしまると、お夏ははらりと袂を畳へ、高髷を衝と低く座を崩して姿を横に、縋るがごとく摺り寄って、「どうしたの、お前、」　とて、膝につむりを載せないばかり。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爰にいたりて自然の勢、最早｜与みし易からぬやうに覚ゆると同時に、肩も竦み、膝もしまるばかり、烈しく恐怖の念が起つて、単に頼むポネヒルの銃口に宿つた星の影も、消えたかと怯れが生じて、迚も敵し難しと、断念をするとともに、張詰めた気も弛み、心も挫けて、一斉にがつくりと疲労が出た。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その演技の勇壮活溌には心神の自ずと引きしまるを覚えたれども、やがて棄子なる演技を観るに及びては堪え得ざる涙に誘はれ終ひに泣き伏したり。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより神の御山なりと思う心に、日の光だに漏らぬ樹蔭の涼しささえ打添わりて、おのずから身も引きしまるようにおぼゆ。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
