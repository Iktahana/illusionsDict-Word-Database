        "examples": {
          "standard": [
            {
              "text": "遭難した船員は、救助を求めて夜空に信号弾を打ち上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "訓練開始の合図として、教官が信号弾を発射した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "花火大会のフィナーレを飾るかのように、一斉に信号弾が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "海魔というが探照灯や信号弾のようなものを放っている様子を見ると、動物ではない。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に赤い信号弾を発射し、病院のテントを引っかけはしまいかと思う程低く飛んだ。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも私が信号弾を一、二発、持ってきますから、必要なら打ち上げます。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "「例の信号弾はどうなった？",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、寂れた不毛の大地が不気味な紫の光に照らされたのは、デントンが信号弾を発射したからだ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
