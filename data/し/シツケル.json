[
  {
    "uuid": "a7d775eb-8ef7-536f-8c45-935551dcfc51",
    "entry": "仕付ける",
    "reading": {
      "primary": "しつける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
