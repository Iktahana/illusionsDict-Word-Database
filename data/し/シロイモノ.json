        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "面白い物が現前しはじめると、漸く実感は立ち返るものだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし物好きな人があってこの模様を散らした着物でも作ればきっと面白い物が出来るだろうと思われる。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い雪、赤い雪、緑の雪　雪と云えば白い物と相場がきまっている。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人が日常坐臥の間に行っている事でも細かに観察してみると、面白い物理学応用の実例はいくらでもある。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年安藤農学士が植物の霜害に関する研究をされたが、これらも面白い物理的研究の一例であろう。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃藤原理学士が乾燥に関する面白い物理学的の理論を出された。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁石に感ぜぬ鉄の合金　一に一を加えて二になるのは当り前だが、白い物と白い物を合せれば必ずしも白くなると限らぬ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白い物がありますから。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十五回　白色巡洋艦大陸の影――矢の如く空中を飛走した――ポツンと白い物――海鳥の群――「ガーフ」の軍艦旗――や、や、あの旗は！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は目眩き朝日の光を避けて、岩の蔭を縫って歩いていると、不図我眼の前に白い物の横わっているのを見付けた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪風に熱い頬を吹かせながら、お葉は快心地に庭前を眺めていると、松の樹の下に何だか白い物の蹲踞んでいるのを不図見付けた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "声の主を早くも其れと知ったのであろう、白い物は勃々と起き上って、縁の前へ忍んで来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭さまで、ずいぶんと面白い物語を聞かされたわけなのだが、併し惜しいことには、君のその卓越した嘘がまたこの物語を大分つじつまの合わないものにしてしまっているのだ。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、そんなに面白い物語で無いかも知れない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町外れの五六本の木の生えた小社の前まで来ると、すぐ路傍に沿うて馬方などが時どき馬を繋いでいる木の根本の暗い処に白い物がちらちらと見えた。",
              "citation": {
                "source": "餅を喫う",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、白い物の影が小八の眼にちらちらと映った。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼白い物凄い電光がぎらぎらと雨戸の隙間から眼を眩まして射し込んだ。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い物はさきに立っている神南の傘の下を掻いくぐって、二番目に立っている堀口に飛びかかった。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大溝のふちには白い物が坐っていた。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お峰は言い知れない恐怖を感じて、無言で文次郎の袖をひくと、彼もその正体を見届けようとして、幾たびか提灯を振り照らしたが、白い物の影はもう浮かび出さなかった。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あぶない」　章一の眼の前に小さな白い物がちかちかと光った。",
              "citation": {
                "source": "一握の髪の毛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには小さな玩具のような三寸位の富士形をした微白い物があった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十六「透かした前途に、蘆の葉に搦んで、一条白い物がすっと懸った。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處の梢も白い物を止めないで疲れたやうに濡て居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な第宅におりたいとも言わず、結構な調度を使いたいとも言わず、うまい物を食べたがりも、面白い物を見たがりもしなかった。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄鶏もやつてきて見て驚ろきました、それは奪ひ合つてゐる白い物は、鶏卵の殻であつたからです。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "白人は白い物と心得た人が多いが、件の『滑稽集』の文でやはり白くないと判る。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほどおもしろいものだから、忘れずにためしてごらんなさい。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんおもしろいものは実写ものである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味でニュース映画は自分にとって最もおもしろいものの一つである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
