    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beginning of an epoch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十五世紀の頃に至って、沖縄島に尚巴志という一英傑が起って三山を一統した時に、久しく断絶していた本国との連絡は回復せられ、日本及び支那の思潮は滔々として沖縄に入り、十六世紀の初葉に至って沖縄人は日本及び支那の文明を消化し沖縄的文化を発揮させたのである。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな心持は庸三が最初葉子の田舎へ招かれた時にも、彼女の母たちにはあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の町の建設は紀元前四世紀の初葉で、それまではイオニア人の都市ナクソス（タオルミーナの南四キロ、今のスキソ付近）が栄えていたのを、ディオニュシウス一世はギリシア勢力絶滅のためにそれを破壊すると同時に、シケリア人をしてタウロスの山腹に新都市を建設させた。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂェズイタ派の組織は近代の初葉に於いては時勢に適合したものであつたが、今日では場ちがひなものになつたのではなからうか？",
              "citation": {
                "source": "聖ロヨラ",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ギニー金貨」は十七世紀後葉から十九世紀初葉まで流通していたイギリスの金貨。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルプス山系の一小部分ともいっていい、この Rigi も十八世紀の中葉頃から、ぽつりぽつりと登山者の注目を牽き、十九世紀の初葉にはこの頂上まで登って展望を楽んだ者はよほど増したということである。",
              "citation": {
                "source": "リギ山上の一夜",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは中山の尚巴思に亡ぼされた他魯毎が居つた居城で、承察度が南山王を稱してから四代百四年、遂に三山統一となつたのは十五世紀の初葉のことである。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんぐりや櫟や柏によって形成られている雑木林には、今は陽があたっていて、初葉さえ附けていない裸体の幹や枝が、紫ばんだ樺色に立ち並んでいたが、紙帳は釣ってなかった。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の如きは、神話的英雄の伝記の初葉に於て、屡ば見る所の現象にして、試に希臘紳話に就て云わばツォイスの子アポロ神に於て然たり、人文神話の英雄ヘラクレスに於て、またその然るを見る。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに平安朝の中頃から鎌倉期の初葉にかけ、補陀洛山に居る生身の観音菩薩を拝すると称して、志願ある者は小舟に打乗り海に出で、浪のままに流れ漂うて往生する事がさかんに行なわれた。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堆書狂で名高かったのは、十九世紀初葉のオランダの貴族ウェストリーネン・ヴァン・ティエランドであるが、此男が豪い蔵書家で、且つ蔵書を人に見せたがらない奇人だった。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖カテリナ（訳者注　四世紀初葉の殉教者にして若い娘の守護神）のような女で、わしがいつもその髪を解かせたく思うのが、世にはたくさんある。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
