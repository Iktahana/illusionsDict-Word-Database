        "examples": {
          "standard": [
            {
              "text": "彼の小説は、現代社会の問題に鋭く切り込む社会派として評価されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その監督は、社会派の視点から人間の葛藤を描くことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近、社会派のドキュメンタリー映画が注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "モダーニズムは併し当然主知主義・新心理主義・新社会派・等々にまで分化発達した。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "主知主義となれば（之は社会派に極めて近いものを持っている――例えば、Ａ・ハクスリ）、モラルは更に機能的になって来て、知性的な論理にまで接近する。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
