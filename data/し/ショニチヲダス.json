    "definitions": [
      {
        "index": 1,
        "gloss": "to achieve one's first victory after a string of losses",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「もう一つ不思議なことは、紋作と冠蔵が一度に居なくなったので、芝居の方では急に代り役をこしらえて、いよいよ十二月の初めから初日を出すと、三段目の幕が今明くという時に、師直と判官の首が一度にころりと落ちたそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日では各劇場申合わせたように月初めに初日を出すことになっているが、その頃は中旬でも月末でも一向無頓着で、思い思いに開場するのが習いであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のように毎月殆んど欠かさずに開場するならば、どうしても月初めに初日を出すことにしなければならないが、一年四、五回か三、四回の興行であれば、初日はいつでも構わないということにもなる。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて初日を出すとそれこそ満員客止です。",
              "citation": {
                "source": "燕枝芸談",
                "author": "談洲楼燕枝（二代）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
