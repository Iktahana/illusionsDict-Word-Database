    "definitions": [
      {
        "index": 1,
        "gloss": "hardy begonia (Begonia grandis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
