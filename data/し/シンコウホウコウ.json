        "examples": {
          "standard": [
            {
              "text": "電車の進行方向と逆向きに座ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "車の進行方向を示す矢印が、道路に表示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "迷子になった時、進行方向が分からなくなり困った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "観光客は進行方向左に折れて琵琶湖疏水を渡り、宝塔寺や石峰寺、瑞光寺を訪ね、全国に広がるおいなりさんの総本宮、伏見稲荷大社に足を伸ばす。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "深草で電車を降り、観光客とは逆に進行方向右に折れると、竜谷大学と向かい合って京都府警察学校がある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「隊長どの、唯今の報告に基き計算致しますと、敵機の進行方向は東南東であります」　その声の終るか終らぬうちに、浦和の聴音隊からの警報がやって来た。",
              "citation": {
                "source": "空襲下の日本",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その進行方向は確かに本船に向かっていた。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　隼人は無視して通り過ぎようとしたが小太りの男は隼人の進行方向に立ちはだかり、執拗にくっついてくる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
