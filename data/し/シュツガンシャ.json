        "examples": {
          "standard": [
            {
              "text": "今回の採用試験では、海外からの出願者が例年の倍以上に増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出願者の氏名や住所に誤りがないか、受付窓口で厳重なチェックが行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "奨学金の希望者が多いため、成績上位の出願者から優先的に選考が進められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "但、御陳情によりまして以後、唄うたいの新出願者は決して許可しないことにいたしましょう。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出願者の数はこれまでの記録をやぶって、ほとんど定員の二倍になっていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
