        "examples": {
          "standard": [
            {
              "text": "彼は、社会政策学会で自身の研究成果を発表する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "社会政策学会では、定期的にシンポジウムが開催されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "社会政策学会の最新の論文集を読んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私らがはじめて高等官になった明治三十五、六年ごろ、山崎覚次郎、桑田熊蔵などという人が主宰して、社会政策学会をおこしたことがある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会政策学会の大きなバックは金井延博士だったが、私らは山崎君には大変引き立てられた方だった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころはまだのんきで、西園寺さんが議会で「社会政策学会とはどういうものか」と質問せられたとき、断じてああいうものには賛成しないといったことさえあった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会党と社会政策学会との区別さえよくわからなかったくらいである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
