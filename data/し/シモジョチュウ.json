        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あたしが置かれた部屋は格の好い方で、老侯の愛妾の部屋に隣り、殿様付きの老女格の人と、御前様づきのお側女中との二人が一人の下女中を雇っている世帯へ、食事は御番――主人の食事係が賄うことにして、部屋だけ居候だった。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上女中、お下女中、三十人からの女中が一日、齷齪とすわる暇もなく、ざわざわしていた家である。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱手は、頭の物、着物の類を、下女中に命じて、金に替えさせた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女中の、持って戻って来た金に、己の金のありったけを加えて、綱手は、蔵屋敷の門を出た。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "召使、小間使二人、下女中二人、書生、自動車運転手、助手　これだけが山野家に起臥していた。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「裏口の方からだれか出入りしたものはありませんか」　明智は最後に二人の下女中をとらえた。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
