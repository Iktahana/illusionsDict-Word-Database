    "definitions": [
      {
        "index": 1,
        "gloss": "simple (and honest)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
