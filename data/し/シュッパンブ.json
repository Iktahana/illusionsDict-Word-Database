    "definitions": [
      {
        "index": 1,
        "gloss": "publishing department",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出版部の長沼さんも、氣の毒がつて居られた。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井芹昌信さんはアスキーの出版部門の書籍の親分、土田米一さんは雑誌の親分、大石工次さんは営業の親分だった人だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "全集ではないが、『金色夜叉』の如きは何度重版しても足りないで、毎年の出版部数が今だに相当な高率を維持しているそうだ。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすれば、わき筋に入りこむ傾向のつよい初稿を読み、物語としての軸を明確にするよう腐心してくださった、新潮社出版部の佐久間憲一氏に、この決定稿は大きく負っている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東大協同組合出版部から、『きけわだつみのこえ』という戦没学生の手記を集めた本が発行された。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五月九日）『中央公論』は、仄聞するところによると十万の出版部数をもっているそうだ。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十一日）［『大杉栄随筆集』人文会出版部、一九二七年五月］",
              "citation": {
                "source": "書簡　山田邦子宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーン、アン／＼と顏に手を當ててぢだんだを踏んで泣き喚いても足りない思ひをしてる時、途端、ガラツと格子戸が開いて、羽織袴の、Ｓ社の出版部のＡさんが、玄關に見えた。",
              "citation": {
                "source": "足相撲",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も時偶そこへ白鷹を飲みに行くが、そののれんを外にくぐり出ると、真向の路地の入口にわが友水守亀之助君経営の人文会出版部の標木が、闇にも白く浮出しているのが眼につくであろう。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その春以来、彼がその団体で献身的に働いていた出版部の活動が非常な困難に陥った。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "※エンゲルス、「家族、私有財産、国家の発生」　　これは党出版部から出したいが、計画についておききでしょうか。",
              "citation": {
                "source": "往復帖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（高島屋出版部）道標（第一部）。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに忘れられないのは、モウパッサンの例のアメリカ廉価版が何冊か届いて、それを電話で丸善から知らせて来たので、金のないのを無理に出版部に行ってたのんで工面してもらって、あたふたと急いでそこに出かけて行ったときのことであった。",
              "citation": {
                "source": "日本橋附近",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "在学中、私は早稲田美術研究会の幹事をしていたが、その縁で紀淑雄先生から、日本の美術に関した本を全部書上げてくれないか、出版部から発行するから、という話があった。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が書上げると同時に「出版部の都合で中止になった」　と、云われてしまった。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　矢島は復員後、かなり著名な出版社の出版部長をつとめていた。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉喜大臣云々といふ書出しからして、これはいはゆる講談本と同種であり、恰度僕が長崎へ出発の数日前大井広介氏が送つてくれた「天草騒動」といふ本、これは早稲田出版部の「近世実録全書」といふ中に収められてゐるものだが、題は違ふが内容は同一物のやうに思はれた。",
              "citation": {
                "source": "島原一揆異聞",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛巻は私を誘ひ（二人が編輯に当つてゐたから）岩波書店の出版部長をよびだし、神田一円の表通り裏通りを当もなくグル／＼と歩き廻りながら、岩波が言を左右にして申出をはぐらかす曖昧な態度を難詰し、芥川全集の出版は中止にします、と叫んだが、彼の全身は怒りのためにふるへてゐた。",
              "citation": {
                "source": "処女作前後の思ひ出",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして此の玩具の大半は出版部の倉庫の中で洪水を喫つて全滅してしまつた。",
              "citation": {
                "source": "支那の明器",
                "author": "會津八一",
                "note": "青空文庫"
              }
            },
            {
              "text": "放二さんが引きうけて下さるなら、出版部長におむかえしたいのよ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども雑誌編輯部にくらべれば、出版部は大きにヒマな方だ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "放二も、記代子も、青木も、出版部をまかされていた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もと放二たちの編集長の穂積が出版部長であった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "せつ子はお義理で入社させた連中をみんな出版部へ集めたのである。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『プロレタリア詩』一九三一年九月号に黒島謙名で発表　同年八月日本プロレタリア作家同盟出版部刊『一九三二年版日本プロレタリア詩集』を底本）",
              "citation": {
                "source": "無念女工",
                "author": "榎南謙一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は學校を卒業すると、直ぐに早稻田の出版部に奉職した。",
              "citation": {
                "source": "編集者今昔",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版部仕事は興味もなく、私には不適當であつたので、半年あまりで辭職した。",
              "citation": {
                "source": "編集者今昔",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間の私の編輯者としての行動を、こゝでくど／＼と述べるのは遠慮すべきであるが、たゞ一つだけ云つて置きたいと思ふのは、出版部の編輯者としても、新聞の訪問記者としても、私は名刺といふ物を殆んど用ひなかつたことである。",
              "citation": {
                "source": "編集者今昔",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版部の時には名刺を作らなかつたのではないかと回顧されるが、讀賣の時には作る事は作つても、殆んど用ひなかつたのではないかと、私は記憶してゐる。",
              "citation": {
                "source": "編集者今昔",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、この春ハーバード大学出版部から『雪の結晶』を出したのと、経験は二回だけである。",
              "citation": {
                "source": "校正の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
