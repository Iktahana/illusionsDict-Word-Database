  {
    "uuid": "4412c64f-71b6-55d4-bb9e-35ddc2f54fe2",
    "entry": "失命",
    "reading": {
      "primary": "しつめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "losing one's life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今かかる達人の見地よりせば、いわゆる道のためには喪身失命を辞せずで、手足なお断つべし、いわんやこの肉体を養うための衣食のごとき、場合によってはほとんど問題にもならぬのである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいか、殺を論じて、一毫を破らず、活を論じて、喪身失命すとは、このことじゃ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
