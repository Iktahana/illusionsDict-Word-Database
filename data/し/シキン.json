[
  {
    "uuid": "e799cc43-e5f8-51f2-8c32-d8e53e6970f2",
    "entry": "資金",
    "reading": {
      "primary": "しきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
