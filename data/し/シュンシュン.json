        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "きんは、がっかりした気持ちで、しゅんしゅんと沸きたっているあられの鉄瓶を取って茶を淹れた。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、湯がしゅんしゅんとわく。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所の方にはいつもサモヴァルがしゅんしゅんいっていて、お得意は輪形のパンでお茶の饗応にあずかった。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "その卓子のうえにはすでに家庭用の大きなサモヴァルがしゅんしゅん沸いて、セーヴル燒きの家族用の茶飮み茶碗が並べてあった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
