        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山の中で、雪を売るということが、一方の室で、シトロンやミルクキャラメルを売っているのに対して、いかにも原始的で、室でやりそうな商いではないか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲食も、コーヒー、シトロン、紅茶などの近代的芳香の飲料と、阿倍川もち、力もち、葛湯、麦粉などの中世的粗野なる甘味が供給される。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手に頂戴いたしますから」かの女はなおもシトロンの壜の口をあけて、コップの口に臨ませて来る夫人を軽く手で制してそう云った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぞ、シトロンかサイダアでもめしあがりますか。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに赤いシトロンと草の緑は天幕の内部を明るくする。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それからシトロンを一本あけてもらったが、また金は払わずに飛び出す私を私は見出した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥では燻製の鰊や、蟹の鑵詰の鑵や、シトロン、麦酒の瓶などが、売品として、二、三の卓上に飾り立ててもあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢の中でも、私は、強情な植物共の蔓を引張り、蕁麻の棘に悩まされ、シトロンの針に突かれ、蜂には火の様に螫され続ける。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海抜千三百｜呎、シトロンやたこの木に取囲まれた山頂の空地である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "噎せる程強いシトロンの香の立ちこめる熱い空気の中で、会衆は静かに頭を垂れた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大田黒君はシトロンを三本贈つた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "会の席で妾のコップにシトロンでなくビールがついであったのを思い出したにちがいありません。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "帶は臙脂にガランスとシトロンの亂菊模樣のついたのを締めさせて、曇日の合歡の葉影にほのかな淡紅の花をおいた背景で描いた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽は高い塀に遮られて見えないが、空はうららかに晴れ渡って、空気はシトロンのように爽かであった。",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それらの壺の幾つかには夫々色の異る薔薇や鬼薊の花束とか、橄欖やシトロンの杖が盛られてゐるところを見ると、一見花屋の店先か知ら？",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒はと問われて、大村は麦酒、純一はシトロンを命じた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「シトロン酒の強いやつを飲まして下さい」　ガルールは、男が出してくれた煙草を捲きながら答えた。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのシトロン君はまだ聖ケヴィンズ・パレードに達者で勤めているかしら？",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "シトロン君の籐椅子に腰掛けたモリ。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯のシトロンの飲めぬ為にも少からぬ不自由を忍んでいる。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "シトロンでも煽る調子で食事｜毎に葡萄酒や茴香酒を飲む。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人皆太陽に酔へる時、忽ち前に裂くるは夕立のシトロン。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯のシトロンの飲めぬ為にも少からぬ不自由を忍んでゐる。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、｜鮫の緬を持って来い、シトロンを持って来い！",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "合乗り乳母車　――仏蘭西縦断の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――シトロンでいい。",
              "citation": {
                "source": "ガンバハル氏の実験（ラヂオドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそうと、さぞびっくり仰天することだろう、わたしのステッキが小さな樹になっていて、葉のついた若い枝に覆われ、なお、もしかして、その枝の一本に、旅の渇きを癒すため、ステファアヌ・マラルメが愛でた果実、「理想の苦みに味つけられた黄金色のシトロン」をちぎる悦びをもつとしたら。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の娘たちはシトロンをたべない。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "シトロンが決して落ちないようにするには、常に行儀よくしていればいい。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この国に輸入されてふつう丸い小箱に入れられている、小さな緑のライム、シトロン、ホップ・トップ、プラム、アンジェリカ根、などの砂糖漬け、はしばしば銅で汚染されている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
