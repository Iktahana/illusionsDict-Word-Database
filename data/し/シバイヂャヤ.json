    "definitions": [
      {
        "index": 1,
        "gloss": "tearoom attached to a theater (esp. in kabuki)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芝居茶屋というものの光景の記憶がかすかに残っている、それを考えると徳川時代の一角をのぞいて来たような幻覚が起こる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に座附の芝居茶屋全廃論も出でたるが、未解決に終れり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門町の青楼と道頓堀の芝居茶屋が、ちょうど川をはさんで、背中を向け合っている。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居茶屋の階子段のお手際では、この石段は覚束ない。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　巻莨と硝子盃を両手に、二口、三口重ねると、圧えた芝居茶屋の酔を、ぱっと誘った。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの飴屋は芝居茶屋の若い衆でね」と、老人は話した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うも、やっぱり私の心持が、少しは分ったと見え、芝居茶屋の二階へ舞台姿の維盛卿でやって来たのです。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（芝居茶屋の花車女に案内され、若き町娘下手の入口より入って来る）花車女　おお源次さま。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以来、侍の芝居見物ということが又やかましくなりまして、それまでは大小をさしたまゝで芝居小屋へ這入ることも出来たのですが、以来は大小をさして木戸をくゞること堅く無用、腰の物はかならず芝居茶屋にあずけて行くことに触れ渡されてしまいました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもやっぱり芝居見物をやめられないと云う熱心家は、芝居茶屋に大小をあずけ、羽織もあずけ、そこで縞物の羽織などに着かえるものもある。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの四人連が下谷の池の端から来た客だということを芝居茶屋の若い衆から聞いているので、藤崎さんは先廻りをして広徳寺前のあたりにうろ／＼していると、この頃の天気癖で細かい雨がぽつ／＼降って来ました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも芝居の喧嘩の一件が町方の耳に這入って、芝居茶屋の方を一応吟味したのですが、茶屋でも何かのかゝり合を恐れたとみえて、そのお武家は初めてのお客であるから何処の人だか知らないと云い切ってしまったので、まるで手がかりがありません。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇場の両側には六、七軒の芝居茶屋がならんでいる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき着いた芝居茶屋は菊岡という家で、わたしはここで袴を脱がされた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "座の両側にも芝居茶屋が軒をならべて、築地橋から座の前を通りぬけた四つ角まで殆んどみな芝居茶屋であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに馴染の芝居茶屋の若い者や劇場の出方などが番附を配って来る。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、一枚刷の番附は前にいったように芝居茶屋や出方が客先へ配るか、または辻番附と唱えて市内の辻々や湯屋｜髪結床などへ広告用に懸けて置くだけのことで、芝居見物に行った場合には、別にかの絵本をうけ取ることになっていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその後に座付の芝居茶屋、猿家のうしろ楯を得て、興行ごとに大役を背負うようになったのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治座は閉っている頃で、軒を並べた芝居茶屋まで夏季らしくひっそりとしていた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君はまだ自分で自分の身体をいたわるかのように、瀟洒な模様のついた芝居茶屋の団扇などを手にしながら、「姉さんも生命拾いをしたよ」　と自分のことを捨吉に言って見せて、微笑んだ。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の間は応接室がわりに成っていて、仕切場だとか大札だとか芝居茶屋の女将だとかそういう座付の連中ばかりでなくその他の客が入れ替り立ち替り訪ねて来る度に、よく捨吉が茶を運ぶところだ。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治座の横手について軒を並べた芝居茶屋の前を見て通ると、俳優への贈物かと見ゆる紅白の花の飾り台なぞが置かれ、二階には幕も引廻され、見物の送迎にいそがしそうな茶屋の若い者が華やかな提灯の下を出たり入ったりしていた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊芸をみっちり仕込んだ嫖致の好い姉娘は、芝居茶屋に奉公しているうちに、金さんと云う越後産の魚屋と一緒になって、小楽に暮しているが、爺さんの方へは今は余り寄りつかないようにしている。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に伝わった俳名｜三升、白猿の外に、夜雨庵、二九亭、寿海老人と号した人で、葺屋町の芝居茶屋｜丸屋三右衛門の子、五世団十郎の孫である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安の女二人のうち、敬は猿若町三丁目の芝居茶屋三河屋に、銓は蔵前須賀町の呉服屋｜桝屋儀兵衛の許にいた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時此家は芝居茶屋を業としてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかなり大きくなってからでも、芝居茶屋の二階に、ポツネンと、あねさまを飾ったり、ボンヤリ考えたりして一人で居残っていたことが多かった。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
