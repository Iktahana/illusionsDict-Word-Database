[
  {
    "uuid": "3af2cb5d-e879-5033-a032-0ac136e07024",
    "entry": "仕切り",
    "reading": {
      "primary": "しきり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "partition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "箱の中にいくつも仕切りをしてその中に一つ一つ猫を入れておく。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妓は船の中の仕切りに腰かけていて、帯の間から煙草入れとライターを取出しかけながら「いい景色だね」と云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かようにしてすべての戸棚や引出しの仕切りをことごとく破ってしまうのが、物理科学の究極の目的である。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方の仕切りにはテプラーポンプや附属のマノメーターなどを置いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワシントンからマウント・ウェザーの気象台へ見学に出かけた田舎廻りのがたがた汽車はアメリカとは思われない旧式の煤けた小さな客車であったが、その客車が二つの仕切りに区分されていて、広い方の入口には「ホワイト」、狭い方には「カラード」という表札が打ってある。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、その水島君の樣子をちらと眺めた女は、あわてたやうに立ち上つて、仕切りの框に肘つきながら云つた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきから隣の仕切りの部屋のテエブルに一人凭て、二人の何れかを一夜のとりこにでもする積りだつたのか、しきりに媚態を送つてゐた、英語の巧い、二十六七の女である。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人のボオイが持つて來た傳票に少しの酒手を加へて拂ひをすますと、水島君と私とは仕切りの部屋を廊下へと飛び出した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "源作は、算盤が一と仕切りすむまで待っていた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相島は仕切りの襖を締めて廊下に出て、其處の押入れから茶碗を二つと土瓶と茶筒とをつかんで來た。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで苦しんだなら、いくら厚い仕切りでも消える筈だ。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもおかしい、おれは生焼けの餅を食わされたんだ」　――あら、そんなお話はじめてよ、今まで一度も仰らなかったじゃないの」　妻は仕切りの障子を開けて白い顔を茶の間に出した。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝸牛の殻が乗るように仕切りのある特別の皿も用意してある。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心に仕切りがあるようにどうしても進めない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二軒の家は、間取りも、壁の色も、窓も、煙突も、ポオチもすっかり同じで、境の花園などは仕切りがなく共通になっている。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、馬をつなぐ仕切りはそのまま残してあって、これをかざりたてて、見物の桟敷にしてあったのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の伯母なるものに問合すと、年老いてることでもあり葬儀万端｜然るべくという返事なので鼈四郎は、主に立って取仕切り野辺の煙りにしたことであった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九曜星の紋のある中仕切りの暖簾を分けて、袂を口角に当てて、出て来た娘を私はあまりの美しさにまじまじと見詰めてしまった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "開かれた仕切りの扉から覗かれる表部屋の沢山の箪笥や長持の新らしい木膚を斜に見るまでもなく、これ等のすべてが婚礼支度であることは判る。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は車室の仕切り板の方に顏を向けながら暫く雜誌を讀み耽つてゐたが、時時無意識にとろとろと眠り落ちる。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は波の代りに、斜めに引かれたる赤條で旗の下端を三角に仕切り、そこを黒く染めて白の井桁を拔いたのもある。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都を歩いて居ると無用のものが多く、だだ廣くて直きに可厭になるが、大阪に至つては街區のどの一角を仕切り取つても活溌な生活の斷片を掴む事が出來るやうに感ぜられる。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅宿といっても客の部屋はこれ一つらしく、この部屋の仕切りをしている襖の角の隅に古屏風が囲ってあり、その屏風にわたくしの見慣れた先生の裏毛の外套やスカーフが掛けてあるところを見ると、ここに先生の居どころが設けられてゞもあるのでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の間との仕切りの襖が開いて、縞のブラウズを着た千代重が悠然と出て来た。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の上手の方にほんの仕切りしただけの垣があり、枯れ秋草がしどろもどろに乱れている。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは家を手に入れて、調度を揃える、お女中の給金を払う、つまりその場の取り仕切りを全部やる。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは山に向ふ看者の間に介まりて、推されながらも、白き石垣もて仕切りたる葡萄圃の中なる徑を登り行きぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の角にも似たような仕切りが二つあり、実際、前のよりはずっと尊敬されてはいなかったが、それでもやはり非常に畏怖の念を起させるものだった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "この名刺差しには三つ四つの仕切りがあって、五、六枚の名刺と、一通だけの手紙とが入っていた。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "名刺を読むと、しきりにまたガツテンガツテンをしながら私の顔をみて、それからタモトに入れたのであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
