        "examples": {
          "standard": [
            {
              "text": "彼の目はまるで死んだ魚のようだった。何か大きな悲しみを抱えているに違いない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "徹夜明けで、鏡に映った自分の顔を見たら、死んだ魚の目をしていて驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「おい、大丈夫か？死んだ魚の目をしてるぞ」と上司に心配された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、海は、ちょうど死んだ魚の目のように、どんよりと曇って、毎日、毎日、雪が降っていました。",
              "citation": {
                "source": "月とあざらし",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくのあいだ、ぼくは同じ姿勢のまま、いちめんに死んだ魚の目玉の白さをむきだしにしている、どんよりと曇った冬の日のその天の魚を見ていた。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
