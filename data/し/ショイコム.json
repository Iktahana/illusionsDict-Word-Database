    "definitions": [
      {
        "index": 1,
        "gloss": "to carry on one's back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
