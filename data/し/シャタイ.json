    },
    "definitions": [
      {
        "index": 1,
        "gloss": "oblique type",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
