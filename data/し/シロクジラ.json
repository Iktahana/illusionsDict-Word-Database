        "examples": {
          "standard": [
            {
              "text": "昔は白鯨のひげで精巧な工芸品が作られていたと、博物館で説明を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この飾りは、貴重な白鯨のひげを加工して作られた一点ものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館には、かつて漁師が使っていた白鯨のひげを使った道具が展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
