        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "『白鯨』は、エイハブ船長と巨大なマッコウクジラの戦いを描いた有名な文学作品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海の深くに白鯨が生息しているという伝説があり、漁師たちの間で語り継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水族館の巨大なプールで、白鯨が悠々と泳ぐ姿を見ることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "はたや又、我がなつかしき白村に翡翠白鯨我が事を語りてあらむ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所のテーブルで用事の合間に「白鯨」をよむ。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨には抹香鯨、槌鯨、つばな鯨、白鯨、ごんどう鯨、白長鬚鯨、長鬚鯨、鰮鯨、座頭鯨、背美鯨、北極鯨、小形鰮鯨など大分変わった種類があり、すなめり、いるか、さかまたなどがその親戚になっている。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピッツフィールドのこっち側では、ハーマン・メルヴィルが、大きなグレイロックの姿が窓をふさがんばかりにそびえている書斎で、彼の長編「白鯨」の雄大な構想を練っていることだろう。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂先の白鯨も卵色になっている。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
