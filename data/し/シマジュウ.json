        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "島中先生を好んものは有りましねえで。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "島中を歩き廻って宿へ帰ったら番頭がやって来て何か事々しく言訳をする。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南洋のソロモン群島中のある島に存する竹製の縦笛にププホルと称するのがある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻木海軍大佐は今や此島中に身を潜めて兼て企つるといふ、軍事上の大發明に着手して居るのではあるまいか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「島山鳴動して猛火は炎々と右の火穴より噴き出だし火石を天空に吹きあげ、息をだにつく隙間もなく火石は島中へ降りそそぎ申し候。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白くもないし、二三年で僕は此中学を止めて了って、三島中洲先生の二松学舎へ転じたのであるが、其時分｜此処に居て今知られて居る人は京都大学の田島錦治、井上密などで、この間の戦争に露西亜へ捕虜になって行った内務省の小城なども居ったと思う。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "午になり、島中の誰彼が木蔭や家の中の竹床の上でうつらうつら午睡をとる時も、此の男ばかりは、家内の清掃に、小舎の建築に、椰子蜜採りに、椰子縄｜綯いに、屋根｜葺きに、家具類の製作に、目が廻る程忙しい。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちかちか明の鴉の鳴くこえきけば、首尾えい首尾えいと島中に告げる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人のおかげでシラキュースは急にどんどんお金持になり、島中のほかの殖民地に比べて、一ばん勢力のある町になりました。",
              "citation": {
                "source": "デイモンとピシアス",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六一八九一年九月×日　近頃島中に怪しい噂が行われている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ島では、巡査と公學校長（校長ばかりで下に訓導のゐない學校が甚だ多いので）と、島中でこの二人だけが日本人であり、且つ官吏であるので、自然勢力爭ひが起るのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "島内を一巡して見たが、島中、椰子と蛸樹と麺麭樹とがギツシリ密生してゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、私は、餘り上等でないパナマ帽をかぶつて群島中を歩いた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう島では、巡査と公学校長（校長ばかりで下に訓導のいない学校が甚だ多いので）と、島中でこの二人だけが日本人であり、且つ官吏であるので、自然勢力争いが起るのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "島内を一巡して見たが、島中、椰子と蛸樹と麺麭樹とがギッシリ密生している。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、私は、余り上等でないパナマ帽をかぶって群島中を歩いた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、島中の人民はほとんど総てが信徒なので、征討軍が放つ密偵は悉く偽りの報告を齎すから、まるで裏をかかれ通しである。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『いゝえなに、島中くるりと※つても半日とはかゝりませんからな、ハヽヽ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピンカートンの『海陸紀行全集』一に収めたマーチンの『蘇格蘭西島記』に、ロナ島へどこからとも知れず鼠群れ来って島中の穀を食い尽した上、泣き面に蜂とか、水夫が上陸してただ一疋あった牛を掠め去ったから、全く食物なくなったのに一年間糧船来らず、全島の民が死に尽した。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "大高森とは、宮戸島中の最高峯にして、四方の眺望極めて佳也。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一島これ山、一山これ島、島中絶えて平地を餘さず、燈臺と黄金祠との外には、農家もなく、住む人よりも猿多く、鹿多し。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも八千尺以上となれば高山なるが、本島中八千尺以上の山は、信濃を中心として、その附近にのみ集まれり。",
              "citation": {
                "source": "一萬尺の山嶽",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは島中の目印になった木やがな。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "島へ上陸した有王は、三日の間、島中を探し回った。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は俊寛が生活した旧跡でも見たいと思って、人の住む所と否とを問わず、島中を縫うように駆け回った。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "通例天地創造の行為は単に物質の整頓であると考えられ、大多数の場合にはそれが地と原始水あるいは大洋との分離であったと考えられている（太平洋諸島中の若干の民族は地が大洋から漁獲されたと考えている）。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田家では最初この家との縁談があった時、妾の子ではと一時躊躇したのだそうだが、川村大将とか高島中将とかが中にはいって、無理にもらわしてしまったのだのとかと聞いた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして特に、終始一貫、有形無形に多大の援助を賜わった中央公論社長島中雄作氏に、僕は心からなる感謝と握手の手を差し伸べる。",
              "citation": {
                "source": "踊る地平線",
                "author": "附記",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　りすたちは　しまじゅうで　どんぐりを　さがし、　ちいさな　ふくろを　いっぱいに　しました。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
