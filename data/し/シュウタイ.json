    "definitions": [
      {
        "index": 1,
        "gloss": "disgraceful behavior",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眼前の異樣の風景に接して、腰を拔かすなどといふ醜態を示す事は無かつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑つてころんだりしては醜態だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は重々しき語気をもて、「はいではない、こんな処に寝ていちゃあいかん、疾く行け、なんという醜態だ」　と鋭き音調。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十指の指差すところ、十目の見るところの、いかなる弁明も成立しない醜態を、君はまだ避けているようですね。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、これで自分も、申しぶんの無い醜態の男になった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唯だ東京の奴等を言ったのサ、名利に汲々としているその醜態は何だ！",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は周章てゝ起上つたが、怒氣滿面、けれど自己が醜態に怒る事も出來ず、ビール樽のやうな腹に手を當てゝ、物凄い眼に水夫共を睨み付けると、此時私の傍には鬚の長い、頭の禿た、如何にも古風らしい一個の英國人が立つて居つたが、此活劇を見るより、ぶるぶると身慄して『あゝ、あゝ、縁起でもない、南無阿彌陀佛！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あゝ、何たる醜態ぞ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私は躍起になつた、此處には春枝夫人の如き殊勝なる女性もあるに、彼船長の醜態は何事ぞと思ふと、もう默つては居られぬ、元より無益の業ではあるが、せめての腹愈しには、吾鐵拳をもつて彼の頭に引導渡して呉れんと、驅出す袂を夫人は靜に留めた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち山岳鳴動し、黒烟朦朧と立昇る、其黒烟の絶間に眺めると、猛狒は三頭共微塵になつて碎け死んだ、獅子も大半は打斃れた、途端に水兵が『あれ／＼、あの醜態よう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に其の帷中の婦を見れば、宛としておでこの醜態、明白に成畢ぬ。",
              "citation": {
                "source": "鑑定",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかばかしい、銭を出して、あの醜態を見せられて、置き去りを吃うやつもないものだ」「全くそうでごさいますよ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この臆病者等が怯んで動揺めく醜態をじろじろ見廻して、「ははははは。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧なせえまし、此の醜態だ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘いものに餓えているような顔で、「やあ……これは珍しいですな」　などと、やに下って手を出すのは、醜態だと思ったのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが、今夜のおれと来たら……」　と、豹吉は自分の醜態にあいそがつきるくらいだった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "喀血その事よりも、見知らぬ女の前でそんな醜態を演じてしまったことが情無かった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて始めての経験であるから、無理もないことだが幾分醜態だった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "震えているという醜態のためだった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも先ず、四十過ぎて妻に裏切られた男の醜態を人眼にさらしてはならないのだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼前の異様の風景に接して、腰を抜かすなどといふ醜態を示す事は無かつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という返事で、ついに一度も、私が支払い得なかったという醜態ぶりであった。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の異様な酒宴に於いて、最も泥酔し、最も見事な醜態を演じた人は、実にわが友、伊馬春部君そのひとであった。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな年寄りになるまで生きていて、人から老人扱いをされ、浅ましい醜態を曝して徘徊する位なら、今の中に早く死んだ方がどんなにましかも知れない。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に於ての恥かしいこと、醜態を極めたこと、みさげはてたること、野卑と愚劣との外の何物でもないやうな記憶の再現は、砒毒のやうな激烈さで骨の髓まで紫色に變色する。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
