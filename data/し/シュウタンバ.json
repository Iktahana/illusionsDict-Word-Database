[
  {
    "uuid": "595d4a94-97a0-5b78-b49b-354d5b91ee20",
    "entry": "愁嘆場",
    "reading": {
      "primary": "しゅうたんば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tragic scene (moving one to tears)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一場の不可解な愁嘆場は衝立の蔭になっていたので、他の誰にも見えなかったのは幸でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いもよらない愁嘆場を見せられて、半七ももう仮面をかぶっていられなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公である私生子の少年はそのために非常に苦しんで大愁嘆場が演じられるわけです。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ家臣清三郎（虚心）が駈付けて来るので、それに後事を託し、蒲地は切腹して落入るといふ愁嘆場。",
              "citation": {
                "source": "硯友社と文士劇",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鶏卵を買いに出たという現場不在証明と、この愁嘆場によって、ブラドンはたくみにクロスレイ夫人はじめ下宿の人々を瞞着して、底を割ることなく、この芝居を打ちとおしたのだ。",
              "citation": {
                "source": "浴槽の花嫁",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服を着た菊五郎と銀杏返しの半四郎とが、火入りの月の下で愁嘆場を出している所です。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「恋の闇路を踏み迷ふ……」と云つた調子の狂乱の場や、「散り失せしこそ哀れなれ」式の愁嘆場を通じて、勿論、これほどまでゝはないが、可なりの通俗味がある。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎の愁嘆場のやうなものが実際あつたらをかしなものだが、そのとき自分は愕然と鉄格子から外を覗いて阿呆のやうにぼんやりしてゐたものである。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが愁嘆場へ行くと非常に頻繁になってついには手に持った手布を打ち振るようなことをする。",
              "citation": {
                "source": "美音会",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居じみたことが好きだから深刻さうなことを言つたり、小説にでもありさうな愁嘆場を演じることも稀にあるけど、ほんとの気持は平気なのね」「特別好きな男ができたら――さういふ時もあると思ふが」「浮気だから仕方がないのよ」「なるほどな」と左門は言つたが、然しはつきり分かつたわけではないのであつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生みの親にめぐり逢いてえとか、この世の名残りにせがれに一目あって死にてえとかいうのは、お芝居としちゃあ結構な愁嘆場かも知れねえが、生で見せられると根っから栄えねえものなんだぜ……お前さんも、そこをよく心得ていなくちゃいけねえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても前述の愁嘆場と同じくこうした呼吸をもって表現するところは速記では全く味わい知るべくもない。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧派の演劇で非業に子を失った母親の愁嘆場には、往々にして「疱瘡も軽く済ましたものを」という繰り言が伴っている。",
              "citation": {
                "source": "特殊部落の人口増殖",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内に福宝館がある誇り蔦雄忍術をつかひ大勝館でまき十九樽愁嘆場弁士美文もちつとまぜ雀郎男優は眼玉女優は瞳なり同停電のつなぎに弁士洒落を云ふ夜刃郎大晦日テケツ島田に結つてゐる鉄次郎　福宝館は浅草にこそなかつたが、宛かも牛肉屋のいろはのごとく、第一、第二と市内各所に点存してゐた。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愁嘆場」で「美文」をまぜる弁士（映画解説者）の口吻は、全トーキーの今日では偲ぶよすがもなくなつてゐるが、そのころの弁士の存在たるや、下町にも山の手にも、云ひ換へると庶民階級にもインテリ階級にも、若い男女にとつて凡そかがやかしくハイカラな存在だつた。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼もあてられない愁嘆場で、送りの同心もつい貰い泣きをすることがあるそうです。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は、氏が横濱行の愁嘆場の記事を差して云つてゐるのだらうと察してゐた。",
              "citation": {
                "source": "昔の西片町の人",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろくもない愁嘆場だよ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日の午さがりだけあって、いかにも間の抜けた愁嘆場……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋は直ぐ其處、中へ入ると、全く眼も當てられぬ愁嘆場です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋はすぐそこ、中へ入ると、全く眼も当てられぬ愁嘆場です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣の強い駒込の長五郎――嫁の親父の、あの祿でもなしも、聟の榮三郎の愁嘆場に膽を潰して、マアマアと慰め方に廻つたのは、變な圖でしたよ」「お前は地主の多之助の死んだのを知らせる筈ではなかつたのか」「飛んで行きましたよ、相模屋の方は宜い加減にして。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき獲物",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、あなたは抗議したり、責めたり、愁嘆場を演じようとは思つてゐない。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間も寝静まっている頃なのに、母はぼくらを抱いてなお動こうともせず、まるで芝居の愁嘆場そのままだが、袖口に顔を埋めて、「……どうしてあんな恐ろしい人へ嫁いできたのだろう」と、くどくどと恨んで泣き、「……おまえたちさえ産んでいなければ」と、身もだえして泣いた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり長く愁嘆場を演じた結果、わたし達の間にはこんな口約束ができました。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊三郎の死骸は、檢屍が遲れて夕方になつて漸く志賀屋が引取り、船を仕立てて哀れ深く歸つて行きましたが、その時、姉娘のお里が『死の船』の後を追つかけ、潮入の堀割の岸で、芝居でも見られぬ大愁嘆場をやつたさうで、下男の久六などは、生れつきの神經の太さで、それを面白いもののやうに話してゐるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青葉の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが隣りから隣りへ伝って、庭いちめんの愁嘆場となった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
