          "literary": [
            {
              "text": "この久兵衛とお艶とどういう関係にあるのか、などと改めて四角張るのは野暮の骨頂で、片方が気違いのことだ、順序も系統もあったものではない。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お白洲じゃないから、四角張るには及ばない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "三千両異変",
                "note": "青空文庫"
              }
            },
            {
              "text": "同級生もお客となると四角張る。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
