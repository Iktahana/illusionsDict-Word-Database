          "literary": [
            {
              "text": "願わくばコンピューターよ、舌っ足らずのオレに表現力を与えよ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか、あたいにも訳が分らないんだよ」　と言うと、すすっと寄ってきて舌っ足らずの声で、「先生……マア起きていたんだね。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだといって……※　なんだか、あたいにも訳が分らないんだよ」　と言うと、すすっと寄ってきて舌っ足らずの声で、「先生……マア起きていたんだね。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶよぶよした、しまりのない感じで、二十五にもなっているというのに、子供のような舌っ足らずなものの言いかたをする。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "色白で、面長で、眉が薄くて、ひどく撫で肩で、下唇が突出して、いささか舌っ足らずで――こう条件を並べただけで、大方若旦那金之助の風貌は想像がつくでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つになるのに口のおそい子で、ときどき気取って舌っ足らずなことを云う。",
              "citation": {
                "source": "ちゃん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌っ足らずに訛ったのだろう、のちには直ったけれども、初めのうちはわからなくて出三郎はどう呼んでいいか当惑したものであった。",
              "citation": {
                "source": "艶書",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "動作ものろくさしているし、舌っ足らずな口をきくし、見ているとじれったくなるばかりだった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ幼ない鳥とみえ、その囀は片言の舌っ足らずで、笹鳴きのあいだに偶然「ほ、きょきょう」とはいる。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さよう、とつぜんの出火で」　老番士は舌っ足らずな口ぶりで続けた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
