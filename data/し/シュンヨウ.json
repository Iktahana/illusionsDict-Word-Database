[
  {
    "uuid": "12d775e3-8756-52a7-bafa-3ca5f9314a4d",
    "entry": "春陽",
    "reading": {
      "primary": "しゅんよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
