        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "沈み込む程ふっくりした夜具に潜り込む時、彼は又ちょっと考えた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく少女は眠りに落ち、旅人の大きな胸の中に気持ちよく沈み込む。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど、鍛冶屋の金敷の台木の中に、いつの間にか鉄屑が嵌り込み、沈み込むのとよく似ている。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は電車の中へ沈み込むやうに乘ると家へ歸つた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "体は、畳から浮上って気味悪く高い庭へつり上ったかと思うと、眩暈につれて、低い低い、底なしの暗闇に沈み込むようだ。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、尤もな条件だ――コウツは頻りに合点いて、新聞を片手に、深い思案と安楽椅子の底へ、一緒に沈み込む。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "端末の高機能版とオフィスコンピューターの小型版という、コンピューターの専門部隊が提案した二つのパーソナルコンピューターのイメージに、渡辺和也は鉛を飲んだ胃袋の底が深く沈み込むような、疲労と違和感とを覚えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は彼の中にもつと深く沈み込むことによつて、彼がクリストと同じやうに背負はされてゐる十字架を見出すからである。",
              "citation": {
                "source": "芥川龍之介論",
                "author": "――藝術家としての彼を論ず――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が集団大衆となることで、また物質の光学的科学機構の中に沈み込むことで、物質的影像である一コマ一コマを、民衆は歴史的意欲の撃発者として捉えたのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉が無くなると、いつも二人でじっと愛の祈祷のうちに沈み込むより外はなかった。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞正なる自己の國に導く力は、どう／＼めぐりではなくて、掘り下げ、推し進め、かつぎ入り、沈み込む力でなければならない。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、まったく腕の運動が休止して、ガブリと水の中へ沈み込むと、またあわてたように忙がしく手足を動かす。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日没後すっかり暗くなるまでの庭を見、庭が夜の中に沈み込むのを見おさめることは、庭というものの精神を見てやるようなものである。",
              "citation": {
                "source": "日本の庭",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福な親子が、優しい中音と、飛ぶような声高を織りまぜて、睦まじく笑い合う声を聞きながら、膝を抱えて柱に倚り掛った正隆は、心から淋しい、どこにも慰安のない、天地から指をさされるような心持に、沈み込むのである。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂のどん底に沈み込むような気がした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛するものを眼前に所有してるという清浄な楽しみのうちに、魂はうっとりと沈み込む。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし哲学者にして、絶えず消散してゆくこの言語を、よく観察するために一時一定の形に引き止めるならば、彼は痛ましいかつ有益な瞑想に沈み込むであろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今にも沈み込むような気がした。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい快活な明智小五郎ではあったが、彼とても、探偵事件がうまく運ばぬ様な時には、憂欝に沈み込むこともあるのだ。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
