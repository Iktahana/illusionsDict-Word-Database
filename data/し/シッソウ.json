[
  {
    "uuid": "0aa9e0bd-6898-5b99-b716-09de874b33a3",
    "entry": "失踪",
    "reading": {
      "primary": "しっそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
