          "standard": [
            {
              "text": "出版不況の影響で、多くの老舗雑誌が相次いで休刊に追い込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出版不況と言われる今こそ、読者の心に刺さる尖った企画が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "返品率の高さが、出版不況に苦しむ書店の経営を圧迫している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "このごろの出版不況で、文芸雑誌のいくつかが廃刊した。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版不況は、戦後の浮草的出版業を淘汰したと同時に、同人雑誌の活溌化をみちびき出している。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち出版不況の時世となって、Ｙ氏の雑誌も立ちゆかなくなり、旧知の作家Ｏ氏の救援を乞うたところ、Ｏ氏のはからいで、Ｏ氏や私を同人ということにして、新雑誌をだすことになった。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            }
          ]
        }
