        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "思へば小学校の頃からだ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の正面の壁に子供の小学校の霜降の服と、糊でビリビリの日覆をかけた小学帽とが掛かつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けばその後また横浜の小学校に転任したさうであるが、ナニ、ブラ公なぞが訪ねた所で誰が喜ぶものでもあるまい。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "就職試験を受けにいって、小学校の算術の問題を提出されて、大いに狼狽している姿と似ている。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三、四年生の頃だつたと思ひます。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三、四年生の頃だったと思います。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山奥の村に、新しく小学校が設けられる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校では、毎年創立記念日に学童の作品展覧会が催される。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は今年七ツになる、先達小学校に入学したばかりだつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校から中学校へかけ、学生時代の僕の過去は、今から考えてみて、僕の生涯の中での最も呪わしく陰鬱な時代であり、まさしく悪夢の追憶だった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等小学校の理科の時間にＴＫ先生という先生が坩堝の底に入れた塩酸カリの粉に赤燐をちょっぴり振りかけたのを鞭の先でちょっとつつくとぱっと発火するという実験をやって見せてくれたことを思い出す。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐山岳会長若尾金造氏が待ち受けて、一とまず常磐町の同氏邸宅前まで、自動車で伴い行かれ、ここで弁当などを積み込み、大沢照貞氏と、田富小学校長｜輿石正久氏が加わり、自動車で八ヶ岳の高原へと走らす。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、家を出る時に、小学校に今年上つた女の児が、「お母あさん。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜だつたので、小学校四年の男の子も、私もそれを聞いてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも子供だけにはこんないたずらをさせないように家庭や小学校で教えるといいと思われた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その屋根には静岡何某小学校と大きく書いてある。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い婦人で小学校の先生らしいのが両腕でものを抱えるような恰好をして拍子をとっている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで日本のような、世界的に有名な地震国の小学校では少なくも毎年一回ずつ一時間や二時間くらい地震津浪に関する特別講演があっても決して不思議はないであろうと思われる。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果として得られた規準に従って作られた家は耐震的であると同時にまた耐風的であるということは、今度の大阪における木造小学校建築物被害の調査からも実証された。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、昭和四年三月以後に建てられた小学校は皆この規準に従って建てられたものであるが、それらのうちで倒潰はおろか傾斜したものさえ一校もなかった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校や中学校で教える天文学では、大小無数の恒星もその一なる太陽も動かぬものとなっている。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校や中学校で太陽系を説くのは丁度船中で船内の事のみを教えているようなものである。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒワ色、褪紅色の無地ちりめん兵古帯など小学校から女学校時代袴下にしめました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の小学校でも石の巻の近くの海岸に十五日も生徒を連れて行きましたし、隣りの女学校でも臨海学校をはじめていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一｜中隊ぐらいで、鉄橋の上を行く汽車よりはもっとゆるく、小学校の遠足の列よりはも少し早く、たぶんは中隊長らしい人を先頭にだんだん橋を渡って行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の生徒の科学知識に対しては中等教育を受けた者は大抵は権威となり得る資格があるはずである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは涜職者を出すから小学校長を全廃せよ、腐った牛肉で中毒する人があるから牛肉を食うなというような議論ではないかと思われる。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日大学の専門の学生でさえ講義ばかり当てにして自分から進んで研究しようという気風が乏しく知識が皮相的に流れやすいのは、小学校以来の理科教授がただ与えられた知識を覚えればよいというように教えこまれている結果であろう。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから小学校では少し無理かも知らないが、科学の教え方に時々歴史的の色彩を加味するのも有益である。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭二君は明治十年十月二十四日東京で生れ、芝桜田小学校から日本中学校に入り故杉浦重剛氏の薫陶を受けた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
