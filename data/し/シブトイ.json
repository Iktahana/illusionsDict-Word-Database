        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冗談じゃあねえぜ、余りやり方がしぶといや。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の心持が今少しませて居ったならば、この二日の間にも将来の事など随分話し合うことが出来たのであろうけれど、しぶとい心持などは毛ほどもなかった二人には、その場合になかなかそんな事は出来なかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもしぶとい奴だと言わんばかりな眼が、渡瀬の額の生えぎわのあたりを意地悪くさまよっているのは、明かに渡瀬の神経にこたえてきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前、行ってくればいいでねえか」　薄ぼんやりと、しかもしぶとい声で純次がこう答えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　はて、しぶとい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三吉は左手を伸べて白き頸を掻掴み、「ええ、しぶとい、さあ立て、立たねえとこうするぞ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――全くしぶとい小娘だ。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しぶとい人ったらありゃしないよ、何故はいと云わないの、いくらお前さんが強情張ったってだめじゃないの、早くはいと云いなさいよ、いくら厭だと云ったってだめだから、痛い思いをしないうちに、はいと云って、奥様に可愛がられたら好いじゃないの、はいと云いなさいよ」　讓は少年の顔に注意した。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しぶとい人つたらありはしないよ。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しぶとい奴だ」　鬼卒達は無理にその手を引き放そうとした。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぶしぶといったふうに肩をそびやかすと、客人は早口でそわそわ身振り手振りを交えて、話を一挙に語り出す。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱々しゅう見えてもしぶとい者どもじゃ。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なかなかしぶとい奴だな。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬にこんな不思議な眼を授けた自然は、かまきりにはかなり鋭利な二つの鎌と一緒に、しぶとい反抗心を与えてくれた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなしぶとい奴とは思わなかった。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると隅にいたヨコハマ・ジャックがのっそり進み出て、「この日本の小猿めは、しぶとい奴ですよ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして某生命保險會社代理店の看板を家の前に下げてゐる石川剛造を先頭とするその勢力が、いかにしぶといものであるかを、彼らの育て役であつた杉村自身、いまはじめて知つたのである。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその漂泊が、今もいふやうに絶對を求めて得られぬ迷ひと異なり、その漂泊のなかにこそ自由な精神を感じてゐるといふやうなものだから、しぶといところがあるんだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛　わしはわしのしぶとい性質を呪う。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのしぶとい奴等め！",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野依さんに、もつとしぶとい腹があつたらと思ひます。",
              "citation": {
                "source": "妾の会つた男の人々（野依秀一、中村弧月印象録）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の一家族や寡婦の妹と一緒に農家に避難した僕は、それから後、絶えずこのしぶとい悲しい焔に包囲されていた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の一家族や寡婦の妹と一緒に農家に避難した僕は、それから後、絶えずこのしぶとい悲しい焔に包囲されてゐた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「しぶとい子供だねえ、そんなとこに呆んやりしてないで、さっさと井戸端でお顔でも拭いていらっしゃい！",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の我慢強さが、ゆき子には自分でも性根のしぶとい女だと思はれたが、この行き暮れた気持ちを、誰に打ちあけると云ふすべもないのをよく知つてゐたからでもある。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも誰か怪しい者がこの家を狙っている証拠でもありますか」「……………」「ハッキリ返事をなさい」「ハイ……ハ……ハイ……」「あると言うのですか」「……………」「あなたは……どうしてソンナにしぶといのですか」　そういううちにマダムの背後に隠れていた白い肉付きのいい右手が前に出て来た。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、考えても考えきれぬような異様な撞着ではあるけれども、そうして、人魚に伝説の衣を着せ、美しい霧一重に隔てて眺めはじめてからというものは、どうしたことかそれまで軽い愛着を覚えていた、久米八に対する情が消え失せて、さらにしぶとい、燃えさかるようなそれを、今度は逢痴に求めるようになってしまった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、そのしぶとい相克が、地峡のいいしれぬ荒廃と寂寥の気に触れたとすれば、当然いつかは、狂気とも衝動ともなりそうな、妙に底からひたぶりに揺り上げるようなものが溜ってきた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですもの、私に絶えずつき纏っているのが、そのしぶとい影だとしたら、たとえば悪魔に渡されようたって……。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗さという暗さを幾層にも重ね合わせたように、しぶとい暁前の闇が行手を遮っているのだった。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
