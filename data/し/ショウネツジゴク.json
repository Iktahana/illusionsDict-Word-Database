        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（二〇）とんだ宿屋　雲巌寺から黒羽町までは炎天干しで、その暑い事は焦熱地獄よろしくだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年時代の僕は、それの焦熱地獄のベットの上で、終日反転悶々して苦しんだが、今ではもうそんな恐ろしい地獄もない。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してまつくらな焦熱地獄のどん底に絶望的の悶絶をつづけながら、しかも尚、新らしい救ひをもとめようとしてもがきあがいてゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高煦生きながらに焦熱地獄に堕し、高煦の諸子皆死を賜う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王範を垂れて反を敢てし、身｜幸にして志を得たりと雖も、終に域外の楡木川に死し、愛子高煦は焦熱地獄に堕つ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は天災地變に苛まれる人生の焦熱地獄に堪へられなくなつて、この假現の濁世穢土から遁れようとしたのです。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下はおそらく焦熱地獄の機関室であろうか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "市九郎が有司の下に自首しようかというのを止めて、「重ね重ねの悪業を重ねた汝じゃから、有司の手によって身を梟木に晒され、現在の報いを自ら受くるのも一法じゃが、それでは未来永劫、焦熱地獄の苦艱を受けておらねばならぬぞよ。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前を犧牲にして、生きるよりも、俺は焦熱地獄の釜の中で、千萬年煮られてゐる方が、まだよい！",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたも焦熱地獄の苦しみうけて相果てた！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十日　ああ妾の生活は、まるで焦熱地獄だ。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲哲　まつたく今日の井戸がへは焦熱地獄だ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦熱地獄のような工場の八時間は、僕のような変質者にとって、むしろ快い楽園であった。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島を仮のすみかと思えばこそ、硫黄ヶ岳に立つ煙さえ、焦熱地獄に続くもののように、ものうく思われたのだ。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそっちにも焦熱地獄が、待っていないとはどうして云えよう。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄には誰でも知っている通り、剣の山や血の池の外にも、焦熱地獄という焔の谷や極寒地獄という氷の海が、真暗な空の下に並んでいます。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙示録では、世界最後の日に悪魔に唆かされてキリストの国に反抗して立ち、結局悪魔と共に焦熱地獄で身を滅ぼす諸々の地上の国王を意味している。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でもある時のこと、どういふ罪でか、そこんとこあ、からつきし分らねえだが、一匹の悪魔めが焦熱地獄からお払ひ箱になつたちふだのう……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを復活祭の前になると、けだかい大天使たちがちやんと掛けるのさ、そして神様が一番うへの梯子段に足をおかけになるといつしよに、悪霊どもは残らず真逆さまに転げ落ちて、ひと塊まりになつて焦熱地獄へおちこんでしまふのさ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく水中へ身投げをして、魂だけは焦熱地獄へまつさかさまに落ちて行くだらうなどと、ぬけぬけと切りだしたものだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "大寒地獄に焦熱地獄。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "流るる汗は止め度もなく、喘ぐ呼吸は火焔のよう……殊に、その手に杖ついている鍬の刃先が、この数十日の砂掘り作業の如何に熱狂的に猛烈であったかを物語るべく、波形に薄く磨り減って、銀のようにギラギラと輝いている物凄さ……生きながらの焦熱地獄に堕ちた、亡者の姿とはこの事であろう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄には誰でも知つてゐる通り、剣の山や血の池の外にも、焦熱地獄といふ焔の谷や極寒地獄といふ氷の海が、真暗な空の下に並んでゐます。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉の中の火は、予等に取つては一瞥してさへ眼睛の糜爛を恐れしめ、二目とは覗かれない程に淒惨なものであるが、どの熔炉の口にも焦熱地獄の竃を焚く鬼の如き火夫が炭を投じ火を守つて、冷然と蹲居してゐるのに驚かれた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、言って、今は、まるで放心したように、目をみはり、唇を開けて、うっとりと突ッ立ってしまった相手を眺めたが、急に、ぐっと編笠に蔽われた顔を突き出して、囁くように――「その、呪文のような文には、こう書いてあるに違いない――（口惜しや、口惜しや、焦熱地獄の苦しみ、生きていがたい。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜しゅうて死ねぬ、いつまでつづくこの世の苦艱、焦熱地獄）――たしか、こんなものであろうな？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜しや、口惜しや、焦熱地獄の苦しみ、生きていがたい。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでつづくこの世の苦艱、焦熱地獄。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
