    },
    "definitions": [
      {
        "index": 1,
        "gloss": "appearance (in a film, play, TV show, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中国の名優の梅蘭芳が帝国劇場に出演しに来たとき、その肝煎りをした某富豪に向って、老妓は「費用はいくらかかっても関いませんから、一度のおりをつくって欲しい」と頼み込んで、その富豪に宥め返されたという話が、嘘か本当か、彼女の逸話の一つになっている。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこれから見に行こうとしている明治座の喜劇に出演する筈のその当人であるらしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日たった後に帝劇で映画の間奏として出演しているウィンナ舞踊団を見た。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを此の度太秦発声で「清水次郎長」に出演している一党の態度を見て僕は一入感を深くした。",
              "citation": {
                "source": "雑録",
                "author": "――前進座に就いて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）中村仲蔵死を決して出演し日下部典六一党率いて繰り出したと聞けば此村大吉たる者亦登場せざるべからず。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私は、当市で開催されていた、植民地博覧会に、東洋曲芸団の花形として出演していました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは文藝作品の――特に世界的な名篇傑作の撮影などと云へば、監督には勿論仕映えのある仕事だらうし、俳優達も進んで出演したがると云ふやうなこともあるからに違ひない。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の名優の梅蘭芳が帝国劇場に出演しに来たとき、その肝煎りをした某富豪に向って、老妓は「費用はいくらかかっても関いませんから、一度のおりをつくって欲しい」と頼み込んで、その富豪に宥め返されたという話が、嘘か本当か、彼女の逸話の一つになっている。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "在京の主なる俳優は殆ど全部出演し、わが劇界空前の名誉なりと喧伝せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女優として千歳米坡も出演す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田国五郎、西川伊三郎を始めとして、在京の人形使いはすべて出演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "土肥春曙、東儀鉄笛、水口薇陽ら出演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は京極の小屋へ明日から出演するため、今朝の汽車で東京から着くと、宿の番頭からこの店のことをきいて、早速やって来たのである。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトラクションに出演している望月三郎の名を見つけたのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころは弁士もまだ場末の小屋には、ちらほら残炎を保っていて、彼はこの附近の二つの館を掛持ちし、無声映画のちゃんばらものなどに出演していた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "演舞場では、いま春秋座の一党が出演しているのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や市設の興行館、鷺市劇場へ以前から度々出演を頼んでいたお艶という東都の歌曲の名手がありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出演の都度、休憩や食事の関係からわたくしの経営する鷺市会館へ寄って行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出演者は思いもかけぬ父の円団治でした。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、あとでその時の音楽会に出演した人にきくと、その日はどんより曇っていて、赤トンボなぞ一匹も飛んでいなかったということである。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏会の話も、レコード吹き込みの話も、そして映画出演の話も、こうして、すべて立ち消えになってしまった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "因みにその夜の出演者は左の通りである。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから本来の博多仁輪加では、その出演者同志がお互いに、人生、人情、世態に通暁徹底していなければいけない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも逸話に属する話かも知れぬが、当時の出演者はシテ方、ワキ方は勿論、囃子方といわず狂言方といわず、見物人の批評を恐るる者は一人も居なかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち明治何年であったか、京都で何かの大能が催さるるとかで、翁の状態を知らぬ旧知、金剛謹之介氏から翁に出演の勧誘状が来た。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "出演者自身の述懐によると……翁が覗いて御座るナ……と思ったトタンに囃子方は手を忘れ、地謡は文句を飛ばし、シテは膝頭がふるえ出したという。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分西洋の事と思うが、それでもその背景の感じを活かすのがその出演者の腕一つである事は云う迄もない。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした出演者の表現能力のみをもって舞台面を一パイにして行く行き方に、日本では所作事式のものが色々ある。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
