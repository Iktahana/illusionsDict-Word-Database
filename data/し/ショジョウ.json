        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　僕はそつと眼を盜んで、君の机の側にある書状を見た。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」支配人は〔二〕通の宛名を打った書状を出した。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉は短けれどその意は長し――　この書状は例によりてかの人に託すべけれど、貴嬢が手に届くは必ず数日の後なるべし、貴嬢もしかの君に示さんとならば、そは貴嬢の自由なり、われには何の関りもなし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ればみんな二通三通ずつの書状を携えている。",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケットの内なるは治子よりの昨夜の書状なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の考えでは、不幸の知らせは元来書状でほんとうの意味の知友にのみ出すべきもので、それ以外の人は葬式などがすんで後に聞き伝え、あるいは週刊旬刊でゆっくり知ってもたいしたさしつかえはないはずである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本當に奇妙な事だと思つて居ると、或日の事、ウルピノ山中とて、子ープルスの街からは餘程離れた寒村の、浮世の外の尼寺から、一通の書状が屆きました、疑もなき亞尼の手跡で、はじめて仔細が分りましたよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門は旧恩ある太政大臣忠平へ書状を発した。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」又｜右少弁源相職朝臣仰せの旨を引いて書状を送れり、詞に云はく、武蔵介経基の告状により、定めて将門を推問すべきの後符あり了んぬと。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても孤島に流されているアグリパイナと、ネロの身の上を恐ろしきものに思い、可哀そうでならぬから、と誰にとも無き言いわけを、頬あからめて呟きつつ、その二人への赦免の書状に署名を為した。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その翌々日の事であった、東京なる高山法学士から一｜通の書状が村長の許に届いた。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は一週日の猶予を請いて、とやこうと思い煩ううち、わが生涯にてもっとも悲痛を覚えさせたる二通の書状に接しぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき戸口に人の声して、ほどなく庖廚にありしエリスが母は、郵便の書状を持て来て余にわたしつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪しき便りにてはよも」彼は例の新聞社の報酬に関する書状と思いしならん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日街へ行った時、見知らぬ土人から青封筒の公式の書状を渡された。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、川中島出陣に際して、越後岩船の色部勝長に送った書状にも、「（前略）雪中御大儀たるべしと雖も、夜を以って日に継ぎ、御着陣｜待入候。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は詞なくて、卓上の書状を指し、友のこれを讀む間、これに背きて涙を拂ひつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫しありて友は我に、此書状を見たる後、既に思ひ定むる所ありやと問ひたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "流離　その頃フアビアニ公子の書状屆きしに、文中公子のわがヱネチアに留まること四月の久しきに至るを怪み、強ひてにはあらねど、我にミラノ若くはジエノワに遊ばんことを勸めたる一節あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "意外なりしは重井より心情を籠めし書状を送り来りし事なり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手短かに事の始終を告げ、授けられた一封の書状を讀上げる。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗用の書状だけでも私の代筆が出來るならばまだしものことであります。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其晩に直次から書状を以て平常の通心得られたいと云つて來た。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は一週日の猶豫を請ひて、とやかうと思ひ煩ふうち、我生涯にて尤も悲痛を覺えさせたる二通の書状に接しぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時戸口に人の聲して、程なく庖厨にありしエリスが母は、郵便の書状を持て來て余にわたしつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は例の新聞社の報酬に關する書状と思ひしならん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時戸口に人の聲して、ほどなく庖厨にありしエリスが母は、郵便の書状を持て來て余にわたしつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「晩年」の袋の中には、別に書状を二通こっそり入れて置いた。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
