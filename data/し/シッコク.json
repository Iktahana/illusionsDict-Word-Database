[
  {
    "uuid": "d545c61b-8525-5d28-a193-891ce4e4c65e",
    "entry": "漆黒",
    "reading": {
      "primary": "しっこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
