    },
    "definitions": [
      {
        "index": 1,
        "gloss": "woman who puts thick white powder on her neck",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこから私は彼女を連れて、白首女の蝟集する裏町へ行って、チョップ・ハウスのサルーンで、一夜そこの踊子たちの仲間入を彼女にさせました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの白首に藤吉は馴染が出来て、余計な金が要る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおかた大浜（白首街）のアンチキショウの処へ持って行く金じゃったろ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一卷の蠧書に眼睛を瞎卻されて、白首皓髯、猶机を離れずといふやうではならぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、淑女の面の醜なるは、芸妓、娼妓、矢場女、白首にだも如かざるなり。",
              "citation": {
                "source": "醜婦を呵す",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸妓とも白首ともつかぬ若い女を二人ほど手元に引きつけて、それもいい加減に本性を露わしかけているのだった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の縁に紅でもさしたのか、それがなるほど白首の狐の面。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草は今では活動写真館が軒を並べてイルミネーションを輝かし、地震で全滅しても忽ち復興し、十二階が崩壊しても階下に巣喰った白首は依然隠顕出没して災後の新らしい都会の最も低級な享楽を提供している。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてね、あそこはこのごろできた白首女の岡場所だが、だんなのなじみがいるんですかい」「しようのねえやつだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の事はない、浅草区内に今まで居た醜業婦をほかへやって、あとに今までよりも白首をふやした上に、こんな大券番を増設したことになる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの白首、身体こったらに小せえくせに、とても上手えがったどオ！",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺にだって嬶や子供はいるんだで」白首のことを話した漁夫が急に怒ったように云った。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社をやめて、バアーの女給さんになったり、たまには白首になったりする女工さんがあるのを。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでの彼は見習からタヽキ上げられた、女工の尻を追ったり、白首を買ったり、女の話しかしない金属工でしかなかった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "んで、白首になるッてな！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「んか、白首にか！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「蛇吉」はＨ町のある料理屋の白首を妾同様にして通っていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「のべ源」はここで酔いつぶれると、そのまま白首のいる「そば屋」へ行った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "『山海経』に「陰山に獣ありそのかたち狸の如くして白首、名づけて天狗といふ」というのであるから、我国の天狗には当嵌まらない。",
              "citation": {
                "source": "妖怪漫談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがひどく色っぽい魔窟で、百鬼横行するけれど、おおかた美しい白首なのであった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年ほど前からあるのであるが、最近、素晴しく美しい女が、チョイチョイ店へ出るというので、にわかにワッと人気が立ち、白首、地まわり、ごろん棒、おつにひねったイカ物食い、そういうこれまでの馴染以外、相当立派な侍や、大店の若旦那というような者まで、昨今は出入りをするようになった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワルゼエはよく淫売狩をも行つた男で、何でもその当時巴里で名うての白首を情婦にして、内職には盗賊を稼いでゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "九日の例年「草堂集」には、蘭軒が「偏喜青年人進学、休嗤白首自忘愚」の聯を作つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "至今猶想荒川雨　　今に至るも猶ほ想ふ荒川の雨、手械東過白首囚　　手械　東に過ぐ　白首の囚。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ孫仲益の楓橋寺を過ぎる詩を読むに、云ふ、白首重来一夢中、青山不改旧時容、烏啼月落橋辺寺、欹枕猶聞夜半鐘と。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "到る処に白首の店が、押すな押すなで軒を並べて、弦歌の声、湧くが如しだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里に美術家が集るのも、大阪に商売人が集るのも釜ヶ｜崎に乞食が集るのも、東京へ文芸が集るのも、支那に支那人が多いのも銀座にカフェが出来るのも十二階下に白首が集るのも、皆魂が魂を呼んでお互に相通じる生活をしようとする結果かと私は考える。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲水で思ひ出したが、この蝸牛庵の筋向ひの角には狐拳といふ小料理屋があつて、關東大震災のとき、いつもは顏をみせない白首態の女が客といつしよに、寢卷姿で逃げだすのを目撃して、奇異の念にうたれたと、かつて幸田文さんは私に語つた。",
              "citation": {
                "source": "露伴忌",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいてや明治四十一、二年の頃より大正三、四年の頃まで浅草十二階下、日本橋浜町蠣殻町辺に白首夥しく巣を喰ひ芸者娼妓これがために顔色なかりき。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
