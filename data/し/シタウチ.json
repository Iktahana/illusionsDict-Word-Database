    "definitions": [
      {
        "index": 1,
        "gloss": "clicking one's tongue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馬場は音たかく舌打ちして、「おい佐竹、からかうのはやめろ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああ、舌打ちの音まで馬場に似て来たようだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "要太郎は舌打ちをしたと云う風であったが此方を見て高く笑うた。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　秋山は舌打ちをした。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次嫌な奴と舌打ちした。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "違ったので舌打ちと一緒に彼方へ捨てる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェッと舌打ちしてその印籠を投げる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次チェッと舌打ちする。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝内部　主膳チエッと舌打ちする。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ほんとにお前のお蔭で餘計な人騷ぎをした‥‥‥‥‥』『それでもまあ直ぐ鎭まつて、ようございましたね‥‥‥‥』『それもさうですが、ほんとに云はんこつちやない‥‥‥』と、兄は幽かに舌打ちした。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中根だな、相變らず爲樣のない奴だ‥‥」と、私は銃身で突き上げられた左の頬を抑へながら、忌々しさに舌打ちした。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　馭者のチョッ／＼という舌打ちがして、橇は速力をゆるめた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、馭者台から舌打ちがして、馬はくるりと反対にまわってしまった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじは、また、郭進才の場合のように呉の床箆子の附近をさがしまわって、破った、虱のいる肌着が一枚丸めて放ってあるのをつまみ上げ、舌打ちをした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」健二は思わず舌打ちをした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『もう店の戸を引き寄せて置きな、』と主人は怒鳴って、舌打ちをして、『また降って来やあがった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけだから、どうにもこうにも手の着けようがなくなって……」　半七は舌打ちした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "しようがありませんねえ」と、庄太はそこの店を出て、汗をふきながら舌打ちした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりはだんだんに薄暗くなって、どこからとも無しに藪蚊のうなり声が湧き出して来たので、半七は舌打ちした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年工と少女工が、作業台に並んで、手品師の如く素早く頭付軸木を黄色の小函に詰めている「函詰」では、牛を追う舌打ちのように気ぜわしい音響が絶えず連続して起っている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　山崎は、頭から、自動車の土塵埃にまかれて、親方が弟子の失策を不満がるように舌打ちをした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "落合に水の声して、　　　　　　　　老いの屠者たゞ舌打ちぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにはげしく舌打ちて、　　長ぞまなこをそらしぬと、楽手はさびしだんまりの、　　投げの型してまぎらかす。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎょっとして、あわてて精進揚げを呑みくだし、うむ、と首肯くと、その女は、連れの職工のおいらんのほうを向いて小声で、育ちの悪い男は、ものを食べさせてみるとよくわかるんだよ、ちょっちょっと舌打ちをしながら食べるんだよ、と全くなんの表情も無く、お天気の事でも言っているみたいに澄まして言うのでございます。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂正作は武士の子、今や彼が一家は非運の底にあれど、ようするに彼は紳士の子、それが下等社会といっしょに一膳めしに舌打ち鳴らすか、と思って涙ぐんだのではない。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧のような雨がひやひやと襟頸に入るので、舌打ちして『星どころか』と微かに言ったが、荒々しく戸を閉めたと思うと間もなく家の内ひっそりとなってしまった。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもうまそうに舌打ちして飲んでござった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の黙っているのを見て、武はいまいましそうに舌打ちしましたが、『すぐ公然の女房になされ』『女房に？",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこよ、しっかりッてこの娘――口へ出したうちはまだしも、しまいには目を据えて、熟と視たと思うと、湯上りの浴衣のままで、あの高々と取った欄干を、あッという間もなく、跣足で、跣足で跨いで――お帳場でそういいましたよ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お目にかかってお話も伺いたかったのですが、悲しみが先だちまして、どうしようもございませんでしたうちに、もうこんなに早くお出かけになるそうです。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
