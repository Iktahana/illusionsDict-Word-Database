    },
    "definitions": [
      {
        "index": 1,
        "gloss": "private offering (of securities)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはもう、疲れしぼみ、悔とさびしい微笑としか持つてはをらぬけれど、それは此の世の親しみのかずかずが、縺れ合ひ、香となつて籠る壺なんだ。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ山より摘みてかへれば、紫苑はなしぼみて、すでに秋の愁ひをさそふ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幕の一部を左右に引きしぼつたやうに梓川の谿谷が口を開いてゐる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幕の一部を左右に引きしぼったように梓川の谿谷が口を開いている。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕合わせとこれが気立てのやさしい正直もので、もっとも少しぼんやりしていて、たぬきは人に化けるものだというような事を信じていたが、とにかく忠実に病人の看護もし、しかられても腹も立てず、そして時にしくじりもやった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きめが細かくて、そのくせ、しぼが、さらつとして柔かく、しんにぴんとした感じがあつた。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぼがやたらに荒くつて、もめんのやうな感じの素朴なちりめん。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぼがゑぼしの折りのやうに高く立つてゐるからゑぼしちりめんなのださうです。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぼは普通で赤地に白で松竹梅などの柄が出てゐました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の神が捧げて過ぎた机代のものの中で、平手に盛った宇流志禰の白い色、本陀理に入れたにいしぼりの高い匂いが、自分に絶望しかけて凡欲の心に還りつつある翁の眼や鼻から餓えた腸にかぐわしく染みた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャフェのテラスに並んでうそ寒く肩をしぼめながら誂えたコーヒの色は一きわきめこまかに濃く色が沈んで、唇に当るグラスの親しみも余計しみじみと感ぜられる。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、茶いろの少しぼろぼろの外套を着て、白い巾でつつんだ荷物を、二つに分けて肩に掛けた、赤髯のせなかのかがんだ人でした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　東の空のききょうの花びらはもういつかしぼんだように力なくなり、朝の白光りがあらわれはじめました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二室三室と移って行くうちに、始めの緊張した心持は孔のあいた風船玉のようにしぼみ縮んで行く。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから一列に輸入品の帽子が並べられて、その後で職業女の赤い唇がひらいたりしぼんだりした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏は灰白色に變つて、脣は紫色にしぼんでゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七味唐辛子を売り歩く男で、頭には高くとがった円錐形の帽子をかぶり、身にはまっかな唐人服をまとい、そうしてほとんど等身大の唐辛子の形をした張り抜きをひもで肩につるして小わきにかかえ、そうして「トーン、トーオン、トンガシノコ」と四拍子の簡単な旋律を少しぼやけた中空なバリトンで歌い歩くのがいた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地蔵菩薩のすがたして、　　　栗を食うぶる童と、縞の粗麻布の胸しぼり、　　　鏡欲りするその姉と。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっしろに光ってゐる白いそらに暗くゆるやかにつらなってゐた峠の頂の方が少しぼんやり見えて来ました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たいてい推量もなさるであろうが、いかに草臥れておっても申上げたような深山の孤家で、眠られるものではない、それに少し気になって、はじめの内｜私を寝かさなかった事もあるし、目は冴えて、まじまじしていたが、さすがに、疲が酷いから、心は少しぼんやりして来た、何しろ夜の白むのが待遠でならぬ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い肌で、乳房がしぼんだ茶袋を思わせて、あわれである。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄八丈、蚊がすり、藍みじん、麻の葉、鳴海しぼり。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道化の華とやらも、どうやらここでしぼんだやうだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、さもしく醜くきたなくしぼんだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文士、ひどく露骨で、下品な口をきくので、その好男子の編集者はかねがね敬遠していたのだが、きょうは自身に傘の用意が無かったので、仕方なく、文士の蛇の目傘にいれてもらい、かくは油をしぼられる結果となった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の方は、足をのせるかねの台があって、それにはすかしぼりの模様があります。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「清作は、葡萄をみんなしぼりあげ　砂糖を入れて　瓶にたくさんつめこんだ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　東の空の桔梗の花びらはもういつかしぼんだやうに力なくなり、朝の白光りがあらはれはじめました。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
