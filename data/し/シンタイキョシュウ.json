        "examples": {
          "standard": [
            {
              "text": "彼は自分の進退去就を、家族とじっくり話し合って決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政治家は国民に対して、自身の進退去就を明らかにする義務がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社の将来に関わる重要な局面で、彼の進退去就が注目された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お勢の心一ツで進退去就を決しさえすればイサクサは無い。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うから、このたびこそは討たずにはおかぬと、一刀流月輪の門下、軍之助、房之丞を、かしらに冷剣の刃ぶすま、ずらりと大広間に展開して、四方八方から一泰軒をめざし、進退去就いっせいに、ツツウと刻みあし！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
