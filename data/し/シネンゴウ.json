      {
        "index": 1,
        "gloss": "era name used by commoners (as opposed to the imperial court)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
