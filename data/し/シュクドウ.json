        "examples": {
          "standard": [
            {
              "text": "強い光を当てると、瞳孔が収縮する縮瞳反応が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "薬物の副作用として、患者に顕著な縮瞳の症状が現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "暗い場所から急に明るい屋外に出たため、激しい縮瞳が起きた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "認識された病気は、結膜炎――主症状は、発赤、腫脹、分泌、であって、それぞれ独立に治療される――炎症性角膜混濁、角膜の膿瘍、流涙症、縮瞳症、白斑症、眼瞼の斑状出血、斜視、稗粒腫、結膜浮腫、眼瞼下垂、逆さまつげ、など。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
