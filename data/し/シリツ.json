    "definitions": [
      {
        "index": 1,
        "gloss": "municipal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰かが自分を 〔Ho^tel-Dieu〕（市立病院）に入院させにやつて來て呉れようとも、自分はきつと其處で死んでしまふだらう。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どんな小さな瀕死人でもがその市立病院に一直線にはひつて行かうと思ひつめさへしたら、サガン公爵ですら、その行列を止まらさない訣には行かない。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その立派な市立病院は非常に古かつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は、ことし市立の中学へはいりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャネットの学校はベルリンの西北隅に在る市立音響体操学校と言うの。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車は二人を乗せると市立精神病院を出て、直ぐ繁華な街へ出て行った。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し死体遺棄罪として一応は検事局へ……それから、西谷は、市立精神病院の岡埜博士の御手元へもう一度……爺さん！",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「市立病院かい、それは？",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「市立じゃないけれど、公立だよ」船頭さんは答えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は市立つ日とて、秤を腰に算盤を懐にしたる人々のそこここに行きかい、糸繭の売買に声かしましく罵り叫く。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ル時代ノ社會主義者ノ市立ノ家屋ヲ考ヘシ如キハ市民ノ全部ニ居常且終生劃一ナル兵隊服ヲ着用セシムベシト云フト一般、愚論ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういえばいいのか、うさぎ屋がユニオンになるというのは、きみの通った市立小学校の校庭が、突然、ジャイアンツのホームグラウンドになる、なんて事態に似ているかもしれない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしい時代が来て、新らしい市立の精神病院が出来上ると、その頃からたださえ多くもない患者がめきめきと減って行った。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして本部を市内の警察署に移し、留守を署長に預けると、赤沢病院とは反対側の郊外にある、市立の精神病院へやって来た。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "市立高等女学校にＳという三十越した女教師があったのだ。",
              "citation": {
                "source": "段梯子の恐怖",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは市立の女学校であり、この場合の性質は、学校の経営的な原因より、むしろはっきり、戦時的認識を若い娘心に銘させようとする意味に立っているのである。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のところでは上野の帝国図書館にしろ蔵書の量と種目とでは決して満足と云えないし、日比谷の市立図書館を、東亜の大首都東京市の代表図書館であると云わなければならないことには、些か忸怩たるものがありはしないだろうか。",
              "citation": {
                "source": "実際に役立つ国民の書棚として図書館の改良",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間断なき週間制によって、五日週間を働くようになった一般勤労者は、職場職場で、生産能率増進のウダールニクを組織し、家へかえる道々には、例えばモスクワ市立銀行の屋根に、赤く翻るプラカートを見た。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクシム・ゴーリキイより三歳年下であったシャポワロフは、一八八一年の三月頃はまだペテルブルグの市立小学校へ通っていた。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで度度難儀に逢つて来た市立劇場の座主は、妬ましげに此人気を見てゐる。",
              "citation": {
                "source": "防火栓",
                "author": "DAS GROBE VERGNUGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸市立板宿小学校時代の最良の思い出は、六年生のとき、教師に代わって、理科の授業で乾電池の使い方を講義したことだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町ではたった一つしかない市立の女学校に這入りました。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから抱え出されて聖路易の市立病院の病床に寝かされても相も変らず「わんかぷ、てんせんす」をやっていたそうです。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四番が最高で、成績はよくなかったが、その代りに、初めて出来た中之島の、大阪市立図書館へ「図書館へ行かんとあかん」　の、私の一言で「真平御免」の父は「そうか」　と、許してくれた。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "西宮市立高等女学校校歌自ら春の園に入り花を作るも勇みあり。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "市立高岡高等女学校校歌我等の歌は、もろともに内の理想の叫びなり。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高岡市立高女生、これを我等の誇りとす。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "友直云、此地既に當國｜市立の濫觴にて其基本最久し。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の市立には禳災と稱し、餅を賣るもの多し。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の這入つたサナトリウムは、ある宗教家の経営してゐるもので、小さな、建つたばかりのものだつたが、すぐ近くに東京市立の施療病院と、もう一つ時々婦人雑誌に撮影されたりするカトリックの病院があつた。",
              "citation": {
                "source": "鬼神",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
