        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "食堂のテーブルに向い合った僅な時間のひまにも、この子はおぼつかないながら、ナイフとフオクとは確に自分の物として、焼きたてのパンや黄色いバタや塩っぱいオムレツの上にのぞんで、決して自分を取り乱さなかった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩っぱい味がする……重曹の味だけだ。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という塩っぱい、鼻を刺すような匂だろう。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然がかくばかり細かな用意をもって、倹約して物を使っているのに、この木の芽の塩っぱい匂は、あまりに濫費に過ぎ、あまりに一人よがりに過ぎはしないだろうか。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はふっと塩っぱい涙がこぼれて来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩っぱい涙をくくみながら、声を挙げて泣き笑いしていると、凸坊が驚いて、玩具をほおり出して一緒に泣き出してしまった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩っぱい涙を舌のさきでなめているかと思うと、もう、けろりとして、また背中の荷物をゆすぶりあげて歩く。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は青い海の照り返りを見ながら、塩っぱい涙を啜った。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エヘヘヘヘヘ……」　と冷やかし笑いをして見せたら、試験官の奴、塩っぱい面をして睨み付けたと思うと、プリプリして出て行きおった。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又、船のお医者って奴がチャチな塩っぱい野郎だったのでしょう。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "船艙も、胴の間も、塩っぱい水腫でふくれたなかで、われわれは跳びつく、しがみつく、引っ張りすぎた三縄紐のように。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "膳の上は、定まって、薄い味噌汁に古漬か、でなければ、乾らびて塩っぱい煮豆一と皿。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷くドロドロした、塩っぱい寒天みたいなものだったが、実にうまかった。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "くっつけ合った二人の頬のあいだに、涙があふれて、あたしの口に塩っぱい液体が、ドクドク流れこんでくるのよ」男「いやだなあ、その話は。",
              "citation": {
                "source": "断崖",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水はなんだかしょっぱいへんな味がしました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハンネスは、寝台のまえにひざをついて、死んだおとうさんの手にほおずりして、しょっぱい涙をとめどなくながしていました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょっぱい水に首までつかって。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくモード嬢がひどく赤面していることや、目にしょっぱい涙を浮かべていることなど、知らない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
