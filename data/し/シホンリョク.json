    "definitions": [
      {
        "index": 1,
        "gloss": "capital strength (of an enterprise)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
