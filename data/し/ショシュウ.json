    "definitions": [
      {
        "index": 1,
        "gloss": "early autumn (fall)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "初秋の薄ら冷たさも身に泌みなれた九月下旬の或日の夕方、いよ／＼それを取はづさうとして手をかけた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　今迄かつと照り渡つてゐた初秋の空に僅か飛行船程の暗雲が浮んだ。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方でまたこの分泌には一年を週期とする季節的変化があって、その最高が晩春、最低が初秋のころにあると仮定する。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一と月後には下の平野におとずれるはずの初秋がもうここまで来ているのである。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪慳な養母にさいなまれつづけて、若い美しい師匠は十八の初秋にこの世と別れを告げた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "其年も初秋の初夜過ぎて、白井氏が玉川べりの実家へ出向いた帰りだと云って、――夕立が地雨に成つて、しと／＼と降る中を、まだ寝ぬ門を訪れて、框にしつとりと置いて、帰んなすつた。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平洋戦争のかなりすすんだ、あれは初秋の頃であったか、丸山定夫君から、次のような意味のおたよりをいただいた。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十三年初秋萩原恭次郎",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋や雁やそら行く中空に、みつる光は靈のきざしよ。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路の闇を程よく残して初秋らしい店の灯の光が撒き水の上にきらきらと煌めいたり流れたりしていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡面を洗い澄ましたような初秋の太陽が昇ったのだ。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋のころ、伊豆の沼津あたりに佳い苗があるといふことを聞いて、たちまち旅装をととのへ、顔色を変へて発足した。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は三十七歳、自分は十六歳の初秋の事である。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年まえの初秋に、百円持って友人三人を誘って湯河原温泉に遊びに行き、そうして私たち四人は、それぞれ殺し合うほどの喧嘩をしたり、泣いたり、笑って仲直りしたときのことを書くつもりであったのだが、いやになった。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、伝兵衛と云う中年の男であったが、それが初秋の比、夕飯の後で北上川の網打ちに往って、彼方此方と網を入れてみたが、不思議に何も獲れなかった。",
              "citation": {
                "source": "亀の子を握ったまま",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十三年の初秋、思ひをあらたにする覚悟で、私は、かばんひとつさげて旅に出た。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　太陽が鮮に初秋の朝を燦かし始めた。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして額や頬に初秋の海風が一しきり流れると彼女は急に崩折れた。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　初秋の午前の陽が、窓から萌黄色に射し込み、鏡の前にゼラニュウムの花が赤い唇を湿らして居る夢のような部屋。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の御寺の夕づく日、ほの照り黄ばむさみしらにやがて鉦うつ一人のその夜ぞこひし、野も暮れよ、あはれ初秋、日もゆふべ、落穂ふみつつ身はまよふ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋身について来た浪の音だよ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この豊原、旧ウラジミロフカの夏はいかにも高原地の初秋らしい風の涼しさを見せている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありし事がらは、そがまうへなる禅寺の墓地にして、頃は去歳の初秋とか言へり。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　災害の来た一日はちょうど二百十日の前日で、東京では早朝からはげしい風雨を見ましたが、十時ごろになると空も青々とはれて、平和な初秋びよりになったとおもうと、午どきになって、とつぜんぐら／＼／＼とゆれ出したのです。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "月のない暗い空で、初秋の夜ふけの風がひやひやと肌にしみるので、女房は薄い着物の袖をかきあわせながら路を急いだ。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは娘たちが入院してから三日目のことで、この日も初秋らしい風が吹いて空は青々と晴れていました。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄く曇った日の午過ぎで、そこらの草の葉を吹き分ける風はもう初秋の涼しさを送っていた。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇八（明治四十一）年　一月、「初秋の歌」を「馬酔木」終刊号に発表。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　初秋の晩、私は一人だったので、玄関に鍵をかけて置いた。",
              "citation": {
                "source": "秋草の顆",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
