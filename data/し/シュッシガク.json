        "examples": {
          "standard": [
            {
              "text": "会社の規模を拡大するため、増資を行って出資額を引き上げることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "各株主の出資額に応じて、配当金の支払額が決定される仕組みだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出資額の制限があるため、個人投資家が一度に投資できる金額には限りがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また五十歳以上の者は、その出資額千円以上に達するにあらざれば、その加盟を許さずうんぬん。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾が出来たとき、「社」の連中は出資額に応じて、田地を分割した。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
