    "definitions": [
      {
        "index": 1,
        "gloss": "newspaper reporter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
