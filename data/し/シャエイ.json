  {
    "uuid": "95a8da37-4fd6-5fc2-80f4-ef3c89da6604",
    "entry": "斜影",
    "reading": {
      "primary": "しゃえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slanted or oblique shadow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陽の当る時には、いつもそれ等を通して屋内の畳へ落ちる色とりどりの斜影が美しかつた。",
              "citation": {
                "source": "「いろは」の五色ガラスについて",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先刻までは、その人々の鋭い気合だの、床を踏み鳴らす響きがしていたが、今来てみると、みな追い返したのか、寂として人影もない、また足脂に磨かれた広い板敷にも、塵ひとつ見えず、ただ何処からか映す春の陽が長閑に斜影をながしている。",
              "citation": {
                "source": "剣の四君子",
                "author": "柳生石舟斎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
