[
  {
    "uuid": "0fb05c95-7e0e-5dcc-8459-b838dccbe52c",
    "entry": "舎営",
    "reading": {
      "primary": "しゃえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "billeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五月｜朔日、前隊は出でて平野に舎営した。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "遼陽戦がわが勝利に終って、わたしが城北の大紙房という村落に舎営している時のことであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳樹屯に帰れば近衛師団は上陸して金州地方に舎営せりと聞こゆ。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "両隊は国富村｜操山の少林寺に舎営することになつた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "住吉｜新慶町辺に来ると、兼て六番、八番の両隊が舎営していたことがあるので、路傍に待ち受けて別を惜むものがある。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り戦地でも舎営をしている間は、これだけの事を廃せないのである。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "宴席の給仕がすべて督軍附の兵士であるのも私には異様の経験であり、支那の歴史で読んだ塞外舎営の光景のやうに感ぜられた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "習志野に舎営をしに行つた時、頭が痛いと云つて演習を休み、バラツクの陰に蹲つてツルゲエニエフの「貴族の家」を読んだことを覚えてゐる。",
              "citation": {
                "source": "兵営と文学",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を食ひに行かう」　飯を何処へ食ひに行くのかと訊いたら、すぐそばの村落に、夜はちやんと舎営してゐるのだとわかつた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "舎営風景　Ｓはまだ此処へ着いたばかりで、部下の宿舎をゆつくり巡視する暇がなかつたらしく、私にも見て行かぬかといふので、二人は車を待たして一緒に本部を出た。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体穏かだが、なかには油断のならん奴がゐるよ」「ある砲兵隊が舎営してゐる部落で、敗残兵だか匪賊だかの襲撃を受けたところがあるつてね。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "舎営の門口のきらめく歩哨の銃剣、将校｜馬蹄の響き、下士をしかりいる士官、あきれ顔にたたずむ清人、縦横に行き違う軍属、それらの間を縫うて行けば、軍夫五六人、焚火にあたりつ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三蓋ヲ煙草盆トシテ煙管ポンポンナドノ便アリ、第四舎営ノ夜半ニ筆ヲ揮フトキ蝋燭立トスベシ、第五ハ即チ枕ノ代理而シテ彼ノぴすとるニ至ツテハ、幸ニ吾常勝軍ニ従フニ依ツテ徒ニ行李ノ重量ヲ増スノミ、更ニ一分ノ用ヲモナサズ。",
              "citation": {
                "source": "小杉放庵",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸地測量部の五万分一図にも記載があり、ことに今日は師団の演習舎営地として知られている。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーテルローの戦いの後、読者は思い起こすであろうが、ポンメルシーはオーアンの凹路から引き出され、首尾よく味方の軍隊に合することができ、野戦病院から野戦病院へ運び回され、ついにロアールの舎営地に落ち着いたのである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
