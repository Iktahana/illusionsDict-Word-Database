        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「俺知らんけど……ね、行かうよ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに遣るわいな」「遣る、遣るて、おまはんはなんぼ口が商売か知らんけど、日の丸湯の鑵といっしょで湯（言う）ばっかしや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "気に入るかどないか知らんけど、結婚いうもんは本人同志が決めるもんと違う。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく此方は教育を受けた年限も長いんやから、心臟が強い云はれるかも知らんけど、なんぼでもよいからＴさんより上にして下さい言うたんですよ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気に入るかどないか知らんけど、結婚いうもんは本人が決めるもんと違う。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はちょっと考えて、「ええ度胸かなんか知らんけど、生意気な真似しやがると、承知せえへんぞ！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕は知らんけど……。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年さきのことやらうち知らんけど、恐いことがうちを待つてをるのやわ、きつと。",
              "citation": {
                "source": "鬼神",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "変化いうたら大袈裟か知らんけど、なんということもなく、うちの好みが変ってしまうのんです。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……恁那事おまはんの前で云ふと怒るかも知らんけど……まア栄一様此処より二階へでも行かんで、今日は皆学校へなり外へなり出て留守ぢやからない、まア二階へでもお出でなはれ……』『エ、有難う』と黙つて急な小さい段梯子を上つて叔母について行く。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしや、ようは知らんけど……」　素子は、いちいちうなづいて、それを聴いてゐた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの事は知らんけど、この僕のカンには間違いは絶対に無い！",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好　よくも知らんけど、二三度会った事はある。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豊　でも、壮六さんは、あんなふうにあんたのこと心配して――金吾　壮六はなんと言ったか知らんけど、あやつは一人がってんの野郎でなし、俺にゃ女房もつ気は無えです。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "変化いうたら、大袈裟か知らんけど、なんちうこともなく、うちの好みが変ってしまうのンです。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやれ、私は昨日も一昨日も来たのに、絵を描きに写生に行ってるとかって、たんびに無駄足ばかりさせられて、ホントにまあ、絵だか屁だか知らんけど、しとを茶にするのもいいかげんにして下さいよ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――あの人、姉ちゃんどう思てるか知らんけど、いつやあんなりになってしもてて、何や気持が済まんよって、是非姉ちゃんに会わしてほしいいうてんねん。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "…」そないいうてやりなさったら、ぎょッとした顔して、「手妻の種て何のこっちゃ」いいますのんで、「何のこっちゃ知らんけど、何もあれから絶交したともいエへんのんに、あんた独りで絶交したもんと極めてるいうのんけったいやないか。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたは疑ごうてるか知らんけど、あてかてあんたのイヤがるようなこと決して姉ちゃんにいエへんし。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そしたらあない空々しいしてて、蔭でそうッと手エ握ろいうことあの時から考えてたのんか知らんで」「そらどや知らんけど、あてがあの人｜放ったらかして姉ちゃんと逃げるのんやないかいうで、常時心配しててんし。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのお婆ちゃん、いくつか知らんけど、ちょっとも歳を取らんようやないか」貞之助は、あの、鹿のような軽快な歩調でチョコチョコと歩いて行く、特に後姿の若く見える「お婆ちゃん」の影を見送りながら云った。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしも聞いたことで、ようは知らんけどな、高門の武十旦那の話によると、こうじゃ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちこがれた夫を見たうれしさや、腹立たしさや、悲しさやがこんぐらがって、（ふン、今時分まで、どこをほっつき歩いとったか知らんけど、いきなり、飛びこんで来て、間男呼ばわりするなんて、勝手のええにもほどがあるわ）　心のうちで、そんな天の邪鬼な意地を出していた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に非ずかなんか知らんけど、若松じゃあ、民政党に入らんことには、商売ひとつ、満足に出来やせん。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そいで戦争すんで戻って来たら、世の中あ、このありさま、正直者がバカを見るんだか何だかしらんけど……そこへ病気になったりしてよ。",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみにも不満はあるかしらんけど、こっちゃにも云いたいことはあるねんけど、わいはよう云わんとくさかい、きみもおとなしく引取っとくなはれ」「おかしいですね、それはどういう意味ですか」　おれとすればかなり馘にはなりたくない気持だった。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
