[
  {
    "uuid": "ebc888a8-5871-5ff2-90de-0096c705964c",
    "entry": "沈める",
    "reading": {
      "primary": "しずめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
