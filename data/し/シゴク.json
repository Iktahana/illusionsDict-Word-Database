[
  {
    "uuid": "179a878e-3a09-582b-8746-04fb890dedb5",
    "entry": "扱く",
    "reading": {
      "primary": "しごく",
      "alternatives": [
        "シゴく"
      ],
      "is_heteronym": false
    },
    "grammar": {
