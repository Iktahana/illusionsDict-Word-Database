  {
    "uuid": "d3bab76a-57b6-556f-b316-a14326e68dad",
    "entry": "集金",
    "reading": {
      "primary": "しゅうきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
