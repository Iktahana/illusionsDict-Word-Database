    "definitions": [
      {
        "index": 1,
        "gloss": "making frequent appearances",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
