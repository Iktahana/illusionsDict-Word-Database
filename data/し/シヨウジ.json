          "literary": [
            {
              "text": "それは是から使用時期になるので、精力をつけるためであつた。",
              "citation": {
                "source": "籠の小鳥",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで学校はＤＥＣのＰＤＰ―10を持っていたゼネラルエレクトリックと交渉し、使用時間に応じて料金を支払う契約を結んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の秋、コンピューターの使用時間を切り売りするビジネスを目指してシアトルに設立されたＣＣＣ社はポール・アレンとビル・ゲイツのコンピューター熱をいっそうあおり、彼らに技を磨く絶好の機会を提供することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲイツとアレンはその後、企業の給与計算ソフトウエアを書き、学校からはクラスの編成プログラムを頼まれて、コンピューターの使用時間とアルバイト料をせしめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学に籍を置いたというよりもむしろ、ＣＤＣ社の６４００の収まっていたコンピューター室に所属した形のウォズニアックは、書き上げたプログラムをつぎつぎとマシンに流し込んで使用時間を稼ぎはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "常にコンピューター室にたむろしては、使用時間に対応したレンタル業者の請求額をうなぎ登りに増加させるウォズニアックは、すぐに学校側に目を付けられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "退学をちらつかせてコンピューターの使用時間を制限しようとする大学側に対し、ウォズニアックは弁護士を雇って対抗したが、結局一年ほどでコロラド大学を去った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学時代、プログラミングに熱中してコンピューターの使用時間を稼いでいるあいだも、常に彼の念頭にあったのは「どうすればプログラムを短くできるか」に対する挑戦意識だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が費やしたコンピューターの使用時間は、金額にして四万ドル以上になります。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心の健康及び使用時間の許さぬうちにあつて、この両者を能くし得たりとは決して思はず。",
              "citation": {
                "source": "『文学論』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "また石器時代から金屬使用時代にはひる中間時代を、金石併用期と名づける學者もありますが、かようにわけて行けば限りなくわけられますけれども、それらの細かいことは改めてお話しする時がありませう。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一手指すたびに、記録係が指手と使用時間を書いた紙片を屏風の隙間から出しておく。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女と男の便所使用時間をきめるかどうか。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方は一度消しても後から後からと霧が流れて来るので、使用時間中ずっと石油を燃し続ける必要がある。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、早仕舞にしようじゃないか」　秋山と云う、ライナーのハンドルを握ってるのが、小林に云った。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう五尺は入っただろう」「そうさなあ、入ったかも知れねえな」「早仕舞にしようじゃないか」「いいなあ、ハムマーの連中にそう云おうかなあ」「だが、ダイの仕度は出来てるかい？",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かまた昔話でもしようじゃあありませんか」と、老人は食い荒しの皿小鉢を老婢に片付けさせながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことにしようじゃないか。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主同士だから仲よくしようじゃないか」「おれが貴様みたような奴と、手も足もないヌッペラボーと仲よくするものか。",
              "citation": {
                "source": "章魚の足",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが先生僕と比較すると初から利口であったねエ、二月ばかりも辛棒していたろうか、或日こんな馬鹿気たことは断然｜止うという動議を提出した、その議論は何も自からこんな思をして隠者になる必要はない自然と戦うよりか寧ろ世間と格闘しようじゃアないか、馬鈴薯よりか牛肉の方が滋養分が多いというんだ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが先生僕と比較すると初から利口であったねエ、二月ばかりも辛棒していたろうか、或日こんな馬鹿気たことは断然止うという動議を提出した、その議論は何も自からこんな思をして隠者になる必要はない自然と戦うよりか寧ろ世間と格闘しようじゃアないか、馬鈴薯よりか牛肉の方が滋養分が多いというんだ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と客に言って大あくびを一ツして「とにかく呼ぶとしようじゃアないか。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし」とまた時計をのぞいて、少し考えて「あすの朝早くしようじゃアないか。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして戸部とともちゃんとの未来を祝福しようじゃないか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは俺たち四人は戸部とともちゃんとに最後の告別をしようじゃないか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、どこかちょっと人目に着かない処で道寄をしようじゃあないか、そしていろいろ相談をするとしよう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番何でもそういったものを、どしどし私たちが頂戴をすることにしようじゃないか。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かおもしろいことをしようじゃありませんか」ホモイが、　「どんなこと？",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう夜になっては探せないから、今日はどこかに野宿して、明朝早く探すことにしようじゃないか。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜杯やりながら何かの相談をしようじゃあねえか」　今は堅気になっていても押上の甚右衛門、ここらでは相当に顔の売れている男である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
