        "examples": {
          "standard": [
            {
              "text": "11月に狩猟期が解禁されると、山には多くのハンターが訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "禁猟区以外の場所でも、狩猟期以外に動物を撃つことは厳禁だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今年の狩猟期は雪が多く、獲物を見つけるのが非常に難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その大塚は至って殺生好きで、狩猟期になると何時も銃を肩にして出かけて往った。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある程度鳥獣のいる他の場所では、狩猟期になると猟の部隊がやって来、獲物の有るに従って各地に天幕を張って止り、従って文字通りそこで産する生活資料の量に比例して人が住むことになるのである６）。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
