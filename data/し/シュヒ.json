  {
    "uuid": "4375f4f4-dc41-50c6-8e9d-74bd57d7ba5f",
    "entry": "守秘",
    "reading": {
      "primary": "しゅひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
