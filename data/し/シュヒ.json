        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "keeping a secret",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ＩＢＭ側はまず、「話し合いの中で明らかにされた内容は外部に漏らさない」とする守秘義務合意書へのサインを求めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月に入ってからの二度目の訪問時に守秘義務合意書にサインをすませると、謎が明かされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この見方によってのみ我々は、『中関白記』に清少納言は「肥後守秘蔵娘也、皇后愛憐之間、予密召之、雖然大酒不女所為、申宮方与暇」［肥後の守秘蔵の娘なり、皇后愛憐の間、予密かに之を召す。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはお医者さんで、守秘義務がありますからね。",
              "citation": {
                "source": "親友たち",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
