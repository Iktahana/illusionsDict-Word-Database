    "definitions": [
      {
        "index": 1,
        "gloss": "neglecting the duties of an office while taking pay",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
