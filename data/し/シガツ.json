            {
              "text": "（完）（「新著月刊」第一号　明治30年４月）",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "徑が曲りくねつて居るから見た所が窮屈でごちや／＼して居るので一向に興が薄ひ樣な心持がする、再び本道へ出ると桃の枝に中山こんにやくをぶらさげ自轉車へ乘つて來る人に逢つた明治36年４月７日『日本』署名　　クモ生投",
              "citation": {
                "source": "市川の桃花",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『江戸と東京』38年４月号）",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『新小説』24年４月号／『岡本綺堂読物選集・４』青蛙房、69・５）",
              "citation": {
                "source": "父の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和２年４月「新潮」）",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『文藝倶楽部』02年４月号）＊〈日本妖怪実譚〉（記者）より。",
              "citation": {
                "source": "池袋の怪",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『文藝倶楽部』02年４月号）＊不通庵〈妖怪談〉より。",
              "citation": {
                "source": "お住の霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正15年４月「改造」）",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九二八・三―）（全詩人聯合創刊号　昭和３年４月発行）",
              "citation": {
                "source": "早春雑記",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治26年３月〜４月「東京朝日新聞」）",
              "citation": {
                "source": "隅田の春",
                "author": "饗庭篁村",
                "note": "青空文庫"
              }
            },
            {
              "text": "1795年４月に、ここで全員に（＊人痘）接種が行われ、メレットは家族と一緒に接種された。",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            },
            {
              "text": "（参照：第３図）第※例　４月５日。",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            },
            {
              "text": "(参照：第４図）第※例　この少女（※）の腕から試料を採取して４月12日に次の子供たちの腕に接種した。",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈『北海道新聞』昭和36年４月９日朝刊〉",
              "citation": {
                "source": "おば金成マツのこと",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "（談）〈『北海タイムス』昭和36年４月８日朝刊〉",
              "citation": {
                "source": "金成マツとユーカラ",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "（談）〈『北海タイムス』昭和30年４月10日〉",
              "citation": {
                "source": "図書館通い",
                "author": "――私の中学時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホッキまきは例年８月15日に始まって翌年の４月15日に終ることになっている。",
              "citation": {
                "source": "ホッキ巻",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、（ミュージカル版から考えれば２００９年４月からなので）長かった翻訳もいったん一区切りです。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "２月に婚約したが４月には口もきかなくなった。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば1885年４月１日に市立病院であるモントリオール病院で１人の天然痘死亡者が出て、罹っていない患者は家に帰った。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "590年の４月25日に既にローマの医学についての守護聖人であった聖コスマス・聖ダミアンの教会から、聖グレゴリウス１世に導かれてペストにたいする７重の嘆願を歌いながらの行列があった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の講義は1616年４月までは始まらなかった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドのある１つの部分で1908年の最後の４月に全人口の４分の１がこの病気で苦しみ、40万人の死亡者があったが殆ど全部はマラリアによるものであった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「改造」昭和22年４月１日）",
              "citation": {
                "source": "大阪の反逆",
                "author": "――織田作之助の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「東京朝日新聞」昭和８年４月21日朝刊）",
              "citation": {
                "source": "丸之内点景",
                "author": "‥‥東京の盛り場を巡る‥‥",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「話」昭和12年４月号）",
              "citation": {
                "source": "車中も亦愉し",
                "author": "小津安二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「幸福な奧樣がた」４月５日號、齋藤由起さん）それは「私はいま一人です。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今から４月初旬までです。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸せな世なら、この花は単なる４月のお供え花になるところです。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また他の者たちは、西洋詩の生硬な直訳を思はせるやうな、息苦しい悪い趣味の詩を発表して新らしがつて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            }
          ]
        }
