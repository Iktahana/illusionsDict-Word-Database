    "definitions": [
      {
        "index": 1,
        "gloss": "family of Shinto priests serving a shrine on a hereditary basis",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かくて社家の方、樹立に入る。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでにいう、奥州の和淵神社は大晦日に鰹と鮭の子を塩して供え、正月十八日に氏子が社家に集り鰹と鮮魚を下げて食い、二十八日に鮭の子を卸して食う。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "本多家の祖先｜某はもと加茂の社家であつたが、豊後の本多荘に流されたので、本多を名乗るやうになつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "加茂の社家だつただけに本多家では二葉葵を紋所に使つてゐると、それを清康が見て、「いゝ紋ぢや、俺の家で使ふ事にしよう。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百八　関藤藤陰は備中国吉浜の社家関藤左京政信の第四子で、六歳の時医師石川順介直経に養はれ、石川氏を冒した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "天滿宮には別當、六坊、社家の外に、八十人の御家人と、六十人の長谷川組といふものとが、近郷近在に散らばつてゐた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "道臣等の親子三人が支度を調へ、留守を昔の社家の長老に頼んで東の門まで出かけた時、お時の裾端折つて緋縮緬の湯もじを精一杯見せた旅姿は、左の方のだら／＼坂の半腹に見えた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は社家、葛城藤馬の長女で稲代というのであった。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして漸く奈良の杉と雑木の濃緑の一色で塗りつめられたる単調の下に、銀色のすすきが日に日に高く高畑の社家町の跡を埋めて行く。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩尻の社家北条主計、この人の屋敷へ貝十郎一行が、滞在してから五日経った。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "社家家宝の雪舟筆の、豪宕の唐風景を描いた屏風が、二人を囲って立っていたが、墨色さえ寒く感じられた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「社家北条｜主計の屋敷に！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはこの時より半月ほど以前に、塩尻の社家を引き払い、この小諸の牧野家の居城へ、田沼主殿頭に扈従して参り、今に滞在しているのであった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩尻の社家｜主計の屋敷で、一旦勘助を捕えたが、大して憎くない男だったので、覚蔵の家の内｜土蔵の中へ、冬次郎様と熊太郎とを、翻弄的に閉じこめておいて、主計方へ帰って来た貝十郎は、その夜勘助を追い払った。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その倅は三輪大明神の社家、植田丹後守の屋敷に預けられていたお豊に命がけで懸想した男であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、翌日より大工頭、下奉行等｜社家一同の先達にて、御本社、拝殿、玉垣を始め、仮殿、御旅所にいたるまで残らず見分。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかで今日以後、山門の喜びは一門の喜び、社家の憤りは一門の憤りとなさん。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "世俗的な叔父の立場にしたがえば、もちろん、反対しなければならないところだが、日本自体が無くなりかけているというのに、社家も神道もあるものではない。",
              "citation": {
                "source": "春雪",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "山城の賀茂は社家でいながら、賀茂村から比叡山の水呑に達する広大な領地をもって居り、一族の女たちは国学と古文に凝りかたまって、みな独身で終ってしまう。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この社家くずれの女には、これでもう二度も欺された。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、此處ですよ」　植木屋の多い西根岸、御隱殿に近く百姓地を前に控へて、まことに閑靜ですが、社家とも寺とも、寮ともつかぬ門構へ、百壽園と船板の看板、洒落たやうな、氣障なやうな、異樣な構への家に、八五郎は案内したのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の祕薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の本でも、明治になってから、伊勢の旧家の神官の家のものや、京都の社家の蔵書など、ここに収められたものがあった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十二年の暮日本で亡くなったが、京都の賀茂の社家町の家は、財団法人にして保存してある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九二七年）付記　この理念はある程度実現されて、京都市上加茂町の古い社家の建物を一軒借りて、青田五良（織物）および鈴木実（染織）青田七良（金工）黒田辰秋（木工）が同居して、仕事にいそしんだ。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これを公に印刷に付したのは本書が初めてである）そうして京都上加茂の社家の家を一軒借りて仕事を始めた。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            },
            {
              "text": "幣下と唱る社家も諸方にあまたある大社也。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十二年、その家をこわして、こちらに移したわけですが、この家ができるまでの間、つまりその年の七月から五カ月間あまり、下鴨の社家町で過ごしました。",
              "citation": {
                "source": "鴨川を愛して",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "加うるに天平四年から六年にかけては諸国が飢饉に襲われ、百姓の労苦甚しく、その上地震も屡々起きて寺社家屋の倒壊したことが続紀にみられる。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから程遠からぬ三輪の町に植田丹後守という社家がある――武術を好んでことのほか旅の人を愛する、そこへ行ってごらんなさいと、長谷の町の町はずれで、井戸の水を無心しながら、このあたりに武術家はないかと、それとなく竜之助が尋ねた時に煙草を刻んでいた百姓が教えてくれた。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜之助は、ともかくもその植田丹後守なる三輪大明神の社家を訪ねてみる気になって、ここまでやって来たものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
