          "standard": [],
          "literary": [
            {
              "text": "誰が来たって、どいつが来たって、坊を渡すこっちゃねえからな」　彼は、子供を確り抱きしめた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫は未だ確りしていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の確りしたところで、いつも気を引立てられている勝気にも性の弱い弟は、この秘密で冒険な行旅を、姉の敢行力の庇に在って、共々、行い味われたので、一も二もなく賛成した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お沢　はい――はい……媛神　まだ形代を確り持っておいでだね。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……目を確り瞑れや。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か一筋、心のしんになる確りした考え。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄でいながら確りした肉付の背中を持っていて、稍々左肩を聳やかし、細そりした頸から顔をうつ向き加減に前へ少し乗り出させながら、とっとと歩いて行く。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最後の病床で、堺屋の妻は、木下の小さい体を確り抱き締めて、「この子供はどうしてもあたしの子」とぜいぜいいって叫んだ。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱の盤　姥殿、確り。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と膝で確りと手を取って、「じゃ、あの、この炬燵の上へ盆を乗せて、お銚子をつけて、お前さん、あい、お酌って、それから私も飲んで。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、然うやつて何時の間にやら現とも無しに、恁う、其の不思議な、結構な薫のする暖い花の中へ、柔かに包まれて、足、腰、手、肩、頸から次第に、天窓まで一｜面に被つたから吃驚、石に尻持を搗いて、足を水の中に投出したから落ちたと思ふ途端に、女の手が脊後から肩越に胸をおさへたので確りつかまつた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この確りした男は役者である。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその能の最後の責任は常に監督の双肩に在るので、監督が確りしていないと主演者は安心して舞えない。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形使　それ、確りさっせえ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「確に、」「ええ、確りだ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、私の声と同時に、給仕でも飛んで出て来るように、二人の男が飛んで出て来て私の両手を確りと掴んだ。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も頼むから確りやつて呉れよ。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は悩む者のするやうに両手で確り頭を圧えた。",
              "citation": {
                "source": "爪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本当のところを確りと詳しく理解することが学問である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代の大勢とは相容れ難くも有っただろうが、確りとした、そして整った、博大な、空疎でない、文明的で人道的な世界の成立を目的とした、「物事」に伴い「実際」を遺れない立派なものであったと考えられる。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに彼が、人間にも似た確りとした理智の眼をもつて居り、同時に彼が、友人とはげしい争闘をするときは、嵐のやうな激情の、凄まじい男性味をもつてゐる。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、一層空々しい気がしてならなかつたが、確りと堪へなければならないものを感じてゐたので――酒でも飲まなければ、反つて病気になつてしまふ――と憎態な調子で口に浮びかゝつた言葉を慌てゝ飲み下した。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "周一は片眼を確りと閉ぢた。",
              "citation": {
                "source": "周一と空気銃とハーモニカ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと確りしなくちやあ。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい」と蛸の肩を突衝いて、よろけるのをまたぐいと引き寄せて「君の眼はどだい節穴だよ」「そうかい」「ちと確りしろ。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも渡す事は出来ないといって、確り掴んでいるようです。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、確りしろ」　と世話役は叫んで、倒れたまゝ愈起きまじとする重右衛門を殆ど五人掛りにて辛くも抱上げ、猶ぐづ／＼に埋窟を云ひ懸くるにも頓着せずに、Ｘの字にその大広間をよろめきながら、遂に戸外へと伴れ出した。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながら彼の腕を確りとおさへて離さなかつた。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことあるものですかね、あなたさへ確りしてゐれば、安心なものさ。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしのからだを、しっかり抱いてもらいたかった。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
