        "examples": {
          "standard": [
            {
              "text": "彼女は長年、主婦業を完璧にこなしてきたが、最近再就職を考え始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「主婦業って、休みがないから意外と重労働なのよね」と彼女はこぼした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "主婦業の傍ら、独学で行政書士の資格を取得したというから驚きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "初子は退職して、いったんは姫路で主婦業におさまった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから一生懸命あなたの生活を快適にしてあげますし、主婦業を勉強します。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
