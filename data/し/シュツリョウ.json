          "literary": [
            {
              "text": "時々出猟する彼らの或る者の姿さえ見かけることがあるともいう話であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通に『前漢書』列伝李広善く射る、出猟し草中の石を見て虎と思い射て石に中て矢をい没む、見れば石なり。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに鳥獣は、国主の出猟であるがために、忠直卿の矢面に好んで飛び出すものはなかった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
