    "definitions": [
      {
        "index": 1,
        "gloss": "white vegetables or fish simmered without soy sauce",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お庄は蓮の白煮を拵えるつもりで皮を剥きはじめた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮根が大層白くって綺麗ですね」妻君「それは蓮根の白煮といってお米を磨いだ白水で湯煮るのです。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "看痾宮沢賢治七月はさやに来れど故しらに人はなほ疾み日過ぎ来し白雲の野はさびしくも掃き浄めらる",
              "citation": {
                "source": "看痾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなくちゃ」呟きながら眼がしらにちょっと袖口を当てた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おわあ、こんばんは』『おわあ、こんばんは』『おぎやあ、おぎやあ、おぎやあ』『おわああ、ここの家の主人は病気です』貝つめたきもの生れ、その歯はみづにながれ、その手はみづにながれ、潮さし行方もしらにながるるものを、浅瀬をふみてわが呼ばへば、貝は遠音にこたふ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるえる手先が障子にかかると、出会いがしらに一人の女がはいって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "野を野のかぎり旱割れ田の、　　白き空穂のなかにして、術をもしらに家長たち、　　　　むなしく風をみまもりぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉の居を卜せしは即ちこの川の北岸にして、満潮の潮がしらに川角へさし来る水の勢に乗つて照り渡れる月に句を按じ、あるいは五本松あたり、一川の上下に同じ観月の友を思へるなど、皆こゝに居たるよりの風雅のすさびなりけんと想はる。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子は、将来きっと百千の人のかしらに立つ人ゆえ、かならず無礼あってはならぬと、わが子ながらも尊敬、つつしみ、つつしみ、奉仕した。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからちょうど前を通って行く一本のでんしんばしらに、「こらこら、なぜわき見をするか。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけどあたしらには前のやうに赤く見えないわ。",
              "citation": {
                "source": "まなづるとダァリヤ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時一人で行っていた時、庭のほうで子供の声がするのでガラス越しに見ると十三歳ぐらいをかしらに四五人の女の子が来て竹切れで雑草の中をつついている。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、突然Ｉが袂の中のハンケチを取り出す間もおそしと眼がしらに持つて行つた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川柳に、（歌一つあつて話にけつまづき）と云ふのがあると、何時かも笑つて居りました、成程其の通りと感心しましたのが、今度は身の上で、歌があつて蹴躓きまして、部屋がしらに笑はれますのが、手前口惜しいと存じまして、へい。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川柳に、歌一つあつて話にけつまづき、と云ふのがあると何時かも笑つて居りましたが、成程其の通りと感心しましたのが、今度は身の上で、歌があつて躓きまして、部屋がしらに笑はれますのが、手前口惜しいと存じまして。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど門のはしらには、小医リンパー先生と、金看板がかけてある。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昇降口のほとり、出逢ひがしらに、下方から昇つて來たのは、夫人と少年とであつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まひるの草木と石土を　照らさんことを怠りし　赤きひかりは集い来てなすすべしらに漂えよ。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では第二服　まひるの草木と石土を　照らさんことを怠りし　黄なるひかりは集い来てなすすべしらに漂えよ」　空気へうすい蜜のような色がちらちら波になりました。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからちやうど前を通つて行く一本のでんしんばしらに、「こらこら、なぜわき見をするか。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滿潮の時は、さつと潮してくる浪がしらに、虎斑の海月が乘つて、あしの葉の上を泳いだほどの水場だつたが、三年あまり一度もよしきりを聞いた事……無論見た事もない。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶わんがあるならかしらにも持って来てあげましたのに。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔牛はお腹がすいて来たのか、からだをかしらにすりよせました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは早速その一升を飲みはじめ、彼の大柄でおとなしそうな細君にも紹介せられ、また十三の男の子をかしらに、三人の子供も見せてもらった。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛の弾が膝がしらに当って、よほどの怪我をしたのにきまっている。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおよそは何かしらに拠って、手製の万八を無遠慮に加えず、斯様も有ったろうというだけを評釈的に述べて、夜涼の縁側に団扇を揮って放談するという格で語ろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ささやかな思い出に一滴の涙が眼がしらに浮ぶときにも、彼はここぞと鏡の前に飛んでゆき、自らの悲歎に暮れたる侘しき姿を、ほれぼれと眺めた。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、やけに突立つ膝がしらに、麦こがしの椀を炉の中へ突込んで、ぱっと立つ白い粉に、クシンと咽せたは可笑いが、手向の水の涸れたようで、見る目には、ものあわれ。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "畝路で出合がしらに、一同は騒ぎ立てた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ出合いがしらに来合わせた誰かと、玄関の扉を開けた処で話し声をぼそぼそ立てて居た。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
