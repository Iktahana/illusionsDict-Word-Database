[
  {
    "uuid": "03ae243f-13df-5321-80c8-8947a96a4b68",
    "entry": "頻りと",
    "reading": {
      "primary": "しきりと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
