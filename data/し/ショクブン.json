[
  {
    "uuid": "588bc7de-be01-540e-8ab8-22c194bcd5dd",
    "entry": "職分",
    "reading": {
      "primary": "しょくぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's duty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "狭い職分や交際範囲の中に同じような空気を呼吸して来た若い男女が、どのみち一組になりそうなことは池の中の魚のように本能的に感じられるものである。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ分相応にその道に精進すべきは人間の職分として当然のことであるとだけは言った。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に自分の職務さえ、辛うじて務めたほどのものが、何の余裕があって、敵情を探るなんて、探偵や、斥候の職分が兼ねられます。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "志一や高天は言うに足らない、山伏や坊さんは職分的であるから興味もない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその職分を忠実に勤めただけか。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がこうやッて村立尋常小学校の校長それも最初はただの教員から初めて十何年という長い間、汲々乎として勤めお互いの朋輩にはもう大尉になッた奴もいれば法学士で判事になった奴もいるのを知らん顔でうらやましいとも思わず平気で自分の職分を守っている。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして利休は、これを口に唱えるばかりではなく、職分の上に実行してもいました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の職分としての責任であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に知られず、効果を考えず、深く自分の職分を考えて、その準備を深めて行く。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "利休の茶道の歌に、寒熱の地獄を潜る茶柄杓も　　心なければ苦しくもなし　これ利休が職分の深いたしなみから、人生の悟道（さとり）に入った証拠であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁護を引き受ける以上は、その者の罪を軽くするように尽力するのが弁護士の職分だ」　甲者はますます不平に堪えざりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は弁者を睨して、「職分だって、あなた、出刃打ちなんぞの肩を持つてえことがあるもんですか。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、仮い野心が無いにしても、人間に対して屡々危害を加える山に関係があるらしく思われるのであるから、警官の職分として、唯見逃しては置かれぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "車窓の眺めは例によつて例の如しであるから退屈の餘りの時間を雜談に消すほかはなかつたが、安成子は職分に忠實なので、しきりに八景論を提出して老人の談話を引出さうとつとめる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠等が天命の職分たるや、花の如く、雪の如く、唯、美、これを以て吾人男性に対すべきのみ。",
              "citation": {
                "source": "醜婦を呵す",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に自分の職務さへ、辛うじて務めたほどのものが、何の余裕があつて、敵情を探るなんて、探偵や、斥候の職分が兼ねられます。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "材能伎芸を以て奉承するは男芸者の職分である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどわが近眼はただおのれが尽したる職分をのみ見き。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七）　記載報告といふ事は文芸の職分の全部でない事は、植物の採集分類が植物学の全部でないと同じである。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "記載報告ということは文芸の職分の全部でないことは、植物の採集分類が植物学の全部でないと同じである。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "事、水産に関する限り、知らんという事は只の一つも無いのが職分だぞ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新後、西洋崇拝の弊風が天下を吹きめぐって我国固有の美風良俗が地を払って行く中に毅然として能楽の師家たる職分を守り、生涯を貫いて倦まず。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家元制度　能は日本の封建時代から生れて来たものであるから、能を職分とする者が世襲制度を執るのは自然の傾向かも知れぬ。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが能楽師たる者の最高の職分である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが家元の職分の初め終りである。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどわれ若し憚ることなくして、人々よ、我も一々の美を見ざるにあらねど、我を動かすものは彼に在らずしてその全體の美に在り、是れ我職分なりと曰はゞ、人々は必ず陽に、げに／＼我等の教ふるところは汝詩人の目の視るところより低かるべしと曰ひつゝ、陰に我愚を笑ふなるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視総監はドユパンに屈伏しながら、心中不平に堪へないので、人間は職分外の事に手を出すのは好くないなどとつぶやいてゐた。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は固より定役なき身の仮令終日｜書を伴とすればとて、敢えて拒む者はあらざるも、せめては、婦女の職分をも尽して、世間の誤謬を解かん者と、進んで定役ある女囚と伍し、毎日定役とせる物を仕上げてさて二時間位は罷役より前にわが監房に帰り、読書をなすを例とせり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
