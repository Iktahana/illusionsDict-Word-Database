        "動詞-一段"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to cause someone to worry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "決して御心配をかけるような事はありません。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしく心配をかける奴ばかりである。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「いや、貴女だけに、心配をかける訳には行かないし、それに、毎日二百円はかかりますよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配をかけるのは、新さんあなたが、悪いんですよ。",
              "citation": {
                "source": "誓之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、いずれにしても、この際お父さんや阿母さんに余計な心配をかけるのは好くありませんから、私も努めて打ち消すように注意しますよ。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "よけいな事をして年寄りには心配をかける。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥ずかしいことをいいたてて、どうじゃ、どうじゃと責めたてますゆえ、思案にあまり、きょうの晩までご返事お待ちくだされませと、その場をのがれて、ただ恐ろしい一心から、かく宿下がりをいたしましたが、幸助さまにご相談したとてもご心配をかけるばかり。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、もうこの上あなたにご心配をかける必要はないと思います」　こうは言ったものの、わたしの心のうちでは、ヘザーレッグの治療などで、私のこころの重荷を軽くすることが出来るものかと思っていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども姫は両親にこの事を話すと、却て心配をかけると思ったから、毎晩｜故意とよく眠ったふりをして我慢しながら、どうかして新しい珍らしいお話を聞く工夫はないかと、そればかり考えていた。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたあちやんは、三又｜土筆のことをお母さんに話して了ふかと思ひましたが、それでは却つてお母さんに心配をかけるだらうと、一人で胸をいためて居りました。",
              "citation": {
                "source": "虹の橋",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫に余計な心配をかけるのを恐れたばかりでなく、自分もそれを口にするのが何だか恐ろしいように思われたからである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上さらに御心配をかけるのもはなはだ相済みませんが、この際私に是非お願いしたい二つのことがあります。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでへんな事をいい出して、この上この美しい女性に心配をかけるなという意味であろう。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこれらのことが全部避け得られても、なお山麓の村人に心配をかけることのみはどうしても、避け得られないだろう。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら山に迷えるとはいえ、病気の父にこれほどまでも心配をかけるとは、なんという不孝者であろう。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一人の心の迷いからこうまで多くの人々に心配をかけるとは、おおなんという恐ろしいことだろうとひどく胸を打たれてしまった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天にも地にもタッタ一人の妹に心配をかけるばかりでなく、両親がやっとの思いで残してくれた、無けなしの学費を、この上に喰い込むような事があったら、どうしよう。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一不意にさうして心配をかけることもないし学科にさしさはりの出来るやうなこともないし、常々うちの手伝ひでもしてゐれば家の為めにもどの位なるかしれない。",
              "citation": {
                "source": "嘘言と云ふことに就いての追想",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分には父は帰っているだろうし、あの奥さんは自分の子供の事だ、余計に心配をかけるのは気の毒だが、きっと待っているだろう。",
              "citation": {
                "source": "愛の為めに",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後この猫、年に一二回妊娠をするし、分娩の時の世話やら、生れた仔猫の貰われ口など、随分心配をかけるが、それだけにまた家庭生活の中に根を下して、すっかり家族の一員となってしまった。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなにこの大伯母に心配をかけるに十分なだけ信二もまたかっちまりのない風にゆれる夕顔みたいなノコンとした気持で居た。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁にはそれが不思議でもあり、心がゝりでもありますので、ある時、そのわけを聞きますと、「今までに、度々お話しようと思ひましたが、御心配をかけるのもどうかと思つて、打ち明けることが出來ませんでした。",
              "citation": {
                "source": "竹取物語",
                "author": "和田萬吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに女にはよくあり勝だよ、隠さないでも済む事をイヤに隠したがってわざわざ外の人に心配をかける。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつぞやから、今度逢ったら言おう言おうと思っていましたが、何だかまたよけいな御心配をかけるような気もして……じつは前の月からわたし見るものを見ませんの」「え？",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちは決して、お父さんに御心配をかけるようなことはしません」　春木少年が一同を代表して断言すると、小玉氏はにこにこ笑って、「よしよし。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ心配をかける事の方が多くなるのではないか。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「然し余り国の人達に心配をかけるのはよくないね。",
              "citation": {
                "source": "香奠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、よけいな心配をかけるわけで、あまり感心しないと思うんですがね」「なに、おどす？",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それを私にご返却なさらない間は、あなたもご安心が出来ますまいし、私としてもあなたに新しいご心配をかけるのは好ましくありません。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあえず半蔵はこのことを多吉夫婦の耳に入れ、郷里の留守宅あてにもありのままを書いて、自分の粗忽から継母にまで心配をかけることはまことに申し訳がないと言い送った。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
