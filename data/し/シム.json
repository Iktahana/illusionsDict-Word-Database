    "definitions": [
      {
        "index": 1,
        "gloss": "to occupy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "客車狭くして腰掛のうす汚きも我慢して座を占むれば窓外のもの動き出して新聞売の声後になる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上面および底面上にて対角線によって結び付けられた頂点に位置を占むる趣味は相対立する一対を示す。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一条の水路は甚だ狭隘にしてかつ甚だ不潔なれども、不潔物その他の運搬には重要なる位置を占むること、その不快を極むるところの一路なるをも忌み厭ふに暇あらずして渠身不相応なる大船の数※出入するに徴して知るべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前は青田、青田が尽きて塩浜、堤高くして海面こそ見えね、間近き沖には大島小島の趣も備わりて、まず眺望には乏しからぬ好地位を占むるがこの店繁盛の一理由なるべし。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで私のいう労働者とは、社会問題の最も重要な位置を占むべき労働問題の対象たる第四階級と称せられる人々をいうのだ。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月、川上音二郎、藤沢浅二郎の書生芝居が中村座に乗込み、意外の大入りを占む、東京における書生芝居の始めとす。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座にて団十郎は歌舞伎十八番の「暫」を勤め、連日売切れの大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優は沢村小伝次、中村吉右衛門にて、意外の大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治は左団次一派、本郷は新派の深沢恒造らにて、いずれも大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主なる女優は森律子、村田嘉久子、初瀬浪子らにて、女優劇の名が好奇心を誘い、意外の大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の目的が平和にあらうとも、芸術にあらうとも、信仰にあらうとも、知識にあらうとも、それを今批判する余裕はないが、とにかく戦争が手段である以上、人間の目的でない以上、それに成効の実力を付与する軍国主義なるものも亦決して活力評価表の上に於て、決して上位を占むべきものでない事は明かである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州の耕地面積二割五分に対して、わづかに一割半を占むる哀れなる奥州。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり文界の浪士のみ之を占むるにあらず、無名の詩人、無文の歌客、こゝやかしこにさまよふめり。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "論文欄は毎号紙数の大多部を占むると共に、又常に比較的他欄より幼稚なる傾向有之候が、本号も亦其例外に立ち難く見受けられ候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前から（徳川時代から）忌避され軽蔑されていた肉慾描写や不倫の世相が、自然主義の輸入以来、臆面もなく逆照され初めて、往昔、最低級の芸術として扱われていた作品が、堂々として一般民衆の趣味傾向の王座を占むる事となった。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大化改新の功臣たる藤原鎌足の子孫が、朝廷に勢力を占むるは、当然の勢ひではあらうが、彼等は他の名門、旧家を排斥し、皇室の外戚として、摂政関白、その他の高位高官を独占する傾向を生じてゐた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "女客の來て座を占むるあれば、ベルナルドオ必ずその月旦を怠ることなし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女子の胸の片隅を占むるや、その奧に進むべき鍵は、詩人の手にあるものぞ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちデンマーク国の欧州大陸に連なる部分にして、その領土の大部分を占むるユトランド（Jutland）の荒漠を化してこれを沃饒の地となさんとの大計画を、彼はすでに彼の胸中に蓄えました。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十六講　ゾパル再び語る第二十章の研究◯ヨブは十九章において大なる啓示に接して光明全心に漲るに至り、今は友の上に優逸なる信仰の地歩を占むることとなりて、今までは友に撃たれつつありしに今は威迫を以て友に臨み得るに至った。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅樹千章、雪裡今に春を占む。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きさを云へば、妙義は二里四方、榛名は六里四方、赤城は十里四方の地盤を占む。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男獨り甲板の上に、この清風明月を占む。",
              "citation": {
                "source": "月の東京灣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術の神聖を信じ、芸術が実生活の上に玉座を占むべきものであるのを疑わない君も、その事がらが君自身に関係して来ると、思わず知らず足もとがぐらついて来るのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "代々此習慣がついてるから、中流以下は勿論、士族が大部分を占むる中流以上の家でも、特別に学問好き書籍好きの主人の家は別として、大抵な家でも主人の書斎の無い家がある。",
              "citation": {
                "source": "家庭の読書室",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子舞歌海潮音　序　巻中収むる処の詩五十七章、詩家二十九人、伊太利亜に三人、英吉利に四人、独逸に七人、プロヴァンスに一人、而して仏蘭西には十四人の多きに達し、曩の高踏派と今の象徴派とに属する者その大部を占む。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子舞歌　　海潮音　序　巻中収むる処の詩五十七章、詩家二十九人、伊太利亜に三人、英吉利に四人、独逸に七人、プロヴァンスに一人、而して仏蘭西には十四人の多きに達し、曩の高踏派と今の象徴派とに属する者その大部を占む。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族旅行と木箱との過剰は最早、世界をして理知にて笑はしめ、感情にて判断せしむるなり。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに哀しく、きのふきみのくちびる吸ひてきずつけ、かへれば琥珀の石もて魚をかこひ、かの風景をして水盤に泳がしむるの日、遠望の魚鳥ゆゑなきに消え、塔をきづくの額は研がれて、はや秋は晶玉の死を窓にかけたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
