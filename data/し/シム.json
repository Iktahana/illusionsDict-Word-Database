  {
    "uuid": "3f93d3ca-0e88-5f5c-bee7-03cd494aea09",
    "entry": "ＳＩＭ",
    "reading": {
      "primary": "シム",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "SIM (card)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蚤ガ群ッテ集マルノデ眠ルノハ少シムツカシイ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は陰影で煮〆たようなキャフェ・マキシムでもなかろう。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の自由詩はまだ皆生硬で眞のシムボリズムになつて居ません。",
              "citation": {
                "source": "ふつくりとした人柄",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれは父が自分の家族のためにどれほど身をつめているかを人に見せびらかすシムボルなのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シムキというアイヌだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤眼のシムソンの様に、がむしゃに働いて食う外は無え。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　いつまでもシムプルでありたい、ナイーブでありたい、少くとも、シムプルにナイーブに事物を味わいうるだけの心持を失いたくない。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちかくの如きものは、實に言葉の一大シムホニイである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王サマハ、「デンデン　ムシムシ」ト　口ノ　中デ　イヒナガラ、ニハヲ　グルリト　マハツテ　キマシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレデモ、オモヒダセナイノデ、トウトウ　オコツテ、カタツムリヲ　ツブシテ　シマハウト　シタ　トキ、フツト　オウサマノ　ココロニ、「デンデン　ムシムシ　ツノ　フレヨ、夜アケニ、ヌストガ　ヤツテ　クル」ト　イフ　ウタガ、ウカビマシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉は昨晩レストラン・マキシムで無暗にあおったシャンパンの酸味が爛れた胃壁から咽喉元へ伝い上って来るのに噎び返りながらテーブルの前へ起きて来た。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべはマキシムで偶然ベッシェール夫人の最後の夫ジョルジュに遇った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々刻々ノワガ姿、笑ッタ、怒ッタ、マノワルキカッカッ燃ユル頬、トウモロコシムシャムシャ、ヒトリ伏シテメソメソ泣イテイル、スベテ記シテ、ノチノチノ弱キ、ケレドモ温キ若キ人ノタメニ、尊キ文字タルベキコト疑ワズ、ソコガソレ、スランプノモト。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学ハ、知ヘノ愛デハナクテ、真実ノ知トシテ成立セシムベキ様ノ体系知デアル、ヘエゲル先生ノコノ言葉、一学兄ニ教エラレタ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文字ノ害タル、人間ノ頭脳ヲ犯シ、精神ヲ痲痺セシムルニ至ッテ、スナワチ極マル。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例を現代に取るも、人の普く知る如くマキシム・ゴルキーは、露国最下の賤民たる放浪の徒たりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしいではないか、若いロセツチが生命の家のよろこびを古いソンネツトの形式に寄せたやうに私も奔放自由なシムフオニーの新曲に自己の全感覚を響かすあとから、寥しい一絃の古琴を新らしい悲しい指さきでこころもちよく爪弾きしたところで少しも差支へはない筈だ。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私らはシムプルな情緒そのものを素朴な古人のやうに詠歎することに最早や少からぬ不満足を感ずる。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしいではないか、若いロセツチが生命の家のよろこびを古いソンネツトの形式に寄せたやうに私も奔放自由なシムフオニーの新曲に自己の全感覚を響かすあとから、寥しい一絃の古琴を新らしい悲しい指さきでこころもちよく爪弾したところで少しも差支へはない筈だ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんの名をカシムと言い、弟の名をアリ・ババと言いました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、カシムはお金持のおじょうさんをおよめさんにもらいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金持のおじょうさんをもらったカシムは、毎日ぶらぶら遊んでくらしていましたが、そのはんたいに、アリ・ババは毎日せっせと働かなくてはなりませんでした。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「私はこれからカシム兄さんのところへ行って、ますをかりて来ましょう。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、おかみさんは、カシムの家へ出かけて行きました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "カシムの家では、ちょうどカシムがるすでした。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでカシムのおかみさんに、「姉さん。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カシムのおかみさんは、ぶあいそうな顔をしてこう答えました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
