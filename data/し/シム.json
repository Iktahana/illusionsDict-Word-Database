  {
    "uuid": "812cc888-c93f-576c-8103-509463987d1d",
    "entry": "使む",
    "reading": {
      "primary": "しむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "補助動詞",
        "Nidan verb (lower class) with 'mu' ending (archaic)"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "auxiliary verb indicating the causative voice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○死卒を収取し、相迎へ使むる無し。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "由の字のこのような意味を知れば、「民は之に由ら使む可し」を朱子（中国南宋の儒学者）が解釈して、「民はこの道理の当然に由らしむべし」と言うのが、実に明白な解釈だと感じられる。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族旅行と木箱との過剰は最早、世界をして理知にて笑はしめ、感情にて判断せしむるなり。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに哀しく、きのふきみのくちびる吸ひてきずつけ、かへれば琥珀の石もて魚をかこひ、かの風景をして水盤に泳がしむるの日、遠望の魚鳥ゆゑなきに消え、塔をきづくの額は研がれて、はや秋は晶玉の死を窓にかけたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情といふ語の内容も色々であらうが、「独り居て怡しむ」底の感情、対人的に発露するに非ざる、そこはかとなき欣怡の情である。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "議論の内容如何に拘わず、議論することそのことが癪だといふ、女ならでは夜の明けぬ、悲しむべきことではあるまいか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォルムのない競技で以て、徒らに勝たうとばかりしてゐるやうなもので、仮令勝てたにしても、競技そのものを楽しむ気持はなく、勝つた時に熱病的に嬉しいだけで、十年の後に回想したらば、なんといふこともなかつたと、呆然としなければならない始末だらう。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "で結局僕は僕の心の虫をいつくしむんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつくしむよりほかどうしやうもあるもんか。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しむ、私よろこばないです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "博識の人が、おのれの知識を機会ある毎に、のこりなく開陳するというのは、極めて自然の事で、少しも怪しむに及ばぬ筈であるが、世の中は、おかしなもので、自己の知っている事の十分の一以上を発表すると、その発表者を物知りぶるといって非難する。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間修業」だの、「自然に親しむ」なぞといふことが云はれるが、それはもとより大切乍ら、それと詩とは只関係が密接なだけで、先づ何よりも先人の作品は読まれなければならぬ。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それは余りお菓子の欲しくない人が駄菓子の方が寧ろ美味い、といふ時のやうなふうにして発生した通念と見えるが、それにしても、一応の由来はあると思へるので、一寸その事に就いて云つてみれば、　西洋人の方が、我々よりも尠くも形の上では楽天的である、従つて即興的であるよりも構成を怡しむ習性を一層持つてゐる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、詩といへば「ああいふもの」と、一般的にハツキリと位置するものとなつたとしたら、楽しむ方でも作る方でも、事情は一変するのであるが、これは容易に首肯されさうでゐて、却々了得され難いことだと思はれる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの男について言つてみれば、この男はその悲しむ段となつてはまるで無意識家と同しなのです。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、悲しむ段となつてだけ無意識なんてことがありませうか？",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがどんなに悲しむべきことであるかは、知る人ぞ知る、とても悲し過ぎて、今茲で簡単にその証明をするわけには行かぬ。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もかも再会に懐しむ、あの貞順な奥さんも昔の喜びに笑ひいでる。",
              "citation": {
                "source": "秋の日曜",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼が自ら言ふ通り、今の彼が詩を書く気持は、昔のやうに張り切つたものではなくつて、飽食の後に一杯の紅茶をすすり、労作の後に机を浄めて、心の余裕を楽しむ閑文学の風雅にすぎない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼が石を集め、苔を植ゑて庭を造り楽しむ時、しばしばその自己流の道楽芸が専門の庭園師を嘆息させるほど、真にユニイクな芸術創作となるのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日だけの休暇を楽しむ、可憐な奉公人の子供は、何の夢を見ていることやら、と言う意味である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは柚の花の侘しく咲いている、昔々の家に鳴るオルゴールの音色のように、人生の孤独に凍え寂しむ詩人の心が、哀切深く求め訪ねた家郷であり、そしてしかも、侘しいオルゴールの音色にのみ、転寝の夢に見る家郷であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何で年よる」という言葉の響に、如何にも力なく投げ出してしまったような嘆息があり、老を悲しむ情が切々と迫っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎なり昇降機械の往復する東京市中繁華の屋根に琥珀の斑なる毛皮をきて曠野の如くに寂しむもの。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白痴の主人公は、愛情の昂奮に駆られた時、不意に対手の頭を擲ろうとする衝動が起り、抑えることが出来ないで苦しむのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人は、仲間と一緒の方を楽しむらしい。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ僕だけが変人であり、一人の自由と気まま勝手を楽しむのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自然に友人を避け、孤独で暮すことを楽しむように、環境から躾けられてしまったのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋琴楼に仮寓の昔も思い出さしむ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
