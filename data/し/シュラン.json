    "definitions": [
      {
        "index": 1,
        "gloss": "drunken frenzy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "主人の放蕩、女狂い、酒乱がそれまでにとにかく得て来た彼の地位を崩してしまった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或人は、酒乱者の一人」また問い給う「なんじらは我を誰と言うか」ひとりの落第生答えて言う「なんじはサタン、悪の子なり」かれ驚きたまい「さらば、これにて別れん」　私は学生たちと別れて家に帰り、ひどい事を言いやがる、と心中はなはだ穏かでなかった。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊五郎の魚屋宗五郎の酒乱、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、長男の道楽は、次男三男の酒乱の如くムキなものではなく、ほんの片手間の遊びである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい盃の中の酒を、一息にぐいと飲みほしても、周囲の人たちが眼を見はったもので、まして独酌で二三杯、ぐいぐいつづけて飲みほそうものなら、まずこれはヤケクソの酒乱と見なされ、社交界から追放の憂目に遭ったものである。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は酒乱じゃないけど、かなり好きなほうだ。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが、抜け目ない柳田も、頭をかいて苦笑し、「酒乱にはかなわねえ。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の制裁は酒乱と共にだん／＼苛酷を極めて来た。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は北の新地のかしくといった全盛の遊女で、ある蔵屋敷の客に引かされて天満の老松辺に住んでいたが、酒乱の癖が身に禍いして、兄の吉兵衛に手傷を負わせた為に、大坂じゅう引廻しの上に獄門の処刑を受けたのであった。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈火の点く頃には、少し酒乱の癖のある主人の信之が、向鉢巻をしてカツポレを踊り出した。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――　処が樽野の妻である長女から末娘の逃走を聞いて酒乱を起す、そして思はず狂気になつて、「たまなしだ／＼！",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女の父は、以前に酒乱の癖があつたさうだ。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒乱の酷い頃は連夜、吾家に帰つて乱暴を働き、その頃小さな運送店を経営してゐたのであるが、店の者などは蒼くなつて逃げ出したさうだ。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代の話によれば、彼女の父は町で有名な酒乱であった。",
              "citation": {
                "source": "或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒はどうしてもやめられないから飲む、飲めば飲みすぎる、そして酒乱になる、だらしなくなる、一種のマニヤだ、つつしまなければならないなどと考へてゐるうちに、ぐつすりとねむつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒乱清算の機縁が熟したと思ふ（私の場合では酒乱といふよりも酒狂といふべきだらう）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時の汽車に乗るべく、またタクシーで、――私はたうとう愚劣きわまる酒乱患者となつてしまつた！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――酒乱、醜態、あゝあゝ、……恥を知れ、恥を、……死んでしまひたい、……馬鹿、阿呆。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして酒乱の性癖があった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きんが十九の頃、相沢の家も、合百の鳥越と云う男が出入りするようになってから、家が何となくかたむき始め、養母のりつは酒乱のような癖がついて、長い事暗い生活が続いていたが、きんはふっとした冗談から鳥越に犯されてしまった。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "癇癪持で酒乱の父に兄や姉は叱られた怖い思い出ばかり残っているようだが、末ッ子のぼくは父から嘗められるみたいに愛された記憶が強い。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはひどい酒乱でのう。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃刀をあてると、青い剃りあとに酒乱の痕跡の泛び出た美男になる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この久左衛門と参右衛門が、まったく地位の転倒した別家と本家の関係にあり、それも三間の空地をへだてた隣家で、酒を飲み交している場では、定めし酒乱の殴打はなみなみならぬ響きが籠っていたことだろう。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒乱癖の彼の酔った夜は、清江はあたりの物をすべて取り片附けて傍へは近よらない。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　勘三はいささか酒乱の相がある。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きんが十九の頃、相沢の家も、合百の鳥越と云ふ男が出入りするやうになつてから、家が何となくかたむき始め、養母のりつは酒乱のやうな癖がついて、長い事暗い生活が続いてゐたが、きんはふつとした冗談から鳥越に犯されてしまつた。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、妾、思はず手を引き候ひしに、御盃の中のもの、御膝に打ちこぼれしより、忽ち御酒乱の体とならせ給ひ、押し止むる乳母を抜く手を見せず討ち放され候。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
