    "definitions": [
      {
        "index": 1,
        "gloss": "new (train) station",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text_content": "来年、この路線に新駅が開業する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content_content": "新駅の周辺は再開発が進み、活気にあふれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content_content": "新駅の設置により、通勤が格段に便利になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "越後金丸・越後片貝など言う新駅も、出来たばかりで、まだ人影もなく、深い山の中に真白に静まり返って居た。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "総テ這地ノ隆盛ナル反ツテ旧趾ノ南浜新駅ヲ羞シムベキ景勢ナリ。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
