        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実際にこういう空間曲線を作る事は厄介であるから、その代りにこの曲線をＸＺ面とＹＺ面に投射したものと二つを画いて調べる外はないのである。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きな望遠鏡で銀河をよっく調べると銀河は大体何でせう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "運勢でも調べるのですかと問われた。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震だけを調べるのでは、地震の本体は分りそうもない。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに瀬戸内海のように外洋との通路がいくつもあり、内海の中にもまた瀬戸が沢山あって、いくつもの灘に分れているところでは、潮の満干もなかなか込み入って来てこれを詳しく調べるのはなかなか難しいのです。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "字に書いたものを土台にして調べるという場合には、すぐこんな問題に打突かるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし宣長翁は『古事記』以外のものについては精密に調べる暇がなかったのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためには五感のうちの一つを欠いた人間の知識の内容がどのようなものかという事を調べるのも、最も適当な手掛りの一つだと思われた。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしその欠けたのの特別な色合でも何か調べる必要があるのなら持って行ってもいいが、もう一つ欠けないのもぜひ持って行けというのである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄五郎は三次の身体を調べる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙入れの中味を調べると、金と一緒に出て来たのが仇討赦免状（大写）。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋　棚倉等と捕方が協力して長屋を一軒一軒調べる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "受けとった徳兵衛中味を調べる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次中を調べると、　三四郎さままいる、とした色文が十五六通。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、それが賭博との疑ひを受けて、或る晩一｜同がその筋から取り調べを受けるやうな事件が持ち上つたが、取り調べる側がその技法を知らないので誰かが滔滔と講釋をはじめ、係官を烟に卷いたといふ一｜插話もある。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "憲兵が取調べる際にも、やはり、その弱点を掴むことに伍長と上等兵の眼は向けられた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、年来の宿痾が図書館の古い文献を十分に調べることを妨げた。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかしてこの害虫を絶滅する方法はないものだろうかと思うだけで、専門家に聞いてみるでもなく、書物を調べるでもなく、ついそのままにしておくのである。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "念のために神田の上州屋を調べると、果たして為次郎は宵から悔みに来て、四ツ少し前に帰ったということが確かめられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「町奉行は格別、番屋で調べるときには、岡っ引や手先ばかりでなく、八丁堀のお役人衆もみんなこの息で頭からぽんぽん退治つけるんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳は、蒋介石の北上と共に、だん／＼はいりこんで来た南軍の密偵と、便衣隊について調べるため街に出かけたのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負作業の出来高を調べるものゝように、仕事場に這入った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きな望遠鏡で銀河をよっく調べると銀河は大体何でしょう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）１３＝（Ｆ・Ｉ）以前の橋の処　土左衛門を調べる右門主従と敬四郎。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）１８＝（Ｆ・Ｉ）右門宅　編笠と羽織を調べる右門。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が、Ｔ「早速貴殿の奥方様にお目に掛りましょう」　敬四郎が驚いて、　「いいや」Ｔ「身共の家内は身共が調べる」　右門が、　「では」Ｔ「拙者もお立合致します」　と言われては敬四郎も、　「勝手にさッしゃい」という他なし。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）13＝（Ｆ・Ｉ）以前の橋の処　土左衛門を調べる右門主従と敬四郎。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）18＝（Ｆ・Ｉ）右門宅　編笠と羽織を調べる右門。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "心さえ急かねば謀られる訳はないが、他人にして遣られぬ前にというのと、なまじ前に熟視していて、テッキリ同じ物だと思った心の虚というものとの二ツから、金八ほどの者も右左を調べることを忘れて、一盃食わせられたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは主に、猫の歴史と地理をしらべるところでした。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
