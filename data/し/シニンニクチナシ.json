    "definitions": [
      {
        "index": 1,
        "gloss": "dead men tell no tales",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
