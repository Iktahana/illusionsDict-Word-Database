        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔鷺はひかりのそらに餓ゑ〕宮沢賢治鷺はひかりのそらに餓ゑ羊歯にはそゝぐきりさめをあしきテノールうちなして二人の紳士　森を来る",
              "citation": {
                "source": "〔鷺はひかりのそらに餓ゑ〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらこちらに切り倒された大木の下から、真青な羊歯の鋸葉が覗いている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬返しより太郎坊まで、羊歯の小自由国や、蘚苔の小王国を保護して、樅落葉松の純林、戟を揃へて隣々相立てるあり、これありて裾野の柔美式なる色相図に、剛健なる鉄銹色を点し、無敵の冬をも呵して、一路空山｜料峭の天に向ひて立つものあるなり。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊歯の葉は、よあけの霧を吸って、青くつめたくゆれました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔島わにあらき潮騒を〕宮沢賢治島わにあらき潮騒をうつつの森のなかに聴き羊歯の葉しげき下蔭に青き椿の実をとりぬ　　南の風のくるほしく　　波のいぶきを吹き来れば　　百千鳥　すだきわぶる三原の山に燃ゆる火のなかばは雲に鎖されぬ",
              "citation": {
                "source": "〔島わにあらき潮騒を〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷羊歯の汽車、恋人、アルネ。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "径の傍らには種々の実生や蘚苔、羊歯の類がはえていた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく蕈も大ていなくなり理助は炭俵一ぱいに詰めたのをゆるく両手で押すようにしてそれから羊歯の葉を五六枚のせて縄で上をからげました。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と二人の娘とは部屋の装飾をするために山に羊歯の葉や草花を採りに行った。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は酔い心地になって、日あたりのいい斜面を選んで、羊歯を折り敷いて腰をおろした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の下に踏みにじられた羊歯の青くさい香を私は耳でかいでいるような気がした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船乗りの青年はポケツトから小さなナイフを出してその窓の羊歯の葉の形をした氷をガリガリ削り落しました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、通れ」　伝令はいそがしく羊歯の森のなかへはいって行きました。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき霧の向こうから、大きな赤い日がのぼり、羊歯もすぎごけもにわかにぱっと青くなり、蟻の歩哨は、またいかめしくスナイドル式銃剣を南の方へ構えました。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、通れ」　伝令はいそがしく羊歯の森のなかへ入つて行きました。",
              "citation": {
                "source": "朝に就ての童話的構図",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき霧の向ふから、大きな赤い日がのぼり、羊歯もすぎごけもにはかにぱつと青くなり、蟻の歩哨は、また厳めしくスナイドル式銃剣を南の方へ構へました。",
              "citation": {
                "source": "朝に就ての童話的構図",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく蕈も大ていなくなり理助は炭俵一ぱいに詰めたのをゆるく両手で押すやうにしてそれから羊歯の葉を五六枚のせて繩で上をからげました。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがある夕方二人が羊歯の葉に水をかけてたら、遠くの遠くの野はらの方から何とも云えない奇体ないい音が風に吹き飛ばされて聞えて来るんだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や早やも土は凝りて、岩角の犬羊歯が下、枯れ枯れの雑木の根ごと、そくそくと氷柱さがれり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒々しい触手を伸ばした羊歯類。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨幹と数知れぬ其の従者共（気根）とは、地球を担うアトラスの様に、怪鳥の翼を拡げたるが如き大枝の群を支え、一方、枝々の嶺の中には、羊歯・蘭類がそれぞれ又一つの森のように叢がり茂っている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の左側には、巨大な羊歯族の峡谷を距てて、ぎらぎらした豊かな緑の氾濫の上に、タファ山の頂であろうか、突兀たる菫色の稜線が眩しい靄の中から覗いている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大な芋葉と羊歯とを透かしてチラと裸体の影を見たように思った時、鋭い嬌声が響いた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の跡らしいもの、井戸の形をしたものなどが、密生した羊歯類の間に見え隠れする。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大な芋葉と羊歯とを透かしてチラと裸体の影を見たやうに思つた時、鋭い嬌声が響いた。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖からしみ出る水は美しい羊歯の葉末からしたたって下の岩のくぼみにたまり、余った水はあふれて苔の下をくぐって流れる。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰や雪をもよおす雲は空に低くかかり、大烏は羊歯の上に立って、「カオカオ。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、平凡万能の時勢が、表明するとしないとに関らず醸しだしてゐる空気といふものは、智的なものでも芸術的なものでもないといふことである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいに四方を眺むれば、遠き地平を超え、黒き眞冬を超えて叫びしんりつす、ああ聖地靈感の狼ら、かなしみ切齒なし、にくしんを研ぎてもとむるものを、息絶えんとしてかつはしる。",
              "citation": {
                "source": "巡禮紀行",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地宮沢賢治焦ぎ木のむらはなほあれば山の畑の雪消えて〔以下なし〕　――――――――青年団が総出にてしだれ桜を截りしなり",
              "citation": {
                "source": "開墾地",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
