[
  {
    "uuid": "da7b47f0-c34e-53e3-99c4-edff0d81486e",
    "entry": "仕向ける",
    "reading": {
      "primary": "しむける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
