        "examples": {
          "standard": [
            {
              "text": "アルプスの山中で、珍しいシャモアの群れを目撃した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "シャモアは、険しい岩場でも軽やかに動き回る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "革製品のシャモアは、非常に柔らかくて肌触りが良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "剥製の箱は素敵に大きなもので、シャモアの立派なのが三｜疋、シュネーフーンに狐やフュレーなどは、冬毛と夏毛をわけて、山草をあしらった大きな台にのせてある。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "狩猟館の方も非常に面白い、シャモアやヒルシュの首だけ剥製にした飾りものが、場内の壁一面に並べてある。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
