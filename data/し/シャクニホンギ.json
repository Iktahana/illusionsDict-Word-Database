    "definitions": [
      {
        "index": 1,
        "gloss": "Shaku Nihongi (commentary on the Nihon Shoki compiled in the late 13th century)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
