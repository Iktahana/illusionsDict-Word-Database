          "standard": [
            {
              "text": "先生：「彼女は、困難な状況でも芯が強い子です。応援しています。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "母親：「娘には、どんな時でも芯が強い人間になってほしいと願っています。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アスリート：「逆境を乗り越えられたのは、心の底からの強い意志、芯が強かったからだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし不思議なことにはこういう食事をとりながら、運動も盛んにやり、野球の選手までつとめてきたのであるから、人間というものは案外に芯が強いものだと、われながら感心する。",
              "citation": {
                "source": "若き日の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
