    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hierarchy of samurai, farmers, artisans, and merchants in Edo society",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上は摂政関白武将より下は士農工商あらゆる階級の間に行なわれ、これらの人々の社会人としての活動生活の侶伴となってそれを助け導いて来たと思われる。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童の一肩、聳えつつ、「芸人でしゅか、士農工商の道を外れた、ろくでなしめら。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "士農工商という順序に従えば、私は大工の息子です、ずっと身分が下であります。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "士農工商師匠のこせついたのは見苦しいが、ことの序でに戒めて置くぞ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から士農工商というが、あれは誠と嘘との使いわけの程度によって、順序を立てたので、仕事の性質がそうなっているのだ。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の社会は経済的関係なるが故に、士農工商如何なる職業のものも生活を談じ米塩を説いて少しも憚からず。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸に住まって江戸の人間になろうとするにゃ、ご藩士ご家中お大名仕えの者はいざ知らず、その他の者は、士農工商いずれであろうと、もよりもよりのお寺に人別届けをやって、だれそれ子どもが何人、父母いくつと寺受けをしてもらわなくちゃならねえおきてなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "事、ひとたび流血沙汰に及んだとすれば、農民達にいか程正義正当の理由があったにしても、士農工商、階級の相違、権力の相違が片手落ちならぬ片手落ちの裁きをうけて、結局悲しい処罰をうけねばならぬ者は、正しいその農民達なのです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これらの藩学校は、藩という制度の枠にはまっていた本質上、当時の身分制度である士農工商のけじめを脱したものではなかった。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治維新の誰でも知っているこういう特質は、「四民平等」となって、ふるい士農工商の身分制を一応とりさったようでも、数百年にわたった「身分」の痕跡は、人民生活のなかに強くのこりつづけた。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はわざわざ正午に出かけて行って見たんだが、その四個の時計人形は士農工商を象徴しているらしい。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代に入って封建制は確められ、士農工商の身分的区別も確立した。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い例でいえば、徳川末期の武家権力の崩壊期に、経済的実力をもってきた町人階級が、士農工商の封建身分制にたいする反抗として遊里という治外法権地域をつくり、馬琴の文学にたいして、京伝らの文学をもった場合にもこのことが見られました。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸人のなりたちは、士農工商のうち農だけが缺けてゐる。",
              "citation": {
                "source": "初かつを",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "士農工商、相互にその自由独立を妨ぐべからず。",
              "citation": {
                "source": "中津留別の書",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は人間普通の実学にて、人たる者は貴賤上下の区別なく、みなことごとくたしなむべき心得なれば、この心得ありて後に、士農工商おのおのその分を尽くし、銘々の家業を営み、身も独立し、家も独立し、天下国家も独立すべきなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王制｜一度新たなりしより以来、わが日本の政風大いに改まり、外は万国の公法をもって外国に交わり、内は人民に自由独立の趣旨を示し、すでに平民へ苗字・乗馬を許せしがごときは開闢以来の一｜美事、士農工商四民の位を一様にするの基ここに定まりたりと言うべきなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "父兄は子弟に独立を教え、教師は生徒に独立を勧め、士農工商ともに独立して国を守らざるべからず。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この心得ありて後に、士農工商、おのおのその志すところの学を勤むべし。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧富貴賤、士農工商に依って階級の差等や権利の差等を認めず、一斉に同じ出発点に立って創造能力の競争に参加し得るのが「平等の権利」です。",
              "citation": {
                "source": "婦人も参政権を要求す",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薄馬鹿を守り立てて、そのお扶持をいただいて、士農工商の上にいると自慢する武士という奴等が、癪にさわっているのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような笠が揃って四五名、まだ士農工商のいずれともわからないが、こちらへ向いて四五名が隊をなしてやって来る姿が、豆のように見えることは確かです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "北斎は士農工商の生活、男女老弱の挙動及姿勢を仔細に観察し進んで各人の特徴たる癖を描き得たり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世士農工商の階級既に存せずといへども利のために人の道を顧みざる商賈の輩は全く人の最下に位せしめて然るべきなり。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "故不能窺神明高貴之庭※、而士農工商倶嫌‐忌之。",
              "citation": {
                "source": "エタに対する圧迫の沿革",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世武士が勢力を得て、農民の上に立ち、工業、商業が、立派な独立の営業となった時代においても、なお士農工商と順序して、工商の地位を農民の下に置きましたのは、かかる沿革があったためです。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側とも菜飯田楽の行燈を出した二階｜立の料理屋と、往来を狭むるほどに立連った葭簀張の掛茶屋、またはさまざまなる大道店の日傘の間をば士農工商思い思いの扮装形容をした人々が後から後からと引きも切らずに歩いて行く。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "士農工商ある中に、両替仲間相場立ち、大銭小銭を打並べ出しゃ、お白洲でしかりゃせぬ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
