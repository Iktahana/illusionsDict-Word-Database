[
  {
    "uuid": "302a8852-2a4b-5efc-8814-d9a7fe0bd1db",
    "entry": "士農工商",
    "reading": {
      "primary": "しのうこうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
