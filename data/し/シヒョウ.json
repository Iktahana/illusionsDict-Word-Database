[
  {
    "uuid": "75a2fa76-9d29-5e11-a99f-832623555b1c",
    "entry": "師表",
    "reading": {
      "primary": "しひょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
