[
  {
    "uuid": "33ad7d00-29fc-5abc-8f06-949afae81c53",
    "entry": "新市街",
    "reading": {
      "primary": "しんしがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
