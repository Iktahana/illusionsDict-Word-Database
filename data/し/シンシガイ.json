      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "new town (of a city; as opposed to the old town)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大阪では安政の地震津浪で洗われた区域に構わず新市街を建てて、昭和九年の暴風による海嘯の洗礼を受けた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ充分な調査資料を手にしないから確実なことは言われないが、最もひどい損害を受けたおもな区域はおそらくやはり明治以後になってから急激に発展した新市街地ではないかと想像される。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処には調和と云ふよりも寧ろ旧都会と新市街との不可思議な対照がある。",
              "citation": {
                "source": "新橋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "粘土と平ったい石片とで築かれたアラビア人の城砦の廃墟というのへ登り、風にさからって展望すると、バクーの新市街の方はヨーロッパ風の建物の尖塔や窓々で燦めいている。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハルビン」　灰色にくすぶる新市街の停車場。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐人街、新市街、どこを歩いても、見切品ばかりが眼について嫌になつちまう、人間がそも／＼見切だから詮方もないが、実は旧臘以来、安物ばかり買はされてきたせいだ。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しくて大きい旅館で、舊市街と新市街の間のやうなところにあつた。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "碌三も猛之介も、近頃新市街に編入されたばかりのこの土地では生えぬきで、若衆仲間からのつき合いであった。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新市街に編入されたというのも、近年こっち方面へ著しく工業が発展して来たからで、麦畑のあっちこっちに高い煙突が建った。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海の新たな新市街計画も、また済南のそれも、恐らくこれほど整然とはゆくまい。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海だけの寂びと潤ひとが無いのは歳月を経ない新市街のためであらうか。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "予等は再び自動車に乗り、新市街の大和ホテルに入つて午※として辞し、更に自動車を爾霊山に走らせた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂ゆる二〇三米突の最高峰に立つて四望すると、東北には砲台のあつた諸峰が連立し、西北には関東州の平野、南には渤海、東には黄海を遮断して壁立する老鉄山と旅順新市街との間にコバルトを湛へた西港の水が俯瞰される。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "山を下つて新市街を過ぐる時、アカシヤ並木の若葉が持つ柔かな鮮緑を車上より幾たびも頭を回しつつ歎賞した。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の附近の新市街には諸国の領事館や会社商店が整然として並び、旧市街と云はれる支那街は少しく河下に離れて望まれる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "安東の市街は、鴨緑江の西岸、江口を溯ること十六哩の平地に、東北から西南に展開し、中央に西より来て鴨緑江に入る沙河を挟んで、その東北は旧市街即ち支那街があり、西南は新市街即ち日本街に分れてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処は満洲鉄道本線の開通に由つて出来た新市街で、一昨年更に四鉄道に沿うた内蒙古各地にある邦人の女子は、すべて此地や大連方面へ引上げてしまつた事が確実になつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "城壁の四方の大門に対して井字形に四大街が区劃され、其れに東西十二条、南北六条の小街路が交叉して整然たる新市街を成してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉斉哈爾公園の噴水ハルビン新市街の一部　市内に引返して、東支鉄道の倶楽部で古澤先生から午※の饗を受けた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の東南は一段の高地で新市街と呼ばれ、比較的閑雅な官署、銀行会社、中流人の住宅地になつてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の泊つてゐる満鉄公館のある所も此の新市街の吉林街である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "新市街の東南に馬家溝と云ふ広大な住宅地域が将来の発展を待ち、馬家溝の東南に露国が最初に経営した露人の住宅地域が、旧市街の名を以て帝政時代の豪勢であつた規模を存してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れが日本人の作つた新市街で、駅の広場から放射線形に三筋の大通が北に射出し、中小の街区が縦横に交叉して、繁華な欧風都市を成してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "撫順にある永安台の新市街は、旧市街の地下の炭田が露天掘の砿区となつた為めに近く移された満鉄経営の欧風日本街である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "遼河源流の一つである渾河（一名瀋水）を北西に望んで、東へ延びた沃野の中に位置し、西は満鉄線に沿うて鉄道附属地に東北より西南に長方形を成した日本の新市街が、奉天駅から放射状に浪華平安の二大街を貫通し、それに大小の街区が分布され、舗道、並木、上下水道、欧風建築等の整然とした文化都市を実現してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "モハメド・アリ通を中心とする新市街はヨーロッパ風の豪華な町並で、通行人もヨーロッパ風の服装の者が多いが、旧市街部へ行くと昔のままの家屋と風俗で、多少穢くはあるが、見た目には絵画的だ。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外の方か、新市街地に行けば虫の出ない部屋が幾らもあるといふが、為事のためには矢張り教室の近くでなければならない。",
              "citation": {
                "source": "南京虫日記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ極めたかといふに、ここは教室から遠くて不便であるが、新市街地で南京虫がゐない。",
              "citation": {
                "source": "南京虫日記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "復興新市街をもった帝都の昼間は、アスファルト路面が熱気を一ぱいに吸いこんでは、所々にブクブクと真黒な粘液を噴きだし、コンクリートの厚い壁体は燃えあがるかのように白熱し、隣りの通にも向いの横丁にも、暑さに脳髄を変にさせた犠牲者が発生したという騒ぎだった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月七日（水曜）　奥さんという人達と日本食　昼、加賀美さんの宅で図書館長、夫人、国際運輸の上田さんの傅家田、新市街（キタエスカヤ辺よりずっと品よく）ハルビンは（支那十二三万人、日本三千五百、ロシア数万の由）。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
