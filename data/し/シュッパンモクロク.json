        "examples": {
          "standard": [
            {
              "text": "出版目録を見れば、その出版社がこれまでにどのような本を出したか一目でわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "巻末にある出版目録から、次に読むべきシリーズの続刊を探した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古書店で手に入れた古い出版目録は、当時の文化を知る貴重な資料だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「せっかく書いたのに断裁はむごい」と喉まででかかったが、ある程度の部数がはけて算盤勘定に合わない本を、商業出版社が出版目録に入れておいてくれないことは当然だった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央公論の出版目録は直接そちらへ送るように書きました、そう云えば、岩波から『図書』の八月よこしましたろうか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
