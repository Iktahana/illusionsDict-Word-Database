    },
    "definitions": [
      {
        "index": 1,
        "gloss": "neighbourhood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "男　（四辺を見廻す様にして）はははは。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さう次の瞬間に脳膸が孤立したやうになつて感じられた時、同時に彼女は四辺をケロ、ケロツと見廻した。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間」という言葉によって、それが如何にも物珍しく、人跡全く絶えた山中であり、稀れに鳴く鶯のみが、四辺の静寂を破っていることを表象している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠いものは小さく、近いものは大きく、遠いものは橙や黄いろではっきりし、近いものは青白く少しかすんで、或ひは三角形、或ひは四辺形、あるひは電や鎖の形、さまざまにならんで、野原いっぱい光ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四辺の温和な山川の中に神代の巨人のごとく伝説の英雄のごとく立ちはだかっている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この光景の映写の間にこれと相錯綜して、それらの爆撃機自身に固定されたカメラから撮影された四辺の目まぐるしい光景が映出されるのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而るに今朝来、濃霧四辺を閉ざしシセキを弁じ難き趣きありしが、正午前、玄海洋上に望みし時忽ち右舷に当り大艦影を認む。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊の鬼さんがキョロキョロ四辺を見廻し乍らやって来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ四辺をキョロキョロ見廻し乍ら勝坊が現れた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（驚きて四辺を見廻す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（物思いに沈みて凝立すること暫くにして、忽然夢の覚めたるが如き気色をなし、四辺を見廻す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "四辺はひっそりとして物音無し。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐にためらいつつ部屋の内に進み、始終物を怖るる如く四辺を見廻す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠いものは小さく、近いものは大きく、遠いものは橙や黄いろではっきりし、近いものは青白く少しかすんで、或いは三角形、或いは四辺形、あるいは電や鎖の形、さまざまにならんで、野原いっぱい光っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "売薬は先へ下りたが立停ってしきりに四辺を※している様子、執念深く何か巧んだかと、快からず続いたが、さてよく見ると仔細があるわい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）といってきょろきょろと四辺を※す。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）といったが坐り直ってふと気がついたように四辺を※した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故か四辺が視められる。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが向う岸へ着いたと思うと、四辺また濛々、空の色が少し赤味を帯びて、殊に黒ずんだ水面に、五六人の気勢がする、囁くのが聞えた。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ひながら、四辺を見た。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠いものは小さく、近いものは大きく、遠いものは橙や黄いろではっきりし、近いものは青白く少しかすんで、あるいは三角形、あるいは四辺形、あるいは電や鎖の形、さまざまにならんで、野原いっぱいに光っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は更けて人の通行も稀になっていたから四辺は極めて静に僕の靴の音、二人の下駄の響ばかり物々しゅう反響していたが、先刻の母の言草が胸に応えているので僕も娘も無言、母も急に真面目くさって黙って歩るいていました。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては盗賊と半ば身体を起してきょろきょろと四辺を見廻したが、森としてその様子もない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "きよろ／＼四辺を見廻して居たが吻と酒気を吐き、舌打して再び内によろめき込んだ。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日自分は何時のように滑川の辺まで散歩して、さて砂山に登ると、思の外、北風が身に沁ので直ぐ麓に下て其処ら日あたりの可い所、身体を伸して楽に書の読めそうな所と四辺を見廻わしたが、思うようなところがないので、彼方此方と探し歩いた、すると一個所、面白い場所を発見けた。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四辺の家々より起こる叫び声、泣き声、遠かたに響く騒然たる物音、げにまれなる強震なり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "土人のおそろしい兇器のやうにいろいろな呪文がそこらいつぱいにかかつてしまつた景色はもうろうとして暗くなるしへんてこなる砂風がぐるぐるとうづをまいてる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはようすがすこしへんでした。",
              "citation": {
                "source": "草",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから貴下とお呼びする事にしたんだけど、「貴下」も、やっぱり少しへんね。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モルジアナは、この言いつけを聞いた時、少しへんだなと思いました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
