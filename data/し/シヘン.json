[
  {
    "uuid": "ce191bc9-40e9-5809-82a9-9d3a37ac11c6",
    "entry": "四辺",
    "reading": {
      "primary": "しへん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
